#!/bin/sh
# Medaka pre-commit hook — reject commits containing unformatted or lint-failing .mdk
# source, or a snapshot suite the author forgot to re-run.
#
# Checks 1–2 run over every staged .mdk (added/copied/modified); `test/` fixtures are
# deliberately excluded from BOTH — they are golden inputs kept intentionally unformatted
# and often violate style rules on purpose. Check 4 has a wider trigger (see below).
#
#   1. FORMAT: `medaka fmt --check` — aborts if any file differs from its formatted form.
#   2. LINT:   `medaka lint --only=<gated rules> --deny=<gated rules>` — aborts if any
#      file trips a GATED lint rule. MAX RATCHET: ALL rules are gated (the whole tree
#      is at 0 findings, so any NEW finding of any rule — style or correctness — fails
#      the commit). A genuine intentional exception can be silenced inline with an
#      ESLint-style directive comment, e.g. `-- lint-disable-next-line rule-lambda-section`
#      (also -line / -file forms). If a gated style rule proves too noisy in practice,
#      remove it from GATED_LINT_RULES below (it then still warns under plain `medaka lint`).
#   3. CROSS-FILE LINT: one project-wide scan (rule-duplicate-body can't be checked
#      per-staged-file).
#   4. SNAPSHOT: `make snapshot-check` — the per-stage snapshot suite, CHECK ONLY.
#   5. LEXTOK:   `test/diff_compiler_lex_files.sh` — OPPORTUNISTIC: only runs if
#      test/bin/lex_main already exists (this hook never builds an oracle). Scoped to
#      staged files (from check 1's set) that already have a sibling .lextok.golden.
#
# ── #491: this hook covers ONE of five golden families outright, plus one more
# OPPORTUNISTICALLY (check 5, only when test/bin/lex_main happens to already be
# built) — it never builds an oracle itself, and a fresh clone/worktree has none.
# The three remaining families (stdlib/<f>.test.golden, test/selfproc_goldens/**,
# test/native_cli_goldens/check/**) need a full oracle set + a heavier run and
# stay CI-only. `.test.golden` was tried here and REMOVED (see #536 review):
# `test/diff_compiler_test.sh` runs four fixture assertions (mixed.mdk, list.mdk,
# test_decls.mdk, hash_negative_hash.mdk) UNCONDITIONALLY regardless of the file
# arguments passed to it — so scoping this hook's call to only the staged file(s)
# does not stop it from also re-checking those four fixtures against whatever
# test_main oracle happens to be sitting in test/bin/, and two of those four
# (test_decls.mdk, hash_negative_hash.mdk) have NO .test.golden at all — their
# expected output is an inline string literal in the gate script — so a stale
# oracle can reject a commit that never touched them, with no working per-file
# remediation. That is the exact #459 disease ("a gate names a recipe that does
# nothing"), so this hook does not carry it. Silence here was historically
# misread as "goldens are complete", so the hook NAMES what it did and did not
# check on every run that reaches this point (see the final section) — that is
# the fix for `.test.golden` until `test/diff_compiler_test.sh` itself is scoped
# (tracked separately; not this hook's file to fix).
#
# ── check 4, and the one thing a hook must never be ──────────────────────────
# The hook's job here is "you did not forget to run the suite". It is NOT, and cannot be,
# the review gate for BLESSING a snapshot: the author runs the hook, and the bless button
# is right there. A hook that offered to re-cut the goldens it just found stale would be
# a rubber stamp with a progress bar. So it runs `--check` and stops; re-cutting is an
# explicit, named, human act:
#
#     sh test/diff_compiler_snapshot_frontend.sh --bless <the file you changed>
#
# and the actual review gate is `git diff` on test/snapshots/ — which is what a reviewer
# and every CI shard look at. (See compiler/tools/snapshot.mdk for the three locks on
# --bless: scoped, non-creating, and refuses diagnostic-bearing sections outright.)
#
# The trigger is WIDER than checks 1–3: the corpus contains the compiler's own 50 sources,
# all of stdlib, AND test/{parse,parse_only,diff}_fixtures — so a staged test/ fixture
# moves a snapshot too, and so does a pure `medaka fmt` reflow of a compiler source. The
# hook therefore fires on ANY staged .mdk (test/ included) or any staged
# test/snapshots/**.md.
#
# Install (from the repo root):
#     cp .githooks/pre-commit "$(git rev-parse --git-common-dir)/hooks/pre-commit"
#     chmod +x "$(git rev-parse --git-common-dir)/hooks/pre-commit"
#
# Binary lookup order: $MEDAKA, then <repo-root>/medaka, then `medaka` on PATH.
# If none is found: a commit with NOTHING relevant staged (no .mdk, no snapshot)
# is allowed silently — this hook has nothing to check either way. But a commit
# that DOES stage a .mdk (or a snapshot) is FAILED (#437) — a missing binary is
# the normal state of a fresh worktree, and silently allowing it here would mean
# exactly the commits that need fmt/lint most (an agent's first .mdk commit in a
# freshly-spawned worktree) get none. Emergency bypass either way: `git commit --no-verify`.
#
# Note: this checks the WORKING-TREE copy of each staged file (the normal
# full-staging case). Partially-staged files are checked as they exist on disk.
set -u

# Lint rules that BLOCK a commit. The whole tree is at 0 lint findings, so every
# rule is gated as a ratchet: any NEW warning fails the commit. Per-file rules are
# checked per staged file; the cross-file rule (rule-duplicate-body) needs a
# whole-project scan (it compares a body against OTHER files), so it's checked in
# one scan over all source roots at once (catches cross-root duplicates too).
# Intentional exceptions use inline directives (-- lint-disable-next-line / -file <rule>).
GATED_LINT_RULES="rule-match-on-param,rule-hand-rolled-derivable,rule-stdlib-reimpl,rule-bind-then-destructure,rule-lambda-section,rule-if-max-min,rule-andthen-pure-map,rule-destructure-in-param,rule-missing-signature,rule-not-eq,rule-bool-simplify,rule-rem-parity,rule-double-reverse,rule-when-unless,rule-complement-predicate,rule-match-to-map,rule-bind-chain-to-do,rule-dead-code,rule-concat-to-interp"
# Cross-file rules, checked project-wide (not per staged file).
GATED_CROSSFILE_RULES="rule-duplicate-body"
# Source roots scanned for the cross-file check (dirs that exist are used).
LINT_ROOTS="compiler stdlib sqlite"

ROOT="$(git rev-parse --show-toplevel)"

# Staged .mdk files, excluding test/ fixtures (checks 1–3).
files="$(git diff --cached --name-only --diff-filter=ACM -- '*.mdk' ':(exclude)test/**')"
# Anything that can move a snapshot (check 4): ANY staged .mdk — test/ fixtures included,
# they are in the corpus — plus the snapshots themselves.
snapfiles="$(git diff --cached --name-only --diff-filter=ACMD -- '*.mdk' 'test/snapshots/*.md')"
[ -z "$files" ] && [ -z "$snapfiles" ] && exit 0

# Union of both sets, deduped — everything this hook would check if a binary
# were available. Computed BEFORE the binary lookup below so the "no binary"
# branch can name exactly what it is failing to check (#437).
staged_mdk="$(printf '%s\n%s\n' "$files" "$snapfiles" | grep -v '^$' | sort -u)"

MEDAKA="${MEDAKA:-$ROOT/medaka}"
if [ ! -x "$MEDAKA" ]; then
  if command -v medaka >/dev/null 2>&1; then
    MEDAKA="$(command -v medaka)"
  else
    # #437: staged .mdk (or a snapshot) with no medaka binary reachable is a REAL
    # coverage gap, not a no-op commit — this hook is the ONLY fmt/lint enforcement
    # in the repo (CI does not check tree fmt/lint cleanliness). Unlike the "nothing
    # relevant staged" early-exit above, this does NOT silently allow the commit.
    echo "" >&2
    echo "✗ pre-commit: medaka binary not found — cannot check staged .mdk:" >&2
    for f in $staged_mdk; do echo "      $f" >&2; done
    echo "" >&2
    echo "  This hook is the ONLY fmt/lint enforcement in the repo (CI does not check" >&2
    echo "  tree fmt/lint cleanliness), so committing unchecked would ship silently." >&2
    echo "  Build it:      make -C $ROOT medaka" >&2
    echo "  Or point at one:  MEDAKA=/path/to/medaka git commit ...   (or add to PATH)" >&2
    echo "  Bypass once:   git commit --no-verify" >&2
    echo "" >&2
    exit 1
  fi
fi

# ── 1. formatter check ───────────────────────────────────────────────────────
bad=""
for f in $files; do
  [ -f "$f" ] || continue
  "$MEDAKA" fmt --check "$f" >/dev/null 2>&1 || bad="$bad $f"
done

if [ -n "$bad" ]; then
  echo "" >&2
  echo "✗ pre-commit: unformatted (or unparseable) .mdk staged for commit:" >&2
  for f in $bad; do echo "      $f" >&2; done
  echo "" >&2
  echo "  Format them:  medaka fmt --write$bad" >&2
  echo "  Re-stage:     git add$bad" >&2
  echo "  Bypass once:  git commit --no-verify" >&2
  echo "" >&2
  exit 1
fi

# ── 2. lint check (gated rules only) ──────────────────────────────────────────
badlint=""
for f in $files; do
  [ -f "$f" ] || continue
  "$MEDAKA" lint --only="$GATED_LINT_RULES" --deny="$GATED_LINT_RULES" "$f" >/dev/null 2>&1 || badlint="$badlint $f"
done

if [ -n "$badlint" ]; then
  echo "" >&2
  echo "✗ pre-commit: gated lint rule(s) violated in staged .mdk ($GATED_LINT_RULES):" >&2
  for f in $badlint; do echo "      $f" >&2; done
  echo "" >&2
  echo "  See findings:  medaka lint --only=$GATED_LINT_RULES$badlint" >&2
  echo "  If intentional, silence inline with a directive comment above the site:" >&2
  echo "                 -- lint-disable-next-line <rule>" >&2
  echo "  Bypass once:   git commit --no-verify" >&2
  echo "" >&2
  exit 1
fi

# ── 3. cross-file lint check (project-wide) ───────────────────────────────────
# rule-duplicate-body compares a body against OTHER files, so a per-staged-file
# check can't see the duplicate — scan the source roots as a whole. Runs only
# because a .mdk is staged (we returned early otherwise). Respects inline
# -- lint-disable-* directives (intentional dups are silenced in-source).
# One project-wide scan over all source roots at once, so cross-ROOT duplicates
# (a body shared between compiler/ and stdlib/, etc.) are caught too.
roots=""
[ -n "$files" ] && for r in $LINT_ROOTS; do [ -d "$ROOT/$r" ] && roots="$roots $ROOT/$r"; done
if [ -n "$roots" ]; then
  # shellcheck disable=SC2086
  if ! "$MEDAKA" lint --only="$GATED_CROSSFILE_RULES" --deny="$GATED_CROSSFILE_RULES" $roots >/dev/null 2>&1; then
    echo "" >&2
    echo "✗ pre-commit: cross-file lint rule(s) violated ($GATED_CROSSFILE_RULES):" >&2
    echo "" >&2
    # shellcheck disable=SC2086
    echo "  See findings:  medaka lint --only=$GATED_CROSSFILE_RULES$roots" >&2
    echo "  If intentional, silence with a directive in the offending file(s):" >&2
    echo "                 -- lint-disable-file rule-duplicate-body" >&2
    echo "  Bypass once:    git commit --no-verify" >&2
    echo "" >&2
    exit 1
  fi
fi

# ── 4. snapshot suite (CHECK only — this hook can never bless) ────────────────
# ~7s, no oracle binaries needed. Runs against the BUILT ./medaka, so if you have staged
# a compiler change you have not rebuilt, this checks the OLD compiler's behaviour — it
# still catches the common case it is here for (a fixture/source edit that moved a
# `# SOURCE` section), and `make medaka` before committing makes it exact.
if [ -n "$snapfiles" ]; then
  snapgate="$ROOT/test/diff_compiler_snapshot_frontend.sh"
  if [ -f "$snapgate" ]; then
    snapout="$(MEDAKA="$MEDAKA" sh "$snapgate" 2>&1)"; snapst=$?
    if [ "$snapst" -eq 2 ]; then
      echo "pre-commit: snapshot suite could not run (compiler not built) — skipping check 4." >&2
    elif [ "$snapst" -ne 0 ]; then
      echo "" >&2
      echo "✗ pre-commit: the snapshot suite is stale (make snapshot-check):" >&2
      echo "" >&2
      printf '%s\n' "$snapout" | grep -E ': (FAIL|ERROR)' | sed 's/^/    /' >&2
      echo "" >&2
      echo "  Re-cut ONLY the fixtures you changed, by name:" >&2
      echo "      sh test/diff_compiler_snapshot_frontend.sh --bless <file.mdk> ..." >&2
      echo "  then re-stage test/snapshots/ and READ the diff — that diff is the review gate." >&2
      echo "  (There is no whole-suite bless. A diagnostic-bearing section will refuse to" >&2
      echo "   bless at all: read the new message, then rm the .md and re-cut it with --new.)" >&2
      echo "" >&2
      echo "  Bypass once:  git commit --no-verify" >&2
      echo "" >&2
      exit 1
    fi
  fi
fi

# ── 5. lextok check (OPPORTUNISTIC — never builds the oracle) ────────────────
# Scoped to $files (check 1's set: staged .mdk, test/ excluded) that already have
# a sibling <f>.lextok.golden — i.e. files this family is actually meant to cover,
# not every staged .mdk (a file that never had a lextok golden captured, e.g. a
# newly-added stdlib module, would otherwise report a false "no golden" FAIL).
lex_relevant=""
for f in $files; do
  [ -f "$f" ] || continue
  [ -f "${f%.mdk}.lextok.golden" ] && lex_relevant="$lex_relevant $f"
done
lex_checked=0
if [ -n "$lex_relevant" ]; then
  if [ -x "$ROOT/test/bin/lex_main" ]; then
    lex_checked=1
    # shellcheck disable=SC2086
    lexout="$(sh "$ROOT/test/diff_compiler_lex_files.sh" $lex_relevant 2>&1)"; lexst=$?
    if [ "$lexst" -ne 0 ]; then
      echo "" >&2
      echo "✗ pre-commit: lextok golden(s) stale (self-lex token-stream snapshot):" >&2
      echo "" >&2
      printf '%s\n' "$lexout" | grep -E '^(FAIL|no golden)' | sed 's/^/    /' >&2
      echo "" >&2
      echo "  Recapture:" >&2
      # shellcheck disable=SC2086
      echo "      CAPTURE=1 sh test/diff_compiler_lex_files.sh$lex_relevant" >&2
      echo "  then re-stage the .lextok.golden file(s)." >&2
      echo "  Bypass once:  git commit --no-verify" >&2
      echo "" >&2
      exit 1
    fi
  else
    echo "pre-commit: could NOT check lextok goldens for:$lex_relevant (no test/bin/lex_main —" >&2
    echo "pre-commit:   FORCE=1 JOBS=1 sh test/build_oracles.sh --build-one lex_main to enable)." >&2
  fi
fi

# ── #491: NAME THE BLIND SPOT ─────────────────────────────────────────────────
# This hook's silence has repeatedly been read as "goldens are complete" — it
# never is. State plainly, every run that reaches here, what got checked and
# what did NOT, rather than letting the absence of a message imply coverage.
# `.test.golden` is ALWAYS in the not-checked list: see the header note above
# (#536) on why `test/diff_compiler_test.sh` cannot be scoped to staged files
# from the outside — running it here would risk rejecting a commit over an
# unrelated, stale fixture with no working per-file remediation.
checked="fmt, lint, snapshots"
notchecked=""
if [ "$lex_checked" = 1 ]; then checked="$checked, lextok"; else notchecked="$notchecked lextok"; fi
notchecked="$notchecked .test.golden selfproc-goldens native_cli-check-goldens"
echo "" >&2
echo "pre-commit: checked this run: $checked." >&2
echo "pre-commit: NOT checked this run:$notchecked —" >&2
echo "pre-commit:   if you touched stdlib/ or compiler/, run their gates before you push" >&2
echo "pre-commit:   (test/diff_compiler_lex_files.sh, test/diff_compiler_test.sh," >&2
echo "pre-commit:    test/diff_compiler_selfproc.sh, test/diff_native_cli.sh). This hook's" >&2
echo "pre-commit:   silence is not evidence those goldens are still current. (#491)" >&2

exit 0
