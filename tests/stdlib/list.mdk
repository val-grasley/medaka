pub map f xs =
  match xs
    [] => []
    h::t => (f h) :: (map f t)

pub filter pred xs =
  match xs
    [] => []
    h::t => if pred h then h :: (filter pred t) else filter pred t

pub foldl f acc xs =
  match xs
    [] => acc
    h::t => foldl f (f acc h) t

pub length xs =
  match xs
    [] => 0
    _::t => 1 + length t
