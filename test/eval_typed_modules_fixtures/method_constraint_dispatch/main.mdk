-- Regression for the eval-path method-constraint dict-threading SOUNDNESS bug
-- (compiler/types/typecheck.mdk inferImplMethod / registerImplMethodDicts):
-- a dispatched interface method whose OWN signature carries a method-level `=>`
-- constraint (`Thenable m`) and whose body returns a constraint-var method
-- (`pure []`) PANICKED in native `run` (`no matching impl for dispatch`) while
-- native `build` was correct.  The impl method gets a leading method-dict param
-- ($dict_wrap_0); the inner `pure []` must route RDictFwd to it so eval narrows it
-- by the dict supplied at the call site instead of falling to arg-tag dispatch.
--
-- Drives the LOADER / elaborateModules + eval_modules path (exactly what `medaka
-- run` uses), where this class of bug is historically masked relative to the flat
-- single-file path.  GOLDEN IS NATIVE-SOURCED (native>oracle): the frozen OCaml
-- oracle mis-evaluates this shape (returns `[[1, 2, 3]]`); the .eval.golden is
-- captured from native `medaka run` == native `medaka build`+exec.
--
-- NOTE: the interface/impl are defined IN this entry module on purpose.  The
-- cross-module variant (interface/impl imported from a sibling) is now COVERED
-- by the sibling fixtures `cross_module_method_userconstraint/` (direct sibling
-- import) and `cross_module_method_userconstraint_diamond/` (re-export via an
-- intermediate module using `export import`).  Fixed at `221af36` (dict-id
-- alignment — `alignedMethodConstraintIds` read-side fix in `recordMethodDicts`)
-- + `a35c87b` (export-import re-export seed — `reexportSeed` helper threads
-- `DUse True` schemes into the typecheck depEnv at all four driver loops).
interface Box t where
  wrap : Thenable m => (a -> m b) -> t a -> m (List b)

impl Box List where
  wrap f xs = match xs
    []        => pure []
    (x::rest) => andThen (f x) (y => andThen (wrap f rest) (ys => pure (y :: ys)))

check : Int -> Result String Int
check x = if x > 0 then Ok x else Err "neg"

main =
  println (debug (wrap (x => if x > 0 then Some x else None) [1, 2, 3]))
  println (debug (wrap (x => if x > 0 then Some x else None) [1, -2, 3]))
  println (debug (wrap check [1, 2, 3]))
