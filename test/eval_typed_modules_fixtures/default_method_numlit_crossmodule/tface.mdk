import sdisp.{S(..), s}

-- `t`'s default body consumes an ambiguous Num literal body-locally: the
-- element var of `[1, 2]` surfaces NOWHERE in `t`'s declared type (`a -> Int`),
-- so nothing outside the body can determine it. Whether that var gets grounded
-- to Int depends on WHICH path checks this default body — see main.mdk.
export interface T a where
  t : a -> Int
  t _ = s [1, 2]
