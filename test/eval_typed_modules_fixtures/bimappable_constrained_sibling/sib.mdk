-- A function constrained on the new core `Bimappable` class, used through the
-- loader from a sibling module — exercises return-position dispatch of the
-- class's `bimap`/`mapFirst`/`mapSecond` across a module boundary.
export bumpBoth : Bimappable p => p Int Int -> p Int Int
bumpBoth pv = bimap (x => x + 1) (y => y * 10) pv

export bumpLeft : Bimappable p => p Int Int -> p Int Int
bumpLeft pv = mapFirst (x => x + 100) pv

export bumpRight : Bimappable p => p Int Int -> p Int Int
bumpRight pv = mapSecond (y => y * 1000) pv
