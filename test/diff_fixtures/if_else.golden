=== AST ===
classify n = if n < 0 then "negative" else if n > 0 then "positive" else "zero"
abs n = if n < 0 then 0 - n else n
main : <IO> Unit
main =
  println (classify (-5))
  println (classify 0)
  println (classify 3)
  println (abs (-7))
