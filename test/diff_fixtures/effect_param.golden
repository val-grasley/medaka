=== AST ===
effect Net Prefix
internal effect Mut
effect Stdout
extern netGet : String -> <Net "a.com/foo"> String
fetch : String -> <Net "a.com/foo"> String
fetch path = netGet path
main : <IO> Unit
main = println "effect param ok"
