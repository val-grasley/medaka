mapSecond : (a -> b) -> c d a -> c d b
fold : (a -> b -> a) -> a -> c b -> a
foldRight : (a -> b -> b) -> b -> c a -> b
foldMap : (a -> b) -> c a -> b
toList : a b -> List b
isEmpty : a b -> Bool
