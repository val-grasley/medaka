=== AST ===
double x = x * 2
isEven x = x % 2 == 0
sumList xs = fold (acc x => acc + x) 0 xs
main : <IO> Unit
main =
  println (map double [1, 2, 3, 4, 5])
  println (filter isEven [1, 2, 3, 4, 5, 6])
  println (sumList (map double [1, 2, 3]))
