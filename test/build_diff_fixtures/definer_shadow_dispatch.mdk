-- P0-18: a standalone fn that shadows an interface method name (a "definer shadow").
-- On the BUILD (native emit) path `size (Box 3)` must DISPATCH to the `Sizeable Box`
-- impl (→ 3) because `Box` HAS an impl, while `size 3` must fall back to the standalone
-- (→ 4) because `Int` has none.  Before the fix the mangler renamed the standalone +
-- its call sites to `<mid>__size` before marking, so the mark pass never saw the shadow
-- and emitted a direct call to the standalone for BOTH — `size (Box 3)` built to garbage.
interface Sizeable a where
  size : a -> Int

data Box = Box Int

impl Sizeable Box where
  size (Box n) = n

size : Int -> Int
size n = n + 1

main =
  println (size (Box 3))
  println (size 3)
