-- Regression: an instance-level `requires` on a sibling impl at the same head
-- tycon whose requires targets a NON-functor param (Applicative's `Semigroup e`)
-- must not corrupt the element-dict routing of the type's Debug impl.  Before the
-- fix the RKey for `Debug (VT ...)` picked the first VT `requires` impl by head
-- tag alone (Applicative), producing empty/wrong routes -> SIGSEGV on build.
data VT e a = VF e | VS a

export
impl Mappable (VT e) where
  map f (VS a) = VS (f a)
  map _ (VF e) = VF e

export
impl Applicative (VT e) requires Semigroup e where
  pure a = VS a
  ap (VF e1) (VF e2) = VF (e1 ++ e2)
  ap (VF e) _ = VF e
  ap (VS f) v = map f v

export
impl Debug (VT e a) requires Debug e, Debug a where
  debug (VF e) = "VF " ++ debug e
  debug (VS a) = "VS " ++ debug a

mydbg : Debug a => a -> <IO> Unit
mydbg x = putStrLn (debug x)

sv : VT (List String) Int
sv = VS 7

acc : VT (List String) Int
acc = ap (VF ["e1"]) (VF ["e2"])

main =
  mydbg sv
  mydbg acc
