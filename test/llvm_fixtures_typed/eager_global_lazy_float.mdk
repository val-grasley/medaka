-- #561 PR-A regression lock — a LAZY global of NON-Int type (Float) in ARITHMETIC.
--
-- `cell = mkF 0` is dispatch-reaching, so #561 PR-A emits it LAZILY; the LAZY read
-- returns a PLACEHOLDER LTy `LTInt` (llvm_emit.mdk lookupVarG). This fixture proves that
-- is HARMLESS for a Float used in arithmetic: `cell + 1.0` selects float-add from the
-- CBinPrim's typecheck-stamped scalar tag (scalarTagIsFloat), NOT from the lazy read's
-- returned LTy. eval==native==`3.5`. If a future consumer keyed off the lazy read's LTy,
-- this fails (it would emit integer add and print garbage).

interface MkF a where
  mkF : a -> Float

impl MkF Int where
  mkF _ = base

cell = mkF 0

base = 2.5

main = cell + 1.0
