-- TYPECHECK-AUDIT S2: a method with its OWN method-level constraint
-- (`build : Num e => e -> t`) implemented by an explicit impl. The method-level
-- dict param (`$dict_build_0`, from `Num e`) must lead the impl clause's params;
-- dropping it (the old DImpl `match reqs []=>d` early-out) mis-bound the dict into
-- the first VALUE parameter `n`, so `n + n` panicked `unknown op '+'`. After the
-- k-offset fix (dictParams n k prepended in implDictPassMethods), compiler prints
-- `6` matching the oracle.
-- W3 (#816): the original body `MkBox (n + n)` PINNED the method var `e := Int`
-- (a caller may instantiate `Num e` at Float and get a garbage Box) and is now
-- rejected; `n + n` still evaluates — the dict-offset purpose this fixture pins
-- (a mis-bound dict panics 'unknown op +') is intact — but its result no longer
-- flows into the Int field, so `e` stays the caller's.
interface Builder t where
  build : Num e => e -> t

data Box = MkBox Int

impl Builder Box where
  build n =
    let _ = n + n
    MkBox 6

unbox : Box -> Int
unbox (MkBox x) = x

main = putStrLn (intToString (unbox (build 3 : Box)))
