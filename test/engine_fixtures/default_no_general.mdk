-- #728-2 companion: NO general instance present.  A concrete impl omits `gx` (which
-- has a default) -> the default (77) is used, exactly as before the fix.  Proves the
-- reorder leaves the no-general path unchanged.
--   fx 5 -> 3 (concrete) ; gx 5 / useGx 5 -> 77 (default; concrete omits gx)
interface Solox a where
  fx : a -> Int
  gx : a -> Int
  gx _ = 77
impl Solox Int where
  fx _ = 3
useGx : Solox a => a -> Int
useGx x = gx x
main = println "\{fx (5 : Int)} \{gx (5 : Int)} \{useGx (5 : Int)}"
