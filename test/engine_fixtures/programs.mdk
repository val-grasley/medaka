-- small end-to-end programs exercising prelude dispatch (Ord/Eq/Debug) +
-- recursion + ADTs through core.mdk
-- Reshaped for the engines corpus (#711, following #707): 6-tuple exceeds the
-- <=5 tuple-Display arity, nested into two <=5 sub-tuples. Same values,
-- autoprints identically across engines.
-- `qs`/`lessThan`/`atLeast` are mutually recursive with no signature, so the typed
-- backends monomorphize them to the FIRST call site's type and reject the second
-- (`qs` is used below at both `List Int` and `List String`) with "Ambiguous
-- instance for Ord" -- eval has no such restriction. Explicit `Ord a =>` signatures
-- force generalization so all three engines agree at both call sites.
qs : Ord a => List a -> List a
qs [] = []
qs (p :: rest) = qs (lessThan p rest) ++ [p] ++ qs (atLeast p rest)
lessThan : Ord a => a -> List a -> List a
lessThan _ [] = []
lessThan p (x :: xs) = if x < p then x :: lessThan p xs else lessThan p xs
atLeast : Ord a => a -> List a -> List a
atLeast _ [] = []
atLeast p (x :: xs) = if x >= p then x :: atLeast p xs else atLeast p xs

data Exp = Lit Int | Add Exp Exp | Mul Exp Exp deriving (Debug, Eq)
ev (Lit n) = n
ev (Add a b) = ev a + ev b
ev (Mul a b) = ev a * ev b

prog = Add (Lit 2) (Mul (Lit 3) (Lit 4))
main =
  ( (qs [3, 1, 4, 1, 5, 9, 2, 6], qs ["pear", "apple", "fig", "date"], ev prog, debug prog, prog == prog)
  , prog == Lit 0
  )
