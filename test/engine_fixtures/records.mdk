-- record create / field access / update / pattern match
-- `deriving (Display)` added for the engines corpus (#707): `main` returns `Point`/`Box`
-- values the auto-print contract Displays (the eval_fixtures twin uses pp_value instead).
data Point = { x : Int, y : Int } deriving (Display)
data Box = { label : String, pt : Point } deriving (Display)
distSq p = p.x * p.x + p.y * p.y
moveRight p = { p | x = p.x + 1 }
swap p = match p
  Point { x, y } => Point { x = y, y = x }
labelOf b = b.label
main =
  let p = Point { x = 3, y = 4 }
  let q = moveRight p
  let b = Box { label = "origin", pt = Point { x = 0, y = 0 } }
  -- 7-tuple exceeds the ≤5 tuple-Display arity → nested into two ≤5 sub-tuples.
  ( (p, distSq p, q, distSq q)
  , (swap p, labelOf b, b.pt.y)
  )
