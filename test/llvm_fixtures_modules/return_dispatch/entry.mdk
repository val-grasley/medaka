-- Cross-module RETURN-POSITION dispatch.  `Flag` is imported from flag.mdk; the
-- `Default` interface + its Int/Flag impls live HERE, but the `Default Flag` impl
-- dispatches on an IMPORTED type.  `def`'s type param appears only in the result,
-- so each use resolves by the ANNOTATED result type (RKey), not a discriminating
-- arg: `baseInt : Int = def` → the Int impl; `baseFlag : Flag = def` → the Flag
-- impl (over the imported type) — a direct call to the lifted impl, no runtime tag
-- test, the dispatch decided by the result type across the module boundary.
-- Return-position dispatch is slice 6 — already emittable.
--
-- NOTE: exported interface METHODS do not yet resolve cross-module through the
-- compiler typed pipeline, so the interface/impls stay in the entry; the DATA TYPE
-- is what crosses.  The nested `match` is lifted to a top-level binding (`flagVal`)
-- because `match` in argument position (e.g. `f (match x …)`) is ALSO rejected by
-- the OCaml reference parser — the lexer suppresses INDENT/DEDENT inside `(…)`, so
-- the `MATCH expr_or INDENT arms DEDENT` rule can never fire.  Not a compiler gap.
import flag.{Flag(..)}

interface Default a where
  def : a

impl Default Int where
  def = 7

impl Default Flag where
  def = On

baseInt : Int
baseInt = def

baseFlag : Flag
baseFlag = def

flagVal : Int
flagVal = match baseFlag
  Off => 0
  On => baseInt

main = putStrLn (intToString flagVal)
