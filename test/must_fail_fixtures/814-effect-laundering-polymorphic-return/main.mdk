interface Mk a where
  mk : a -> b                          -- polymorphic return (type var b)
data Dog = Dog
impl Mk Dog where
  mk d = u =>
    let _ = putStr "[minimal] "        -- intrinsic <Stdout> on b's instantiated function arrow
    "woof"
pureUse : Mk a => a -> (Unit -> String)   -- caller fixes b := pure Unit -> String
pureUse x = mk x
main = putStrLn ((pureUse Dog) ())
