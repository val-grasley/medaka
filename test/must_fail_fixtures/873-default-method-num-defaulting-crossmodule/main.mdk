import tface.{T(..), t}

-- impl T Foo is in a DIFFERENT module from interface T, so fillImplDefaults does
-- NOT specialize the default here: the generic default (default path) runs.
-- Ungrounded element var => receiver seen as `List _a` => the GENERAL
-- `impl S (List a)` is selected => 999, when the correct answer is 1.
data Foo = Foo

impl T Foo where

main = println (t Foo)
