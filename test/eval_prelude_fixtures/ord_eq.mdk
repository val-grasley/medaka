-- Eq / Ord dispatch through the prelude on builtin + derived types
data Suit = Clubs | Diamonds | Hearts | Spades deriving (Eq, Ord, Debug)
main =
  ( compare 3 5
  , compare "abd" "abc"
  , max 3 7
  , min 'a' 'z'
  , compare Hearts Spades
  , max Clubs Diamonds
  , Hearts == Hearts
  , Clubs == Spades
  , debug (compare Spades Clubs)
  , [Clubs, Diamonds] == [Clubs, Diamonds]
  )
