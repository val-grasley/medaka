-- #803 (S0, silent wrongness): an impl method performing an INTRINSIC effect (not
-- sourced from any argument) under an interface method whose effect var `<e>` IS
-- argument-carried (so #784 Option A correctly ACCEPTS the interface). The impl's
-- own <Stdout> (`putStr`, the callback `cb` is never invoked) is absorbed into the
-- open `<e>` at impl-check, then `pureUse` instantiates e := <> and is certified
-- PURE — yet `run` performs <Stdout>, laundering IO into a pure-typed function.
-- The impl-body effect-launder residual check (T-EFFECT-LAUNDER) now rejects it:
-- a declared effect var may hold no concrete atom the signature does not declare.
-- check == run == build all REJECT via a DIAGNOSTIC, never a runtime panic.
interface Speak a where
  speak : a -> (Unit -> <e> Unit) -> <e> String

data Dog = Dog

impl Speak Dog where
  speak d cb =
    let _ = putStr "[cb] "
    "woof"

pureUse : Speak a => a -> (Unit -> Unit) -> String
pureUse x cb = speak x cb

main = putStrLn (pureUse Dog (u => u))
