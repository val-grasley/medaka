-- #781 (S0): follow-up to #777/#780, which fixed the GROUND impl-body case.  A
-- genuine non-literal type mismatch inside a PARAMETRIC impl-method body was still
-- unenforced end-to-end — check + build both exited 0 and the binary printed the
-- String value "str" at exit 0 (an Int->Int helper "returned" a String, satisfying
-- the declared String return BY ACCIDENT).  #780 only body-inferred GROUND impl
-- heads (implHeadGround), so `impl Sig (List a)` was never checked.  All three
-- engines must now REJECT it via a DIAGNOSTIC (inferUserImplBodies now infers
-- parametric heads too, keeping the unify mismatch).  This drained #781.
idInt : Int -> Int
idInt x = x

interface Sig a where
  sig : a -> String

impl Sig (List a) where
  sig _ = idInt "str"

main = println (sig ([1] : List Int))
