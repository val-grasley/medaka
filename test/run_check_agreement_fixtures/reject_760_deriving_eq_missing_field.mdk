-- #760 (S1): `deriving (Eq)` over a field whose type lacks an Eq instance.
-- The derived `eq` body calls `eq` on the Inner field, so the obligation
-- `Eq Inner` is present but was NOT surfaced at typecheck for the derived
-- instance: `check` accepted, `run` printed True/False via a structural
-- fallback, and `build` panicked "no impl of method 'eq' for type 'Inner'".
-- Now `check`/`run`/`build` all reject with the same "No impl of Eq for Inner"
-- diagnostic a direct `Inner 1 == Inner 1` already emits.
data Inner = Inner Int
data Outer = Outer Inner deriving (Eq)
main =
  println (Outer (Inner 1) == Outer (Inner 1))
  println (Outer (Inner 1) == Outer (Inner 2))
