-- #760 (S1): `deriving (Debug)` over a field whose type lacks a Debug instance.
-- The derived `debug` body calls `debug` on the Inner field, so the obligation
-- `Debug Inner` is present but was NOT surfaced at typecheck for the derived
-- instance: `check` accepted, `run` panicked with a MISLEADING "intToString: not
-- an Int", and `build` panicked "no impl of method 'debug' for type 'Inner'".
-- Now `check`/`run`/`build` all reject with "No impl of Debug for Inner".
-- (The scrutinee is bound with `let` so the derived obligation grounds
-- independently of the caller's dispatch — an inline `debug (Outer (Inner 7))`
-- with a bare Num literal trips a separate pre-existing receiver-grounding path.)
data Inner = Inner Int
data Outer = Outer Inner deriving (Debug)
main =
  let o = Outer (Inner 7)
  println (debug o)
