-- S-1, REJECT direction: the standalone's own constraints were never recorded as CALL
-- obligations, so `size "hi"` (=> `Num String`, which has no impl) was silently
-- ACCEPTED by `check`.  Root cause: for a SIGNATURED binding, schemeObligationsRef's
-- ids (from generalization) and funConstraintsRef's ids (from the signature) are
-- DIFFERENT ID SPACES, so the obligation lookup silently found nothing.  Must REJECT
-- with a located `No impl of Num for String`.
data Box = Box Int

interface Sz a where
  size : a -> String

impl Sz Box where
  size _ = "IMPL"

size : Num a => a -> a
size x = x + 1

main = println (size "hi")
