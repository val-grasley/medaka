-- TRMC stack-safety: a MULTI-CLAUSE cons-tail builder (`myMap`, head = f x)
-- builds a deep list in O(1) stack via the decision-tree TRMC path, then a
-- musttail length consumes it.  `myMap` is unconstrained (no dict even on the
-- shipping path); `upto` is unannotated ⇒ dict-carrying there — both pinned.
-- EXPECT-TMC: myMap upto
myMap f [] = []
myMap f (x::xs) = f x :: myMap f xs

upto m n
  | m > n = []
  | otherwise = m :: upto (m + 1) n

isNil xs = match xs
  [] => True
  _ => False

tl xs = match xs
  (_::ys) => ys
  [] => []

lenAcc acc xs
  | isNil xs = acc
  | otherwise = lenAcc (acc + 1) (tl xs)

main = lenAcc 0 (myMap (x => x + 1) (upto 1 2000000))
