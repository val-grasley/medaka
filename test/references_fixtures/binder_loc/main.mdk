-- #913 Inc 2 regression fixture — every param/local binder must record its DEF
-- at its OWN name-token Loc, NOT the enclosing declaration's name Loc.
--
-- Read the golden (test/references_fixtures/binder_loc/expected.golden) as the
-- assertion: a `local` binder's DEF column must be the binder token's own column,
-- distinct from the enclosing `val` decl's DEF (always column 0). A regression
-- that reverts to recording at the enclosing decl loc collapses the two DEF sites
-- back together and MOVES this golden.

-- S0-1: the fn param `p` must NOT record at `incByOne`'s name Loc. Before the
-- fix, `binder_loc|local|p|N` sat at `incByOne`'s DEF (`:<line>:0`), so a click on
-- the function name resolved to the param. After: `p` sits at its own token col.
export incByOne : Int -> Int
incByOne p = p + 1

export callIncByOne : Int
callIncByOne = incByOne 5

-- S0-2: the `let tmp` local must record at the `let tmp` binder token, NOT at
-- `shadowLet`'s name Loc. Before the fix `tmp`'s DEF was `shadowLet`'s own line:0
-- (so its uses' declaration resolved to the enclosing binding name).
export shadowLet : Int
shadowLet =
  let tmp = 99
  tmp + tmp

-- S0-3 (#913 Inc 2b): the prop param `ys` must record its DEF at its OWN name
-- token, NOT the prop's decl Loc (which is the prop NAME string). Before Inc 2b
-- the DProp param was recorded at the whole prop's loc, so a rename of `ys`
-- overwrote the prop's name string. The `ys` DEF col must be the param token col.
prop "ys length is nonneg" (ys : List Int) = length ys >= 0

-- S0-4 (#913 Inc 2b): a PUNNED record field `{ radius }` binds `radius`; its DEF
-- must be the FIELD-NAME token, NOT the enclosing `match` Loc. Before Inc 2b the
-- pun recorded at the match loc, so a rename of `radius` edited (deleted) the
-- whole match expression. The `local radius` DEF must sit at the pun's own token.
data Circ = MkCirc { radius : Int }

export circArea : Circ -> Int
circArea c = match c
  MkCirc { radius } => radius * radius
