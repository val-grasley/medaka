-- codepoint string indexing/slicing, int + char range patterns, backtick infix
sub x y = x - y
classify n = match n
  0..9 => "low"
  10..99 => "mid"
  _ => "high"
kind c = match c
  'a'..'z' => "lower"
  'A'..'Z' => "upper"
  '0'..'9' => "digit"
  _ => "sym"
main =
  ( "hello".[0]
  , "hello".[1..3]
  , "hello".[1..=3]
  , "héllo".[1]
  , classify 3
  , classify 42
  , classify 500
  , kind 'q'
  , kind 'K'
  , kind '7'
  , kind '!'
  , sub 100 (sub 20 5)
  )
