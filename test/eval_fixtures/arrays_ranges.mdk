-- array literals, indexing, ranges (list + array), slices
arr = [|10, 20, 30, 40, 50|]
xs = [1..5]
ys = [0..=4]
zs = [|2..6|]
sumList [] = 0
sumList (x :: xs) = x + sumList xs
main =
  let a3 = arrayGetUnsafe 3 arr
  let mid = arr.[1..3]
  let lst = xs.[1..=3]
  (a3, mid, xs, ys, zs, lst, sumList xs, arrayGetUnsafe 0 arr + arrayGetUnsafe 4 arr)
