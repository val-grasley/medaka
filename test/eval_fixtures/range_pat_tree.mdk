-- range patterns through the decision tree (PRng arms with fall-through)
classify n = match n
  0..=4 => "tiny"
  5..=9 => "small"
  _ => "big"

hexDigit c = match c
  '0'..'9' => "num"
  'a'..'f' => "lo"
  'A'..'F' => "hi"
  _ => "no"

main =
  ( classify 0
  , classify 4
  , classify 5
  , classify 9
  , classify 10
  , hexDigit '3'
  , hexDigit 'b'
  , hexDigit 'E'
  , hexDigit 'z'
  )
