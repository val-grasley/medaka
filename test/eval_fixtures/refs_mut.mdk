-- explicit Refs (Ref / setRef / .value) + pure recursive accumulation
countUp n =
  let r = Ref 0
  let _ = bump r n
  r.value
bump r 0 = r.value
bump r k =
  let _ = setRef r (r.value + 1)
  bump r (k - 1)
sumTo n = loop 0 1 n
loop acc i n
  | i > n = acc
  | otherwise = loop (acc + i) (i + 1) n
main =
  let r = Ref 41
  let _ = setRef r (r.value + 1)
  (r.value, r, countUp 5, sumTo 10)
