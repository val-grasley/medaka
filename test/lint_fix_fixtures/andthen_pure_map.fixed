-- Fixture for rule-andthen-pure-map autofix (`andThen m (x => pure body)` → `map`).

-- POSITIVE (eta): `f x` eta-reduces to `map f m`.
etaCtor m = map Some m
etaFn m f = map f m
etaPartial m y = map (pair y) m

-- POSITIVE (general): keeps the lambda — `map (x => body) m`.
genNonFinal m = map (x => foo x bar) m

-- POSITIVE (nested): the bind can sit anywhere in a decl body.
nested m = wrap (map Some m)

-- NEGATIVE: continuation body is not `pure …` — must stay untouched.
negNoPure m = andThen m (x => somethingElse x)

-- NEGATIVE: lambda param used TWICE in the pure argument — must stay untouched.
negTwice m = andThen m (x => pure (combine x x))

-- NEGATIVE: over-applied `pure` — must stay untouched.
negOverApplied m = andThen m (x => pure step x)

-- NEGATIVE: multi-param continuation lambda — must stay untouched.
negMultiParam m = andThen m (x y => pure (g x y))
