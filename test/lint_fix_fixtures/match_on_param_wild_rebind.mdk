-- Fixable: a wildcard arm whose body references the scrutinee `batches` is
-- rewritten with the param name (re-binding the scrutinee), not `_` (STYLE §8).
pageCountOf : List Int -> Int
pageCountOf batches = match batches
  [_] => 1
  _ => 1 + length batches

main = println (pageCountOf [1, 2, 3])
