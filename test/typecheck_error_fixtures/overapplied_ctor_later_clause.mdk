-- Regression: an over-applied nullary constructor in a LATER clause (here the
-- second function's first clause, `classify (TUpper _)`) must report its error at
-- ITS OWN clause line — not at an innocent, well-typed clause of an earlier
-- function.  Patterns carry no source Loc, so the pattern-arity error was being
-- recorded at the STALE currentLoc left by the previous function's body inference,
-- mis-blaming the `nextMode _ m = m` clause below.
data Tok = TUpper | TIndent Int
data Mode = MVariant | MPayload

nextMode : Tok -> Mode -> Mode
nextMode (TIndent _) MVariant = MPayload
nextMode _ m = m

classify : Tok -> Mode
classify (TUpper _) = MVariant
classify _ = MPayload
