-- #818 (#838 I3) regression net: a method-level `=>` constraint on an interface
-- method (`peer : Ord b => …`) must be recorded as an OBLIGATION at the call site,
-- so instantiating `b` to a type with NO impl (`NoOrd`) is rejected at check time.
-- Was: check-green, wrong answer at run, crash/segfault at build.  Re-opening #818
-- (dropping the method-level obligation) flips this back to a schemes-dump accept.
interface M a where
  peer : Ord b => a -> b -> b -> Bool

data Dog = Dog

impl M Dog where
  peer d x y = x < y

data NoOrd = NoOrd

main = println (peer Dog NoOrd NoOrd)
