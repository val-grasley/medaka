-- WS-3b/filerw-hole-flip FILEWRITE hole-fill on the REAL stdlib builtin
-- `writeFile` ⊄ REJECT.  α fills <FileWrite "/var/log/app.log"> from the
-- literal path; the declared bound <FileWrite "/tmp/*"> does not cover
-- "/var/log/app.log" (different prefix) ⇒ REJECT
-- (performs <FileWrite "/var/log/app.log">).
writeLog : Unit -> <FileWrite "/tmp/*"> Result String Unit
writeLog _ = writeFile "/var/log/app.log" "x"

main : <IO> Unit
main = println "should not typecheck"
