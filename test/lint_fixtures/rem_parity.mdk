-- Fixture for rule-rem-parity: `n % 2 == 0` → isEven, `n % 2 != 0` → isOdd.

-- POSITIVE: the two parity comparisons (either operand order).
evenTest n = n % 2 == 0
oddTest n = n % 2 != 0
evenFlipped n = 0 == n % 2

-- POSITIVE: nested in a body.
nested n = if n % 2 == 0 then n else n + 1

-- NEGATIVE: `% 2 == 1` is WRONG for negative odd n (`%` follows the dividend).
negOne n = n % 2 == 1

-- NEGATIVE: not modulo-2.
negThree n = n % 3 == 0

-- NEGATIVE: the `isEven`/`isOdd` definitions THEMSELVES must not self-rewrite.
isEven n = n % 2 == 0
isOdd n = n % 2 != 0
