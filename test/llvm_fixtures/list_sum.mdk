-- slice 5b: built-in list match heads.  A `data … = Cons … | Nil` ADT whose
-- constructors are named Cons/Nil — so the decision-tree lowering (decodeHead)
-- maps the match arms to the built-in HCons/HNil switch heads (not HCon).  The
-- emitter must treat those as constructor tests against hashName "Cons"/"Nil"
-- (arities 2/0), the same tags Cons/Nil construction stamps.  Exercises nested
-- cons allocation and a recursive fold to a scalar Int.
data IntList = Cons Int IntList | Nil

sum lst = match lst
  Cons x xs => x + sum xs
  Nil => 0

main = sum (Cons 1 (Cons 2 (Cons 3 (Cons 4 Nil))))
