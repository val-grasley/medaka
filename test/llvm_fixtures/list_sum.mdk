-- slice 5b: user-constructor list match heads.  A `data … = Cons … | Nil` ADT
-- whose constructors are named Cons/Nil.  Since the decodeHead reserved-name fix
-- these lower to `HCon "Cons"`/`HCon "Nil"` (NOT the built-in HCons/HNil, which
-- now key off reserved synthetic names).  conHeadInfo maps both forms to the
-- SAME (name, arity) — hashName "Cons"/"Nil", arities 2/0 — the same tags Cons/Nil
-- construction stamps, so construct/match agree and the LLVM gate is unchanged.
-- Exercises nested cons allocation and a recursive fold to a scalar Int.
data IntList = Cons Int IntList | Nil

sum lst = match lst
  Cons x xs => x + sum xs
  Nil => 0

main = sum (Cons 1 (Cons 2 (Cons 3 (Cons 4 Nil))))
