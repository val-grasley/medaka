-- roles.mdk — semantic-token role fixture.  Exercises the distinct roles the
-- context classifier separates (and the v1 lexer-only version conflated):
--   Color  → type/`class`     (legend 1)
--   Red    → constructor/`macro` (legend 2)
--   Show   → typeclass/`selfParameter` (legend 7)  — interface, distinct from types
data Color = Red

interface Show a where
  show : a -> Color

paint : Color -> Color
paint c = Red
