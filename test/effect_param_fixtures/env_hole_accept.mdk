-- WS-3b ENV hole-fill ⊆ ACCEPT.  `getEnv : String -> <Env _> …` carries the
-- universal inferred-hole `_`; the call-site α recovers the literal first arg
-- "HOME" and the DOMAIN-DIRECTED fill builds the singleton authority set
-- <Env {"HOME"}> (Set domain, not a Prefix pattern).  Declared bound is the
-- SUPERSET {"HOME","PATH"} ⇒ {"HOME"} ⊆ {"HOME","PATH"} ⇒ ACCEPT.
effect Env Set

extern getEnv : String -> <Env _> Option String

readHome : Unit -> <Env {"HOME", "PATH"}> Option String
readHome _ = getEnv "HOME"

main : <IO> Unit
main = println "env hole-fill accept"
