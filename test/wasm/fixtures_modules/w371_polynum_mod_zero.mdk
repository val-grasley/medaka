-- #371: the poly-`Num` int `%` arm ($mdk_value_mod, wasm_preamble.mdk) must produce
-- the SAME coded [E-MOD-ZERO] stderr line native does, not a raw engine trap
-- ("remainder by zero"). Peer of w371_polynum_div_zero.mdk — see its header for the
-- poly-vs-concrete routing note. Since #531, diff_wasm_modules.sh compares stderr
-- and exit code generically for every fixture, so this no longer needs a bespoke
-- per-fixture assert (as div_zero's header explains).
modP a b = a % b

main =
  println "before"
  println (modP 7 0)
