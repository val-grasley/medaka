-- SHADOW-SEMANTICS cell D15: the d13 arity-differ value-position shape with the
-- interface having ZERO impls — proving shadow-hood + arity mismatch + value
-- position suffices, and that the impl universe is irrelevant to #410 (the
-- S2 INVERSION means a definer shadow never consults it).
-- Annotated for the same reason as d13: isolate the emitter arity lie from the
-- separate unannotated route bug ledgered in d14.
-- Expected: check/run/build all accept and print [2, 3, 4].
interface Sizeable a where
  size : a -> a -> Int

size : Int -> Int
size n = n + 1

main =
  let ys = map size [1, 2, 3] : List Int
  println ys
