-- SHADOW-SEMANTICS cell D4b: definer shadow in VALUE position over LIVE-IMPL
-- elements.  If the bare-name-is-the-standalone rule (D4) is total, this must
-- REJECT (standalone is Int -> Int, elements are Box) — dispatching would require
-- the value to be the method.  Records which way the binary actually goes.
interface Sizeable a where
  size : a -> Int

data Box = Box Int

impl Sizeable Box where
  size (Box n) = n

size : Int -> Int
size n = n + 1

main = println (map size [Box 1, Box 2])
