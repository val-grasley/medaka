-- SHADOW-SEMANTICS cell I8 (matrix row 22): IMPORTER shadow, N-way multi-impl
-- selection in APPLIED position.  S3 is explicitly "Unchanged for importer shadows",
-- so each receiver selects its OWN impl and the no-impl receiver (Int) falls back to
-- the imported standalone.
--
-- ⚠️ This is FORK 1's control at N-way width: it must NOT follow row 6 (the definer
-- N-way), which FLIPPED to a blanket REJECT when S3 became vacuous for DEFINER
-- shadows.  An `import` is a SIBLING scope, not an inner one.  (§2 row 22 still says
-- "expected = row 6"; that cross-reference predates the flip -- S3's own prose is the
-- authority.  Probed conformant while fixing #411.)
-- Expected: check accepts; run/build print 3, 30, 4.
import prov.{size}

interface Sizeable a where
  size : a -> Int

data Box = Box Int

data Bar = Bar Int Int

impl Sizeable Box where
  size (Box n) = n

impl Sizeable Bar where
  size (Bar a b) = a + b

main =
  println (size (Box 3))
  println (size (Bar 10 20))
  println (size 3)
