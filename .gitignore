_build/
*.install
.merlin
*.swp
.DS_Store

# bootstrap_from_seed.sh output (regenerable native emitter binary)
/medaka_emitter
# build_native_medaka.sh output (the native OCaml-free `medaka` CLI binary)
/medaka

# Native gate oracles (built by test/build_oracles.sh)
/test/bin/

# Playground dist artifacts (built by playground/build_playground_wasm.sh; not committed)
/playground/dist/*.wasm
/playground/dist/*.mdk

# Playground deployable site folder (built by playground/build_site.sh; not committed)
/playground/site/

# SQLite demo/probe build artifacts (built to repo root by demos/oracles).
# `/*_demo` covers the whole family (delete_demo, update_demo, update_expr_demo,
# writer_demo, writer_api_demo, overflow_demo, rowid_roundtrip_demo,
# multipage_write_demo, multitable_write_demo, …) — these were being enumerated one
# at a time, and the ones that got missed (e.g. update_expr_demo) sat untracked at
# the root as ~330 KB git-add-A landmines. An agent once committed 5 of them.
/sqlite_*
/*_demo
