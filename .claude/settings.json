{
  "permissions": {
    "allow": [
      "Bash(dune build)",
      "Bash(dune build *)",
      "Bash(dune build @thorough)",
      "Bash(./_build/default/test/*.exe *)",
      "Bash(./_build/default/dev/debug.exe *)",
      "Bash(./_build/default/dev/tc_debug.exe *)",
      "Bash(./_build/default/bin/main.exe check *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(opam list *)",
      "Bash(opam exec *)"
    ],
    "deny": [
      "Read(./tree-sitter-medaka/src/parser.c)",
      "Read(./tree-sitter-medaka/src/grammar.json)",
      "Read(./tree-sitter-medaka/src/node-types.json)",
      "Read(./tree-sitter-medaka/src/tree_sitter/parser.h)",
      "Read(./editors/vscode-medaka/package-lock.json)",
      "Read(./tree-sitter-medaka/package-lock.json)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-triage.py\""
          }
        ]
      }
    ]
  }
}
