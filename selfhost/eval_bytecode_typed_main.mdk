-- TYPED bytecode-VM entry point (STAGE2-DESIGN §2.2, slice 5) — the bytecode
-- analog of selfhost/core_ir_typed_main.mdk:
--
--   medaka run selfhost/eval_bytecode_typed_main.mdk <runtime.mdk> <prelude.mdk>... <source.mdk>
--
-- desugar → elaborate (typecheck stamps the EMethodAt/EDictAt dispatch routes) →
-- LOWER to Core IR → COMPILE + RUN through the bytecode VM for its stdout.
-- This is the bytecode-VM path that exercises IMethod (CMethod / narrowMethod +
-- routeTag) and IDict (CDict / applyDicts) with real elaborated routes: return-
-- position dispatch (`pure`/`empty`/…) routed by the concrete return type (RKey).
-- Diffs byte-for-byte against the reference TYPED path (`medaka run <file>`),
-- the SAME oracle core_ir_typed_main.mdk and eval_typed_main.mdk use.

import ast.{Decl}
import parser.{parse}
import desugar.{desugar}
import typecheck.{elaborate}
import eval.{funNamesOf, dropShadowedExp}
import core_ir_lower.{lowerProgram}
import bytecode.{bcEvalOutput}

main = match args ()
  (runtimePath :: rest) => withRuntime runtimePath rest
  _ => ePutStrLn "usage: medaka run selfhost/eval_bytecode_typed_main.mdk <runtime.mdk> <prelude.mdk>... <file.mdk>"

withRuntime runtimePath rest = match splitLast rest
  Some (preludePaths, targetPath) => withFiles runtimePath preludePaths targetPath
  None => ePutStrLn "usage: <runtime.mdk> <prelude.mdk>... <file.mdk>"

splitLast : List a -> Option (List a, a)
splitLast [] = None
splitLast [x] = Some ([], x)
splitLast (x :: rest) = match splitLast rest
  Some (init, lst) => Some (x :: init, lst)
  None => None

withFiles runtimePath preludePaths targetPath = match readFile runtimePath
  Ok rsrc => withPreludes rsrc preludePaths targetPath
  Err msg => ePutStrLn msg

withPreludes rsrc preludePaths targetPath = match readAllDecls preludePaths
  Ok preludeDecls => withTarget rsrc preludeDecls targetPath
  Err msg => ePutStrLn msg

withTarget rsrc preludeDecls targetPath = match readFile targetPath
  Ok tsrc => putStr (runTyped (desugar (parse rsrc)) preludeDecls (desugar (parse tsrc)))
  Err msg => ePutStrLn msg

runTyped : List Decl -> List Decl -> List Decl -> <Mut> String
runTyped runtimeDecls preludeDecls userDecls =
  let combined = dropShadowedExp (funNamesOf userDecls) preludeDecls ++ userDecls
  bcEvalOutput (lowerProgram (elaborate runtimeDecls combined))

readAllDecls : List String -> <IO> Result String (List Decl)
readAllDecls [] = Ok []
readAllDecls (p :: rest) = match readFile p
  Err msg => Err msg
  Ok src => match readAllDecls rest
    Err msg => Err msg
    Ok more => Ok (desugar (parse src) ++ more)
