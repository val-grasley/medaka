-- Core IR -> textual LLVM IR — Stage 2.4 NATIVE BACKEND (slices 1–8+).
--
-- This IS the canonical LLVM backend (STAGE2-DESIGN.md §2.4). Originally
-- developed as a de-risking spike AFTER the bytecode VM (§2.2, removed
-- 2026-06-10). It emits textual LLVM IR + shells out to clang (no llc/opt,
-- no C++ bindings). Consumes the Core IR (core_ir.mdk) the tree-walker-
-- validated lowering produces, and its emitted
-- binary's stdout is diffed byte-for-byte against the tree-walker oracle
-- (test/diff_selfhost_llvm.sh) over prelude-free fixtures — the usual
-- equivalence-gate shape, exactly as core_ir_main.mdk gates the lowering itself.
--
-- SCOPE DISCIPLINE (matches runtime/medaka_rt.c):
--   • slice 1 — integer/float arithmetic, comparisons, unary -/!, let, if,
--     top-level value bindings, and a type-directed print of `main`.
--   • slice 2 — top-level FUNCTIONS (`name p… = …` → `define i64 @mdk_<name>`)
--     and saturated direct CALLS (`CApp` spine with a known-function head).
--     Self-recursive tail calls lower to `musttail call` + `ret` (the
--     calling-convention proof: self-recursion ⇒ caller/callee prototypes match,
--     which musttail requires; empirically TCO-correct under clang -O0).
--   • slice 2b — Bool/Float FUNCTION BOUNDARIES.  Core IR is type-erased, so a
--     two-pass signature inference (`inferSigs`/`typeOf`/`paramUseTy`) RECOVERS
--     each function's param + return LTy: a param's type comes from its first
--     typed use (an `if`-condition/`!` ⇒ Bool, an arith/compare operand shares its
--     sibling, an argument to a known fn takes that fn's param type), the return
--     type follows structurally.  This is the pure twin of the type-recovery
--     `emitExpr` already does as it emits.  The ABI is UNCHANGED — every value is
--     a uniform i64 word regardless (Int immediate, Bool immediate, Float
--     boxed-pointer-as-i64), so no `define`/`call`/musttail prototype changes; the
--     recovered type only selects int-vs-float instructions in the body and the
--     print routine for the result (so a Bool-returning function prints
--     `true`/`false`, a Float param unboxes/reboxes).
--   • slice 3 — ALGEBRAIC DATA TYPES + PATTERN MATCHING.  A constructor lowers to
--     a BOXED heap cell (RUNTIME-DESIGN.md §8.4 Option A): a one-word header (the
--     constructor name string-hashed to an i64 tag) followed by the field words,
--     allocated via @mdk_alloc (the same boxing path slice 1 uses for Float).  A
--     `match` lowered to a decision tree (`CDecision`, the Maranget tree from
--     core_ir_lower) becomes an LLVM CFG: each `CTSwitch` tests the focus value's
--     head (load tag → icmp → br for constructors; icmp on the immediate for int
--     literals) and descends into the matched cell's fields as the new focus
--     columns; a leaf re-matches its arm's pattern against the scrutinee to bind
--     variables (getelementptr loads), evaluates the body into an alloca result
--     slot, and branches to the decision's end block.  Mirrors core_ir_eval's
--     cevalDecision/cevalTree/cevalSwitch one-to-one, value-walk → block-emit.
--   • slice 4 — CLOSURES + HIGHER-ORDER FUNCTIONS.  A `CLam` is lambda-lifted to a
--     top-level `define @mdk_lamN(i64 %clos, i64 %arg…)` and, at its site, a BOXED
--     closure cell {header, code_ptr, captured…} is allocated (the slice-3 ctor
--     alloc, reused verbatim with "fields" = [code_ptr, capture…]).  The CAPTURED
--     set is freeVars(body) − params, intersected with the live emit env.  An
--     application whose head is NOT a known fn/ctor (a closure-valued param /
--     let-binding / returned closure / immediately-applied lambda) lowers to an
--     INDIRECT call: load code_ptr, `call` it passing the closure word as the
--     leading argument (RUNTIME-DESIGN.md §8.5).  A named top-level fn used as a
--     VALUE is eta-wrapped into a captureless static closure forwarding to
--     `@mdk_<name>`.  SATURATED calls only — the type-erased Core IR can't see a
--     closure's arity at the call site; partial / over-application are OUT (the
--     real backend will carry arity in the cell).
--   • slice 5a — RECORDS, TUPLES, and MUTABLE REFS.  Records lower to boxed cells
--     exactly like ADT constructors (emitCtorAlloc/storeFields/loadField verbatim):
--     header = hashName(record-type-name), then one word per field in source
--     declaration order.  Field access looks up the positional index from a record-
--     field-order table built by scanning CRecord nodes in the program up front.
--     Record update copies all fields from the base then overwrites the named ones.
--     Tuples use the same cell layout with a fixed header (hashName "$tuple"); tuple
--     destructuring via `let (a, b, c) = t` binds elements by loadField.  Mutable
--     refs are lowered INLINE (no new runtime functions): `Ref x` allocates a 1-field
--     cell; `set_ref r x` stores into its field; `r.value` loads from it.
--     SPIKE-REP NOTES (filed here per the slice-3/4 convention):
--       • Records: positional-by-declaration-order.  Name-keyed access at runtime
--         would need a name→offset map; the spike sidesteps this by reading the
--         declaration (from scanned CRecord nodes) at emit time.
--       • Tuples: fixed header hashName "$tuple".  Headerless tuples would save one
--         word but break the uniform cell discipline used for tag-testing in switches.
--       • Refs: 1-field cells over @mdk_alloc (malloc-and-leak).  The real GC will
--         need a write barrier on the `set_ref` store — this is the FIRST mutation
--         site in the spike and the first place a GC would need to act.
--   • slice 5b — BUILT-IN LIST/TUPLE MATCH HEADS + RECURSIVE CLOSURES.  The
--     decision tree's built-in list heads (HCons/HNil) and tuple head (HTuple n)
--     are now treated as constructor tests: `conHeadInfo` maps HCon/HCons/HNil/
--     HTuple to a (name, arity) pair — HCons → ("Cons", 2), HNil → ("Nil", 0),
--     HTuple n → ("$tuple", n) — so emitSwitch/emitConChain compare the loaded tag
--     against `cellTag e name`, the SAME tag the constructor/tuple alloc site stamps
--     (so construction and match agree by construction).  `bindPattern` gains
--     `PCons h t` (a 2-field [head, tail] extraction) and `PList []` (binds nothing).
--     A recursive function-`let` (`let f p… = … in e2` → CLet True (PVar f) (CLam …))
--     lambda-lifts like any CLam but EXCLUDES `f` from the capture set (it is the
--     closure cell itself) and binds `f → %clos` inside the lifted body, so the
--     self-call re-enters the same cell.
--   • slice 6 — TYPECLASS DISPATCH.  The Core IR's two dispatch nodes lower here:
--     `CMethod` (a method occurrence) and `CDict` (a `=>`-constrained-fn occurrence),
--     each carrying the typechecker's resolved `Route`s.  An `RKey` route is
--     STATICALLY resolved (the concrete impl is known at compile time) → a DIRECT
--     call to that impl's lifted `@mdk_impl_<tag>_<method>`; `RDict`/`RDictFwd` read
--     a runtime dict-parameter witness word → an inline if-chain over the method's
--     impls.  Mirrors core_ir_eval's methodAtNarrow/applyDicts/narrowMethod.  See the
--     "typeclass dispatch (slice 6)" section below for the (j)/(k)/(l) rep notes.
--   • slice 8 — ARRAYS + RANGES.  CArray allocates a length-prefixed boxed cell
--     (layout: [ i64 raw_len | elem0 | elem1 … ], reusing the slice-3 cell shape
--     but with the header word = raw element count rather than a constructor hash).
--     CIndex loads the length, bounds-checks (calls @mdk_oob() on failure), then
--     GEPs to field (idx+1) dynamically.  CRangeArray and CSlice both emit an
--     alloca-counter loop (the spike's first non-recursion loop): CRangeArray fills
--     i ↦ lo+i (tagged Int word); CSlice copies elements from the source array.
--   • slice 9 — LISTS (CList + CRangeList).  CList [e0…en] right-folds inline into
--     Cons/Nil boxed cells (the same cells the slice-5b HCons/HNil match heads test,
--     so construction and match agree).  CRangeList lo hi incl builds an ascending
--     list via an alloca-counter back-to-front loop (initialise Nil, prepend
--     Cons(lo+i,acc) for i from count-1 downto 0) — avoids stack overflow and
--     mirrors the slice-8 loop discipline.  See the "lists (slice 9)" section and
--     §2.4a-6 in STAGE2-DESIGN.md for the (u)/(v) rep notes.
--   • native extern catalog slice 1 — STRINGS + minimal string/IO externs (NOT a
--     Core IR-surface slice; the first leg of the real-backend extern catalog,
--     unblocked by Boehm GC).  Locks the String rep (RUNTIME-DESIGN §4/§7 decision
--     2: UTF-8 bytes + cached codepoint count) as a boxed cell
--     [ header | byte_len | cp_count | bytes… | NUL ].  `CLit (LString _)` emits a
--     private `@.str.N` byte-array global (`\HH`-escaped, codepoints re-encoded to
--     UTF-8 via utf8Bytes) + a run-time @mdk_str_lit box; `intToString` lowers to a
--     direct @mdk_int_to_string call (first extern RETURNING a heap String — the
--     §2a GC-alloc contract); a String-typed `main` auto-prints via @mdk_print_str
--     (raw bytes + newline, matching pp_value (VString s) = s).  See the "string
--     literals + string externs" section and §2.4a-7 for the (w)–(z) rep notes.
-- Still OUT of scope: arg-tag dispatch on non-ADT args; nested requires dicts;
-- further string/IO externs (charToStr/stringConcat/putStr/file-IO/unicode); the
-- Char rep (gates charCode).
-- An unsupported Core IR node panics with its tag (the spike refuses to emit wrong
-- code rather than silently mis-lowering).
--
-- VALUE REPRESENTATION (PROVISIONAL — revisable; see RUNTIME-DESIGN.md "Value
-- representation & calling convention").  A value is a uniform 64-bit word:
--   • Int  — immediate, (n << 1) | 1   (low bit 1).  Arithmetic untags/retags,
--            so the tagging cost is VISIBLE in the emitted IR (the point).
--   • Bool — the immediate-int encoding 0/1 (slice 1 is statically typed, so the
--            print routine is chosen by static type; the rep need not yet tell a
--            Bool from an Int — a limitation this spike deliberately exposes).
--   • Float — BOXED: word is a pointer to a 16-byte cell {i64 header, double},
--            allocated via @mdk_alloc.  Surfaces "floats don't fit a tagged-int
--            word", which is the core input to the rep proposal.
--   • ADT  — a constructor with FIELDS is BOXED (slice 3): word is a pointer (low
--            bit 0) to a heap cell [ i64 tag | field0 | field1 … ], one 8-byte word
--            each; tag = the composite (typeId<<32 | ctor-ordinal) `cellTag` stamps.
--            The same boxed-pointer discipline as Float, extended to n fields.  A
--            NULLARY constructor is IMMEDIATE (low bit 1, RUNTIME-DESIGN §8.1/§8.4):
--            the word is `(cellTag<<1)|1` carrying that same composite tag, NO
--            allocation — the Bool immediate (True→3/False→1) generalised to every
--            nullary ctor.  A `match` head recovers the tag via `loadDiscriminant`
--            (branch on the low bit: immediate ⇒ `ashr 1`, boxed ⇒ load header), so
--            a type mixing both (Option = None immediate + Some boxed) discriminates
--            without ever dereferencing an immediate.
--   • Closure — BOXED (slice 4): word is a pointer to a heap cell
--            [ i64 header | i64 code_ptr | capt0 | capt1 … ] (RUNTIME-DESIGN.md
--            §8.5).  The same cell shape as an ADT (header + fields), so it reuses
--            the slice-3 alloc; calling loads code_ptr and passes the cell pointer
--            as the leading argument.
--   • Record — BOXED (slice 5a): word is a pointer to a heap cell
--            [ i64 header | field0 | field1 … ], fields in declaration order.
--            header = hashName(record-type-name), same hashing as ADT constructors.
--   • Tuple  — BOXED (slice 5a): same cell shape with header = hashName "$tuple".
--   • Ref    — BOXED (slice 5a): 1-field cell [ i64 header | stored_value ].
--            header = hashName "$ref".  .value loads field 0; set_ref stores into
--            field 0.  Write barrier absent (malloc-and-leak, same as @mdk_alloc).
--   • String — BOXED (native extern catalog slice 1): word is a pointer to a heap
--            cell [ i64 header | i64 byte_len | i64 cp_count | UTF-8 bytes… | NUL ]
--            (RUNTIME-DESIGN §4, rep LOCKED 2026-06-07).  Built by @mdk_str_lit
--            (literals + intToString); cp_count cached so stringLength is O(1).
--            GC-managed under Boehm for free (aligned pointer, low bit 0).

import ast.{Lit(..), Pat(..), Addr(..), Route(..)}
import core_ir.{CExpr(..), CField(..), CBind(..), CClause(..), CStmt(..), CProgram(..), CArm(..), CGuard(..), CTree(..), CTBranch(..), CHead(..), CImplEntry(..), CImplBody(..)}
import core_ir_lower.{compileTree, canonPat}
import util.{reverseL, joinNl, lookupAssoc, listLen}

-- ── D4 emitter-completeness inventory (record-and-skip) ──────────────────────
-- A MEASUREMENT scaffold for STAGE D4 (selfhost/EMITTER-GAPS.md).  OFF by default:
-- when `gapRecordEnabled` is False every gap site below still `panic`s, exactly as
-- before, so normal emit output and all four diff_selfhost_* gates stay
-- byte-identical.  The D4 gaps probe (llvm_emit_gaps_main.mdk) flips it ON to
-- COLLECT every gap in one pass instead of aborting on the first: each gap is
-- recorded as "<binding>\t<reason>" and the offending construct returns a benign
-- placeholder so emission of the rest of the program proceeds.  The placeholder
-- poisons only that one sub-expression's output (which the probe discards — it
-- never compiles/links the .ll), so it surfaces ALL gaps rather than one.
gapRecordEnabled : Ref Bool
gapRecordEnabled = Ref False

gapLog : Ref (List String)
gapLog = Ref []

curGapBind : Ref String
curGapBind = Ref "?"

-- The fallthrough target for a multi-clause function (or guarded match) emitted as
-- a CHAIN of single-clause decision trees: when clause K's pattern fails to match
-- (CTFail) OR its guard chain falls through (`__fallthrough__ ()`), control must
-- resume at clause K+1's entry block — exactly the interpreter's VFallthrough →
-- "try next clause" semantics (eval.mdk's fallthroughToNone).  Holds the current
-- next-clause LLVM label; "" means "no next clause" → the historical `@mdk_oob`
-- non-exhaustive abort.  Set per-clause by emitClauseChain; read by CTFail and the
-- `__fallthrough__` arm of emitApp.  A module-level Ref (mirrors gapLog) to avoid
-- threading the label through every emitTree/emitExpr arm.
fallthroughLabelRef : Ref String
fallthroughLabelRef = Ref ""

-- emit a branch to the current next-clause fallthrough target, or the historical
-- @mdk_oob abort when there is none (single-clause / exhausted chains).
emitFallthrough : Emit -> <Mut> (String, LTy)
emitFallthrough e = match fallthroughLabelRef.value
  "" =>
    let _ = emit e "  call void @mdk_oob()"
    ("0", LTInt)
  lbl =>
    let _ = emit e ("  br label %" ++ lbl)
    ("0", LTInt)

-- ── TRMC (tail-recursion-modulo-cons) context (PLAN #56, TRMC-DESIGN.md) ─────
-- When a top-level NON-DICT self-recursive define is `trmcEligible` — its tail
-- leaves are `head :: self-call` cons-tails (`upto`/`replicate`/`myMap`) — it is
-- emitted in destination-passing form: an O(1)-stack loop with a MUTABLE
-- destination slot (`%trmc_dest`, an `alloca ptr` holding the address of the i64
-- to fill next).  A cons leaf allocates the cell, links it into `*dest`, advances
-- `dest` to the cell's tail slot, recomputes the recursion args into the param
-- slots, and branches back to the loop head; a base leaf stores its value into
-- `*dest` and branches to the exit, which loads `%trmc_hole` (the final list head)
-- and rets.  The self-call is NEVER emitted as a `call` — only its arg
-- recomputation feeds the loop, which is what removes the stack-growing call.
--
-- A module-level Ref (mirroring fallthroughLabelRef) carries the active context
-- so the decision-tree leaf (emitLeaf) and the single-clause CIf-tail descent
-- (emitTrmcBody) both route into it without threading it through every emit arm.
-- TrmcOff = ordinary (non-TRMC) codegen; TrmcOn self arity destSlot loopL exitL
-- paramSlots = the live context.  `self` is the SelfRef the loop recurses on (a
-- top-level CVar name, or a dispatched CMethod method+tag — Phase 2 B-dispatch);
-- destSlot is the `alloca ptr` register (the mutable destination); loopL/exitL the
-- loop-head / exit blocks; paramSlots the mutable `alloca i64` param slots the cons
-- leaf recomputes the recursion args into.
data TrmcCtx = TrmcOff | TrmcOn SelfRef Int String String String (List String)

-- How the eligible function refers to ITSELF in a tail self-call.  A top-level
-- define recurses by NAME (`CVar self`); a dispatched instance method (Phase 2
-- B-dispatch — stdlib `map`/`filterMap`) recurses via a `CMethod method (RKey tag)`
-- node post-restampIface, where the method NAME is invisible to `freeVars` — so the
-- self-walk MUST be SelfRef-aware, not freeVars-based, or a non-tail `CMethod`
-- self-recursion is silently accepted and MISCOMPILED (TRMC-DESIGN §"SAFETY-CRITICAL").
data SelfRef = SelfByVar String | SelfByMethod String String

trmcCtxRef : Ref TrmcCtx
trmcCtxRef = Ref TrmcOff

export
enableGapRecord : Unit -> <Mut> Unit
enableGapRecord _ = set_ref gapRecordEnabled True

-- clear the gap log (so one process can run several independent gap censuses).
export
resetGaps : Unit -> <Mut> Unit
resetGaps _ =
  let _ = set_ref gapLog []
  let _ = resetEmittedDefaults ()
  set_ref curGapBind "?"

-- the recorded gap events, in first-recorded order ("<binding>\t<reason>").
export
gapEvents : Unit -> List String
gapEvents _ = reverseL gapLog.value

-- set the binding name attributed to subsequent gaps (the probe sets this per
-- top-level binding / impl entry before emitting it).
export
setGapBind : String -> <Mut> Unit
setGapBind name = set_ref curGapBind name

noteGap : String -> <Mut> Unit
noteGap reason = set_ref gapLog ((curGapBind.value ++ "\t" ++ reason) :: gapLog.value)

-- ── method-call RESULT-type inference (native backend) ──────────────────────
-- The (interface, method) -> returns-self table, computed by core_ir_lower's
-- `returnsSelfTable` and installed once at the start of emitProgram/
-- emitProgramGaps (a module-level Ref, mirroring gapLog — avoids threading a
-- field through every Emit pattern).  A method whose RESULT type mentions the
-- interface/self type variable (`map`/`ap`/`andThen`: f a -> … -> f b) returns
-- the CONTAINER; the emitter types its RKey-dispatched call result as the impl's
-- own type (`tagToLTy tag` → LTCon for List), so a downstream `++`/`::` on that
-- result picks list/string append instead of falling to the LTInt default.  This
-- closes EMITTER-GAPS #3's last residual (`ap@List` / `andThen@List`, whose `++`
-- operand is a CALL result like `map f xs` / the recursive `ap fs xs`, not a
-- param the static E2c typing could reach).
returnsSelfTableRef : Ref (List ((String, String), Bool))
returnsSelfTableRef = Ref []

-- install the (interface, method) -> returns-self table (from core_ir_lower's
-- `returnsSelfTable <decls>`).  A consumer that emits typeclass methods calls
-- this BEFORE emitProgram/emitProgramGaps; a method/interface-free consumer may
-- skip it (the empty default ⇒ returns-self False ⇒ unchanged behaviour).
export
installReturnsSelf : List ((String, String), Bool) -> <Mut> Unit
installReturnsSelf t = set_ref returnsSelfTableRef t

-- does interface method (iface, method) return the self/container type?
-- (False when absent — the conservative default keeps the pre-change behaviour.)
methodReturnsSelf : String -> String -> <Mut> Bool
methodReturnsSelf iface method = lookupReturnsSelf iface method returnsSelfTableRef.value

lookupReturnsSelf : String -> String -> List ((String, String), Bool) -> Bool
lookupReturnsSelf _ _ [] = False
lookupReturnsSelf iface method (((i, m), b)::rest)
  | i == iface && m == method = b
  | otherwise = lookupReturnsSelf iface method rest

-- ── self-returning function-PARAM typing (native backend) ───────────────────
-- The (interface, method) -> [function-param positions returning self] table,
-- from core_ir_lower's `selfFnParamTable`.  When emitting an impl method's body,
-- the params at those positions are callbacks that yield the container (e.g.
-- `andThen : m a -> (a -> m b) -> m b`, param 1 = `a -> m b`).  Before emitting a
-- group body, `curSelfFnParamsRef` is set to the NAMES of those params and
-- `curImplTagRef` to the impl's type-head tag; `emitIndirect` then types the
-- APPLICATION of such a param (`f x`) as `tagToLTy curImplTagRef` instead of the
-- LTInt indirect-call default.  This closes `andThen@List`, whose `++` LEFT
-- operand `f x` is an indirect call the method-call inference can't reach.
selfFnParamTableRef : Ref (List ((String, String), List Int))
selfFnParamTableRef = Ref []

export
installSelfFnParams : List ((String, String), List Int) -> <Mut> Unit
installSelfFnParams t = set_ref selfFnParamTableRef t

selfFnParamPositions : String -> String -> <Mut> List Int
selfFnParamPositions iface method = lookupSelfFnParams iface method selfFnParamTableRef.value

lookupSelfFnParams : String -> String -> List ((String, String), List Int) -> List Int
lookupSelfFnParams _ _ [] = []
lookupSelfFnParams iface method (((i, m), p)::rest)
  | i == iface && m == method = p
  | otherwise = lookupSelfFnParams iface method rest

-- ── interface-default-method dispatch (native backend, E19) ──────────────────
-- The method → (interface, full-arity) table from core_ir_lower's
-- `methodIfaceTable`.  An interface DEFAULT method (a `CImplDefault` body the
-- type's `impl` did not override — e.g. `filter` on a `Filterable List` that only
-- defines `filterMap`, or `max`/`min` on an `Ord` instance) is dispatched by
-- emitting the default body as a lifted `@mdk_default_<method>[_<tag>]` define.
-- Two facts this table supplies:
--   • ARITY — eta-expand a point-free default (`filter p = filterMap …` is
--     arity-1 in source but the method is arity-2) to its full arity so the
--     direct RKey call passes every call-site argument.
--   • INTERFACE — recognise inner SAME-interface method occurrences in the default
--     body (the `filterMap` in `filter`'s body) and re-stamp them to the concrete
--     dispatch tag, so a partially-applied inner method lowers to a direct
--     `@mdk_impl_<tag>_<method>` call instead of an un-dispatchable arg-tag site.
-- Keyed by BARE method name (interface method names are distinct in the prelude).
methodIfaceTableRef : Ref (List (String, (String, Int)))
methodIfaceTableRef = Ref []

export
installMethodIface : List (String, (String, Int)) -> <Mut> Unit
installMethodIface t = set_ref methodIfaceTableRef t

-- the interface a method name belongs to (""=not an interface method).
methodIfaceOf : String -> <Mut> String
methodIfaceOf method = match lookupAssoc method methodIfaceTableRef.value
  Some (iface, _) => iface
  None => ""

-- the declared full arity of an interface method (0 = not found).
methodArityOf : String -> <Mut> Int
methodArityOf method = match lookupAssoc method methodIfaceTableRef.value
  Some (_, arity) => arity
  None => 0

-- ── constructor → DECLARED field type-head names (native backend, Gap E2) ────
-- The ctor → declared-field-type-head-name table from core_ir_lower's
-- `ctorFieldTypeNames` (e.g. `Rect Float Float` → ("Rect", ["Float","Float"])).
-- `bindFields` reads it to type a match-bound field VARIABLE from the ctor's
-- DECLARED field type rather than guessing from body-use (`paramUseTy`, which
-- defaults a Float field to LTInt → integer arith on a boxed-Float pointer-word →
-- SIGSEGV; Gap E2).  Installed before emitProgram/emitProgramGaps (module-level
-- Ref, mirroring returnsSelfTableRef); empty default ⇒ no field is overridden ⇒
-- unchanged pre-change behaviour.
ctorFieldTypesRef : Ref (List (String, List String))
ctorFieldTypesRef = Ref []

export
installCtorFieldTypes : List (String, List String) -> <Mut> Unit
installCtorFieldTypes t = set_ref ctorFieldTypesRef t

-- the declared field type-head names of a constructor, or [] if unknown.
ctorFieldTypeNamesOf : String -> <Mut> List String
ctorFieldTypeNamesOf con = match lookupAssoc con ctorFieldTypesRef.value
  Some names => names
  None => []

-- map a declared field type-head NAME to a definite scalar LTy, or None when it
-- is not a known scalar (polymorphic / pointer-typed / "" unknown) — None ⇒ the
-- caller falls back to paramUseTy/LTInt, so the override is ADDITIVE: only
-- known-scalar fields (esp. Float/Bool) change typing.
fieldNameToLTy : String -> Option LTy
fieldNameToLTy "Float"  = Some LTFloat
fieldNameToLTy "Bool"   = Some LTBool
fieldNameToLTy "Int"    = Some LTInt
fieldNameToLTy "Char"   = Some LTChar
fieldNameToLTy "String" = Some LTStr
fieldNameToLTy _        = None

-- ── function → DECLARED param/return type-head names (native backend, Gap E1) ─
-- The fn → (declared-param-type-head-names, declared-return-type-head-name) table
-- from core_ir_lower's `declSigTypeNames` (e.g. `double : Float -> Float` →
-- ("double", (["Float"], "Float"))).  Signature inference (`inferSigs` →
-- `inferOneSig`/`inferParamTys`) SEEDS each param/return LTy from this declared
-- type when it is a known scalar, winning over the body-use guess (`paramUseTy`,
-- which for a literal-free annotated body like `double x = x + x` finds no Float
-- anchor → LTInt → integer arith on a boxed-Float word → garbage; Gap E1).
-- Installed before emitProgram/emitProgramGaps (module-level Ref, mirroring
-- ctorFieldTypesRef); empty default ⇒ no fn is seeded ⇒ unchanged pre-change
-- behaviour.  ADDITIVE: only known-scalar declared params/returns override; an
-- unannotated fn / non-scalar declared type falls through to the existing guess.
declSigTypesRef : Ref (List (String, (List String, String)))
declSigTypesRef = Ref []

export
installDeclSigTypes : List (String, (List String, String)) -> <Mut> Unit
installDeclSigTypes t = set_ref declSigTypesRef t

-- the declared (param-type-head-names, return-type-head-name) of a function, or
-- None when it has no annotation.
declSigOf : String -> <Mut> Option (List String, String)
declSigOf name = lookupAssoc name declSigTypesRef.value

-- the declared LTy of param index `i` of function `name`, if annotated with a
-- known scalar there; else None (caller falls back to body-use inference).
declParamLTy : String -> Int -> <Mut> Option LTy
declParamLTy name i = match declSigOf name
  Some (ptyNames, _) => match nthName ptyNames i
    Some n => fieldNameToLTy n
    None => None
  None => None

-- the declared RETURN LTy of function `name`, if annotated with a known scalar;
-- else None.
declRetLTy : String -> <Mut> Option LTy
declRetLTy name = match declSigOf name
  Some (_, retName) => fieldNameToLTy retName
  None => None

nthName : List String -> Int -> Option String
nthName (x::_) 0 = Some x
nthName (_::rest) i = nthName rest (i - 1)
nthName [] _ = None

-- the set of default fn names already lifted (one define per (method, tag)),
-- reset at the start of each emit run so the two censuses don't share state.
emittedDefaultsRef : Ref (List String)
emittedDefaultsRef = Ref []

resetEmittedDefaults : Unit -> <Mut> Unit
resetEmittedDefaults _ = set_ref emittedDefaultsRef []

markDefaultEmitted : String -> <Mut> Unit
markDefaultEmitted name = set_ref emittedDefaultsRef (name :: emittedDefaultsRef.value)

defaultAlreadyEmitted : String -> <Mut> Bool
defaultAlreadyEmitted name = containsStr name emittedDefaultsRef.value

-- the impl currently being emitted: its type-head tag, and the NAMES of its
-- params that are self-returning function callbacks (set in emitGroupBody).
curImplTagRef : Ref String
curImplTagRef = Ref ""

curSelfFnParamsRef : Ref (List String)
curSelfFnParamsRef = Ref []

-- set the current-impl context for self-returning-fn-param typing; cleared after
-- the group body so a following top-level fn body isn't mis-typed.
setCurImplSelfFns : String -> List String -> <Mut> Unit
setCurImplSelfFns tag names =
  let _ = set_ref curImplTagRef tag in set_ref curSelfFnParamsRef names

clearCurImplSelfFns : Unit -> <Mut> Unit
clearCurImplSelfFns _ =
  let _ = set_ref curImplTagRef "" in set_ref curSelfFnParamsRef []

-- is `name` a self-returning function param of the impl currently being emitted?
isCurSelfFnParam : String -> <Mut> Bool
isCurSelfFnParam name = containsStr name curSelfFnParamsRef.value


-- gap helpers: when recording is on, log the reason + return a placeholder so
-- emission continues; otherwise `panic` (the unchanged normal-path behaviour).
-- One per return shape the panic sites need.
gapE : String -> <Mut> (String, LTy)
gapE reason = if gapRecordEnabled.value then let _ = noteGap reason in ("0", LTInt) else panic reason

gapU : String -> <Mut> Unit
gapU reason = if gapRecordEnabled.value then noteGap reason else panic reason

-- gap that returns the unchanged emit env (the bindPattern accumulator).
gapEnv : String -> List (String, (String, LTy)) -> <Mut> List (String, (String, LTy))
gapEnv reason env = if gapRecordEnabled.value then let _ = noteGap reason in env else panic reason

-- gap that returns a placeholder operand word (an unbound dict witness).
gapStr : String -> <Mut> String
gapStr reason = if gapRecordEnabled.value then let _ = noteGap reason in "0" else panic reason

-- the static type of a slice-1/3 value, used to pick the print routine and the
-- int-vs-float instruction (Core IR is type-erased; for this subset the type is
-- recoverable structurally as we emit).  `LTCon` (slice 3) is an ADT value — a
-- boxed heap-cell pointer word; it never reaches an arithmetic/print site in the
-- supported subset (constructor values flow only as scrutinees and call args,
-- which are LTy-agnostic uniform i64 words), so it carries no payload type.
-- `LTClosure` (slice 4) is a first-class function value — a boxed closure cell
-- pointer word, like `LTCon`.  It flows only as a call argument and as the head of
-- an indirect call (both LTy-agnostic uniform i64 words); it never reaches an
-- arithmetic or print site in the supported subset, so it carries no payload type.
-- `LTRef` (slice 5a) is a mutable ref cell pointer word.  Like `LTCon`/`LTClosure`,
-- it never reaches an arithmetic or print site directly — so it carries no payload.
-- `LTStr` (native extern catalog slice 1) is a heap String value — a boxed cell
-- pointer word (RUNTIME-DESIGN.md §4: UTF-8 bytes + cached codepoint count).  It
-- flows as a call argument and reaches the top-level print site (mdk_print_str);
-- it never reaches an arithmetic site, so it carries no payload type.
-- `LTUnit` (native extern catalog slice 3) is the Unit return type of IO-output
-- externs (putStr/putStrLn/ePutStr/ePutStrLn).  Its operand word is never
-- inspected — only auto-printed as "()" by emitPrint.
-- `LTUnknown` tags the result of a `++` whose operand static LTy could NOT be
-- recovered (the runtime-dispatched @mdk_append fallback below).  Its VALUE is
-- always correct (mdk_append inspects the cell header: String → string append,
-- list → list append), but its static kind is genuinely unknown — it may be a
-- String (the dominant `scanTriple`/`splitLines` string-builder case) OR a list
-- (e.g. typecheck.mdk's `freeEffvars a ++ rowFreeEffvars r ++ freeEffvars b`,
-- `List Int`).  Crucially it must NOT be treated as a guaranteed String: a
-- CHAINED `++` over an LTUnknown left operand re-routes through @mdk_append
-- (runtime dispatch) rather than a DIRECT @mdk_string_append, which would read a
-- list cell as a String header and segfault.  Everywhere a guaranteed String is
-- treated specially (print, `==`/`!=`) LTUnknown follows LTStr, because those
-- sites are only reached for the string-builder case in practice.
-- LTNum (G3): a POLYMORPHIC numeric operand — a `Num a =>`-constrained param
-- whose declared type head is a type variable, so it could be an Int OR a Float
-- at runtime.  The emitter can't pick int- vs float-instructions statically, so
-- LTNum arithmetic/print route through the runtime tag-dispatched @mdk_num_*
-- helpers (low-bit discriminator).  EVERYWHERE ELSE LTNum behaves like LTInt
-- (its word rep IS the tagged-int/boxed-float word, default-handled like a word),
-- so concrete Int/Float paths are byte-unchanged; only emitArith/emitPrint
-- special-case it.
data LTy = LTInt | LTFloat | LTBool | LTCon | LTClosure | LTStr | LTUnit | LTChar | LTUnknown | LTNum

-- emitter state: a fresh-name counter, the output lines (accumulated in REVERSE
-- — prepend is O(1); reverseL'd once at the end restores program order), the
-- set of known top-level FUNCTION names (slice 2), so a `CApp` head can be
-- distinguished as a direct call to `@mdk_<name>` vs an unsupported higher-order
-- application, and the function SIGNATURE table (slice 2b — `name ->
-- (param types, return type)`), which lets a `CApp` recover the callee's return
-- type and a `define` bind each parameter at its inferred type instead of
-- assuming Int.  Both the function set and the signature table are populated
-- once, up front, in emitProgram.  The fifth ref is the CONSTRUCTOR table
-- (slice 3 — `name -> arity`, read out of `CProgram`): it tells a `CVar`/`CApp`
-- head apart as an ADT constructor (→ heap-cell allocation) vs a function call /
-- local variable, and supplies the arity for the alloc + field stores.  The SIXTH
-- ref (slice 4) is a SEPARATE output buffer for LIFTED LAMBDA definitions: a CLam
-- is lambda-lifted to its own top-level `define` (LLVM has no nested functions),
-- but it is DISCOVERED mid-body while the main buffer holds the enclosing
-- function — so its `define` is emitted into this side buffer (via a save/restore
-- swap of the main buffer) and concatenated after `@main` at module end (LLVM
-- define order is irrelevant).  The SEVENTH ref (slice 5a) is the RECORD FIELD
-- ORDER table (`name -> [label_in_order]`, built by scanning CRecord nodes in the
-- program up front): it lets CFieldAccess recover a label's positional index so
-- the field can be reached by loadField without carrying type information.  The
-- EIGHTH ref (slice 6 — typeclass dispatch) is the IMPL TABLE: the program's
-- `CImplEntry` list (read out of `CProgram`).  It tells a `CMethod` site which
-- concrete impl body an `RKey`-resolved route names (→ a direct call to that
-- impl's lifted `@mdk_impl_<tag>_<method>`), and supplies the full impl set a
-- runtime `RDict`/`RDictFwd` site switches over by the dict's head tag.  The
-- NINTH ref (slice 7 — arg-position dispatch) is the CTOR→TYPE map (read out of
-- `CProgram`'s 3rd field): a method dispatched on its argument's runtime tag
-- (`eq`/`compare`/`show`) lowers to a bare `CVar` applied to args; the call site
-- loads the discriminating argument's constructor tag and selects the impl whose
-- TYPE owns that constructor — this map turns the loaded ctor tag into its type.
-- The TENTH ref (slice E1b — top-level value/`Ref` globals) is the GLOBALS
-- REGISTRY: `name -> (initialised?, LTy)`.  Each top-level non-`main` non-function
-- binding is emitted as a module global `@mdk_g_<name>` and computed once in an
-- `@main` init prologue (source order).  The registry lets `emitVar` recognise such
-- a name and lower it to a `load i64, ptr @mdk_g_<name>` referenceable from ANY
-- `define` (the gap #7 fix: a value binding referenced from a sibling function is
-- no longer an unbound local).  The `initialised?` flag is set as the prologue
-- computes each rhs in source order, so a reference to a NOT-yet-computed global
-- inside the prologue (a forward / mutual init dependency) is caught precisely
-- instead of loading an uninitialised 0; after the prologue every entry is `True`,
-- so any function body may reference any global.  MULTI-MODULE init (each module's
-- globals initialised in cross-module dependency order) is a D4 concern — NOT built
-- here; this is the single-program (`@main` + prologue) milestone.
data Emit = Emit (Ref Int) (Ref (List String)) (Ref (List String)) (Ref (List (String, FnSig))) (Ref (List (String, Int))) (Ref (List String)) (Ref (List (String, List String))) (Ref (List CImplEntry)) (Ref (List (String, String))) (Ref (List (String, (Bool, LTy))))

-- a function's inferred signature: its parameter types (in order) and its return
-- type.  At the LLVM ABI every value is a uniform i64 word regardless (Int
-- immediate, Bool immediate, Float boxed-pointer-as-i64), so a signature changes
-- NO `define`/`call` LLVM type — it only drives the static LTy bookkeeping that
-- picks int-vs-float instructions in the body and the print routine for a result.
data FnSig = FnSig (List LTy) LTy

-- an emit-time environment: source name -> (its LLVM operand, its static type).
-- A "register" is any LLVM operand text: a `%tN`, or an immediate like `5` for a
-- tagged-int constant (constants are used inline, emitting no instruction).

-- ── emitter plumbing ────────────────────────────────────────────────────────
freshId : Emit -> <Mut> Int
freshId (Emit c _ _ _ _ _ _ _ _ _) =
  let n = c.value
  let _ = set_ref c (n + 1)
  n

freshReg : Emit -> <Mut> String
freshReg e = "%t" ++ intToString (freshId e)

emit : Emit -> String -> <Mut> Unit
emit (Emit _ buf _ _ _ _ _ _ _ _) line = set_ref buf (line :: buf.value)

-- the main output buffer ref (slice 4: needed for the save/restore swap that
-- redirects emission of a lifted lambda's `define` into the side buffer).
bufRef : Emit -> Ref (List String)
bufRef (Emit _ buf _ _ _ _ _ _ _ _) = buf

-- the side buffer holding lifted-lambda `define`s, in REVERSE order (newest
-- first): each append prepends its chunk (O(chunk), amortized O(total)) instead
-- of the old O(N²) `acc ++ forward`; the consumer `reverseL`s it once at module
-- end (slice 4).
lamsRef : Emit -> Ref (List String)
lamsRef (Emit _ _ _ _ _ lams _ _ _ _) = lams

-- the known-function table (set once in emitProgram); membership decides whether
-- a `CApp` head names a callable top-level function.
fnNames : Emit -> <Mut> List String
fnNames (Emit _ _ fns _ _ _ _ _ _ _) = fns.value

-- ── known-function index (perf) ─────────────────────────────────────────────
-- `fnNames` is set ONCE at Emit construction and never mutated (unlike `sigs`,
-- which the two-pass float propagation rewrites — that is why only THIS table,
-- not the sig table, is safely indexable). Index it into a BST (EMap, a plain ADT
-- → self-compiles in llvm_emit's own graph) installed at emitProgram, so the
-- per-CApp/CVar `isKnownFn` membership test is O(log n) not O(fns).
data EMap a = ETip | EBin String a (EMap a) (EMap a)

emInsert : String -> a -> EMap a -> EMap a
emInsert k v ETip = EBin k v ETip ETip
emInsert k v (EBin k2 v2 l r) = match stringCompare k k2
  Lt => EBin k2 v2 (emInsert k v l) r
  Gt => EBin k2 v2 l (emInsert k v r)
  Eq => EBin k2 v l r

emLookup : String -> EMap a -> Option a
emLookup k ETip = None
emLookup k (EBin k2 v l r) = match stringCompare k k2
  Lt => emLookup k l
  Gt => emLookup k r
  Eq => Some v

emFromNames : List String -> EMap Unit -> EMap Unit
emFromNames [] m = m
emFromNames (x :: rest) m = emFromNames rest (emInsert x () m)

-- generic key-value index; insert REVERSED so the FIRST list entry wins on a
-- duplicate key (matches lookupAssoc's first-match). For CONSTANT tables only.
emFromPairs : List (String, a) -> EMap a -> EMap a
emFromPairs [] m = m
emFromPairs ((k, v) :: rest) m = emFromPairs rest (emInsert k v m)

knownFnMapRef : Ref (Option (EMap Unit))
knownFnMapRef = Ref None

installKnownFnMap : List String -> <Mut> Unit
installKnownFnMap fns = set_ref knownFnMapRef (Some (emFromNames fns ETip))

-- ctor-arity table index (ct field is set once at Emit construction, constant).
ctorMapRef : Ref (Option (EMap Int))
ctorMapRef = Ref None

installCtorMap : List (String, Int) -> <Mut> Unit
installCtorMap t = set_ref ctorMapRef (Some (emFromPairs (reverseL t) ETip))

-- sig table index — ONLY for the GLOBAL-`sigs` users (fnRetTy/fnArity), which read
-- the Emit's `sigs` field. That field is set once at construction and never
-- mutated (constant), so a memo built from `sigTable e` is byte-identical to the
-- old `lookupAssoc name sigs.value`. NOTE: callRetTy/nthParamTy use a DIFFERENT,
-- THREADED `sigs` augmented with locally-inferred Float-propagation types — those
-- are NOT covered here (see the reverted sig-table attempt + fn_float_chain).
sigMapRef : Ref (Option (EMap FnSig))
sigMapRef = Ref None

installSigMap : List (String, FnSig) -> <Mut> Unit
installSigMap t = set_ref sigMapRef (Some (emFromPairs (reverseL t) ETip))

isKnownFn : Emit -> String -> <Mut> Bool
isKnownFn e name = match knownFnMapRef.value
  Some m => match emLookup name m
    Some _ => True
    None => False
  None => containsStr name (fnNames e)

-- the inferred return type of a known function (Int if unknown — keeps the
-- pre-signature behaviour for any head the table somehow misses).
fnRetTy : Emit -> String -> <Mut> LTy
fnRetTy e name = match sigMapRef.value
  Some m => match emLookup name m
    Some (FnSig _ rty) => rty
    None => LTInt
  None => match lookupAssoc name (sigTable e)
    Some (FnSig _ rty) => rty
    None => LTInt

-- ── constructor table (slice 3) ─────────────────────────────────────────────
-- the constructor arity table (set once in emitProgram); membership decides
-- whether a `CVar`/`CApp` head names an ADT constructor (→ heap allocation).
ctorTable : Emit -> <Mut> List (String, Int)
ctorTable (Emit _ _ _ _ ct _ _ _ _ _) = ct.value

isCtor : Emit -> String -> <Mut> Bool
isCtor e name = match ctorMapRef.value
  Some m => match emLookup name m
    Some _ => True
    None => False
  None => match lookupAssoc name (ctorTable e)
    Some _ => True
    None => False

-- ── record field-order table (slice 5a) ─────────────────────────────────────
-- maps record-type-name -> [field-names-in-declaration-order].  Built up front
-- in emitProgram by scanning all CRecord nodes in the program's CBind groups.
-- CFieldAccess uses it to convert a label name to a positional index so the
-- field can be reached by loadField without carrying type information.
recFieldTable : Emit -> <Mut> List (String, List String)
recFieldTable (Emit _ _ _ _ _ _ rt _ _ _) = rt.value

-- ── impl table (slice 6) ────────────────────────────────────────────────────
-- the program's CImplEntry list (set once in emitProgram).  A CMethod site reads
-- it two ways: `implFor` resolves an RKey-narrowed route to the ONE concrete impl
-- it names (a direct call to that impl's lifted fn); `implsOf` returns every
-- tagged impl of a method (the runtime RDict/RDictFwd dispatch-switch arms).
implEntriesOf : Emit -> <Mut> List CImplEntry
implEntriesOf (Emit _ _ _ _ _ _ _ ie _ _) = ie.value

-- the impls of a method, in program order — only the CImplTagged ones (an
-- untagged CImplDefault is the arg-tag fallback, never a static-dispatch target).
implsOf : Emit -> String -> <Mut> List CImplEntry
implsOf e method = filterTagged method (implEntriesOf e)

filterTagged : String -> List CImplEntry -> List CImplEntry
filterTagged _ [] = []
filterTagged method ((CImplEntry n s (CImplTagged tag iface ps pats body))::rest)
  | n == method = (CImplEntry n s (CImplTagged tag iface ps pats body)) :: filterTagged method rest
  | otherwise = filterTagged method rest
filterTagged method (_::rest) = filterTagged method rest

-- the single tagged impl an RKey route names: the CImplTagged of `method` whose
-- type-head tag equals `tag`.  None ⇒ the route named an impl not in the program
-- (an internal error — the typechecker only stamps tags it resolved an impl for).
implFor : Emit -> String -> String -> <Mut> Option CImplEntry
implFor e method tag = findByTag tag (implsOf e method)
findByTag : String -> List CImplEntry -> Option CImplEntry
findByTag _ [] = None
findByTag tag ((CImplEntry n s (CImplTagged t iface ps pats body))::rest)
  | t == tag = Some (CImplEntry n s (CImplTagged t iface ps pats body))
  | otherwise = findByTag tag rest
findByTag tag (_::rest) = findByTag tag rest

-- the interface DEFAULT entry (CImplDefault) for a method: the untagged body the
-- interface declared and the type's `impl` did not override.  None ⇒ no default
-- (the method has no default body — a genuine missing-impl error).
defaultFor : Emit -> String -> <Mut> Option CImplEntry
defaultFor e method = findDefault method (implEntriesOf e)

findDefault : String -> List CImplEntry -> Option CImplEntry
findDefault _ [] = None
findDefault method ((CImplEntry n s (CImplDefault pats body))::rest)
  | n == method = Some (CImplEntry n s (CImplDefault pats body))
  | otherwise = findDefault method rest
findDefault method (_::rest) = findDefault method rest

-- the lifted LLVM name of an interface default method (E19): `mdk_default_<method>_<tag>`.
-- A default is emitted only on the CONCRETE RKey path (`filter`@List), keyed per
-- (method, tag) — its inner same-interface calls are re-stamped to that tag, so
-- distinct dispatch types need distinct defines.
defaultFnName : String -> String -> String
defaultFnName tag method = "mdk_default_" ++ method ++ "_" ++ tag

-- the lifted LLVM name of a tagged impl method: `mdk_impl_<tag>_<method>`.  Type
-- heads and method names are alphanumeric identifiers (an operator like `+` is a
-- `CBinPrim`, never a method name here), so the concatenation is always a legal
-- LLVM symbol — clang would reject it loudly otherwise, which the gate catches.
implFnName : String -> String -> String
implFnName tag method = "mdk_impl_" ++ tag ++ "_" ++ method

-- the distinct method names of the program's tagged impls (slice 7).  A bare CVar
-- naming one of these, applied to args, is an arg-position dispatch site (return-
-- position methods are CMethod nodes, never a bare applied CVar — so this set is
-- exactly the arg-dispatched methods at a call site).
implMethodNames : Emit -> <Mut> List String
implMethodNames e = dedupS (taggedMethodNames (implEntriesOf e))

taggedMethodNames : List CImplEntry -> List String
taggedMethodNames [] = []
taggedMethodNames ((CImplEntry m _ (CImplTagged _ _ _ _ _))::rest) = m :: taggedMethodNames rest
taggedMethodNames (_::rest) = taggedMethodNames rest

isImplMethod : Emit -> String -> <Mut> Bool
isImplMethod e name = containsStr name (implMethodNames e)

-- the parameter patterns + body of an impl entry (CImplTagged or CImplDefault).
implPats : CImplEntry -> List Pat
implPats (CImplEntry _ _ (CImplTagged _ _ _ pats _)) = pats
implPats (CImplEntry _ _ (CImplDefault pats _)) = pats

implBody : CImplEntry -> CExpr
implBody (CImplEntry _ _ (CImplTagged _ _ _ _ body)) = body
implBody (CImplEntry _ _ (CImplDefault _ body)) = body

implEntryTag : CImplEntry -> String
implEntryTag (CImplEntry _ _ (CImplTagged tag _ _ _ _)) = tag
implEntryTag (CImplEntry _ _ (CImplDefault _ _)) = ""

implEntryMethod : CImplEntry -> String
implEntryMethod (CImplEntry n _ _) = n

-- ── ctor→type map (slice 7) ─────────────────────────────────────────────────
-- the program's constructor→type-name map (CProgram's 3rd field).  An arg-tag
-- dispatch loads the discriminating argument's constructor tag at run time; this
-- map names the constructors each candidate TYPE owns, so the dispatch chain can
-- test "is the loaded ctor tag one of type T's constructors?" by OR-ing the
-- hashName of each.
ctorTypeTable : Emit -> <Mut> List (String, String)
ctorTypeTable (Emit _ _ _ _ _ _ _ _ ctt _) = ctt.value

-- ── globals registry (slice E1b) ────────────────────────────────────────────
-- the top-level value/`Ref` globals registry ref: `name -> (initialised?, LTy)`.
-- `emitVar` consults it (via lookupVarG) to lower a value-binding reference to a
-- `load i64, ptr @mdk_g_<name>`; the `@main` init prologue computes each rhs in
-- source order and flips its flag, so a forward/mutual init dependency is caught.
globalsRegRef : Emit -> Ref (List (String, (Bool, LTy)))
globalsRegRef (Emit _ _ _ _ _ _ _ _ _ gr) = gr

-- mark a global initialised, recording the static type its rhs computed to.  Drops
-- any prior (uninitialised) entry for the name and prepends the resolved one.
markGlobalInit : Emit -> String -> LTy -> <Mut> Unit
markGlobalInit e name ty =
  let gr = globalsRegRef e
  set_ref gr ((name, (True, ty)) :: dropAssoc name gr.value)

-- drop the first entry keyed `k` from an assoc list (keeps the rest in order).
dropAssoc : String -> List (String, (Bool, LTy)) -> List (String, (Bool, LTy))
dropAssoc _ [] = []
dropAssoc k ((n, v)::rest) = if n == k then rest else (n, v) :: dropAssoc k rest


-- the constructor names owned by a type, in program order.
ctorsOfType : Emit -> String -> <Mut> List String
ctorsOfType e ty = ctorsOfTypeIn ty (ctorTypeTable e)

ctorsOfTypeIn : String -> List (String, String) -> List String
ctorsOfTypeIn _ [] = []
ctorsOfTypeIn ty ((c, t)::rest)
  | t == ty = c :: ctorsOfTypeIn ty rest
  | otherwise = ctorsOfTypeIn ty rest


containsStr : String -> List String -> Bool
containsStr _ [] = False
containsStr x (y::ys) = if x == y then True else containsStr x ys

-- ── tag / box helpers (the value-representation, made concrete) ──────────────
-- untag an immediate int word -> raw i64 (arithmetic shift, preserves sign).
untagInt : Emit -> String -> <Mut> String
untagInt e v =
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = ashr i64 " ++ v ++ ", 1")
  r

-- tag a raw i64 -> immediate int word ((x << 1) | 1).
tagInt : Emit -> String -> <Mut> String
tagInt e v =
  let s = freshReg e
  let _ = emit e ("  " ++ s ++ " = shl i64 " ++ v ++ ", 1")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = or i64 " ++ s ++ ", 1")
  r

-- box a double -> a heap cell {i64 header, double}; word = pointer-as-i64.
boxFloat : Emit -> String -> <Mut> String
boxFloat e d =
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = call ptr @mdk_alloc(i64 16)")
  let _ = emit e ("  store i64 2, ptr " ++ p)
  let dp = freshReg e
  let _ = emit e ("  " ++ dp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 8")
  let _ = emit e ("  store double " ++ d ++ ", ptr " ++ dp)
  let w = freshReg e
  let _ = emit e ("  " ++ w ++ " = ptrtoint ptr " ++ p ++ " to i64")
  w

-- unbox a float word -> the stored double.
unboxFloat : Emit -> String -> <Mut> String
unboxFloat e v =
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = inttoptr i64 " ++ v ++ " to ptr")
  let dp = freshReg e
  let _ = emit e ("  " ++ dp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 8")
  let d = freshReg e
  let _ = emit e ("  " ++ d ++ " = load double, ptr " ++ dp)
  d

-- ── expressions ─────────────────────────────────────────────────────────────
emitExpr : Emit -> List (String, (String, LTy)) -> CExpr -> <Mut> (String, LTy)
emitExpr e _ (CLit l) = emitLit e l
emitExpr e env (CVar x _) = emitVar e env x
emitExpr e env (CBinPrim op l r) = emitBin e env op l r
emitExpr e env (CUnOp op x) = emitUn e env op x
emitExpr e env (CIf c t f) = emitIf e env c t f
emitExpr e env (CLet recF pat e1 e2) = emitLet e env recF pat e1 e2
emitExpr e env (CLetGroup binds body) = emitLetGroup e env binds body
emitExpr e env (CBlock stmts) = emitBlock e env stmts
emitExpr e env (CApp f a) = emitApp e env (CApp f a)
emitExpr e env (CLam pats body) = emitLam e env pats body
emitExpr e env (CDecision scrut arms tree) = emitDecision e env scrut arms tree
emitExpr e env (CTuple es) = emitTuple e env es
emitExpr e env (CRecord name fields) = emitRecordCreate e env name fields
emitExpr e env (CFieldAccess ex label) = emitFieldAccess e env ex label
emitExpr e env (CRecordUpdate base updates) = emitRecordUpdate e env base updates
emitExpr e env (CVariantUpdate con base updates) = emitVariantUpdate e env con base updates
emitExpr e env (CMethod name route implRoutes methRoutes) = emitMethodValue e env name route implRoutes methRoutes
emitExpr e env (CArray es) = emitArrayCreate e env es
emitExpr e env (CRangeArray lo hi incl) = emitRangeArray e env lo hi incl
emitExpr e env (CIndex a i) = emitArrayIndex e env a i
emitExpr e env (CSlice a lo hi incl) = emitArraySlice e env a lo hi incl
emitExpr e env (CList es) = emitList e env es
emitExpr e env (CRangeList lo hi incl) = emitRangeList e env lo hi incl
emitExpr _ _ other = gapE ("unsupported Core IR node " ++ ctag other)

-- a variable occurrence: a bare constructor name (slice 3) is a NULLARY ADT value
-- → allocate its heap cell; a bare KNOWN top-level FUNCTION name used as a VALUE
-- (slice 4 — not the head of a saturated call) must become a closure, so eta-wrap
-- it into a captureless static closure forwarding to `@mdk_<name>`; anything else
-- is a let/param-bound local operand.
--
-- The math/bound constants (`pi`/`e`/`intMaxBound`/…) are ordinary PRELUDE
-- bindings, so a LOCAL of the same name must shadow them — check the local env
-- FIRST for those.  (`True`/`False`/`otherwise` and constructors are reserved
-- value keywords a local can never rebind, so they stay ahead of the env check.)
-- This matters for real code: the self-hosted lexer uses `e` as a parameter name
-- pervasively (`let e = identEnd …`); intercepting it as Euler's number wrecked
-- every `substr … e` call (B1 bootstrap bug).
emitVar : Emit -> List (String, (String, LTy)) -> String -> <Mut> (String, LTy)
emitVar e env x =
  if x == "True" then ("3", LTBool)
  else if x == "False" then ("1", LTBool)
  else if x == "otherwise" then ("3", LTBool)
  else if isLocal env x then lookupVarG e env x
  else if x == "pi" then (boxFloat e "3.141592653589793", LTFloat)
  else if x == "e" then (boxFloat e "2.718281828459045", LTFloat)
  else if x == "intMaxBound" then ("9223372036854775807", LTInt)
  else if x == "intMinBound" then ("-9223372036854775807", LTInt)
  else if x == "charMinBound" then ("1", LTChar)
  else if x == "charMaxBound" then ("2228223", LTChar)
  else if isCtor e x then
    if ctorArity e x == 0 then emitCtorAlloc e x []
    else emitCtorEtaClosure e x
  else if isKnownFn e x then emitEtaClosure e x
  else if isAnyExtern x then emitExternEtaClosure e x
  else if isImplMethod e x then emitMethodEtaClosure e x
  else lookupVarG e env x

-- is `x` a local (let/param) binding in the current emit env?  Used to let a local
-- shadow the prelude math/bound constants (pi/e/intMaxBound/…) above.
isLocal : List (String, (String, LTy)) -> String -> Bool
isLocal env x = match lookupAssoc x env
  Some _ => True
  None => False

-- a Mut-aware variable lookup used at the emit site (emitVar): a local (let/param)
-- operand shadows everything, so the env is checked FIRST; otherwise the name may
-- be a top-level value/`Ref` global (slice E1b) → emit a `load i64, ptr @mdk_g_<x>`
-- (referenceable from any `define`).  A global that the source-order init prologue
-- has NOT yet computed (a forward/mutual init dependency) records a precise gap
-- rather than loading an uninitialised 0.  When gap-recording is on, a genuinely
-- unbound variable records a gap and returns a placeholder instead of aborting (the
-- dict/internal callers keep the pure `lookupVar` panic).
lookupVarG : Emit -> List (String, (String, LTy)) -> String -> <Mut> (String, LTy)
lookupVarG e env x = match lookupAssoc x env
  Some vt => vt
  None => match lookupAssoc x (globalsRegRef e).value
    Some (True, ty) =>
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = load i64, ptr @mdk_g_" ++ x)
      (r, ty)
    -- A not-yet-initialised global is still loaded from its `@mdk_g_<name>` cell:
    -- the `load` resolves at the instruction's RUNTIME, not emit time.  Two cases
    -- reach here, both correct as a deferred load.  (1) A reference INSIDE A LAMBDA
    -- body emitted during an enclosing global's init (`stmtsCons`'s continuation
    -- closes over `stmtsLoop`, defined later): the closure runs only at parse time,
    -- long after every global is initialised, so the load sees the real value — a
    -- gap-`0` here would bake a permanent null into the closure and crash.  (2) An
    -- eager same-init forward ref: orderedValBinds topologically sorts eager
    -- dependencies, so a surviving eager forward ref is a genuine value cycle (none
    -- arise in practice) and the cell still holds 0 — but that is exactly the
    -- interpreter's recursive-value semantics, not an emit-time error.  Either way
    -- the cell exists (declared `@mdk_g_<name> = global i64 0` up front), so emit
    -- the load.  LTy is unknown until init computes it; default LTInt (the loaded
    -- word is a uniform i64 — a downstream container op re-derives its shape).
    Some (False, _) =>
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = load i64, ptr @mdk_g_" ++ x)
      (r, LTInt)
    None => gapE ("unbound variable '" ++ x ++ "' (not a local, ctor, or known fn)")

emitLit : Emit -> Lit -> <Mut> (String, LTy)
emitLit _ (LInt n) = (intToString (n * 2 + 1), LTInt)
emitLit _ (LBool b) = (if b then "3" else "1", LTBool)
emitLit e (LFloat f) =
  let w = boxFloat e (floatToString f)
  (w, LTFloat)
-- a String literal (native extern catalog slice 1): emit a private module-scope
-- byte-array global for the UTF-8 bytes and box it at run time via @mdk_str_lit
-- (which caches the codepoint count, RUNTIME-DESIGN.md §4).  Bytes are escaped
-- one-per-`\HH` so the LLVM `c"…"` constant is byte-faithful to the source.
emitLit e (LString s) =
  let bytes = strBytes s
  let n = lengthS bytes
  let gid = ".str." ++ intToString (freshId e)
  let _ = emitGlobal e ("@" ++ gid ++ " = private unnamed_addr constant [" ++ intToString n ++ " x i8] c\"" ++ escBytes bytes ++ "\"")
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = call i64 @mdk_str_lit(ptr @" ++ gid ++ ", i64 " ++ intToString n ++ ")")
  (p, LTStr)
emitLit _ (LChar c) =
  let cp = charCode (arrayGetUnsafe 0 (stringToChars c))
  (intToString (cp * 2 + 1), LTChar)
emitLit _ LUnit = ("1", LTUnit)
emitLit _ _ = gapE "non-Int/Float/Bool/String/Char/Unit literal (slice 1)"

lookupVar : List (String, (String, LTy)) -> String -> (String, LTy)
lookupVar [] x = panic ("llvm spike: unbound variable " ++ x)
lookupVar ((n, vt)::rest) x = if n == x then vt else lookupVar rest x

-- ── string literals + string externs (native extern catalog slice 1) ─────────
-- emit a module-scope line (a private string-literal global) into the side buffer
-- the lifted-lambda defines also use — LLVM module-item order is irrelevant, so a
-- `@.str.N = … constant …` appended after @main is sound (same discipline as the
-- lifted `define`s).
emitGlobal : Emit -> String -> <Mut> Unit
emitGlobal e line = set_ref (lamsRef e) (line :: (lamsRef e).value)

-- the raw UTF-8 bytes of a string literal, in order.  `stringToChars` yields the
-- source codepoints; `utf8Bytes` re-encodes each to its UTF-8 byte sequence, so the
-- emitted global is byte-faithful to the source whatever the codepoints' width.
strBytes : String -> List Int
strBytes s = strBytesGo (stringToChars s) 0

strBytesGo : Array Char -> Int -> List Int
strBytesGo cs i
  | i >= arrayLength cs = []
  | otherwise = utf8Bytes (charCode (arrayGetUnsafe i cs)) ++ strBytesGo cs (i + 1)

-- encode one Unicode codepoint to its UTF-8 bytes (0..255).  The bit fields are
-- disjoint, so `or` is `+` and the masks are `% 64`; no bitwise primitive needed.
utf8Bytes : Int -> List Int
utf8Bytes cp
  | cp < 128 = [cp]
  | cp < 2048 = [192 + (cp / 64), 128 + (cp % 64)]
  | cp < 65536 = [224 + (cp / 4096), 128 + ((cp / 64) % 64), 128 + (cp % 64)]
  | otherwise = [240 + (cp / 262144), 128 + ((cp / 4096) % 64), 128 + ((cp / 64) % 64), 128 + (cp % 64)]

-- escape a byte list for an LLVM `c"…"` constant: EVERY byte as `\HH` (uppercase
-- hex).  Always valid (no quoting edge cases) and exact — the constant's declared
-- length is the byte count, and mdk_str_lit copies exactly that many bytes.
escBytes : List Int -> String
escBytes [] = ""
escBytes (b::rest) = "\\" ++ hex2 b ++ escBytes rest

hex2 : Int -> String
hex2 b = hexDigit (b / 16) ++ hexDigit (b % 16)

hexDigit : Int -> String
hexDigit d
  | d < 10 = intToString d
  | d == 10 = "A"
  | d == 11 = "B"
  | d == 12 = "C"
  | d == 13 = "D"
  | d == 14 = "E"
  | otherwise = "F"

-- the string-returning leaf externs the spike lowers to direct C-ABI calls
-- (RUNTIME-DESIGN.md §5 LEAF).  `intToString` is the first: it proves the §2a
-- contract that an extern returning a Medaka value allocates it in the GC heap
-- (mdk_int_to_string -> mdk_str_lit -> mdk_alloc).  charToStr/stringConcat/putStr
-- are the obvious next additions (a follow-on slice).
isStrExtern : String -> Bool
isStrExtern name = containsStr name ["intToString", "stringConcat", "stringLength"]

emitStrExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitStrExtern e env "intToString" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_int_to_string(i64 " ++ a ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: intToString takes exactly one argument (slice 1)"
emitStrExtern e env "stringConcat" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_concat(i64 " ++ a ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: stringConcat takes one argument (slice 5)"
emitStrExtern e env "stringLength" args = match emitArgs e env args
  [a] =>                                    -- INTRINSIC: load cp_count@16, tag it
    let p = freshReg e
    let _ = emit e ("  " ++ p ++ " = inttoptr i64 " ++ a ++ " to ptr")
    let cpp = freshReg e
    let _ = emit e ("  " ++ cpp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 16")
    let n = freshReg e
    let _ = emit e ("  " ++ n ++ " = load i64, ptr " ++ cpp)
    (tagInt e n, LTInt)
  _ => panic "llvm spike: stringLength takes one argument (slice 5)"
emitStrExtern _ _ name _ = gapE ("unsupported string extern " ++ name)

-- numeric conversion externs (native extern catalog slice 2).
-- intToFloat / floatToInt are INTRINSIC: inline sitofp / fptosi + box/untag.
-- floatToString is a LEAF: delegates to mdk_float_to_string (mirrors mdk_print_float's
-- %.12g+dot logic but returns a mdk_str_lit box instead of printf-ing).
isNumExtern : String -> Bool
isNumExtern name = containsStr name ["intToFloat", "floatToInt", "floatToString"]

emitNumExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitNumExtern e env "intToFloat" args = match emitArgs e env args
  [a] =>
    let i = untagInt e a
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = sitofp i64 " ++ i ++ " to double")
    (boxFloat e r, LTFloat)
  _ => panic "llvm spike: intToFloat takes exactly one argument (slice 2)"
emitNumExtern e env "floatToInt" args = match emitArgs e env args
  [a] =>
    let d = unboxFloat e a
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = fptosi double " ++ d ++ " to i64")
    (tagInt e r, LTInt)
  _ => panic "llvm spike: floatToInt takes exactly one argument (slice 2)"
emitNumExtern e env "floatToString" args = match emitArgs e env args
  [a] =>
    let d = unboxFloat e a
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_float_to_string(double " ++ d ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: floatToString takes exactly one argument (slice 2)"
emitNumExtern _ _ name _ = gapE ("unsupported numeric extern " ++ name)

-- IO-output externs (native extern catalog slice 3).
-- putStr/putStrLn write to stdout; ePutStr/ePutStrLn write to stderr.
-- All return Unit (LTUnit); the operand "1" is an arbitrary immediate never read.
isIoExtern : String -> Bool
isIoExtern name = containsStr name ["putStr", "putStrLn", "ePutStr", "ePutStrLn", "flushStdout"]

emitIoExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitIoExtern e env "putStr" args = match emitArgs e env args
  [s] =>
    let _ = emit e ("  call void @mdk_putstr(i64 " ++ s ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: putStr takes exactly one argument (slice 3)"
emitIoExtern e env "putStrLn" args = match emitArgs e env args
  [s] =>
    let _ = emit e ("  call void @mdk_putstrln(i64 " ++ s ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: putStrLn takes exactly one argument (slice 3)"
emitIoExtern e env "ePutStr" args = match emitArgs e env args
  [s] =>
    let _ = emit e ("  call void @mdk_eputstr(i64 " ++ s ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: ePutStr takes exactly one argument (slice 3)"
emitIoExtern e env "ePutStrLn" args = match emitArgs e env args
  [s] =>
    let _ = emit e ("  call void @mdk_eputstrln(i64 " ++ s ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: ePutStrLn takes exactly one argument (slice 3)"
emitIoExtern e env "flushStdout" args = match emitArgs e env args
  [u] =>
    let _ = emit e ("  call void @mdk_flushstdout(i64 " ++ u ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: flushStdout takes exactly one argument (slice 3)"
emitIoExtern _ _ name _ = gapE ("unsupported IO extern " ++ name)

-- abort externs (native extern catalog slice 4).
-- panic/exit terminate the process; the call itself never returns, so the
-- auto-print emitted downstream is dead code.  Return ("1", LTUnit) so
-- emitPrint sees LTUnit (safe) rather than LTCon/LTClosure (compile panic).
isAbortExtern : String -> Bool
isAbortExtern name = containsStr name ["panic", "exit"]

emitAbortExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitAbortExtern e env name args = match emitArgs e env args
  [a] =>
    let cname = if name == "panic" then "panic" else "exit"
    let _ = emit e ("  call void @mdk_" ++ cname ++ "(i64 " ++ a ++ ")")
    ("1", LTUnit)
  _ => panic ("llvm spike: emitAbortExtern: " ++ name ++ " takes exactly one argument (slice 4)")

-- array intrinsics (native extern catalog slice 6).
-- pure-inline: no C helper; all three reuse loadTag/loadFieldDyn/storeFieldDyn.
-- arrayLength: header word = raw element count; tag it as a Medaka Int.
-- arrayGetUnsafe: CIndex path minus bounds-check.
-- arraySetUnsafe: store to element slot; returns Unit.
isArrIntrinsic : String -> Bool
isArrIntrinsic name = containsStr name ["arrayLength", "arrayGetUnsafe", "arraySetUnsafe"]

emitArrIntrinsic : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitArrIntrinsic e env "arrayLength" args = match emitArgs e env args
  [arr] => (tagInt e (loadTag e arr), LTInt)
  _ => panic "llvm spike: arrayLength takes one argument (slice 6)"
emitArrIntrinsic e env "arrayGetUnsafe" args = match emitArgs e env args
  [i, arr] =>
    let idx_raw = untagInt e i
    (loadFieldDyn e arr idx_raw, LTInt)
  _ => panic "llvm spike: arrayGetUnsafe takes two arguments (slice 6)"
emitArrIntrinsic e env "arraySetUnsafe" args = match emitArgs e env args
  [i, x, arr] =>
    let idx_raw = untagInt e i
    let _ = storeFieldDyn e arr idx_raw x
    ("1", LTUnit)
  _ => panic "llvm spike: arraySetUnsafe takes three arguments (slice 6)"
emitArrIntrinsic _ _ name _ = gapE ("unsupported array intrinsic " ++ name)

-- array leaf externs (native extern catalog slice 7).
-- C helpers in runtime/medaka_rt.c; array cell = [i64 count | elem@8 | ...].
-- arrayMake/arrayCopy/arrayFromList return Array (LTCon); arrayBlit/arrayFill return Unit.
-- Do NOT end a fixture with an array-returning call: emitPrint LTCon panics.
-- Project to scalar via .[i] (CIndex) in every fixture.
isArrLeafExtern : String -> Bool
isArrLeafExtern name = containsStr name
  ["arrayMake", "arrayCopy", "arrayBlit", "arrayFill", "arrayFromList"]

emitArrLeafExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitArrLeafExtern e env "arrayMake" args = match emitArgs e env args
  [n, x] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_array_make(i64 " ++ n ++ ", i64 " ++ x ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: arrayMake takes two arguments (slice 7)"
emitArrLeafExtern e env "arrayCopy" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_array_copy(i64 " ++ a ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: arrayCopy takes one argument (slice 7)"
emitArrLeafExtern e env "arrayFromList" args = match emitArgs e env args
  [l] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_array_from_list(i64 " ++ l ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: arrayFromList takes one argument (slice 7)"
emitArrLeafExtern e env "arrayBlit" args = match emitArgs e env args
  [src, so, dst, dof, len] =>
    let _ = emit e ("  call void @mdk_array_blit(i64 " ++ src ++ ", i64 " ++ so ++
      ", i64 " ++ dst ++ ", i64 " ++ dof ++ ", i64 " ++ len ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: arrayBlit takes five arguments (slice 7)"
emitArrLeafExtern e env "arrayFill" args = match emitArgs e env args
  [x, arr] =>
    let _ = emit e ("  call void @mdk_array_fill(i64 " ++ x ++ ", i64 " ++ arr ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: arrayFill takes two arguments (slice 7)"
emitArrLeafExtern _ _ name _ = gapE ("unsupported array leaf extern " ++ name)

-- char scalar externs (native extern catalog slice 8).
-- charCode is INTRINSIC: Char and Int share the same tagged word encoding, so
-- charCode is a pure re-type — emit the operand as-is and return LTInt.
-- charToStr delegates to mdk_char_to_str (runtime/medaka_rt.c).
isCharExtern : String -> Bool
isCharExtern name = containsStr name ["charCode", "charToStr"]

emitCharExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitCharExtern e env "charCode" args = match emitArgs e env args
  [a] => (a, LTInt)
  _ => panic "llvm spike: charCode takes one argument (slice 8)"
emitCharExtern e env "charToStr" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_char_to_str(i64 " ++ a ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: charToStr takes one argument (slice 8)"
emitCharExtern _ _ name _ = gapE ("unsupported char extern " ++ name)

-- slice 9: string↔char conversions + codepoint slicing.
isStrCharExtern : String -> Bool
isStrCharExtern name =
  containsStr name ["stringToChars", "stringFromChars", "stringSlice"]

emitStrCharExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitStrCharExtern e env "stringToChars" args = match emitArgs e env args
  [s] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_to_chars(i64 " ++ s ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: stringToChars takes one argument (slice 9)"
emitStrCharExtern e env "stringFromChars" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_from_chars(i64 " ++ a ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: stringFromChars takes one argument (slice 9)"
emitStrCharExtern e env "stringSlice" args = match emitArgs e env args
  [lo, hi, s] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_slice(i64 " ++ lo ++
      ", i64 " ++ hi ++ ", i64 " ++ s ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: stringSlice takes three arguments (slice 9)"
emitStrCharExtern _ _ name _ = gapE ("unsupported str-char extern " ++ name)

-- slice 14: ASCII char classification + case mapping (unicode subset).
-- Predicate externs return raw 0/1 from C; emitter wraps with tagInt to Bool.
-- charIsPunct matches Unicode Pc/Pd/Pe/Pf/Pi/Po/Ps for ASCII (NOT C ispunct —
-- symbols like + $ = ^ ` | ~ are excluded).
isUnicodeExtern : String -> Bool
isUnicodeExtern name = containsStr name
  ["charIsAlpha", "charIsSpace", "charIsUpper", "charIsLower", "charIsPunct",
   "charToUpper", "charToLower", "stringToUpper", "stringToLower"]

emitUnicodeExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitUnicodeExtern e env "charIsAlpha" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_char_is_alpha(i64 " ++ a ++ ")")
    (tagInt e r, LTBool)
  _ => panic "llvm spike: charIsAlpha takes one argument (slice 14)"
emitUnicodeExtern e env "charIsSpace" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_char_is_space(i64 " ++ a ++ ")")
    (tagInt e r, LTBool)
  _ => panic "llvm spike: charIsSpace takes one argument (slice 14)"
emitUnicodeExtern e env "charIsUpper" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_char_is_upper(i64 " ++ a ++ ")")
    (tagInt e r, LTBool)
  _ => panic "llvm spike: charIsUpper takes one argument (slice 14)"
emitUnicodeExtern e env "charIsLower" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_char_is_lower(i64 " ++ a ++ ")")
    (tagInt e r, LTBool)
  _ => panic "llvm spike: charIsLower takes one argument (slice 14)"
emitUnicodeExtern e env "charIsPunct" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_char_is_punct(i64 " ++ a ++ ")")
    (tagInt e r, LTBool)
  _ => panic "llvm spike: charIsPunct takes one argument (slice 14)"
emitUnicodeExtern e env "charToUpper" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_char_to_upper(i64 " ++ a ++ ")")
    (r, LTChar)
  _ => panic "llvm spike: charToUpper takes one argument (slice 14)"
emitUnicodeExtern e env "charToLower" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_char_to_lower(i64 " ++ a ++ ")")
    (r, LTChar)
  _ => panic "llvm spike: charToLower takes one argument (slice 14)"
emitUnicodeExtern e env "stringToUpper" args = match emitArgs e env args
  [s] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_to_upper(i64 " ++ s ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: stringToUpper takes one argument (slice 14)"
emitUnicodeExtern e env "stringToLower" args = match emitArgs e env args
  [s] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_to_lower(i64 " ++ s ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: stringToLower takes one argument (slice 14)"
emitUnicodeExtern _ _ name _ = gapE ("unsupported unicode extern " ++ name)

-- slice 10: ADT-RETURNING externs (precursor canary).  The C side constructs the
-- result cell with the reserved tags (see `reservedTag` / runtime mdk_some etc.), so
-- a later `match` agrees.  `charFromCode` is the canary — it proves both the boxed
-- (`Some`) and immediate (`None`) reserved-tag round-trips end-to-end.  Slices 11/12/
-- 13 extend this family (stringToFloat, args, readFile, …).  Result is LTCon (an ADT
-- value): never auto-printed — fixtures `match` it down to a scalar.
isAdtExtern : String -> Bool
isAdtExtern name = containsStr name ["charFromCode", "stringToFloat", "stringIndexOf", "stringCompare"]

emitAdtExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitAdtExtern e env "charFromCode" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_char_from_code(i64 " ++ a ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: charFromCode takes one argument (slice 10)"
emitAdtExtern e env "stringToFloat" args = match emitArgs e env args
  [s] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_to_float(i64 " ++ s ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: stringToFloat takes one argument (slice 11)"
emitAdtExtern e env "stringIndexOf" args = match emitArgs e env args
  [n, h] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_index_of(i64 " ++ n ++ ", i64 " ++ h ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: stringIndexOf takes two arguments (slice 11)"
emitAdtExtern e env "stringCompare" args = match emitArgs e env args
  [a, b] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_compare(i64 " ++ a ++ ", i64 " ++ b ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: stringCompare takes two arguments (slice 11)"
emitAdtExtern _ _ name _ = gapE ("unsupported adt extern " ++ name)

-- slice 12: args + env externs.  `args ()` → List String of argv[1..];
-- `getEnv name` → Option String.  Results are LTCon — never auto-printed.
isEnvExtern : String -> Bool
isEnvExtern name = containsStr name ["args", "getEnv"]

emitEnvExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitEnvExtern e env "args" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_args(i64 " ++ u ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: args takes one (Unit) argument (slice 12)"
emitEnvExtern e env "getEnv" args = match emitArgs e env args
  [n] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_get_env(i64 " ++ n ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: getEnv takes one argument (slice 12)"
emitEnvExtern _ _ name _ = gapE ("unsupported env extern " ++ name)

-- slice 13: file IO + stdin externs.  Result/Option/List returns are LTCon;
-- fileExists returns raw 0/1 which the emitter tags (LTBool); readLine/readAll
-- return heap Strings (LTStr).  readLine/readLineOpt/readAll are implemented
-- but NOT fixtured — the gate does not pipe stdin.
isFileExtern : String -> Bool
isFileExtern name = containsStr name
  ["readFile", "writeFile", "appendFile", "fileExists", "listDir",
   "readLine", "readLineOpt", "readAll", "readExactly", "makeDir", "runCommand"]

emitFileExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitFileExtern e env "readFile" args = match emitArgs e env args
  [p] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_read_file(i64 " ++ p ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: readFile takes one argument (slice 13)"
emitFileExtern e env "writeFile" args = match emitArgs e env args
  [p, c] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_write_file(i64 " ++ p ++ ", i64 " ++ c ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: writeFile takes two arguments (slice 13)"
emitFileExtern e env "appendFile" args = match emitArgs e env args
  [p, c] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_append_file(i64 " ++ p ++ ", i64 " ++ c ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: appendFile takes two arguments (slice 13)"
emitFileExtern e env "fileExists" args = match emitArgs e env args
  [p] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_file_exists(i64 " ++ p ++ ")")
    (tagInt e r, LTBool)
  _ => panic "llvm spike: fileExists takes one argument (slice 13)"
emitFileExtern e env "listDir" args = match emitArgs e env args
  [p] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_list_dir(i64 " ++ p ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: listDir takes one argument (slice 13)"
emitFileExtern e env "readLine" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_read_line(i64 " ++ u ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: readLine takes one (Unit) argument (slice 13)"
emitFileExtern e env "readLineOpt" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_read_line_opt(i64 " ++ u ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: readLineOpt takes one (Unit) argument (slice 13)"
emitFileExtern e env "readAll" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_read_all(i64 " ++ u ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: readAll takes one (Unit) argument (slice 13)"
emitFileExtern e env "readExactly" args = match emitArgs e env args
  [n] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_read_exactly(i64 " ++ n ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: readExactly takes one (Int) argument"
emitFileExtern e env "makeDir" args = match emitArgs e env args
  [p] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_make_dir(i64 " ++ p ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: makeDir takes one argument (slice 13)"
emitFileExtern e env "runCommand" args = match emitArgs e env args
  [prog, argv] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_run_command(i64 " ++ prog ++ ", i64 " ++ argv ++ ")")
    (r, LTCon)
  _ => panic "llvm spike: runCommand takes two arguments (slice 13)"
emitFileExtern _ _ name _ = gapE ("unsupported file extern " ++ name)

-- Tier D: RNG (deterministic SplitMix64).  The C runtime holds the state; the
-- algorithm matches lib/eval.ml splitmix64_next, seeded identically, so output is
-- byte-identical per seed.  randomInt/Bool/Char return RAW words tagged here;
-- randomFloat returns a boxed Float word; setSeed is Unit.
isRngExtern : String -> Bool
isRngExtern name =
  containsStr name ["randomInt", "randomBool", "randomFloat", "randomChar", "setSeed"]

emitRngExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitRngExtern e env "randomInt" args = match emitArgs e env args
  [lo, hi] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_random_int(i64 " ++ lo ++ ", i64 " ++ hi ++ ")")
    (tagInt e r, LTInt)
  _ => panic "llvm spike: randomInt takes two arguments (Tier D)"
emitRngExtern e env "randomBool" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_random_bool(i64 " ++ u ++ ")")
    (tagInt e r, LTBool)
  _ => panic "llvm spike: randomBool takes one (Unit) argument (Tier D)"
emitRngExtern e env "randomFloat" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_random_float(i64 " ++ u ++ ")")
    (r, LTFloat)
  _ => panic "llvm spike: randomFloat takes one (Unit) argument (Tier D)"
emitRngExtern e env "randomChar" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_random_char(i64 " ++ u ++ ")")
    (tagInt e r, LTChar)
  _ => panic "llvm spike: randomChar takes one (Unit) argument (Tier D)"
emitRngExtern e env "setSeed" args = match emitArgs e env args
  [n] =>
    let _ = emit e ("  call void @mdk_set_seed(i64 " ++ n ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: setSeed takes one argument (Tier D)"
emitRngExtern _ _ name _ = gapE ("unsupported rng extern " ++ name)

-- Hashable per-type hashers (specified, byte-identical to lib/eval.ml hash_*).
-- Each unpacks the native arg the C helper wants (untagged int / codepoint /
-- unboxed double / String cell pointer) and tags the RAW Int result.  hashBool
-- untags the 0/1 bool word.  See runtime/medaka_rt.c mdk_hash_*.
isHashExtern : String -> Bool
isHashExtern name =
  containsStr name ["hashInt", "hashChar", "hashBool", "hashFloat", "hashString"]

emitHashExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitHashExtern e env "hashInt" args = match emitArgs e env args
  [a] =>
    let i = untagInt e a
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_hash_int(i64 " ++ i ++ ")")
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashInt takes one argument"
emitHashExtern e env "hashChar" args = match emitArgs e env args
  [a] =>
    let cp = untagInt e a
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_hash_char(i64 " ++ cp ++ ")")
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashChar takes one argument"
emitHashExtern e env "hashBool" args = match emitArgs e env args
  [a] =>
    let b = untagInt e a
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_hash_bool(i64 " ++ b ++ ")")
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashBool takes one argument"
emitHashExtern e env "hashFloat" args = match emitArgs e env args
  [a] =>
    let d = unboxFloat e a
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_hash_float(double " ++ d ++ ")")
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashFloat takes one argument"
emitHashExtern e env "hashString" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_hash_string(i64 " ++ a ++ ")")
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashString takes one argument"
emitHashExtern _ _ name _ = gapE ("unsupported hash extern " ++ name)

-- Debug-literal externs (byte-exact quoted/escaped rendering; no oracle change).
-- The String/Char arg word passes straight to the C helper (mdk_debug_*_lit
-- reads the cell / untags the codepoint); result is a heap String (LTStr).
isDebugLitExtern : String -> Bool
isDebugLitExtern name = containsStr name ["debugStringLit", "debugCharLit"]

emitDebugLitExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitDebugLitExtern e env "debugStringLit" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_debug_string_lit(i64 " ++ a ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: debugStringLit takes one argument"
emitDebugLitExtern e env "debugCharLit" args = match emitArgs e env args
  [a] =>
    let cp = untagInt e a
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_debug_char_lit(i64 " ++ cp ++ ")")
    (r, LTStr)
  _ => panic "llvm spike: debugCharLit takes one argument"
emitDebugLitExtern _ _ name _ = gapE ("unsupported debug-lit extern " ++ name)

-- ── extern dispatch: applied form ───────────────────────────────────────────
-- Is `name` a KNOWN extern of any family the emitter handles?  The OR of every
-- family predicate (plus the `arrayMakeWith` intrinsic, which has no `isXxx`
-- predicate — it is dispatched by exact name).  Drives both the saturated CApp
-- head path (emitExternApplied) and the value-position eta-wrap (emitVar →
-- emitExternEtaClosure); keeping the membership in ONE place means the two paths
-- can never disagree about what counts as an extern.
isAnyExtern : String -> Bool
isAnyExtern name =
  isStrExtern name || isNumExtern name || isIoExtern name || isAbortExtern name
  || isArrIntrinsic name || name == "arrayMakeWith" || isArrLeafExtern name
  || isCharExtern name || isStrCharExtern name || isUnicodeExtern name
  || isAdtExtern name || isEnvExtern name || isFileExtern name
  || isRngExtern name || isHashExtern name || isDebugLitExtern name

-- SATURATED extern application: route a known extern + its (non-empty) argument
-- list to the right family emitter.  Factored out of emitApp's CVar-head ladder
-- so that the VALUE-position eta-wrap (emitExternEtaClosure) can REPLAY the exact
-- applied-form codegen on synthetic `%argK` operands — value/applied byte-
-- consistency by construction, no parallel codegen to drift.  The family order is
-- the ladder's original order (behaviour-preserving; `arrayMakeWith` keeps its
-- exact-name slot ahead of the arrayLeaf family).  Caller guards `hasArgs args`.
emitExternApplied : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> <Mut> (String, LTy)
emitExternApplied e env fname args =
  if isStrExtern fname then emitStrExtern e env fname args
  else if isNumExtern fname then emitNumExtern e env fname args
  else if isIoExtern fname then emitIoExtern e env fname args
  else if isAbortExtern fname then emitAbortExtern e env fname args
  else if isArrIntrinsic fname then emitArrIntrinsic e env fname args
  else if fname == "arrayMakeWith" then emitArrayMakeWith e env args
  else if isArrLeafExtern fname then emitArrLeafExtern e env fname args
  else if isCharExtern fname then emitCharExtern e env fname args
  else if isStrCharExtern fname then emitStrCharExtern e env fname args
  else if isUnicodeExtern fname then emitUnicodeExtern e env fname args
  else if isAdtExtern fname then emitAdtExtern e env fname args
  else if isEnvExtern fname then emitEnvExtern e env fname args
  else if isFileExtern fname then emitFileExtern e env fname args
  else if isRngExtern fname then emitRngExtern e env fname args
  else if isHashExtern fname then emitHashExtern e env fname args
  else emitDebugLitExtern e env fname args

emitBin : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> <Mut> (String, LTy)
emitBin e env op l r
  | isCmpOp op = emitCmp e env op l r
  | isArithOp op = emitArith e env op l r
  | op == "::" =
    let (lv, _) = emitExpr e env l
    let (rv, _) = emitExpr e env r
    emitCtorAlloc e "Cons" [lv, rv]
  | op == "++" =
    let (lv, lty) = emitExpr e env l
    let (rv, _) = emitExpr e env r
    let r2 = freshReg e
    match lty
      LTStr =>
        let _ = emit e ("  " ++ r2 ++ " = call i64 @mdk_string_append(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
        (r2, LTStr)
      LTCon =>
        let _ = emit e ("  " ++ r2 ++ " = call i64 @mdk_list_append(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
        (r2, LTCon)
      -- LTUnknown: the left operand is itself a runtime-dispatched-append result
      -- (a CHAINED `++`, e.g. `a ++ b ++ c`).  Its kind is genuinely unknown — it
      -- may be a String OR a list (typecheck.mdk's `freeEffvars` builds `List Int`
      -- this way).  Re-route through @mdk_append (NOT a direct @mdk_string_append,
      -- which would crash on a list cell), keeping the result LTUnknown so any
      -- further chaining stays runtime-dispatched.  Value-identical to the direct
      -- path for the string case (mdk_append → mdk_string_append on a String
      -- header), so every byte-diff gate is unaffected.
      LTUnknown =>
        let _ = emit e ("  " ++ r2 ++ " = call i64 @mdk_append(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
        (r2, LTUnknown)
      -- E8 (#3 census-B): operand static LTy unknown (E2c/E7 couldn't recover
      -- it) — the ~328 scanTriple/splitLines string-builder residual.  Instead
      -- of gapE, dispatch at RUNTIME via @mdk_append, which inspects the left
      -- cell header (odd => Nil/list; even header==MDK_STR_TAG => string; else
      -- => Cons/list) and calls the right append helper.  The result VALUE is
      -- always correct.  Result LTy is statically unknowable here, so we tag it
      -- LTUnknown (NOT LTStr): LTUnknown follows LTStr at print/`==` sites (the
      -- dominant String-builder downstream) but a CHAINED `++` over it re-routes
      -- through @mdk_append instead of a direct @mdk_string_append — closing the
      -- segfault when the value is actually a list.  emitPrint LTCon already
      -- panics on lists, and fixtures project String results through
      -- stringLength (a type-forcing String read) so validation is
      -- byte-identical and independent of this default.
      _ =>
        let _ = emit e ("  " ++ r2 ++ " = call i64 @mdk_append(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
        (r2, LTUnknown)
  | otherwise = gapE ("unsupported binary operator '" ++ op ++ "'")

-- the arithmetic operators the spike lowers to int/float instructions.  `::` and
-- `++` survive lowering as CBinPrim but are NOT arithmetic — they fall to the gap.
isArithOp : String -> Bool
isArithOp op = op == "+" || op == "-" || op == "*" || op == "/" || op == "%"

-- arithmetic preserves operand type (well-typed: both operands share a type).
emitArith : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> <Mut> (String, LTy)
emitArith e env op l r =
  let (lv, lty) = emitExpr e env l
  let (rv, rty) = emitExpr e env r
  match lty
    LTFloat =>
      let ld = unboxFloat e lv
      let rd = unboxFloat e rv
      let res = freshReg e
      let _ = emit e ("  " ++ res ++ " = " ++ floatOp op ++ " double " ++ ld ++ ", " ++ rd)
      (boxFloat e res, LTFloat)
    -- G3: a POLYMORPHIC Num operand (declared type-var param) — could be Int OR
    -- Float at runtime.  Route through the runtime tag-dispatched @mdk_num_* helper
    -- (low-bit discriminator), keeping the result LTNum so a chained `Num` op and
    -- the polymorphic print site stay runtime-dispatched.  An LTNum on EITHER side
    -- propagates (the other operand shares the type by well-typing).
    LTNum =>
      let res = freshReg e
      let _ = emit e ("  " ++ res ++ " = call i64 @" ++ numOp op ++ "(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
      (res, LTNum)
    _ => match rty
      LTNum =>
        let res = freshReg e
        let _ = emit e ("  " ++ res ++ " = call i64 @" ++ numOp op ++ "(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
        (res, LTNum)
      _ =>
        let li = untagInt e lv
        let ri = untagInt e rv
        let res = freshReg e
        let _ = emit e ("  " ++ res ++ " = " ++ intOp op ++ " i64 " ++ li ++ ", " ++ ri)
        (tagInt e res, LTInt)

-- comparison always yields a Bool word; dispatch the compare on operand type.
emitCmp : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> <Mut> (String, LTy)
emitCmp e env op l r =
  let (lv, lty) = emitExpr e env l
  let (rv, rty) = emitExpr e env r
  -- A boxed-string operand (EITHER side — a `""` literal forces it even when the
  -- other side's static LTy wasn't inferred to LTStr) routes `==`/`!=` through
  -- @mdk_string_eq; pointer identity (the integer arm) is WRONG for string cells.
  -- An LTUnknown operand (chained-`++` result) could be a String OR a list, so
  -- for `==`/`!=` route through @mdk_value_eq (runtime String/word discriminator)
  -- rather than @mdk_string_eq, which would crash reading a list cell as a String.
  if (isLTUnknown lty || isLTUnknown rty) && isEqOp op then emitValueEq e op lv rv
  else if isStrLTy lty || isStrLTy rty then emitStrCmp e op lv rv
  else match lty
    LTFloat =>
      let ld = unboxFloat e lv
      let rd = unboxFloat e rv
      let c = freshReg e
      let _ = emit e ("  " ++ c ++ " = fcmp " ++ floatPred op ++ " double " ++ ld ++ ", " ++ rd)
      boolFromI1 e c
    -- Unknown static type (LTInt default — could be Int/Bool/Char OR a boxed
    -- String the emitter couldn't recover, e.g. two String params used only in
    -- `n == name`): an integer `icmp eq` is pointer-identity for a boxed String
    -- cell and so WRONG.  Route equality through @mdk_value_eq, which discriminates
    -- at run time (String cell → byte compare; immediate → word compare), mirroring
    -- mdk_append's runtime String/List discrimination.  Ordering ops (`<`/`>`/…)
    -- are never string-valued at an unknown site in the bootstrap, so they keep the
    -- integer compare.  A statically-typed numeric operand never reaches here.
    --
    -- An `if`-EXPRESSION (not a guarded `LTInt if isEqOp op` arm) keeps this
    -- function self-compilable: the gap-tolerant bootstrap emitter cannot lower a
    -- guarded match arm.  IR is byte-identical to the guarded form.
    LTInt =>
      if isEqOp op then emitValueEq e op lv rv
      else emitIntCmp e op lv rv
    _ => emitIntCmp e op lv rv

-- the integer `icmp` compare path shared by the LTInt-non-eq and default arms of
-- emitCmp (factored out so neither needs a guarded match arm).
emitIntCmp : Emit -> String -> String -> String -> <Mut> (String, LTy)
emitIntCmp e op lv rv =
  let li = untagInt e lv
  let ri = untagInt e rv
  let c = freshReg e
  let _ = emit e ("  " ++ c ++ " = icmp " ++ intPred op ++ " i64 " ++ li ++ ", " ++ ri)
  boolFromI1 e c

-- equality of two operands of statically-unknown kind via the runtime
-- discriminator (note at emitCmp).  `==` returns @mdk_value_eq's tagged Bool
-- directly; `!=` flips 3<->1 with `xor … 2` (same shape as emitStrCmp).
emitValueEq : Emit -> String -> String -> String -> <Mut> (String, LTy)
emitValueEq e op lv rv
  | op == "==" =
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = call i64 @mdk_value_eq(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
      (r, LTBool)
  | otherwise =
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = call i64 @mdk_value_eq(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
      let n = freshReg e
      let _ = emit e ("  " ++ n ++ " = xor i64 " ++ r ++ ", 2")
      (n, LTBool)

isEqOp : String -> Bool
isEqOp op = op == "==" || op == "!="

isStrLTy : LTy -> Bool
isStrLTy LTStr = True
-- LTUnknown (chained-`++` result) follows LTStr for `==`/`!=`: route through the
-- runtime string/value discriminator rather than a pointer-identity icmp.
isStrLTy LTUnknown = True
isStrLTy _ = False

isLTUnknown : LTy -> Bool
isLTUnknown LTUnknown = True
isLTUnknown _ = False

-- String `==`/`!=`: pointer identity is WRONG for boxed string cells, so route
-- content equality through @mdk_string_eq (the same helper the pattern-match
-- literal path uses, returning a TAGGED Bool word 3/1).  `==` returns it directly;
-- `!=` flips 3<->1 via `xor … 2`.  Ordering ops (`<`/`>`/`<=`/`>=`) on strings
-- route through @mdk_string_compare_raw, which returns a PLAIN -1/0/1 i64; the
-- operator then becomes `icmp <intPred op> raw, 0` (e.g. `a < b` ⟺ `cmp < 0`),
-- reusing intPred's slt/sgt/sle/sge and boolFromI1.  (Self-compile C2 exercises
-- this: the native emitter's own sanitizeId/safeChar do String `<`/`<=` at emit
-- time; a pointer `icmp` there mis-mangled module names.)
emitStrCmp : Emit -> String -> String -> String -> <Mut> (String, LTy)
emitStrCmp e op lv rv
  | op == "==" =
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_eq(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
      (r, LTBool)
  | op == "!=" =
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_eq(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
      let n = freshReg e
      let _ = emit e ("  " ++ n ++ " = xor i64 " ++ r ++ ", 2")
      (n, LTBool)
  | otherwise =
      let cmp = freshReg e
      let _ = emit e ("  " ++ cmp ++ " = call i64 @mdk_string_compare_raw(i64 " ++ lv ++ ", i64 " ++ rv ++ ")")
      let c = freshReg e
      let _ = emit e ("  " ++ c ++ " = icmp " ++ intPred op ++ " i64 " ++ cmp ++ ", 0")
      boolFromI1 e c

-- an i1 (from icmp/fcmp) -> a Bool word (zext to i64, then tag as immediate int).
boolFromI1 : Emit -> String -> <Mut> (String, LTy)
boolFromI1 e c =
  let z = freshReg e
  let _ = emit e ("  " ++ z ++ " = zext i1 " ++ c ++ " to i64")
  (tagInt e z, LTBool)

emitUn : Emit -> List (String, (String, LTy)) -> String -> CExpr -> <Mut> (String, LTy)
emitUn e env "-" x =
  let (v, ty) = emitExpr e env x
  match ty
    LTFloat =>
      let d = unboxFloat e v
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = fneg double " ++ d)
      (boxFloat e r, LTFloat)
    _ =>
      let i = untagInt e v
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = sub i64 0, " ++ i)
      (tagInt e r, LTInt)
emitUn e env "!" x =
  let (v, _) = emitExpr e env x
  let i = untagInt e v
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = xor i64 " ++ i ++ ", 1")
  (tagInt e r, LTBool)
emitUn _ _ op _ = gapE ("unsupported unary op " ++ op)

-- `if`: lower via an alloca slot (memory, not phi) so a branch's own internal
-- control flow never has to be threaded into a phi's incoming-block list — the
-- simplest correct lowering for a spike (clang -O0 keeps the alloca; mem2reg
-- would promote it under -O).  Both arms share a type; report the then-arm's.
emitIf : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> CExpr -> <Mut> (String, LTy)
emitIf e env c t f =
  let (cv, _) = emitExpr e env c
  let ci = untagInt e cv
  let cb = freshReg e
  let _ = emit e ("  " ++ cb ++ " = icmp ne i64 " ++ ci ++ ", 0")
  let n = intToString (freshId e)
  let thenL = "then" ++ n
  let elseL = "else" ++ n
  let endL = "end" ++ n
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let _ = emit e ("  br i1 " ++ cb ++ ", label %" ++ thenL ++ ", label %" ++ elseL)
  let _ = emit e (thenL ++ ":")
  let (tv, tty) = emitExpr e env t
  let _ = emit e ("  store i64 " ++ tv ++ ", ptr " ++ slot)
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (elseL ++ ":")
  let (fv, _) = emitExpr e env f
  let _ = emit e ("  store i64 " ++ fv ++ ", ptr " ++ slot)
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ slot)
  (r, tty)

emitLet : Emit -> List (String, (String, LTy)) -> Bool -> Pat -> CExpr -> CExpr -> <Mut> (String, LTy)
emitLet e env False (PVar x) e1 e2 =
  let (v, ty) = emitExpr e env e1
  emitExpr e ((x, (v, ty)) :: env) e2
emitLet e env False PWild e1 e2 =
  let _ = emitExpr e env e1
  emitExpr e env e2
emitLet e env False (PTuple ps) e1 e2 =
  let (v, _) = emitExpr e env e1
  let env2 = bindPattern e env (PTuple ps) v e2
  emitExpr e env2 e2
-- a recursive (function-`let`) closure: `let f p… = … in e2` lowers to
-- CLet True (PVar f) (CLam …) (slice 5b).  The lambda's own name `f` is the
-- closure itself, so it is EXCLUDED from the capture set at the alloc site and
-- bound to `%clos` (the leading closure pointer) inside the lifted define — a
-- recursive self-call re-enters the same code with the same cell.  Non-recursive
-- function-lets take the same path harmlessly (`f` simply never appears free).
emitLet e env True (PVar f) (CLam pats body) e2 =
  let (w, ty) = emitRecLam e env f pats body
  emitExpr e ((f, (w, ty)) :: env) e2
emitLet _ _ _ _ _ _ = gapE "unsupported let (slice 5b: only non-recursive let var/_/tuple = e, or function-let)"

-- a `let`/`where` group.  Bindings emit one at a time, left-to-right, threading
-- the growing env, so a later binding sees the earlier ones (and the body sees
-- all).  Two binding shapes:
--   • `CBind name [CClause [] rhs]` — a nullary VALUE binding (slice 1): emit the
--     rhs, bind the word, recurse.
--   • `CBind name clauses` with non-empty params (a LOCAL FUNCTION, possibly
--     multi-clause / self-recursive — the `go`/`step`/`g` workers core.mdk writes
--     with `where`): lambda-lift it into a (self-recursive) closure via
--     `emitGroupBind` and bind its closure word, then recurse.
-- A binding that forward/mutually references a LATER sibling can't be lifted
-- one-at-a-time — the referent's closure word isn't allocated when this binding's
-- captures are taken.  When that happens the maximal contiguous run of LOCAL
-- FUNCTION bindings starting here is KNOT-TIED together (`emitLetGroupKnot`): all
-- their closure cells are allocated up front (so every sibling word exists), every
-- sibling name is bound in the env, and each cell's capture fields are then
-- back-patched with the now-available sibling words (and any enclosing-scope
-- captures).  References to EARLIER siblings, self-references (bound to `%clos`),
-- arbitrary forward refs and true mutual recursion all emit correctly.  A value
-- binding interleaved INSIDE such a run (a mutual ref crossing a non-function
-- sibling) is the residue this scheme doesn't cover — it is rejected precisely
-- (`gapE`) rather than miscompiled.
emitLetGroup : Emit -> List (String, (String, LTy)) -> List CBind -> CExpr -> <Mut> (String, LTy)
emitLetGroup e env [] body = emitExpr e env body
emitLetGroup e env ((CBind name [CClause [] rhs])::rest) body =
  let (v, ty) = emitExpr e env rhs
  emitLetGroup e ((name, (v, ty)) :: env) rest body
emitLetGroup e env ((CBind name clauses)::rest) body
  | refsLater name clauses (bindNames rest) =
      emitKnotRun e env ((CBind name clauses)::rest) body
  | otherwise =
      let (w, ty) = emitGroupBind e env (CBind name clauses)
      emitLetGroup e ((name, (w, ty)) :: env) rest body

-- knot-tie the maximal leading run of function bindings of `binds`, then continue
-- the group with the remainder.  A forward/mutual ref crossing into a LATER value
-- binding (outside the run) is the uncovered residue — rejected precisely.
emitKnotRun : Emit -> List (String, (String, LTy)) -> List CBind -> CExpr -> <Mut> (String, LTy)
emitKnotRun e env binds body =
  let run = takeFnRun binds
  let after = dropS (lengthS run) binds
  let runNames = bindNames run
  if anyRefsOutsideRun run runNames (bindNames after) then
    gapE ("unsupported let-group: a binding forward/mutually references a later value binding (knot-tying covers only mutual function bindings)")
  else
    let env2 = emitLetGroupKnot e env run runNames
    emitLetGroup e env2 after body

-- the maximal leading run of LOCAL FUNCTION bindings (non-empty params) — a nullary
-- VALUE binding (`CBind _ [CClause [] _]`) ends the run.
takeFnRun : List CBind -> List CBind
takeFnRun [] = []
takeFnRun ((CBind _ [CClause [] _])::_) = []
takeFnRun (b::rest) = b :: takeFnRun rest

dropS : Int -> List a -> List a
dropS _ [] = []
dropS n (x::xs) = if n <= 0 then x :: xs else dropS (n - 1) xs

-- True if any binding in the run references a name bound LATER but OUTSIDE the run
-- (i.e. a later value binding) — the case knot-tying cannot tie.
anyRefsOutsideRun : List CBind -> List String -> List String -> Bool
anyRefsOutsideRun [] _ _ = False
anyRefsOutsideRun ((CBind name clauses)::rest) runNames laterOutside
  | anyInList (dedupS (clausesFreeVars name clauses)) laterOutside = True
  | otherwise = anyRefsOutsideRun rest runNames laterOutside
anyRefsOutsideRun (_::rest) runNames laterOutside =
  anyRefsOutsideRun rest runNames laterOutside

-- True when any clause of a local-function binding references a sibling bound
-- LATER in the same group (a forward or mutually-recursive reference whose
-- closure word is not yet available at this binding's capture site).  Self- and
-- param-bound names are excluded by `clausesFreeVars`.
refsLater : String -> List CClause -> List String -> Bool
refsLater name clauses laterNames =
  anyInList (dedupS (clausesFreeVars name clauses)) laterNames

-- the free variables across ALL clauses of a binding, with the self name and each
-- clause's own parameter variables treated as bound.
clausesFreeVars : String -> List CClause -> List String
clausesFreeVars _ [] = []
clausesFreeVars self ((CClause pats body)::rest) =
  freeVars (self :: patVarNames pats) body ++ clausesFreeVars self rest

anyInList : List String -> List String -> Bool
anyInList [] _ = False
anyInList (x::xs) ys = if containsStr x ys then True else anyInList xs ys

-- lambda-lift a LOCAL FUNCTION binding from a `let`/`where` group into a (possibly
-- self-recursive) closure.  Captures are the free variables across all clauses
-- present in the emit env, MINUS the binding's own name (it is the closure cell
-- itself, bound to `%clos` inside the lift — a self-call re-enters the same cell).
-- The lifted body reuses the E1a decision-tree path (`emitClauseTree`), so a
-- multi-clause worker or a patterned param lowers exactly as a top-level fn does.
emitGroupBind : Emit -> List (String, (String, LTy)) -> CBind -> <Mut> (String, LTy)
emitGroupBind e env (CBind name clauses) =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let arity = clauseArity (clauseList clauses)
  let captured = keepInEnv env (removeStr name (dedupS (clausesFreeVars name clauses)))
  let captureWords = capWords env captured
  let _ = emitGroupBindDefine e lamName name arity clauses captured
  emitClosureAlloc e lamName captureWords

-- emit the lifted multi-clause `define` for a let-group local function into the
-- SIDE buffer (same swap discipline as emitPatLamDefine).  Captures load from
-- `%clos` fields 1.., the self name binds to `%clos` (recursive self-call
-- re-enters the same cell), and `emitClauseTree` lowers the clauses over the
-- `%argK` words (arity ≥1 here — nullary values take the fast path above).
emitGroupBindDefine : Emit -> String -> String -> Int -> List CClause -> List String -> <Mut> Unit
emitGroupBindDefine e lamName name arity clauses captured =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  -- A lifted define is a FRESH function: its clause chain's last-clause
  -- fallthrough must be @mdk_oob (non-exhaustive abort), NOT the enclosing
  -- function's leftover next-clause label.  Without this the lifted `go`'s final
  -- clause would `br label %clauseN` to a block defined in the PARENT function —
  -- invalid LLVM once functions are concatenated in the multi-module output
  -- (issue #53).  Same save+null+restore discipline emitDecision uses.
  let savedFt = fallthroughLabelRef.value
  let _ = set_ref fallthroughLabelRef ""
  let _ = emit e ("define i64 @" ++ lamName ++ "(i64 %clos, " ++ implParamDecls arity 0 ++ ") {")
  let _ = emit e "entry:"
  let cenv = loadCaptures e captured 0
  let _ = emitClauseTree e (((name, ("%clos", LTClosure)) :: cenv) ++ implParamEnv arity 0) arity (clauseList clauses)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = set_ref fallthroughLabelRef savedFt
  set_ref (bufRef e) saved

clauseList : List CClause -> List (List Pat, CExpr)
clauseList [] = []
clauseList ((CClause pats body)::rest) = (pats, body) :: clauseList rest

-- ── knot-tying: forward/mutual local function bindings ──────────────────────
-- Tie the knot for a RUN of mutually/forward-referencing local function bindings
-- (E5 residual / EMITTER-GAPS #10).  Two passes over the run:
--   1. ALLOC: for each fn binding, lambda-lift it (the lifted `@mdk_lamN` define is
--      independent of the cells — captures load from `%clos` fields by index), then
--      allocate its closure cell with the code pointer in field 0 and PLACEHOLDER
--      `0` words in the capture fields (`emitClosureAllocPatch` returns the raw cell
--      pointer for later stores).  Every sibling name is bound to its cell word.
--   2. PATCH: now that every sibling word exists, store each cell's REAL capture
--      words — looked up in the fully-knotted env (siblings + enclosing scope) — into
--      its capture fields.  This BY-VALUE back-patch ties arbitrary mutual recursion
--      and forward references; self-recursion still flows through `%clos`.
-- The capture-NAME list per binding is computed against a sibling env (so a sibling
-- ref is kept by `keepInEnv` and indexed correctly), and must MATCH the field order
-- the lifted define's `loadCaptures` reads — both walk the same `captured` list.
emitLetGroupKnot : Emit -> List (String, (String, LTy)) -> List CBind -> List String -> <Mut> List (String, (String, LTy))
emitLetGroupKnot e env run runNames =
  let sibEnv = sibPlaceholderEnv runNames
  let cellEnv = sibEnv ++ env
  let (cells, env2) = knotAlloc e env cellEnv run
  -- pass 2: back-patch each cell's capture fields with real words from env2.
  let _ = knotPatch e env2 cells
  env2

-- a placeholder env entry per run name (word "0", LTClosure) for capture-name
-- computation only.
sibPlaceholderEnv : List String -> List (String, (String, LTy))
sibPlaceholderEnv [] = []
sibPlaceholderEnv (n::rest) = (n, ("0", LTClosure)) :: sibPlaceholderEnv rest

-- a knot cell records the binding name, its allocated cell POINTER (for stores),
-- and its ordered capture-name list (matching the lifted define's field layout).
data KnotCell = KnotCell String String (List String)

-- pass 1: for each fn binding, lift it and alloc its closure cell with placeholder
-- captures; thread the env binding each cell word.  `cellEnv` (siblings + outer)
-- is used to compute the capture NAME set so a sibling ref is kept and indexed.
knotAlloc : Emit -> List (String, (String, LTy)) -> List (String, (String, LTy)) -> List CBind -> <Mut> (List KnotCell, List (String, (String, LTy)))
knotAlloc _ env _ [] = ([], env)
knotAlloc e env cellEnv ((CBind name clauses)::rest) =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let arity = clauseArity (clauseList clauses)
  let captured = keepInEnv cellEnv (removeStr name (dedupS (clausesFreeVars name clauses)))
  let _ = emitGroupBindDefine e lamName name arity clauses captured
  let (cellPtr, cellWord) = emitClosureAllocPatch e lamName (lengthS captured)
  let (cells, env2) = knotAlloc e ((name, (cellWord, LTClosure)) :: env) cellEnv rest
  (KnotCell name cellPtr captured :: cells, env2)
knotAlloc e env cellEnv (_::rest) = knotAlloc e env cellEnv rest

-- pass 2: store each cell's real capture words (from the fully-bound env) into its
-- capture fields (offset 8*(i+1), field 0 holds the code pointer).
knotPatch : Emit -> List (String, (String, LTy)) -> List KnotCell -> <Mut> Unit
knotPatch _ _ [] = ()
knotPatch e env ((KnotCell _ cellPtr captureNames)::rest) =
  let words = capWords env captureNames
  let _ = storeFields e cellPtr words 1
  knotPatch e env rest

-- allocate a closure cell with the code pointer in field 0 and `nCap` PLACEHOLDER
-- zero capture words, returning BOTH the raw cell pointer (for later stores) and
-- the cell word (the closure value).  Mirrors emitClosureAlloc/emitCtorAlloc's
-- layout exactly — field 0 = code_ptr — so the cell is callable immediately
-- (`emitIndirect` loads field 0); only the capture fields await back-patch.
emitClosureAllocPatch : Emit -> String -> Int -> <Mut> (String, String)
emitClosureAllocPatch e lamName nCap =
  let codePtr = "ptrtoint (ptr @" ++ lamName ++ " to i64)"
  let fields = codePtr :: zeroWords nCap
  let arity = lengthS fields
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = call ptr @mdk_alloc(i64 " ++ intToString (8 * (arity + 1)) ++ ")")
  let _ = emit e ("  store i64 " ++ intToString (cellTag e closureHeaderName) ++ ", ptr " ++ p)
  let _ = storeFields e p fields 0
  let w = freshReg e
  let _ = emit e ("  " ++ w ++ " = ptrtoint ptr " ++ p ++ " to i64")
  (p, w)

zeroWords : Int -> List String
zeroWords n = if n <= 0 then [] else "0" :: zeroWords (n - 1)

emitBlock : Emit -> List (String, (String, LTy)) -> List CStmt -> <Mut> (String, LTy)
emitBlock e env [CSExpr ex] = emitExpr e env ex
emitBlock e env ((CSExpr ex)::rest) =
  let _ = emitExpr e env ex
  emitBlock e env rest
emitBlock e env ((CSLet _ (PVar x) ex)::rest) =
  let (v, ty) = emitExpr e env ex
  emitBlock e ((x, (v, ty)) :: env) rest
emitBlock e env ((CSLet _ PWild ex)::rest) =
  let _ = emitExpr e env ex
  emitBlock e env rest
emitBlock e env ((CSLet _ (PTuple ps) ex)::rest) =
  let (v, _) = emitExpr e env ex
  let env2 = bindPattern e env (PTuple ps) v (CLit (LInt 0))
  emitBlock e env2 rest
-- General irrefutable block-let `let pat = e` for an ARBITRARY pattern (PCon,
-- PCons, PList, PAs, nested).  A bare `CSLet _ pat` is irrefutable by
-- construction — a refutable surface let desugars to CSLetElse (handled above) —
-- so we destructure with NO failure branch, exactly as cevalBlock's cBlockLet
-- does (core_ir_eval :269) and as the PTuple arm above does.  Reuses bindPattern,
-- the same destructure path match-arm emission uses; the `rest` block evaluates
-- in the extended env.  Placed after the specialized PVar/PWild/PTuple arms so
-- those stay byte-identical.
emitBlock e env ((CSLet _ pat ex)::rest) =
  let (v, _) = emitExpr e env ex
  let env2 = bindPattern e env pat v (CLit (LInt 0))
  emitBlock e env2 rest
-- last-position block-let `[let pat = e]`: mirror cevalBlock's cBlockLetLast
-- (core_ir_eval :265/:277) — evaluate `e` (for effect + to honour the binding),
-- destructure, and the block yields Unit.  Without this a block ending in a let
-- would recurse into `emitBlock e env2 []` and hit the "empty block" gap.
emitBlock e env [CSLet _ pat ex] =
  let (v, _) = emitExpr e env ex
  let _ = bindPattern e env pat v (CLit (LInt 0))
  ("1", LTUnit)
-- `let mut x = e` reuses the irrefutable `CSLet _ (PVar x)` arm above (the mut
-- flag carries no extra emit work — a mutable local is just an SSA value the
-- block's tail rebinds).  A reassignment `x = e` (CSAssign, gap B1) mirrors the
-- tree-walker's `cevalBlock ((CSAssign x e)::rest)`: re-evaluate `e` and SHADOW
-- the `x` binding for the rest of the block.  Blocks are linear (no back-edge re-
-- enters the binding), so functional rebinding is observationally identical to a
-- real mutable slot — no Ref cell needed.
emitBlock e env ((CSAssign x ex)::rest) =
  let (v, ty) = emitExpr e env ex
  emitBlock e ((x, (v, ty)) :: env) rest
-- the tail statement of a block may be a bare assignment (`x = e`): evaluate for
-- effect, the block yields Unit.
emitBlock e env [CSAssign _ ex] =
  let _ = emitExpr e env ex
  ("1", LTUnit)
-- let-else `let pat = e else alt` (gap B2): match `e` against `pat`; on success
-- bind pattern vars + continue the block; on failure emit `alt` (which diverges —
-- panic / early-exit).  Mirrors core_ir_eval's `cBlockLetElse`.  For an
-- irrefutable pattern the else is dead, so just bind + continue.
emitBlock e env ((CSLetElse pat ex alt)::rest) =
  if irrefutableLet pat then
    let (v, _) = emitExpr e env ex
    let env2 = bindPattern e env pat v (CLit (LInt 0))
    emitBlock e env2 rest
  else
    emitLetElse e env pat ex alt rest
emitBlock _ _ [] = gapE "empty block"
emitBlock _ _ _ = gapE "unsupported block statement (slice 1)"

-- emit a let-else with a REFUTABLE pattern: evaluate the scrutinee, test its
-- discriminant against the pattern's head ctor; on a tag match bind the fields and
-- continue the block into a result slot; on a miss run `alt` (diverges).  Reuses
-- loadDiscriminant / cellTag / loadFields / bindPattern — the same primitives the
-- decision-tree switch chain uses.  Result is the continuation block's value.
emitLetElse : Emit -> List (String, (String, LTy)) -> Pat -> CExpr -> CExpr -> List CStmt -> <Mut> (String, LTy)
emitLetElse e env pat ex alt rest = match letElseHead pat
  Some (c, a, fieldPats) =>
    let (sv, _) = emitExpr e env ex
    let slot = freshReg e
    let _ = emit e ("  " ++ slot ++ " = alloca i64")
    let rty = Ref LTInt
    let tag = loadDiscriminant e sv
    let cmp = freshReg e
    let _ = emit e ("  " ++ cmp ++ " = icmp eq i64 " ++ tag ++ ", " ++ intToString (cellTag e c))
    let n = intToString (freshId e)
    let yes = "letelseok" ++ n
    let no = "letelsealt" ++ n
    let endL = "letelseend" ++ n
    let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ yes ++ ", label %" ++ no)
    let _ = emit e (yes ++ ":")
    let fields = loadFields e sv a 0
    let env2 = bindFieldList e env fieldPats fields
    let (bv, bty) = emitBlock e env2 rest
    let _ = set_ref rty bty
    let _ = emit e ("  store i64 " ++ bv ++ ", ptr " ++ slot)
    let _ = emit e ("  br label %" ++ endL)
    let _ = emit e (no ++ ":")
    let (av, _) = emitExpr e env alt
    let _ = emit e ("  store i64 " ++ av ++ ", ptr " ++ slot)
    let _ = emit e ("  br label %" ++ endL)
    let _ = emit e (endL ++ ":")
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ slot)
    (r, rty.value)
  None =>
    let _ = gapU "let-else with a non-constructor refutable pattern (B2: constructor patterns only)"
    let _ = emitExpr e env ex
    ("1", LTUnit)

-- bind a list of field patterns to a parallel list of loaded field words.
bindFieldList : Emit -> List (String, (String, LTy)) -> List Pat -> List String -> <Mut> List (String, (String, LTy))
bindFieldList _ env [] _ = env
bindFieldList _ env _ [] = env
bindFieldList e env (p::ps) (v::vs) =
  let env2 = bindPattern e env p v (CLit (LInt 0))
  bindFieldList e env2 ps vs

-- the head ctor (name, arity, field patterns) of a refutable let-else pattern, if
-- it is a constructor-like pattern (named ctor, cons, or non-empty list literal).
letElseHead : Pat -> Option (String, Int, List Pat)
letElseHead (PCon c args) = Some (c, listLen args, args)
letElseHead (PCons h t) = Some ("Cons", 2, [h, t])
letElseHead (PList (p::ps)) = Some ("Cons", 2, [p, PList ps])
letElseHead _ = None

-- a let-else pattern whose else branch is statically dead (always matches): a bare
-- var / wildcard / tuple (single inhabitant).  A PLit / ctor / cons can miss.
irrefutableLet : Pat -> Bool
irrefutableLet (PVar _) = True
irrefutableLet PWild = True
irrefutableLet (PTuple _) = True
irrefutableLet (PAs _ p) = irrefutableLet p
irrefutableLet _ = False

-- ── function application (slices 2 + 4) ─────────────────────────────────────
-- Three call shapes, by the application spine's head:
--   • a known top-level FUNCTION (slice 2) — saturated direct `call @mdk_<name>`.
--   • a CONSTRUCTOR (slice 3) — heap-cell allocation.
--   • ANYTHING ELSE (slice 4) — a closure-valued head (a parameter, a let-bound
--     lambda, an immediately-applied `CLam`, or a returned closure): emit the head
--     to a closure word, load its code_ptr, and INDIRECT-call it passing the
--     closure word as the leading argument.  SATURATED only — the Core IR is
--     type-erased, so the call site cannot see the closure's arity; the spike
--     relies on controlled fixtures applying a closure with exactly its arity in
--     one spine.  Partial application (under-application → a residual closure) and
--     over-application are OUT (the real backend will carry arity in the cell).
flattenApp : CExpr -> List CExpr -> (CExpr, List CExpr)
flattenApp (CApp f a) acc = flattenApp f (a :: acc)
flattenApp hd acc = (hd, acc)

emitApp : Emit -> List (String, (String, LTy)) -> CExpr -> <Mut> (String, LTy)
emitApp e env app =
  let (hd, args) = flattenApp app []
  match hd
    CVar fname _ =>
      if fname == "Ref" then emitRefAlloc e env args
      else if fname == "set_ref" then emitSetRef e env args
      else if isAnyExtern fname && hasArgs args then emitExternApplied e env fname args
      else if isCtor e fname then
        let argOps = emitArgs e env args
        emitCtorAlloc e fname argOps
      else if isKnownFn e fname && hasArgs args then
        let argOps = emitArgs e env args
        emitKnownFnSat e ("mdk_" ++ fname) argOps (fnArity e fname) (fnRetTy e fname)
      else if isImplMethod e fname && hasArgs args then
        let argOps = emitArgs e env args
        emitMethodArgDispatch e fname argOps
      else if fname == "__fallthrough__" then emitFallthrough e
      else emitIndirect e env hd args
    -- slice 6: an applied method / constrained-fn occurrence.  The real arguments
    -- emit first (left-to-right), then the dispatch resolves to a direct impl call
    -- (RKey), a runtime impl switch (RDict/RDictFwd), or a dict-passing call (CDict).
    CMethod name route implRoutes methRoutes =>
      let argOps = emitArgs e env args
      emitMethod e env name route implRoutes methRoutes argOps
    CDict name routes =>
      let argOps = emitArgs e env args
      emitDictApp e env name routes argOps
    _ => emitIndirect e env hd args

-- a saturated INDIRECT call (slice 4): emit the head to a closure word, load its
-- code_ptr (cell field 0), and `call` the loaded pointer with the closure word as
-- the leading argument.  The result type is unknown to the type-erased call site;
-- default Int — EXCEPT (native backend) when the head is a self-returning function
-- PARAM of the impl currently being emitted (`andThen`'s `f` in `f x`): that
-- callback yields the container, so type the result as `tagToLTy <curImplTag>`.
emitIndirect : Emit -> List (String, (String, LTy)) -> CExpr -> List CExpr -> <Mut> (String, LTy)
emitIndirect e env hd args =
  let (cw, _) = emitExpr e env hd
  let argOps = emitArgs e env args
  let cp = loadField e cw 0
  let fp = freshReg e
  let _ = emit e ("  " ++ fp ++ " = inttoptr i64 " ++ cp ++ " to ptr")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = call i64 " ++ fp ++ "(" ++ argDecls (cw :: argOps) ++ ")")
  (r, indirectResultTy hd)

-- the static result type of an indirect call: container when the head is a
-- self-returning function param of the current impl, else LTInt (unchanged).
indirectResultTy : CExpr -> <Mut> LTy
indirectResultTy (CVar f _) = if isCurSelfFnParam f then tagToLTy curImplTagRef.value else LTInt
indirectResultTy _ = LTInt


hasArgs : List CExpr -> Bool
hasArgs [] = False
hasArgs _ = True

-- emit each argument expression (left-to-right); collect the i64 operand words.
emitArgs : Emit -> List (String, (String, LTy)) -> List CExpr -> <Mut> List String
emitArgs _ _ [] = []
emitArgs e env (a::rest) =
  let (v, _) = emitExpr e env a
  v :: emitArgs e env rest

-- render an operand list as a comma-separated i64 argument list.
argDecls : List String -> String
argDecls [] = ""
argDecls [x] = "i64 " ++ x
argDecls (x::rest) = "i64 " ++ x ++ ", " ++ argDecls rest

-- ── typeclass dispatch (slice 6) ────────────────────────────────────────────
-- Core IR carries the typechecker's resolved dispatch in two structural nodes
-- (core_ir.mdk): `CMethod name route implRoutes methRoutes` (a method occurrence)
-- and `CDict name routes` (a `=>`-constrained-function occurrence).  Each Route is
-- RNone | RKey String (List Route) | RDict String | RDictFwd String (ast.mdk).
--
-- The KEY TRACTABILITY PROPERTY (the reason the bootstrap is in reach): an RKey
-- route is STATICALLY resolved — the typechecker already pinned the concrete type
-- head, so the impl is known at COMPILE time and the site lowers to a DIRECT call
-- to that impl's lifted `@mdk_impl_<tag>_<method>`, with NO runtime tag inspection.
-- The self-host compiler dispatches return-position via RKey (selfhost/README.md),
-- so RKey alone covers the bootstrap.  RDict/RDictFwd read a named dict PARAMETER
-- at run time, so they lower to an if-chain switching on the dict's head tag over
-- the method's impls (corpus completeness — the dict-passing fixtures).  This
-- mirrors core_ir_eval's `methodAtNarrow`/`applyDicts`/`narrowMethod` one-to-one,
-- resolving the same routes in emitted control flow instead of walking VMulti
-- values.  RNone (D3a: a type-variable arg-position site the front end left
-- unstamped) falls back to runtime arg-tag dispatch; nested-requires dicts are out
-- of scope.
--
-- SPIKE-REP NOTES (slice 6; the (j)/(k)/(l) entries in STAGE2-DESIGN §2.4a):
--   (j) DICTS (GAP 1, Option A — BOXED witness) — a dict witness is a POINTER to a
--       heap cell `[ i64 head_tag | i64 reqdict_0 | … ]` (via @mdk_alloc, the same
--       boxed-cell shape ADT ctors use): field 0 = `hashName(impl-head-tag)` (the
--       djb2 used for the `icmp eq` dispatch test), fields 1..n = the RECURSIVELY-
--       built witness words for the impl's per-instance `requires` dicts.  RNone ⇒ 0
--       (no cell).  The rep is UNIFORM: a one-level dict (`RKey k []`) is a 1-word
--       cell `[ hashName k ]`; a two-level dict (`RKey k [RKey k2 …]`) nests another
--       cell pointer in field 1.  Consumption: the RKey direct-call path forwards the
--       boxed pointer as the impl fn's leading dict param; the RDict dispatch chain
--       (emitDispatchChain) loads the head tag from field 0 for the `icmp` and
--       prepends fields 1..n as the matched impl's leading element-dict args.
--       (Previously the witness was a flat i64 that dropped nested reqs and panicked
--       on a non-empty set — the GAP-1 SIGSEGV `medaka build` hit on `[[Int]]`.)
--   (k) IMPL FUNCTIONS — each tagged impl method lowers to a top-level
--       `@mdk_impl_<tag>_<method>(params…)` (lambda-lift convention of emitFn).  A
--       nullary return-position impl (`def`/`zero`/`empty`) is a zero-arg function
--       the use site CALLs for its value; a parameterized impl takes its params.
--   (l) DISPATCH — RKey ⇒ a direct call (impl chosen at compile time).  RDict/
--       RDictFwd ⇒ an inline if-chain over the method's impls comparing the dict
--       witness word to each impl's hashName tag; an exhausted chain is
--       `unreachable` (the typechecker proves the dict names a real impl).

-- a method occurrence.  `argOps` are the already-emitted real-argument words (empty
-- for a bare nullary method like `def`).  methRoutes/implRoutes apply method-/
-- instance-level constraint dicts as leading args (D3b-1): on an RKey call into a
-- parametric `requires` impl, each materializes a one-word dict witness prepended
-- ahead of the real args, matching dict_pass's leading `$dict_<method>_<slot>`
-- params.  Both empty for an unconstrained impl ⇒ the plain direct call.
-- GAP 1: the route's OWN nested `reqs` are now representable (boxed dict cells,
-- Option A) — the former `ensureNoReqs reqs` guard is gone.  This site's leading
-- dicts come from the call-site routes (methRoutes ++ implRoutes); each such
-- route's nested reqs are materialized recursively inside dictWordOfRoute.
emitMethod : Emit -> List (String, (String, LTy)) -> String -> Route -> List Route -> List Route -> List String -> <Mut> (String, LTy)
emitMethod e env name route implRoutes methRoutes argOps =
  match route
    RKey tag _ =>
      match implFor e name tag
        Some entry =>
          let dictWords = dictWordsOf e env (methRoutes ++ implRoutes)
          -- native backend: a method whose RESULT mentions the interface/self
          -- type variable (map/ap/andThen) returns the CONTAINER; type its
          -- RKey-dispatched result as the impl's own type (tagToLTy tag) so a
          -- downstream `++`/`::` on it dispatches list/string append.  Otherwise
          -- (scalar/element result) keep the LTInt default.
          let resTy = if methodReturnsSelf (implEntryIface entry) name then tagToLTy tag else LTInt
          emitImplCallSat e (implFnName tag name) (dictWords ++ argOps) (methodArityOf name + lengthS dictWords) resTy
        None => emitDefaultRKey e name tag argOps
    RDict d => emitMethodDispatch e env name d argOps
    RDictFwd d => emitMethodDispatch e env name d argOps
    RNone => emitMethodArgDispatch e name argOps
    -- C5 (mirror lib/eval.ml RLocal): NOT a method dispatch — the receiver has no
    -- impl of this interface but an explicitly-imported/local standalone shadows the
    -- method name.  Emit a DIRECT call to that standalone top-level fn (`mdk_<name>`),
    -- exactly as emitApp's isKnownFn branch would for a plain call — no dispatch, no
    -- dicts.  (The self-host compiler's OWN source has no standalone-shadowing-method
    -- site, so this arm is never exercised compiling the compiler → emitted IR for the
    -- fixpoint stays byte-identical; only the box/main fixture reaches it.)
    RLocal => emitKnownFnSat e ("mdk_" ++ name) argOps (fnArity e name) (fnRetTy e name)

-- Gap #50 (value position) — a bare method occurrence `CMethod name route ..` used
-- as a FIRST-CLASS VALUE (passed to a HOF, e.g. `applyOp max 3 7`): there are no
-- applied args, so the saturated dispatch chain that `emitMethod .. []` would emit
-- runs the impl/default with ZERO operands (garbage), and the result is then handed
-- to the HOF as a closure word and INDIRECTLY called → crash.  Instead eta-wrap the
-- method into a real closure value: a lifted `@mdk_methval_<name>_N(%clos, %arg…)`
-- whose body re-emits the SATURATED dispatch (emitMethod with the full %argK
-- operands) under the method's own route.  For an RDict/RDictFwd route the closure
-- CAPTURES the dict word and rebinds it from `%clos` field 1 in the body, so the
-- runtime impl switch still reads the caller's dict.  A nullary method (arity 0,
-- e.g. `def`) is a plain value — keep the immediate `emitMethod .. []`.
emitMethodValue : Emit -> List (String, (String, LTy)) -> String -> Route -> List Route -> List Route -> <Mut> (String, LTy)
emitMethodValue e env name route implRoutes methRoutes =
  let arity = methodArityOf name
  if arity <= 0 then emitMethod e env name route implRoutes methRoutes []
  else
    let capNames = methValDictNames route
    let capWords = capDictWords env capNames
    let lamName = "mdk_methval_" ++ name ++ "_" ++ intToString (freshId e)
    let _ = emitMethodValDefine e lamName name route implRoutes methRoutes arity capNames
    emitClosureAlloc e lamName capWords

-- the dict-witness param name(s) a route reads at runtime (the names whose words the
-- value-closure must capture so the lifted body can rebind them).  Only RDict/
-- RDictFwd name a dict; RKey/RNone/RLocal capture nothing.  (Distinct from the
-- `freeVars` helper `routeDictNames`, which scans a route LIST for free dict vars.)
methValDictNames : Route -> List String
methValDictNames (RDict d) = [d]
methValDictNames (RDictFwd d) = [d]
methValDictNames _ = []

-- the operand words for each captured dict name, looked up in the current emit env.
capDictWords : List (String, (String, LTy)) -> List String -> <Mut> List String
capDictWords _ [] = []
capDictWords env (d::rest) = dictOperand env d :: capDictWords env rest

-- emit the lifted method-value forwarder.  Captures (the dict words) load from
-- `%clos` fields 1.. and rebind the route's dict name(s); the body re-emits the
-- SATURATED method dispatch over the `%argK` value operands.
emitMethodValDefine : Emit -> String -> String -> Route -> List Route -> List Route -> Int -> List String -> <Mut> Unit
emitMethodValDefine e lamName name route implRoutes methRoutes arity capNames =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let _ = emit e ("define i64 @" ++ lamName ++ "(" ++ etaParamDecls arity ++ ") {")
  let _ = emit e "entry:"
  let cenv = loadCaptures e capNames 0
  let synArgs = etaArgOps arity 0
  let (r, _) = emitMethod e cenv name route implRoutes methRoutes synArgs
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  set_ref (bufRef e) saved

-- E19: an RKey route into a method with NO tagged impl for `tag` — the type's
-- `impl` did not override an interface DEFAULT.  Emit the default body as a
-- lifted `@mdk_default_<method>_<tag>` define (eta-expanded to full arity, inner
-- same-interface calls re-stamped to `RKey tag` so a partially-applied inner
-- method like `filterMap` lowers to a direct call), cache it, and call it
-- directly with the call-site args.  No default ⇒ the original missing-impl gap.
emitDefaultRKey : Emit -> String -> String -> List String -> <Mut> (String, LTy)
emitDefaultRKey e name tag argOps = match defaultFor e name
  Some entry =>
    let fname = defaultFnName tag name
    let _ = ensureDefaultEmitted e fname tag name entry
    let resTy = if methodReturnsSelf (methodIfaceOf name) name then tagToLTy tag else LTInt
    emitImplCall e fname argOps resTy
  None => gapE ("no impl of method '" ++ name ++ "' for type '" ++ tag ++ "' (slice 6)")


-- a direct call to a statically-resolved impl fn (RKey).  Nullary (argOps == [])
-- ⇒ `call @mdk_impl_<tag>_<method>()`, yielding the impl's value.  `resTy` is the
-- statically-inferred result type: LTInt for a scalar/element-returning method,
-- or the container (tagToLTy tag) for a returns-self method (map/ap/andThen) so
-- a downstream `++`/`::` types its operand correctly (native backend).
emitImplCall : Emit -> String -> List String -> LTy -> <Mut> (String, LTy)
emitImplCall e fname argOps resTy =
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = call i64 @" ++ fname ++ "(" ++ argDecls argOps ++ ")")
  (r, resTy)

-- a call to a statically-resolved impl fn (RKey / single arg-tag group) that
-- may be UNDER-APPLIED.  A point-free prelude binding (`length = fold f 0`)
-- lowers to the impl method applied to FEWER args than the impl fn's full arity:
-- a saturated `emitImplCall` would emit a call missing its trailing parameter(s),
-- which on the native backend reads a garbage register for the missing arg and
-- crashes.  When `lengthS argOps < arity`, build a PARTIAL-APPLICATION closure
-- capturing the supplied words; the residual closure completes the call when the
-- remaining args arrive at an indirect call site.  Saturated (`==`) ⇒ the plain
-- direct call, unchanged.  (Over-application can't arise at an impl call head —
-- the method's declared arity is its full arity.)
emitImplCallSat : Emit -> String -> List String -> Int -> LTy -> <Mut> (String, LTy)
emitImplCallSat e fname argOps arity resTy
  | lengthS argOps < arity = emitPapClosure e fname argOps arity
  | otherwise = emitImplCall e fname argOps resTy

-- a call to a known top-level function (`@<sym>`, sym already mdk-prefixed) that
-- may be UNDER-APPLIED.  A partial application of a named function passed to a
-- higher-order combinator (`map (desugarDottedField e) fields` — 1 of 2 args)
-- lowers to a residual closure capturing the supplied args, not a truncated
-- direct call (which would read garbage for the missing trailing param).
-- Saturated (`==`) ⇒ the plain direct call, unchanged.  fnArity returns 0 for a
-- fn with no recorded signature; then `lengthS argOps >= 0` is always saturated,
-- preserving the old direct-call behaviour for such (signature-less) callees.
emitKnownFnSat : Emit -> String -> List String -> Int -> LTy -> <Mut> (String, LTy)
emitKnownFnSat e sym argOps arity resTy
  | arity > 0 && lengthS argOps < arity = emitPapClosure e sym argOps arity
  | arity > 0 && lengthS argOps > arity = emitOverApp e sym argOps arity resTy
  | otherwise = emitImplCall e sym argOps resTy

-- OVER-APPLICATION: a known fn of arity N applied to >N args (`makeAdder 10 5` —
-- `makeAdder` returns a closure that consumes the extra arg).  Saturate the direct
-- call with the FIRST N args, then apply the residual VALUE (a closure) to each
-- remaining arg through an indirect call (the same load-code_ptr / call-(closure,
-- arg) shape as emitIndirect).  Without this the trailing args are silently dropped
-- into @sym (which ignores them) and the returned closure is never applied —
-- garbage result / crash.
emitOverApp : Emit -> String -> List String -> Int -> LTy -> <Mut> (String, LTy)
emitOverApp e sym argOps arity resTy =
  let satArgs = takeS arity argOps
  let extra = dropS arity argOps
  let (r0, _) = emitImplCall e sym satArgs resTy
  (emitApplyExtra e r0 extra, LTInt)

-- apply a residual closure VALUE to each remaining arg word, left to right, via an
-- indirect call (load code_ptr from cell field 0, `call codePtr(closure, arg)`).
emitApplyExtra : Emit -> String -> List String -> <Mut> String
emitApplyExtra _ cw [] = cw
emitApplyExtra e cw (a::rest) =
  let cp = loadField e cw 0
  let fp = freshReg e
  let _ = emit e ("  " ++ fp ++ " = inttoptr i64 " ++ cp ++ " to ptr")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = call i64 " ++ fp ++ "(i64 " ++ cw ++ ", i64 " ++ a ++ ")")
  emitApplyExtra e r rest

-- build a partial-application closure over `@fname` with `argOps` already-supplied
-- arg words captured.  Emits a forwarder `@mdk_pap_..(%clos, %arg0..%arg(rem-1))`
-- that loads the captured words from the closure cell (fields 1..k, code_ptr is
-- field 0) and tail-calls `@fname(captured.., remaining..)`; allocates the closure
-- capturing `argOps`.  The residual is a closure VALUE (LTClosure) consumed at an
-- indirect call site — the same cell shape emitClosureAlloc / emitIndirect use.
emitPapClosure : Emit -> String -> List String -> Int -> <Mut> (String, LTy)
emitPapClosure e fname argOps arity =
  let supplied = lengthS argOps
  let remaining = arity - supplied
  let papName = "mdk_pap_" ++ fname ++ "_" ++ intToString (freshId e)
  let _ = emitPapDefine e papName fname supplied remaining
  emitClosureAlloc e papName argOps

-- emit the PAP forwarder define into the side buffer (same swap discipline as
-- emitEtaDefine).  `supplied` captured words are loaded from %clos fields 1..k;
-- `remaining` fresh %argK params follow; the body calls @fname with the captured
-- words first, then the fresh params, in original order, and returns the result.
emitPapDefine : Emit -> String -> String -> Int -> Int -> <Mut> Unit
emitPapDefine e papName fname supplied remaining =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let _ = emit e ("define i64 @" ++ papName ++ "(" ++ etaParamDecls remaining ++ ") {")
  let _ = emit e "entry:"
  let capOps = loadPapCaptures e supplied 0
  let allArgs = capOps ++ argNames remaining 0
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = call i64 @" ++ fname ++ "(" ++ argDecls allArgs ++ ")")
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  set_ref (bufRef e) saved

-- load the `k` captured argument words from %clos fields 1..k (code_ptr is 0).
loadPapCaptures : Emit -> Int -> Int -> <Mut> List String
loadPapCaptures e k i
  | i >= k = []
  | otherwise = loadField e "%clos" (i + 1) :: loadPapCaptures e k (i + 1)

-- the interface name a resolved impl entry belongs to (for the returns-self
-- lookup); "" for a default entry (it carries no tag/iface — never RKey-reached).
implEntryIface : CImplEntry -> String
implEntryIface (CImplEntry _ _ (CImplTagged _ iface _ _ _)) = iface
implEntryIface (CImplEntry _ _ (CImplDefault _ _)) = ""

-- a runtime method dispatch (RDict/RDictFwd): the enclosing function's dict
-- PARAMETER `d` (a BOXED dict-witness pointer, GAP 1 Option A) selects the impl at
-- run time.  Load the head tag from the cell's field 0, then emit an if-chain over
-- the method's tagged impls — compare the head tag to each impl's hashName tag, on
-- a match load the matched impl's nested per-instance dicts from the cell's fields
-- 1..n, PREPEND them to argOps (the impl fn's leading element-dict params), call
-- that impl's lifted fn into a result slot and branch to the end; an exhausted
-- chain is `unreachable`.
emitMethodDispatch : Emit -> List (String, (String, LTy)) -> String -> String -> List String -> <Mut> (String, LTy)
emitMethodDispatch e env name d argOps =
  let dictPtr = dictOperand env d
  let headTag = loadTag e dictPtr
  let impls = implsOf e name
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "dispend" ++ intToString (freshId e)
  -- GAP 2 phase-b: a method with NO tagged impl but a CImplDefault (a pure
  -- interface default like `max`/`min` over `Ord`) reaches an RDict site
  -- generically (`maximum [..]` keeps `Ord a`).  An empty impl chain emits only
  -- `unreachable`, so the dispatched body blanks.  Synthesize a per-tag default
  -- (the E19 machinery) for every tag the interface's dict can carry: the chain
  -- switches the dict's head tag and calls `@mdk_default_<method>_<tag>`, whose
  -- inner same-interface `compare` is restamped to that concrete `RKey tag` (so
  -- it stays a direct call, never the unsound arg-tag site of emitDefaultArgTag).
  let _ = match impls
    [] => match defaultFor e name
            Some entry => emitDefaultDispatchChain e dictPtr headTag (ifaceTags e (methodIfaceOf name)) name entry argOps slot endL
            None => emitDispatchChain e dictPtr headTag impls name argOps slot endL
    _ => emitDispatchChain e dictPtr headTag impls name argOps slot endL
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ slot)
  (r, LTInt)

-- GAP 2 phase-b: the distinct type-head tags an `iface`'s dict can carry — every
-- tagged impl entry whose interface equals `iface`, deduped.  These are exactly
-- the runtime element tags a generic `iface a` dict-word may hold, so the default
-- dispatch chain enumerates one default-synthesis arm per tag.
ifaceTags : Emit -> String -> <Mut> List String
ifaceTags e iface = dedupS (ifaceTagsGo iface (implEntriesOf e))

ifaceTagsGo : String -> List CImplEntry -> List String
ifaceTagsGo _ [] = []
ifaceTagsGo iface ((CImplEntry _ _ (CImplTagged tag ifc _ _ _))::rest)
  | ifc == iface = tag :: ifaceTagsGo iface rest
  | otherwise = ifaceTagsGo iface rest
ifaceTagsGo iface (_::rest) = ifaceTagsGo iface rest

-- GAP 2 phase-b: emit the default-synthesis dispatch chain.  For each `tag` the
-- interface's dict may carry, test the dict head tag and on a match synthesize +
-- call `@mdk_default_<method>_<tag>` (ensureDefaultEmitted restamps its inner
-- same-interface calls to `RKey tag`, keeping `compare` a concrete direct call —
-- the unsoundness trap is avoided precisely because the tag is concrete here).
-- An exhausted chain is `unreachable` (the dict names a real interface impl).
emitDefaultDispatchChain : Emit -> String -> String -> List String -> String -> CImplEntry -> List String -> String -> String -> <Mut> Unit
emitDefaultDispatchChain e _ _ [] _ _ _ _ _ = emit e "  unreachable"
emitDefaultDispatchChain e dictPtr headTag (tag::rest) name entry argOps slot endL =
  let cmp = freshReg e
  let _ = emit e ("  " ++ cmp ++ " = icmp eq i64 " ++ headTag ++ ", " ++ intToString (hashName tag))
  let n = intToString (freshId e)
  let yes = "ddispyes" ++ n
  let next = "ddispnext" ++ n
  let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ yes ++ ", label %" ++ next)
  let _ = emit e (yes ++ ":")
  let fname = defaultFnName tag name
  let _ = ensureDefaultEmitted e fname tag name entry
  let (rv, _) = emitImplCall e fname argOps LTInt
  let _ = emit e ("  store i64 " ++ rv ++ ", ptr " ++ slot)
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (next ++ ":")
  emitDefaultDispatchChain e dictPtr headTag rest name entry argOps slot endL

-- the count of leading element-dict params a matched impl's lifted fn expects: its
-- full clause arity (number of patterns) minus the method's interface arity.  This
-- equals the number of per-instance `requires` dicts stored in the boxed dict cell
-- (fields 1..count), so the chain loads exactly that many and prepends them.
implReqCount : Emit -> String -> CImplEntry -> <Mut> Int
implReqCount e name ent = listLen (implPats ent) - methodArityOf name

-- load `n` nested dict words from the boxed dict cell `dictPtr`.  The head tag is
-- the cell header (offset 0); the nested req dicts are fields 0..n-1 (loadField i ⇒
-- offset 8*(i+1)), stored by emitDictCell via storeFields at the same field indices.
loadReqDicts : Emit -> String -> Int -> Int -> <Mut> List String
loadReqDicts e dictPtr n i
  | i >= n = []
  | otherwise = loadField e dictPtr i :: loadReqDicts e dictPtr n (i + 1)

emitDispatchChain : Emit -> String -> String -> List CImplEntry -> String -> List String -> String -> String -> <Mut> Unit
emitDispatchChain e _ _ [] _ _ _ _ = emit e "  unreachable"
emitDispatchChain e dictPtr headTag (ent::rest) name argOps slot endL =
  let tag = implEntryTag ent
  let cmp = freshReg e
  let _ = emit e ("  " ++ cmp ++ " = icmp eq i64 " ++ headTag ++ ", " ++ intToString (hashName tag))
  let n = intToString (freshId e)
  let yes = "dispyes" ++ n
  let next = "dispnext" ++ n
  let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ yes ++ ", label %" ++ next)
  let _ = emit e (yes ++ ":")
  -- GAP 1: prepend the matched impl's nested element-dicts (cell fields 1..reqCount)
  -- ahead of the real args, matching its leading dict-param order (dict_pass's
  -- methRoutes ++ implRoutes; here the impl's own requires, stored in cell order).
  let reqCount = implReqCount e name ent
  let reqDicts = loadReqDicts e dictPtr reqCount 0
  let (rv, _) = emitImplCall e (implFnName tag name) (reqDicts ++ argOps) LTInt
  let _ = emit e ("  store i64 " ++ rv ++ ", ptr " ++ slot)
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (next ++ ":")
  emitDispatchChain e dictPtr headTag rest name argOps slot endL

-- ── arg-position (arg-tag) dispatch at a call site (slice 7) ─────────────────
-- A bare CVar naming an impl method, applied to args.  The impl is chosen by the
-- discriminating argument's runtime constructor TYPE (mirrors eval's
-- filterByTag → runtimeTypeTag).  Two shapes:
--   • ONE impl group (the method has impls at a single type) — no runtime test is
--     needed: a well-typed call always reaches that impl, so emit a DIRECT call
--     (covers single-impl + the multi-clause-body fixture; the multi-clause
--     fall-through lives INSIDE the impl fn's decision tree, note (n)/(o)).
--   • SEVERAL impl groups (impls at distinct types) — load the discriminating
--     argument's cell tag and emit an if-chain: for each group, test whether the
--     loaded ctor tag is one the group's TYPE owns (OR over its constructors'
--     hashName, via ctorsOfType), and on a match call that group's impl fn.  An
--     exhausted chain is `unreachable` (the typechecker proved a real impl).
--     The discriminating arg may be an IMMEDIATE nullary ctor, so the tag is read
--     via `loadDiscriminant` (low-bit branch), not a bare `loadTag` (note (p)).
emitMethodArgDispatch : Emit -> String -> List String -> <Mut> (String, LTy)
emitMethodArgDispatch e method argOps =
  let groups = implGroupsForMethod e method
  match groups
    [] => emitDefaultArgTag e method argOps
    [g] => emitImplCallSat e (implFnName (groupTag g) method) argOps (methodArityOf method) LTInt
    _ => emitArgTagDispatch e method groups argOps

-- E19: an arg-tag site for a method with NO tagged impl groups — an interface
-- DEFAULT reached on the RNone fallback (`max`/`min`, whose `maximum`/`minimum`
-- callers stay generic `Ord a`).  EMITTING the default body here is UNSOUND for
-- the prelude's Ord defaults: `max`/`min` reduce to `compare m x`, and `compare`'s
-- only impls are at PRIMITIVE types (Int/Float/String/Char/Bool/Ordering) which
-- carry NO runtime constructor cell tag — so the inner `compare` arg-tag dispatch
-- hits `emitTagMatch`'s "owns no constructors" gap (one event per primitive Ord
-- impl × caller).  Emitting the default would therefore REPLACE 1 honest gap with
-- ~6 deeper ones.  A correct max/min needs RKey-concrete `compare` (a monomorphic
-- caller) or primitive-typed arg-tag dispatch — both out of this slice's scope.
-- So a no-impl-groups default is left as the original honest gap; only a default
-- whose inner same-interface calls reach a CONCRETE tag is emittable (the RKey
-- path, emitDefaultRKey — `filter`@List).
emitDefaultArgTag : Emit -> String -> List String -> <Mut> (String, LTy)
emitDefaultArgTag e method argOps =
  gapE ("arg-tag dispatch for method '" ++ method ++ "' has no impl groups (slice 7: unresolved RNone fallback)")

emitArgTagDispatch : Emit -> String -> List ImplGroup -> List String -> <Mut> (String, LTy)
emitArgTagDispatch e method groups argOps
  | headPos (groupPositionsOf (headGroup groups)) >= lengthS argOps =
      gapE ("arg-tag dispatch for method '" ++ method ++ "': discriminating arg position not supplied (slice 7: under-applied / unapplied method)")
  | otherwise =
      emitArgTagDispatchGo e method groups argOps (headPos (groupPositionsOf (headGroup groups)))

emitArgTagDispatchGo : Emit -> String -> List ImplGroup -> List String -> Int -> <Mut> (String, LTy)
emitArgTagDispatchGo e method groups argOps discrimPos =
  let discrimWord = nthStr argOps discrimPos
  let tagReg = loadDiscriminant e discrimWord
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "argdispend" ++ intToString (freshId e)
  let _ = emitArgDispatchChain e method tagReg groups argOps slot endL
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ slot)
  (r, LTInt)

emitArgDispatchChain : Emit -> String -> String -> List ImplGroup -> List String -> String -> String -> <Mut> Unit
emitArgDispatchChain e _ _ [] _ _ _ = emit e "  unreachable"
emitArgDispatchChain e method tagReg (g::rest) argOps slot endL =
  let tag = groupTag g
  let cond = emitTagMatch e tagReg (ctorsOfType e tag)
  let n = intToString (freshId e)
  let yes = "argyes" ++ n
  let next = "argnext" ++ n
  let _ = emit e ("  br i1 " ++ cond ++ ", label %" ++ yes ++ ", label %" ++ next)
  let _ = emit e (yes ++ ":")
  let (rv, _) = emitImplCall e (implFnName tag method) argOps LTInt
  let _ = emit e ("  store i64 " ++ rv ++ ", ptr " ++ slot)
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (next ++ ":")
  emitArgDispatchChain e method tagReg rest argOps slot endL

-- an i1 that is true when the loaded ctor tag equals ANY of a type's constructor
-- tags (OR-chain of icmp eq against each hashName).
emitTagMatch : Emit -> String -> List String -> <Mut> String
emitTagMatch _ _ [] = gapStr "arg-tag dispatch on impl type that owns no constructors (slice 7: primitive receiver carries no cell tag)"
emitTagMatch e tagReg [c] =
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = icmp eq i64 " ++ tagReg ++ ", " ++ intToString (cellTag e c))
  r
emitTagMatch e tagReg (c::rest) =
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = icmp eq i64 " ++ tagReg ++ ", " ++ intToString (cellTag e c))
  let rrest = emitTagMatch e tagReg rest
  let o = freshReg e
  let _ = emit e ("  " ++ o ++ " = or i1 " ++ r ++ ", " ++ rrest)
  o

-- the impl groups of one method, in program order.
implGroupsForMethod : Emit -> String -> <Mut> List ImplGroup
implGroupsForMethod e method = filterGroupsByMethod method (groupImpls (implEntriesOf e))

filterGroupsByMethod : String -> List ImplGroup -> List ImplGroup
filterGroupsByMethod _ [] = []
filterGroupsByMethod method (g::rest)
  | groupMethodOf g == method = g :: filterGroupsByMethod method rest
  | otherwise = filterGroupsByMethod method rest

groupTag : ImplGroup -> String
groupTag (ImplGroup _ tag _ _ _) = tag

groupMethodOf : ImplGroup -> String
groupMethodOf (ImplGroup m _ _ _ _) = m

groupPositionsOf : ImplGroup -> List Int
groupPositionsOf (ImplGroup _ _ p _ _) = p

headGroup : List ImplGroup -> ImplGroup
headGroup (g::_) = g
headGroup [] = panic "llvm spike: no impl group for arg-tag dispatch (slice 7)"

-- the discriminating arg position (first dispatch position; default 0 — for a
-- single-position method like `eq` the head suffices, both args share the type).
headPos : List Int -> Int
headPos (p::_) = p
headPos [] = 0

nthStr : List String -> Int -> String
nthStr (x::_) 0 = x
nthStr (_::rest) i = nthStr rest (i - 1)
nthStr [] _ = panic "llvm spike: discriminating arg index out of range (slice 7)"

-- a constrained-function occurrence (CDict): `name` is a `=>`-constrained function
-- that dict_pass gave leading dict PARAMETERS; the routes give the dict values for
-- this call site.  Lower to a direct call passing the dict words FOLLOWED by the
-- real argument words — the same order applyDicts prepends them at run time and
-- the order emitFn bound `name`'s leading dict params.
emitDictApp : Emit -> List (String, (String, LTy)) -> String -> List Route -> List String -> <Mut> (String, LTy)
emitDictApp e env name routes argOps =
  if isKnownFn e name then
    let dictWords = dictWordsOf e env routes
    let r = freshReg e
    let _ = emit e ("  " ++ r ++ " = call i64 @mdk_" ++ name ++ "(" ++ argDecls (dictWords ++ argOps) ++ ")")
    (r, fnRetTy e name)
  else gapE ("CDict head '" ++ name ++ "' is not a known top-level function (slice 6)")

-- the dict witness words for a constrained-function call's routes (note (j)).
dictWordsOf : Emit -> List (String, (String, LTy)) -> List Route -> <Mut> List String
dictWordsOf _ _ [] = []
dictWordsOf e env (r::rest) = dictWordOfRoute e env r :: dictWordsOf e env rest

-- one route -> its dict witness word (GAP 1, Option A — BOXED dict witness).
-- A dict witness is a POINTER to a heap cell `[ i64 head_tag | i64 reqdict_0 | … ]`
-- allocated via @mdk_alloc (the same boxed-cell shape emitCtorAlloc uses): field 0
-- is `hashName(impl-head-tag)`, fields 1..n are the RECURSIVELY-built witness words
-- for the impl's per-instance `requires` dicts, in `reqs` order (matching the
-- interpreter's structured `VDict(key, map dict_of_route reqs)` and the leading
-- dict-param order dict_pass binds — methRoutes then implRoutes, here the impl's
-- own requires).  This makes the rep UNIFORM: a one-level dict (`RKey k []`) is a
-- pointer to a 1-word cell `[ hashName k ]`; a two-level dict nests another cell
-- pointer in field 1.  Consumption (emitDispatchChain / the RKey direct-call path)
-- loads field 0 for the icmp and prepends fields 1..n as the matched impl's leading
-- element-dict args.  RDict/RDictFwd forward the enclosing dict parameter's word
-- (already a boxed-cell pointer); RNone is the 0 dict (no cell).
dictWordOfRoute : Emit -> List (String, (String, LTy)) -> Route -> <Mut> String
dictWordOfRoute e env (RKey key reqs) =
  let reqWords = dictWordsOf e env reqs
  emitDictCell e (hashName key) reqWords
dictWordOfRoute _ env (RDict d) = dictOperand env d
dictWordOfRoute _ env (RDictFwd d) = dictOperand env d
dictWordOfRoute _ _ RNone = "0"
dictWordOfRoute _ _ RLocal = "0"  -- C5: RLocal carries no dict (mirror eval.mdk's no-op dict)

-- allocate a boxed dict-witness cell `[ i64 headTag | i64 req_0 | … | i64 req_(n-1) ]`
-- via @mdk_alloc and return its pointer word (ptrtoint).  Mirrors emitCtorAlloc's
-- header+fields layout (header at offset 0, field i at 8*(i+1)) so loadField /
-- loadTag read it back without type info.  A one-word cell (no reqs) is the
-- uniform one-level dict.
emitDictCell : Emit -> Int -> List String -> <Mut> String
emitDictCell e headTag reqWords =
  let n = lengthS reqWords
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = call ptr @mdk_alloc(i64 " ++ intToString (8 * (n + 1)) ++ ")")
  let _ = emit e ("  store i64 " ++ intToString headTag ++ ", ptr " ++ p)
  let _ = storeFields e p reqWords 0
  let w = freshReg e
  let _ = emit e ("  " ++ w ++ " = ptrtoint ptr " ++ p ++ " to i64")
  w

-- the operand word a dict parameter name is bound to in the emit env.
dictOperand : List (String, (String, LTy)) -> String -> <Mut> String
dictOperand env d = match lookupAssoc d env
  Some (op, _) => op
  None => gapStr ("unbound dict witness '" ++ d ++ "' in emit env (slice 6: dict not threaded to this site)")

ensureNoReqs : List Route -> <Mut> Unit
ensureNoReqs [] = ()
ensureNoReqs _ = ()

-- ── impl method definitions (slice 6 + slice 7) ─────────────────────────────
-- Each typeclass impl method lowers to ONE top-level `@mdk_impl_<tag>_<method>`,
-- emitted alongside the ordinary function defines (before @main).  Untagged
-- interface defaults (CImplDefault) are the arg-tag fallback path — never a
-- static-dispatch target — so they are skipped.
--
-- SLICE 7 — multi-clause / arg-position impl methods.  The Core IR carries one
-- CImplEntry PER CLAUSE (eval coalesces same-named candidates into a VMulti that
-- falls through arg-by-arg, leftmost clause winning — exactly Maranget column
-- specialization, see ceval/applyOpt/collectPartials).  So same-`(method,tag)`
-- entries are COALESCED here into a single lifted fn whose body is a decision
-- tree built by the SAME `compileTree` the match lowering uses (Axis-1: shared
-- backend-neutral pass).  By arity:
--   • 0 (slice-6 nullary return-position `zero`/`def`): the body is emitted in
--     TAIL position (emitFnBody), byte-for-byte the old single-clause path.
--   • 1: the lone param `%arg0` is the scrutinee; the clauses' single patterns
--     are the match arms.
--   • ≥2: the params are wrapped in a synthetic tuple `(a0, a1, …)` so the
--     multi-param match reduces to a single scrutinee — letting emitDecision /
--     emitTree / bindPattern be reused VERBATIM (note (o); one extra `$tuple`
--     cell alloc per call, acceptable for the spike).

-- a coalesced impl group: method, type-head tag, dispatch positions, arity, and
-- the clauses (patterns + body) in source order (leftmost-first — the priority
-- the decision tree preserves).
data ImplGroup = ImplGroup String String (List Int) Int (List (List Pat, CExpr))

emitImpls : Emit -> List CImplEntry -> <Mut> Unit
emitImpls e entries = emitGroups e (groupImpls entries)

emitGroups : Emit -> List ImplGroup -> <Mut> Unit
emitGroups _ [] = ()
emitGroups e (g::rest) =
  let _ = emitGroup e g
  emitGroups e rest

emitGroup : Emit -> ImplGroup -> <Mut> Unit
emitGroup e (ImplGroup method tag positions arity clauses) =
  let fname = implFnName tag method
  -- native backend: set the self-returning-fn-param context for this impl body so
  -- `emitIndirect` types `f x` (a callback returning the container) as the impl's
  -- own type.  The self-fn positions come from the method's signature (keyed by
  -- iface, looked up from the resolved impl entry); their names are the PVar names
  -- the clauses bind at those positions.  (Set BEFORE choosing the TRMC vs ordinary
  -- body so a cons-head callback `f x` — e.g. `map`'s `f x :: …` — types correctly.)
  let iface = implGroupIface e method tag
  let selfFnPos = selfFnParamPositions iface method
  let _ = setCurImplSelfFns tag (selfFnParamNames clauses selfFnPos)
  -- Phase 2 B-dispatch (TRMC-DESIGN.md): a DISPATCHED self-recursive cons/ctor-tail
  -- impl method (`map`/`filterMap`/`ap` over List, recursing via a `CMethod method
  -- (RKey tag)` node) is emitted as an O(1)-stack destination-passing loop, just like
  -- a top-level builder.  F2(a) scope: NON-dict impls only (`trmcNonDict`); a
  -- point-free eta-reshaped impl (`filter p = filterMap …`) is a single dispatched
  -- call, NOT cons-tail-recursive, so `trmcEligible` rejects it (stays ordinary).
  if trmcImplTry e fname method tag positions arity clauses then
    let _ = clearCurImplSelfFns ()
    ()
  else
    let _ = emit e ("define i64 @" ++ fname ++ "(" ++ implParamDecls arity 0 ++ ") {")
    let _ = emit e "entry:"
    let _ = emitGroupBody e fname tag positions arity clauses
    let _ = clearCurImplSelfFns ()
    let _ = emit e "}"
    emit e ""

-- Phase 2 B-dispatch: try to emit an impl group as a TRMC destination-passing loop.
-- Returns True (and emits the whole define) when the impl is F2(a)-eligible: NON-dict
-- (`trmcNonDict`) and cons/ctor-tail self-recursive via its own `CMethod method
-- (RKey tag)` dispatch (`trmcEligible (SelfByMethod …)`).  Otherwise returns False so
-- emitGroup falls back to the ordinary `emitGroupBody`.  The loop body reuses
-- emitTrmcLoopBody verbatim (the shared Axis-A machinery); the impl path supplies the
-- `@mdk_impl_<tag>_<method>` define name, the receiver-typed `aK` scrutinee env
-- (`patPosTys`), and the SelfByMethod self-ref for the cons/ctor leaf's self-call
-- recognition + the safety-critical `mentionsSelfMethod` disqualification.
trmcImplTry : Emit -> String -> String -> String -> List Int -> Int -> List (List Pat, CExpr) -> <Mut> Bool
trmcImplTry e fname method tag positions arity clauses =
  let self = SelfByMethod method tag
  if arity > 0 && trmcNonDict clauses && trmcEligible e self arity clauses then
    let slotTys = patPosTys tag positions arity 0
    let (spats, sbody) = match clauses
      ((ps, b)::_) => (ps, b)
      [] => ([], CLit LUnit)
    let single = listLen clauses == 1 && allClausesPVar clauses
    let _ = emitTrmcHeader e fname arity
    let _ = emitTrmcLoopBody e self arity slotTys clauses single spats sbody
    let _ = emit e "}"
    let _ = emit e ""
    True
  else False

-- ── interface DEFAULT method bodies (E19) ───────────────────────────────────
-- An interface default (`CImplDefault`) the type's `impl` did not override is
-- lifted to a `@mdk_default_<method>[_<tag>]` define ON DEMAND (the first dispatch
-- that needs it), cached so each (method, tag) is emitted once.  Like a lifted
-- lambda, the define is emitted into the SIDE buffer (LLVM forbids nesting it
-- inside the body being emitted) via the bufRef save/restore swap.
--
-- Two transforms make the point-free / return-position default callable as a
-- DIRECT impl-shaped fn:
--   • ETA-EXPAND to the method's full declared arity (methodArityOf): `filter p =
--     filterMap …` declares arity 2 (`(a->Bool) -> f a -> f a`) but binds one
--     param; the missing trailing params are added and the body applied to them,
--     so the direct call passes every call-site argument.
--   • RE-STAMP inner SAME-interface method calls to `RKey tag` (concrete-tag
--     defaults only — the `filter`@List path): the inner `filterMap` is partially
--     applied (container not yet supplied) so it cannot arg-tag-dispatch; stamping
--     it to the same dispatch tag lowers it to a direct `@mdk_impl_<tag>_filterMap`
--     call.  The arg-tag default path (max/min, tag="") skips this — its inner
--     `compare m x` HAS the discriminating arg and dispatches at run time.
ensureDefaultEmitted : Emit -> String -> String -> String -> CImplEntry -> <Mut> Unit
ensureDefaultEmitted e fname tag method entry =
  if defaultAlreadyEmitted fname then ()
  else
    let _ = markDefaultEmitted fname
    emitDefaultDefine e fname tag method entry

emitDefaultDefine : Emit -> String -> String -> String -> CImplEntry -> <Mut> Unit
emitDefaultDefine e fname tag method entry =
  let pats0 = implPats entry
  let body0 = implBody entry
  let arity = maxInt (methodArityOf method) (listLen pats0)
  let (pats, body1) = etaExpand pats0 body0 arity (listLen pats0)
  -- re-stamp inner same-interface method occurrences to the concrete RKey tag so a
  -- partially-applied inner method (`filterMap` in `filter`'s body) lowers to a
  -- direct `@mdk_impl_<tag>_<method>` call instead of an arg-tag site.
  let body = restampIface methodIfaceTableRef.value (methodIfaceOf method) tag body1
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let savedFt = fallthroughLabelRef.value
  let _ = set_ref fallthroughLabelRef ""
  let _ = emit e ("define i64 @" ++ fname ++ "(" ++ implParamDecls arity 0 ++ ") {")
  let _ = emit e "entry:"
  let _ = emitGroupBody e fname tag [] arity [(pats, body)]
  let _ = emit e "}"
  let _ = emit e ""
  let defLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (defLines ++ (lamsRef e).value)
  let _ = set_ref fallthroughLabelRef savedFt
  set_ref (bufRef e) saved

maxInt : Int -> Int -> Int
maxInt a b = if a >= b then a else b

-- eta-expand `pats`/`body` from `have` params to `arity` by appending fresh
-- `$etaK` params and applying the body to each (left-to-right).
etaExpand : List Pat -> CExpr -> Int -> Int -> (List Pat, CExpr)
etaExpand pats body arity have
  | have >= arity = (pats, body)
  | otherwise =
      let name = "$eta" ++ intToString have
      etaExpand (pats ++ [PVar name]) (CApp body (CVar name AGlobal)) arity (have + 1)

-- rewrite every inner SAME-interface method occurrence (a bare `CVar m` whose
-- interface equals `iface`) to a `CMethod m (RKey tag)`, so a partially-applied
-- inner method lowers to a direct impl call.  Walks the whole CExpr tree.  The
-- method→(iface,arity) table is passed in (a pure snapshot) so the walk stays pure.
restampIface : List (String, (String, Int)) -> String -> String -> CExpr -> CExpr
restampIface tbl iface tag (CVar m ad)
  | iface != "" && ifaceOfIn tbl m == iface = CMethod m (RKey tag []) [] []
  | otherwise = CVar m ad
-- An inner same-interface method that method_marker already rewrote to a
-- `CMethod m RNone` (e.g. `compare` inside the `lt`/`gt`/… Ord defaults) must
-- ALSO be re-stamped to `RKey tag`, or it falls to arg-tag dispatch and a
-- primitive-Ord receiver (which owns no cell tag) panics in emitTagMatch.  Only
-- an unrouted (RNone) same-iface method is restamped — an already-concrete route
-- (a different element type) is left intact.
restampIface tbl iface tag (CMethod m RNone irs mrs)
  | iface != "" && ifaceOfIn tbl m == iface = CMethod m (RKey tag []) irs mrs
  | otherwise = CMethod m RNone irs mrs
restampIface tbl iface tag (CApp f a) = CApp (restampIface tbl iface tag f) (restampIface tbl iface tag a)
restampIface tbl iface tag (CLam ps b) = CLam ps (restampIface tbl iface tag b)
restampIface tbl iface tag (CLet r p rhs b) = CLet r p (restampIface tbl iface tag rhs) (restampIface tbl iface tag b)
restampIface tbl iface tag (CLetGroup bs b) = CLetGroup (map (restampBind tbl iface tag) bs) (restampIface tbl iface tag b)
restampIface tbl iface tag (CMatch s arms) = CMatch (restampIface tbl iface tag s) (map (restampArm tbl iface tag) arms)
restampIface tbl iface tag (CDecision s arms tr) = CDecision (restampIface tbl iface tag s) (map (restampArm tbl iface tag) arms) tr
restampIface tbl iface tag (CIf c t el) = CIf (restampIface tbl iface tag c) (restampIface tbl iface tag t) (restampIface tbl iface tag el)
restampIface tbl iface tag (CBinPrim op a b) = CBinPrim op (restampIface tbl iface tag a) (restampIface tbl iface tag b)
restampIface tbl iface tag (CUnOp op a) = CUnOp op (restampIface tbl iface tag a)
restampIface tbl iface tag (CTuple xs) = CTuple (map (restampIface tbl iface tag) xs)
restampIface tbl iface tag (CList xs) = CList (map (restampIface tbl iface tag) xs)
restampIface tbl iface tag (CFieldAccess a f) = CFieldAccess (restampIface tbl iface tag a) f
restampIface tbl iface tag (CIndex a b) = CIndex (restampIface tbl iface tag a) (restampIface tbl iface tag b)
restampIface _ _ _ other = other

-- the interface a method name belongs to, looked up in a pure table snapshot.
ifaceOfIn : List (String, (String, Int)) -> String -> String
ifaceOfIn tbl m = match lookupAssoc m tbl
  Some (iface, _) => iface
  None => ""

restampBind : List (String, (String, Int)) -> String -> String -> CBind -> CBind
restampBind tbl iface tag (CBind n cs) = CBind n (map (restampClause tbl iface tag) cs)

restampClause : List (String, (String, Int)) -> String -> String -> CClause -> CClause
restampClause tbl iface tag (CClause ps b) = CClause ps (restampIface tbl iface tag b)

restampArm : List (String, (String, Int)) -> String -> String -> CArm -> CArm
restampArm tbl iface tag (CArm p gs b) = CArm p (map (restampGuard tbl iface tag) gs) (restampIface tbl iface tag b)

restampGuard : List (String, (String, Int)) -> String -> String -> CGuard -> CGuard
restampGuard tbl iface tag (CGBool c) = CGBool (restampIface tbl iface tag c)
restampGuard tbl iface tag (CGBind p c) = CGBind p (restampIface tbl iface tag c)

-- the interface a (method, tag) impl belongs to, via the resolved impl entry.
implGroupIface : Emit -> String -> String -> <Mut> String
implGroupIface e method tag = match implFor e method tag
  Some entry => implEntryIface entry
  None => ""

-- the PVar names bound at the self-fn positions, taken from the FIRST clause that
-- binds a plain variable there (impl callback params are PVars across clauses; a
-- non-PVar position contributes no name and is simply not typed specially).
selfFnParamNames : List (List Pat, CExpr) -> List Int -> List String
selfFnParamNames clauses positions = dedupS (concatMapClausePVars clauses positions)

concatMapClausePVars : List (List Pat, CExpr) -> List Int -> List String
concatMapClausePVars [] _ = []
concatMapClausePVars ((pats, _)::rest) positions =
  pvarsAtPositions pats positions 0 ++ concatMapClausePVars rest positions

pvarsAtPositions : List Pat -> List Int -> Int -> List String
pvarsAtPositions [] _ _ = []
pvarsAtPositions ((PVar x)::rest) positions i
  | listContains positions i = x :: pvarsAtPositions rest positions (i + 1)
  | otherwise = pvarsAtPositions rest positions (i + 1)
pvarsAtPositions (_::rest) positions i = pvarsAtPositions rest positions (i + 1)

-- the lifted impl fn's positional parameter list: `i64 %arg0, …` (arity words),
-- or "" for a nullary return-position impl.
implParamDecls : Int -> Int -> String
implParamDecls n i
  | i >= n = ""
  | i == n - 1 = "i64 %arg" ++ intToString i
  | otherwise = "i64 %arg" ++ intToString i ++ ", " ++ implParamDecls n (i + 1)

-- bind each positional param to its `%argK` operand under a synthetic name aK
-- (the names the synthetic scrutinee CVars reference).
implParamEnv : Int -> Int -> List (String, (String, LTy))
implParamEnv n i
  | i >= n = []
  | otherwise = ("a" ++ intToString i, ("%arg" ++ intToString i, LTInt)) :: implParamEnv n (i + 1)

-- map an impl head tag name to its static LTy for use in param typing.
-- Known primitives → their type; everything else (ADT, List, Array, tuples, …) → LTCon.
tagToLTy : String -> LTy
tagToLTy "String" = LTStr
tagToLTy "Int"    = LTInt
tagToLTy "Float"  = LTFloat
tagToLTy "Bool"   = LTBool
tagToLTy "Char"   = LTChar
tagToLTy _        = LTCon

-- like implParamEnv, but types param `i` as `tagToLTy tag` when `i ∈ positions`
-- (the receiver-type positions from CImplTagged), otherwise LTInt.
-- This lets `append xs ys = xs ++ ys` in impl Semigroup (List a) emit xs/ys as
-- LTCon → mdk_list_append, and in impl Semigroup String emit them as LTStr →
-- mdk_string_append — without touching emitBin.
implParamEnvByPos : String -> List Int -> Int -> Int -> List (String, (String, LTy))
implParamEnvByPos _ _ n i | i >= n = []
implParamEnvByPos tag positions n i =
  let ty = if listContains positions i then tagToLTy tag else LTInt
  ("a" ++ intToString i, ("%arg" ++ intToString i, ty)) :: implParamEnvByPos tag positions n (i + 1)

listContains : List Int -> Int -> Bool
listContains [] _ = False
listContains (x :: rest) v
  | x == v    = True
  | otherwise = listContains rest v


emitGroupBody : Emit -> String -> String -> List Int -> Int -> List (List Pat, CExpr) -> <Mut> Unit
emitGroupBody e fname _ _ 0 clauses = match clauses
  [([], body)] => emitFnBody e [] fname body
  _ => gapU "nullary impl group with more than one clause (slice 6)"
-- Fast path: single-clause all-PVar impl (e.g. `append xs ys = xs ++ ys`).
-- Build a typed env directly from param names × receiver type so that `++`/`::`
-- operands inherit the correct LTy (LTStr/LTCon) from the impl head tag.
-- The decision-tree path (emitClauseTree) loses this type info through the
-- tuple-scrutinee indirection → paramUseTy falls back to LTInt → ++ gaps.
--
-- NOTE: this dispatch is written with `if`-EXPRESSIONS (not a guarded match arm)
-- so the emitter itself is self-compilable — the gap-tolerant bootstrap driver
-- cannot lower a guarded match arm (it inserts a `store 0` placeholder, see the
-- CTGuard arm of emitTree), which would silently blank this body in the native
-- emitter.  The IR produced is byte-identical to the guarded form; only the
-- source shape changes.  (The other selfhost stages contain NO guarded matches
-- for the same reason.)
emitGroupBody e fname tag positions arity clauses =
  match clauses
    [(pats, body)] =>
      if allPVar pats then
        let tyList = patPosTys tag positions (listLen pats) 0
        let env = paramEnvByPos pats tyList 0
        emitFnBody e env fname body
      else emitClauseTree e (implParamEnvByPos tag positions arity 0) arity clauses
    _ =>
      emitClauseTree e (implParamEnvByPos tag positions arity 0) arity clauses

-- build a LTy list of length n, typed as tagToLTy tag at positions ∈ positions,
-- LTInt elsewhere.
patPosTys : String -> List Int -> Int -> Int -> List LTy
patPosTys _ _ n i | i >= n = []
patPosTys tag positions n i =
  let ty = if listContains positions i then tagToLTy tag else LTInt
  ty :: patPosTys tag positions n (i + 1)

-- bind PVar params to their %argK operands at the given LTy list.
paramEnvByPos : List Pat -> List LTy -> Int -> List (String, (String, LTy))
paramEnvByPos [] _ _ = []
paramEnvByPos ((PVar x) :: rest) (ty :: tys) i =
  (x, ("%arg" ++ intToString i, ty)) :: paramEnvByPos rest tys (i + 1)
paramEnvByPos ((PVar x) :: rest) [] i =
  (x, ("%arg" ++ intToString i, LTInt)) :: paramEnvByPos rest [] (i + 1)
paramEnvByPos _ _ _ = []

-- the shared decision-tree body for a coalesced multi-clause group (impl methods
-- AND top-level fns, slice 2/E1a).  `env` binds the synthetic `aK` scrutinee
-- params to their `%argK` operands at the caller's chosen LTy (impl: all LTInt;
-- top-level fn: the inferred signature param types).  arity 1 scrutinises the
-- lone param directly; arity ≥2 wraps the params in a synthetic tuple so the
-- multi-param match reduces to one scrutinee, reusing emitDecision verbatim.
emitClauseTree : Emit -> List (String, (String, LTy)) -> Int -> List (List Pat, CExpr) -> <Mut> Unit
emitClauseTree e env arity clauses =
  let scrut = if arity == 1 then CVar "a0" AGlobal else CTuple (implScrutVars arity 0)
  -- Emit the clauses as a CHAIN of single-clause decision trees sharing one result
  -- slot + end label.  Each clause sets fallthroughLabelRef to the NEXT clause's
  -- entry block before emitting, so a pattern miss (CTFail) or a guard fallthrough
  -- (`__fallthrough__`) resumes the next clause — the interpreter's "try next
  -- clause" semantics.  The scrutinee is emitted ONCE, before the chain.  (A lone
  -- clause degenerates to the historical single-tree path: no next label → CTFail
  -- stays `unreachable`, fallthrough stays oob.)
  let (sv, _) = emitExpr e env scrut
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "decend" ++ intToString (freshId e)
  let rty = Ref LTInt
  let saved = fallthroughLabelRef.value
  let _ = emitClauseChain e env arity clauses sv slot endL rty saved
  let _ = set_ref fallthroughLabelRef saved
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ slot)
  emit e ("  ret i64 " ++ r)

-- emit clause chain: each clause's fallthrough target is the NEXT clause's entry
-- block; the LAST clause falls through to `outer` (the fallthrough that was in
-- effect when the chain began — "" at top level → oob; a nested chain inside a
-- guarded clause body inherits the enclosing clause's next-clause label).  A
-- single-clause function degenerates to `outer` directly, preserving the historical
-- single-tree behaviour.
emitClauseChain : Emit -> List (String, (String, LTy)) -> Int -> List (List Pat, CExpr) -> String -> String -> String -> Ref LTy -> String -> <Mut> Unit
emitClauseChain _ _ _ [] _ _ _ _ _ = ()
emitClauseChain e env arity (c::rest) sv slot endL rty outer =
  let nextL = chainNextLabel e rest outer
  let arms = [clauseArm arity c]
  let tree = compileTree [False] (implRows arity [c] 0)
  let _ = set_ref fallthroughLabelRef nextL
  let _ = emitTree e env sv arms [sv] slot endL rty tree
  if isEmptyL rest then ()
  else
    let _ = emit e (nextL ++ ":")
    emitClauseChain e env arity rest sv slot endL rty outer

-- the next clause's entry label: the outer fallthrough when this is the last
-- clause, else a fresh `clauseN` block label.
chainNextLabel : Emit -> List (List Pat, CExpr) -> String -> <Mut> String
chainNextLabel _ [] outer = outer
chainNextLabel e _ _ = "clause" ++ intToString (freshId e)

isEmptyL : List a -> Bool
isEmptyL [] = True
isEmptyL _ = False

-- the synthetic scrutinee components for an arity-≥2 impl: `[a0, a1, …]`.
implScrutVars : Int -> Int -> List CExpr
implScrutVars n i
  | i >= n = []
  | otherwise = CVar ("a" ++ intToString i) AGlobal :: implScrutVars n (i + 1)

-- one match arm per clause: arity 1 uses the lone pattern directly; arity ≥2
-- wraps the patterns in a tuple pattern (matching the tuple scrutinee).
clauseArm : Int -> (List Pat, CExpr) -> CArm
clauseArm 1 (pats, body) = CArm (headPat pats) [] body
clauseArm _ (pats, body) = CArm (PTuple pats) [] body

-- one matrix row per clause (single column: the lone/tuple pattern, CANONICALISED
-- into matrix form via canonPat — the same normalisation initialRows applies to
-- match arms, so compileTree recognises tuple/bool/list heads), index = the
-- clause position so the decision-tree leaf selects the right arm.  The ARM keeps
-- the RAW pattern (clauseArm) — bindPattern re-matches that to bind variables.
implRows : Int -> List (List Pat, CExpr) -> Int -> List (List Pat, Int)
implRows _ [] _ = []
implRows 1 ((pats, _)::rest) i = ([canonPat (headPat pats)], i) :: implRows 1 rest (i + 1)
implRows arity ((pats, _)::rest) i = ([canonPat (PTuple pats)], i) :: implRows arity rest (i + 1)

headPat : List Pat -> Pat
headPat (p::_) = p
headPat [] = PWild

-- ── impl coalescing (slice 7) ───────────────────────────────────────────────
-- group the per-clause CImplTagged entries by `(method, tag)`, preserving the
-- first-seen group order and the source clause order within each (the Maranget
-- priority).  CImplDefault entries (interface defaults) are skipped — they are
-- the arg-tag fallback, never a lifted static-dispatch target.
groupImpls : List CImplEntry -> <Mut> List ImplGroup
groupImpls entries = mapMut (gatherGroup entries) (distinctImplKeys entries [])

-- map a <Mut> function over a list (map is pure; gatherGroup now reads the method
-- arity table to eta-expand point-free impls, so the walk must be <Mut>).
mapMut : (a -> <Mut> b) -> List a -> <Mut> List b
mapMut _ [] = []
mapMut f (x::rest) = f x :: mapMut f rest

-- the (method, tag) keys of tagged entries, in first-seen order.
distinctImplKeys : List CImplEntry -> List (String, String) -> List (String, String)
distinctImplKeys [] seen = reverseL seen
distinctImplKeys ((CImplEntry method _ (CImplTagged tag _ _ _ _))::rest) seen
  | keySeen method tag seen = distinctImplKeys rest seen
  | otherwise = distinctImplKeys rest ((method, tag) :: seen)
distinctImplKeys (_::rest) seen = distinctImplKeys rest seen

keySeen : String -> String -> List (String, String) -> Bool
keySeen _ _ [] = False
keySeen m t ((m2, t2)::rest) = if m == m2 && t == t2 then True else keySeen m t rest

-- build the group for one (method, tag) key: positions + arity from the first
-- matching entry, clauses (pats, body) from all matching entries in order.  A
-- POINT-FREE impl (`length = fold f 0` — clauseArity < the method's declared
-- arity) is ETA-EXPANDED to the method's full arity, mirroring emitDefaultDefine:
-- the lifted `@mdk_impl_<tag>_<method>` then takes every call-site arg, so the
-- RKey/arg-tag call sites (which use methodArityOf) and the define agree.  A
-- multi-clause or already-full-arity impl is unchanged (etaExpand is a no-op when
-- have >= arity).
gatherGroup : List CImplEntry -> (String, String) -> <Mut> ImplGroup
gatherGroup entries (method, tag) =
  let cls0 = gatherClauses method tag entries
  let positions = groupPositions method tag entries
  let arity = maxInt (clauseArity cls0) (methodArityOf method)
  let cls = map (etaExpandClause arity) cls0
  ImplGroup method tag positions arity cls

-- eta-expand one impl clause's (pats, body) to `arity` (no-op when already there).
etaExpandClause : Int -> (List Pat, CExpr) -> (List Pat, CExpr)
etaExpandClause arity (pats, body) = etaExpand pats body arity (lengthS pats)

gatherClauses : String -> String -> List CImplEntry -> List (List Pat, CExpr)
gatherClauses _ _ [] = []
gatherClauses method tag ((CImplEntry m _ (CImplTagged t _ _ pats body))::rest)
  | m == method && t == tag = (pats, body) :: gatherClauses method tag rest
  | otherwise = gatherClauses method tag rest
gatherClauses method tag (_::rest) = gatherClauses method tag rest

groupPositions : String -> String -> List CImplEntry -> List Int
groupPositions _ _ [] = []
groupPositions method tag ((CImplEntry m _ (CImplTagged t _ positions _ _))::rest)
  | m == method && t == tag = positions
  | otherwise = groupPositions method tag rest
groupPositions method tag (_::rest) = groupPositions method tag rest

clauseArity : List (List Pat, CExpr) -> Int
clauseArity ((pats, _)::_) = lengthS pats
clauseArity [] = 0


-- ── closures + higher-order functions (slice 4) ─────────────────────────────
-- VALUE REPRESENTATION (RUNTIME-DESIGN.md §8.5 "Closures"): a closure value is a
-- BOXED heap cell, the same boxed-pointer discipline as ADTs (slice 3) and Floats
-- (slice 1).  Cell layout (8-byte words):
--   [ 0: i64 header ] [ 8: i64 code_ptr ] [ 16: capt0 ] [ 24: capt1 ] …
-- DECISION (filed in PLAN.md as a spike-rep note): the cell carries a one-word
-- HEADER (a fixed closure tag) before `code_ptr`, mirroring §8.5's `{ header,
-- code_ptr, captured… }` and the slice-3 ADT header — NOT code_ptr-at-offset-0.
-- This lets the closure cell reuse `emitCtorAlloc`/`storeFields`/`loadField`
-- VERBATIM: it is allocated exactly like a constructor whose "fields" are
-- `[code_ptr, capt0, capt1, …]`, so `code_ptr` is field 0 and capture i is field
-- i+1.  The CALLING CONVENTION (§8.5): load `code_ptr`, then call passing the
-- closure pointer as a LEADING argument (`@mdk_lamN(i64 %clos, i64 %arg0, …)`).
--
-- Each CLam is LAMBDA-LIFTED to a top-level `define @mdk_lamN` (LLVM has no nested
-- functions).  Its CAPTURED set is freeVars(body) − params, intersected with the
-- emit-time env (free names NOT in the env are top-level globals — known fns /
-- ctors — which need no capture).  At the CLam site we allocate the cell storing
-- `[&@mdk_lamN, capturedWords…]`; in the lifted body we bind params from `%argK`
-- and re-load captures from `%clos`.  Lifted-lambda params/captures default to Int
-- (the type-erased subset; every slice-4 fixture's lambda is Int-typed) — a
-- documented scope limit, like the saturated-only call rule above.

-- the fixed closure-cell header tag.  A "$"-prefixed sentinel, so `cellTag` keeps
-- it on `hashName` rather than a ctor ordinal — closures never flow into a
-- constructor `match`, so the tag is never compared; it just fills the §8.5
-- header word.
closureHeaderName : String
closureHeaderName = "$closure"

-- allocate a closure cell {header, code_ptr, captured…}: reuse the slice-3 ctor
-- alloc with "fields" = [code_ptr, capture…].  `code_ptr` is a constant-expression
-- operand (`ptrtoint (ptr @mdk_lamN to i64)`); `emitCtorAlloc` stores it like any
-- field word.  Result is the cell pointer word, typed LTClosure.
emitClosureAlloc : Emit -> String -> List String -> <Mut> (String, LTy)
emitClosureAlloc e lamName captureWords =
  let codePtr = "ptrtoint (ptr @" ++ lamName ++ " to i64)"
  let (w, _) = emitCtorAlloc e closureHeaderName (codePtr :: captureWords)
  (w, LTClosure)

-- emit a CLam: compute its captured set, lift its body to a top-level define, and
-- allocate the closure cell capturing the live operand words.
-- E2b — a CLam whose params are NOT all plain `PVar` (a tuple/constructor
-- destructuring lambda) routes through `emitLamPatDefine`: the SAME lifted-frame
-- machinery as `emitLamGo`, but the patterned params are bound by a single-clause
-- decision tree (`emitClauseTree`) over the `%argK` words instead of a verbatim
-- `paramEnv`.  Capture computation is identical — `patVarNames` already collects
-- nested pattern vars, so the patterned param vars are correctly excluded from the
-- captured set.  Closes the lambda half of EMITTER-GAPS #5.
emitLam : Emit -> List (String, (String, LTy)) -> List Pat -> CExpr -> <Mut> (String, LTy)
emitLam e env pats body =
  if allPVar pats then emitLamGo e env pats body
  else emitLamPat e env pats body

emitLamGo : Emit -> List (String, (String, LTy)) -> List Pat -> CExpr -> <Mut> (String, LTy)
emitLamGo e env pats body =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let pnames = patVarNames pats
  let captured = keepInEnv env (dedupS (freeVars pnames body))
  let captureWords = capWords env captured
  let _ = emitLamDefine e lamName pats captured body
  emitClosureAlloc e lamName captureWords

emitLamPat : Emit -> List (String, (String, LTy)) -> List Pat -> CExpr -> <Mut> (String, LTy)
emitLamPat e env pats body =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let pnames = patVarNames pats
  let captured = keepInEnv env (dedupS (freeVars pnames body))
  let captureWords = capWords env captured
  let _ = emitPatLamDefine e lamName [] pats captured body
  emitClosureAlloc e lamName captureWords

-- emit a RECURSIVE function-`let` closure (slice 5b): lambda-lift exactly like
-- emitLam, but EXCLUDE the binding's own name `f` from the captured set (it is the
-- closure cell itself, not an external free variable) and, inside the lifted body,
-- bind `f` to `%clos` so a self-call re-enters the same code with the same cell.
emitRecLam : Emit -> List (String, (String, LTy)) -> String -> List Pat -> CExpr -> <Mut> (String, LTy)
emitRecLam e env f pats body =
  if allPVar pats then emitRecLamGo e env f pats body
  else emitRecLamPat e env f pats body

emitRecLamGo : Emit -> List (String, (String, LTy)) -> String -> List Pat -> CExpr -> <Mut> (String, LTy)
emitRecLamGo e env f pats body =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let pnames = patVarNames pats
  let captured = keepInEnv env (removeStr f (dedupS (freeVars pnames body)))
  let captureWords = capWords env captured
  let _ = emitRecLamDefine e lamName f pats captured body
  emitClosureAlloc e lamName captureWords

-- E2b — recursive-`let` lambda with non-`PVar` params: same patterned-frame body
-- as `emitLamPat`, but binds `f -> %clos` ahead of captures so a self-call
-- re-enters the same code with the same cell (mirrors `emitRecLamGo` vs
-- `emitLamGo`).  `f` is removed from the free set before computing captures.
emitRecLamPat : Emit -> List (String, (String, LTy)) -> String -> List Pat -> CExpr -> <Mut> (String, LTy)
emitRecLamPat e env f pats body =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let pnames = patVarNames pats
  let captured = keepInEnv env (removeStr f (dedupS (freeVars pnames body)))
  let captureWords = capWords env captured
  let _ = emitPatLamDefine e lamName [(f, ("%clos", LTClosure))] pats captured body
  emitClosureAlloc e lamName captureWords

-- like emitLamDefine, but prepends `f -> %clos` to the body's env so the lifted
-- body's recursive references resolve to the closure pointer (the leading param).
-- (Gap E3: lambda params are per-param inferred from the body via `inferParamTys`/
-- `paramUseTy`, so a Float-param lambda gets float instruction selection; params
-- `paramUseTy` can't resolve default to LTInt as before.)
emitRecLamDefine : Emit -> String -> String -> List Pat -> List String -> CExpr -> <Mut> Unit
emitRecLamDefine e lamName f pats captured body =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let _ = emit e ("define i64 @" ++ lamName ++ "(" ++ closureParamDecls pats ++ ") {")
  let _ = emit e "entry:"
  let cenv = loadCaptures e captured 0
  let penv = paramEnv pats (inferParamTys (sigTable e) pats body) 0
  let _ = emitFnBody e (((f, ("%clos", LTClosure)) :: cenv) ++ penv) lamName body
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  set_ref (bufRef e) saved

-- E2b — emit a lifted lambda whose params are NON-variable patterns, into the side
-- buffer (same swap discipline as emitLamDefine).  Captures load from `%clos`
-- fields 1.., the patterned params are the synthetic `aK` scrutinee words
-- (`%argK`, via `implParamEnv`), and the SINGLE clause's body is lowered by
-- `emitClauseTree` — the SAME decision-tree path the patterned top-level fns use
-- (E1a) — so a tuple/constructor param binds its vars via `bindPattern` and the
-- body `ret`s.  `extra` is the leading env binding the recursive case prepends
-- (`f -> %clos`); the non-recursive case passes `[]`.  Lambda params/captures
-- default to Int (`implParamEnv`) — the documented slice-4 scope limit, identical
-- to emitLamDefine's `paramEnv … (allInt pats)`.
emitPatLamDefine : Emit -> String -> List (String, (String, LTy)) -> List Pat -> List String -> CExpr -> <Mut> Unit
emitPatLamDefine e lamName extra pats captured body =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let savedFt = fallthroughLabelRef.value
  let _ = set_ref fallthroughLabelRef ""
  let arity = listLen pats
  let _ = emit e ("define i64 @" ++ lamName ++ "(i64 %clos, " ++ implParamDecls arity 0 ++ ") {")
  let _ = emit e "entry:"
  let cenv = loadCaptures e captured 0
  let _ = emitClauseTree e ((extra ++ cenv) ++ implParamEnv arity 0) arity [(pats, body)]
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = set_ref fallthroughLabelRef savedFt
  set_ref (bufRef e) saved

-- drop every occurrence of a name from a list (the recursive-closure self name is
-- removed from its own free-variable set before computing the capture set).
removeStr : String -> List String -> List String
removeStr _ [] = []
removeStr x (y::ys) = if x == y then removeStr x ys else y :: removeStr x ys

-- eta-wrap a NAMED top-level function used as a value into a captureless static
-- closure whose lifted body forwards every argument to `@mdk_<fname>`.  The arity
-- is the function's inferred parameter count (signature table).
emitEtaClosure : Emit -> String -> <Mut> (String, LTy)
emitEtaClosure e fname =
  let arity = fnArity e fname
  let lamName = "mdk_eta_" ++ fname ++ "_" ++ intToString (freshId e)
  let _ = emitEtaDefine e lamName fname arity
  emitClosureAlloc e lamName []

-- the inferred arity of a known top-level function (its signature's param count).
fnArity : Emit -> String -> <Mut> Int
fnArity e fname = match sigMapRef.value
  Some m => match emLookup fname m
    Some (FnSig ptys _) => lengthS ptys
    None => 0
  None => match lookupAssoc fname (sigTable e)
    Some (FnSig ptys _) => lengthS ptys
    None => 0

-- the declared arity of constructor `name` (its field count, from the ctor table).
ctorArity : Emit -> String -> <Mut> Int
ctorArity e name = match ctorMapRef.value
  Some m => match emLookup name m
    Some n => n
    None => 0
  None => match lookupAssoc name (ctorTable e)
    Some n => n
    None => 0

-- a CONSTRUCTOR with arity>0 referenced as a FIRST-CLASS value (`map PVar vars`):
-- emitApp only builds the cell when the ctor is SATURATED (via emitCtorAlloc), so a
-- bare/partial ctor name reaches emitVar.  Eta-wrap it into a captureless static
-- closure whose lifted forwarder allocates the ctor cell from its `%argK` words —
-- mirrors emitEtaClosure (known-fn eta) but the body is emitCtorAlloc, not a call.
-- (Arity-0 ctors stay the immediate `emitCtorAlloc e name []` in emitVar — already a
-- complete value, not a function.)
emitCtorEtaClosure : Emit -> String -> <Mut> (String, LTy)
emitCtorEtaClosure e name =
  let arity = ctorArity e name
  let lamName = "mdk_etac_" ++ name ++ "_" ++ intToString (freshId e)
  let _ = emitCtorEtaDefine e lamName name arity
  emitClosureAlloc e lamName []

-- emit the captureless ctor-eta forwarder `@mdk_etacN(i64 %clos, %arg…) { <alloc
-- cell from %arg0..%argN-1>; ret }` into the side buffer (same swap discipline as
-- emitEtaDefine).
emitCtorEtaDefine : Emit -> String -> String -> Int -> <Mut> Unit
emitCtorEtaDefine e lamName name arity =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let _ = emit e ("define i64 @" ++ lamName ++ "(" ++ etaParamDecls arity ++ ") {")
  let _ = emit e "entry:"
  let (w, _) = emitCtorAlloc e name (argNames arity 0)
  let _ = emit e ("  ret i64 " ++ w)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  set_ref (bufRef e) saved

-- emit a lifted lambda's top-level `define` into the SIDE buffer (LLVM forbids a
-- nested define).  Swap the main buffer out, emit the define with `emit` (so it
-- lands in a private buffer), then move those lines (forward order) into the lams
-- buffer and restore the main buffer.  Captures bind by loading `%clos` fields
-- 1.., params bind to `%argK`; the body is emitted in TAIL position (it `ret`s).
-- (Gap E3: param types are per-param inferred from the body via `inferParamTys`/
-- `paramUseTy` — a Float-param lambda gets float ops; unresolved params → LTInt.)
emitLamDefine : Emit -> String -> List Pat -> List String -> CExpr -> <Mut> Unit
emitLamDefine e lamName pats captured body =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let _ = emit e ("define i64 @" ++ lamName ++ "(" ++ closureParamDecls pats ++ ") {")
  let _ = emit e "entry:"
  let cenv = loadCaptures e captured 0
  let penv = paramEnv pats (inferParamTys (sigTable e) pats body) 0
  let _ = emitFnBody e (cenv ++ penv) lamName body
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  set_ref (bufRef e) saved

-- emit the captureless eta-forwarder `@mdk_etaN(i64 %clos, %arg…) { ret = call
-- @mdk_fname(%arg…); ret }` into the side buffer (same swap discipline).
emitEtaDefine : Emit -> String -> String -> Int -> <Mut> Unit
emitEtaDefine e lamName fname arity =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let _ = emit e ("define i64 @" ++ lamName ++ "(" ++ etaParamDecls arity ++ ") {")
  let _ = emit e "entry:"
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = call i64 @mdk_" ++ fname ++ "(" ++ argDecls (argNames arity 0) ++ ")")
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  set_ref (bufRef e) saved

-- E17: a unicode extern (slice 14) referenced as a FIRST-CLASS value (passed
-- unapplied, e.g. `charPred charIsAlpha`).  emitApp handles these only when
-- saturated (via emitUnicodeExtern); as a bare name they reach emitVar, so
-- eta-wrap into a captureless static closure whose lifted body reproduces
-- emitUnicodeExtern's call+tag.  All nine are arity 1.
emitUnicodeEtaClosure : Emit -> String -> <Mut> (String, LTy)
emitUnicodeEtaClosure e name =
  let lamName = "mdk_eta_" ++ name ++ "_" ++ intToString (freshId e)
  let _ = emitUnicodeEtaDefine e lamName name
  emitClosureAlloc e lamName []

-- the runtime symbol + whether the C result is an untagged 0/1 needing `tagInt`
-- (predicates) — mirrors emitUnicodeExtern exactly.
unicodeExternSym : String -> (String, Bool)
unicodeExternSym "charIsAlpha" = ("@mdk_char_is_alpha", True)
unicodeExternSym "charIsSpace" = ("@mdk_char_is_space", True)
unicodeExternSym "charIsUpper" = ("@mdk_char_is_upper", True)
unicodeExternSym "charIsLower" = ("@mdk_char_is_lower", True)
unicodeExternSym "charIsPunct" = ("@mdk_char_is_punct", True)
unicodeExternSym "charToUpper" = ("@mdk_char_to_upper", False)
unicodeExternSym "charToLower" = ("@mdk_char_to_lower", False)
unicodeExternSym "stringToUpper" = ("@mdk_string_to_upper", False)
unicodeExternSym _ = ("@mdk_string_to_lower", False)

-- emit the arity-1 eta-forwarder `@mdk_etaN(i64 %clos, i64 %arg0) { r = call
-- @mdk_<sym>(%arg0); [tag]; ret }` into the side buffer (same swap discipline
-- as emitEtaDefine).
emitUnicodeEtaDefine : Emit -> String -> String -> <Mut> Unit
emitUnicodeEtaDefine e lamName name =
  let (sym, needsTag) = unicodeExternSym name
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let _ = emit e ("define i64 @" ++ lamName ++ "(i64 %clos, i64 %arg0) {")
  let _ = emit e "entry:"
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = call i64 " ++ sym ++ "(i64 %arg0)")
  let res = if needsTag then tagInt e r else r
  let _ = emit e ("  ret i64 " ++ res)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  set_ref (bufRef e) saved

-- gap-2 (GENERAL): a known extern of ANY family (str/num/io/char/file/hash/…)
-- referenced as a FIRST-CLASS value (point-free alias `f = stringLength`, or
-- passed to a HOF like a fold that applies the extern).  emitApp lowers an extern
-- only when SATURATED (via emitExternApplied); a bare name reaches emitVar.  Eta-
-- wrap it into a captureless static closure whose lifted body REPLAYS
-- emitExternApplied's applied-form codegen on the incoming `%argK` operands, so
-- the value form is byte-consistent with the applied form for every family —
-- including INTRINSICS with no C symbol (e.g. `stringLength`, which inlines a load
-- of the cached codepoint count) since we reuse the exact applied emitter.  Arity
-- comes from the runtime sig (externArity → declSigOf, the runtime extern decls'
-- arrow count), so no per-family arity is hardcoded.
emitExternEtaClosure : Emit -> String -> <Mut> (String, LTy)
emitExternEtaClosure e name =
  let lamName = "mdk_eta_" ++ name ++ "_" ++ intToString (freshId e)
  let _ = emitExternEtaDefine e lamName name (externArity e name)
  emitClosureAlloc e lamName []

-- Gap #50 (value position) — an interface METHOD name reaching emitVar as a bare
-- first-class value (passed to a HOF, e.g. `apply2 max 3 8`).  At a value site the
-- receiver type is monomorphic but NO route accompanies the bare CVar (routes live
-- on CMethod, not CVar), so dispatch must fall to the runtime arg-tag path.  Eta-
-- wrap into a captureless closure whose lifted body REPLAYS emitMethodArgDispatch's
-- applied-form codegen on the incoming `%argK` operands — byte-consistent with the
-- saturated `isImplMethod` call site (emitApp).  Arity = methodArityOf.  (A method
-- reached point-free under a `=>` CONSTRAINT instead becomes a fn-bind with a dict
-- param and is eta-saturated at the define by etaSaturateMethodBody.)
emitMethodEtaClosure : Emit -> String -> <Mut> (String, LTy)
emitMethodEtaClosure e name =
  let lamName = "mdk_eta_" ++ name ++ "_" ++ intToString (freshId e)
  let _ = emitMethodEtaDefine e lamName name (methodArityOf name)
  emitClosureAlloc e lamName []

-- the captureless method-eta forwarder `@mdk_etaN(i64 %clos, %arg…) { <inline
-- arg-tag dispatch over %arg0..%arg(N-1)>; ret }` (mirror of emitExternEtaDefine).
emitMethodEtaDefine : Emit -> String -> String -> Int -> <Mut> Unit
emitMethodEtaDefine e lamName name arity =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let _ = emit e ("define i64 @" ++ lamName ++ "(" ++ etaParamDecls arity ++ ") {")
  let _ = emit e "entry:"
  let synArgs = etaArgOps arity 0
  let (r, _) = emitMethodArgDispatch e name synArgs
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  set_ref (bufRef e) saved

-- the declared arity of extern `name` = the arrow count of its runtime signature
-- (`declSigOf` is seeded from the runtime extern decls via declSigTypeNames).  An
-- extern with no recorded signature defaults to arity 1 (every current extern is
-- annotated, so this is a defensive fallback, not a live path).
externArity : Emit -> String -> <Mut> Int
externArity _ name = match declSigOf name
  Some (ptys, _) => lengthS ptys
  None => 1

-- emit the captureless extern-eta forwarder `@mdk_etaN(i64 %clos, %arg…) {
-- <inline applied-extern body over %arg0..%arg(N-1)>; ret }` into the side buffer
-- (same swap discipline as emitEtaDefine).  The body is produced by calling
-- emitExternApplied with synthetic `__eta_argK__` CVars bound to the `%argK`
-- regs — reuses the EXACT applied-form codegen, guaranteeing value/applied
-- consistency across all families.
emitExternEtaDefine : Emit -> String -> String -> Int -> <Mut> Unit
emitExternEtaDefine e lamName name arity =
  let saved = (bufRef e).value
  let _ = set_ref (bufRef e) []
  let _ = emit e ("define i64 @" ++ lamName ++ "(" ++ etaParamDecls arity ++ ") {")
  let _ = emit e "entry:"
  let argEnv = etaArgEnv arity 0
  let synArgs = etaArgVars arity 0
  let (r, _) = emitExternApplied e argEnv name synArgs
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = set_ref (lamsRef e) (lamLines ++ (lamsRef e).value)
  set_ref (bufRef e) saved

-- env binding `__eta_argK__ -> (%argK, LTInt)` for K in [i, arity) — so the
-- replayed applied-form emitter resolves each synthetic arg to its `%argK` reg.
etaArgEnv : Int -> Int -> List (String, (String, LTy))
etaArgEnv n i =
  if i >= n then []
  else ("__eta_arg" ++ intToString i ++ "__", ("%arg" ++ intToString i, LTInt))
       :: etaArgEnv n (i + 1)

-- the synthetic argument exprs `CVar "__eta_argK__" AGlobal` for K in [i, arity).
etaArgVars : Int -> Int -> List CExpr
etaArgVars n i =
  if i >= n then []
  else CVar ("__eta_arg" ++ intToString i ++ "__") AGlobal :: etaArgVars n (i + 1)

-- the eta-define's `%arg0..%arg(n-1)` parameter OPERAND words (as raw register
-- strings), for an eta body that consumes operands directly (emitMethodArgDispatch)
-- rather than re-emitting CVars through an env.
etaArgOps : Int -> Int -> List String
etaArgOps n i =
  if i >= n then []
  else ("%arg" ++ intToString i) :: etaArgOps n (i + 1)


closureParamDecls : List Pat -> String
closureParamDecls [] = "i64 %clos"
closureParamDecls pats = "i64 %clos, " ++ paramDecls pats 0

-- the eta-forwarder's parameter list: `%clos` then `arity` `%argK`s.
etaParamDecls : Int -> String
etaParamDecls n = "i64 %clos" ++ etaArgDecls n 0

etaArgDecls : Int -> Int -> String
etaArgDecls n i = if i >= n then "" else ", i64 %arg" ++ intToString i ++ etaArgDecls n (i + 1)

-- the `%argK` operand names 0..n-1 (the eta-forwarder's call arguments).
argNames : Int -> Int -> List String
argNames n i = if i >= n then [] else ("%arg" ++ intToString i) :: argNames n (i + 1)

-- bind each captured variable by loading `%clos` field i+1 (field 0 is code_ptr).
loadCaptures : Emit -> List String -> Int -> <Mut> List (String, (String, LTy))
loadCaptures _ [] _ = []
loadCaptures e (c::rest) i =
  let r = loadField e "%clos" (i + 1)
  (c, (r, LTInt)) :: loadCaptures e rest (i + 1)

-- the live operand words for a captured-name list (looked up in the emit env).
capWords : List (String, (String, LTy)) -> List String -> List String
capWords _ [] = []
capWords env (c::rest) =
  let (op, _) = lookupVar env c
  op :: capWords env rest

-- keep only the names present as keys in the emit env (the capturable locals);
-- drop free names that resolve to top-level globals (known fns / ctors).
keepInEnv : List (String, (String, LTy)) -> List String -> List String
keepInEnv _ [] = []
keepInEnv env (k::rest) =
  if envHasKey env k then k :: keepInEnv env rest else keepInEnv env rest

envHasKey : List (String, (String, LTy)) -> String -> Bool
envHasKey [] _ = False
envHasKey ((n, _)::rest) k = if n == k then True else envHasKey rest k

dedupS : List String -> List String
dedupS [] = []
dedupS (x::xs) = if containsStr x xs then dedupS xs else x :: dedupS xs

-- the free variables of a Core IR expression given a set of already-bound names.
-- Returns names (with duplicates; the caller dedups).  Covers the slice-1/3/4
-- node subset; any other node contributes nothing (out-of-scope nodes panic at
-- emit time, so they never reach a lifted lambda body here).
freeVars : List String -> CExpr -> List String
freeVars _ (CLit _) = []
freeVars b (CVar x _) = if containsStr x b then [] else [x]
freeVars b (CApp f a) = freeVars b f ++ freeVars b a
freeVars b (CLam ps body) = freeVars (patVarNames ps ++ b) body
freeVars b (CLet recF pat e1 e2) =
  let b2 = patVars pat ++ b
  let fe1 = if recF then freeVars b2 e1 else freeVars b e1
  fe1 ++ freeVars b2 e2
freeVars b (CLetGroup binds body) =
  let b2 = bindNames binds ++ b
  freeVarsBinds b2 binds ++ freeVars b2 body
freeVars b (CBlock stmts) = freeVarsStmts b stmts
freeVars b (CIf c t f) = freeVars b c ++ freeVars b t ++ freeVars b f
freeVars b (CBinPrim _ l r) = freeVars b l ++ freeVars b r
freeVars b (CUnOp _ x) = freeVars b x
freeVars b (CMatch scrut arms) = freeVars b scrut ++ freeVarsArms b arms
freeVars b (CDecision scrut arms _) = freeVars b scrut ++ freeVarsArms b arms
freeVars b (CTuple es) = freeVarsList b es
freeVars b (CList es) = freeVarsList b es
freeVars b (CRangeList lo hi _) = freeVars b lo ++ freeVars b hi
freeVars b (CRecord _ fields) = freeVarsFields b fields
freeVars b (CFieldAccess ex _) = freeVars b ex
freeVars b (CRecordUpdate base updates) = freeVars b base ++ freeVarsFields b updates
freeVars b (CVariantUpdate _ base updates) = freeVars b base ++ freeVarsFields b updates
freeVars b (CArray es) = freeVarsList b es
freeVars b (CRangeArray lo hi _) = freeVars b lo ++ freeVars b hi
freeVars b (CIndex a i) = freeVars b a ++ freeVars b i
freeVars b (CSlice a lo hi _) = freeVars b a ++ freeVars b lo ++ freeVars b hi
freeVars b (CMethod _ route implRoutes methRoutes) = routeDictNames b (route :: (implRoutes ++ methRoutes))
freeVars b (CDict _ routes) = routeDictNames b routes
freeVars _ _ = []

-- collect the captured dict-param names (RDict/RDictFwd) from a list of Routes.
-- RKey and RNone carry no captured variable name; only RDict/RDictFwd name a dict
-- parameter that the enclosing closure must capture from its env.
routeDictNames : List String -> List Route -> List String
routeDictNames _ [] = []
routeDictNames b (RDict d :: rest)    = (if containsStr d b then [] else [d]) ++ routeDictNames b rest
routeDictNames b (RDictFwd d :: rest) = (if containsStr d b then [] else [d]) ++ routeDictNames b rest
routeDictNames b (_ :: rest)          = routeDictNames b rest

freeVarsFields : List String -> List CField -> List String
freeVarsFields _ [] = []
freeVarsFields b ((CField _ ex)::rest) = freeVars b ex ++ freeVarsFields b rest

freeVarsList : List String -> List CExpr -> List String
freeVarsList _ [] = []
freeVarsList b (e::rest) = freeVars b e ++ freeVarsList b rest

freeVarsArms : List String -> List CArm -> List String
freeVarsArms _ [] = []
freeVarsArms b ((CArm pat _ body)::rest) =
  freeVars (patVars pat ++ b) body ++ freeVarsArms b rest

freeVarsStmts : List String -> List CStmt -> List String
freeVarsStmts _ [] = []
freeVarsStmts b ((CSExpr ex)::rest) = freeVars b ex ++ freeVarsStmts b rest
freeVarsStmts b ((CSLet _ pat ex)::rest) =
  freeVars b ex ++ freeVarsStmts (patVars pat ++ b) rest
freeVarsStmts b ((CSAssign _ ex)::rest) =
  freeVars b ex ++ freeVarsStmts b rest
freeVarsStmts b ((CSLetElse pat ex alt)::rest) =
  freeVars b ex ++ freeVars b alt ++ freeVarsStmts (patVars pat ++ b) rest
freeVarsStmts b (_::rest) = freeVarsStmts b rest

freeVarsBinds : List String -> List CBind -> List String
freeVarsBinds _ [] = []
freeVarsBinds b ((CBind _ [CClause [] rhs])::rest) =
  freeVars b rhs ++ freeVarsBinds b rest
freeVarsBinds b (_::rest) = freeVarsBinds b rest

bindNames : List CBind -> List String
bindNames [] = []
bindNames (b::rest) = bindName b :: bindNames rest

-- the variables a pattern binds.
patVars : Pat -> List String
patVars (PVar x) = [x]
patVars (PCon _ args) = patVarsList args
patVars (PCons h t) = patVars h ++ patVars t
patVars (PTuple ps) = patVarsList ps
patVars (PList ps) = patVarsList ps
patVars (PAs x p) = x :: patVars p
patVars _ = []

patVarsList : List Pat -> List String
patVarsList [] = []
patVarsList (p::rest) = patVars p ++ patVarsList rest

patVarNames : List Pat -> List String
patVarNames ps = patVarsList ps

-- ── ADT constructors + pattern matching (slice 3) ───────────────────────────
-- VALUE REPRESENTATION (RUNTIME-DESIGN.md §8.4 "Option A", extended from the
-- slice-1 Float box): an ADT value is a BOXED heap cell with a one-word header.
--   cell layout (8-byte words):  [ 0: i64 tag ] [ 8: field0 ] [ 16: field1 ] …
-- the tag is the constructor's COMPOSITE (typeId, ordinal) — see `cellTag` (computed
-- identically at the alloc site and at every switch test, so the two always agree); the word
-- carried in registers is the cell pointer (`ptrtoint`, low bit 0 — disjoint from
-- the immediate-int low-bit-1 encoding, exactly as the Float box is).  Allocation
-- reuses the slice-1 `@mdk_alloc` (malloc-and-leak; no GC this slice).

-- hashName: a deterministic djb2 string hash, computed in the EMITTER (the .ll
-- carries the decimal constant).  STILL used for the NON-ctor sentinel headers
-- ("$tuple"/"$ref"/"$closure") and the dict witness words (RKey impl-head keys) —
-- those are not constructor tags and never share an icmp with a ctor cell tag, so
-- a hash is fine there.  Constructor cell tags use `cellTag` (ordinals) instead.
hashName : String -> Int
hashName s = hashChars (stringToChars s) 0 5381

hashChars : Array Char -> Int -> Int -> Int
hashChars cs i acc
  | i >= arrayLength cs = acc
  | otherwise = hashChars cs (i + 1) (acc * 33 + charCode (arrayGetUnsafe i cs))

-- ── constructor tag = dense per-type ordinal (RUNTIME-DESIGN §8.4, ratified ──────
--    2026-06-07; supersedes the spike's i64 string-hash for CONSTRUCTOR tags).
-- A constructor C of type T is tagged with its 0-based index in T's
-- declaration-ordered constructor list (the ratified value — `br_table`-ready and
-- collision-free).  But the spike's ARG-TAG dispatch (emitTagMatch) discriminates a
-- value's TYPE by loading its cell tag and OR-ing it against a candidate type's
-- ctor tags — and per-type ordinals COLLIDE across types (every type has an
-- ordinal-0 ctor), so a bare ordinal cannot identify the type.  The one-word header
-- therefore carries a COMPOSITE: a dense per-type id in the high 32 bits and the
-- ratified per-type ctor ordinal in the low 32 bits.
--   • match-head test (within ONE statically-known type) and `br_table` use the low
--     half — `tag & 0xffffffff` is the dense 0-based ordinal.
--   • the spike's arg-tag dispatch uses the FULL composite, which is globally unique
--     (distinct type ⇒ distinct high half), so cross-type discrimination is exact.
-- The high half is spike scaffolding for that runtime dispatch; the real backend
-- resolves such call sites statically / by dictionary and keeps only the low-half
-- ordinal.  hashName is gone from every constructor tag — collisions are impossible.
-- 2^32, the type-id shift.  (Int is 63-bit; type-id × 2^32 + ordinal stays well
-- under 2^62 for any real program.)
ctorTagShift : Int
ctorTagShift = 4294967296

-- the cell-header tag a NAME stamps / is tested against.  Sentinel headers
-- ("$tuple"/"$ref"/"$closure") keep their hash; every constructor (incl. the
-- built-in list Cons/Nil and a user ctor that owns those names) gets the composite
-- (typeId, ordinal).  Alloc and every tag test route through THIS one function, so
-- the stored tag and the compared tag are identical by construction.
-- RESERVED ADT-TAG BLOCK (slice 10 precursor).  The runtime ADTs — List, Option,
-- Result, Ordering — get FIXED composite tags, far above any real program's dense
-- type-id range, so a C extern can construct these cells (mdk_some/mdk_cons/… in
-- runtime/medaka_rt.c) with a tag a later `match` agrees with.  The driver
-- (llvm_emit_main.mdk) does NOT load the prelude, so a prelude-free fixture using
-- `Some`/`None`/`Ok`/… has them ABSENT from the ctor→type table — without this
-- reservation `Some` and `Cons` both fall to the "one past" type-id with ordinal 0
-- and COLLIDE.  Both alloc and every tag test route through `cellTag`, so reserving
-- here keeps construction and the match-head test consistent by construction.
-- The C side hardcodes the SAME constants (MDK_TAG_* in runtime/medaka_rt.c); keep
-- the two in sync.  Ordinals follow core.mdk: Option = Some|None, Result = Ok|Err,
-- Ordering = Lt|Eq|Gt; List (synthetic) = Cons|Nil.  KNOWN SPIKE LIMITATION: a user
-- type that reuses one of these constructor names aliases the reserved tag (still
-- internally consistent, since alloc+match both reserve); the real backend resolves
-- such sites statically and never relies on a global tag.
reservedTypeBase : Int
reservedTypeBase = 65536

reservedTag : String -> Option Int
reservedTag name =
  if      name == "Cons" then Some ((reservedTypeBase + 0) * ctorTagShift + 0)
  else if name == "Nil"  then Some ((reservedTypeBase + 0) * ctorTagShift + 1)
  else if name == "Some" then Some ((reservedTypeBase + 1) * ctorTagShift + 0)
  else if name == "None" then Some ((reservedTypeBase + 1) * ctorTagShift + 1)
  else if name == "Ok"   then Some ((reservedTypeBase + 2) * ctorTagShift + 0)
  else if name == "Err"  then Some ((reservedTypeBase + 2) * ctorTagShift + 1)
  else if name == "Lt"   then Some ((reservedTypeBase + 3) * ctorTagShift + 0)
  else if name == "Eq"   then Some ((reservedTypeBase + 3) * ctorTagShift + 1)
  else if name == "Gt"   then Some ((reservedTypeBase + 3) * ctorTagShift + 2)
  else None

-- the cell-header tag a NAME stamps / is tested against.  Sentinel headers
-- ("$tuple"/"$ref"/"$closure") keep their hash; the runtime ADTs route through
-- `reservedTag` (fixed, program-stable); every other constructor gets the composite
-- (typeId, ordinal).  Alloc and every tag test route through THIS one function, so
-- the stored tag and the compared tag are identical by construction.
-- Bool immediates are hardcoded by emitVar/emitLit: True→word 3 (ashr1→tag 1),
-- False→word 1 (ashr1→tag 0).  Special-case before the ctor-table lookup so
-- construction and discrimination agree regardless of whether Bool is in the table.
cellTag : Emit -> String -> <Mut> Int
cellTag e name =
  if name == "True"  then 1
  else if name == "False" then 0
  else if containsStr name ["$tuple", "$ref", "$closure"] then hashName name
  else match reservedTag name
    Some t => t
    None => ctorTypeId e name * ctorTagShift + ctorOrdinal e name

-- the 0-based index of constructor `name` in its type's declaration-ordered ctor
-- list.  The built-in list Cons/Nil are not user-declared (absent from the
-- ctor→type table) → reserved ordinals 0/1 of the synthetic list type.
ctorOrdinal : Emit -> String -> <Mut> Int
ctorOrdinal e name = match lookupAssoc name (ctorTypeTable e)
  Some ty => orZero (indexOfStr name (ctorsOfType e ty))
  None => if name == "Nil" then 1 else 0

-- the dense per-type id of the type that owns constructor `name`: its index among
-- the program's distinct type names (declaration order).  The built-in list (and
-- any name not in the ctor→type table) gets a reserved id one past the user types,
-- so its composite tags can never collide with a user type's.
ctorTypeId : Emit -> String -> <Mut> Int
ctorTypeId e name = match lookupAssoc name (ctorTypeTable e)
  Some ty => orZero (indexOfStr ty (distinctTypeNames e))
  None => lengthS (distinctTypeNames e)

-- the distinct type names of the program, in declaration order (the ctor→type
-- table lists each type's ctors consecutively, so dedup-preserving-order gives the
-- type declaration order).
-- `distinctTypeNames` is constant during a program's emission (the ctor→type
-- table is set once), but `ctorTypeId` calls it per ADT-constructor emission and
-- it recomputes the O(n²) `nubStr` each time. Memoize the result (a plain
-- List String — no hash container, so it self-compiles cleanly) in a module-level
-- ref, reset to None at each emitProgram/emitProgramGaps so batched emits recompute.
distinctTypeNamesRef : Ref (Option (List String))
distinctTypeNamesRef = Ref None

resetDistinctTypeNames : Unit -> <Mut> Unit
resetDistinctTypeNames _ = set_ref distinctTypeNamesRef None

distinctTypeNames : Emit -> <Mut> List String
distinctTypeNames e = match distinctTypeNamesRef.value
  Some xs => xs
  None =>
    let xs = nubStr (typeNamesOf (ctorTypeTable e))
    let _ = set_ref distinctTypeNamesRef (Some xs)
    xs

typeNamesOf : List (String, String) -> List String
typeNamesOf [] = []
typeNamesOf ((_, t)::rest) = t :: typeNamesOf rest

orZero : Option Int -> Int
orZero (Some i) = i
orZero None = 0

-- dedup a list of strings, preserving first-occurrence order.
nubStr : List String -> List String
nubStr xs = nubStrAcc xs []

nubStrAcc : List String -> List String -> List String
nubStrAcc [] _ = []
nubStrAcc (x::xs) seen =
  if containsStr x seen then nubStrAcc xs seen
  else x :: nubStrAcc xs (x :: seen)

-- allocate a constructor cell {tag, field…}; the field words are already emitted.
-- Result is the cell pointer as an i64 word, typed LTCon.  A NULLARY constructor
-- (RUNTIME-DESIGN §8.1 / §8.4 decision 1: nullary ctors are immediate/free) does
-- NOT allocate — it is the IMMEDIATE word `(cellTag<<1)|1`, carrying the SAME
-- composite (typeId, ordinal) tag a boxed cell would store in its header, untaggable
-- by `ashr 1`.  This generalises the existing Bool immediate (emitVar True→"3"/
-- False→"1") to every nullary ctor.  The constant operand emits no instructions; a
-- `match` recovers the tag via `loadDiscriminant` (low-bit branch), so construction
-- and the match-head test agree on `cellTag` whether the value is immediate or boxed.
emitCtorAlloc : Emit -> String -> List String -> <Mut> (String, LTy)
emitCtorAlloc e name [] = (intToString (cellTag e name * 2 + 1), LTCon)
emitCtorAlloc e name fields =
  let arity = lengthS fields
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = call ptr @mdk_alloc(i64 " ++ intToString (8 * (arity + 1)) ++ ")")
  let _ = emit e ("  store i64 " ++ intToString (cellTag e name) ++ ", ptr " ++ p)
  let _ = storeFields e p fields 0
  let w = freshReg e
  let _ = emit e ("  " ++ w ++ " = ptrtoint ptr " ++ p ++ " to i64")
  (w, LTCon)

-- store each field at offset 8*(i+1) (field 0 follows the one-word header).
storeFields : Emit -> String -> List String -> Int -> <Mut> Unit
storeFields _ _ [] _ = ()
storeFields e p (f::rest) i =
  let fp = freshReg e
  let _ = emit e ("  " ++ fp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 " ++ intToString (8 * (i + 1)))
  let _ = emit e ("  store i64 " ++ f ++ ", ptr " ++ fp)
  storeFields e p rest (i + 1)

-- load a cell's tag (header word at offset 0) given the cell's pointer word.
loadTag : Emit -> String -> <Mut> String
loadTag e ptrWord =
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = inttoptr i64 " ++ ptrWord ++ " to ptr")
  let t = freshReg e
  let _ = emit e ("  " ++ t ++ " = load i64, ptr " ++ p)
  t

-- the DISCRIMINANT word a constructor `match` head (and arg-tag dispatch) tests.
-- A value of an ADT type is EITHER an immediate nullary ctor (low bit 1 — its
-- composite (typeId, ordinal) tag rides the payload, recovered by `ashr 1`) OR a
-- boxed pointer to a cell whose header word IS that same composite tag (low bit 0 —
-- `loadTag` it).  A type that mixes the two (e.g. Option = None immediate + Some
-- boxed) means a single scrutinee can be either, so branch on the low bit BEFORE
-- choosing — an immediate must NEVER be dereferenced (`loadTag` on an odd word
-- inttoptr's to a misaligned address and segfaults).  Both arms phi to ONE tag word
-- equal to the `cellTag` the alloc site stamps, so emitConChain/emitTagMatch compare
-- against `cellTag` UNCHANGED: immediate and boxed reps are tag-comparable by
-- construction (RUNTIME-DESIGN §8.1).  loadTag stays the raw boxed-cell load — used
-- directly only where the value is known boxed (array length header).
loadDiscriminant : Emit -> String -> <Mut> String
loadDiscriminant e word =
  let n = intToString (freshId e)
  let imm = "discimm" ++ n
  let box = "discbox" ++ n
  let cont = "disccont" ++ n
  let lb = freshReg e
  let _ = emit e ("  " ++ lb ++ " = and i64 " ++ word ++ ", 1")
  let isImm = freshReg e
  let _ = emit e ("  " ++ isImm ++ " = icmp eq i64 " ++ lb ++ ", 1")
  let _ = emit e ("  br i1 " ++ isImm ++ ", label %" ++ imm ++ ", label %" ++ box)
  let _ = emit e (imm ++ ":")
  let iv = freshReg e
  let _ = emit e ("  " ++ iv ++ " = ashr i64 " ++ word ++ ", 1")
  let _ = emit e ("  br label %" ++ cont)
  let _ = emit e (box ++ ":")
  let bv = loadTag e word
  let _ = emit e ("  br label %" ++ cont)
  let _ = emit e (cont ++ ":")
  let d = freshReg e
  let _ = emit e ("  " ++ d ++ " = phi i64 [ " ++ iv ++ ", %" ++ imm ++ " ], [ " ++ bv ++ ", %" ++ box ++ " ]")
  d

-- load field `idx` (offset 8*(idx+1)) of a cell given its pointer word.
loadField : Emit -> String -> Int -> <Mut> String
loadField e ptrWord idx =
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = inttoptr i64 " ++ ptrWord ++ " to ptr")
  let fp = freshReg e
  let _ = emit e ("  " ++ fp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 " ++ intToString (8 * (idx + 1)))
  let f = freshReg e
  let _ = emit e ("  " ++ f ++ " = load i64, ptr " ++ fp)
  f

-- load the first `a` fields of a cell as a list of operand words.
loadFields : Emit -> String -> Int -> Int -> <Mut> List String
loadFields e foc a i
  | i >= a = []
  | otherwise =
    let f = loadField e foc i
    f :: loadFields e foc a (i + 1)

-- a `match` lowered to a decision tree (CDecision).  Mirrors core_ir_eval's
-- cevalDecision exactly, but emits an LLVM CFG instead of walking values: the
-- scrutinee word, an `alloca` result slot, the tree (which routes control via
-- br/icmp to the selected arm, where the arm stores its body value into the slot
-- and branches to the end label), then a load of the slot in the end block.  The
-- arm's static result type is captured into `rty` as the arm body is emitted (all
-- arms agree — well-typed match).
emitDecision : Emit -> List (String, (String, LTy)) -> CExpr -> List CArm -> CTree -> <Mut> (String, LTy)
emitDecision e env scrut arms tree =
  let (sv, _) = emitExpr e env scrut
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "decend" ++ intToString (freshId e)
  let rty = Ref LTInt
  -- A `match` in expression position is self-contained: its own non-exhaustive
  -- CTFail is a genuine abort, NOT the enclosing clause-chain's fallthrough.  Save
  -- + null the fallthrough label across the tree so a body-level match emitted
  -- inside a chained clause leaf doesn't inherit (and wrongly branch to) the
  -- next-clause block.  Restored after.
  let saved = fallthroughLabelRef.value
  let _ = set_ref fallthroughLabelRef ""
  -- Likewise self-contained for TRMC: an expression-position `match`'s arms
  -- compute VALUES into `slot`, never cons-into-dest — so clear the TRMC ctx
  -- across the tree (a tail cons in a match arm is Phase 2, deliberately not here).
  let savedTrmc = trmcCtxRef.value
  let _ = set_ref trmcCtxRef TrmcOff
  let _ = emitTree e env sv arms [sv] slot endL rty tree
  let _ = set_ref fallthroughLabelRef saved
  let _ = set_ref trmcCtxRef savedTrmc
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ slot)
  (r, rty.value)

-- walk the compiled CTree, emitting basic blocks.  `root` is the whole scrutinee
-- word (kept for the leaf re-match that recovers bindings — mirrors ceval's
-- `root`); `occs` is the live column words (the matrix columns), starting as just
-- [root] and expanding into a constructor's fields as the tree descends.  Every
-- path terminates its current block (a `br` to `endL` after storing, a `br` into
-- a sibling test block, or `unreachable` for CTFail).
emitTree : Emit -> List (String, (String, LTy)) -> String -> List CArm -> List String -> String -> String -> Ref LTy -> CTree -> <Mut> Unit
-- CTFail: the matrix path matched no row.  In a CHAINED single-clause tree
-- (emitClauseChain) this is "this clause's pattern didn't match" → resume the next
-- clause via the fallthrough label; with no next clause (`""`) it is the historical
-- non-exhaustive `unreachable`/oob.  emitFallthrough emits the branch; a redundant
-- `unreachable` keeps the block well-formed when it abort()s.
emitTree e _ _ _ _ _ _ _ CTFail = match fallthroughLabelRef.value
  "" => emit e "  unreachable"
  lbl => emit e ("  br label %" ++ lbl)
emitTree e env root arms _ slot endL rty (CTLeaf i) = emitLeaf e env root arms i slot endL rty
-- CTGuard i fail: arm i matched but is GUARDED.  Re-bind its pattern (like a
-- leaf), evaluate its guards; all pass → eval the body (emitLeaf-style); any
-- guard fails → branch to the `fail` subtree, which resumes the ordered match at
-- the same column context `occs` (mirrors core_ir_eval's `cevalGuardedBody`).
-- This CLOSES the historical CTGuard emitter gap — `selfhost/` code on the native
-- self-compile path no longer needs the guard-free convention for `CGBool`
-- guards.  A refutable `p <- e` pattern guard stays a contained gap (not produced
-- by current source); a bad arm index likewise.
emitTree e env root arms occs slot endL rty (CTGuard i fail) = match nthArm arms i
  Some (CArm pat guards body) =>
    if allGuardsEmittable guards then
      emitGuardedArm e env root arms occs pat guards body fail slot endL rty
    else
      let _ = gapU "refutable pattern guard (`p <- e`) in a match arm (CTGuard) — not yet lowered"
      let _ = emit e ("  store i64 0, ptr " ++ slot)
      emit e ("  br label %" ++ endL)
  None =>
    let _ = gapU "guarded arm index out of range (CTGuard)"
    let _ = emit e ("  store i64 0, ptr " ++ slot)
    emit e ("  br label %" ++ endL)
emitTree e env root arms occs slot endL rty (CTDrop sub) =
  emitTree e env root arms (tailS occs) slot endL rty sub
emitTree e env root arms occs slot endL rty (CTSwitch branches dft) =
  emitSwitch e env root arms occs branches dft slot endL rty

-- a terminal leaf: re-match the selected arm's ORIGINAL pattern against the whole
-- scrutinee `root` (the tree path guarantees it matches) to bind its variables —
-- emitting getelementptr loads for each field a `PVar` deconstructs — then emit
-- the body, store the result, and branch to the end block.
emitLeaf : Emit -> List (String, (String, LTy)) -> String -> List CArm -> Int -> String -> String -> Ref LTy -> <Mut> Unit
emitLeaf e env root arms i slot endL rty = match nthArm arms i
  Some (CArm pat _ body) =>
    let env2 = bindPattern e env pat root body
    -- TRMC (TRMC-DESIGN.md): when a destination-passing loop is active (multi-clause
    -- eligible fn — emitClauseTree's clause-selection tree), the clause body is a
    -- TAIL leaf → descend it via emitTrmcBody (cons-into-dest+loop / store+exit)
    -- instead of computing a value into `slot`.  trmcCtxRef is cleared inside any
    -- expression-position `match` (emitDecision), so a nested match's arms still
    -- compute values normally.
    match trmcCtxRef.value
      TrmcOn _ _ _ _ _ _ => emitTrmcBody e env2 body
      TrmcOff =>
        let (bv, bty) = emitExpr e env2 body
        let _ = set_ref rty bty
        let _ = emit e ("  store i64 " ++ bv ++ ", ptr " ++ slot)
        emit e ("  br label %" ++ endL)
  None => gapU "decision arm index out of range"

-- a guarded clause: bind the arm pattern, run the guards (branching to `failL` on
-- any failure), and on all-pass eval the body into `slot`; then emit `failL` and
-- the `fail` subtree (resumes the match at the same column context `occs`).
emitGuardedArm : Emit -> List (String, (String, LTy)) -> String -> List CArm -> List String -> Pat -> List CGuard -> CExpr -> CTree -> String -> String -> Ref LTy -> <Mut> Unit
emitGuardedArm e env root arms occs pat guards body fail slot endL rty =
  let failL = "guardfail" ++ intToString (freshId e)
  let env2 = bindPattern e env pat root body
  let env3 = emitGuardChain e env2 guards body failL
  let (bv, bty) = emitExpr e env3 body
  let _ = set_ref rty bty
  let _ = emit e ("  store i64 " ++ bv ++ ", ptr " ++ slot)
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (failL ++ ":")
  emitTree e env root arms occs slot endL rty fail

-- emit the guard tests left-to-right: a `CGBool` tests a Bool (`True` = the word
-- 3) and branches to `failL` on failure, falling through on success; an
-- (irrefutable) `CGBind p <- e` binds `p` and continues.  Returns the env
-- extended by any `CGBind` bindings (visible to later guards + the body).
emitGuardChain : Emit -> List (String, (String, LTy)) -> List CGuard -> CExpr -> String -> <Mut> List (String, (String, LTy))
emitGuardChain _ env [] _ _ = env
emitGuardChain e env ((CGBool g)::rest) body failL =
  let (bw, _) = emitExpr e env g
  let cmp = freshReg e
  let _ = emit e ("  " ++ cmp ++ " = icmp eq i64 " ++ bw ++ ", 3")
  let pass = "guardok" ++ intToString (freshId e)
  let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ pass ++ ", label %" ++ failL)
  let _ = emit e (pass ++ ":")
  emitGuardChain e env rest body failL
emitGuardChain e env ((CGBind p ex)::rest) body failL =
  let (v, _) = emitExpr e env ex
  let env2 = bindPattern e env p v body
  emitGuardChain e env2 rest body failL

-- a clause's guards are emittable iff every `CGBind`'s pattern is irrefutable (a
-- refutable `p <- e` needs a runtime match test — not yet lowered).  `CGBool`
-- guards are always emittable.
allGuardsEmittable : List CGuard -> Bool
allGuardsEmittable [] = True
allGuardsEmittable ((CGBool _)::rest) = allGuardsEmittable rest
allGuardsEmittable ((CGBind p _)::rest) = irrefutablePat p && allGuardsEmittable rest

irrefutablePat : Pat -> Bool
irrefutablePat (PVar _) = True
irrefutablePat PWild = True
irrefutablePat _ = False

-- bind a pattern's variables against a value word, emitting field loads for the
-- constructor sub-patterns.  Mirrors the binding half of eval.mdk's matchPat, but
-- since the decision tree already proved the shape, it only EXTRACTS (no tests).
-- A `PVar`'s static type is recovered from its first typed use in the arm body
-- (reusing the slice-2b `paramUseTy`); pointer-typed fields default to Int, which
-- is harmless — they only ever flow on as LTy-agnostic call args.
bindPattern : Emit -> List (String, (String, LTy)) -> Pat -> String -> CExpr -> <Mut> List (String, (String, LTy))
bindPattern _ env PWild _ _ = env
bindPattern _ env (PLit _) _ _ = env
bindPattern e env (PVar x) v body = bindVarTy e env x v body ""
-- A constructor pattern binds each field with the field's DECLARED type (Gap E2):
-- a scalar declared field type (esp. Float/Bool) types the bound var directly,
-- so `match (Rect w h) { … w * h }` does FLOAT arith on the unboxed fields rather
-- than guessing LTInt from body-use.  Non-scalar / unknown fields fall back to the
-- paramUseTy guess (declared name "" passed through bindFieldsDecl).
bindPattern e env (PCon c args) v body =
  bindFieldsDecl e env args (ctorFieldTypeNamesOf c) v body 0
bindPattern e env (PTuple ps) v body = bindFields e env ps v body 0
-- built-in list patterns (slice 5b): a cons cell is a 2-field "Cons" constructor
-- (head = field 0, tail = field 1); the empty-list pattern (a "Nil" cell) binds
-- nothing.  The decision tree already proved the shape (HCons/HNil switch), so
-- this only EXTRACTS — same as the PCon binding path, with [head, tail] fields.
bindPattern e env (PCons h t) v body = bindFields e env [h, t] v body 0
bindPattern _ env (PList []) _ _ = env
-- as-pattern `x@p`: bind `x` to the WHOLE value v (same LTy lookup as PVar),
-- then descend into `p` so its inner vars also bind.
bindPattern e env (PAs x p) v body =
  let env2 = bindVarTy e env x v body ""
  bindPattern e env2 p v body
-- non-empty list-literal pattern `[p::ps]`: v is a Cons cell (the switch proved
-- it); bind the head element (field 0) to `p` and the tail (field 1) to `PList ps`.
bindPattern e env (PList (p::ps)) v body = bindFields e env [p, PList ps] v body 0
bindPattern _ env p _ _ =
  gapEnv ("unsupported pattern in match arm (slice 3/5b: variable / wildcard / constructor / tuple / cons / nil / int-literal only): " ++ ptag p) env

-- bind variable `x` to word `v`.  Its LTy is the DECLARED field type-head name
-- `declName` when that is a known scalar (Gap E2), else the paramUseTy guess from
-- the arm body, else LTInt — so the declared-type override is additive.
bindVarTy : Emit -> List (String, (String, LTy)) -> String -> String -> CExpr -> String -> <Mut> List (String, (String, LTy))
bindVarTy e env x v body declName =
  let ty = match fieldNameToLTy declName
    Some t => t
    None => match paramUseTy (sigTable e) [] x body
      Some t => t
      None => LTInt
  (x, (v, ty)) :: env

bindFields : Emit -> List (String, (String, LTy)) -> List Pat -> String -> CExpr -> Int -> <Mut> List (String, (String, LTy))
bindFields _ env [] _ _ _ = env
bindFields e env (p::rest) v body i =
  let f = loadField e v i
  let env2 = bindPattern e env p f body
  bindFields e env2 rest v body (i + 1)

-- like bindFields, but pairs each field pattern with its constructor's DECLARED
-- field type-head name (Gap E2).  A bare PVar/PAs field uses the declared scalar
-- type when known; everything else (nested patterns, unknown/non-scalar fields,
-- missing declared names) falls through to the paramUseTy guess.
bindFieldsDecl : Emit -> List (String, (String, LTy)) -> List Pat -> List String -> String -> CExpr -> Int -> <Mut> List (String, (String, LTy))
bindFieldsDecl _ env [] _ _ _ _ = env
bindFieldsDecl e env (p::rest) declNames v body i =
  let f = loadField e v i
  let declName = nthOr declNames i ""
  let env2 = bindFieldDecl e env p declName f body
  bindFieldsDecl e env2 rest declNames v body (i + 1)

-- bind one constructor field: a bare PVar/PAs uses its declared scalar type, any
-- other pattern recurses through bindPattern (no scalar to apply at the top).
bindFieldDecl : Emit -> List (String, (String, LTy)) -> Pat -> String -> String -> CExpr -> <Mut> List (String, (String, LTy))
bindFieldDecl e env (PVar x) declName f body = bindVarTy e env x f body declName
bindFieldDecl e env (PAs x p) declName f body =
  let env2 = bindVarTy e env x f body declName
  bindPattern e env2 p f body
bindFieldDecl e env p _ f body = bindPattern e env p f body

-- the i-th element of a list, or `dflt` if out of range.
nthOr : List String -> Int -> String -> String
nthOr [] _ dflt = dflt
nthOr (x::rest) i dflt
  | i == 0 = x
  | otherwise = nthOr rest (i - 1) dflt

-- a switch on the focus column (occs head): constructor-LIKE heads (named ADT
-- constructors HCon, built-in list HCons/HNil, and tuples HTuple) test a
-- DISCRIMINANT word (`loadDiscriminant`: an immediate nullary ctor's `ashr 1`
-- payload, or a boxed cell's loaded header — both the composite `cellTag`); int
-- literals test the immediate directly.  A homogeneous switch (the
-- matrix is either all-constructor-like or all-literal in a column), so the first
-- branch's head selects the test kind.  HCons/HNil/HTuple map to the same tag the
-- alloc site stamps (`cellTag` of "Cons"/"Nil"/"$tuple"), so a constructor
-- test reaches them with no special case beyond the name/arity (see conHeadInfo).
emitSwitch : Emit -> List (String, (String, LTy)) -> String -> List CArm -> List String -> List CTBranch -> CTree -> String -> String -> Ref LTy -> <Mut> Unit
emitSwitch e env root arms occs branches dft slot endL rty = match occs
  [] => emitTree e env root arms [] slot endL rty dft
  (foc::rest) => match branches
    [] => emitTree e env root arms rest slot endL rty dft
    ((CTBranch (HLit _) _)::_) =>
      emitLitChain e env root arms foc rest branches dft slot endL rty
    -- HUnit is irrefutable (Unit has exactly one inhabitant): no discriminant test
    -- needed.  Drop the focus occurrence and descend into the single branch body.
    -- This closes gap #12 (the 6 Arbitrary impls in core.mdk and any user f()=…).
    ((CTBranch HUnit sub)::_) =>
      emitTree e env root arms rest slot endL rty sub
    ((CTBranch h _)::_) => match conHeadInfo h
      Some _ =>
        let tagReg = loadDiscriminant e foc
        emitConChain e env root arms foc rest tagReg branches dft slot endL rty
      None => gapSwitchHead e slot endL

-- gap-TOLERANT terminator (bootstrap): a switch head the spike cannot lower
-- records the gap, then — when recording is ON — still TERMINATES the current block
-- (store "0" placeholder, branch to the decision end) so the module stays
-- structurally valid LLVM even though the function is dead code.  With recording
-- OFF the `gapU` panics first, exactly as before.  The harness byte-diff catches
-- any switch the program actually REACHES (its output would diverge).
-- Note: HUnit is now handled before reaching here (irrefutable — no test needed).
gapSwitchHead : Emit -> String -> String -> <Mut> Unit
gapSwitchHead e slot endL =
  let _ = gapU "unsupported switch head (slice 5b: constructor / list / tuple / int-literal / unit heads only)"
  let _ = emit e ("  store i64 0, ptr " ++ slot)
  emit e ("  br label %" ++ endL)

-- the name + arity a constructor-LIKE head tests against: a named ADT constructor
-- carries them directly; built-in list HCons/HNil and tuples HTuple reuse the same
-- boxed-cell discipline with the fixed names the alloc sites stamp (emitTuple uses
-- "$tuple"; a user `data … = Cons … | Nil` stamps "Cons"/"Nil").  HLit/HUnit are
-- not constructor-like (HLit goes through emitLitChain; HUnit handled irrefutably
-- before this call — see emitSwitch).
conHeadInfo : CHead -> Option (String, Int)
conHeadInfo (HCon c a) = Some (c, a)
conHeadInfo HCons = Some ("Cons", 2)
conHeadInfo HNil = Some ("Nil", 0)
conHeadInfo (HTuple n) = Some ("$tuple", n)
conHeadInfo _ = None

-- the constructor-switch test chain: compare the discriminant word (immediate or
-- boxed, via loadDiscriminant) against each branch's composite (type, ctor) tag
-- (`cellTag`); on a match, descend with the matched
-- cell's fields as the new leading columns; on exhausting the branches, take the
-- default (focus dropped).
emitConChain : Emit -> List (String, (String, LTy)) -> String -> List CArm -> String -> List String -> String -> List CTBranch -> CTree -> String -> String -> Ref LTy -> <Mut> Unit
emitConChain e env root arms _ rest _ [] dft slot endL rty =
  emitTree e env root arms rest slot endL rty dft
emitConChain e env root arms foc rest tagReg ((CTBranch h sub)::more) dft slot endL rty =
  match conHeadInfo h
    Some (c, a) =>
      let cmp = freshReg e
      let _ = emit e ("  " ++ cmp ++ " = icmp eq i64 " ++ tagReg ++ ", " ++ intToString (cellTag e c))
      let n = intToString (freshId e)
      let yes = "conyes" ++ n
      let next = "connext" ++ n
      let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ yes ++ ", label %" ++ next)
      let _ = emit e (yes ++ ":")
      let fields = loadFields e foc a 0
      let _ = emitTree e env root arms (fields ++ rest) slot endL rty sub
      let _ = emit e (next ++ ":")
      emitConChain e env root arms foc rest tagReg more dft slot endL rty
    None =>
      let _ = gapU "heterogeneous constructor switch (slice 3: a column is all-constructor or all-literal)"
      let _ = emit e ("  store i64 0, ptr " ++ slot)
      emit e ("  br label %" ++ endL)

-- the literal-switch test chain: compare the focus immediate against each branch's
-- tagged-int constant; a literal head has arity 0, so a match descends with the
-- focus simply dropped (no field columns).
emitLitChain : Emit -> List (String, (String, LTy)) -> String -> List CArm -> String -> List String -> List CTBranch -> CTree -> String -> String -> Ref LTy -> <Mut> Unit
emitLitChain e env root arms _ rest [] dft slot endL rty =
  emitTree e env root arms rest slot endL rty dft
emitLitChain e env root arms foc rest ((CTBranch (HLit (LInt k)) sub)::more) dft slot endL rty =
  let cmp = freshReg e
  let _ = emit e ("  " ++ cmp ++ " = icmp eq i64 " ++ foc ++ ", " ++ intToString (k * 2 + 1))
  let n = intToString (freshId e)
  let yes = "lityes" ++ n
  let next = "litnext" ++ n
  let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ yes ++ ", label %" ++ next)
  let _ = emit e (yes ++ ":")
  let _ = emitTree e env root arms rest slot endL rty sub
  let _ = emit e (next ++ ":")
  emitLitChain e env root arms foc rest more dft slot endL rty
-- Char = immediate codepoint word (cp << 1) | 1 — same comparison shape as Int.
emitLitChain e env root arms foc rest ((CTBranch (HLit (LChar c)) sub)::more) dft slot endL rty =
  let cp = charCode (arrayGetUnsafe 0 (stringToChars c))
  let cmp = freshReg e
  let _ = emit e ("  " ++ cmp ++ " = icmp eq i64 " ++ foc ++ ", " ++ intToString (cp * 2 + 1))
  let n = intToString (freshId e)
  let yes = "lityes" ++ n
  let next = "litnext" ++ n
  let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ yes ++ ", label %" ++ next)
  let _ = emit e (yes ++ ":")
  let _ = emitTree e env root arms rest slot endL rty sub
  let _ = emit e (next ++ ":")
  emitLitChain e env root arms foc rest more dft slot endL rty
-- String = boxed cell; equality via the @mdk_string_eq runtime helper, which
-- returns a TAGGED Bool word (3 = True), so branch on `icmp eq i64 r, 3`.
-- Materialize the literal operand the same way emitLit (LString _) does.
emitLitChain e env root arms foc rest ((CTBranch (HLit (LString s)) sub)::more) dft slot endL rty =
  let (lit, _) = emitLit e (LString s)
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = call i64 @mdk_string_eq(i64 " ++ foc ++ ", i64 " ++ lit ++ ")")
  let cmp = freshReg e
  let _ = emit e ("  " ++ cmp ++ " = icmp eq i64 " ++ r ++ ", 3")
  let n = intToString (freshId e)
  let yes = "lityes" ++ n
  let next = "litnext" ++ n
  let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ yes ++ ", label %" ++ next)
  let _ = emit e (yes ++ ":")
  let _ = emitTree e env root arms rest slot endL rty sub
  let _ = emit e (next ++ ":")
  emitLitChain e env root arms foc rest more dft slot endL rty
emitLitChain _ _ _ _ _ _ _ _ _ _ _ =
  gapU "non-Int literal switch (slice 3: no Float / Bool literal heads)"

-- ── small list helpers (slice 3) ────────────────────────────────────────────
lengthS : List a -> Int
lengthS [] = 0
lengthS (_::xs) = 1 + lengthS xs

takeS : Int -> List a -> List a
takeS n xs
  | n <= 0 = []
  | otherwise = match xs
      [] => []
      (y::ys) => y :: takeS (n - 1) ys

dropS : Int -> List a -> List a
dropS n xs
  | n <= 0 = xs
  | otherwise = match xs
      [] => []
      (_::ys) => dropS (n - 1) ys

tailS : List a -> List a
tailS [] = []
tailS (_::xs) = xs

nthArm : List CArm -> Int -> Option CArm
nthArm (a::_) 0 = Some a
nthArm (_::rest) n = nthArm rest (n - 1)
nthArm [] _ = None

-- a readable tag for the unsupported-pattern panic.
ptag : Pat -> String
ptag (PTuple _) = "PTuple"
ptag (PCons _ _) = "PCons"
ptag (PList _) = "PList"
ptag (PAs _ _) = "PAs"
ptag (PRng _ _ _) = "PRng"
ptag (PRec _ _ _) = "PRec"
ptag _ = "?"

-- ── top-level function definitions (slice 2) ────────────────────────────────
-- Each non-`main` top-level binding with parameters becomes an LLVM function
-- `@mdk_<name>(i64 %arg0, …) -> i64`.  Parameters bind to %argN at their
-- INFERRED static type (slice 2b — every param is still an i64 word at the ABI;
-- the type only selects int-vs-float instructions in the body).  The
-- body is emitted in TAIL position so a self-recursive tail call lowers to
-- `musttail call` immediately followed by `ret` (the calling-convention proof:
-- self-recursion guarantees the caller/callee prototypes match, which musttail
-- requires).  Cross-function tail calls lower to an ordinary `call` (still
-- correct; guaranteed-TCO across distinct prototypes is a later increment).
emitFns : Emit -> List CBind -> <Mut> Unit
emitFns _ [] = ()
emitFns e (b::rest) =
  let _ = emitFn e b
  emitFns e rest

emitFn : Emit -> CBind -> <Mut> Unit
emitFn e (CBind name [CClause pats body]) =
  let (pats2, body2) = etaSaturateMethodBody e name pats body
  if trmcTryFn e name [(pats2, body2)] True then ()
  else if allPVar pats2 then emitFnClause e name pats2 body2
  else emitMultiClauseFn e name [(pats2, body2)]
emitFn e (CBind name (c::rest)) =
  let clauses = clausePairs (c::rest)
  if trmcTryFn e name clauses False then ()
  else emitMultiClauseFn e name clauses
emitFn _ (CBind _ []) = gapU "top-level function with no clauses"

-- TRMC branch point (TRMC-DESIGN.md §"Emitter touchpoints" #2): if `name`'s
-- clauses are TRMC-eligible AND the function is a top-level NON-DICT define (no
-- leading `$dict` params — stdlib `map`/`filterMap` and lifted lambdas are Phase
-- 2, out of scope), emit it as a destination-passing loop and return True; else
-- return False so the caller falls back to the current (stack-growing) codegen.
-- `forceSingle` marks the all-PVar single-clause path so emitTrmcFn descends the
-- CIf-guarded body directly instead of the decision-tree chain.
trmcTryFn : Emit -> String -> List (List Pat, CExpr) -> Bool -> <Mut> Bool
trmcTryFn e name clauses forceSingle =
  let arity = clauseArity clauses
  let single = forceSingle && allClausesPVar clauses
  if arity > 0 && trmcNonDict clauses && trmcEligible e (SelfByVar name) arity clauses then
    let ptys = match lookupAssoc name (sigTable e)
      Some (FnSig ts _) => ts
      None => []
    let (spats, sbody) = match clauses
      ((ps, b)::_) => (ps, b)
      [] => ([], CLit LUnit)
    let _ = emitTrmcFn e name arity ptys clauses single spats sbody
    True
  else False

-- every clause's params are all plain PVars (the single-clause TRMC ABI shape).
allClausesPVar : List (List Pat, CExpr) -> Bool
allClausesPVar [] = True
allClausesPVar ((pats, _)::rest) = allPVar pats && allClausesPVar rest

-- a NON-DICT define: no clause has a leading `$dict_…` param (dict-passed methods
-- / lifted lambdas are Phase 2).  leadingDictPats counts them; 0 ⇒ non-dict.
trmcNonDict : List (List Pat, CExpr) -> Bool
trmcNonDict [] = True
trmcNonDict ((pats, _)::rest) = leadingDictPats pats == 0 && trmcNonDict rest


-- Gap #50 — eta-SATURATE a point-free constrained binding whose body is an
-- UNDER-APPLIED interface-method (CMethod) or constrained-fn (CDict) occurrence.
-- `callMax : Ord a => a -> a -> a; callMax = max` dict-passes to a clause with ONE
-- param (the `Ord a` dict) and body `CMethod "max" (RDict $d) ..` applied to ZERO
-- value args — but `max` needs TWO.  The lifted define then has arity 1 (dict only)
-- while the call site (emitDictApp `callMax $d x y`) passes dict + the two real
-- args, OVER-applying the define and silently DROPPING the value args → the method
-- dispatch runs with garbage operands (observed: 0).  Append `deficit` fresh value
-- params to the clause and apply them to the body, so (1) the define's arity matches
-- what the call site passes, and (2) the body becomes a SATURATED method application
-- (emitMethod threads the full argOps through the RDict dispatch chain).  General:
-- any method/constrained-fn used point-free under a `=>` constraint (the dict makes
-- it a fn-bind, not the arity-0 value global that an UNCONSTRAINED alias becomes and
-- which already eta-closures correctly via emitVar→emitEtaClosure).
--
-- Gap #12 (3rd wrapper shape — CLam/compose) — a point-free `=>`-constrained binding
-- whose body is a CLOSURE VALUE, not a method spine.  `clamp lo hi = min hi >> max lo`
-- dict-passes to a clause `[$dict, lo, hi]` (arity 3) whose body is the `CLam` compose
-- (`>>`/`<<` desugar to CLam) producing `\x -> max lo (min hi x)`.  The closure is
-- well-formed and dispatches correctly, but the define RETURNS it unapplied (arity 3)
-- while the call site `clamp 0 10 7` passes `$dict + 3 value args` (arity 4) — the
-- extra arg is DROPPED, garbage out (SIGSEGV at -O2).  methodBodyDeficit is 0 (the
-- body is a CLam value, not an under-applied CMethod/CDict head), so the method-spine
-- path can't fire.  The SIGNATURE-arity deficit catches it: a constrained binding's
-- define MUST have arity `dictCount + sigValueArity` (what emitDictApp passes at every
-- call site = leading dict words ++ all declared value args); when the clause binds
-- fewer params (the closure body supplies the rest), append the shortfall as fresh
-- eta params and APPLY them to the body.  applyEtaArgs' `CApp body etaVar` over a CLam
-- body lowers via emitIndirect (closure-alloc → load code_ptr → call), i.e. it applies
-- the returned closure — exactly the missing application.  General for any point-free
-- constrained binding under-applied relative to its declared value arity, whatever the
-- wrapper (bare CLam, or a method/closure spine the method-spine path already covers —
-- both deficits agree there, so the method-spine path is kept as the primary signal).
etaSaturateMethodBody : Emit -> String -> List Pat -> CExpr -> <Mut> (List Pat, CExpr)
etaSaturateMethodBody e name pats body =
  let mDeficit = methodBodyDeficit e body
  -- method-spine deficit is the primary signal (#50/#11).  When it is 0 the body may
  -- still be a CLOSURE VALUE (CLam from compose `>>`/`<<`) that the define returns
  -- unapplied while the call site passes more value args (clamp/#12) — recover that
  -- shortfall from the SIGNATURE arity, but ONLY when the tail is a CLam (a bare value
  -- return is legitimate point-free currying; eta-applying it would corrupt the body).
  let deficit = etaDeficit e name pats body mDeficit
  if deficit <= 0 then (pats, body)
  else
    let fresh = etaFreshPats deficit (listLen pats)
    (pats ++ fresh, applyEtaArgsTail body fresh)

-- the eta deficit: the method-spine count when positive, else the signature-arity
-- shortfall when the body tail is a CLam closure value (#12), else 0.
etaDeficit : Emit -> String -> List Pat -> CExpr -> Int -> <Mut> Int
etaDeficit e name pats body mDeficit
  | mDeficit > 0 = mDeficit
  | tailIsLam body = sigArityDeficit e name pats
  | otherwise = 0

-- does the body's TAIL (through where/let wrappers) reduce to a CLam closure value?
-- Mirrors applyEtaArgsTail's CLet/CLetGroup transparency so a compose under a
-- `where` is still recognised.
tailIsLam : CExpr -> Bool
tailIsLam (CLet _ _ _ b) = tailIsLam b
tailIsLam (CLetGroup _ b) = tailIsLam b
tailIsLam (CLam _ _) = True
tailIsLam _ = False

-- the shortfall between a constrained binding's REQUIRED define arity
-- (`dictCount + sigValueArity` = what every call site passes through emitDictApp)
-- and the clause's actual param count.  0 (or negative) when the clause already
-- binds every dict + value param (the ordinary case) or when no signature is known
-- (fnArity 0 ⇒ no eta-expansion — leave it to the method-spine path).  dictCount is
-- the number of leading `$dict_…` params dict_pass prepended; the remaining pats are
-- the source value params, and a point-free closure body (e.g. compose) makes that
-- count fall short of the declared sigValueArity.
sigArityDeficit : Emit -> String -> List Pat -> <Mut> Int
sigArityDeficit e name pats =
  let sigArity = fnArity e name
  if sigArity <= 0 then 0
  else maxInt 0 (leadingDictPats pats + sigArity - listLen pats)

-- count of leading `$dict_…` parameter patterns (the dict witnesses dict_pass
-- prepends ahead of the source value params).
leadingDictPats : List Pat -> Int
leadingDictPats ((PVar x)::rest) =
  if isDictParamName x then 1 + leadingDictPats rest else 0
leadingDictPats _ = 0

-- a dict-witness parameter name (dict_pass emits `$dict_<method>_<slot>`).
isDictParamName : String -> Bool
isDictParamName x = stringLength x >= 5 && stringSlice 0 5 x == "$dict"

-- the count of still-unapplied VALUE params of an under-applied method/dict body
-- (0 = saturated / not a method-or-dict head ⇒ no eta-expansion).  A bare CMethod
-- needs its full `methodArityOf`; an applied spine `(CApp.. (CMethod..) a1..ak)`
-- needs `methodArityOf - k`.  CDict (a constrained-fn occurrence) is left alone:
-- when its head is point-free it is an arity-0 value alias handled elsewhere, and a
-- partially-applied CDict already passes its supplied args through emitDictApp.
-- A `where`/`let` wrapper (CLet/CLetGroup) is TRANSPARENT to the deficit — the
-- under-applied method may be the let-body TAIL (`maximum = fold step None`
-- desugars its `step` `where`-helper to a CLetGroup around the `fold` spine).  The
-- companion applyEtaArgsTail threads the fresh args into that same tail.
methodBodyDeficit : Emit -> CExpr -> <Mut> Int
methodBodyDeficit e (CLet _ _ _ b) = methodBodyDeficit e b
methodBodyDeficit e (CLetGroup _ b) = methodBodyDeficit e b
methodBodyDeficit _ (CMethod name _ _ _) = methodArityOf name
methodBodyDeficit e app =
  let (hd, args) = flattenApp app []
  match hd
    CMethod name _ _ _ => maxInt 0 (methodArityOf name - listLen args)
    _ => 0

-- `n` fresh value-param PVars (`__eta_<i>`) numbered after the existing `start`
-- params so paramEnv/paramDecls index them positionally without clashing.
etaFreshPats : Int -> Int -> List Pat
etaFreshPats 0 _ = []
etaFreshPats n start = PVar ("__eta_" ++ intToString start) :: etaFreshPats (n - 1) (start + 1)

-- apply the fresh eta params at the body's TAIL position, threading THROUGH any
-- enclosing `where`/`let` wrappers so the let bindings (e.g. `maximum`'s `step`
-- helper) stay in scope for the now-saturated tail application.  Mirrors
-- methodBodyDeficit's CLet/CLetGroup transparency.
applyEtaArgsTail : CExpr -> List Pat -> CExpr
applyEtaArgsTail (CLet r p rhs b) fresh = CLet r p rhs (applyEtaArgsTail b fresh)
applyEtaArgsTail (CLetGroup bs b) fresh = CLetGroup bs (applyEtaArgsTail b fresh)
applyEtaArgsTail body fresh = applyEtaArgs body fresh

-- apply `body` to each fresh eta param as a CVar (AGlobal — emit resolves a CVar by
-- NAME against the param env, ignoring the Addr), left to right.
applyEtaArgs : CExpr -> List Pat -> CExpr
applyEtaArgs body [] = body
applyEtaArgs body ((PVar x)::rest) = applyEtaArgs (CApp body (CVar x AGlobal)) rest
applyEtaArgs body (_::rest) = applyEtaArgs body rest

-- E1a — multi-clause / patterned top-level fns.  Route ordinary fn-binds whose
-- clauses don't all reduce to plain-variable params through the SAME
-- clause-coalescing + decision-tree lowering the impl methods use
-- (`emitClauseTree`).  This closes EMITTER-GAPS #1 (multi-clause top-level fn)
-- and the fn half of #4 (non-variable parameter pattern), since the decision
-- tree binds patterned params via `bindPattern` in each leaf.  The synthetic
-- `aK` scrutinee params are typed from the fn's inferred signature (sigTable /
-- FnSig) so body arithmetic/printing selects the right instruction; absent a
-- sig, params default to Int (the impl-path behaviour).
emitMultiClauseFn : Emit -> String -> List (List Pat, CExpr) -> <Mut> Unit
emitMultiClauseFn e name clauses =
  let arity = clauseArity clauses
  let ptys = match lookupAssoc name (sigTable e)
    Some (FnSig ts _) => ts
    None => []
  let env = implParamEnvTyped arity ptys 0
  let _ = emit e ("define i64 @mdk_" ++ name ++ "(" ++ implParamDecls arity 0 ++ ") {")
  let _ = emit e "entry:"
  let _ = emitClauseTree e env arity clauses
  let _ = emit e "}"
  emit e ""

-- the (List Pat, CExpr) clause pairs of a fn-bind, in source order.
clausePairs : List CClause -> List (List Pat, CExpr)
clausePairs [] = []
clausePairs ((CClause pats body)::rest) = (pats, body) :: clausePairs rest

-- the shared param count of a fn's clauses (first clause; all clauses agree).
clauseArity : List (List Pat, CExpr) -> Int
clauseArity ((pats, _)::_) = listLen pats
clauseArity [] = 0

-- ── TRMC eligibility analysis (TRMC-DESIGN.md §"Phase 1 scope") ──────────────
-- A function `self` of `arity` is TRMC-eligible when every clause body descends
-- (through CIf / CLet / CLetGroup tail wrappers) to leaves that are EITHER a
-- base/other leaf with NO self-call, OR an eligible cons-tail leaf
-- `CBinPrim "::" head (self-call)` where the tail is a SATURATED self CApp-spine
-- and `head` contains no self-call.  At least one cons-tail leaf must exist (else
-- there is nothing to transform).  Any self-call OUTSIDE a cons-tail leaf
-- DISQUALIFIES the whole function (we cannot prove the loop preserves it) → fall
-- back to the current stack-growing codegen.  Structural + deterministic, so
-- interp- and native-emit produce identical IR (fixpoint holds by construction).
trmcEligible : Emit -> SelfRef -> Int -> List (List Pat, CExpr) -> <Mut> Bool
trmcEligible e self arity clauses =
  trmcClausesOk e self arity clauses && trmcAnyCons e self arity clauses

-- every clause body is TRMC-safe (no misplaced self-call).
trmcClausesOk : Emit -> SelfRef -> Int -> List (List Pat, CExpr) -> <Mut> Bool
trmcClausesOk _ _ _ [] = True
trmcClausesOk e self arity ((_, body)::rest) =
  trmcBodyOk e self arity body && trmcClausesOk e self arity rest

-- at least one clause has an eligible cons/ctor-tail leaf.
trmcAnyCons : Emit -> SelfRef -> Int -> List (List Pat, CExpr) -> <Mut> Bool
trmcAnyCons _ _ _ [] = False
trmcAnyCons e self arity ((_, body)::rest) =
  trmcBodyHasCons e self arity body || trmcAnyCons e self arity rest

-- a tail expr is TRMC-safe: descend through CIf/CLet/CLetGroup wrappers; at a
-- leaf, either it is an eligible ctor-tail (`Ctor f… (self-call)`, the LAST field
-- is the self-call and every other field self-free) or it contains no self-call
-- at all.  A self-call anywhere else fails.  "Self-free" is SelfRef-directed:
-- `selfFree` (freeVars for SelfByVar; the CMethod-aware `mentionsSelfMethod` walk
-- for SelfByMethod — `freeVars` is BLIND to the method name, so a dispatched self
-- recursion outside an eligible tail leaf MUST be caught here, TRMC-DESIGN
-- §"SAFETY-CRITICAL", or it is silently accepted and MISCOMPILED).
trmcBodyOk : Emit -> SelfRef -> Int -> CExpr -> <Mut> Bool
trmcBodyOk e self arity (CIf c t f) =
  selfFree self c && trmcBodyOk e self arity t && trmcBodyOk e self arity f
trmcBodyOk e self arity (CLet _ _ rhs b) =
  selfFree self rhs && trmcBodyOk e self arity b
trmcBodyOk e self arity (CLetGroup binds b) =
  not (selfRefersToBinds self binds) && trmcBodyOk e self arity b
-- B-match-descent (TRMC-DESIGN §"Phase 2 sub-part 3"): a tail-position decision
-- tree (CDecision — `lowerMatch` lowers a constructor/list/tuple/literal match to
-- this; a non-treeable CMatch has NO emit arm and is left to disqualify) is
-- descended — the SCRUTINEE must be self-free (it is evaluated eagerly, not in the
-- loop's destination-passing position), and every arm body must itself be TRMC-safe
-- in tail position.  An arm body may be a cons/ctor-tail leaf, a self-free base, OR
-- the new F3 plain-tail self-call leaf (`None => self …` — iterate on a shorter
-- list, build no cell).  Any self-call in a NON-tail position inside an arm is
-- caught by `trmcBodyOk`'s leaf check (`selfFree` is SelfRef-directed, so a
-- dispatched self-recursion is not blind).
trmcBodyOk e self arity (CDecision scrut arms _) =
  selfFree self scrut && trmcArmsOk e self arity arms
trmcBodyOk e self arity ex =
  if isCtorTail e self arity ex then True
  else if isSelfSatApp self arity ex then True
  else selfFree self ex

-- every match-arm body is TRMC-safe in tail position (guards must be self-free —
-- a self-call inside a guard would run outside the loop's tail position).
trmcArmsOk : Emit -> SelfRef -> Int -> List CArm -> <Mut> Bool
trmcArmsOk _ _ _ [] = True
trmcArmsOk e self arity ((CArm _ guards body)::rest) =
  trmcGuardsSelfFree self guards && trmcBodyOk e self arity body && trmcArmsOk e self arity rest

-- every guard expr is self-free (guards run before the arm body, not in tail
-- position — a self-call there can't be a tail leaf).
trmcGuardsSelfFree : SelfRef -> List CGuard -> Bool
trmcGuardsSelfFree _ [] = True
trmcGuardsSelfFree self ((CGBool c)::rest) = selfFree self c && trmcGuardsSelfFree self rest
trmcGuardsSelfFree self ((CGBind _ c)::rest) = selfFree self c && trmcGuardsSelfFree self rest

-- does a tail expr (under the same wrappers) reach an eligible ctor-tail leaf?
-- (The plain-tail self-call leaf is NOT a "cons" — it builds no cell — so it does
-- not satisfy trmcAnyCons; a function whose ONLY self-calls are plain-tail (pure
-- tail recursion) is left to the musttail path, not TRMC.  At least one cons/ctor
-- tail must exist to warrant the destination-passing loop.)
trmcBodyHasCons : Emit -> SelfRef -> Int -> CExpr -> <Mut> Bool
trmcBodyHasCons e self arity (CIf _ t f) =
  trmcBodyHasCons e self arity t || trmcBodyHasCons e self arity f
trmcBodyHasCons e self arity (CLet _ _ _ b) = trmcBodyHasCons e self arity b
trmcBodyHasCons e self arity (CLetGroup _ b) = trmcBodyHasCons e self arity b
trmcBodyHasCons e self arity (CDecision _ arms _) = trmcArmsHaveCons e self arity arms
trmcBodyHasCons e self arity ex = isCtorTail e self arity ex

trmcArmsHaveCons : Emit -> SelfRef -> Int -> List CArm -> <Mut> Bool
trmcArmsHaveCons _ _ _ [] = False
trmcArmsHaveCons e self arity ((CArm _ _ body)::rest) =
  trmcBodyHasCons e self arity body || trmcArmsHaveCons e self arity rest

-- the eligible ctor-tail shape (Phase 2 Axis A — general single-constructor
-- LAST-field TMC).  Two cases, both: the LAST field is a SATURATED self-recursive
-- spine (head==self, exactly `arity` args), every OTHER field self-free.
--   • `CBinPrim "::" head tail` — the `::`/Cons special case (never flattens to a
--     `CVar` head): field0=head (self-free), last field=tail (the self-call).
--   • a saturated ctor app `Ctor f0 f1 … (self …)`: flattenApp head is `CVar ctor`
--     with `isCtor`, exactly `ctorArity` fields, `ctorArity ≥ 1`, the LAST field a
--     saturated self-call, every other field self-free.
-- `self` is a SelfRef: SelfByVar (top-level define) → the self-call spine head is
-- `CVar self`; SelfByMethod (Phase 2 B-dispatch) → `CMethod method (RKey tag) …`.
isCtorTail : Emit -> SelfRef -> Int -> CExpr -> <Mut> Bool
isCtorTail _ self arity (CBinPrim "::" head tail) =
  selfFree self head && isSelfSatApp self arity tail
isCtorTail e self arity ex = match flattenApp ex []
  (CVar ctor _, fields) =>
    if isCtor e ctor && lengthS fields == ctorArity e ctor && ctorArity e ctor >= 1 then
      ctorTailFieldsOk self arity fields
    else False
  _ => False

-- the field list of a saturated ctor app is TRMC-eligible: the LAST field is the
-- saturated self-call (`isSelfSatApp`), every OTHER (leading) field is self-free.
ctorTailFieldsOk : SelfRef -> Int -> List CExpr -> Bool
ctorTailFieldsOk self arity fields = match splitLastF fields
  Some (lead, last) =>
    allSelfFreeF self lead && isSelfSatApp self arity last
  None => False

allSelfFreeF : SelfRef -> List CExpr -> Bool
allSelfFreeF _ [] = True
allSelfFreeF self (x::rest) = selfFree self x && allSelfFreeF self rest

-- split a non-empty list into (leading elements, last element).
splitLastF : List a -> Option (List a, a)
splitLastF [] = None
splitLastF [x] = Some ([], x)
splitLastF (x::rest) = match splitLastF rest
  Some (lead, last) => Some (x :: lead, last)
  None => None

-- `ex` is a SATURATED self-call to exactly `arity` value args.  SelfByVar: a
-- `CVar self`-headed spine.  SelfByMethod: a `CMethod method (RKey tag) …`-headed
-- spine (the dispatched recursive call post-restampIface — the only shape that
-- lowers to a direct `@mdk_impl_<tag>_<method>` recursion).
isSelfSatApp : SelfRef -> Int -> CExpr -> Bool
isSelfSatApp self arity ex = match flattenApp ex []
  (hd, args) => isSelfHead self hd && listLen args == arity

-- is `hd` the head of a self-call for this SelfRef?
isSelfHead : SelfRef -> CExpr -> Bool
isSelfHead (SelfByVar self) (CVar f _) = f == self
isSelfHead (SelfByMethod method tag) (CMethod m route _ _) =
  m == method && routeIsKey tag route
isSelfHead _ _ = False

-- a route is `RKey tag …` for this tag (the concrete-impl dispatch a dispatched
-- self-recursion carries after restampIface).
routeIsKey : String -> Route -> Bool
routeIsKey tag (RKey t _) = t == tag
routeIsKey _ _ = False

-- `ex` contains NO free reference to `self`.  SelfByVar: freeVars (a CVar name).
-- SelfByMethod: the CMethod-aware walk (freeVars CANNOT see a method name —
-- TRMC-DESIGN §"SAFETY-CRITICAL").
selfFree : SelfRef -> CExpr -> Bool
selfFree (SelfByVar self) ex = not (containsStr self (freeVars [] ex))
selfFree (SelfByMethod method tag) ex = not (mentionsSelfMethod method tag ex)

-- does `ex` mention the self-method `method`@`tag` (a `CMethod method (RKey tag)`
-- occurrence) ANYWHERE in its tree?  This is the safety-critical disqualification:
-- `freeVars (CMethod …)` returns only the dict NAMES, so a dispatched self-call in
-- a NON-tail position is invisible to the freeVars-based `selfFree` and would be
-- wrongly accepted as "self-free" → the body TRMC-transformed → the non-tail self
-- recursion DROPPED → silent miscompile.  This full structural walk closes that.
mentionsSelfMethod : String -> String -> CExpr -> Bool
mentionsSelfMethod method tag (CMethod m route _ _) =
  m == method && routeIsKey tag route
mentionsSelfMethod method tag (CApp f a) =
  mentionsSelfMethod method tag f || mentionsSelfMethod method tag a
mentionsSelfMethod method tag (CLam _ b) = mentionsSelfMethod method tag b
mentionsSelfMethod method tag (CLet _ _ rhs b) =
  mentionsSelfMethod method tag rhs || mentionsSelfMethod method tag b
mentionsSelfMethod method tag (CLetGroup binds b) =
  mentionsSelfMethodBinds method tag binds || mentionsSelfMethod method tag b
mentionsSelfMethod method tag (CBlock stmts) = mentionsSelfMethodStmts method tag stmts
mentionsSelfMethod method tag (CIf c t f) =
  mentionsSelfMethod method tag c || mentionsSelfMethod method tag t || mentionsSelfMethod method tag f
mentionsSelfMethod method tag (CBinPrim _ l r) =
  mentionsSelfMethod method tag l || mentionsSelfMethod method tag r
mentionsSelfMethod method tag (CUnOp _ x) = mentionsSelfMethod method tag x
mentionsSelfMethod method tag (CMatch s arms) =
  mentionsSelfMethod method tag s || mentionsSelfMethodArms method tag arms
mentionsSelfMethod method tag (CDecision s arms _) =
  mentionsSelfMethod method tag s || mentionsSelfMethodArms method tag arms
mentionsSelfMethod method tag (CTuple xs) = mentionsSelfMethodList method tag xs
mentionsSelfMethod method tag (CList xs) = mentionsSelfMethodList method tag xs
mentionsSelfMethod method tag (CArray xs) = mentionsSelfMethodList method tag xs
mentionsSelfMethod method tag (CRangeList lo hi _) =
  mentionsSelfMethod method tag lo || mentionsSelfMethod method tag hi
mentionsSelfMethod method tag (CRangeArray lo hi _) =
  mentionsSelfMethod method tag lo || mentionsSelfMethod method tag hi
mentionsSelfMethod method tag (CRecord _ fields) = mentionsSelfMethodFields method tag fields
mentionsSelfMethod method tag (CFieldAccess ex _) = mentionsSelfMethod method tag ex
mentionsSelfMethod method tag (CRecordUpdate base ups) =
  mentionsSelfMethod method tag base || mentionsSelfMethodFields method tag ups
mentionsSelfMethod method tag (CVariantUpdate _ base ups) =
  mentionsSelfMethod method tag base || mentionsSelfMethodFields method tag ups
mentionsSelfMethod method tag (CIndex a i) =
  mentionsSelfMethod method tag a || mentionsSelfMethod method tag i
mentionsSelfMethod method tag (CSlice a lo hi _) =
  mentionsSelfMethod method tag a || mentionsSelfMethod method tag lo || mentionsSelfMethod method tag hi
mentionsSelfMethod _ _ _ = False

mentionsSelfMethodList : String -> String -> List CExpr -> Bool
mentionsSelfMethodList _ _ [] = False
mentionsSelfMethodList method tag (x::rest) =
  mentionsSelfMethod method tag x || mentionsSelfMethodList method tag rest

mentionsSelfMethodArms : String -> String -> List CArm -> Bool
mentionsSelfMethodArms _ _ [] = False
mentionsSelfMethodArms method tag ((CArm _ guards body)::rest) =
  mentionsSelfMethodGuards method tag guards
  || mentionsSelfMethod method tag body
  || mentionsSelfMethodArms method tag rest

mentionsSelfMethodGuards : String -> String -> List CGuard -> Bool
mentionsSelfMethodGuards _ _ [] = False
mentionsSelfMethodGuards method tag ((CGBool c)::rest) =
  mentionsSelfMethod method tag c || mentionsSelfMethodGuards method tag rest
mentionsSelfMethodGuards method tag ((CGBind _ c)::rest) =
  mentionsSelfMethod method tag c || mentionsSelfMethodGuards method tag rest

mentionsSelfMethodFields : String -> String -> List CField -> Bool
mentionsSelfMethodFields _ _ [] = False
mentionsSelfMethodFields method tag ((CField _ v)::rest) =
  mentionsSelfMethod method tag v || mentionsSelfMethodFields method tag rest

mentionsSelfMethodStmts : String -> String -> List CStmt -> Bool
mentionsSelfMethodStmts _ _ [] = False
mentionsSelfMethodStmts method tag (s::rest) =
  mentionsSelfMethodStmt method tag s || mentionsSelfMethodStmts method tag rest

mentionsSelfMethodStmt : String -> String -> CStmt -> Bool
mentionsSelfMethodStmt method tag (CSExpr ex) = mentionsSelfMethod method tag ex
mentionsSelfMethodStmt method tag (CSLet _ _ ex) = mentionsSelfMethod method tag ex
mentionsSelfMethodStmt method tag (CSLetElse _ ex el) =
  mentionsSelfMethod method tag ex || mentionsSelfMethod method tag el
mentionsSelfMethodStmt method tag (CSAssign _ ex) = mentionsSelfMethod method tag ex

mentionsSelfMethodBinds : String -> String -> List CBind -> Bool
mentionsSelfMethodBinds _ _ [] = False
mentionsSelfMethodBinds method tag ((CBind _ clauses)::rest) =
  mentionsSelfMethodClauses method tag clauses || mentionsSelfMethodBinds method tag rest

mentionsSelfMethodClauses : String -> String -> List CClause -> Bool
mentionsSelfMethodClauses _ _ [] = False
mentionsSelfMethodClauses method tag ((CClause _ body)::rest) =
  mentionsSelfMethod method tag body || mentionsSelfMethodClauses method tag rest

-- does any nullary let-group binding's RHS reference `self`?  (Only the nullary
-- shape is descendable here; a parametric where-helper that called `self` would
-- be a misplaced self-call, so treat a non-nullary binding conservatively too.)
selfRefersToBinds : SelfRef -> List CBind -> Bool
selfRefersToBinds _ [] = False
selfRefersToBinds self ((CBind _ [CClause [] rhs])::rest) =
  not (selfFree self rhs) || selfRefersToBinds self rest
selfRefersToBinds self ((CBind _ clauses)::rest) =
  selfRefersToBindClauses self clauses || selfRefersToBinds self rest
selfRefersToBinds self (_::rest) = selfRefersToBinds self rest

selfRefersToBindClauses : SelfRef -> List CClause -> Bool
selfRefersToBindClauses _ [] = False
selfRefersToBindClauses self ((CClause _ body)::rest) =
  not (selfFree self body) || selfRefersToBindClauses self rest

-- the recursion args of an eligible ctor-tail's self-call (the LAST field's
-- saturated self CApp-spine args).  Works for both the `::` form and a general
-- ctor app: the last field is always the self-call.
consTailArgs : CExpr -> List CExpr
consTailArgs (CBinPrim "::" _ tail) = match flattenApp tail []
  (_, args) => args
consTailArgs ex = match flattenApp ex []
  (_, fields) => match splitLastF fields
    Some (_, last) => match flattenApp last []
      (_, args) => args
    None => []

-- the ctor NAME of an eligible ctor-tail leaf (`Cons` for the `::` form).
ctorTailName : CExpr -> String
ctorTailName (CBinPrim "::" _ _) = "Cons"
ctorTailName ex = match flattenApp ex []
  (CVar ctor _, _) => ctor
  _ => ""

-- the LEADING (non-last) field exprs of an eligible ctor-tail leaf — the fields
-- that get stored into the cell (the last field is the destination link, not
-- stored).  For `::` this is `[head]`.
ctorTailLeadFields : CExpr -> List CExpr
ctorTailLeadFields (CBinPrim "::" head _) = [head]
ctorTailLeadFields ex = match flattenApp ex []
  (_, fields) => match splitLastF fields
    Some (lead, _) => lead
    None => []

-- the self-call's field INDEX within the ctor cell (0-based field index, i.e.
-- offset `8*(idx+1)`).  Axis A: always the LAST field ⇒ `arity-1`.  Kept COMPUTED
-- (not hardcoded "last") so Phase-2 F1(b) [self-call in any field] is a localized
-- detection patch — the emit already offsets by this index (TRMC-DESIGN F1(b) seam).
ctorTailSelfIdx : CExpr -> Int
ctorTailSelfIdx (CBinPrim "::" _ _) = 1
ctorTailSelfIdx ex = match flattenApp ex []
  (_, fields) => lengthS fields - 1

-- ── TRMC emit (destination-passing loop) ────────────────────────────────────
-- emit a TRMC-eligible function as an O(1)-stack destination-passing loop.
-- entry sets up the result hole + the mutable destination slot + the mutable
-- param slots, then jumps to the loop head; the loop reloads the params, runs the
-- ORDINARY param dispatch (single-clause: CIf-tail descent; multi-clause: the
-- decision-tree clause chain) whose LEAVES are redirected via trmcCtxRef:
--   • cons leaf:  alloc Cons cell, store head, link cell into `*dest`, advance
--                 `dest` to the cell's tail slot (+16), recompute the recursion
--                 args into the param slots, br loop.
--   • base leaf:  store the value into `*dest`, br exit.
-- exit loads the hole (the final list head) and rets it.  destSlot holds the
-- ADDRESS of the next i64 to fill; the hole's address is the first destination, a
-- linked cell's tail slot (cell+16) each subsequent one.
emitTrmcFn : Emit -> String -> Int -> List LTy -> List (List Pat, CExpr) -> Bool -> List Pat -> CExpr -> <Mut> Unit
emitTrmcFn e name arity ptys clauses single singlePats singleBody =
  let _ = emitTrmcHeader e ("mdk_" ++ name) arity
  let _ = emitTrmcLoopBody e (SelfByVar name) arity ptys clauses single singlePats singleBody
  let _ = emit e "}"
  emit e ""

-- emit the `define` header + entry label for a TRMC define.  `defineName` is the
-- bare symbol (`mdk_<name>` for a top-level fn, `mdk_impl_<tag>_<method>` for a
-- dispatched impl method).  The caller emits the closing `}` (the impl path's
-- emitGroup already brackets the define).
emitTrmcHeader : Emit -> String -> Int -> <Mut> Unit
emitTrmcHeader e defineName arity =
  let _ = emit e ("define i64 @" ++ defineName ++ "(" ++ implParamDecls arity 0 ++ ") {")
  emit e "entry:"

-- the REUSABLE TRMC loop body (assumes `define`+`entry:` already emitted; does NOT
-- emit the closing `}`).  Sets up the result hole + mutable destination slot +
-- mutable param slots, jumps to the loop head, reloads the params, runs the
-- ordinary param dispatch (single-clause: CIf-tail descent; multi-clause: the
-- decision-tree clause chain) with the LEAVES redirected via trmcCtxRef (TrmcOn
-- carries the SelfRef so the cons/ctor leaf recognises the self-call — a CVar for
-- a top-level fn, a CMethod for a dispatched impl method), then emits the exit
-- block (load hole, ret).  `self` is the SelfRef the loop recurses on; `slotTys`
-- types each reloaded `aK` scrutinee word (top-level: inferred sig types, padded
-- with LTInt; impl: receiver type at the impl positions, LTInt elsewhere).
emitTrmcLoopBody : Emit -> SelfRef -> Int -> List LTy -> List (List Pat, CExpr) -> Bool -> List Pat -> CExpr -> <Mut> Unit
emitTrmcLoopBody e self arity slotTys clauses single singlePats singleBody =
  let hole = freshReg e
  let _ = emit e ("  " ++ hole ++ " = alloca i64")
  let destSlot = freshReg e
  let _ = emit e ("  " ++ destSlot ++ " = alloca ptr")
  let _ = emit e ("  store ptr " ++ hole ++ ", ptr " ++ destSlot)
  -- mutable param slots, seeded from the incoming %argK words.
  let pslots = trmcEmitParamSlots e arity 0
  let loopL = "trmcloop" ++ intToString (freshId e)
  let exitL = "trmcexit" ++ intToString (freshId e)
  let _ = emit e ("  br label %" ++ loopL)
  let _ = emit e (loopL ++ ":")
  -- reload the params into fresh regs for THIS iteration (each loop re-executes
  -- the loads, so a back-edge to %loop re-reads the mutated slots — valid SSA).
  let reloaded = trmcReloadParams e pslots slotTys 0
  let saved = trmcCtxRef.value
  let _ = set_ref trmcCtxRef (TrmcOn self arity destSlot loopL exitL pslots)
  let _ = trmcEmitDispatch e reloaded arity clauses single singlePats reloaded singleBody
  let _ = set_ref trmcCtxRef saved
  let _ = emit e (exitL ++ ":")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ hole)
  emit e ("  ret i64 " ++ r)

-- one mutable `alloca i64` param slot per arg, seeded from %argK; returns the slot
-- registers in order.
trmcEmitParamSlots : Emit -> Int -> Int -> <Mut> List String
trmcEmitParamSlots e arity i
  | i >= arity = []
  | otherwise =
    let slot = freshReg e
    let _ = emit e ("  " ++ slot ++ " = alloca i64")
    let _ = emit e ("  store i64 %arg" ++ intToString i ++ ", ptr " ++ slot)
    slot :: trmcEmitParamSlots e arity (i + 1)

-- reload each param slot into a fresh reg at the loop head, binding the synthetic
-- `aK` scrutinee name (the name emitClauseTree's scrutinee tuple uses) to the
-- loaded word at the fn's inferred param type.
trmcReloadParams : Emit -> List String -> List LTy -> Int -> <Mut> List (String, (String, LTy))
trmcReloadParams _ [] _ _ = []
trmcReloadParams e (slot::rest) tys i =
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ slot)
  let ty = match tys
    (t::_) => t
    [] => LTInt
  (("a" ++ intToString i), (r, ty)) :: trmcReloadParams e rest (trmcTail tys) (i + 1)

trmcTail : List a -> List a
trmcTail [] = []
trmcTail (_::xs) = xs

-- run the in-loop param dispatch.  Single-clause (all-PVar params): rename the
-- reloaded `aK` env to the clause's PVar names and descend the body in tail
-- position (emitTrmcBody).  Multi-clause: reuse emitClauseTree's decision-tree
-- chain verbatim — its emitLeaf is TRMC-aware via trmcCtxRef.
trmcEmitDispatch : Emit -> List (String, (String, LTy)) -> Int -> List (List Pat, CExpr) -> Bool -> List Pat -> List (String, (String, LTy)) -> CExpr -> <Mut> Unit
trmcEmitDispatch e reloaded arity clauses single singlePats aenv singleBody =
  if single then
    let env = trmcRenameEnv singlePats aenv
    emitTrmcBody e env singleBody
  else emitClauseTree e reloaded arity clauses

-- bind the clause's PVar param names to the reloaded `aK` operand words (single
-- clause, all-PVar params — the slice-2 ABI requirement also holds for TRMC).
trmcRenameEnv : List Pat -> List (String, (String, LTy)) -> List (String, (String, LTy))
trmcRenameEnv [] _ = []
trmcRenameEnv ((PVar x)::ps) ((_, op)::rest) = (x, op) :: trmcRenameEnv ps rest
trmcRenameEnv (_::ps) (_::rest) = trmcRenameEnv ps rest
trmcRenameEnv _ [] = []

-- single-clause TRMC body in TAIL position: descend CIf/CLet/CLetGroup wrappers,
-- emit each leaf via the TRMC context (cons leaf or base leaf).  Mirrors
-- emitFnBody's CIf descent but redirects the value leaves.  CLet/CLetGroup descend
-- only their (self-free, verified by trmcBodyOk) simple value-binding shapes; any
-- richer let is emitted whole as a base leaf (no self-call inside ⇒ no stack risk).
emitTrmcBody : Emit -> List (String, (String, LTy)) -> CExpr -> <Mut> Unit
emitTrmcBody e env (CIf c t f) =
  let (cv, _) = emitExpr e env c
  let ci = untagInt e cv
  let cb = freshReg e
  let _ = emit e ("  " ++ cb ++ " = icmp ne i64 " ++ ci ++ ", 0")
  let n = intToString (freshId e)
  let thenL = "trmcthen" ++ n
  let elseL = "trmcelse" ++ n
  let _ = emit e ("  br i1 " ++ cb ++ ", label %" ++ thenL ++ ", label %" ++ elseL)
  let _ = emit e (thenL ++ ":")
  let _ = emitTrmcBody e env t
  let _ = emit e (elseL ++ ":")
  emitTrmcBody e env f
emitTrmcBody e env (CLet False (PVar x) rhs b) =
  let (v, ty) = emitExpr e env rhs
  emitTrmcBody e ((x, (v, ty)) :: env) b
emitTrmcBody e env (CLetGroup binds b) =
  if allNullaryBinds binds then
    let env2 = trmcBindNullaryGroup e env binds
    emitTrmcBody e env2 b
  else emitTrmcLeaf e env (CLetGroup binds b)
-- B-match-descent (TRMC-DESIGN §"Phase 2 sub-part 3"): a TAIL-position decision
-- tree.  Emit the scrutinee, then walk the SAME decision-tree machinery as
-- emitDecision (emitTree) but keep trmcCtxRef LIVE — so each arm body is descended
-- as a TRMC tail leaf (cons-into-dest+loop / plain-tail-call+loop / base+exit) via
-- emitLeaf's TrmcOn branch, NOT computed into a value slot.  This is the inverse of
-- emitDecision's save+clear, which stays for an EXPRESSION-position match inside an
-- arm (a value-producing match whose arms must store into its own slot).  The
-- result slot + end label passed to emitTree are a DEAD block (no leaf stores into
-- them under TrmcOn — every leaf branches to loopL/exitL); LLVM tolerates the
-- unreachable load/branch (Phase-1 precedent: the nested decision result slot is a
-- dead block).  fallthroughLabelRef is saved+cleared (a non-exhaustive tail match's
-- CTFail is a genuine abort, not the enclosing clause chain's fallthrough).
emitTrmcBody e env (CDecision scrut arms tree) =
  let (sv, _) = emitExpr e env scrut
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "trmcdecend" ++ intToString (freshId e)
  let rty = Ref LTInt
  let savedFT = fallthroughLabelRef.value
  let _ = set_ref fallthroughLabelRef ""
  -- trmcCtxRef is INTENTIONALLY left LIVE across the tree (the tail arms cons/loop
  -- into the active destination); a nested EXPRESSION-position match within an arm
  -- body re-enters emitDecision, which saves+clears it for its own value arms.
  let _ = emitTree e env sv arms [sv] slot endL rty tree
  let _ = set_ref fallthroughLabelRef savedFT
  -- the dead end block: no TrmcOn leaf branches here, but emit it well-formed so a
  -- (non-treeable / fallthrough) path that did would still verify.
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ slot)
  emit e "  unreachable"
emitTrmcBody e env ex = emitTrmcLeaf e env ex

-- every binding is a nullary value binding (the descendable let-group shape).
allNullaryBinds : List CBind -> Bool
allNullaryBinds [] = True
allNullaryBinds ((CBind _ [CClause [] _])::rest) = allNullaryBinds rest
allNullaryBinds _ = False

-- emit each nullary value binding left-to-right, threading the env (mirrors
-- emitLetGroup's value-binding arm).
trmcBindNullaryGroup : Emit -> List (String, (String, LTy)) -> List CBind -> <Mut> List (String, (String, LTy))
trmcBindNullaryGroup _ env [] = env
trmcBindNullaryGroup e env ((CBind name [CClause [] rhs])::rest) =
  let (v, ty) = emitExpr e env rhs
  trmcBindNullaryGroup e ((name, (v, ty)) :: env) rest
trmcBindNullaryGroup _ env (_::rest) = env

-- a TRMC tail leaf: an eligible ctor-tail conses into the destination + loops; a
-- bare plain-tail self-call (F3 — `None => self …`, no enclosing cons/ctor)
-- recomputes its args + loops with NO cell alloc + NO dest store (iterate on a
-- shorter list); any other leaf stores its value into the destination + exits.
emitTrmcLeaf : Emit -> List (String, (String, LTy)) -> CExpr -> <Mut> Unit
emitTrmcLeaf e env ex = match trmcCtxRef.value
  TrmcOff => emitValueRet e env ex
  TrmcOn self arity destSlot loopL exitL pslots =>
    if isCtorTail e self arity ex then
      emitTrmcCtor e env (ctorTailName ex) (ctorTailLeadFields ex) (consTailArgs ex) (ctorTailSelfIdx ex) destSlot loopL pslots
    else if isSelfSatApp self arity ex then
      emitTrmcTailCall e env ex loopL pslots
    else emitTrmcBase e env ex destSlot exitL

-- F3 plain-tail self-call leaf (TRMC-DESIGN §"Phase 2 sub-part 3"): a bare
-- saturated self-call in tail position (`None => filterMap f xs`).  It is the
-- cons-leaf MINUS the cell alloc + head store + dest link/advance — an
-- iterate-on-a-shorter-list step: recompute the recursion args into TEMPS (an arg
-- may read an earlier param), store them into the loop's param slots, and branch
-- back to the loop head.  The destination is left UNCHANGED (this arm produces no
-- list cell), so the next iteration fills the same destination slot — exactly the
-- "drop this element" semantics of `filter`/`filterMap`.  The self-call is NOT
-- emitted as a `call` (that is what removes the stack-growing recursion).
emitTrmcTailCall : Emit -> List (String, (String, LTy)) -> CExpr -> String -> List String -> <Mut> Unit
emitTrmcTailCall e env ex loopL pslots =
  let args = match flattenApp ex []
    (_, as_) => as_
  let argOps = emitArgs e env args
  let _ = trmcStoreParamSlots e pslots argOps
  emit e ("  br label %" ++ loopL)

-- ctor leaf (Phase 2 Axis A): alloc a single-constructor cell (header + the
-- non-last fields), link it into the current destination at the SELF-CALL field
-- slot (offset `8*(selfIdx+1)`), advance the destination to that slot, recompute
-- the recursion args into the param slots, and branch back to the loop head.  The
-- self-call is NOT emitted — only the leading fields + arg recomputations are,
-- which is what removes the stack-growing `call`.  Store order (GC-safe,
-- TRMC-DESIGN §"Risk"): alloc → header → leading fields → link-into-dest → advance;
-- the cell's own self-call slot stays ZEROED (GC_malloc returns zeroed memory; an
-- even/null word is never dereferenced by Boehm) until the next iteration fills it.
-- For `::`/Cons this is arity 2, selfIdx 1 (offset 16) — the Phase-1 cons shape.
-- F1(b) SEAM: the dest-offset is COMPUTED from `selfIdx`, not hardcoded "last", so a
-- future self-call-in-any-field is a detection-only patch (this emit is unchanged).
emitTrmcCtor : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> List CExpr -> Int -> String -> String -> List String -> <Mut> Unit
emitTrmcCtor e env ctor leadFields args selfIdx destSlot loopL pslots =
  let arity = lengthS leadFields + 1
  -- emit the leading (non-last) field values FIRST (left-to-right), then alloc.
  let leadVals = emitArgs e env leadFields
  let cell = freshReg e
  let _ = emit e ("  " ++ cell ++ " = call ptr @mdk_alloc(i64 " ++ intToString (8 * (arity + 1)) ++ ")")
  let _ = emit e ("  store i64 " ++ intToString (cellTag e ctor) ++ ", ptr " ++ cell)
  -- store the leading fields at their positional offsets (field 0 at +8, …).  The
  -- self-call slot (offset 8*(selfIdx+1)) is left zeroed for the link below.
  let _ = storeFields e cell leadVals 0
  let cellw = freshReg e
  let _ = emit e ("  " ++ cellw ++ " = ptrtoint ptr " ++ cell ++ " to i64")
  let d = freshReg e
  let _ = emit e ("  " ++ d ++ " = load ptr, ptr " ++ destSlot)
  let _ = emit e ("  store i64 " ++ cellw ++ ", ptr " ++ d)
  -- advance the destination to THIS cell's self-call field slot (offset
  -- 8*(selfIdx+1)) — COMPUTED from the field index (F1(b) seam).
  let newdest = freshReg e
  let _ = emit e ("  " ++ newdest ++ " = getelementptr i8, ptr " ++ cell ++ ", i64 " ++ intToString (8 * (selfIdx + 1)))
  let _ = emit e ("  store ptr " ++ newdest ++ ", ptr " ++ destSlot)
  -- recompute every recursion arg into a TEMP first (an arg may read an earlier
  -- param), THEN store all temps into the slots, so an in-place store can't clobber
  -- a not-yet-read param within the same iteration.
  let argOps = emitArgs e env args
  let _ = trmcStoreParamSlots e pslots argOps
  emit e ("  br label %" ++ loopL)

-- store the recomputed arg operands back into the loop's mutable param slots.
trmcStoreParamSlots : Emit -> List String -> List String -> <Mut> Unit
trmcStoreParamSlots _ [] _ = ()
trmcStoreParamSlots _ _ [] = ()
trmcStoreParamSlots e (slot::slots) (op::ops) =
  let _ = emit e ("  store i64 " ++ op ++ ", ptr " ++ slot)
  trmcStoreParamSlots e slots ops

-- base/other leaf: store the value into the current destination, branch to exit.
emitTrmcBase : Emit -> List (String, (String, LTy)) -> CExpr -> String -> String -> <Mut> Unit
emitTrmcBase e env ex destSlot exitL =
  let (v, _) = emitExpr e env ex
  let d = freshReg e
  let _ = emit e ("  " ++ d ++ " = load ptr, ptr " ++ destSlot)
  let _ = emit e ("  store i64 " ++ v ++ ", ptr " ++ d)
  emit e ("  br label %" ++ exitL)

-- like implParamEnv, but types each synthetic `aK` scrutinee param from the fn's
-- inferred signature param types (FnSig ts) instead of defaulting to LTInt.
-- Params past the signature length (or with no sig) fall back to LTInt.
implParamEnvTyped : Int -> List LTy -> Int -> List (String, (String, LTy))
implParamEnvTyped n _ i | i >= n = []
implParamEnvTyped n (ty::tys) i = ("a" ++ intToString i, ("%arg" ++ intToString i, ty)) :: implParamEnvTyped n tys (i + 1)
implParamEnvTyped n [] i = ("a" ++ intToString i, ("%arg" ++ intToString i, LTInt)) :: implParamEnvTyped n [] (i + 1)

-- emit one variable-pattern function clause (the slice-2 path).
emitFnClause : Emit -> String -> List Pat -> CExpr -> <Mut> Unit
emitFnClause e name pats body =
  let ptys = match lookupAssoc name (sigTable e)
    Some (FnSig ts _) => ts
    None => allInt pats
  let env = paramEnv pats ptys 0
  let _ = emit e ("define i64 @mdk_" ++ name ++ "(" ++ paramDecls pats 0 ++ ") {")
  let _ = emit e "entry:"
  let _ = emitFnBody e env name body
  let _ = emit e "}"
  emit e ""

-- every parameter is a plain variable pattern (the slice-2 ABI requirement).
allPVar : List Pat -> Bool
allPVar [] = True
allPVar ((PVar _)::rest) = allPVar rest
allPVar _ = False

sigTable : Emit -> <Mut> List (String, FnSig)
sigTable (Emit _ _ _ sigs _ _ _ _ _ _) = sigs.value

-- default param types when no signature was inferred (every param Int).
allInt : List Pat -> List LTy
allInt [] = []
allInt (_::rest) = LTInt :: allInt rest

paramDecls : List Pat -> Int -> String
paramDecls [] _ = ""
paramDecls [PVar _] i = "i64 %arg" ++ intToString i
paramDecls ((PVar _)::rest) i = "i64 %arg" ++ intToString i ++ ", " ++ paramDecls rest (i + 1)
paramDecls _ _ = panic "llvm spike: function parameters must be plain variables in slice 2"

-- bind each parameter to %argN at its inferred static type (every param is an i64
-- word at the ABI; the type only drives int-vs-float instruction selection).
paramEnv : List Pat -> List LTy -> Int -> List (String, (String, LTy))
paramEnv [] _ _ = []
paramEnv ((PVar x)::rest) (ty::tys) i = (x, ("%arg" ++ intToString i, ty)) :: paramEnv rest tys (i + 1)
paramEnv ((PVar x)::rest) [] i = (x, ("%arg" ++ intToString i, LTInt)) :: paramEnv rest [] (i + 1)
paramEnv _ _ _ = panic "llvm spike: function parameters must be plain variables in slice 2"

-- emit a function body in TAIL position: every control path ends in a `ret`.
-- An `if` recurses into both arms (each arm is itself in tail position and rets);
-- a tail call to a known function emits `[musttail] call` + `ret`; anything else
-- is computed as a value and returned.
emitFnBody : Emit -> List (String, (String, LTy)) -> String -> CExpr -> <Mut> Unit
emitFnBody e env self (CIf c t f) =
  let (cv, _) = emitExpr e env c
  let ci = untagInt e cv
  let cb = freshReg e
  let _ = emit e ("  " ++ cb ++ " = icmp ne i64 " ++ ci ++ ", 0")
  let n = intToString (freshId e)
  let thenL = "then" ++ n
  let elseL = "else" ++ n
  let _ = emit e ("  br i1 " ++ cb ++ ", label %" ++ thenL ++ ", label %" ++ elseL)
  let _ = emit e (thenL ++ ":")
  let _ = emitFnBody e env self t
  let _ = emit e (elseL ++ ":")
  emitFnBody e env self f
emitFnBody e env self other =
  let (hd, args) = flattenApp other []
  match hd
    CVar fname _ =>
      if isKnownFn e fname && hasArgs args then
        let argOps = emitArgs e env args
        let r = freshReg e
        let kw = if fname == self then "musttail call" else "call"
        let _ = emit e ("  " ++ r ++ " = " ++ kw ++ " i64 @mdk_" ++ fname ++ "(" ++ argDecls argOps ++ ")")
        emit e ("  ret i64 " ++ r)
      else emitValueRet e env other
    _ => emitValueRet e env other

emitValueRet : Emit -> List (String, (String, LTy)) -> CExpr -> <Mut> Unit
emitValueRet e env ex =
  let (v, _) = emitExpr e env ex
  emit e ("  ret i64 " ++ v)

-- ── classifying top-level bindings ──────────────────────────────────────────
-- a function binding = non-`main`, first clause has at least one parameter.
isFnBind : CBind -> Bool
isFnBind (CBind "main" _) = False
isFnBind (CBind _ ((CClause (_::_) _)::_)) = True
isFnBind _ = False

bindName : CBind -> String
bindName (CBind name _) = name

collectFns : List CBind -> List String
collectFns [] = []
collectFns (b::rest) =
  if isFnBind b then bindName b :: collectFns rest else collectFns rest

fnBinds : List CBind -> List CBind
fnBinds [] = []
fnBinds (b::rest) = if isFnBind b then b :: fnBinds rest else fnBinds rest

-- the nullary value bindings (non-`main`, no parameters), in source order.
valBinds : List CBind -> List CBind
valBinds [] = []
valBinds ((CBind "main" cs)::rest) = valBinds rest
valBinds (b::rest) = if isFnBind b then valBinds rest else b :: valBinds rest

-- value bindings ORDERED so a binding precedes the ones that reference it (E1b).
-- The init prologue computes each rhs once, eagerly, so a binding whose rhs reads
-- ANOTHER value global (`prog = andThen skip …`, `skip` defined later) must run
-- after that dependency or it captures the still-zero global cell — a null that
-- crashes at use.  Source order is NOT dependency order in general (the self-host
-- parser binds combinator values forward of their producers), so topologically
-- sort by intra-value-global references.  A genuine VALUE cycle (mutual recursion
-- through nullary globals — none arise in practice) keeps its members in source
-- order, the pre-existing behaviour (still caught by the forward-ref gap).
orderedValBinds : List CBind -> List CBind
orderedValBinds binds =
  let names = map bindName binds
  let (_, ordered) = topoValGo binds names binds [] []
  ordered

-- DFS post-order: visit each binding's value-global dependencies first, appending
-- the binding after them.  `visiting` guards against cycles (a back-edge is
-- skipped — its target stays where source order placed it).  Returns the grown
-- (done-names, ordered-binds) accumulators.
topoValGo : List CBind -> List String -> List CBind -> List String -> List CBind -> (List String, List CBind)
topoValGo _ _ [] done acc = (done, acc)
topoValGo all names (b::rest) done acc =
  let (done2, acc2) = topoValVisit all names b done acc []
  topoValGo all names rest done2 acc2

topoValVisit : List CBind -> List String -> CBind -> List String -> List CBind -> List String -> (List String, List CBind)
topoValVisit all names b done acc visiting
  | containsStr (bindName b) done = (done, acc)
  | containsStr (bindName b) visiting = (done, acc)
  | otherwise =
      let deps = intersectStr (dedupS (bindFreeVars b)) names
      let (done2, acc2) = topoValVisitDeps all names deps done acc (bindName b :: visiting)
      (bindName b :: done2, acc2 ++ [b])

topoValVisitDeps : List CBind -> List String -> List String -> List String -> List CBind -> List String -> (List String, List CBind)
topoValVisitDeps _ _ [] done acc _ = (done, acc)
topoValVisitDeps all names (d::rest) done acc visiting =
  match findBind d all
    Some db =>
      let (done2, acc2) = topoValVisit all names db done acc visiting
      topoValVisitDeps all names rest done2 acc2 visiting
    None => topoValVisitDeps all names rest done acc visiting

-- the value-global names a binding's rhs references EAGERLY (at init time) — i.e.
-- references NOT inside a lambda body.  A `CLam` captures a global by reference
-- and resolves it only when the closure is later CALLED (at parse time, long after
-- all globals are initialised), so a name appearing only inside a lambda is NOT an
-- init-order dependency.  Counting it would forge a false cycle between two
-- combinator globals that reference each other solely through their closures
-- (`stmtsLoop = orElse stmtsCons (pure [])` ← eager; `stmtsCons = do … stmtsLoop`
-- ← the back-reference is inside stmtsCons's `do` closure, lazy), and the
-- cycle-fallback would then emit them in source order, leaving the eager ref null.
bindFreeVars : CBind -> List String
bindFreeVars (CBind _ [CClause [] body]) = eagerVars [] body
bindFreeVars _ = []

-- free CVar names evaluated EAGERLY in `body`: like freeVars, but a `CLam` body is
-- NOT descended (its references are deferred to call time).  Bound names (`b`)
-- accumulate so a let/match-bound local is not mistaken for a global.
eagerVars : List String -> CExpr -> List String
eagerVars _ (CLam _ _) = []
eagerVars b (CVar x _) = if containsStr x b then [] else [x]
eagerVars _ (CLit _) = []
eagerVars b (CApp f a) = eagerVars b f ++ eagerVars b a
eagerVars b (CLet recF pat e1 e2) =
  let b2 = patVars pat ++ b
  let fe1 = if recF then eagerVars b2 e1 else eagerVars b e1
  fe1 ++ eagerVars b2 e2
eagerVars b (CLetGroup binds body) =
  let b2 = bindNames binds ++ b
  eagerVarsBinds b2 binds ++ eagerVars b2 body
eagerVars b (CBlock stmts) = eagerVarsStmts b stmts
eagerVars b (CIf c t f) = eagerVars b c ++ eagerVars b t ++ eagerVars b f
eagerVars b (CBinPrim _ l r) = eagerVars b l ++ eagerVars b r
eagerVars b (CUnOp _ x) = eagerVars b x
eagerVars b (CMatch scrut arms) = eagerVars b scrut ++ eagerVarsArms b arms
eagerVars b (CDecision scrut arms _) = eagerVars b scrut ++ eagerVarsArms b arms
eagerVars b (CTuple es) = eagerVarsList b es
eagerVars b (CList es) = eagerVarsList b es
eagerVars b (CRangeList lo hi _) = eagerVars b lo ++ eagerVars b hi
eagerVars b (CRecord _ fields) = eagerVarsFields b fields
eagerVars b (CFieldAccess ex _) = eagerVars b ex
eagerVars b (CRecordUpdate base updates) = eagerVars b base ++ eagerVarsFields b updates
eagerVars b (CVariantUpdate _ base updates) = eagerVars b base ++ eagerVarsFields b updates
eagerVars b (CArray es) = eagerVarsList b es
eagerVars b (CRangeArray lo hi _) = eagerVars b lo ++ eagerVars b hi
eagerVars b (CIndex a i) = eagerVars b a ++ eagerVars b i
eagerVars b (CSlice a lo hi _) = eagerVars b a ++ eagerVars b lo ++ eagerVars b hi
eagerVars _ _ = []

eagerVarsList : List String -> List CExpr -> List String
eagerVarsList _ [] = []
eagerVarsList b (e::rest) = eagerVars b e ++ eagerVarsList b rest

eagerVarsArms : List String -> List CArm -> List String
eagerVarsArms _ [] = []
eagerVarsArms b ((CArm pat _ body)::rest) =
  eagerVars (patVars pat ++ b) body ++ eagerVarsArms b rest

eagerVarsFields : List String -> List CField -> List String
eagerVarsFields _ [] = []
eagerVarsFields b ((CField _ ex)::rest) = eagerVars b ex ++ eagerVarsFields b rest

eagerVarsStmts : List String -> List CStmt -> List String
eagerVarsStmts _ [] = []
eagerVarsStmts b ((CSExpr ex)::rest) = eagerVars b ex ++ eagerVarsStmts b rest
eagerVarsStmts b ((CSLet _ pat ex)::rest) =
  eagerVars b ex ++ eagerVarsStmts (patVars pat ++ b) rest
eagerVarsStmts b ((CSAssign _ ex)::rest) =
  eagerVars b ex ++ eagerVarsStmts b rest
eagerVarsStmts b ((CSLetElse pat ex alt)::rest) =
  eagerVars b ex ++ eagerVars b alt ++ eagerVarsStmts (patVars pat ++ b) rest
eagerVarsStmts b (_::rest) = eagerVarsStmts b rest

eagerVarsBinds : List String -> List CBind -> List String
eagerVarsBinds _ [] = []
eagerVarsBinds b ((CBind _ [CClause [] rhs])::rest) =
  eagerVars b rhs ++ eagerVarsBinds b rest
eagerVarsBinds b (_::rest) = eagerVarsBinds b rest

findBind : String -> List CBind -> Option CBind
findBind _ [] = None
findBind name (b::rest) = if bindName b == name then Some b else findBind name rest

-- the elements of `xs` that also appear in `ys` (membership, order from xs).
intersectStr : List String -> List String -> List String
intersectStr [] _ = []
intersectStr (x::rest) ys
  | containsStr x ys = x :: intersectStr rest ys
  | otherwise = intersectStr rest ys


-- the initial globals registry (slice E1b): every value binding's name registered
-- UNinitialised (`False`) with a placeholder LTy.  The `@main` init prologue flips
-- each to `(True, <its rhs LTy>)` in source order as it computes the rhs, so a
-- reference to a not-yet-computed global is caught as a forward/mutual dependency.
initGlobalsReg : List CBind -> List (String, (Bool, LTy))
initGlobalsReg [] = []
initGlobalsReg (b::rest) = (bindName b, (False, LTInt)) :: initGlobalsReg rest

-- a fully-initialised globals registry: every value binding registered `True` with
-- a placeholder LTy.  The D4 gaps probe uses this so a function body referencing a
-- top-level value binding resolves to a global load (no spurious gap) — the probe
-- discards the emitted text, so the placeholder LTy is immaterial.
initGlobalsRegReady : List CBind -> List (String, (Bool, LTy))
initGlobalsRegReady [] = []
initGlobalsRegReady (b::rest) = (bindName b, (True, LTInt)) :: initGlobalsRegReady rest

-- emit a zero-initialised module global `@mdk_g_<name> = global i64 0` for each
-- value binding (into the side buffer, like string-literal globals — LLVM module
-- item order is irrelevant).  The `@main` prologue stores each binding's computed
-- rhs word here; references anywhere load it back.
emitGlobalDecls : Emit -> List CBind -> <Mut> Unit
emitGlobalDecls _ [] = ()
emitGlobalDecls e (b::rest) =
  let _ = emitGlobal e ("@mdk_g_" ++ bindName b ++ " = global i64 0")
  emitGlobalDecls e rest

-- ── function signature inference (slice 2b) ──────────────────────────────────
-- Core IR is type-erased, so to lower a Bool/Float-typed function boundary we
-- must RECOVER the static type of each parameter and result.  `typeOf` is the
-- pure (non-emitting) twin of the type-recovery that `emitExpr` already does as
-- it emits — it computes a CExpr's LTy from the signature table + a var→LTy env,
-- with no side effects.  `inferSigs` runs it to a two-pass fixpoint so a callee's
-- signature is available before its caller's body is typed (one extra pass lets a
-- caller see a callee defined later / mutual recursion settle).
--
-- Float/Bool ride the EXISTING uniform i64 word (Float boxed, Bool immediate), so
-- inference changes no LLVM type — only which instructions the body emits and the
-- print routine `main` picks.  Param/return remain i64 at the ABI, so musttail's
-- prototype-match invariant is untouched.

-- structural type of an expression given known fn signatures + a var→type env.
-- Unknown vars (top-level value globals) default to Int — the slice's existing
-- assumption (function bodies referencing globals are out of scope anyway).
typeOf : List (String, FnSig) -> List (String, LTy) -> CExpr -> LTy
typeOf _ _ (CLit (LInt _)) = LTInt
typeOf _ _ (CLit (LFloat _)) = LTFloat
typeOf _ _ (CLit (LBool _)) = LTBool
typeOf _ _ (CLit (LString _)) = LTStr
typeOf _ _ (CLit (LChar _)) = LTChar
-- A list literal / range-list is a chain of Cons/Nil cells — a constructor
-- value (LTCon), NOT an Int.  Without this, the empty-list base clause of a
-- list-returning multi-clause fn (e.g. `externNames [] = []`) typed as LTInt, so
-- the fn's inferred return LTy was LTInt; a `++` on its result then fell to the
-- runtime-dispatch arm (default LTStr), and a CHAINED outer `++` saw LTStr and
-- statically emitted mdk_string_append on a List → memmove crash.  LTCon routes
-- the whole `++` chain through mdk_list_append correctly.
typeOf _ _ (CList _) = LTCon
typeOf _ _ (CRangeList _ _ _) = LTCon
typeOf _ env (CVar x _) = match lookupAssoc x env
  Some t => t
  None => LTInt
typeOf sigs env (CBinPrim op l r)
  | isCmpOp op = LTBool
  | op == "::" = LTCon
  | otherwise = typeOf sigs env l
typeOf _ _ (CUnOp "!" _) = LTBool
typeOf sigs env (CUnOp "-" x) = typeOf sigs env x
typeOf sigs env (CIf _ t _) = typeOf sigs env t
typeOf sigs env (CLet False (PVar x) e1 e2) =
  typeOf sigs ((x, typeOf sigs env e1) :: env) e2
typeOf sigs env (CLetGroup binds body) =
  typeOf sigs (letGroupEnv sigs env binds) body
typeOf sigs env (CBlock stmts) = blockTy sigs env stmts
typeOf sigs env (CDecision _ arms _) = armsRetTy sigs env arms
-- A constrained-function or return-position-method occurrence (CDict/CMethod)
-- carries the SAME callee name as the bare CVar would; its emit path
-- (`emitDictApp`/`emitMethod`) types the result via `fnRetTy e name`, so the pure
-- twin must mirror that and route through `callRetTy sigs name` — not default to
-- LTInt.  Without this, a Unit-returning constrained stdlib fn called inside a
-- user fn (e.g. `f s = println s`, where `println : Display a => a -> <IO> Unit`
-- lowers `f`'s body to `CDict "println" …`) inferred `f`'s return as LTInt,
-- mis-printing `main`'s `()` result as `0` (construct-gap F1; layers on #2b's
-- LTUnit IO-extern fix).
typeOf sigs env app =
  let (hd, args) = flattenApp app []
  match hd
    CVar fname _ => if hasArgs args then callRetTy sigs fname else LTInt
    CDict fname _ => callRetTy sigs fname
    CMethod fname _ _ _ => callRetTy sigs fname
    _ => LTInt

-- the return type of a known function from the sig table (Int if unknown).
-- the return type of a known function from the sig table (Int if unknown).
-- IO output externs (putStr/putStrLn/…) return Unit but are NOT user-fn binds,
-- so they are absent from `sigs` and would default to LTInt — typing a
-- Unit-returning wrapper (e.g. `println x = putStrLn (display x)`) as LTInt and
-- mis-rendering `main`'s result as `0` instead of `()` (Stage 3 #2b).  Resolve
-- them to LTUnit up front, matching the real emit path (`emitIoExtern`).
callRetTy : List (String, FnSig) -> String -> LTy
callRetTy sigs fname =
  if isIoExtern fname then LTUnit
  else match lookupAssoc fname sigs
    Some (FnSig _ rty) => rty
    None => LTInt

-- a decision's result type is its first arm's body type (all arms agree —
-- well-typed match).  Pattern-bound vars are unknown to the pure pass, so a body
-- referencing them defaults via typeOf's CVar/None branch; the fixtures' arms are
-- Int-typed, matching the runtime-captured `rty`.
armsRetTy : List (String, FnSig) -> List (String, LTy) -> List CArm -> LTy
armsRetTy _ _ [] = LTInt
armsRetTy sigs env ((CArm _ _ body)::_) = typeOf sigs env body

letGroupEnv : List (String, FnSig) -> List (String, LTy) -> List CBind -> List (String, LTy)
letGroupEnv _ env [] = env
letGroupEnv sigs env ((CBind name [CClause [] rhs])::rest) =
  letGroupEnv sigs ((name, typeOf sigs env rhs) :: env) rest
letGroupEnv _ env _ = env

blockTy : List (String, FnSig) -> List (String, LTy) -> List CStmt -> LTy
blockTy sigs env [CSExpr ex] = typeOf sigs env ex
blockTy sigs env ((CSExpr _)::rest) = blockTy sigs env rest
blockTy sigs env ((CSLet _ (PVar x) ex)::rest) =
  blockTy sigs ((x, typeOf sigs env ex) :: env) rest
-- a constructor / nested block-let (emitBlock now binds these): type its pattern
-- vars in blockTy's env so a tail expr that uses a bound field still recurses
-- (the old catch-all stopped at LTInt for the whole tail).  blockTy is pure, so
-- it cannot consult the (Mut) ctor field-type table — each var gets LTInt, the
-- same default the catch-all produced.  emitBlock's bindPattern applies the
-- precise declared scalar types at emit time; this only types the result lookup.
blockTy sigs env ((CSLet _ pat ex)::rest) =
  blockTy sigs (patBindTys pat ++ env) rest
blockTy sigs env ((CSAssign x ex)::rest) =
  blockTy sigs ((x, typeOf sigs env ex) :: env) rest
blockTy _ _ _ = LTInt

-- bind a non-PVar block-let pattern's vars for blockTy's env.  blockTy is pure,
-- so we cannot consult the (Mut) ctor field-type table; each var gets LTInt (the
-- same value the catch-all `blockTy _ _ _ = LTInt` produced for these lets).
patBindTys : Pat -> List (String, LTy)
patBindTys pat = mapVarLTInt (patVars pat)

mapVarLTInt : List String -> List (String, LTy)
mapVarLTInt [] = []
mapVarLTInt (x::rest) = (x, LTInt) :: mapVarLTInt rest

-- infer one parameter's type from its first typed USE in the body: the condition
-- of an `if` or the operand of `!` forces Bool; an operand of an arithmetic/
-- comparison binop shares its SIBLING's type; an argument to a known function
-- takes that function's parameter type.  None ⇒ no determining use found (the
-- caller defaults it to Int).
paramUseTy : List (String, FnSig) -> List (String, LTy) -> String -> CExpr -> Option LTy
paramUseTy sigs env p (CIf c t f) =
  if isVarNamed p c then Some LTBool
  else firstSome (paramUseTy sigs env p t) (paramUseTy sigs env p f)
paramUseTy _ _ p (CUnOp "!" x) = if isVarNamed p x then Some LTBool else None
paramUseTy sigs env p (CUnOp _ x) = paramUseTy sigs env p x
-- `::` is NOT a symmetric binop: in `l :: r`, l is the ELEMENT and r is the
-- `List element` — their LTys differ.  So a var on the LEFT of `::` cannot take
-- the right operand's (list) type; doing so mistypes a String accumulator as
-- LTCon (e.g. `acc :: …` in splitLines), routing its OTHER `++` use to
-- mdk_list_append on a String → crash.  Skip the element side; a var on the
-- right of `::` is a list (LTCon).
paramUseTy sigs env p (CBinPrim "::" l r) =
  if isVarNamed p r then Some LTCon
  else firstSome (paramUseTy sigs env p l) (paramUseTy sigs env p r)
paramUseTy sigs env p (CBinPrim _ l r) =
  if isVarNamed p l then Some (typeOf sigs env r)
  else if isVarNamed p r then Some (typeOf sigs env l)
  else firstSome (paramUseTy sigs env p l) (paramUseTy sigs env p r)
paramUseTy sigs env p (CLet _ _ e1 e2) =
  firstSome (paramUseTy sigs env p e1) (paramUseTy sigs env p e2)
paramUseTy sigs env p app =
  let (hd, args) = flattenApp app []
  match hd
    CVar fname _ => if hasArgs args then
        firstSome (argPosTy sigs env p fname args 0) (paramUseArgs sigs env p args)
      else None
    _ => paramUseArgs sigs env p args

-- if `p` is passed as the Nth argument to a known function, its type is that
-- function's Nth parameter type.
argPosTy : List (String, FnSig) -> List (String, LTy) -> String -> String -> List CExpr -> Int -> Option LTy
argPosTy _ _ _ _ [] _ = None
argPosTy sigs env p fname (a::rest) i =
  if isVarNamed p a then nthParamTy sigs fname i
  else argPosTy sigs env p fname rest (i + 1)

-- the type of the Nth parameter of a known function (None if unknown).
nthParamTy : List (String, FnSig) -> String -> Int -> Option LTy
nthParamTy sigs fname i = match lookupAssoc fname sigs
  Some (FnSig ptys _) => nthTy ptys i
  None => None

nthTy : List LTy -> Int -> Option LTy
nthTy [] _ = None
nthTy (t::_) 0 = Some t
nthTy (_::rest) i = nthTy rest (i - 1)

paramUseArgs : List (String, FnSig) -> List (String, LTy) -> String -> List CExpr -> Option LTy
paramUseArgs _ _ _ [] = None
paramUseArgs sigs env p (a::rest) =
  firstSome (paramUseTy sigs env p a) (paramUseArgs sigs env p rest)

isVarNamed : String -> CExpr -> Bool
isVarNamed p (CVar x _) = p == x
isVarNamed _ _ = False

firstSome : Option a -> Option a -> Option a
firstSome (Some x) _ = Some x
firstSome None y = y

-- infer one function's full signature against the current (partial) sig table.
inferOneSig : List (String, FnSig) -> Option (List String, String) -> CBind -> FnSig
inferOneSig sigs dsig (CBind _ [CClause pats body]) =
  let ptys = inferParamTysSeed sigs dsig pats body 0
  let env = zipParamEnv pats ptys
  FnSig ptys (seedRetTy dsig (typeOf sigs env body))
inferOneSig sigs dsig (CBind _ (c::rest)) = inferMultiSig sigs dsig (c::rest)
inferOneSig _ _ _ = FnSig [] LTInt

-- E1: a DECLARED scalar param/return type (from `declSigTypesRef`, sourced from
-- the fn's `DTypeSig`) WINS over the body-use guess.  `seedParamTy` overrides the
-- i-th inferred param type with its declared scalar LTy when one is known (else
-- keeps the guess); `seedRetTy` likewise for the return.  ADDITIVE: an
-- unannotated fn (`dsig = None`) or a non-scalar declared type leaves the guess
-- untouched, so literal-anchored Float fns and Int fns are unchanged.
seedParamTy : Option (List String, String) -> Int -> LTy -> LTy
seedParamTy dsig i guessed = match dsig
  Some (ptyNames, _) => match declScalarAt ptyNames i
    Some t => t
    None => guessed
  None => guessed

seedRetTy : Option (List String, String) -> LTy -> LTy
seedRetTy dsig guessed = match dsig
  Some (_, retName) => match fieldNameToLTy retName
    Some t => t
    None => guessed
  None => guessed

-- the declared scalar LTy at param index `i` of a declared param-type-head list,
-- or None when out of range / not a known scalar.
declScalarAt : List String -> Int -> Option LTy
declScalarAt names i = match nthName names i
  Some n => fieldNameToLTy n
  None => None

-- E1a: signature inference for a MULTI-CLAUSE binding.  A param's type is the
-- first type-revealing finding scanning clauses left-to-right (a literal pattern
-- names it directly; a plain-var pattern is inferred from that clause's body use
-- via `paramUseTy`; a constructor/tuple/wild pattern is an i64 word, left to
-- default Int).  The return type is the first clause's body typed under its
-- param env.  Without this, a multi-clause fn fell to `FnSig [] LTInt`, so its
-- non-Int params (`implParamEnvTyped`) and non-Int result (`fnRetTy` → print
-- selection) were both lost.  (Gap E1: a declared scalar param/return seeds over
-- the guess via `seedParamTy`/`seedRetTy`.)
inferMultiSig : List (String, FnSig) -> Option (List String, String) -> List CClause -> FnSig
inferMultiSig sigs dsig clauses =
  let arity = clauseArityC clauses
  let ptys = inferMultiParamTys sigs dsig clauses arity 0
  FnSig ptys (seedRetTy dsig (inferMultiRetTy sigs clauses ptys))

clauseArityC : List CClause -> Int
clauseArityC ((CClause pats _)::_) = listLen pats
clauseArityC [] = 0

inferMultiParamTys : List (String, FnSig) -> Option (List String, String) -> List CClause -> Int -> Int -> List LTy
inferMultiParamTys sigs dsig clauses arity i
  | i >= arity = []
  | otherwise = seedParamTy dsig i (paramTyAcross sigs clauses i) :: inferMultiParamTys sigs dsig clauses arity (i + 1)

-- the i-th param's type: the first informative finding across clauses, else Int.
paramTyAcross : List (String, FnSig) -> List CClause -> Int -> LTy
paramTyAcross sigs clauses i = match firstInformative sigs clauses i
  Some t => t
  None => LTInt

firstInformative : List (String, FnSig) -> List CClause -> Int -> Option LTy
firstInformative _ [] _ = None
firstInformative sigs ((CClause pats body)::rest) i =
  firstSome (clausePatTy sigs pats body i) (firstInformative sigs rest i)

-- one clause's contribution to the i-th param type: a plain var is inferred from
-- its body use; a literal pattern carries its literal type; a ctor/tuple/wild
-- pattern is uninformative (an i64 word, defaulted to Int by the caller).
clausePatTy : List (String, FnSig) -> List Pat -> CExpr -> Int -> Option LTy
clausePatTy sigs pats body i = match nthPat pats i
  Some (PVar x) => paramUseTy sigs [] x body
  Some (PLit l) => Some (litTy l)
  _ => None

litTy : Lit -> LTy
litTy (LInt _) = LTInt
litTy (LFloat _) = LTFloat
litTy (LBool _) = LTBool
litTy (LString _) = LTStr
litTy (LChar _) = LTChar
litTy LUnit = LTInt

nthPat : List Pat -> Int -> Option Pat
nthPat (p::_) 0 = Some p
nthPat (_::rest) i = nthPat rest (i - 1)
nthPat [] _ = None

-- the multi-clause return type: the first clause's body typed under that clause's
-- (var-pattern → inferred-param-type) env.
inferMultiRetTy : List (String, FnSig) -> List CClause -> List LTy -> LTy
inferMultiRetTy sigs ((CClause pats body)::_) ptys = typeOf sigs (zipParamEnv pats ptys) body
inferMultiRetTy _ [] _ = LTInt

inferParamTys : List (String, FnSig) -> List Pat -> CExpr -> List LTy
inferParamTys _ [] _ = []
inferParamTys sigs ((PVar x)::rest) body =
  let ty = match paramUseTy sigs [] x body
    Some t => t
    None => LTInt
  ty :: inferParamTys sigs rest body
inferParamTys sigs (_::rest) body = LTInt :: inferParamTys sigs rest body

-- like inferParamTys, but a DECLARED scalar type at param index `i` seeds (wins)
-- over the body-use guess (Gap E1: `double x = x + x : Float -> Float` has no
-- Float literal anchor, so the guess is LTInt → int arith on a boxed Float;
-- the declared `Float` overrides to LTFloat).  Index-tracked so each param's
-- declared type lines up by position.
inferParamTysSeed : List (String, FnSig) -> Option (List String, String) -> List Pat -> CExpr -> Int -> List LTy
inferParamTysSeed sigs dsig pats body i = inferParamTysSeedD sigs dsig pats body i i

-- like inferParamTysSeed, but tracks the DECLARED-param index `di` separately from
-- the emit/IR position `i`.  A dict-passing param (`$dict_<fn>_<slot>`, prepended
-- by elaborateModules to a `=>`-constrained fn) advances `i` but NOT `di`, so the
-- declared signature's param types — which DON'T include the synthesized dict
-- params — stay aligned to the source params.  Without this, a `Num a =>` fn's
-- real param sits one slot right of where `declScalarAt`/`isNumPolyParam` look
-- (the G3 root cause: x's LTNum seed was read at the dict's index → missed).
inferParamTysSeedD : List (String, FnSig) -> Option (List String, String) -> List Pat -> CExpr -> Int -> Int -> List LTy
inferParamTysSeedD _ _ [] _ _ _ = []
inferParamTysSeedD sigs dsig ((PVar x)::rest) body i di
  | isDictParamName x = LTInt :: inferParamTysSeedD sigs dsig rest body (i + 1) di
  | otherwise =
    let guessed = match paramUseTy sigs [] x body
      Some t => t
      None => LTInt
    -- G3: a param whose DECLARED type head is a type variable (`a` in
    -- `double : Num a => a -> a`) and which is USED arithmetically is polymorphic
    -- over Num — neither statically Int nor Float.  Seed LTNum so emitArith/emitPrint
    -- route through the runtime tag-dispatched @mdk_num_* helpers.  A concrete
    -- declared scalar (Int/Float/…) still wins via seedParamTy; a type-var param
    -- NOT used in arithmetic (e.g. `id : a -> a`) keeps its guess (no LTNum).
    let seeded = seedParamTy dsig di guessed
    let final = numPolySeed dsig di seeded (paramUsedInArith x body)
    final :: inferParamTysSeedD sigs dsig rest body (i + 1) (di + 1)
inferParamTysSeedD sigs dsig (_::rest) body i di =
  seedParamTy dsig di LTInt :: inferParamTysSeedD sigs dsig rest body (i + 1) (di + 1)

-- a dict-passing parameter synthesized by elaborateModules carries the
-- `$dict_<fn>_<slot>` naming (typecheck.mdk `dictParamName`).
isDictParamName : String -> Bool
isDictParamName n = strHasPrefix "$dict_" n

strHasPrefix : String -> String -> Bool
strHasPrefix pre s
  | stringLength s < stringLength pre = False
  | otherwise = stringSlice 0 (stringLength pre) s == pre

-- G3: override a type-var param's LTInt seed with LTNum when it's used in
-- arithmetic (a polymorphic Num operand); otherwise keep the seed unchanged.
numPolySeed : Option (List String, String) -> Int -> LTy -> Bool -> LTy
numPolySeed dsig i seeded usedArith
  | isNumPolyParam dsig i seeded && usedArith = LTNum
  | otherwise = seeded

-- G3: True when param index `i`'s declared type head is a type VARIABLE (a
-- lowercase-initial name like `a` — concrete cons are uppercase) and the
-- seedParamTy result is still LTInt (i.e. no concrete scalar declared/inferred).
-- This is the "polymorphic Num operand" signal.
isNumPolyParam : Option (List String, String) -> Int -> LTy -> Bool
isNumPolyParam dsig i seeded = match seeded
  LTInt => match dsig
    Some (ptyNames, _) => match nthName ptyNames i
      Some n => isTypeVarName n
      None => False
    None => False
  _ => False

-- a type-variable head name is lowercase-initial (`a`, `elem`); a concrete type
-- (`Int`, `Float`, a user type) is uppercase-initial.  Empty ⇒ not a var.
isTypeVarName : String -> Bool
isTypeVarName n =
  let cs = stringToChars n
  numVarFirst cs

numVarFirst : Array Char -> Bool
numVarFirst cs
  | arrayLength cs == 0 = False
  | otherwise = isLowerCode (charCode (arrayGetUnsafe 0 cs))

isLowerCode : Int -> Bool
isLowerCode c = c >= 97 && c <= 122

-- G3: True when `p` is an operand of an arithmetic binop anywhere in the body.
paramUsedInArith : String -> CExpr -> Bool
paramUsedInArith p (CBinPrim op l r) =
  if isArithOp op && (isVarNamed p l || isVarNamed p r) then True
  else paramUsedInArith p l || paramUsedInArith p r
paramUsedInArith p (CIf c t f) =
  paramUsedInArith p c || paramUsedInArith p t || paramUsedInArith p f
paramUsedInArith p (CUnOp _ x) = paramUsedInArith p x
paramUsedInArith p (CLet _ _ e1 e2) = paramUsedInArith p e1 || paramUsedInArith p e2
paramUsedInArith p app =
  let (_, args) = flattenApp app []
  anyArithArg p args
paramUsedInArith _ _ = False

anyArithArg : String -> List CExpr -> Bool
anyArithArg _ [] = False
anyArithArg p (a::rest) = paramUsedInArith p a || anyArithArg p rest



zipParamEnv : List Pat -> List LTy -> List (String, LTy)
zipParamEnv ((PVar x)::ps) (t::ts) = (x, t) :: zipParamEnv ps ts
zipParamEnv (_::ps) (_::ts) = zipParamEnv ps ts
zipParamEnv _ _ = []

-- one inference pass: recompute every function's signature using the prior table.
-- (Gap E1: each binding's DECLARED signature, looked up by name in the installed
-- `declSigTypesRef` table, seeds its param/return types over the body-use guess.)
inferPass : List (String, FnSig) -> List CBind -> <Mut> List (String, FnSig)
inferPass _ [] = []
inferPass sigs (b::rest) =
  (bindName b, inferOneSig sigs (declSigOf (bindName b)) b) :: inferPass sigs rest

-- fixpoint to two passes: pass 1 seeds signatures (callees defined earlier are
-- already typed); pass 2 lets a caller see a callee defined later / mutual
-- recursion settle.  Two passes suffice for the spike's call graphs (no deeper
-- type-flow chains than caller→callee→sibling exist in the subset).
inferSigs : List CBind -> <Mut> List (String, FnSig)
inferSigs fns =
  let pass1 = inferPass [] fns
  inferPass pass1 fns

-- ── operator -> LLVM mnemonic tables ────────────────────────────────────────
intOp : String -> String
intOp "+" = "add"
intOp "-" = "sub"
intOp "*" = "mul"
intOp "/" = "sdiv"   -- OCaml `/` truncates toward zero; sdiv matches
intOp "%" = "srem"   -- OCaml `mod` sign-of-dividend; srem matches
intOp op = panic ("llvm spike: unsupported int operator " ++ op)

floatOp : String -> String
floatOp "+" = "fadd"
floatOp "-" = "fsub"
floatOp "*" = "fmul"
floatOp "/" = "fdiv"
floatOp "%" = "frem"   -- OCaml Float.rem == C fmod == LLVM frem
floatOp op = panic ("llvm spike: unsupported float operator " ++ op)

-- G3: the runtime tag-dispatched numeric helper for a POLYMORPHIC Num operand
-- (mdk_num_* branch on the low bit: Int → int op, boxed Float → float op).
numOp : String -> String
numOp "+" = "mdk_num_add"
numOp "-" = "mdk_num_sub"
numOp "*" = "mdk_num_mul"
numOp "/" = "mdk_num_div"
numOp "%" = "mdk_num_mod"
numOp op = panic ("llvm spike: unsupported num operator " ++ op)

intPred : String -> String
intPred "==" = "eq"
intPred "!=" = "ne"
intPred "<" = "slt"
intPred ">" = "sgt"
intPred "<=" = "sle"
intPred ">=" = "sge"
intPred op = panic ("llvm spike: unsupported comparison " ++ op)

floatPred : String -> String
floatPred "==" = "oeq"
floatPred "!=" = "one"
floatPred "<" = "olt"
floatPred ">" = "ogt"
floatPred "<=" = "ole"
floatPred ">=" = "oge"
floatPred op = panic ("llvm spike: unsupported comparison " ++ op)

isCmpOp : String -> Bool
isCmpOp op = op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">="

-- ── records, tuples, and mutable refs (slice 5a) ────────────────────────────

emitTuple : Emit -> List (String, (String, LTy)) -> List CExpr -> <Mut> (String, LTy)
emitTuple e env es =
  let words = emitArgs e env es
  emitCtorAlloc e "$tuple" words

emitRecordCreate : Emit -> List (String, (String, LTy)) -> String -> List CField -> <Mut> (String, LTy)
emitRecordCreate e env name fields =
  let words = emitFieldExprs e env fields
  emitCtorAlloc e name words

emitFieldAccess : Emit -> List (String, (String, LTy)) -> CExpr -> String -> <Mut> (String, LTy)
emitFieldAccess e env ex label =
  let (w, _) = emitExpr e env ex
  if label == "value" then
    let f = loadField e w 0
    (f, LTInt)
  else
    let idx = findFieldIdx (recFieldTable e) label
    let f = loadField e w idx
    (f, LTInt)

emitRecordUpdate : Emit -> List (String, (String, LTy)) -> CExpr -> List CField -> <Mut> (String, LTy)
emitRecordUpdate e env base updates =
  let (bw, _) = emitExpr e env base
  let firstLabel = cFieldFirstLabel updates
  match findRecordByLabel (recFieldTable e) firstLabel
    None => gapE ("CRecordUpdate: unknown record type for field '" ++ firstLabel ++ "'")
    Some (name, labels) =>
      let updatePairs = emitUpdatePairs e env updates
      let words = buildUpdateWords e bw labels updatePairs 0
      emitCtorAlloc e name words

emitVariantUpdate : Emit -> List (String, (String, LTy)) -> String -> CExpr -> List CField -> <Mut> (String, LTy)
emitVariantUpdate e env con base updates =
  let (bw, _) = emitExpr e env base
  match lookupAssoc con (recFieldTable e)
    None => gapE ("CVariantUpdate: unknown variant type for constructor '" ++ con ++ "'")
    Some labels =>
      let updatePairs = emitUpdatePairs e env updates
      let words = buildUpdateWords e bw labels updatePairs 0
      emitCtorAlloc e con words

emitRefAlloc : Emit -> List (String, (String, LTy)) -> List CExpr -> <Mut> (String, LTy)
emitRefAlloc e env args = match args
  [x] =>
    let (xw, _) = emitExpr e env x
    emitCtorAlloc e "$ref" [xw]
  _ => gapE "Ref expects exactly 1 argument"

emitSetRef : Emit -> List (String, (String, LTy)) -> List CExpr -> <Mut> (String, LTy)
emitSetRef e env args = match args
  [r, x] =>
    let (rw, _) = emitExpr e env r
    let (xw, _) = emitExpr e env x
    let p = freshReg e
    let _ = emit e ("  " ++ p ++ " = inttoptr i64 " ++ rw ++ " to ptr")
    let fp = freshReg e
    let _ = emit e ("  " ++ fp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 8")
    let _ = emit e ("  store i64 " ++ xw ++ ", ptr " ++ fp)
    ("1", LTInt)
  _ => gapE "set_ref expects exactly 2 arguments"

emitFieldExprs : Emit -> List (String, (String, LTy)) -> List CField -> <Mut> List String
emitFieldExprs _ _ [] = []
emitFieldExprs e env ((CField _ ex)::rest) =
  let (w, _) = emitExpr e env ex
  w :: emitFieldExprs e env rest

emitUpdatePairs : Emit -> List (String, (String, LTy)) -> List CField -> <Mut> List (String, String)
emitUpdatePairs _ _ [] = []
emitUpdatePairs e env ((CField k ex)::rest) =
  let (w, _) = emitExpr e env ex
  (k, w) :: emitUpdatePairs e env rest

buildUpdateWords : Emit -> String -> List String -> List (String, String) -> Int -> <Mut> List String
buildUpdateWords _ _ [] _ _ = []
buildUpdateWords e bw (label::rest) updates i =
  let w = match lookupAssoc label updates
    Some newWord => newWord
    None => loadField e bw i
  w :: buildUpdateWords e bw rest updates (i + 1)

cFieldFirstLabel : List CField -> String
cFieldFirstLabel [] = panic "llvm spike: CRecordUpdate: empty update list"
cFieldFirstLabel ((CField k _)::_) = k

cFieldLabels : List CField -> List String
cFieldLabels [] = []
cFieldLabels ((CField k _)::rest) = k :: cFieldLabels rest

cFieldExprs : List CField -> List CExpr
cFieldExprs [] = []
cFieldExprs ((CField _ ex)::rest) = ex :: cFieldExprs rest

findFieldIdx : List (String, List String) -> String -> Int
findFieldIdx table label = match findRecordByLabel table label
  Some (_, labels) => match indexOfStr label labels
    Some i => i
    None => panic ("llvm spike: field '" ++ label ++ "' not found in record (internal error)")
  None => panic ("llvm spike: CFieldAccess: unknown field '" ++ label ++ "'")

findRecordByLabel : List (String, List String) -> String -> Option (String, List String)
findRecordByLabel [] _ = None
findRecordByLabel ((name, labels)::rest) label =
  if containsStr label labels then Some (name, labels)
  else findRecordByLabel rest label

indexOfStr : String -> List String -> Option Int
indexOfStr _ [] = None
indexOfStr x (y::rest) =
  if x == y then Some 0
  else match indexOfStr x rest
    Some i => Some (i + 1)
    None => None

collectRecords : List CBind -> List (String, List String)
collectRecords [] = []
collectRecords ((CBind _ clauses)::rest) =
  collectRecordsClauses clauses ++ collectRecords rest

collectRecordsClauses : List CClause -> List (String, List String)
collectRecordsClauses [] = []
collectRecordsClauses ((CClause _ body)::rest) =
  scanExprRecords body ++ collectRecordsClauses rest

scanExprRecords : CExpr -> List (String, List String)
scanExprRecords (CRecord name fields) =
  (name, cFieldLabels fields) :: scanExprsRecords (cFieldExprs fields)
scanExprRecords (CFieldAccess ex _) = scanExprRecords ex
scanExprRecords (CRecordUpdate base updates) =
  scanExprRecords base ++ scanExprsRecords (cFieldExprs updates)
scanExprRecords (CVariantUpdate _ base updates) =
  scanExprRecords base ++ scanExprsRecords (cFieldExprs updates)
scanExprRecords (CTuple es) = scanExprsRecords es
scanExprRecords (CApp f a) = scanExprRecords f ++ scanExprRecords a
scanExprRecords (CLam _ body) = scanExprRecords body
scanExprRecords (CIf c t f) =
  scanExprRecords c ++ scanExprRecords t ++ scanExprRecords f
scanExprRecords (CBinPrim _ l r) = scanExprRecords l ++ scanExprRecords r
scanExprRecords (CUnOp _ x) = scanExprRecords x
scanExprRecords (CLet _ _ e1 e2) = scanExprRecords e1 ++ scanExprRecords e2
scanExprRecords (CLetGroup binds body) =
  collectRecords binds ++ scanExprRecords body
scanExprRecords (CBlock stmts) = scanStmtsRecords stmts
scanExprRecords (CDecision scrut arms _) =
  scanExprRecords scrut ++ scanArmsRecords arms
scanExprRecords (CMatch scrut arms) = scanExprRecords scrut ++ scanArmsRecords arms
scanExprRecords (CArray es) = scanExprsRecords es
scanExprRecords (CRangeArray lo hi _) = scanExprRecords lo ++ scanExprRecords hi
scanExprRecords (CRangeList lo hi _) = scanExprRecords lo ++ scanExprRecords hi
scanExprRecords (CIndex a i) = scanExprRecords a ++ scanExprRecords i
scanExprRecords (CSlice a lo hi _) =
  scanExprRecords a ++ scanExprRecords lo ++ scanExprRecords hi
scanExprRecords _ = []

scanExprsRecords : List CExpr -> List (String, List String)
scanExprsRecords [] = []
scanExprsRecords (e::rest) = scanExprRecords e ++ scanExprsRecords rest

scanArmsRecords : List CArm -> List (String, List String)
scanArmsRecords [] = []
scanArmsRecords ((CArm _ _ body)::rest) =
  scanExprRecords body ++ scanArmsRecords rest

scanStmtsRecords : List CStmt -> List (String, List String)
scanStmtsRecords [] = []
scanStmtsRecords ((CSExpr ex)::rest) = scanExprRecords ex ++ scanStmtsRecords rest
scanStmtsRecords ((CSLet _ _ ex)::rest) = scanExprRecords ex ++ scanStmtsRecords rest
scanStmtsRecords ((CSAssign _ ex)::rest) = scanExprRecords ex ++ scanStmtsRecords rest
scanStmtsRecords ((CSLetElse _ ex alt)::rest) = scanExprRecords ex ++ scanExprRecords alt ++ scanStmtsRecords rest
scanStmtsRecords (_::rest) = scanStmtsRecords rest

-- ── arrays + ranges (slice 8) ────────────────────────────────────────────────
-- VALUE REPRESENTATION (RUNTIME-DESIGN.md §8 — see also §2.4a-5 in STAGE2-DESIGN.md):
-- an array is a BOXED heap cell with the same layout as an ADT cell but with the
-- header word = the raw element count (not a constructor hash):
--   [ 0: i64 raw_len | 8: elem0 | 16: elem1 … ]
-- `loadTag` thus reads the raw element count; `loadField e w i` reads element i
-- (at offset 8*(i+1)), exactly the ADT field convention.  Allocation reuses
-- @mdk_alloc; element words are uniform i64 (tagged Ints for range elements).
-- BOUNDS CHECKS: OOB calls @mdk_oob() (noreturn; prints + exits, matching eval's
-- panic).  Fixtures are in-bounds so the check never fires in practice.
-- LOOPS: CRangeArray and CSlice use an alloca-counter loop (the first non-recursion
-- loop in the spike — avoids phi instructions and matches the alloca/store/load
-- pattern the rest of the emitter uses for multi-path merges).
-- SCOPE: CList and CRangeList are covered by slice 9 ("lists" section below).
-- list MATCH (HCons/HNil) works from slice 5b.
-- SPIKE-REP NOTES (slice 8; extending (a)–(p)):
--   (q) ARRAY CELL — header word = raw_len (not hashName), so `loadTag` gives the
--       count directly.  Element i is at offset 8*(i+1), consistent with `loadField`.
--   (r) BOUNDS CHECK — two icmps (idx < 0 || idx >= len) OR'd, br to an @mdk_oob
--       block (call + unreachable); the ok path continues inline.
--   (s) RANGE LOOP — alloca i64 counter + load/store inside the loop; each element
--       = `tagInt(lo_raw + i)`.  CFG: br to cond block → load/icmp/br → body
--       (compute+store+increment) → back to cond; done block receives the br on
--       exit.  No phi nodes (consistent with the rest of the emitter).
--   (t) SLICE LOOP — same alloca-counter pattern; each iteration loads element
--       (lo_raw+i) from the source array via `loadFieldDyn` and stores it to dest
--       field i.

-- allocate an array cell with a STATICALLY known element list; header = raw count.
emitArrayAlloc : Emit -> Int -> List String -> <Mut> (String, LTy)
emitArrayAlloc e n fields =
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = call ptr @mdk_alloc(i64 " ++ intToString (8 * (n + 1)) ++ ")")
  let _ = emit e ("  store i64 " ++ intToString n ++ ", ptr " ++ p)
  let _ = storeFields e p fields 0
  let w = freshReg e
  let _ = emit e ("  " ++ w ++ " = ptrtoint ptr " ++ p ++ " to i64")
  (w, LTCon)

-- allocate an array cell with a DYNAMIC element count (for ranges and slices);
-- returns the raw ptr register (caller fills element fields).
emitArrayDynAlloc : Emit -> String -> <Mut> String
emitArrayDynAlloc e len_raw =
  let sz = freshReg e
  let _ = emit e ("  " ++ sz ++ " = add i64 " ++ len_raw ++ ", 1")
  let bytes = freshReg e
  let _ = emit e ("  " ++ bytes ++ " = mul i64 " ++ sz ++ ", 8")
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = call ptr @mdk_alloc(i64 " ++ bytes ++ ")")
  let _ = emit e ("  store i64 " ++ len_raw ++ ", ptr " ++ p)
  p

-- CArray [e0, e1, …]: allocate a static-size array cell, emit each element,
-- store them as fields, return the cell pointer word.
emitArrayCreate : Emit -> List (String, (String, LTy)) -> List CExpr -> <Mut> (String, LTy)
emitArrayCreate e env es =
  let words = emitArgs e env es
  emitArrayAlloc e (lengthS words) words

-- load a cell field at a DYNAMIC index (offset = (idxRaw+1)*8).  Used for CIndex
-- and the CSlice copy loop.
loadFieldDyn : Emit -> String -> String -> <Mut> String
loadFieldDyn e ptrWord idxRaw =
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = inttoptr i64 " ++ ptrWord ++ " to ptr")
  let off1 = freshReg e
  let _ = emit e ("  " ++ off1 ++ " = add i64 " ++ idxRaw ++ ", 1")
  let off = freshReg e
  let _ = emit e ("  " ++ off ++ " = mul i64 " ++ off1 ++ ", 8")
  let fp = freshReg e
  let _ = emit e ("  " ++ fp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 " ++ off)
  let f = freshReg e
  let _ = emit e ("  " ++ f ++ " = load i64, ptr " ++ fp)
  f

-- store `val` (an i64 word) to element at dynamic index `idxRaw` of a boxed array.
-- mirrors loadFieldDyn verbatim, but ends with a store instead of a load.
storeFieldDyn : Emit -> String -> String -> String -> <Mut> Unit
storeFieldDyn e ptrWord idxRaw val =
  let p = freshReg e
  let _ = emit e ("  " ++ p ++ " = inttoptr i64 " ++ ptrWord ++ " to ptr")
  let off1 = freshReg e
  let _ = emit e ("  " ++ off1 ++ " = add i64 " ++ idxRaw ++ ", 1")
  let off = freshReg e
  let _ = emit e ("  " ++ off ++ " = mul i64 " ++ off1 ++ ", 8")
  let fp = freshReg e
  let _ = emit e ("  " ++ fp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 " ++ off)
  let _ = emit e ("  store i64 " ++ val ++ ", ptr " ++ fp)
  ()

-- CIndex arr i: bounds-check, then load element at dynamic offset.
emitArrayIndex : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> <Mut> (String, LTy)
emitArrayIndex e env a i =
  let (arr_w, _) = emitExpr e env a
  let (idx_w, _) = emitExpr e env i
  let idx_raw = untagInt e idx_w
  let arr_len = loadTag e arr_w
  let c1 = freshReg e
  let _ = emit e ("  " ++ c1 ++ " = icmp slt i64 " ++ idx_raw ++ ", 0")
  let c2 = freshReg e
  let _ = emit e ("  " ++ c2 ++ " = icmp sge i64 " ++ idx_raw ++ ", " ++ arr_len)
  let oob = freshReg e
  let _ = emit e ("  " ++ oob ++ " = or i1 " ++ c1 ++ ", " ++ c2)
  let n = intToString (freshId e)
  let oobL = "oob" ++ n
  let okL = "idx_ok" ++ n
  let _ = emit e ("  br i1 " ++ oob ++ ", label %" ++ oobL ++ ", label %" ++ okL)
  let _ = emit e (oobL ++ ":")
  let _ = emit e "  call void @mdk_oob()"
  let _ = emit e "  unreachable"
  let _ = emit e (okL ++ ":")
  let r = loadFieldDyn e arr_w idx_raw
  (r, LTInt)

-- CRangeArray lo hi incl: compute count, alloc, fill with alloca-counter loop.
emitRangeArray : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> Bool -> <Mut> (String, LTy)
emitRangeArray e env lo hi incl =
  let (lo_w, _) = emitExpr e env lo
  let (hi_w, _) = emitExpr e env hi
  let lo_raw = untagInt e lo_w
  let hi_raw = untagInt e hi_w
  let hi_adj = if incl then
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = add i64 " ++ hi_raw ++ ", 1")
      r
    else hi_raw
  let count = freshReg e
  let _ = emit e ("  " ++ count ++ " = sub i64 " ++ hi_adj ++ ", " ++ lo_raw)
  let p = emitArrayDynAlloc e count
  let n = intToString (freshId e)
  let condL = "rng_cond" ++ n
  let bodyL = "rng_body" ++ n
  let doneL = "rng_done" ++ n
  let ic = freshReg e
  let _ = emit e ("  " ++ ic ++ " = alloca i64")
  let _ = emit e ("  store i64 0, ptr " ++ ic)
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (condL ++ ":")
  let iv = freshReg e
  let _ = emit e ("  " ++ iv ++ " = load i64, ptr " ++ ic)
  let cmp = freshReg e
  let _ = emit e ("  " ++ cmp ++ " = icmp sge i64 " ++ iv ++ ", " ++ count)
  let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ doneL ++ ", label %" ++ bodyL)
  let _ = emit e (bodyL ++ ":")
  let elem_sum = freshReg e
  let _ = emit e ("  " ++ elem_sum ++ " = add i64 " ++ lo_raw ++ ", " ++ iv)
  let elem_w = tagInt e elem_sum
  let off1 = freshReg e
  let _ = emit e ("  " ++ off1 ++ " = add i64 " ++ iv ++ ", 1")
  let off = freshReg e
  let _ = emit e ("  " ++ off ++ " = mul i64 " ++ off1 ++ ", 8")
  let fp = freshReg e
  let _ = emit e ("  " ++ fp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 " ++ off)
  let _ = emit e ("  store i64 " ++ elem_w ++ ", ptr " ++ fp)
  let iv2 = freshReg e
  let _ = emit e ("  " ++ iv2 ++ " = add i64 " ++ iv ++ ", 1")
  let _ = emit e ("  store i64 " ++ iv2 ++ ", ptr " ++ ic)
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (doneL ++ ":")
  let w = freshReg e
  let _ = emit e ("  " ++ w ++ " = ptrtoint ptr " ++ p ++ " to i64")
  (w, LTCon)

-- CSlice arr lo hi incl: compute new_len, alloc, copy elements with loop.
emitArraySlice : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> CExpr -> Bool -> <Mut> (String, LTy)
emitArraySlice e env a lo hi incl =
  let (arr_w, _) = emitExpr e env a
  let (lo_w, _) = emitExpr e env lo
  let (hi_w, _) = emitExpr e env hi
  let lo_raw = untagInt e lo_w
  let hi_raw = untagInt e hi_w
  let end_raw = if incl then
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = add i64 " ++ hi_raw ++ ", 1")
      r
    else hi_raw
  let new_len = freshReg e
  let _ = emit e ("  " ++ new_len ++ " = sub i64 " ++ end_raw ++ ", " ++ lo_raw)
  let p = emitArrayDynAlloc e new_len
  let n = intToString (freshId e)
  let condL = "sl_cond" ++ n
  let bodyL = "sl_body" ++ n
  let doneL = "sl_done" ++ n
  let ic = freshReg e
  let _ = emit e ("  " ++ ic ++ " = alloca i64")
  let _ = emit e ("  store i64 0, ptr " ++ ic)
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (condL ++ ":")
  let iv = freshReg e
  let _ = emit e ("  " ++ iv ++ " = load i64, ptr " ++ ic)
  let cmp = freshReg e
  let _ = emit e ("  " ++ cmp ++ " = icmp sge i64 " ++ iv ++ ", " ++ new_len)
  let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ doneL ++ ", label %" ++ bodyL)
  let _ = emit e (bodyL ++ ":")
  let src_idx = freshReg e
  let _ = emit e ("  " ++ src_idx ++ " = add i64 " ++ lo_raw ++ ", " ++ iv)
  let elem = loadFieldDyn e arr_w src_idx
  let dst_off1 = freshReg e
  let _ = emit e ("  " ++ dst_off1 ++ " = add i64 " ++ iv ++ ", 1")
  let dst_off = freshReg e
  let _ = emit e ("  " ++ dst_off ++ " = mul i64 " ++ dst_off1 ++ ", 8")
  let dst_fp = freshReg e
  let _ = emit e ("  " ++ dst_fp ++ " = getelementptr i8, ptr " ++ p ++ ", i64 " ++ dst_off)
  let _ = emit e ("  store i64 " ++ elem ++ ", ptr " ++ dst_fp)
  let iv2 = freshReg e
  let _ = emit e ("  " ++ iv2 ++ " = add i64 " ++ iv ++ ", 1")
  let _ = emit e ("  store i64 " ++ iv2 ++ ", ptr " ++ ic)
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (doneL ++ ":")
  let w = freshReg e
  let _ = emit e ("  " ++ w ++ " = ptrtoint ptr " ++ p ++ " to i64")
  (w, LTCon)

-- arrayMakeWith n f: INLINE INTRINSIC.  Allocates a dynamic array of `n` elements;
-- fills element i by calling the Medaka closure `f` with the tagged index `i`.
-- Shape mirrors emitRangeArray (alloca-counter loop) + emitIndirect (closure call).
-- No C extern; the closure is called directly from the emitted loop body.
emitArrayMakeWith : Emit -> List (String, (String, LTy)) -> List CExpr -> <Mut> (String, LTy)
emitArrayMakeWith e env args = match args
  [nExpr, fExpr] =>
    let (n_w, _) = emitExpr e env nExpr
    let (fw, _) = emitExpr e env fExpr
    let count = untagInt e n_w
    let p = emitArrayDynAlloc e count
    let n = intToString (freshId e)
    let condL = "mw_cond" ++ n
    let bodyL = "mw_body" ++ n
    let doneL = "mw_done" ++ n
    let ic = freshReg e
    let _ = emit e ("  " ++ ic ++ " = alloca i64")
    let _ = emit e ("  store i64 0, ptr " ++ ic)
    let _ = emit e ("  br label %" ++ condL)
    let _ = emit e (condL ++ ":")
    let iv = freshReg e
    let _ = emit e ("  " ++ iv ++ " = load i64, ptr " ++ ic)
    let cmp = freshReg e
    let _ = emit e ("  " ++ cmp ++ " = icmp sge i64 " ++ iv ++ ", " ++ count)
    let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ doneL ++ ", label %" ++ bodyL)
    let _ = emit e (bodyL ++ ":")
    let ti = tagInt e iv
    let cp = loadField e fw 0
    let fp = freshReg e
    let _ = emit e ("  " ++ fp ++ " = inttoptr i64 " ++ cp ++ " to ptr")
    let elem = freshReg e
    let _ = emit e ("  " ++ elem ++ " = call i64 " ++ fp ++ "(i64 " ++ fw ++ ", i64 " ++ ti ++ ")")
    let off1 = freshReg e
    let _ = emit e ("  " ++ off1 ++ " = add i64 " ++ iv ++ ", 1")
    let off = freshReg e
    let _ = emit e ("  " ++ off ++ " = mul i64 " ++ off1 ++ ", 8")
    let ep = freshReg e
    let _ = emit e ("  " ++ ep ++ " = getelementptr i8, ptr " ++ p ++ ", i64 " ++ off)
    let _ = emit e ("  store i64 " ++ elem ++ ", ptr " ++ ep)
    let iv2 = freshReg e
    let _ = emit e ("  " ++ iv2 ++ " = add i64 " ++ iv ++ ", 1")
    let _ = emit e ("  store i64 " ++ iv2 ++ ", ptr " ++ ic)
    let _ = emit e ("  br label %" ++ condL)
    let _ = emit e (doneL ++ ":")
    let w = freshReg e
    let _ = emit e ("  " ++ w ++ " = ptrtoint ptr " ++ p ++ " to i64")
    (w, LTCon)
  _ => gapE "arrayMakeWith takes two arguments"

-- ── lists (slice 9) ─────────────────────────────────────────────────────────
-- VALUE REPRESENTATION: a list is a chain of boxed Cons cells (matching the
-- slice-5b match heads HCons/HNil, which test `cellTag` of "Cons"/"Nil").
-- The built-in list is not user-declared, so "Cons"/"Nil" are absent from the
-- ctor→type table and `cellTag` gives them the reserved list-type id with ordinals
-- 0 (Cons) and 1 (Nil) — UNLESS a user `data` owns those names, in which case both
-- the list literal and the user ctor resolve to that type's ordinal (they alias,
-- exactly as they did under the old hash).  Cell layouts (8-byte words):
--   Nil  → odd immediate (nullary; low bit 1)                  (no cell allocated)
--   Cons → [ i64 cellTag "Cons" | i64 head | i64 tail ]   (3-word cell)
-- Construction uses emitCtorAlloc "Nil" [] / emitCtorAlloc "Cons" [hw, tw]
-- verbatim — the SAME tag the slice-5b switch tests, so construction
-- and match agree by construction.
--
-- SPIKE-REP NOTES (slice 9; extending (a)–(t)):
--   (u) CList [e0…en] is RIGHT-FOLDED INLINE (compile-time unroll): N+1 allocs
--       emitted as a straight-line sequence from tail to head.  No loop, no
--       stack growth — the list size is statically known.  Consistent with
--       emitTuple (which also unrolls inline for a static arity).
--   (v) CRangeList lo hi incl uses an ALLOCA-COUNTER LOOP (back-to-front):
--       initialise tail=Nil, i=count-1; while i≥0 prepend Cons(lo+i, tail) and
--       decrement i.  Back-to-front builds the list in ascending order (lo…hi)
--       without reversing.  An alloca i64 `acc` holds the current list head word
--       (a cell pointer as i64), so the same alloca/store/load discipline the
--       rest of the emitter uses for multi-path merges.  An empty range (count≤0)
--       returns Nil immediately (i=count-1 < 0 on first test).  This approach
--       matches the slice-8 loop pattern and avoids stack overflow on large ranges.

-- CList [e0, e1, …, en]: right-fold to Cons cells, innermost first.
emitList : Emit -> List (String, (String, LTy)) -> List CExpr -> <Mut> (String, LTy)
emitList e _ [] = emitCtorAlloc e "Nil" []
emitList e env (x::xs) =
  let (xw, _) = emitExpr e env x
  let (tw, _) = emitList e env xs
  emitCtorAlloc e "Cons" [xw, tw]

-- CRangeList lo hi incl: build an ascending list [lo…hi] (or [lo…<hi]) via a
-- back-to-front alloca-counter loop.  An alloca i64 `acc` holds the current
-- head pointer; a second alloca i64 `ic` holds the loop counter (count-1 downto 0).
emitRangeList : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> Bool -> <Mut> (String, LTy)
emitRangeList e env lo hi incl =
  let (lo_w, _) = emitExpr e env lo
  let (hi_w, _) = emitExpr e env hi
  let lo_raw = untagInt e lo_w
  let hi_raw = untagInt e hi_w
  let hi_adj = if incl then
      let r = freshReg e
      let _ = emit e ("  " ++ r ++ " = add i64 " ++ hi_raw ++ ", 1")
      r
    else hi_raw
  let count = freshReg e
  let _ = emit e ("  " ++ count ++ " = sub i64 " ++ hi_adj ++ ", " ++ lo_raw)
  -- Seed the accumulator with Nil.
  let (nil_w, _) = emitCtorAlloc e "Nil" []
  let acc = freshReg e
  let _ = emit e ("  " ++ acc ++ " = alloca i64")
  let _ = emit e ("  store i64 " ++ nil_w ++ ", ptr " ++ acc)
  -- Counter starts at count-1 (back-to-front).
  let ic = freshReg e
  let _ = emit e ("  " ++ ic ++ " = alloca i64")
  let im1 = freshReg e
  let _ = emit e ("  " ++ im1 ++ " = sub i64 " ++ count ++ ", 1")
  let _ = emit e ("  store i64 " ++ im1 ++ ", ptr " ++ ic)
  let n = intToString (freshId e)
  let condL = "rl_cond" ++ n
  let bodyL = "rl_body" ++ n
  let doneL = "rl_done" ++ n
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (condL ++ ":")
  let iv = freshReg e
  let _ = emit e ("  " ++ iv ++ " = load i64, ptr " ++ ic)
  let cmp = freshReg e
  let _ = emit e ("  " ++ cmp ++ " = icmp slt i64 " ++ iv ++ ", 0")
  let _ = emit e ("  br i1 " ++ cmp ++ ", label %" ++ doneL ++ ", label %" ++ bodyL)
  let _ = emit e (bodyL ++ ":")
  let elem_raw = freshReg e
  let _ = emit e ("  " ++ elem_raw ++ " = add i64 " ++ lo_raw ++ ", " ++ iv)
  let elem_w = tagInt e elem_raw
  let tail_w = freshReg e
  let _ = emit e ("  " ++ tail_w ++ " = load i64, ptr " ++ acc)
  let (cons_w, _) = emitCtorAlloc e "Cons" [elem_w, tail_w]
  let _ = emit e ("  store i64 " ++ cons_w ++ ", ptr " ++ acc)
  let iv2 = freshReg e
  let _ = emit e ("  " ++ iv2 ++ " = sub i64 " ++ iv ++ ", 1")
  let _ = emit e ("  store i64 " ++ iv2 ++ ", ptr " ++ ic)
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (doneL ++ ":")
  let r = freshReg e
  let _ = emit e ("  " ++ r ++ " = load i64, ptr " ++ acc)
  (r, LTCon)

-- ── program ─────────────────────────────────────────────────────────────────
-- Emit a whole CProgram as a textual LLVM module: the runtime declares, then one
-- LLVM function per top-level `name p… = …` binding (slice 2), then a single
-- `@main` that computes the top-level nullary value bindings (in source order),
-- then `main`'s body, then a type-directed print.
export
emitProgram : CProgram -> <Mut> String
emitProgram (CProgram groups ctorArs ctorTypes implEntries) =
  let e = Emit (Ref 0) (Ref []) (Ref (collectFns groups)) (Ref (inferSigs (fnBinds groups))) (Ref ctorArs) (Ref []) (Ref (collectRecords groups)) (Ref implEntries) (Ref ctorTypes) (Ref (initGlobalsReg (valBinds groups)))
  let _ = resetDistinctTypeNames ()
  let _ = installKnownFnMap (collectFns groups)
  let _ = installCtorMap ctorArs
  let _ = installSigMap (sigTable e)
  let _ = resetEmittedDefaults ()
  let _ = emitPreamble e
  -- declare a module global per top-level value/`Ref` binding (slice E1b).
  let _ = emitGlobalDecls e (valBinds groups)
  -- emit `@main` FIRST: its init prologue computes each value-binding rhs in
  -- SOURCE ORDER and marks the registry, so the globals' LTys are resolved before
  -- the function `define`s (emitted next) reference them.  LLVM module-item order
  -- is irrelevant, so emitting `@main` ahead of the fn/impl defines is sound.
  let _ = emit e "define i32 @main(i32 %argc, ptr %argv) {"
  let _ = emit e "entry:"
  let _ = emit e "  call void @mdk_set_args(i32 %argc, ptr %argv)"
  let _ = emitTopGlobals e (orderedValBinds (valBinds groups))
  let (mv, mty) = emitExpr e [] (mainBody groups)
  let _ = emitPrint e mv mty
  let _ = emit e "  ret i32 0"
  let _ = emit e "}"
  -- the function + impl defines (registry now fully initialised, so any body may
  -- reference any global via a `load i64, ptr @mdk_g_<name>`).
  let _ = emitFns e (fnBinds groups)
  let _ = emitImpls e implEntries
  -- the module body (preamble, @main, fn/impl defines) in forward order, then the
  -- side buffer (string-literal + value-binding globals, lifted-lambda defines).
  -- LLVM module-item order is irrelevant, so appending the side buffer is sound.
  match e
    Emit _ buf _ _ _ lams _ _ _ _ => joinNl (reverseL buf.value ++ reverseL lams.value)

emitPreamble : Emit -> <Mut> Unit
emitPreamble e =
  let _ = emit e "; Medaka native spike (Stage 2.4) — emitted textual LLVM IR."
  let _ = emit e "; Value rep is PROVISIONAL (uniform 64-bit tagged word); see RUNTIME-DESIGN.md."
  let _ = emit e "declare ptr @mdk_alloc(i64)"
  let _ = emit e "declare void @mdk_oob() noreturn"
  let _ = emit e "declare void @mdk_print_int(i64)"
  let _ = emit e "declare void @mdk_print_bool(i64)"
  let _ = emit e "declare void @mdk_print_float(double)"
  let _ = emit e "declare i64 @mdk_num_add(i64, i64)"
  let _ = emit e "declare i64 @mdk_num_sub(i64, i64)"
  let _ = emit e "declare i64 @mdk_num_mul(i64, i64)"
  let _ = emit e "declare i64 @mdk_num_div(i64, i64)"
  let _ = emit e "declare i64 @mdk_num_mod(i64, i64)"
  let _ = emit e "declare void @mdk_print_num(i64)"
  let _ = emit e "declare i64 @mdk_str_lit(ptr, i64)"
  let _ = emit e "declare void @mdk_print_str(i64)"
  let _ = emit e "declare i64 @mdk_int_to_string(i64)"
  let _ = emit e "declare i64 @mdk_float_to_string(double)"
  let _ = emit e "declare i64 @mdk_string_concat(i64)"
  let _ = emit e "declare i64 @mdk_string_append(i64, i64)"
  let _ = emit e "declare i64 @mdk_string_eq(i64, i64)"
  let _ = emit e "declare i64 @mdk_value_eq(i64, i64)"
  let _ = emit e "declare i64 @mdk_list_append(i64, i64)"
  let _ = emit e "declare i64 @mdk_append(i64, i64)"
  let _ = emit e "declare void @mdk_putstr(i64)"
  let _ = emit e "declare void @mdk_putstrln(i64)"
  let _ = emit e "declare void @mdk_eputstr(i64)"
  let _ = emit e "declare void @mdk_eputstrln(i64)"
  let _ = emit e "declare void @mdk_flushstdout(i64)"
  let _ = emit e "declare void @mdk_print_unit()"
  let _ = emit e "declare void @mdk_panic(i64)"
  let _ = emit e "declare void @mdk_exit(i64)"
  let _ = emit e "declare i64 @mdk_array_make(i64, i64)"
  let _ = emit e "declare i64 @mdk_array_copy(i64)"
  let _ = emit e "declare void @mdk_array_blit(i64, i64, i64, i64, i64)"
  let _ = emit e "declare void @mdk_array_fill(i64, i64)"
  let _ = emit e "declare i64 @mdk_array_from_list(i64)"
  let _ = emit e "declare void @mdk_print_char(i64)"
  let _ = emit e "declare i64 @mdk_char_to_str(i64)"
  let _ = emit e "declare i64 @mdk_string_to_chars(i64)"
  let _ = emit e "declare i64 @mdk_string_from_chars(i64)"
  let _ = emit e "declare i64 @mdk_string_slice(i64, i64, i64)"
  let _ = emit e "declare i64 @mdk_char_is_alpha(i64)"
  let _ = emit e "declare i64 @mdk_char_is_space(i64)"
  let _ = emit e "declare i64 @mdk_char_is_upper(i64)"
  let _ = emit e "declare i64 @mdk_char_is_lower(i64)"
  let _ = emit e "declare i64 @mdk_char_is_punct(i64)"
  let _ = emit e "declare i64 @mdk_char_to_upper(i64)"
  let _ = emit e "declare i64 @mdk_char_to_lower(i64)"
  let _ = emit e "declare i64 @mdk_string_to_upper(i64)"
  let _ = emit e "declare i64 @mdk_string_to_lower(i64)"
  let _ = emit e "declare i64 @mdk_char_from_code(i64)"
  let _ = emit e "declare i64 @mdk_string_to_float(i64)"
  let _ = emit e "declare i64 @mdk_string_index_of(i64, i64)"
  let _ = emit e "declare i64 @mdk_string_compare(i64, i64)"
  let _ = emit e "declare i64 @mdk_string_compare_raw(i64, i64)"
  let _ = emit e "declare void @mdk_set_args(i32, ptr)"
  let _ = emit e "declare i64 @mdk_args(i64)"
  let _ = emit e "declare i64 @mdk_get_env(i64)"
  let _ = emit e "declare i64 @mdk_read_file(i64)"
  let _ = emit e "declare i64 @mdk_write_file(i64, i64)"
  let _ = emit e "declare i64 @mdk_append_file(i64, i64)"
  let _ = emit e "declare i64 @mdk_file_exists(i64)"
  let _ = emit e "declare i64 @mdk_list_dir(i64)"
  let _ = emit e "declare i64 @mdk_read_line(i64)"
  let _ = emit e "declare i64 @mdk_read_line_opt(i64)"
  let _ = emit e "declare i64 @mdk_read_all(i64)"
  let _ = emit e "declare i64 @mdk_read_exactly(i64)"
  let _ = emit e "declare i64 @mdk_make_dir(i64)"
  let _ = emit e "declare i64 @mdk_run_command(i64, i64)"
  let _ = emit e "declare void @mdk_set_seed(i64)"
  let _ = emit e "declare i64 @mdk_random_int(i64, i64)"
  let _ = emit e "declare i64 @mdk_random_bool(i64)"
  let _ = emit e "declare i64 @mdk_random_float(i64)"
  let _ = emit e "declare i64 @mdk_random_char(i64)"
  let _ = emit e "declare i64 @mdk_hash_int(i64)"
  let _ = emit e "declare i64 @mdk_hash_char(i64)"
  let _ = emit e "declare i64 @mdk_hash_bool(i64)"
  let _ = emit e "declare i64 @mdk_hash_float(double)"
  let _ = emit e "declare i64 @mdk_hash_string(i64)"
  let _ = emit e "declare i64 @mdk_debug_string_lit(i64)"
  let _ = emit e "declare i64 @mdk_debug_char_lit(i64)"
  emit e ""

-- the `@main` init prologue (slice E1b): compute each top-level value/`Ref`
-- binding's rhs in SOURCE ORDER and `store` the word into its module global
-- `@mdk_g_<name>`, then mark the registry entry initialised with the rhs's LTy.
-- Computing in source order means a binding referencing an EARLIER one loads the
-- already-stored global; a reference to a LATER (not-yet-marked) global hits the
-- forward/mutual-dependency gap in lookupVarG instead of an uninitialised 0.
-- A `Ref v` rhs allocs its cell as usual → the stored word is the cell POINTER, so
-- `.value`/`set_ref` deref through the loaded global.
emitTopGlobals : Emit -> List CBind -> <Mut> Unit
emitTopGlobals _ [] = ()
emitTopGlobals e ((CBind name [CClause [] body])::rest) =
  let (v, ty) = emitExpr e [] body
  let _ = emit e ("  store i64 " ++ v ++ ", ptr @mdk_g_" ++ name)
  let _ = markGlobalInit e name ty
  emitTopGlobals e rest
emitTopGlobals _ ((CBind name _)::_) =
  panic ("llvm spike: top-level function '" ++ name ++ "' unsupported in slice 1 (value bindings only)")

emitPrint : Emit -> String -> LTy -> <Mut> Unit
emitPrint e v LTInt =
  let i = untagInt e v
  emit e ("  call void @mdk_print_int(i64 " ++ i ++ ")")
emitPrint e v LTBool =
  let i = untagInt e v
  emit e ("  call void @mdk_print_bool(i64 " ++ i ++ ")")
emitPrint e v LTFloat =
  let d = unboxFloat e v
  emit e ("  call void @mdk_print_float(double " ++ d ++ ")")
emitPrint e v LTStr =
  emit e ("  call void @mdk_print_str(i64 " ++ v ++ ")")
-- LTUnknown reaches print only for the dominant String-builder case (a chained
-- `++` whose value is a String); print it as a String, matching the old LTStr
-- default.  A list-valued LTUnknown is never printed by the bootstrap fixtures.
emitPrint e v LTUnknown =
  emit e ("  call void @mdk_print_str(i64 " ++ v ++ ")")
emitPrint e _ LTUnit =
  emit e "  call void @mdk_print_unit()"
emitPrint e v LTChar =
  emit e ("  call void @mdk_print_char(i64 " ++ v ++ ")")
-- G3: a polymorphic Num result (LTNum) is an Int OR boxed-Float word; dispatch
-- the print on its runtime tag via @mdk_print_num (mirrors the @mdk_num_* arith).
emitPrint e v LTNum =
  emit e ("  call void @mdk_print_num(i64 " ++ v ++ ")")
emitPrint _ _ LTCon =
  panic "llvm spike: cannot print an ADT value (slice 3: `main` must reduce to a scalar Int/Bool/Float)"
emitPrint _ _ LTClosure =
  panic "llvm spike: cannot print a closure value (slice 4: `main` must reduce to a scalar Int/Bool/Float)"

-- the body of the `main` binding (must be a nullary clause).
mainBody : List CBind -> CExpr
mainBody [] = panic "llvm spike: no `main` binding"
mainBody ((CBind "main" [CClause [] body])::_) = body
mainBody ((CBind "main" _)::_) = panic "llvm spike: `main` must be a nullary value (main = ...)"
mainBody (_::rest) = mainBody rest

-- a readable tag for the unsupported-node panic (only the nodes a slice-1
-- fixture could hit if it strayed out of scope).
ctag : CExpr -> String
ctag (CApp _ _) = "CApp (function application)"
ctag (CLam _ _) = "CLam (lambda)"
ctag (CMatch _ _) = "CMatch"
ctag (CDecision _ _ _) = "CDecision (match)"
ctag (CTuple _) = "CTuple"
ctag (CList _) = "CList"
ctag (CArray _) = "CArray"
ctag (CRecord _ _) = "CRecord"
ctag (CFieldAccess _ _) = "CFieldAccess"
ctag (CRecordUpdate _ _) = "CRecordUpdate"
ctag (CRangeList _ _ _) = "CRangeList"
ctag (CRangeArray _ _ _) = "CRangeArray"
ctag (CIndex _ _) = "CIndex"
ctag (CSlice _ _ _ _) = "CSlice"
ctag (CMethod _ _ _ _) = "CMethod (typeclass dispatch)"
ctag (CDict _ _) = "CDict (dictionary)"
ctag (CVariantUpdate _ _ _) = "CVariantUpdate (named-field variant update)"
ctag _ = "?"

-- ── D4 emitter-completeness inventory entry point ───────────────────────────
-- Mirrors emitProgram's setup but turns gap-recording ON, attributes each gap to
-- the top-level binding / impl group being emitted, and SKIPS the `@main` path (a
-- real prelude/compiler module carries no `main`).  Emits every fn-bind, value
-- bind, and impl group; returns the recorded gap events ("<binding>\t<reason>").
-- The emitted LLVM text is discarded by the probe — only the gap log matters.
export
emitProgramGaps : CProgram -> <Mut> List String
emitProgramGaps (CProgram groups ctorArs ctorTypes implEntries) =
  let e = Emit (Ref 0) (Ref []) (Ref (collectFns groups)) (Ref (inferSigs (fnBinds groups))) (Ref ctorArs) (Ref []) (Ref (collectRecords groups)) (Ref implEntries) (Ref ctorTypes) (Ref (initGlobalsRegReady (valBinds groups)))
  let _ = resetDistinctTypeNames ()
  let _ = installKnownFnMap (collectFns groups)
  let _ = installCtorMap ctorArs
  let _ = installSigMap (sigTable e)
  let _ = resetGaps ()
  let _ = enableGapRecord ()
  let _ = emitPreamble e
  let _ = emitFnsGaps e (fnBinds groups)
  let _ = emitImplsGaps e implEntries
  let _ = emitTopBindsGaps e [] (valBinds groups)
  gapEvents ()

emitFnsGaps : Emit -> List CBind -> <Mut> Unit
emitFnsGaps _ [] = ()
emitFnsGaps e ((CBind name cs)::rest) =
  let _ = setGapBind ("fn " ++ name)
  let _ = emitFn e (CBind name cs)
  emitFnsGaps e rest

emitImplsGaps : Emit -> List CImplEntry -> <Mut> Unit
emitImplsGaps e entries = emitGroupsGaps e (groupImpls entries)

emitGroupsGaps : Emit -> List ImplGroup -> <Mut> Unit
emitGroupsGaps _ [] = ()
emitGroupsGaps e (g::rest) =
  let _ = setGapBind ("impl " ++ groupMethodOf g ++ "@" ++ groupTag g)
  let _ = emitGroup e g
  emitGroupsGaps e rest

emitTopBindsGaps : Emit -> List (String, (String, LTy)) -> List CBind -> <Mut> Unit
emitTopBindsGaps _ _ [] = ()
emitTopBindsGaps e env ((CBind name [CClause [] body])::rest) =
  let _ = setGapBind ("val " ++ name)
  let (v, ty) = emitExpr e env body
  emitTopBindsGaps e ((name, (v, ty)) :: env) rest
emitTopBindsGaps e env ((CBind name _)::rest) =
  let _ = setGapBind ("val " ++ name)
  let _ = gapU "non-nullary / multi-clause value binding (slice 1)"
  emitTopBindsGaps e env rest
