+-- ── (b′) dispatch-into-single-target TMC emit ───────────────────────────────
+-- The LLVM port of the WASM (b′) dispatch-group emit (WASMGC-TRMC-DESIGN.md §11).
+-- Mirrors the existing self-recursive TRMC machinery (emitTrmcCtor / dest-passing)
+-- but, because LLVM cannot `br` across a define boundary the way the WASM globals +
+-- `return_call` cross-function loop does, the loop is the `musttail call` cycle
+-- through the group functions (the proven cross-fn-musttail analogue of return_call
+-- — same as the float wrapper→worker split), and the destination state lives in 3
+-- module globals.  A group MEMBER emits via the NORMAL clause machinery (emitFnBody
+-- / emitClauseTree) with wDispCtxRef live, so its SPINE-cons / root-call / base
+-- leaves are redirected (emitWDispLeaf).  The root additionally gets a reset
+-- wrapper.  EVERYTHING outside a detected group keeps its current codegen.
+
+-- the 3 dest globals (into the side buffer, like @mdk_g_* — module item order is
+-- irrelevant).  @g_tmc_head = i64 (the accumulating list head, 0 = the seed Nil),
+-- @g_tmc_dest = ptr (address of the next tail word to fill), @g_tmc_first = i64
+-- (1 until the first cell is built — then the head IS the first cell).
+emitWDispGlobalDecls : Emit -> <Mut> Unit
+emitWDispGlobalDecls e =
+  let _ = emitGlobal e "@g_tmc_head = global i64 0"
+  let _ = emitGlobal e "@g_tmc_dest = global ptr null"
+  emitGlobal e "@g_tmc_first = global i64 1"
+
+-- emit a group MEMBER.  Two defines per member (see the WDispCtx comment): a PUBLIC
+-- `@mdk_<m>(real arity)` for external callers (plain `call` into the inner symbol,
+-- ABI-preserving) and an INNER `@mdk_<m>__disp(uniform arity U)` carrying the real
+-- body with leaves redirected.  The ROOT's public define additionally RESETS the 3
+-- dest globals first (a fresh spine per external entry).
+emitWDispMember : Emit -> DispGroup -> String -> List (List Pat, CExpr) -> <Mut> Unit
+emitWDispMember e grp name clauses =
+  let root = dispGroupRoot grp
+  let arity = clauseArity clauses
+  let u = dispGroupUniformArity (n => fnArity e n) grp
+  let isRoot = dispIsRoot grp name
+  let _ = emitWDispPublic e name arity u isRoot
+  emitWDispInner e root name arity u clauses
+
+-- the public define `@mdk_<m>(real arity)`: (root only) reset the dest globals, then
+-- a PLAIN `call @mdk_<m>__disp(real args padded to U)` + ret.  Plain (not musttail)
+-- is fine — an external entry runs ONCE per top-level spine, not per element, so it
+-- adds a single frame, not O(n).  It also sidesteps musttail's arity-match rule at
+-- the real-arity boundary (the hot cycle stays inside the uniform-arity inner ring).
+emitWDispPublic : Emit -> String -> Int -> Int -> Bool -> <Mut> Unit
+emitWDispPublic e name arity u isRoot =
+  let _ = emit e ("define i64 @mdk_" ++ name ++ "(" ++ implParamDecls arity 0 ++ ") {")
+  let _ = emit e "entry:"
+  let _ = if isRoot then
+      let _ = emit e "  store i64 1, ptr @g_tmc_first"
+      let _ = emit e "  store i64 0, ptr @g_tmc_head"
+      emit e "  store ptr null, ptr @g_tmc_dest"
+    else ()
+  let r = freshReg e
+  let _ = emit e ("  " ++ r ++ " = call i64 @" ++ wDispInner name ++ "(" ++ paddedArgDecls (forwardArgList arity 0) u ++ ")")
+  let _ = emit e ("  ret i64 " ++ r)
+  let _ = emit e "}"
+  emit e ""
+
+-- forward the `%argK` words as an operand LIST (for padding to U).
+forwardArgList : Int -> Int -> List String
+forwardArgList n i
+  | i >= n = []
+  | otherwise = ("%arg" ++ intToString i) :: forwardArgList n (i + 1)
+
+-- render `ops` as an `i64 op, …` decl list PADDED with `i64 0` up to length `u`.
+paddedArgDecls : List String -> Int -> String
+paddedArgDecls ops u = argDecls (padOpsZero ops u)
+
+-- pad an operand list with the word `0` up to length `u` (the unused uniform slots).
+padOpsZero : List String -> Int -> List String
+padOpsZero ops u =
+  let need = u - listLen ops
+  if need <= 0 then ops else ops ++ zeroOps need
+
+zeroOps : Int -> List String
+zeroOps n
+  | n <= 0 = []
+  | otherwise = "0" :: zeroOps (n - 1)
+
+-- emit the inner define `@mdk_<m>__disp(U params)` with the dispatch context LIVE,
+-- reusing the ordinary clause machinery (emitFnBody / emitClauseTree) — its leaves
+-- are redirected through wDispCtxRef (emitFnBody / emitLeaf / emitGuardedArm).  The
+-- body binds only the first `arity` of the U params; the rest are unused padding.
+emitWDispInner : Emit -> String -> String -> Int -> Int -> List (List Pat, CExpr) -> <Mut> Unit
+emitWDispInner e root name arity u clauses =
+  let rootArity = fnArity e root
+  let ptys = match lookupAssoc name (sigTable e)
+    Some (FnSig ts _) => ts
+    None => []
+  let saved = wDispCtxRef.value
+  let _ = set_ref wDispCtxRef (WDispOn root rootArity u)
+  let _ = emit e ("define i64 @" ++ wDispInner name ++ "(" ++ implParamDecls u 0 ++ ") {")
+  let _ = emit e "entry:"
+  let _ = match clauses
+    [(pats, body)] => if allPVar pats then
+        emitFnBody e (paramEnv pats (padTys ptys (listLen pats)) 0) name body
+      else emitClauseTree e (implParamEnvTyped arity ptys 0) arity clauses
+    _ => emitClauseTree e (implParamEnvTyped arity ptys 0) arity clauses
+  let _ = emit e "}"
+  let _ = emit e ""
+  set_ref wDispCtxRef saved
+
+-- pad/truncate an inferred sig type list to length n (LTInt fill), so paramEnv gets
+-- one LTy per param even when the sig is short/absent.
+padTys : List LTy -> Int -> List LTy
+padTys _ n
+  | n <= 0 = []
+padTys (t::rest) n = t :: padTys rest (n - 1)
+padTys [] n = LTInt :: padTys [] (n - 1)
+
+-- ── leaf redirect (called from the 3 leaf-emit sites when wDispCtxRef is live) ─
+-- redirect a TAIL leaf under an active (b′) dispatch context.  Every HOT edge is a
+-- `musttail call @mdk_<m>__disp(real args padded to U) ; ret` into the uniform-arity
+-- inner ring (so the musttail prototype matches):
+--   • spine cons `<head> :: root <sat>` → build cell, link into *@g_tmc_dest (or
+--     seed @g_tmc_head on the first cell), advance dest, musttail @mdk_<root>__disp.
+--   • a bare saturated root call → musttail @mdk_<root>__disp directly (skip the
+--     root's PUBLIC define, which would re-zero the in-flight dest globals).
+--   • a saturated tail-call to another GROUP/known fn → musttail @mdk_<f>__disp
+--     (the dest globals thread through untouched).
+--   • any other leaf (a base value, e.g. `[]`) → close the dest + ret @g_tmc_head.
+emitWDispLeaf : Emit -> List (String, (String, LTy)) -> String -> Int -> Int -> CExpr -> <Mut> Unit
+emitWDispLeaf e env root rootArity u ex = match ex
+  CBinPrim "::" head tail =>
+    let satRoot = dispIsSatRootCall (n => canonFnName e n) root rootArity tail
+    let headFree = not (dispCallsRootE e root head)
+    if satRoot && headFree then emitWDispSpineCons e env root u tail head
+    else emitWDispBase e env ex
+  other =>
+    let satRoot = dispIsSatRootCall (n => canonFnName e n) root rootArity other
+    if satRoot then
+      -- a bare dispatcher tail-call to root: musttail the root inner symbol.
+      let (_, args) = flattenApp other []
+      let argOps = emitArgs e env args
+      let r = freshReg e
+      let _ = emit e ("  " ++ r ++ " = musttail call i64 @" ++ wDispInner root ++ "(" ++ paddedArgDecls argOps u ++ ")")
+      emit e ("  ret i64 " ++ r)
+    else emitWDispTailOrBase e env root u other
+
+-- a non-cons, non-bare-root leaf: a saturated tail-call to a GROUP-or-known fn →
+-- `musttail call @mdk_<f>__disp(args padded to U)` (the dest threads through); a base
+-- value (no call to root) → close the dest.  Targeting the inner `__disp` symbol
+-- keeps the whole hot cycle at uniform arity U so every musttail prototype-matches.
+emitWDispTailOrBase : Emit -> List (String, (String, LTy)) -> String -> Int -> CExpr -> <Mut> Unit
+emitWDispTailOrBase e env root u ex =
+  let (hd, args) = flattenApp ex []
+  match hd
+    CVar f0 _ =>
+      let f = canonFnName e f0
+      if isKnownFn e f && hasArgs args && wDispMember f then
+        let argOps = emitArgs e env args
+        let r = freshReg e
+        let _ = emit e ("  " ++ r ++ " = musttail call i64 @" ++ wDispInner f ++ "(" ++ paddedArgDecls argOps u ++ ")")
+        emit e ("  ret i64 " ++ r)
+      else emitWDispBase e env ex
+    _ => emitWDispBase e env ex
+
+-- is `f` a member of the active (b′) group (so its inner `__disp` symbol exists to
+-- musttail into)?  A tail-call OUT of the group to an ordinary fn is NOT a hot edge
+-- (it leaves the spine) → treat it as a base value, not a uniform-arity musttail.
+wDispMember : String -> <Mut> Bool
+wDispMember f = match wDispCtxRef.value
+  WDispOn root _ _ => match dispGroupOf wDispGroupsRef.value root
+    Some grp => contains f (dispGroupMembers grp)
+    None => False
+  WDispOff => False
+
+-- the spine-cons leaf: build a Cons cell `[tag=Cons | head | placeholder-tail]`,
+-- link it into the current destination (or seed @g_tmc_head on the FIRST cell),
+-- advance @g_tmc_dest to the cell's tail slot (cell+16), then musttail the inner
+-- loop with the recomputed root args.  The cell's tail stays 0 (a Nil sentinel)
+-- until the NEXT iteration's leaf links into it — exactly the WASM placeholder.
+-- The head is evaluated FIRST (it may read the member's params); the recursion args
+-- are evaluated AFTER (an arg may read a param too) but BEFORE the musttail.
+emitWDispSpineCons : Emit -> List (String, (String, LTy)) -> String -> Int -> CExpr -> CExpr -> <Mut> Unit
+emitWDispSpineCons e env root u tail head =
+  -- 1. evaluate the head, build the cell (Cons = tag, head, tail-placeholder).
+  let headOps = emitArgs e env [head]
+  let cell = freshReg e
+  let _ = emit e ("  " ++ cell ++ " = call ptr @mdk_alloc(i64 24)")
+  let _ = emit e ("  store i64 " ++ intToString (cellTag e "Cons") ++ ", ptr " ++ cell)
+  let _ = storeFields e cell headOps 0
+  let cellw = freshReg e
+  let _ = emit e ("  " ++ cellw ++ " = ptrtoint ptr " ++ cell ++ " to i64")
+  -- 2. link: first cell → @g_tmc_head := cell, @g_tmc_first := 0 ; else store the
+  --    cell word into *@g_tmc_dest.
+  let first = freshReg e
+  let _ = emit e ("  " ++ first ++ " = load i64, ptr @g_tmc_first")
+  let fb = freshReg e
+  let _ = emit e ("  " ++ fb ++ " = icmp ne i64 " ++ first ++ ", 0")
+  let n = intToString (freshId e)
+  let seedL = "dispseed" ++ n
+  let linkL = "displink" ++ n
+  let contL = "dispcont" ++ n
+  let _ = emit e ("  br i1 " ++ fb ++ ", label %" ++ seedL ++ ", label %" ++ linkL)
+  let _ = emit e (seedL ++ ":")
+  let _ = emit e ("  store i64 " ++ cellw ++ ", ptr @g_tmc_head")
+  let _ = emit e "  store i64 0, ptr @g_tmc_first"
+  let _ = emit e ("  br label %" ++ contL)
+  let _ = emit e (linkL ++ ":")
+  let d = freshReg e
+  let _ = emit e ("  " ++ d ++ " = load ptr, ptr @g_tmc_dest")
+  let _ = emit e ("  store i64 " ++ cellw ++ ", ptr " ++ d)
+  let _ = emit e ("  br label %" ++ contL)
+  let _ = emit e (contL ++ ":")
+  -- 3. advance the dest to THIS cell's tail slot (offset 16) for the next link.
+  let newdest = freshReg e
+  let _ = emit e ("  " ++ newdest ++ " = getelementptr i8, ptr " ++ cell ++ ", i64 16")
+  let _ = emit e ("  store ptr " ++ newdest ++ ", ptr @g_tmc_dest")
+  -- 4. recompute the root args + musttail the root inner symbol (the loop edge).
+  let (_, args) = flattenApp tail []
+  let argOps = emitArgs e env args
+  let r = freshReg e
+  let _ = emit e ("  " ++ r ++ " = musttail call i64 @" ++ wDispInner root ++ "(" ++ paddedArgDecls argOps u ++ ")")
+  emit e ("  ret i64 " ++ r)
+
+-- the base leaf: close the dest with the real base value (the spine terminator,
+-- e.g. `[]` = the Nil word 0), then ret @g_tmc_head.  If no cell was ever built
+-- (@g_tmc_first still 1) the whole result IS the base value.
+emitWDispBase : Emit -> List (String, (String, LTy)) -> CExpr -> <Mut> Unit
+emitWDispBase e env ex =
+  let (v, _) = emitExpr e env ex
+  let first = freshReg e
+  let _ = emit e ("  " ++ first ++ " = load i64, ptr @g_tmc_first")
+  let fb = freshReg e
+  let _ = emit e ("  " ++ fb ++ " = icmp ne i64 " ++ first ++ ", 0")
+  let n = intToString (freshId e)
+  let seedL = "dispbseed" ++ n
+  let storeL = "dispbstore" ++ n
+  let doneL = "dispbdone" ++ n
+  let _ = emit e ("  br i1 " ++ fb ++ ", label %" ++ seedL ++ ", label %" ++ storeL)
+  let _ = emit e (seedL ++ ":")
+  -- no cell built — the base value IS the whole result.
+  let _ = emit e ("  ret i64 " ++ v)
+  let _ = emit e (storeL ++ ":")
+  let d = freshReg e
+  let _ = emit e ("  " ++ d ++ " = load ptr, ptr @g_tmc_dest")
+  let _ = emit e ("  store i64 " ++ v ++ ", ptr " ++ d)
+  let _ = emit e ("  br label %" ++ doneL)
+  let _ = emit e (doneL ++ ":")
+  let h = freshReg e
+  let _ = emit e ("  " ++ h ++ " = load i64, ptr @g_tmc_head")
+  emit e ("  ret i64 " ++ h)
+
+-- does `e` mention `root` as a call head anywhere (the cons HEAD must be root-free
+-- so it doesn't re-enter the spine)?  Uses canonFnName via the shared analysis.
+dispCallsRootE : Emit -> String -> CExpr -> <Mut> Bool
+dispCallsRootE e root ex =
+  let isSpine = dispIsSpineCons (n => canonFnName e n) root (fnArity e root) ex
+  -- reuse: a spine cons or a root-headed call mentions root.  Conservative head
+  -- check: a head that is the bare root var, or any sub-spine, is NOT root-free.
+  if isSpine then True else dispHeadMentionsRoot e root ex
+
+-- shallow root-mention check for a cons head (the head is a small expr, not a tail).
+dispHeadMentionsRoot : Emit -> String -> CExpr -> <Mut> Bool
+dispHeadMentionsRoot e root ex = match flattenApp ex []
+  ((CVar f _), _) =>
+    let cn = canonFnName e f
+    cn == root
+  _ => False
+
+
