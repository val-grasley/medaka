+-- ── (b′) dispatch-into-single-target TMC group detection ─────────────────────
+-- The third TMC shape (WASMGC-TRMC-DESIGN.md §1.2): a tail-connected GROUP of
+-- functions rooted at ONE cons-target `root` (the lexer's `scan`).  The ROUTERS
+-- (`scan`/`scanAt`) are cons-free dispatchers that only tail-call into the group;
+-- the LEAVES (`scanLower`/`emit`/…) each end in `tok :: root …` — so the
+-- cons-bearing frame is a LEAF but the recursion target is the single ROOT.  This
+-- is neither self-recursion (Phase 1) nor general mutual recursion: a STAR rooted
+-- at one cons-target.  The per-function self-detection above misses it (the
+-- cons-bearer ≠ the recursion target), so this is a separate GROUP analysis.
+--
+-- Lifted backend-agnostic from `wasm_emit.mdk`'s `detectDispatchGroups` (the WASM
+-- (b′) AS-BUILT, §11) so BOTH emitters share it.  The two `Prog`-coupled lookups
+-- are PARAMETERIZED exactly like `trmcEligible`'s ctor lookups:
+--   `cf : String -> <Mut> String`  — canonical name (alias resolution: the WASM
+--                                     `canonFn`; the LLVM `canonFnName`).
+--   `fa : String -> <Mut> Int`     — a top-level fn's arity (WASM `progFnArity`;
+--                                     LLVM `fnArity`); -1/0 when not a known fn.
+-- `progFnNames` is just the bind names, derived here.  No backend emit state.
+public export data DispGroup = DispGroup String (List String)
+
+-- the root name of a group.
+export
+dispGroupRoot : DispGroup -> String
+dispGroupRoot (DispGroup root _) = root
+
+-- the member names of a group (including the root).
+export
+dispGroupMembers : DispGroup -> List String
+dispGroupMembers (DispGroup _ members) = members
+
+-- look up which group (if any) a fn name belongs to.
+export
+dispGroupOf : List DispGroup -> String -> Option DispGroup
+dispGroupOf [] _ = None
+dispGroupOf ((DispGroup root members)::rest) name =
+  if contains name members then Some (DispGroup root members) else dispGroupOf rest name
+
+-- is `name` the ROOT of this group?
+export
+dispIsRoot : DispGroup -> String -> Bool
+dispIsRoot (DispGroup root _) name = root == name
+
+-- the UNIFORM arity U of a group = the max arity over its members (via `fa`).  The
+-- LLVM (b′) emit gives every member's inner symbol this arity so the cross-member
+-- `musttail` cycle prototype-matches (WASM's `return_call` needed no such uniformity).
+export
+dispGroupUniformArity : (String -> <Mut> Int) -> DispGroup -> <Mut> Int
+dispGroupUniformArity fa (DispGroup _ members) = dispMaxArity fa members 0
+
+dispMaxArity : (String -> <Mut> Int) -> List String -> Int -> <Mut> Int
+dispMaxArity _ [] acc = acc
+dispMaxArity fa (m::rest) acc =
+  let a = fa m
+  let acc2 = if a > acc then a else acc
+  dispMaxArity fa rest acc2
+
+-- ── bind/clause/arm/stmt accessors (self-contained for the lift) ──────────────
+-- (`bindName` is already defined+exported above.)
+export
+clauseBodyOf : CClause -> CExpr
+clauseBodyOf (CClause _ body) = body
+
+export
+clausePats : CClause -> List Pat
+clausePats (CClause pats _) = pats
+
+export
+clauseArityOf : List CClause -> Int
+clauseArityOf ((CClause pats _)::_) = listLen pats
+clauseArityOf [] = 0
+
+export
+armBodyOf : CArm -> CExpr
+armBodyOf (CArm _ _ body) = body
+
+export
+lastStmtExpr : List CStmt -> Option CExpr
+lastStmtExpr [] = None
+lastStmtExpr [(CSExpr ex)] = Some ex
+lastStmtExpr (_::rest) = lastStmtExpr rest
+
+export
+findBind : List CBind -> String -> Option CBind
+findBind [] _ = None
+findBind ((CBind n cs)::rest) m = if n == m then Some (CBind n cs) else findBind rest m
+
+-- only ordinary bool guards (the leaf rewrite can't carry a refutable guard binder).
+export
+allBoolGuards : List CGuard -> Bool
+allBoolGuards [] = True
+allBoolGuards ((CGBool _)::rest) = allBoolGuards rest
+allBoolGuards _ = False
+
+-- a clause whose params are all plain PVar/PWild.
+export
+dispAllPVarParams : List CClause -> Bool
+dispAllPVarParams clauses = not (anyList (c => not (dispPlainParams (clausePats c))) clauses)
+
+dispPlainParams : List Pat -> Bool
+dispPlainParams [] = True
+dispPlainParams ((PVar _)::rest) = dispPlainParams rest
+dispPlainParams (PWild::rest) = dispPlainParams rest
+dispPlainParams _ = False
+
+-- a non-dict define: no clause has a leading dict param.  We keep this lenient
+-- (NON-root members may have literal-pattern clauses for char dispatch — the
+-- normal clause-chain emit handles them); only the LEADING-dict shape is excluded.
+export
+dispNonDict : List CClause -> Bool
+dispNonDict clauses = not (anyList dispClauseHasLeadingDict clauses)
+
+dispClauseHasLeadingDict : CClause -> Bool
+dispClauseHasLeadingDict (CClause ((PVar x)::_) _) = dispIsDictParamName x
+dispClauseHasLeadingDict _ = False
+
+dispIsDictParamName : String -> Bool
+dispIsDictParamName x = dispStartsWithDollarDict x
+
+-- "$dict"-prefix test (no string import; a literal char-by-char prefix check).
+dispStartsWithDollarDict : String -> Bool
+dispStartsWithDollarDict x = startsWith x "$dict"
+
+-- ── the detection entry point ────────────────────────────────────────────────
+-- For each bind, try to grow a (b′) group rooted at it.  A bind `R` qualifies as a
+-- root iff: arity>0, all-PVar params, non-dict, and SOME function has a spine cons
+-- `_ :: R <saturated>`.  The group is the transitive closure of fns tail-reachable
+-- from R whose EVERY tail leaf is (1) base, (2) a spine cons to R, or (3) a
+-- saturated tail-call to a group fn.  Any other tail leaf ⇒ reject (None) — no
+-- transform, no regression.
+export
+detectDispatchGroups : (String -> <Mut> String) -> (String -> <Mut> Int) -> List CBind -> <Mut> List DispGroup
+detectDispatchGroups cf fa binds =
+  let fnNames = map bindName binds
+  flatMap (b => dispTryRoot cf fa binds fnNames b) binds
+
+-- a single-element group (the root) if `R` is a viable root, else [].
+dispTryRoot : (String -> <Mut> String) -> (String -> <Mut> Int) -> List CBind -> List String -> CBind -> <Mut> List DispGroup
+dispTryRoot cf fa binds fnNames (CBind root clauses) =
+  let arity = clauseArityOf clauses
+  if arity > 0
+     && dispNonDict clauses
+     && dispAllPVarParams clauses
+     && dispSomeSpineConsTo cf root arity binds then
+    match dispGrow cf fa binds fnNames root arity [root] [root]
+      Some members =>
+        -- require ≥1 spine cons across the whole group (the dest is a Cons spine).
+        if dispGroupHasSpineCons cf root arity binds members then
+          [DispGroup root members]
+        else []
+      None => []
+  else []
+
+-- does ANY function in `binds` have a SPINE cons `_ :: root <saturated to arity>`?
+dispSomeSpineConsTo : (String -> <Mut> String) -> String -> Int -> List CBind -> <Mut> Bool
+dispSomeSpineConsTo cf root arity binds =
+  anyListM (b => dispBindHasSpineCons cf root arity b) binds
+
+dispBindHasSpineCons : (String -> <Mut> String) -> String -> Int -> CBind -> <Mut> Bool
+dispBindHasSpineCons cf root arity (CBind _ clauses) =
+  anyListM (c => dispExprHasSpineCons cf root arity (clauseBodyOf c)) clauses
+
+-- a SPINE cons leaf reachable through the tail wrappers: `<head> :: root <sat>`.
+dispExprHasSpineCons : (String -> <Mut> String) -> String -> Int -> CExpr -> <Mut> Bool
+dispExprHasSpineCons cf root arity e = match e
+  CIf _ t f =>
+    let lt = dispExprHasSpineCons cf root arity t
+    if lt then True else dispExprHasSpineCons cf root arity f
+  CLet _ _ _ b => dispExprHasSpineCons cf root arity b
+  CBlock stmts => match lastStmtExpr stmts
+    Some ex => dispExprHasSpineCons cf root arity ex
+    None => False
+  CDecision _ arms _ => anyListM (a => dispExprHasSpineCons cf root arity (armBodyOf a)) arms
+  CMatch _ arms => anyListM (a => dispExprHasSpineCons cf root arity (armBodyOf a)) arms
+  other => dispIsSpineCons cf root arity other
+
+-- `e` is a spine cons `<head> :: root <saturated>` (head root-call-free; the tail
+-- a saturated direct call to `root`).
+export
+dispIsSpineCons : (String -> <Mut> String) -> String -> Int -> CExpr -> <Mut> Bool
+dispIsSpineCons cf root arity (CBinPrim "::" head tail) =
+  let hc = dispCallsRoot cf root head
+  if hc then False else dispIsSatRootCall cf root arity tail
+dispIsSpineCons _ _ _ _ = False
+
+-- a saturated direct call to `root` (canonicalized): flattenApp head is `CVar f`,
+-- `cf f == root`, arg count == arity.
+export
+dispIsSatRootCall : (String -> <Mut> String) -> String -> Int -> CExpr -> <Mut> Bool
+dispIsSatRootCall cf root arity e = match flattenApp e []
+  ((CVar f _), args) =>
+    let cn = cf f
+    cn == root && listLen args == arity
+  _ => False
+
+-- does `e` mention `root` as a call head anywhere (used to keep cons HEADS
+-- root-free so the cell's lead fields don't themselves re-enter the spine)?
+dispCallsRoot : (String -> <Mut> String) -> String -> CExpr -> <Mut> Bool
+dispCallsRoot cf root e =
+  let heads = dispAllCallHeads cf e
+  contains root heads
+
+dispAllCallHeads : (String -> <Mut> String) -> CExpr -> <Mut> List String
+dispAllCallHeads cf e = match e
+  CVar f _ => [cf f]
+  CApp f a => dispAllCallHeads cf f ++ dispAllCallHeads cf a
+  CLam _ b => dispAllCallHeads cf b
+  CLet _ _ e1 e2 => dispAllCallHeads cf e1 ++ dispAllCallHeads cf e2
+  CLetGroup _ b => dispAllCallHeads cf b
+  CBlock stmts => flatMap (s => dispAllCallHeadsStmt cf s) stmts
+  CIf c t f => dispAllCallHeads cf c ++ dispAllCallHeads cf t ++ dispAllCallHeads cf f
+  CBinPrim _ l r => dispAllCallHeads cf l ++ dispAllCallHeads cf r
+  CUnOp _ x => dispAllCallHeads cf x
+  CMatch s arms => dispAllCallHeads cf s ++ flatMap (a => dispAllCallHeads cf (armBodyOf a)) arms
+  CDecision s arms _ => dispAllCallHeads cf s ++ flatMap (a => dispAllCallHeads cf (armBodyOf a)) arms
+  CTuple es => flatMap (dispAllCallHeads cf) es
+  CList es => flatMap (dispAllCallHeads cf) es
+  CArray es => flatMap (dispAllCallHeads cf) es
+  CRecord _ fs => flatMap (f => dispAllCallHeads cf (cfieldExprT f)) fs
+  CFieldAccess x _ => dispAllCallHeads cf x
+  CIndex a i => dispAllCallHeads cf a ++ dispAllCallHeads cf i
+  _ => []
+
+dispAllCallHeadsStmt : (String -> <Mut> String) -> CStmt -> <Mut> List String
+dispAllCallHeadsStmt cf (CSExpr e) = dispAllCallHeads cf e
+dispAllCallHeadsStmt cf (CSLet _ _ e) = dispAllCallHeads cf e
+dispAllCallHeadsStmt cf (CSAssign _ e) = dispAllCallHeads cf e
+dispAllCallHeadsStmt cf (CSLetElse _ e els) = dispAllCallHeads cf e ++ dispAllCallHeads cf els
+dispAllCallHeadsStmt _ _ = []
+
+cfieldExprT : CField -> CExpr
+cfieldExprT (CField _ e) = e
+
+-- grow the group: `worklist` = members yet to scan, `acc` = accepted members.  For
+-- each member, every tail leaf must be (1) base, (2) a spine cons to root, or (3) a
+-- saturated tail-call to a group fn (NEW members are added to the worklist).  Any
+-- other tail leaf ⇒ reject (None).  Fuel = the finite worklist.
+dispGrow : (String -> <Mut> String) -> (String -> <Mut> Int) -> List CBind -> List String -> String -> Int -> List String -> List String -> <Mut> Option (List String)
+dispGrow _ _ _ _ _ _ [] acc = Some acc
+dispGrow cf fa binds fnNames root arity (m::rest) acc =
+  match findBind binds m
+    None => None
+    Some (CBind _ clauses) =>
+      if not (dispNonDict clauses) then None
+      else match dispMemberTailsOk cf fa fnNames root arity acc clauses
+        None => None
+        Some newMembers =>
+          let toAdd = filterList (n => not (contains n acc)) newMembers
+          dispGrow cf fa binds fnNames root arity (rest ++ toAdd) (acc ++ toAdd)
+
+-- check every clause's every tail leaf; collect the NEW group fns referenced by
+-- case-(3) tail-calls.  None if any leaf is an unsupported shape.
+dispMemberTailsOk : (String -> <Mut> String) -> (String -> <Mut> Int) -> List String -> String -> Int -> List String -> List CClause -> <Mut> Option (List String)
+dispMemberTailsOk cf fa fnNames root arity acc clauses =
+  dispClausesGo cf fa fnNames root arity acc clauses []
+
+dispClausesGo : (String -> <Mut> String) -> (String -> <Mut> Int) -> List String -> String -> Int -> List String -> List CClause -> List String -> <Mut> Option (List String)
+dispClausesGo _ _ _ _ _ _ [] found = Some found
+dispClausesGo cf fa fnNames root arity acc ((CClause _ body)::rest) found =
+  match dispLeavesOk cf fa fnNames root arity acc body found
+    None => None
+    Some found2 => dispClausesGo cf fa fnNames root arity acc rest found2
+
+-- descend the tail wrappers; check each leaf; accumulate referenced new group fns.
+dispLeavesOk : (String -> <Mut> String) -> (String -> <Mut> Int) -> List String -> String -> Int -> List String -> CExpr -> List String -> <Mut> Option (List String)
+dispLeavesOk cf fa fnNames root arity acc e found = match e
+  CIf _ t f => match dispLeavesOk cf fa fnNames root arity acc t found
+    None => None
+    Some f2 => dispLeavesOk cf fa fnNames root arity acc f f2
+  CLet False (PVar _) _ b => dispLeavesOk cf fa fnNames root arity acc b found
+  CLet False PWild _ b => dispLeavesOk cf fa fnNames root arity acc b found
+  CBlock stmts => match lastStmtExpr stmts
+    Some ex => dispLeavesOk cf fa fnNames root arity acc ex found
+    None => None
+  CDecision _ arms _ => dispArmsOk cf fa fnNames root arity acc arms found
+  CMatch _ arms => dispArmsOk cf fa fnNames root arity acc arms found
+  other => dispLeafOk cf fa fnNames root arity acc other found
+
+dispArmsOk : (String -> <Mut> String) -> (String -> <Mut> Int) -> List String -> String -> Int -> List String -> List CArm -> List String -> <Mut> Option (List String)
+dispArmsOk _ _ _ _ _ _ [] found = Some found
+dispArmsOk cf fa fnNames root arity acc ((CArm _ guards body)::rest) found =
+  if not (allBoolGuards guards) then None
+  else match dispLeavesOk cf fa fnNames root arity acc body found
+    None => None
+    Some f2 => dispArmsOk cf fa fnNames root arity acc rest f2
+
+-- classify a single LEAF.  base ⇒ ok (no new fns).  spine cons ⇒ ok.  saturated
+-- tail-call to a known group-or-fn ⇒ ok + add that fn as a new member.  Else None.
+dispLeafOk : (String -> <Mut> String) -> (String -> <Mut> Int) -> List String -> String -> Int -> List String -> CExpr -> List String -> <Mut> Option (List String)
+dispLeafOk cf fa fnNames root arity acc e found =
+  let isSpine = dispIsSpineCons cf root arity e
+  if isSpine then Some found
+  else
+    match flattenApp e []
+      ((CVar f0 _), args) =>
+        let f = cf f0
+        if f == root then
+          if listLen args == arity then Some found else None
+        else
+          let isMember = contains f fnNames
+          let memArity = fa f
+          if isMember && memArity >= 0 && listLen args == memArity then
+            Some (f :: found)
+          else
+            let isB = dispLeafIsBase cf root e
+            if isB then Some found else None
+      _ =>
+        let isB = dispLeafIsBase cf root e
+        if isB then Some found else None
+
+-- a BASE leaf: a value with NO call to `root` (e.g. `[]`, a literal, a non-recursive
+-- value).  We only need it root-free; the dest-close handles its value.
+dispLeafIsBase : (String -> <Mut> String) -> String -> CExpr -> <Mut> Bool
+dispLeafIsBase cf root e =
+  let cr = dispCallsRoot cf root e
+  not cr
+
+-- the group built a Cons spine somewhere (sanity: the dest cell is `$C_Cons`).
+dispGroupHasSpineCons : (String -> <Mut> String) -> String -> Int -> List CBind -> List String -> <Mut> Bool
+dispGroupHasSpineCons cf root arity binds members =
+  anyListM (m => dispMemberHasSpineCons cf root arity binds m) members
+
+dispMemberHasSpineCons : (String -> <Mut> String) -> String -> Int -> List CBind -> String -> <Mut> Bool
+dispMemberHasSpineCons cf root arity binds m = match findBind binds m
+  Some (CBind _ cs) => anyListM (c => dispExprHasSpineCons cf root arity (clauseBodyOf c)) cs
+  None => False
+
+-- effectful (`<Mut>`) anyList: the prelude `anyList` predicate is pure, but our
+-- spine-cons / call-head walks thread the `cf`/`fa` <Mut> lookups, so we need a
+-- short-circuiting any over a <Mut> predicate.
+anyListM : (a -> <Mut> Bool) -> List a -> <Mut> Bool
+anyListM _ [] = False
+anyListM p (x::rest) =
+  let h = p x
+  if h then True else anyListM p rest
