-- TYPED DICT-PASSING bytecode-VM entry point (STAGE2-DESIGN §2.3 item 2) —
-- the bytecode analog of selfhost/eval_dict_main.mdk:
--
--   medaka run selfhost/eval_bytecode_typed_dict_main.mdk <runtime.mdk> <prelude.mdk>... <source.mdk>
--
-- desugar → elaborateDict (RKey rewrite + EDictAt rewrite of the user's
-- constrained fns, typecheck stamps every route, dict_pass prepends the
-- matching leading dict params) → LOWER to Core IR → COMPILE + RUN through
-- the bytecode VM for its stdout.
-- This exercises IMethod + IDict with real dict-passed routes, including
-- return-position methods at a constraint variable's type (e.g. `empty` inside
-- `f : Monoid a => a -> a`) that plain arg-tag dispatch cannot resolve.
-- Diffs byte-for-byte against `medaka run <file>` for the full eval_dict corpus.

import ast.{Decl}
import parser.{parse}
import desugar.{desugar}
import typecheck.{elaborateDict, constrainedSigNames, preludeReturnPosDictNames}
import eval.{funNamesOf, dropShadowedExp}
import core_ir_lower.{lowerProgram}
import bytecode.{bcEvalOutput}

main = match args ()
  (runtimePath :: rest) => withRuntime runtimePath rest
  _ => ePutStrLn "usage: medaka run selfhost/eval_bytecode_typed_dict_main.mdk <runtime.mdk> <prelude.mdk>... <file.mdk>"

withRuntime runtimePath rest = match splitLast rest
  Some (preludePaths, targetPath) => withFiles runtimePath preludePaths targetPath
  None => ePutStrLn "usage: <runtime.mdk> <prelude.mdk>... <file.mdk>"

splitLast : List a -> Option (List a, a)
splitLast [] = None
splitLast [x] = Some ([], x)
splitLast (x :: rest) = match splitLast rest
  Some (init, lst) => Some (x :: init, lst)
  None => None

withFiles runtimePath preludePaths targetPath = match readFile runtimePath
  Ok rsrc => withPreludes rsrc preludePaths targetPath
  Err msg => ePutStrLn msg

withPreludes rsrc preludePaths targetPath = match readAllDecls preludePaths
  Ok preludeDecls => withTarget rsrc preludeDecls targetPath
  Err msg => ePutStrLn msg

withTarget rsrc preludeDecls targetPath = match readFile targetPath
  Ok tsrc => putStr (runDictBytecode (desugar (parse rsrc)) preludeDecls (desugar (parse tsrc)))
  Err msg => ePutStrLn msg

runDictBytecode : List Decl -> List Decl -> List Decl -> <Mut> String
runDictBytecode runtimeDecls preludeDecls userDecls =
  let userNames = funNamesOf userDecls
  let livePrelude = dropShadowedExp userNames preludeDecls
  let combined = livePrelude ++ userDecls
  let dictNames = preludeReturnPosDictNames livePrelude combined ++ constrainedSigNames userDecls
  bcEvalOutput (lowerProgram (elaborateDict runtimeDecls dictNames userNames combined))

readAllDecls : List String -> <IO> Result String (List Decl)
readAllDecls [] = Ok []
readAllDecls (p :: rest) = match readFile p
  Err msg => Err msg
  Ok src => match readAllDecls rest
    Err msg => Err msg
    Ok more => Ok (desugar (parse src) ++ more)
