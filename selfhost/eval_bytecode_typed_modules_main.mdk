-- TYPED multi-module bytecode-VM entry (STAGE2-DESIGN §2.3 item 1) — the
-- composition of eval_typed_modules_main.mdk (elaborateModules route-stamping)
-- and eval_bytecode_modules_main.mdk (annotate → lower → bcEvalModulesOutput):
--
--   medaka run selfhost/eval_bytecode_typed_modules_main.mdk <runtime.mdk> <core.mdk> <entry.mdk> [root ...]
--
-- loads <entry.mdk> + its transitive imports (dependency-first), desugars each,
-- then `elaborateModules` threads the marker + typecheck route-stamping through
-- the loader's module graph (per-module-frame typecheck in dependency order,
-- EMethodAt routes stamped per module) — so return-position dispatch (`pure`/
-- `andThen` — the Parser monad) is routed by RKey.  The elaborated trees are
-- then annotated (lexical addressing, §2.0 EMIT pass) and run through
-- bcEvalModulesOutput (per-module bytecode frames over the shared prelude).
-- Forces the entry module's `main` for IO side-effects and prints captured stdout.
--
-- Diffs against `medaka run <entry.mdk>` (the OCaml oracle) — byte-identical
-- output to eval_typed_modules_main.mdk for all probes requiring return-position
-- dispatch (selfproc_parse_probe, selfproc_tc_probe).

import ast.{Decl}
import parser.{parse}
import desugar.{desugar}
import annotate.{annotateProgram}
import loader.{loadProgram}
import typecheck.{elaborateModules}
import bytecode.{bcEvalModulesOutput}

main = match args ()
  (runtimeP :: coreP :: entry :: roots) => run runtimeP coreP entry (rootsOrDefault entry roots)
  _ => ePutStrLn "usage: medaka run selfhost/eval_bytecode_typed_modules_main.mdk <runtime.mdk> <core.mdk> <entry.mdk> [root ...]"

rootsOrDefault : String -> List String -> List String
rootsOrDefault entry [] = [dirOf entry]
rootsOrDefault _ roots = roots

dirOf : String -> String
dirOf path = dirGo path (stringLength path)

dirGo : String -> Int -> String
dirGo path 0 = "."
dirGo path i =
  if stringSlice (i - 1) i path == "/" then stringSlice 0 (i - 1) path
  else dirGo path (i - 1)

desugarPair : (String, List Decl) -> (String, List Decl)
desugarPair (mid, p) = (mid, desugar p)

-- annotate-only: elaborateModules already desugared; just run the §2.0 EMIT pass
annotatePair : (String, List Decl) -> (String, List Decl)
annotatePair (mid, ds) = (mid, annotateProgram ds)

run : String -> String -> String -> List String -> <IO, Mut> Unit
run runtimeP coreP entry roots = match readFile runtimeP
  Err e => ePutStrLn e
  Ok rsrc => match readFile coreP
    Err e => ePutStrLn e
    Ok csrc => match loadProgram entry roots
      Err e => ePutStrLn e
      Ok mods => runElab (desugar (parse rsrc)) (desugar (parse csrc)) (map desugarPair mods)

runElab : List Decl -> List Decl -> List (String, List Decl) -> <IO, Mut> Unit
runElab runtimeDecls coreDecls modules =
  let elaborated = elaborateModules runtimeDecls coreDecls modules
  let annotatedPrelude = annotateProgram (fst elaborated)
  let annotatedModules = map annotatePair (snd elaborated)
  putStr (bcEvalModulesOutput annotatedPrelude annotatedModules)
