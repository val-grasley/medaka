-- True-execution (stdout) entry point for the bytecode VM (STAGE2-DESIGN §2.2) —
-- the bytecode analog of selfhost/core_ir_run_main.mdk:
--
--   medaka run selfhost/eval_bytecode_run_main.mdk <prelude.mdk>... <source.mdk>
--
-- prepends the prelude file(s) (core.mdk [list.mdk …]), shadow-drops any prelude
-- function the user program redefines (mirrors the reference's prelude_for
-- shadow-drop), annotates + LOWERS the whole program to Core IR, COMPILES it to
-- bytecode and runs it on the stack VM for its OUTPUT (putStr/putStrLn captured
-- into eval.mdk's output buffer), and prints the captured stdout — diffs against
-- the === EVAL === goldens (test/diff_fixtures/*.golden), the SAME goldens
-- diff_selfhost_eval_run.sh and diff_selfhost_core_ir_run.sh match.

import ast.{Decl}
import parser.{parse}
import desugar.{desugar}
import annotate.{annotateProgram}
import core_ir_lower.{lowerProgram}
import bytecode.{bcEvalOutput}
import eval.{dropShadowedExp, funNamesOf}

main = match splitLast (args ())
  Some (preludePaths, targetPath) => withPreludes preludePaths targetPath
  None => ePutStrLn "usage: medaka run selfhost/eval_bytecode_run_main.mdk <prelude.mdk>... <file.mdk>"

splitLast : List a -> Option (List a, a)
splitLast [] = None
splitLast [x] = Some ([], x)
splitLast (x :: rest) = match splitLast rest
  Some (init, lst) => Some (x :: init, lst)
  None => None

withPreludes : List String -> String -> <IO, Mut> Unit
withPreludes preludePaths targetPath = match readAllDecls preludePaths
  Ok preludeDecls => withTarget preludeDecls targetPath
  Err msg => ePutStrLn msg

withTarget : List Decl -> String -> <IO, Mut> Unit
withTarget preludeDecls targetPath = match readFile targetPath
  Ok targetSrc =>
    let user = desugar (parse targetSrc)
    putStr (bcEvalOutput (lowerProgram (annotateProgram (dropShadowedExp (funNamesOf user) preludeDecls ++ user))))
  Err msg => ePutStrLn msg

-- parse + desugar each prelude file in order, concatenating their decls
readAllDecls : List String -> <IO> Result String (List Decl)
readAllDecls [] = Ok []
readAllDecls (p :: rest) = match readFile p
  Err msg => Err msg
  Ok src => match readAllDecls rest
    Err msg => Err msg
    Ok more => Ok (desugar (parse src) ++ more)
