-- Batched variant of eval_prelude_main.mdk (core only) — prelude caching.
--   medaka run selfhost/eval_prelude_batch.mdk <core.mdk> <file.mdk>...
-- Parses + desugars core.mdk ONCE, evaluates pp_value of each target's `main`.
--
-- NB: each target is evaluated + PRINTED strictly before the next (the IO loop
-- via `let _ = putStr ...`), because the self-hosted evaluator keeps a global
-- ctor->type table (eval.mdk ctorToTypeRef) reseeded per program; a lazy
-- string-builder would let one program's dispatch be forced after the next has
-- already clobbered that table.

import frontend.ast.{Decl}
import frontend.parser.{parse}
import frontend.desugar.{desugar}
import eval.eval.{evalMain}

main = match args ()
  (corePath :: targets) => withCore corePath targets
  _ => ePutStrLn "usage: medaka run selfhost/eval_prelude_batch.mdk <core.mdk> <file.mdk>..."

withCore corePath targets = match readFile corePath
  Err msg => ePutStrLn msg
  Ok csrc => emitAll (desugar (parse csrc)) targets

emitAll : List Decl -> List String -> <IO, Mut> Unit
emitAll preludeDecls [] = putStr ""
emitAll preludeDecls (path :: rest) = match readFile path
  Err msg =>
    let _ = ePutStrLn msg
    emitAll preludeDecls rest
  Ok src =>
    let _ = putStr ("===SELFHOST-FIX=== " ++ path ++ "\n" ++ evalMain (preludeDecls ++ desugar (parse src)) ++ "\n")
    emitAll preludeDecls rest
