-- Multi-module execution through the bytecode VM (STAGE2-DESIGN §2.2, slice 6)
-- — the loader-driven bytecode path, the analog of core_ir_modules_main.mdk:
--
--   medaka run selfhost/eval_bytecode_modules_main.mdk <core.mdk> <entry.mdk> [root ...]
--
-- loads <entry.mdk> + its transitive imports (dependency-first), desugars +
-- annotates each (so each module's CVars are born lexically addressed, §2.0),
-- LOWERS them per-module to Core IR and evaluates them in per-module bytecode
-- frames over the shared prelude (bytecode.bcEvalModulesOutput), forces the
-- entry module's `main` for its IO side-effects, and prints the captured
-- stdout.  Diffs byte-for-byte against `medaka run <entry.mdk>` — the SAME
-- oracle eval_modules_main and core_ir_modules_main use.

import ast.{Decl}
import parser.{parse}
import desugar.{desugar}
import annotate.{annotateProgram}
import loader.{loadProgram}
import bytecode.{bcEvalModulesOutput}

main = match args ()
  (coreP :: entry :: roots) => run coreP entry (rootsOrDefault entry roots)
  _ => ePutStrLn "usage: medaka run selfhost/eval_bytecode_modules_main.mdk <core.mdk> <entry.mdk> [root ...]"

rootsOrDefault : String -> List String -> List String
rootsOrDefault entry [] = [dirOf entry]
rootsOrDefault _ roots = roots

dirOf : String -> String
dirOf path = dirGo path (stringLength path)

dirGo : String -> Int -> String
dirGo path 0 = "."
dirGo path i =
  if stringSlice (i - 1) i path == "/" then stringSlice 0 (i - 1) path
  else dirGo path (i - 1)

-- desugar + annotate each loaded module (the loader returns parsed-not-desugared
-- decls); annotateProgram is the §2.0 EMIT pass, run per-module so each
-- module's Core IR is born lexically addressed.
annotatePair : (String, List Decl) -> (String, List Decl)
annotatePair (mid, p) = (mid, annotateProgram (desugar p))

run : String -> String -> List String -> <IO, Mut> Unit
run coreP entry roots = match readFile coreP
  Err e => ePutStrLn e
  Ok csrc => match loadProgram entry roots
    Err e => ePutStrLn e
    Ok mods => putStr (bcEvalModulesOutput (annotateProgram (desugar (parse csrc))) (map annotatePair mods))
