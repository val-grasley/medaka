-- Batched variant of eval_prelude_main.mdk with core.mdk + list.mdk — prelude caching.
--   medaka run selfhost/eval_list_batch.mdk <core.mdk> <list.mdk> <file.mdk>...
-- Parses + desugars core.mdk + list.mdk ONCE, evaluates pp_value of each target's
-- `main`.  Strict per-target IO loop (see eval_prelude_batch.mdk for why).

import frontend.ast.{Decl}
import frontend.parser.{parse}
import frontend.desugar.{desugar}
import eval.eval.{evalMain}

main = match args ()
  (corePath :: listPath :: targets) => withPreludes corePath listPath targets
  _ => ePutStrLn "usage: medaka run selfhost/eval_list_batch.mdk <core.mdk> <list.mdk> <file.mdk>..."

withPreludes corePath listPath targets = match readFile corePath
  Err msg => ePutStrLn msg
  Ok csrc => match readFile listPath
    Err msg => ePutStrLn msg
    Ok lsrc => emitAll (desugar (parse csrc) ++ desugar (parse lsrc)) targets

emitAll : List Decl -> List String -> <IO, Mut> Unit
emitAll preludeDecls [] = putStr ""
emitAll preludeDecls (path :: rest) = match readFile path
  Err msg =>
    let _ = ePutStrLn msg
    emitAll preludeDecls rest
  Ok src =>
    let _ = putStr ("===SELFHOST-FIX=== " ++ path ++ "\n" ++ evalMain (preludeDecls ++ desugar (parse src)) ++ "\n")
    emitAll preludeDecls rest
