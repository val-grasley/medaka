-- Self-hosted `medaka test` driver — doctests + property tests.
--
--   medaka run selfhost/entries/test_main.mdk <runtime.mdk> <core.mdk> <file.mdk> [root ...]
--
-- Thin driver: the logic lives in selfhost/test_cmd.mdk (`runTest`), shared with
-- the native CLI (medaka_cli.mdk's runTestCmd).  This file only parses argv and
-- defaults the roots, then calls runTest.  Output byte-mirrors
-- `./_build/default/bin/main.exe test <file.mdk>`.

import tools.test_cmd.{runTest, rootsOrDefault}

main = match args ()
  runtimeP::coreP::target::roots => runTest runtimeP coreP target (rootsOrDefault target roots)
  _ => ePutStrLn "usage: medaka run selfhost/entries/test_main.mdk <runtime.mdk> <core.mdk> <file.mdk> [root ...]"
