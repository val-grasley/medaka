-- | sqlite.lib.select — a typed ADT query model over the B-tree read path.
--
-- This module is a B-tree READER, not a SQL engine.  A `Select` value (an ADT)
-- DRIVES the existing table scanner (`sqlite/lib/query.mdk`): we compile its
-- `where_` predicate to a closure over the raw `List Cell` and filter the scan,
-- then `offset`/`limit`, then decode survivors via a `RowType a`.
--
-- Three public surfaces:
--   * Untyped core (`Literal`/`CmpOp`/`SqlExpr`/`Select`) — ships execution.
--   * Phantom `Expr a` smart-constructor layer — zero-cost type safety
--     (`eEq (eColInt "age") (eLitT "x")` is a `medaka check` ERROR).
--   * `render : Select -> Result String (String, List Literal)` — an
--     injection-safe SQL-string projection for the oracle/display (every literal
--     becomes a `?` placeholder with its value pushed to the ordered bind list).
--
-- Names are deliberately OFF the prelude (`eGt`/`eEq`/`eAnd`/...) so they never
-- collide with `Ord`/`Eq`/`Bool` methods (`gt`/`eq`/`and`/...).

import lib.recordfmt.{Cell, CNull, CInt, CText, CBlob, CFloat, nthCell}
import lib.sqlite.{
  Db,
  scanTableRowsIpk,
  rowCellsWithIpk,
  columnIndex,
  columnNames,
  findTable,
  schemaSql,
  pkColumnIndex,
}
import lib.btree.{Row}
import lib.rowtype.{RowType, rtDecode}
import list.{reverse, take, drop, sortBy, nub}
import string.{join, fromChars, replaceAll, toInt, toFloat}

-- ---------------------------------------------------------------------------
-- Untyped core
-- ---------------------------------------------------------------------------

-- | A literal value that can appear in a query.  Mirrors `Cell` minus the
--   "decoded from a column" provenance.
public export data Literal =
  | LInt Int
  | LText String
  | LFloat Float
  | LBlob (Array Int)
  | LNull
deriving (Debug, Eq)

-- | A comparison operator.
public export data CmpOp =
  | OpEq
  | OpNe
  | OpLt
  | OpLe
  | OpGt
  | OpGe
deriving (Eq, Debug)

-- | An arithmetic operator: `+`, `-`, `*`, `/` (division), `%` (modulo).
public export data ArithOp =
  | AAdd
  | ASub
  | AMul
  | ADiv
  | AMod
deriving (Eq, Debug)

-- | An aggregate function.  `FnCount` is the only one that may appear with NO
--   operand — that is `COUNT(*)`.
public export data AggFn =
  | FnCount
  | FnSum
  | FnAvg
  | FnMin
  | FnMax
deriving (Eq, Debug)

-- | An untyped boolean/value expression tree.  `ECol`/`ELit` are leaves;
--   `EBin` is a comparison; `EArith` is a numeric binary op; `EAnd`/`EOr`/`ENot`
--   are logical; `EIsNull`/`ENotNull` are the null tests.
--
--   `EAgg fn operand` is a REAL aggregate node: `EAgg FnCount None` is
--   `COUNT(*)` (the `None` operand is what encodes the `*`), `EAgg FnSum (Some e)`
--   is `SUM(e)`.  Because the operand is a full `SqlExpr` — not a bare column
--   name — `sum(price * qty)` is expressible.  An aggregate is legal in the
--   SELECT list, in HAVING, and in ORDER BY; it is REJECTED in WHERE and in a
--   JOIN's ON (compile-time `Err`), and it may not nest inside another aggregate.
--
--   `Eq SqlExpr` is derived: the executor uses structural equality to (a) match a
--   projection/ORDER BY/HAVING sub-expression against a GROUP BY key and (b)
--   dedup the aggregate list, so `count(*)` mentioned in both the select list and
--   ORDER BY is computed once.
--   `EConcat` is `||` string concatenation (NULL if either side is NULL;
--   numbers are coerced to text — SQLite semantics).  `ELike x pat` is `x LIKE
--   pat` (case-insensitive for ASCII only, `%`/`_` wildcards); `NOT LIKE` is
--   just `ENot (ELike ..)`.  `EIn x vs` is `x IN (v1, .., vn)`; `NOT IN` is
--   `ENot (EIn ..)`.  There is no `EBetween` — `x BETWEEN a AND b` desugars at
--   PARSE time to `EAnd (EBin OpGe x a) (EBin OpLe x b)` (exactly SQLite's own
--   definition), so it needs no new evaluator code and renders/round-trips
--   through the existing AND/comparison machinery.  `ECase` is CASE/WHEN/THEN/
--   ELSE/END (the simple `CASE x WHEN v THEN r` form desugars at parse time to
--   `WHEN x = v THEN r`, so only the searched form is a real node).
--   `ECoalesce` backs both `COALESCE(a, b, ..)` and `IFNULL(a, b)` (`IFNULL` is
--   parsed as a 2-argument `ECoalesce` — SQLite defines it that way).  `EFn`
--   is a scalar string-function call (`LENGTH`/`UPPER`/`LOWER`/`SUBSTR`/`TRIM`/
--   `LTRIM`/`RTRIM`/`REPLACE`); the name is validated at parse time, so
--   `compileFnCall`'s arity fallback is defensive dead code, not a live path.
public export data SqlExpr =
  | ECol String
  | ELit Literal
  | EAgg AggFn (Option SqlExpr)
  | EBin CmpOp SqlExpr SqlExpr
  | EArith ArithOp SqlExpr SqlExpr
  | EConcat SqlExpr SqlExpr
  | EAnd SqlExpr SqlExpr
  | EOr SqlExpr SqlExpr
  | ENot SqlExpr
  | EIsNull SqlExpr
  | ENotNull SqlExpr
  | ELike SqlExpr SqlExpr
  | EIn SqlExpr (List SqlExpr)
  | ECase (List (SqlExpr, SqlExpr)) (Option SqlExpr)
  | ECoalesce (List SqlExpr)
  | EFn String (List SqlExpr)
deriving (Eq, Debug)

-- | The join kind: `JInner` drops unmatched left rows (SQL INNER JOIN);
--   `JLeft` keeps every left row, null-padding the right side when no match is
--   found (SQL LEFT [OUTER] JOIN).
public export data JoinKind = JInner | JLeft deriving (Eq, Debug)

-- | A single JOIN clause: the joined table, its kind, its optional alias, and
--   its ON predicate.  The ON expression references columns by qualified name
--   (`table.column`, or `alias.column` when the table is aliased) or by an
--   unambiguous bare column name; it is compiled over the COMBINED row (all
--   tables concatenated, `from`-table columns first, then each join's columns in
--   `joins` order).  `alias` is `None` for `JOIN orders …` and `Some "o"` for
--   `JOIN orders o …` / `JOIN orders AS o …`; when set, qualified references to
--   this table MUST use the alias (SQLite's rule — the real name is then hidden).
public export data Join =
  | Join {
      table : String,
      kind : JoinKind,
      alias : Option String,
      on : SqlExpr,
    }
deriving (Eq, Debug)

-- | A whole SELECT — the single query ADT.  One `Select`, one executor
--   (`runPipeline`), running the real SQL evaluation order:
--
--     FROM → JOIN → WHERE → GROUP BY → HAVING → project (SELECT list)
--       → DISTINCT → ORDER BY → LIMIT/OFFSET
--
--   The COMBINED row (when `joins` is non-empty) lays out cells as: all of the
--   `from` table's columns, then each join table's columns in `joins` order.
--
--   `columns` is the PROJECTION expression list (SELECT a+b, count(*) FROM t).
--   The default `[]` means `SELECT *`: in an UNGROUPED query the raw cells pass
--   through decode unchanged (so every pre-unification query stays
--   byte-identical); in a GROUPED query it means the synthetic group row —
--   group-key cells (in `groupBy` order) followed by the aggregate cells.  The
--   `RowType` passed to `query` decodes the PROJECTED row positionally, so it
--   must match the projection's cell order/types.
--
--   `groupBy` is a list of key EXPRESSIONS (not just column names).  A query is
--   AGGREGATE when `groupBy` is non-empty, OR `having` is set, OR an `EAgg`
--   appears anywhere in `columns`/`having`/`orderBy` — matching SQL.  In an
--   aggregate query every non-aggregate projection/HAVING/ORDER BY expression
--   must be built from GROUP BY keys and literals; a bare column that is not a
--   key is an `Err` (SQL's "must appear in the GROUP BY clause" rule) rather
--   than silent garbage.  With no GROUP BY there is exactly ONE group over the
--   whole filtered table (`SELECT count(*) FROM t` = one row, 0 on empty).
--
--   `orderBy` keys are EXPRESSIONS too, so ORDER BY can name an original column,
--   a computed column, or an aggregate — the v1 "ORDER BY cannot reference a
--   computed column" limitation is gone.  Sort keys are evaluated against the
--   pre-projection row (raw row when ungrouped, synthetic group row when
--   grouped), which is exactly what lets `ORDER BY count(*) DESC` work whether
--   or not `count(*)` is in the select list.  Grouped output is key-ascending by
--   default; an explicit `orderBy` sorts on top of that (so it is a deterministic
--   tiebreak, `sortBy` being stable).
--
--   `distinct` is a flag only — `render` reads it to emit `SELECT DISTINCT`,
--   but `query` (unconstrained: no `Eq a`) ignores it entirely. DISTINCT
--   *execution* dedups on the DECODED projected values, which needs `Eq a`,
--   so it lives in the separate `queryDistinct` entry point below. Plain
--   `query` MUST stay unconstrained — don't add `Eq a` here.
--   `fromAlias` is the optional alias of the `from` table (`FROM users u` /
--   `FROM users AS u`).  When `Some`, qualified column references to the `from`
--   table MUST use the alias (`u.name`), not the real name — SQLite's rule.
--
--   `columnAliases` is a per-projection output name (`SELECT a AS x` ⇒ `Some
--   "x"`), positionally parallel to `columns`: the alias at index `i` names the
--   projection at index `i`.  It is `[]` when nothing is aliased (and may be
--   shorter than `columns`, in which case the missing tail is all-`None`).  The
--   executor ignores it entirely — it affects only rendering and
--   `selectColumnNames` (output-column naming), never the computed cells.
public export data Select =
  | Select {
      from : String,
      fromAlias : Option String,
      joins : List Join,
      where_ : Option SqlExpr,
      groupBy : List SqlExpr,
      having : Option SqlExpr,
      orderBy : List (SqlExpr, Bool),
      limit : Option Int,
      offset : Option Int,
      distinct : Bool,
      columns : List SqlExpr,
      columnAliases : List (Option String),
    }
deriving (Eq, Debug)

-- ---------------------------------------------------------------------------
-- Phantom type-safe layer: Expr a
--
-- `Expr a` is a zero-cost wrapper around `SqlExpr`; the phantom `a` exists only
-- for the type checker.  Users NEVER construct `MkExpr` directly — the smart
-- constructors below are the entire public surface, and they alone decide the
-- phantom type.  This buys: a comparison forces both sides to the same `a`, a
-- column witness fixes `a`, and the logical ops force `Expr Bool`.
-- ---------------------------------------------------------------------------

public export data Expr a = MkExpr SqlExpr

-- | Recover the untyped expression (e.g. to put it in `where_`).
export unExpr : Expr a -> SqlExpr
unExpr (MkExpr x) = x

-- | Wrap an untyped expression at an arbitrary phantom type (internal).
export mkE : SqlExpr -> Expr a
mkE x = MkExpr x

-- Column references, each fixing the phantom witness type.
export eColInt : String -> Expr Int
eColInt name = MkExpr (ECol name)

export eColText : String -> Expr String
eColText name = MkExpr (ECol name)

export eColFloat : String -> Expr Float
eColFloat name = MkExpr (ECol name)

-- | An untyped column reference (when you don't want a witness).
export eCol : String -> Expr a
eCol name = MkExpr (ECol name)

-- Literals.
export eLitI : Int -> Expr Int
eLitI n = MkExpr (ELit (LInt n))

export eLitT : String -> Expr String
eLitT s = MkExpr (ELit (LText s))

export eLitF : Float -> Expr Float
eLitF f = MkExpr (ELit (LFloat f))

-- Comparisons: both operands share the phantom `a`, result is `Expr Bool`.
export eEq : Expr a -> Expr a -> Expr Bool
eEq l r = MkExpr (EBin OpEq (unExpr l) (unExpr r))

export eNe : Expr a -> Expr a -> Expr Bool
eNe l r = MkExpr (EBin OpNe (unExpr l) (unExpr r))

export eLt : Expr a -> Expr a -> Expr Bool
eLt l r = MkExpr (EBin OpLt (unExpr l) (unExpr r))

export eLe : Expr a -> Expr a -> Expr Bool
eLe l r = MkExpr (EBin OpLe (unExpr l) (unExpr r))

export eGt : Expr a -> Expr a -> Expr Bool
eGt l r = MkExpr (EBin OpGt (unExpr l) (unExpr r))

export eGe : Expr a -> Expr a -> Expr Bool
eGe l r = MkExpr (EBin OpGe (unExpr l) (unExpr r))

-- Arithmetic combinators: both operands share the phantom `a`, result is
-- `Expr a` (the value stays in the same numeric domain for the type checker).
export eAdd : Expr a -> Expr a -> Expr a
eAdd l r = MkExpr (EArith AAdd (unExpr l) (unExpr r))

export eSub : Expr a -> Expr a -> Expr a
eSub l r = MkExpr (EArith ASub (unExpr l) (unExpr r))

export eMul : Expr a -> Expr a -> Expr a
eMul l r = MkExpr (EArith AMul (unExpr l) (unExpr r))

export eDiv : Expr a -> Expr a -> Expr a
eDiv l r = MkExpr (EArith ADiv (unExpr l) (unExpr r))

export eMod : Expr a -> Expr a -> Expr a
eMod l r = MkExpr (EArith AMod (unExpr l) (unExpr r))

-- | `||` string concatenation.  Typed `String -> String -> String` (the typed
--   layer does not model SQLite's number-to-text coercion — that is a runtime
--   behavior of the untyped evaluator, not something the phantom layer should
--   pretend is type-safe).
export eConcat : Expr String -> Expr String -> Expr String
eConcat l r = MkExpr (EConcat (unExpr l) (unExpr r))

-- | `x LIKE pattern` / `x NOT LIKE pattern` — case-insensitive (ASCII only).
export eLike : Expr String -> Expr String -> Expr Bool
eLike x pat = MkExpr (ELike (unExpr x) (unExpr pat))

export eNotLike : Expr String -> Expr String -> Expr Bool
eNotLike x pat = MkExpr (ENot (ELike (unExpr x) (unExpr pat)))

-- | `x IN (v1, .., vn)` / `x NOT IN (v1, .., vn)`.
export eIn : Expr a -> List (Expr a) -> Expr Bool
eIn x vs = MkExpr (EIn (unExpr x) (map unExpr vs))

export eNotIn : Expr a -> List (Expr a) -> Expr Bool
eNotIn x vs = MkExpr (ENot (EIn (unExpr x) (map unExpr vs)))

-- | `x BETWEEN lo AND hi` / `x NOT BETWEEN lo AND hi` — inclusive, exactly
--   `lo <= x AND x <= hi` (SQLite's own definition; there is no `EBetween`
--   node, see the `SqlExpr` doc comment).
export eBetween : Expr a -> Expr a -> Expr a -> Expr Bool
eBetween x lo hi =
  MkExpr (EAnd
    (EBin OpGe (unExpr x) (unExpr lo))
    (EBin OpLe (unExpr x) (unExpr hi)))

export eNotBetween : Expr a -> Expr a -> Expr a -> Expr Bool
eNotBetween x lo hi =
  MkExpr (ENot (EAnd
    (EBin OpGe (unExpr x) (unExpr lo))
    (EBin OpLe (unExpr x) (unExpr hi))))

-- | `COALESCE(a, b, ..)` — the first non-NULL argument, or NULL if all are.
export eCoalesce : List (Expr a) -> Expr a
eCoalesce es = MkExpr (ECoalesce (map unExpr es))

-- | `IFNULL(a, b)` — SQLite defines this as exactly `COALESCE(a, b)`.
export eIfNull : Expr a -> Expr a -> Expr a
eIfNull a b = MkExpr (ECoalesce [unExpr a, unExpr b])

-- | Searched `CASE WHEN c1 THEN r1 .. [ELSE re] END`.  There is no typed
--   builder for the simple `CASE x WHEN v THEN r` form — build the equivalent
--   `eEq x v` conditions directly, exactly what the SQL parser desugars to.
export eCase : List (Expr Bool, Expr a) -> Option (Expr a) -> Expr a
eCase whens els = MkExpr (ECase (map unExprPair whens) (map unExpr els))

unExprPair : (Expr Bool, Expr a) -> (SqlExpr, SqlExpr)
unExprPair (c, r) = (unExpr c, unExpr r)

-- | `TRUE` / `FALSE` — SQLite represents both as the integer literals `1`/`0`.
export eTrue : Expr Bool
eTrue = MkExpr (ELit (LInt 1))

export eFalse : Expr Bool
eFalse = MkExpr (ELit (LInt 0))

-- String scalar functions (SQLite semantics — see the evaluator section below
-- for the exact per-function NULL/coercion rules, verified against `sqlite3`).
export eLength : Expr String -> Expr Int
eLength s = MkExpr (EFn "LENGTH" [unExpr s])

export eUpper : Expr String -> Expr String
eUpper s = MkExpr (EFn "UPPER" [unExpr s])

export eLower : Expr String -> Expr String
eLower s = MkExpr (EFn "LOWER" [unExpr s])

export eTrimSql : Expr String -> Expr String
eTrimSql s = MkExpr (EFn "TRIM" [unExpr s])

export eLtrim : Expr String -> Expr String
eLtrim s = MkExpr (EFn "LTRIM" [unExpr s])

export eRtrim : Expr String -> Expr String
eRtrim s = MkExpr (EFn "RTRIM" [unExpr s])

-- | `substr(s, start)` — 1-indexed, negative `start` counts from the end.
export eSubstr2 : Expr String -> Expr Int -> Expr String
eSubstr2 s start = MkExpr (EFn "SUBSTR" [unExpr s, unExpr start])

-- | `substr(s, start, len)` — see `fnSubstr3`'s doc comment for the exact
--   (verified-against-`sqlite3`) rules for zero/negative `start`/`len`.
export eSubstr3 : Expr String -> Expr Int -> Expr Int -> Expr String
eSubstr3 s start len =
  MkExpr (EFn "SUBSTR" [unExpr s, unExpr start, unExpr len])

export eReplaceSql : Expr String -> Expr String -> Expr String -> Expr String
eReplaceSql s from to =
  MkExpr (EFn "REPLACE" [unExpr s, unExpr from, unExpr to])

-- Logical combinators: force `Expr Bool` operands and result.
export eAnd : Expr Bool -> Expr Bool -> Expr Bool
eAnd l r = MkExpr (EAnd (unExpr l) (unExpr r))

export eOr : Expr Bool -> Expr Bool -> Expr Bool
eOr l r = MkExpr (EOr (unExpr l) (unExpr r))

export eNot : Expr Bool -> Expr Bool
eNot e = MkExpr (ENot (unExpr e))

-- Null tests over any column type.
export eIsNull : Expr a -> Expr Bool
eIsNull e = MkExpr (EIsNull (unExpr e))

export eNotNull : Expr a -> Expr Bool
eNotNull e = MkExpr (ENotNull (unExpr e))

-- Aggregate constructors.  These build a REAL `EAgg` node — unlike the legacy
-- `lib.aggregate` `eCountStar`/`eSum`/… builders, which fake an aggregate as an
-- `ECol` whose *name* happens to read "count(*)".  Each takes a full `Expr a`
-- operand, so `aSum (eMul (eColInt "price") (eColInt "qty"))` is `SUM(price*qty)`.
-- The phantom result type follows SQL: COUNT is an Int, AVG is a Float, and
-- SUM/MIN/MAX stay in the operand's domain.

-- | `COUNT(*)` — counts rows, NULLs included.  The only operand-less aggregate.
export aCountStar : Expr Int
aCountStar = MkExpr (EAgg FnCount None)

-- | `COUNT(e)` — counts the rows where `e` is non-NULL.
export aCount : Expr a -> Expr Int
aCount e = MkExpr (EAgg FnCount (Some (unExpr e)))

export aSum : Expr a -> Expr a
aSum e = MkExpr (EAgg FnSum (Some (unExpr e)))

export aAvg : Expr a -> Expr Float
aAvg e = MkExpr (EAgg FnAvg (Some (unExpr e)))

export aMin : Expr a -> Expr a
aMin e = MkExpr (EAgg FnMin (Some (unExpr e)))

export aMax : Expr a -> Expr a
aMax e = MkExpr (EAgg FnMax (Some (unExpr e)))

-- ---------------------------------------------------------------------------
-- Select builders
-- ---------------------------------------------------------------------------

-- | A bare SELECT over a table: no WHERE, no GROUP BY, no ORDER BY, no
--   limit/offset.
export selectFrom : String -> Select
selectFrom tbl = selectFromAs tbl None

-- | A bare SELECT over a table with an optional alias (`FROM tbl AS a`).
--   `selectFrom tbl` is `selectFromAs tbl None`.
export selectFromAs : String -> Option String -> Select
selectFromAs tbl alias = Select {
  from = tbl,
  fromAlias = alias,
  joins = [],
  where_ = None,
  groupBy = [],
  having = None,
  orderBy = [],
  limit = None,
  offset = None,
  distinct = False,
  columns = [],
  columnAliases = [],
}

-- | Attach an alias to the `from` table of an existing `Select`.
export withFromAlias : Option String -> Select -> Select
withFromAlias alias sel = { sel | fromAlias = alias }

-- | Append an INNER JOIN of `tbl` with the type-safe `on` predicate.  Joins are
--   applied in call order (each appends), so the combined row lays out the
--   `from` columns first, then each joined table's columns in this order.  The
--   phantom `Expr Bool` is stripped here, exactly like `withWhere`.
export innerJoin : String -> Expr Bool -> Select -> Select
innerJoin tbl onExpr sel = innerJoinAs tbl None onExpr sel

-- | Append an INNER JOIN with an optional table alias (`JOIN tbl AS a ON …`).
--   `innerJoin` is `innerJoinAs tbl None`.  When aliased, the `on` predicate (and
--   the rest of the query) references this table's columns through the alias.
export innerJoinAs : String -> Option String -> Expr Bool -> Select -> Select
innerJoinAs tbl alias onExpr sel = { sel | joins = sel.joins ++ [Join {
    table = tbl,
    kind = JInner,
    alias = alias,
    on = unExpr onExpr,
  }] }

-- | Append a LEFT [OUTER] JOIN of `tbl` with the type-safe `on` predicate.
--   Every row of the accumulated left side is kept: when no right row matches
--   `on`, the joined table's columns are null-padded instead of dropping the
--   row.  Decode a LEFT-joined table's columns via `tOption` (see
--   `lib.rowtype`) since they may be `CNull` when unmatched.
export leftJoin : String -> Expr Bool -> Select -> Select
leftJoin tbl onExpr sel = leftJoinAs tbl None onExpr sel

-- | Append a LEFT [OUTER] JOIN with an optional table alias.  `leftJoin` is
--   `leftJoinAs tbl None`.
export leftJoinAs : String -> Option String -> Expr Bool -> Select -> Select
leftJoinAs tbl alias onExpr sel = { sel | joins = sel.joins ++ [Join {
    table = tbl,
    kind = JLeft,
    alias = alias,
    on = unExpr onExpr,
  }] }

-- | Attach a typed `Expr Bool` predicate as the WHERE clause.  The phantom
--   wrapper is stripped here — this is the type-safe boundary at which an
--   `Expr Bool` becomes an untyped `SqlExpr`.
export withWhere : Expr Bool -> Select -> Select
withWhere e sel = { sel | where_ = Some (unExpr e) }

export withLimit : Int -> Select -> Select
withLimit n sel = { sel | limit = Some n }

export withOffset : Int -> Select -> Select
withOffset n sel = { sel | offset = Some n }

-- | Order the results by `col`, ascending when `asc = True`, descending when
--   `asc = False`.  Sorting applies BEFORE offset/limit, matching SQL semantics.
--   Multi-column ORDER BY: each call APPENDS a key, so the first call is the
--   primary sort key, the second breaks ties on the first, etc. — matching
--   `ORDER BY a ASC, b DESC` when chained `withOrderBy "a" True |> withOrderBy "b" False`.
--   Sugar for `withOrderByExpr (ECol col)`.
export withOrderBy : String -> Bool -> Select -> Select
withOrderBy col asc sel = { sel | orderBy = sel.orderBy ++ [(ECol col, asc)] }

-- | Order by an arbitrary EXPRESSION — a computed column (`ORDER BY price*qty`)
--   or an aggregate (`ORDER BY count(*) DESC`).  Appends, exactly like
--   `withOrderBy`.  In an aggregate query the expression must be built from
--   GROUP BY keys, aggregates, and literals; otherwise it is an `Err` at
--   execution, matching SQL.  The key need NOT appear in the select list.
export withOrderByExpr : SqlExpr -> Bool -> Select -> Select
withOrderByExpr e asc sel = { sel | orderBy = sel.orderBy ++ [(e, asc)] }

-- | GROUP BY the named columns (left-to-right key order).  Sugar for
--   `withGroupExprs (map ECol cols)`.
export withGroupCols : List String -> Select -> Select
withGroupCols cols sel = { sel | groupBy = map ECol cols }

-- | GROUP BY arbitrary key EXPRESSIONS (e.g. `GROUP BY salary / 1000`).  Any
--   non-aggregate projection / HAVING / ORDER BY expression must then be built
--   from these keys (structurally) plus literals.
export withGroupExprs : List SqlExpr -> Select -> Select
withGroupExprs es sel = { sel | groupBy = es }

-- | Attach a HAVING predicate — a filter over the GROUPED rows, so it may
--   reference aggregates (`aCountStar`, `aSum …`) and GROUP BY keys.  Setting a
--   HAVING makes the query an aggregate query even with no GROUP BY, matching SQL.
--
--   NAME: deliberately NOT `withHaving` — `lib.aggregate` already exports that
--   for the legacy `AggQuery`, and a module importing both would collide.
export withHavingPred : Expr Bool -> Select -> Select
withHavingPred e sel = { sel | having = Some (unExpr e) }

-- | Mark the SELECT as DISTINCT: `render` emits `SELECT DISTINCT`, and
--   `queryDistinct` dedups the DECODED, projected rows (see `Select.distinct`
--   doc comment for why this needs a separate `Eq a`-constrained entry point
--   rather than living on plain `query`).
export withDistinct : Select -> Select
withDistinct sel = { sel | distinct = True }

-- | Set the PROJECTION column list (`SELECT <e1>, <e2>, … FROM …`).  The list is
--   heterogeneous (a projection may mix `Expr Int`, `Expr String`, …), so it
--   takes UNTYPED `SqlExpr`s rather than `List (Expr a)` — the caller erases the
--   phantom with `unExpr` (or the `col`-style helpers). The `RowType` passed to
--   `query` is the type-safe decode boundary and MUST match this list
--   positionally (same count, same cell types, same order). An empty list keeps
--   the default `SELECT *` behaviour (raw cells pass through unchanged).
--
--   Example: `withColumns [unExpr (eAdd (eColInt "a") (eColInt "b")), unExpr (eColText "name")]`.
export withColumns : List SqlExpr -> Select -> Select
withColumns cols sel =
  { sel | columns = cols, columnAliases = map (_ => None) cols }

-- | Set the PROJECTION column list WITH per-column output aliases (`SELECT e1 AS
--   x, e2 FROM …`).  Each element is `(expr, Some name)` for an aliased column or
--   `(expr, None)` for an unaliased one; the alias flows into rendering and
--   `selectColumnNames` but the executor treats the projection exactly as
--   `withColumns` would.
export withColumnsAliased : List (SqlExpr, Option String) -> Select -> Select
withColumnsAliased cols sel =
  { sel | columns = map fst cols, columnAliases = map snd cols }

-- ---------------------------------------------------------------------------
-- render : injection-safe SQL projection
-- ---------------------------------------------------------------------------

-- | Project a `Select` to a parameterized SQL string plus its ordered binds.
--   Every `ELit` emits a `?` and pushes its `Literal` to the bind list
--   (left-to-right); literal values are NEVER inlined into the SQL text.
--   Identifiers (table + column names) are charset-asserted (`[A-Za-z0-9_]`);
--   an illegal identifier yields `Err`.
export render : Select -> Result String (String, List Literal)
render (Select { from = tbl, fromAlias = fa, joins = js, where_ = w, groupBy = gb, having = h, orderBy = ob, limit = lm, offset = of_, distinct = dst, columns = cols, columnAliases = cas }) =
  if not (validIdent tbl) then Err "render: invalid table name: \{tbl}"
  else do
    fromAliasSql <- renderAliasSuffix fa
    (joinSql, joinBinds) <- renderJoins js
    (colSql, colBinds) <- renderColumnsA cols cas
    (whereSql, binds) <- renderWhere w
    (grpSql, grpBinds) <- renderGroupBy gb
    (havSql, havBinds) <- renderHaving h
    (ordSql, ordBinds) <- renderOrderBy ob
    let limOff = renderLimitOffset lm of_
    let distPfx = if dst then "SELECT DISTINCT " else "SELECT "
    let selectSql = "\{distPfx}\{colSql}"
    let sql = "\{selectSql} FROM \{tbl}\{fromAliasSql}\{joinSql}\{whereSql}\{grpSql}\{havSql}\{ordSql}\{limOffSql limOff}"
    Ok
      (
        sql,
        colBinds ++ joinBinds ++ binds ++ grpBinds ++ havBinds ++ ordBinds ++ limOffBinds limOff lm of_,
      )

-- Render the GROUP BY clause (comma-joined key expressions).  Empty ⇒ no clause.
renderGroupBy : List SqlExpr -> Result String (String, List Literal)
renderGroupBy [] = Ok ("", [])
renderGroupBy gb = map
  ((parts, binds) => (" GROUP BY \{join ", " parts}", binds))
  (renderColumnParts gb)

-- Render the HAVING clause (with leading " HAVING ") and collect its binds.
renderHaving : Option SqlExpr -> Result String (String, List Literal)
renderHaving None = Ok ("", [])
renderHaving (Some e) =
  map ((sql, binds) => (" HAVING \{sql}", binds)) (renderExpr e)

-- Alias-aware projection render: each column may carry a `Some name` output
-- alias, rendered as `<expr> AS <name>`.  `cas` is positionally parallel to
-- `cols` and may be shorter (missing tail ⇒ no alias).  Empty `cols` ⇒ `*`.
renderColumnsA : List SqlExpr -> List (Option String) -> Result String (String, List Literal)
renderColumnsA [] _ = Ok ("*", [])
renderColumnsA cols cas = map
  ((parts, binds) => (join ", " parts, binds))
  (renderColumnAliasedParts (zipAliases cols cas))

renderColumnAliasedParts : List (SqlExpr, Option String) -> Result String (List String, List Literal)
renderColumnAliasedParts [] = Ok ([], [])
renderColumnAliasedParts ((e, a)::rest) = do
  (sql, binds) <- renderExpr e
  suffix <- renderAliasSuffix a
  (restParts, restBinds) <- renderColumnAliasedParts rest
  Ok ("\{sql}\{suffix}"::restParts, binds ++ restBinds)

-- Pair each expression with its alias, padding a short/empty alias list with
-- `None` so the two lists need not be kept in lockstep by every caller.
zipAliases : List SqlExpr -> List (Option String) -> List (SqlExpr, Option String)
zipAliases [] _ = []
zipAliases (e::es) [] = (e, None) :: zipAliases es []
zipAliases (e::es) (a::arest) = (e, a) :: zipAliases es arest

-- Render an optional alias as a ` AS <name>` suffix.  The name is identifier-
-- charset-asserted, exactly like a table/column name, so an illegal alias is an
-- `Err` rather than injected verbatim.
renderAliasSuffix : Option String -> Result String String
renderAliasSuffix None = Ok ""
renderAliasSuffix (Some a) =
  if validIdent a then
    Ok " AS \{a}"
  else
    Err "render: invalid alias: \{a}"

renderColumnParts : List SqlExpr -> Result String (List String, List Literal)
renderColumnParts [] = Ok ([], [])
renderColumnParts (e::rest) = do
  (sql, binds) <- renderExpr e
  (restParts, restBinds) <- renderColumnParts rest
  Ok (sql::restParts, binds ++ restBinds)

-- Render the JOIN clauses (in order), each " INNER JOIN <table> ON <expr>" or
-- " LEFT JOIN <table> ON <expr>" per its `kind`, accumulating their
-- ON-expression binds left-to-right.  Empty ⇒ no clause.
renderJoins : List Join -> Result String (String, List Literal)
renderJoins [] = Ok ("", [])
renderJoins ((Join { table = t, kind = k, alias = a, on = e })::rest) =
  if not (validIdent t) then Err "render: invalid join table name: \{t}"
  else do
    aliasSql <- renderAliasSuffix a
    (onSql, onBinds) <- renderExpr e
    (restSql, restBinds) <- renderJoins rest
    Ok
      (
        " \{joinKindSql k} \{t}\{aliasSql} ON \{onSql}\{restSql}",
        onBinds ++ restBinds,
      )

joinKindSql : JoinKind -> String
joinKindSql JInner = "INNER JOIN"
joinKindSql JLeft = "LEFT JOIN"

-- The limit/offset clause is rendered as text + its (ordered) binds.  We keep
-- the placeholders parameterized too (LIMIT ? / OFFSET ?) for uniformity.
-- `limOff` is just the text; binds are appended by the caller.
renderLimitOffset : Option Int -> Option Int -> String
renderLimitOffset lm of_ =
  let l = match lm
    Some _ => " LIMIT ?"
    None => ""
  let o = match of_
    Some _ => " OFFSET ?"
    None => ""
  "\{l}\{o}"

-- Render the ORDER BY clause.  Keys are EXPRESSIONS now, so they render through
-- `renderExpr` (a bare `ECol "age"` still renders as plain `age`, keeping every
-- pre-unification rendering byte-identical) and may carry binds — e.g.
-- `ORDER BY (price * ?)`.  Empty key list ⇒ no clause at all.
renderOrderBy : List (SqlExpr, Bool) -> Result String (String, List Literal)
renderOrderBy [] = Ok ("", [])
renderOrderBy keys = map
  ((parts, binds) => (" ORDER BY \{join ", " parts}", binds))
  (renderOrderByParts keys)

renderOrderByParts : List (SqlExpr, Bool) -> Result String (List String, List Literal)
renderOrderByParts [] = Ok ([], [])
renderOrderByParts ((e, asc)::rest) = do
  (sql, binds) <- renderExpr e
  let dir = if asc then "ASC" else "DESC"
  (restParts, restBinds) <- renderOrderByParts rest
  Ok ("\{sql} \{dir}"::restParts, binds ++ restBinds)

limOffSql : String -> String
limOffSql s = s

limOffBinds : String -> Option Int -> Option Int -> List Literal
limOffBinds _ lm of_ =
  let lb = match lm
    Some n => [LInt n]
    None => []
  let ob = match of_
    Some n => [LInt n]
    None => []
  lb ++ ob

-- Render the WHERE clause (with leading " WHERE ") and collect its binds.
renderWhere : Option SqlExpr -> Result String (String, List Literal)
renderWhere None = Ok ("", [])
renderWhere (Some e) =
  map ((sql, binds) => (" WHERE \{sql}", binds)) (renderExpr e)

-- Render an expression to (sql, binds).  Binds accumulate left-to-right.
renderExpr : SqlExpr -> Result String (String, List Literal)
renderExpr (ECol name) =
  if validQualIdent name then
    Ok (name, [])
  else
    Err "render: invalid column name: \{name}"
renderExpr (ELit lit) = Ok ("?", [lit])
renderExpr (EAgg FnCount None) = Ok ("count(*)", [])
renderExpr (EAgg fn (Some operand)) =
  map ((sql, binds) => ("\{aggFnSql fn}(\{sql})", binds)) (renderExpr operand)
renderExpr (EAgg fn None) =
  Err
    "render: \{aggFnSql fn}(*) is not valid — only count(*) may omit its operand"
renderExpr (EBin op l r) = renderBinary (cmpSql op) l r
renderExpr (EArith op l r) = renderBinary (arithSql op) l r
renderExpr (EConcat l r) = renderBinary "||" l r
renderExpr (EAnd l r) = renderBinary "AND" l r
renderExpr (EOr l r) = renderBinary "OR" l r
renderExpr (ENot inner) =
  map ((sql, binds) => ("(NOT \{sql})", binds)) (renderExpr inner)
renderExpr (EIsNull inner) =
  map ((sql, binds) => ("(\{sql} IS NULL)", binds)) (renderExpr inner)
renderExpr (ENotNull inner) =
  map ((sql, binds) => ("(\{sql} IS NOT NULL)", binds)) (renderExpr inner)
renderExpr (ELike x pat) = renderBinary "LIKE" x pat
renderExpr (EIn x vs) = do
  (xsql, xbinds) <- renderExpr x
  (partsSql, partsBinds) <- renderColumnParts vs
  Ok ("(\{xsql} IN (\{join ", " partsSql}))", xbinds ++ partsBinds)
renderExpr (ECase whens els) = do
  (whenSql, whenBinds) <- renderCaseWhens whens
  (elsSql, elsBinds) <- renderCaseElse els
  Ok ("(CASE \{whenSql}\{elsSql}END)", whenBinds ++ elsBinds)
renderExpr (ECoalesce es) = do
  (partsSql, partsBinds) <- renderColumnParts es
  Ok ("coalesce(\{join ", " partsSql})", partsBinds)
renderExpr (EFn name args) = do
  (partsSql, partsBinds) <- renderColumnParts args
  Ok ("\{asciiFold asciiLowerChar name}(\{join ", " partsSql})", partsBinds)

renderCaseWhens : List (SqlExpr, SqlExpr) -> Result String (String, List Literal)
renderCaseWhens [] = Ok ("", [])
renderCaseWhens ((c, r)::rest) = do
  (csql, cbinds) <- renderExpr c
  (rsql, rbinds) <- renderExpr r
  (restSql, restBinds) <- renderCaseWhens rest
  Ok ("WHEN \{csql} THEN \{rsql} \{restSql}", cbinds ++ rbinds ++ restBinds)

renderCaseElse : Option SqlExpr -> Result String (String, List Literal)
renderCaseElse None = Ok ("", [])
renderCaseElse (Some e) = do
  (sql, binds) <- renderExpr e
  Ok ("ELSE \{sql} ", binds)

renderBinary : String -> SqlExpr -> SqlExpr -> Result String (String, List Literal)
renderBinary opSql l r = do
  (lsql, lbinds) <- renderExpr l
  (rsql, rbinds) <- renderExpr r
  Ok ("(\{lsql} \{opSql} \{rsql})", lbinds ++ rbinds)

-- | The canonical SQL name of an aggregate function.  Rendering `EAgg` through
--   this reproduces exactly the strings the legacy `lib.aggregate.aggName` puns
--   on (`count(*)`, `sum(salary)`, …) — so the render output of a shimmed
--   `AggQuery` and a native `Select` agree.
export aggFnSql : AggFn -> String
aggFnSql FnCount = "count"
aggFnSql FnSum = "sum"
aggFnSql FnAvg = "avg"
aggFnSql FnMin = "min"
aggFnSql FnMax = "max"

arithSql : ArithOp -> String
arithSql AAdd = "+"
arithSql ASub = "-"
arithSql AMul = "*"
arithSql ADiv = "/"
arithSql AMod = "%"

cmpSql : CmpOp -> String
cmpSql OpEq = "="
cmpSql OpNe = "<>"
cmpSql OpLt = "<"
cmpSql OpLe = "<="
cmpSql OpGt = ">"
cmpSql OpGe = ">="

-- | A valid SQL identifier for our purposes: non-empty, all chars in
--   `[A-Za-z0-9_]`.  (Quoting/escaping is out of scope; we reject instead.)
validIdent : String -> Bool
validIdent s =
  let chars = stringToChars s
  if arrayLength chars == 0 then
    False
  else
    validIdentGo chars 0 (arrayLength chars)

validIdentGo : Array Char -> Int -> Int -> Bool
validIdentGo chars i n =
  if i >= n then
    True
  else if identChar (charCode chars[i]) then
    validIdentGo chars (i + 1) n
  else
    False

identChar : Int -> Bool
identChar c =
  c >= 48 && c <= 57  -- 0-9
  || c >= 65 && c <= 90  -- A-Z
  || c >= 97 && c <= 122  -- a-z
  || c == 95  -- _

-- | A valid (possibly qualified) identifier for the ON/render path: either a
--   bare `validIdent`, or `table.column` with EXACTLY one `.` and each side a
--   `validIdent`.  This does NOT loosen `validIdent` itself (still used for
--   table names).
validQualIdent : String -> Bool
validQualIdent s =
  let chars = stringToChars s
  match countDots chars 0 (arrayLength chars) 0
    0 => validIdent s
    1 => match splitOnDot s
      (a, b) => validIdent a && validIdent b
    _ => False

countDots : Array Char -> Int -> Int -> Int -> Int
countDots chars i n acc =
  if i >= n then
    acc
  else
    countDots chars (i + 1) n (if charCode chars[i] == 46 then acc + 1 else acc)

-- Split on the first '.' (caller guarantees exactly one).  Returns (before, after).
splitOnDot : String -> (String, String)
splitOnDot s =
  let chars = stringToChars s
  let n = arrayLength chars
  let di = dotIndex chars 0 n
  (stringSlice 0 di s, stringSlice (di + 1) n s)

dotIndex : Array Char -> Int -> Int -> Int
dotIndex chars i n =
  if i >= n then
    n
  else if charCode chars[i] == 46 then
    i
  else
    dotIndex chars (i + 1) n

-- ---------------------------------------------------------------------------
-- compilePred : SqlExpr -> (List Cell -> Bool)
--
-- Compile a predicate to a closure over the RAW cell list (so we can filter on
-- columns the RowType doesn't project).
--
-- ⚠️ SQL logic is THREE-valued (TRUE / FALSE / UNKNOWN) and this evaluator now
-- says so (`Tri`).  It used to collapse UNKNOWN to FALSE at every node, which is
-- *accidentally* right everywhere EXCEPT under a `NOT` — and there it is a
-- silent WRONG ANSWER:
--
--     age  = NULL
--     WHERE NOT age = 30
--       SQL:  NOT (NULL = 30)  =  NOT UNKNOWN  =  UNKNOWN  ⇒ row DROPPED
--       old:  not (False)      =  True                     ⇒ row KEPT  ✗
--
-- The same hole swallowed `NOT (a AND b)` whenever a sub-term was UNKNOWN.  It
-- survived every earlier oracle because none of them put a `NOT` over a nullable
-- column; the SQL-string oracle (test/sql_oracle.sh) caught it on its first run.
--
-- So: evaluate to `Tri`, and collapse to Bool exactly ONCE, at the WHERE / ON /
-- HAVING boundary — "keep the row iff the predicate is definitively TRUE", which
-- is precisely SQL's rule.  AND/OR/NOT/IS NULL follow the standard truth tables
-- (`triAnd` / `triOr` / `triNot`); `IS [NOT] NULL` is the one construct that is
-- never UNKNOWN, which is the whole reason SQL has it.
-- ---------------------------------------------------------------------------

-- | SQL's three truth values.  `TUnknown` is what a comparison against NULL
--   yields — it is NOT the same as `TFalse`, and conflating them mis-evaluates
--   `NOT`.
data Tri = TTrue | TFalse | TUnknown deriving (Eq)

-- NOT: UNKNOWN is a fixpoint (that is the entire subtlety).
triNot : Tri -> Tri
triNot TTrue = TFalse
triNot TFalse = TTrue
triNot TUnknown = TUnknown

-- AND: FALSE dominates (FALSE AND UNKNOWN = FALSE); otherwise UNKNOWN infects.
triAnd : Tri -> Tri -> Tri
triAnd TFalse _ = TFalse
triAnd _ TFalse = TFalse
triAnd TTrue TTrue = TTrue
triAnd _ _ = TUnknown

-- OR: TRUE dominates (TRUE OR UNKNOWN = TRUE); otherwise UNKNOWN infects.
triOr : Tri -> Tri -> Tri
triOr TTrue _ = TTrue
triOr _ TTrue = TTrue
triOr TFalse TFalse = TFalse
triOr _ _ = TUnknown

-- A raw cell in a boolean position: NULL is UNKNOWN, not FALSE.
cellTri : Cell -> Tri
cellTri CNull = TUnknown
cellTri c = boolTri (cellTruthy c)

litTri : Literal -> Tri
litTri LNull = TUnknown
litTri l = boolTri (litTruthy l)

boolTri : Bool -> Tri
boolTri True = TTrue
boolTri False = TFalse

-- | Compile `expr` against a column-name→index resolver into a row predicate.
--   The row is kept iff the predicate evaluates to `TTrue` — SQL's rule.  `Err`
--   on an unknown column name.
export compilePred : (String -> Option Int) -> SqlExpr -> Result String (List Cell -> Bool)
compilePred lookup e = do
  t <- compileTri lookup e
  Ok (cells => t cells == TTrue)

-- The three-valued evaluator.  Everything above the WHERE boundary stays in
-- `Tri`; only `compilePred` collapses it.
compileTri : (String -> Option Int) -> SqlExpr -> Result String (List Cell -> Tri)
compileTri lookup (ECol name) = match lookup name
  None => Err "compilePred: unknown column: \{name}"
  Some i => Ok (cells => cellTri (nthCell cells i))
compileTri _ (ELit lit) = Ok (_ => litTri lit)
compileTri _ (EAgg fn _) =
  Err
    "\{aggFnSql fn}(...): aggregate functions are not allowed in WHERE or a JOIN's ON — put the condition in HAVING"
compileTri lookup (EBin op l r) = compileCmp lookup op l r
compileTri lookup (EArith op l r) = do
  g <- compileOperand lookup (EArith op l r)
  Ok (cells => cellTri (g cells))
compileTri lookup (EConcat l r) = do
  g <- compileOperand lookup (EConcat l r)
  Ok (cells => cellTri (g cells))
-- `LIKE` has its own NULL rule (either side NULL ⇒ UNKNOWN, never a match/miss
-- collapsed via `cellTri`), so it gets a dedicated arm rather than routing
-- through `compileOperand` + `cellTri`.
compileTri lookup (ELike x pat) = do
  gx <- compileOperand lookup x
  gp <- compileOperand lookup pat
  Ok (cells => likeTri (gx cells) (gp cells))
-- `IN` is literally `x = v1 OR x = v2 OR ..`, so its NULL behavior falls out of
-- the SAME `cmpCellsTri OpEq` + tri-OR rules used everywhere else — no separate
-- truth table to get wrong.  `5 IN (1, NULL)` ⇒ UNKNOWN (not FALSE): the `NULL`
-- element's comparison is UNKNOWN, and UNKNOWN survives an OR unless a TRUE is
-- found.  Verified against `sqlite3` — see findings.
compileTri lookup (EIn x vs) = do
  gx <- compileOperand lookup x
  gvs <- compileProjections lookup vs
  Ok (cells => inTri (gx cells) (map (g => g cells) gvs))
compileTri lookup (ECase whens els) = do
  g <- compileOperand lookup (ECase whens els)
  Ok (cells => cellTri (g cells))
compileTri lookup (ECoalesce es) = do
  g <- compileOperand lookup (ECoalesce es)
  Ok (cells => cellTri (g cells))
compileTri lookup (EFn name args) = do
  g <- compileOperand lookup (EFn name args)
  Ok (cells => cellTri (g cells))
compileTri lookup (EAnd l r) = do
  pl <- compileTri lookup l
  pr <- compileTri lookup r
  Ok (cells => triAnd (pl cells) (pr cells))
compileTri lookup (EOr l r) = do
  pl <- compileTri lookup l
  pr <- compileTri lookup r
  Ok (cells => triOr (pl cells) (pr cells))
compileTri lookup (ENot inner) = do
  p <- compileTri lookup inner
  Ok (cells => triNot (p cells))
-- `IS NULL` / `IS NOT NULL` are the two constructs that are NEVER UNKNOWN — a
-- NULL operand is exactly what they are asking about.
compileTri lookup (EIsNull inner) = do
  g <- compileOperand lookup inner
  Ok (cells => boolTri (cellIsNull (g cells)))
compileTri lookup (ENotNull inner) = do
  g <- compileOperand lookup inner
  Ok (cells => boolTri (not (cellIsNull (g cells))))

-- Compile a comparison.  Both operands resolve to a `List Cell -> Cell`
-- accessor; a NULL on either side makes the result UNKNOWN (NOT false), which is
-- what lets a `NOT` above it stay UNKNOWN rather than flipping to TRUE.
compileCmp : (String -> Option Int) -> CmpOp -> SqlExpr -> SqlExpr -> Result String (List Cell -> Tri)
compileCmp lookup op l r = do
  gl <- compileOperand lookup l
  gr <- compileOperand lookup r
  Ok (cells => cmpCellsTri op (gl cells) (gr cells))

-- An operand is a column (resolved to an index accessor), a literal (a constant
-- cell), or an arithmetic expression (both sides compiled to accessors, then
-- combined per row via `evalArith`).  Returns a `List Cell -> Cell` accessor.
-- Exported so `lib.mutate` can evaluate UPDATE SET right-hand sides.
export compileOperand : (String -> Option Int) -> SqlExpr -> Result String (List Cell -> Cell)
compileOperand lookup (ECol name) = match lookup name
  None => Err "compilePred: unknown column: \{name}"
  Some i => Ok (cells => nthCell cells i)
compileOperand lookup (ELit lit) = Ok (_ => litToCell lit)
compileOperand lookup (EArith op l r) = do
  gl <- compileOperand lookup l
  gr <- compileOperand lookup r
  Ok (cells => evalArith op (gl cells) (gr cells))
compileOperand lookup (EConcat l r) = do
  gl <- compileOperand lookup l
  gr <- compileOperand lookup r
  Ok (cells => evalConcat (gl cells) (gr cells))
compileOperand lookup (ECase whens els) = do
  wtri <- compileCaseWhens lookup whens
  gEls <- compileCaseElseVal lookup els
  Ok (evalCaseGo wtri gEls)
compileOperand lookup (ECoalesce es) = do
  gs <- compileProjections lookup es
  Ok (evalCoalesceGo gs)
compileOperand lookup (EFn name args) = do
  gs <- compileProjections lookup args
  compileFnCall name gs
-- An `EAgg` reaching here is an aggregate in a per-ROW position: either inside a
-- WHERE/ON, or nested inside another aggregate's operand.  Both are SQL errors.
compileOperand _ (EAgg fn _) =
  Err
    "\{aggFnSql fn}(...): aggregate functions cannot be nested or used per-row — they are only valid in the SELECT list, HAVING, or ORDER BY of a grouped query"
-- `ELike`/`EIn` (and the boolean-combinator nodes `EBin`/`EAnd`/`EOr`/`ENot`/
-- `EIsNull`/`ENotNull`) are not usable as VALUE operands — a pre-existing
-- limitation this task does not extend (real SQLite treats a boolean as an
-- Int 0/1/NULL value; this engine does not, for ANY of these nodes).
compileOperand lookup _ = Err "compilePred: operand must be a column or literal"

-- | Compile any `SqlExpr` value operand to a per-row `List Cell -> Cell`
--   accessor (an alias of `compileOperand` for the UPDATE SET call site).
export compileValue : (String -> Option Int) -> SqlExpr -> Result String (List Cell -> Cell)
compileValue = compileOperand

-- ---------------------------------------------------------------------------
-- CASE evaluation
--
-- WHEN conditions are three-valued (a NULL/UNKNOWN condition is treated as not
-- taken — `CASE WHEN NULL THEN 'a' ELSE 'b' END` is `'b'`, verified against
-- `sqlite3`), so each condition compiles via `compileTri`, collapsed to a
-- branch decision exactly like the WHERE boundary: the branch fires iff its
-- condition is definitively `TTrue`.  The result expressions are ordinary
-- VALUE operands.
-- ---------------------------------------------------------------------------

compileCaseWhens : (String -> Option Int) -> List (SqlExpr, SqlExpr) -> Result String (List (List Cell -> Tri, List Cell -> Cell))
compileCaseWhens _ [] = Ok []
compileCaseWhens lookup ((c, r)::rest) = do
  ct <- compileTri lookup c
  cr <- compileOperand lookup r
  rest2 <- compileCaseWhens lookup rest
  Ok ((ct, cr)::rest2)

compileCaseElseVal : (String -> Option Int) -> Option SqlExpr -> Result String (List Cell -> Cell)
compileCaseElseVal _ None = Ok (_ => CNull)
compileCaseElseVal lookup (Some e) = compileOperand lookup e

evalCaseGo : List (List Cell -> Tri, List Cell -> Cell) -> (List Cell -> Cell) -> List Cell -> Cell
evalCaseGo [] gEls cells = gEls cells
evalCaseGo ((ct, cr)::rest) gEls cells =
  if ct cells == TTrue then
    cr cells
  else
    evalCaseGo rest gEls cells

-- ---------------------------------------------------------------------------
-- COALESCE / IFNULL evaluation: the first non-NULL argument, NULL if all are
-- (or the list is empty — unreachable, the parser demands at least one arg).
-- ---------------------------------------------------------------------------

evalCoalesceGo : List (List Cell -> Cell) -> List Cell -> Cell
evalCoalesceGo [] _ = CNull
evalCoalesceGo (g::gs) cells =
  let c = g cells
  if cellIsNull c then evalCoalesceGo gs cells else c

-- ---------------------------------------------------------------------------
-- `x IN (v1, .., vn)` — three-valued via the SAME `cmpCellsTri OpEq` used by
-- ordinary comparisons: TRUE if `x` equals any element; UNKNOWN if it matches
-- none but at least one element (or `x` itself) is NULL; else FALSE.
-- ---------------------------------------------------------------------------

inTri : Cell -> List Cell -> Tri
inTri x vs = inTriGo x vs False

inTriGo : Cell -> List Cell -> Bool -> Tri
inTriGo _ [] sawUnknown = if sawUnknown then TUnknown else TFalse
inTriGo x (v::rest) sawUnknown = match cmpCellsTri OpEq x v
  TTrue => TTrue
  TFalse => inTriGo x rest sawUnknown
  TUnknown => inTriGo x rest True

-- ---------------------------------------------------------------------------
-- `||` concatenation and `LIKE` share a coercion rule: SQLite auto-converts a
-- non-NULL, non-text operand to its text representation (`5 || 'x'` is
-- `"5x"`; `5 LIKE '5%'` is true) — verified against `sqlite3`.  A BLOB is
-- decoded byte-for-byte via `charFromCode` (best-effort; SQLite's own blob
-- text coercion is likewise a raw byte reinterpretation, but only ASCII bytes
-- are verified here — see findings).
-- ---------------------------------------------------------------------------

cellToTextOp : Cell -> Option String
cellToTextOp CNull = None
cellToTextOp (CInt n) = Some "\{n}"
cellToTextOp (CFloat f) = Some "\{f}"
cellToTextOp (CText s) = Some s
cellToTextOp (CBlob b) = Some (blobToText b)

blobToText : Array Int -> String
blobToText b = fromChars (blobToCharsGo b 0 (arrayLength b))

blobToCharsGo : Array Int -> Int -> Int -> List Char
blobToCharsGo b i n =
  if i >= n then []
  else match charFromCode b[i]
    Some c => c :: blobToCharsGo b (i + 1) n
    None => blobToCharsGo b (i + 1) n

evalConcat : Cell -> Cell -> Cell
evalConcat a b = match (cellToTextOp a, cellToTextOp b)
  (Some sa, Some sb) => CText (sa ++ sb)
  _ => CNull

likeTri : Cell -> Cell -> Tri
likeTri x pat = match (cellToTextOp x, cellToTextOp pat)
  (Some s, Some p) => boolTri (likeMatch (asciiFold asciiUpperChar s) (asciiFold asciiUpperChar p))
  _ => TUnknown

-- A classic backtracking LIKE matcher: `%` matches any run (incl. empty),
-- `_` matches exactly one char.  Both operands are pre-folded to the SAME
-- case by the caller, so this is a plain codepoint comparison.
likeMatch : String -> String -> Bool
likeMatch text pat =
  let tc = stringToChars text
  let pc = stringToChars pat
  likeMatchGo tc (arrayLength tc) 0 pc (arrayLength pc) 0

likeMatchGo : Array Char -> Int -> Int -> Array Char -> Int -> Int -> Bool
likeMatchGo tc tn ti pc pn pi =
  if pi >= pn then
    ti >= tn
  else if pc[pi] == '%' then
    likeMatchStar tc tn ti pc pn (pi + 1)
  else if pc[pi] == '_' then
    ti < tn && likeMatchGo tc tn (ti + 1) pc pn (pi + 1)
  else
    ti < tn && tc[ti] == pc[pi] && likeMatchGo tc tn (ti + 1) pc pn (pi + 1)

likeMatchStar : Array Char -> Int -> Int -> Array Char -> Int -> Int -> Bool
likeMatchStar tc tn ti pc pn pi =
  if likeMatchGo tc tn ti pc pn pi then
    True
  else if ti < tn then
    likeMatchStar tc tn (ti + 1) pc pn pi
  else
    False

-- ---------------------------------------------------------------------------
-- ASCII-only case fold.  SQLite's built-in `LIKE`/`UPPER`/`LOWER` fold ONLY
-- `a`-`z`/`A`-`Z` — unlike `string.toUpper`/`toLower` (full Unicode, so
-- `upper('café')` stays `'café'` in real sqlite but `string.toUpper "café"`
-- would produce `"CAFÉ"`).  Verified against `sqlite3`; see findings — this is
-- exactly the kind of stdlib/domain-semantics mismatch worth flagging rather
-- than silently reusing the Unicode-correct function and getting a wrong
-- answer on non-ASCII input.
-- ---------------------------------------------------------------------------

-- Exported (not just used locally) so `lib.sqlparse` can lowercase an `EFn`
-- name for rendering with the SAME ASCII-only fold, rather than hand-rolling
-- a second copy (a first draft did exactly that; `medaka lint`'s cross-file
-- `rule-duplicate-body` caught the two `charFromCodeOr`-shaped helpers).
export asciiUpperChar : Char -> Char
asciiUpperChar c =
  let n = charCode c
  if n >= 97 && n <= 122 then charFromCodeOr c (n - 32) else c

export asciiLowerChar : Char -> Char
asciiLowerChar c =
  let n = charCode c
  if n >= 65 && n <= 90 then charFromCodeOr c (n + 32) else c

charFromCodeOr : Char -> Int -> Char
charFromCodeOr fallback n = match charFromCode n
  Some c => c
  None => fallback

export asciiFold : (Char -> Char) -> String -> String
asciiFold f s =
  let chars = stringToChars s
  fromChars (asciiFoldGo f chars 0 (arrayLength chars))

asciiFoldGo : (Char -> Char) -> Array Char -> Int -> Int -> List Char
asciiFoldGo f chars i n =
  if i >= n then
    []
  else
    f chars[i] :: asciiFoldGo f chars (i + 1) n

-- ---------------------------------------------------------------------------
-- Scalar string functions.  Every one of these auto-coerces a non-NULL,
-- non-text operand to text first (`length(12345)` is `5`, `upper(123)` is
-- `"123"` — verified against `sqlite3`), via the SAME `cellToTextOp` `||`/
-- `LIKE` use; any NULL argument makes the whole call NULL.
-- ---------------------------------------------------------------------------

compileFnCall : String -> List (List Cell -> Cell) -> Result String (List Cell -> Cell)
compileFnCall "LENGTH" [g] = Ok (cells => fnLength (g cells))
compileFnCall "UPPER" [g] = Ok (cells => fnUpperSql (g cells))
compileFnCall "LOWER" [g] = Ok (cells => fnLowerSql (g cells))
compileFnCall "TRIM" [g] = Ok (cells => fnTrimSql (g cells))
compileFnCall "LTRIM" [g] = Ok (cells => fnLtrimSql (g cells))
compileFnCall "RTRIM" [g] = Ok (cells => fnRtrimSql (g cells))
compileFnCall "REPLACE" [g1, g2, g3] =
  Ok (cells => fnReplaceSql (g1 cells) (g2 cells) (g3 cells))
compileFnCall "SUBSTR" [g1, g2] = Ok (cells => fnSubstr2 (g1 cells) (g2 cells))
compileFnCall "SUBSTR" [g1, g2, g3] =
  Ok (cells => fnSubstr3 (g1 cells) (g2 cells) (g3 cells))
-- Unreachable: the parser validates name+arity before ever building an `EFn`
-- node.  Kept so `compileFnCall` stays total rather than panicking.
compileFnCall name _ = Err "internal: bad arity for function '\{name}'"

fnLength : Cell -> Cell
fnLength c = match cellToTextOp c
  None => CNull
  Some s => CInt (stringLength s)

fnUpperSql : Cell -> Cell
fnUpperSql c = match cellToTextOp c
  None => CNull
  Some s => CText (asciiFold asciiUpperChar s)

fnLowerSql : Cell -> Cell
fnLowerSql c = match cellToTextOp c
  None => CNull
  Some s => CText (asciiFold asciiLowerChar s)

-- SQLite's 1-argument `trim`/`ltrim`/`rtrim` strip ONLY the ASCII space
-- character (0x20) — NOT general whitespace (tab/newline survive), verified
-- against `sqlite3`.  This is a real divergence from `string.trim*` (which
-- strips all Unicode whitespace) — see findings.
fnTrimSql : Cell -> Cell
fnTrimSql c = match cellToTextOp c
  None => CNull
  Some s => CText (spaceTrimRight (spaceTrimLeft s))

fnLtrimSql : Cell -> Cell
fnLtrimSql c = match cellToTextOp c
  None => CNull
  Some s => CText (spaceTrimLeft s)

fnRtrimSql : Cell -> Cell
fnRtrimSql c = match cellToTextOp c
  None => CNull
  Some s => CText (spaceTrimRight s)

spaceTrimLeft : String -> String
spaceTrimLeft s =
  let chars = stringToChars s
  let n = arrayLength chars
  stringSlice (spaceTrimLeftIdx chars 0 n) n s

spaceTrimLeftIdx : Array Char -> Int -> Int -> Int
spaceTrimLeftIdx chars i n =
  if i < n && charCode chars[i] == 32 then
    spaceTrimLeftIdx chars (i + 1) n
  else
    i

spaceTrimRight : String -> String
spaceTrimRight s =
  let chars = stringToChars s
  let n = arrayLength chars
  stringSlice 0 (spaceTrimRightIdx chars n) s

spaceTrimRightIdx : Array Char -> Int -> Int
spaceTrimRightIdx chars j =
  if j > 0 && charCode chars[j - 1] == 32 then
    spaceTrimRightIdx chars (j - 1)
  else
    j

-- `replace(X, Y, Z)`: every non-overlapping occurrence of Y replaced by Z;
-- unchanged if Y is empty.  `string.replaceAll` already has EXACTLY this
-- contract (verified against `sqlite3`, including the empty-`Y` case), so it
-- is reused directly rather than re-implemented.
fnReplaceSql : Cell -> Cell -> Cell -> Cell
fnReplaceSql xc yc zc = match (cellToTextOp xc, cellToTextOp yc, cellToTextOp zc)
  (Some s, Some old, Some new) => CText (replaceAll old new s)
  _ => CNull

-- ---------------------------------------------------------------------------
-- `substr(X, Y [, Z])` — SQLite semantics, derived and checked exhaustively
-- against `sqlite3` (1-indexed; Y=0 and negative Y/Z all have specific rules
-- that are easy to get subtly wrong — see findings for the derivation and the
-- verification matrix).  Unified formula: let `vs` be the 0-based virtual
-- start position (`Y - 1` for `Y >= 0`; `n + Y` for `Y < 0`, i.e. "count from
-- the end").  With no `Z`: slice from `clamp(vs, 0, n)` to `n`.  With `Z >=
-- 0`: slice `[clamp(vs,0,n), clamp(vs+Z,0,n))`.  With `Z < 0` ("the
-- characters preceding the Y-th"): slice `[clamp(vs+Z,0,n), clamp(vs,0,n))`.
-- ---------------------------------------------------------------------------

fnSubstr2 : Cell -> Cell -> Cell
fnSubstr2 xc yc = match (cellToTextOp xc, cellToIntPart yc)
  (Some s, Some y) => CText (substrFrom s y)
  _ => CNull

substrFrom : String -> Int -> String
substrFrom s y =
  let n = stringLength s
  let vs = substrVirtualStart n y
  stringSlice (clampInt vs 0 n) n s

fnSubstr3 : Cell -> Cell -> Cell -> Cell
fnSubstr3 xc yc zc = match (cellToTextOp xc, cellToIntPart yc, cellToIntPart zc)
  (Some s, Some y, Some z) => CText (substrFromLen s y z)
  _ => CNull

substrFromLen : String -> Int -> Int -> String
substrFromLen s y z =
  let n = stringLength s
  let vs = substrVirtualStart n y
  let start = clampInt (if z >= 0 then vs else vs + z) 0 n
  let end = clampInt (if z >= 0 then vs + z else vs) 0 n
  if end <= start then "" else stringSlice start end s

substrVirtualStart : Int -> Int -> Int
substrVirtualStart n y = if y >= 0 then y - 1 else n + y

clampInt : Int -> Int -> Int -> Int
clampInt v lo hi = max lo (min v hi)

-- ---------------------------------------------------------------------------
-- Arithmetic evaluation (SQLite semantics)
--
-- NULL propagation: either operand NULL ⇒ NULL.  `+ - *`: CInt⊕CInt ⇒ CInt,
-- otherwise coerce to CFloat.  `/`: both-int ⇒ integer division truncating
-- toward zero (÷0 ⇒ NULL); either-real ⇒ float division (÷0.0 ⇒ NULL).  `%`:
-- integer modulo on the integer parts (sign follows the dividend; x%0 ⇒ NULL).
--
-- A TEXT (or BLOB) operand is COERCED to a number first — SQLite's rule: take
-- the longest leading numeric prefix, 0 if there is none (`'5'+2 = 7`,
-- `'5abc'+2 = 7`, `'abc'+2 = 2`, `'3.5'*2 = 7.0`).  See `coerceNumericCell` for
-- the exact prefix grammar, all verified against `sqlite3`.
-- ---------------------------------------------------------------------------

evalArith : ArithOp -> Cell -> Cell -> Cell
evalArith op a b =
  if cellIsNull a || cellIsNull b then
    CNull
  else
    evalArithNum op (coerceNumericCell a) (coerceNumericCell b)

-- After coercion both operands are `CInt`/`CFloat`, so the numeric arms below
-- always fire (their `_ => CNull` fall-throughs are defensive dead code).
evalArithNum : ArithOp -> Cell -> Cell -> Cell
evalArithNum AMod a b = evalMod a b
evalArithNum ADiv a b = evalDiv a b
evalArithNum op a b = evalAddSubMul op a b

-- ---------------------------------------------------------------------------
-- SQLite text→numeric coercion (applied to an arithmetic operand).
--
-- Numbers pass through unchanged; a TEXT/BLOB operand yields the value of its
-- longest leading NUMERIC PREFIX — optional leading whitespace, optional sign,
-- integer and/or fractional digits, and an optional `e`/`E` exponent (which is
-- only consumed when at least one exponent digit follows — `'5e'` ⇒ 5, not an
-- error).  A prefix that carries a `.` or a valid exponent is REAL (`CFloat`),
-- otherwise INTEGER (`CInt`); an integer that overflows Medaka's `Int` falls
-- back to `CFloat`, mirroring SQLite's own integer→real overflow.  NO numeric
-- prefix (`'abc'`, `''`, `'  '`, `'0x10'` past the `0`) ⇒ `CInt 0`.
--
-- Verified against `sqlite3`; see findings/sql-arith-rowid-coercion.md.  Two
-- deliberately-unmatched edges are documented there: text that parses to an
-- integer in `(2^62, 2^63)` becomes REAL here (Medaka `Int` is 63-bit, SQLite's
-- is 64-bit), and `'inf'`/`'nan'` coerce to 0 (SQLite agrees for those literal
-- spellings).
coerceNumericCell : Cell -> Cell
coerceNumericCell (CInt n) = CInt n
coerceNumericCell (CFloat f) = CFloat f
coerceNumericCell (CText s) = coerceTextNumeric s
coerceNumericCell (CBlob b) = coerceTextNumeric (blobToText b)
coerceNumericCell CNull = CNull

coerceTextNumeric : String -> Cell
coerceTextNumeric s =
  let chars = stringToChars s
  let n = arrayLength chars
  let ws = skipNumWs chars 0 n
  let afterSign = if ws < n && isSignChar chars[ws] then ws + 1 else ws
  let intEnd = skipDigits chars afterSign n
  let intDigits = intEnd - afterSign
  let hasDot = intEnd < n && charCode chars[intEnd] == 46
  let fracStart = if hasDot then intEnd + 1 else intEnd
  let fracEnd = if hasDot then skipDigits chars fracStart n else intEnd
  let fracDigits = fracEnd - fracStart
  if intDigits <= 0 && fracDigits <= 0 then CInt 0
  else
    let expEnd = parseExpEnd chars fracEnd n
    let hasExp = expEnd > fracEnd
    let numEnd = if hasExp then expEnd else fracEnd
    let prefix = stringSlice ws numEnd s
    if hasDot || hasExp then floatCellOf prefix
    else match toInt prefix
      Some i => CInt i
      None => floatCellOf prefix

floatCellOf : String -> Cell
floatCellOf s = match toFloat s
  Some f => CFloat f
  None => CFloat 0.0  -- defensive: an extracted prefix is always well-formed

-- ASCII whitespace SQLite skips before a number: space + \t \n \v \f \r.
isNumWs : Char -> Bool
isNumWs c =
  let k = charCode c
  k == 32 || k >= 9 && k <= 13

isSignChar : Char -> Bool
isSignChar c = charCode c == 43 || charCode c == 45  -- + -

isExpChar : Char -> Bool
isExpChar c = charCode c == 101 || charCode c == 69  -- e E

isDigitCode : Int -> Bool
isDigitCode k = k >= 48 && k <= 57

skipNumWs : Array Char -> Int -> Int -> Int
skipNumWs chars i n =
  if i < n && isNumWs chars[i] then
    skipNumWs chars (i + 1) n
  else
    i

skipDigits : Array Char -> Int -> Int -> Int
skipDigits chars i n =
  if i < n && isDigitCode (charCode chars[i]) then
    skipDigits chars (i + 1) n
  else
    i

-- The end index of a VALID exponent starting at `i` (`e`/`E`, optional sign,
-- ≥1 digit), or `i` itself when there is no valid exponent — so a dangling
-- `'5e'` / `'5e+'` leaves the number ending before the `e`.
parseExpEnd : Array Char -> Int -> Int -> Int
parseExpEnd chars i n =
  if i < n && isExpChar chars[i] then
    let j = if i + 1 < n && isSignChar chars[i + 1] then i + 2 else i + 1
    let k = skipDigits chars j n
    if k > j then k else i
  else i

-- `+ - *`: integer result when both operands are integers, else float.
evalAddSubMul : ArithOp -> Cell -> Cell -> Cell
evalAddSubMul op a b = match (a, b)
  (CInt x, CInt y) => CInt (intArith op x y)
  (CInt x, CFloat y) => CFloat (floatArith op (intToFloat x) y)
  (CFloat x, CInt y) => CFloat (floatArith op x (intToFloat y))
  (CFloat x, CFloat y) => CFloat (floatArith op x y)
  _ => CNull

intArith : ArithOp -> Int -> Int -> Int
intArith AAdd x y = x + y
intArith ASub x y = x - y
intArith AMul x y = x * y
intArith _ x _ = x  -- ADiv/AMod never reach here (handled upstream)

floatArith : ArithOp -> Float -> Float -> Float
floatArith AAdd x y = x + y
floatArith ASub x y = x - y
floatArith AMul x y = x * y
floatArith _ x _ = x  -- ADiv/AMod never reach here (handled upstream)

-- Division: both-int ⇒ truncating integer division; any-float ⇒ float division.
-- Division by zero (integer or real) ⇒ NULL, matching sqlite.
evalDiv : Cell -> Cell -> Cell
evalDiv a b = match (a, b)
  (CInt x, CInt y) => if y == 0 then CNull else CInt (x / y)
  (CInt x, CFloat y) => if y == 0.0 then CNull else CFloat (intToFloat x / y)
  (CFloat x, CInt y) => if y == 0 then CNull else CFloat (x / intToFloat y)
  (CFloat x, CFloat y) => if y == 0.0 then CNull else CFloat (x / y)
  _ => CNull

-- Modulo: operate on the integer parts (floats truncate toward zero via the
-- pattern below only reaching integer cells here); x%0 ⇒ NULL; sign follows the
-- dividend (Medaka `%` matches sqlite for negatives, verified).
evalMod : Cell -> Cell -> Cell
evalMod a b = match (cellToIntPart a, cellToIntPart b)
  (Some x, Some y) => if y == 0 then CNull else CInt (x % y)
  _ => CNull

-- Truncate a numeric cell to its integer part (toward zero).  Non-numeric ⇒ None.
cellToIntPart : Cell -> Option Int
cellToIntPart (CInt n) = Some n
cellToIntPart (CFloat f) = Some (floatToInt f)
cellToIntPart _ = None

-- ---------------------------------------------------------------------------
-- Cell / comparison helpers (used by compilePred)
-- ---------------------------------------------------------------------------

cellIsNull : Cell -> Bool
cellIsNull CNull = True
cellIsNull _ = False

-- A bare column/literal in a boolean position: SQLite treats nonzero numeric as
-- true, NULL/zero/empty as false-ish.
cellTruthy : Cell -> Bool
cellTruthy CNull = False
cellTruthy (CInt n) = n != 0
cellTruthy (CFloat f) = f != 0.0
cellTruthy (CText s) = stringLength s > 0
cellTruthy (CBlob _) = True

litTruthy : Literal -> Bool
litTruthy LNull = False
litTruthy (LInt n) = n != 0
litTruthy (LFloat f) = f != 0.0
litTruthy (LText s) = stringLength s > 0
litTruthy (LBlob _) = True

litToCell : Literal -> Cell
litToCell (LInt n) = CInt n
litToCell (LText s) = CText s
litToCell (LFloat f) = CFloat f
litToCell (LBlob b) = CBlob b
litToCell LNull = CNull

-- Compare two cells under `op`.  Any NULL operand ⇒ UNKNOWN (SQL), NOT False —
-- see the `Tri` note above `compilePred`.  Numeric cells (CInt/CFloat) compare
-- numerically across the int/float split.
cmpCellsTri : CmpOp -> Cell -> Cell -> Tri
cmpCellsTri op a b =
  if cellIsNull a || cellIsNull b
  then TUnknown
  else match cmpOrder a b
    None   => TFalse                -- incomparable shapes ⇒ definitively unequal
    Some o => boolTri (applyCmp op o)

-- A three-way ordering of two non-null cells, or None if the shapes are not comparable.
cmpOrder : Cell -> Cell -> Option Ordering
cmpOrder a b = match (a, b)
  (CInt x, CInt y) => Some (compare x y)
  (CFloat x, CFloat y) => Some (compare x y)
  (CInt x, CFloat y) => Some (compare (intToFloat x) y)
  (CFloat x, CInt y) => Some (compare x (intToFloat y))
  (CText x, CText y) => Some (compare x y)
  (CBlob x, CBlob y) => Some (compare (arrayLength x) (arrayLength y))
  _ => None

applyCmp : CmpOp -> Ordering -> Bool
applyCmp op o = match (op, o)
  (OpEq, Eq) => True
  (OpNe, Eq) => False
  (OpNe, _) => True
  (OpLt, Lt) => True
  (OpLe, Gt) => False
  (OpLe, _) => True
  (OpGt, Gt) => True
  (OpGe, Lt) => False
  (OpGe, _) => True
  _ => False

-- ---------------------------------------------------------------------------
-- The unified executor
--
-- ONE pipeline, running SQL's real evaluation order:
--
--   FROM → JOIN → WHERE → GROUP BY → HAVING → project → DISTINCT → ORDER BY
--     → LIMIT/OFFSET → decode
--
-- `runPipeline` does everything up to and including ORDER BY, and hands back the
-- final, ordered, PROJECTED cell rows.  The two public entry points differ ONLY
-- in what they do after that — which is exactly the `Eq a` split:
--
--   * `query`         : slice (offset/limit) → decode.       No constraint.
--   * `queryDistinct` : decode → nub → slice.                Needs `Eq a`.
--
-- DISTINCT dedups on DECODED values, so it cannot live in `runPipeline` (which
-- is still in cell-land) without dragging `Eq a` onto plain `query`.  Keeping
-- `query` unconstrained is a hard invariant — do not "simplify" these together.
-- ---------------------------------------------------------------------------

-- | Execute a `Select` and decode each result row via `rt`.  Ignores `distinct`
--   (see `queryDistinct`).  A decode error on any row aborts the whole query.
export query : Db -> Select -> RowType a -> Result String (List a)
query db sel rt = do
  rows <- runPipeline db sel
  decodeCells rt (applyOffsetLimit (selOffset sel) (selLimit sel) rows) []

-- | Execute a `Select` with DISTINCT semantics: identical to `query` through
--   ORDER BY, but dedups on the DECODED, PROJECTED rows and applies LIMIT/OFFSET
--   AFTER the dedup (SQL: DISTINCT collapses the result set, LIMIT slices what's
--   left).  `nub` is stable, so the ORDER BY ordering survives the dedup.
export queryDistinct : Eq a => Db -> Select -> RowType a -> Result String (List a)
queryDistinct db sel rt = do
  rows <- runPipeline db sel
  decoded <- decodeCells rt rows []
  Ok (dropTakeList (selOffset sel) (selLimit sel) (nub decoded))

selLimit : Select -> Option Int
selLimit sel = sel.limit

selOffset : Select -> Option Int
selOffset sel = sel.offset

-- The shared engine: source rows → WHERE → (grouped | flat) → ordered, projected
-- cell rows.  Everything except DISTINCT, LIMIT/OFFSET, and decode.
runPipeline : Db -> Select -> Result String (List (List Cell))
runPipeline db (Select { from = tbl, fromAlias = fa, joins = js, where_ = w, groupBy = gb, having = h, orderBy = ob, columns = cols }) = do
  (lookup, rawRows) <- sourceRows db tbl fa js
  pred <- compileWhere lookup w
  let kept = filter pred rawRows
  if isAggregate gb h ob cols then
    runGrouped lookup gb h ob cols kept
  else
    runFlat lookup ob cols kept

-- FROM + JOINs → (combined column resolver, materialized wide rows).
-- The no-join case keeps its own single-table lookup (`columnIndex` over the one
-- CREATE TABLE) rather than routing through the join machinery, so a plain
-- single-table query behaves exactly as it did before joins existed.
--
-- An aliased `from` table with NO joins still routes through the join machinery
-- (a one-table `mkJoinLookup`) so that `alias.column` resolves and the real name
-- is hidden — matching SQLite.  The fast single-table path is reserved for the
-- un-aliased, un-joined common case, keeping its resolution byte-identical.
sourceRows : Db -> String -> Option String -> List Join -> Result String (String -> Option Int, List (List Cell))
sourceRows db tbl None [] = do
  entry <- findTable db tbl
  let lookup = mkLookup (schemaSql entry)
  (pkIdx, rows) <- scanTableRowsIpk db tbl
  Ok (lookup, map (rowCellsWithIpk pkIdx) rows)
sourceRows db tbl fromAlias js = do
  let fromRef = (tbl, optOr fromAlias tbl)
  infos <- gatherJoinInfos db (fromRef :: map joinRefPair js) 0 []
  let lookup = mkJoinLookup (map infoLookup infos)
  joined <- runJoins lookup infos js
  Ok (lookup, joined)

-- (real table name to scan, effective name to resolve qualified references by).
joinRefPair : Join -> (String, String)
joinRefPair j = (joinTable j, joinEffName j)

-- | Is this an aggregate query?  SQL's rule: yes if there is a GROUP BY, OR a
--   HAVING (a HAVING with no GROUP BY still collapses the table to one group),
--   OR an aggregate function anywhere in the select list / HAVING / ORDER BY.
isAggregate : List SqlExpr -> Option SqlExpr -> List (SqlExpr, Bool) -> List SqlExpr -> Bool
isAggregate gb h ob cols = match (gb, h)
  ([], None) => containsAgg (cols ++ map fst ob)
  _ => True

-- ---------------------------------------------------------------------------
-- The ungrouped path
--
-- Sort keys are evaluated against the RAW (pre-projection) row.  That is what
-- retires the old v1 limitation "ORDER BY cannot reference a computed column":
-- a computed column IS just an expression over the raw columns, so `ORDER BY
-- (price * qty)` evaluates the very same expression the select list projects —
-- no need to look it up in the projected row.  It also keeps SQL's other
-- allowance (ORDER BY on a column that is NOT in the select list) working.
-- ---------------------------------------------------------------------------

runFlat : (String -> Option Int) -> List (SqlExpr, Bool) -> List SqlExpr -> List (List Cell) -> Result String (List (List Cell))
runFlat lookup ob cols kept = do
  projEvals <- compileProjections lookup cols
  sortKeys <- compileSortKeys lookup ob
  Ok (map fst (sortPairs sortKeys (pairRows cols projEvals kept)))

-- ---------------------------------------------------------------------------
-- The grouped path
--
-- Each group reduces to a SYNTHETIC row: the group-key cells (in `groupBy`
-- order) followed by one cell per distinct aggregate.  The select list, HAVING,
-- and ORDER BY are then REWRITTEN against that synthetic row — every
-- sub-expression that is structurally a GROUP BY key becomes a positional
-- reference, every `EAgg` becomes a positional reference to its computed cell,
-- and a bare column that is neither is the SQL error "must appear in the GROUP BY
-- clause".  After the rewrite the ordinary `compileOperand`/`compilePred`
-- machinery runs unchanged over the synthetic row — the grouped and ungrouped
-- paths share the whole expression evaluator.
--
-- Groups come out key-ascending (SQLite value ordering), matching what
-- `sqlite3` prints for `GROUP BY k` and what the legacy `queryAgg` promised.  An
-- explicit ORDER BY then sorts on top, so it inherits key-ascending as a stable
-- tiebreak instead of leaving equal-ranked groups in an arbitrary order.
-- ---------------------------------------------------------------------------

runGrouped : (String -> Option Int) -> List SqlExpr -> Option SqlExpr -> List (SqlExpr, Bool) -> List SqlExpr -> List (List Cell) -> Result String (List (List Cell))
runGrouped lookup gb h ob cols kept = do
  -- 1. GROUP BY: evaluate the key expressions per raw row, bucket, sort by key.
  keyEvals <- compileProjections lookup gb
  let groups = groupRows gb keyEvals kept
  -- 2. Reduce every distinct aggregate mentioned anywhere to one cell per group.
  let obExprs = map fst ob
  let aggs = collectAggs (cols ++ optionToList h ++ obExprs)
  aggEvals <- compileAggs lookup aggs
  let synths = map ((k, rows) => k ++ map (f => f rows) aggEvals) groups
  -- 3. Rewrite the post-group expressions against the synthetic row.
  let slookup = synthLookup (length gb + length aggs)
  hR <- rewriteOptPostGroup gb aggs h
  colsR <- rewriteAllPostGroup gb aggs cols
  obR <- rewriteAllPostGroup gb aggs obExprs
  -- 4. HAVING → project → ORDER BY, all over the synthetic row.
  hpred <- compileWhere slookup hR
  let survivors = filter hpred synths
  projEvals <- compileProjections slookup colsR
  sortKeys <- compileSortKeys slookup (zipKeys obR (map snd ob))
  Ok (map fst (sortPairs sortKeys (pairRows colsR projEvals survivors)))

-- Bucket rows by their group key.  NO group-by keys ⇒ exactly ONE group over the
-- whole (possibly empty) input, which is what makes `SELECT count(*) FROM t`
-- return a single `0` row on an empty table.  With keys, an empty input yields
-- ZERO groups.  Groups are emitted key-ascending.
groupRows : List SqlExpr -> List (List Cell -> Cell) -> List (List Cell) -> List (List Cell, List (List Cell))
groupRows [] _ rows = [([], rows)]
groupRows _ keyEvals rows =
  let keyed = map (r => (map (g => g r) keyEvals, r)) rows
  let keys = distinctKeys (map fst keyed)
  let grouped = map (k => (k, map snd (filter ((kk, _) => cellListEq kk k) keyed))) keys
  sortBy
    (a b => match (a, b)
      ((ka, _), (kb, _)) => cellListOrder ka kb)
    grouped

-- Distinct group keys, in first-encounter order (the sort below fixes the final
-- order; encounter order just keeps this deterministic).
distinctKeys : List (List Cell) -> List (List Cell)
distinctKeys ks = reverse (distinctKeysGo ks [])

distinctKeysGo : List (List Cell) -> List (List Cell) -> List (List Cell)
distinctKeysGo [] acc = acc
distinctKeysGo (k::rest) acc =
  if containsKey k acc then
    distinctKeysGo rest acc
  else
    distinctKeysGo rest (k::acc)

containsKey : List Cell -> List (List Cell) -> Bool
containsKey _ [] = False
containsKey k (x::xs) = if cellListEq k x then True else containsKey k xs

-- ---------------------------------------------------------------------------
-- Aggregate collection + reduction
-- ---------------------------------------------------------------------------

-- Every distinct `EAgg` node appearing in the given expressions, in order.  The
-- dedup (via the derived `Eq SqlExpr`) is why `count(*)` in BOTH the select list
-- and `ORDER BY count(*) DESC` is computed once and shares one output cell.
collectAggs : List SqlExpr -> List SqlExpr
collectAggs es = nub (concatAggs es)

concatAggs : List SqlExpr -> List SqlExpr
concatAggs [] = []
concatAggs (e::rest) = aggsIn e ++ concatAggs rest

-- The aggregate nodes inside an expression.  Does NOT descend into an aggregate's
-- own operand — a nested aggregate is an error, caught later by `compileOperand`.
aggsIn : SqlExpr -> List SqlExpr
aggsIn (ECol _) = []
aggsIn (ELit _) = []
aggsIn (EAgg fn operand) = [EAgg fn operand]
aggsIn (EBin _ l r) = aggsIn l ++ aggsIn r
aggsIn (EArith _ l r) = aggsIn l ++ aggsIn r
aggsIn (EConcat l r) = aggsIn l ++ aggsIn r
aggsIn (EAnd l r) = aggsIn l ++ aggsIn r
aggsIn (EOr l r) = aggsIn l ++ aggsIn r
aggsIn (ENot e) = aggsIn e
aggsIn (EIsNull e) = aggsIn e
aggsIn (ENotNull e) = aggsIn e
aggsIn (ELike x p) = aggsIn x ++ aggsIn p
aggsIn (EIn x vs) = aggsIn x ++ concatAggs vs
aggsIn (ECase whens els) = concatAggs (aggsCasePairs whens)
  ++ concatAggs (optionToList els)
aggsIn (ECoalesce es) = concatAggs es
aggsIn (EFn _ args) = concatAggs args

aggsCasePairs : List (SqlExpr, SqlExpr) -> List SqlExpr
aggsCasePairs [] = []
aggsCasePairs ((c, r)::rest) = c :: r :: aggsCasePairs rest

containsAgg : List SqlExpr -> Bool
containsAgg es = match concatAggs es
  [] => False
  _ => True

-- Compile each aggregate to a `group rows -> Cell` reducer.
compileAggs : (String -> Option Int) -> List SqlExpr -> Result String (List (List (List Cell) -> Cell))
compileAggs _ [] = Ok []
compileAggs lookup (a::rest) = do
  f <- compileAgg lookup a
  fs <- compileAggs lookup rest
  Ok (f::fs)

-- COUNT(*) counts ROWS (NULLs included).  Every other aggregate — including
-- COUNT(e) — evaluates its operand per row and SKIPS NULLs, matching sqlite3.
compileAgg : (String -> Option Int) -> SqlExpr -> Result String (List (List Cell) -> Cell)
compileAgg _ (EAgg FnCount None) = Ok (rows => CInt (length rows))
compileAgg lookup (EAgg fn (Some operand)) = do
  g <- compileOperand lookup operand
  reduce <- aggReducer fn
  Ok (rows => reduce (nonNull (map g rows)))
compileAgg _ (EAgg fn None) =
  Err "\{aggFnSql fn}(*) is not valid — only count(*) may omit its operand"
compileAgg _ _ = Err "internal: compileAgg called on a non-aggregate expression"

-- Reduce a group's non-NULL operand cells to one cell.  Empty (or all-NULL)
-- group: COUNT = 0, everything else = NULL — sqlite3's rule.
aggReducer : AggFn -> Result String (List Cell -> Cell)
aggReducer FnCount = Ok (cs => CInt (length cs))
aggReducer FnSum = Ok sumCells
aggReducer FnAvg = Ok avgCells
aggReducer FnMin = Ok minCells
aggReducer FnMax = Ok maxCells

nonNull : List Cell -> List Cell
nonNull cells = filter (c => not (cellIsNull c)) cells

-- SUM: NULL over an empty set; integer while every value is an integer, float as
-- soon as one is a float.
sumCells : List Cell -> Cell
sumCells [] = CNull
sumCells cells =
  if any isFloatCell cells then
    CFloat (sumFloat cells)
  else
    CInt (sumInt cells)

sumFloat : List Cell -> Float
sumFloat cells = fold (acc c => acc + cellNumF c) 0.0 cells

sumInt : List Cell -> Int
sumInt cells = fold (acc c => acc + cellNumI c) 0 cells

-- AVG is always a Float (= sum / count over the non-NULLs); NULL over an empty set.
avgCells : List Cell -> Cell
avgCells [] = CNull
avgCells cells = CFloat (sumFloat cells / intToFloat (length cells))

minCells : List Cell -> Cell
minCells [] = CNull
minCells (c::rest) =
  fold (acc x => if cellOrder x acc == Lt then x else acc) c rest

maxCells : List Cell -> Cell
maxCells [] = CNull
maxCells (c::rest) =
  fold (acc x => if cellOrder x acc == Gt then x else acc) c rest

isFloatCell : Cell -> Bool
isFloatCell (CFloat _) = True
isFloatCell _ = False

cellNumF : Cell -> Float
cellNumF (CInt n) = intToFloat n
cellNumF (CFloat f) = f
cellNumF _ = 0.0

cellNumI : Cell -> Int
cellNumI (CInt n) = n
cellNumI _ = 0

-- ---------------------------------------------------------------------------
-- Post-group rewrite: expressions over the raw row → expressions over the
-- synthetic group row (key cells ++ aggregate cells)
--
-- The synthetic row is addressed POSITIONALLY.  We reuse `ECol` for that, with
-- the name being the decimal index — safe because after the rewrite there are no
-- original column names left in the tree (any that survived would be exactly the
-- ones SQL forbids, and they are rejected here instead).
-- ---------------------------------------------------------------------------

-- Resolve `name` against the synthetic row: the rewrite emits `ECol "0"`,
-- `ECol "1"`, … so the lookup is just "is this one of my `n` slot names".
synthLookup : Int -> String -> Option Int
synthLookup n = name => indexOfString name (slotNames 0 n)

slotNames : Int -> Int -> List String
slotNames i n = if i >= n then [] else intToString i :: slotNames (i + 1) n

indexOfString : String -> List String -> Option Int
indexOfString name names = indexOfStringGo name names 0

indexOfStringGo : String -> List String -> Int -> Option Int
indexOfStringGo _ [] _ = None
indexOfStringGo name (x::rest) i =
  if name == x then
    Some i
  else
    indexOfStringGo name rest (i + 1)

rewriteAllPostGroup : List SqlExpr -> List SqlExpr -> List SqlExpr -> Result String (List SqlExpr)
rewriteAllPostGroup _ _ [] = Ok []
rewriteAllPostGroup gb aggs (e::rest) = do
  e2 <- rewritePostGroup gb aggs e
  rest2 <- rewriteAllPostGroup gb aggs rest
  Ok (e2::rest2)

rewriteOptPostGroup : List SqlExpr -> List SqlExpr -> Option SqlExpr -> Result String (Option SqlExpr)
rewriteOptPostGroup _ _ None = Ok None
rewriteOptPostGroup gb aggs (Some e) = map Some (rewritePostGroup gb aggs e)

rewriteCaseWhens : List SqlExpr -> List SqlExpr -> List (SqlExpr, SqlExpr) -> Result String (List (SqlExpr, SqlExpr))
rewriteCaseWhens _ _ [] = Ok []
rewriteCaseWhens gb aggs ((c, r)::rest) = do
  c2 <- rewritePostGroup gb aggs c
  r2 <- rewritePostGroup gb aggs r
  rest2 <- rewriteCaseWhens gb aggs rest
  Ok ((c2, r2)::rest2)

-- A whole sub-expression that IS a GROUP BY key resolves to that key's slot —
-- checked FIRST, so `GROUP BY (a + b)` makes `SELECT a + b` legal.  Otherwise we
-- recurse structurally.
rewritePostGroup : List SqlExpr -> List SqlExpr -> SqlExpr -> Result String SqlExpr
rewritePostGroup gb aggs e = match indexOfExpr e gb
  Some i => Ok (ECol (intToString i))
  None => rewriteInner gb aggs e

rewriteInner : List SqlExpr -> List SqlExpr -> SqlExpr -> Result String SqlExpr
rewriteInner gb aggs (EAgg fn operand) = match indexOfExpr (EAgg fn operand) aggs
  Some j => Ok (ECol (intToString (length gb + j)))
  None => Err "internal: aggregate was not collected before the rewrite"
rewriteInner _ _ (ELit lit) = Ok (ELit lit)
-- THE rule: in an aggregate query a bare column must be a GROUP BY key or sit
-- inside an aggregate.  sqlite is lenient here (it silently picks an arbitrary
-- row from the group); we reject, because "silently returns garbage" is worse.
rewriteInner _ _ (ECol name) =
  Err
    "column '\{name}' must appear in the GROUP BY clause or be used in an aggregate function"
rewriteInner gb aggs (EBin op l r) = do
  l2 <- rewritePostGroup gb aggs l
  r2 <- rewritePostGroup gb aggs r
  Ok (EBin op l2 r2)
rewriteInner gb aggs (EArith op l r) = do
  l2 <- rewritePostGroup gb aggs l
  r2 <- rewritePostGroup gb aggs r
  Ok (EArith op l2 r2)
rewriteInner gb aggs (EConcat l r) = do
  l2 <- rewritePostGroup gb aggs l
  r2 <- rewritePostGroup gb aggs r
  Ok (EConcat l2 r2)
rewriteInner gb aggs (ELike x p) = do
  x2 <- rewritePostGroup gb aggs x
  p2 <- rewritePostGroup gb aggs p
  Ok (ELike x2 p2)
rewriteInner gb aggs (EIn x vs) = do
  x2 <- rewritePostGroup gb aggs x
  vs2 <- rewriteAllPostGroup gb aggs vs
  Ok (EIn x2 vs2)
rewriteInner gb aggs (ECase whens els) = do
  whens2 <- rewriteCaseWhens gb aggs whens
  els2 <- rewriteOptPostGroup gb aggs els
  Ok (ECase whens2 els2)
rewriteInner gb aggs (ECoalesce es) = do
  es2 <- rewriteAllPostGroup gb aggs es
  Ok (ECoalesce es2)
rewriteInner gb aggs (EFn name args) = do
  args2 <- rewriteAllPostGroup gb aggs args
  Ok (EFn name args2)
rewriteInner gb aggs (EAnd l r) = do
  l2 <- rewritePostGroup gb aggs l
  r2 <- rewritePostGroup gb aggs r
  Ok (EAnd l2 r2)
rewriteInner gb aggs (EOr l r) = do
  l2 <- rewritePostGroup gb aggs l
  r2 <- rewritePostGroup gb aggs r
  Ok (EOr l2 r2)
rewriteInner gb aggs (ENot e) = map ENot (rewritePostGroup gb aggs e)
rewriteInner gb aggs (EIsNull e) = map EIsNull (rewritePostGroup gb aggs e)
rewriteInner gb aggs (ENotNull e) = map ENotNull (rewritePostGroup gb aggs e)

indexOfExpr : SqlExpr -> List SqlExpr -> Option Int
indexOfExpr e es = indexOfExprGo e es 0

indexOfExprGo : SqlExpr -> List SqlExpr -> Int -> Option Int
indexOfExprGo _ [] _ = None
indexOfExprGo e (x::rest) i =
  if e == x then
    Some i
  else
    indexOfExprGo e rest (i + 1)

optionToList : Option SqlExpr -> List SqlExpr
optionToList None = []
optionToList (Some e) = [e]

zipKeys : List SqlExpr -> List Bool -> List (SqlExpr, Bool)
zipKeys [] _ = []
zipKeys _ [] = []
zipKeys (e::es) (d::ds) = (e, d) :: zipKeys es ds

-- ---------------------------------------------------------------------------
-- Projection + sorting (shared by both paths)
-- ---------------------------------------------------------------------------

-- Pair each row with its projection: `(projected, sortSource)`.  The SOURCE row
-- is kept alongside so ORDER BY can sort on expressions that never made it into
-- the select list.  An empty column list is SELECT * — the projected row IS the
-- source row (raw row when flat; synthetic group row when grouped, which is
-- exactly the layout the legacy `queryAgg` promised).
pairRows : List SqlExpr -> List (List Cell -> Cell) -> List (List Cell) -> List (List Cell, List Cell)
pairRows [] _ rows = map (r => (r, r)) rows
pairRows _ evals rows = map (r => (map (g => g r) evals, r)) rows

compileProjections : (String -> Option Int) -> List SqlExpr -> Result String (List (List Cell -> Cell))
compileProjections _ [] = Ok []
compileProjections lookup (e::rest) = do
  g <- compileValue lookup e
  gs <- compileProjections lookup rest
  Ok (g::gs)

-- Compile the ORDER BY keys to accessors over the SOURCE row.  Unlike the old
-- name-based version, an unresolvable key is an `Err` rather than being silently
-- dropped — a typo'd sort column used to just leave the rows unsorted.
compileSortKeys : (String -> Option Int) -> List (SqlExpr, Bool) -> Result String (List (List Cell -> Cell, Bool))
compileSortKeys _ [] = Ok []
compileSortKeys lookup ((e, asc)::rest) = do
  g <- compileValue lookup e
  gs <- compileSortKeys lookup rest
  Ok ((g, asc)::gs)

sortPairs : List (List Cell -> Cell, Bool) -> List (List Cell, List Cell) -> List (List Cell, List Cell)
sortPairs [] pairs = pairs
sortPairs keys pairs = sortBy (a b => comparePairs keys a b) pairs

-- Fold the keys left-to-right; the first non-Eq decides.  `asc = False` flips the
-- operands rather than negating the Ordering, so NULL ordering stays consistent.
comparePairs : List (List Cell -> Cell, Bool) -> (List Cell, List Cell) -> (List Cell, List Cell) -> Ordering
comparePairs [] _ _ = Eq
comparePairs ((g, asc)::rest) (pa, sa) (pb, sb) =
  let o = if asc then cellOrder (g sa) (g sb) else cellOrder (g sb) (g sa)
  match o
    Eq => comparePairs rest (pa, sa) (pb, sb)
    _ => o

cellListEq : List Cell -> List Cell -> Bool
cellListEq [] [] = True
cellListEq (a::xs) (b::ys) =
  if cellOrder a b == Eq then
    cellListEq xs ys
  else
    False
cellListEq _ _ = False

cellListOrder : List Cell -> List Cell -> Ordering
cellListOrder [] [] = Eq
cellListOrder [] _ = Lt
cellListOrder _ [] = Gt
cellListOrder (a::xs) (b::ys) = match cellOrder a b
  Eq => cellListOrder xs ys
  o => o

joinTable : Join -> String
joinTable (Join { table = t }) = t

joinOn : Join -> SqlExpr
joinOn (Join { on = e }) = e

joinKind : Join -> JoinKind
joinKind (Join { kind = k }) = k

joinAlias : Join -> Option String
joinAlias (Join { alias = a }) = a

-- The name a table is REFERENCED by in qualified column lookups: its alias when
-- aliased, else its real name (SQLite's rule).
optOr : Option String -> String -> String
optOr (Some a) _ = a
optOr None d = d

joinEffName : Join -> String
joinEffName j = optOr (joinAlias j) (joinTable j)

-- Drop `offset` elements then keep at most `limit`, over the DECODED list —
-- the DISTINCT path's slicer, which must run after `nub`.
dropTakeList : Option Int -> Option Int -> List a -> List a
dropTakeList of_ lm xs =
  let afterOffset = match of_
    Some n => drop n xs
    None => xs
  match lm
    Some n => take n afterOffset
    None => afterOffset

-- Resolve column names against a CREATE TABLE statement (via columnIndex).
-- The implicit `rowid` column (and its aliases `_rowid_` / `oid`) resolves to
-- the INTEGER PRIMARY KEY column, whose cell already holds the rowid value
-- (`rowCellsWithIpk`/`substituteIpk`) — matching SQLite, where those three names
-- are aliases of the IPK on a rowid table.  columnIndex is tried FIRST, so a
-- real user column literally named `rowid` shadows the alias (also SQLite's
-- rule).  See findings/sql-arith-rowid-coercion.md for the non-IPK edge.
mkLookup : String -> String -> Option Int
mkLookup createSql = name => match columnIndex createSql name
  Some i => Some i
  None => if isRowidAlias name then pkColumnIndex createSql else None

-- | True for the implicit-rowid column names, case-insensitively: `rowid`,
--   `_rowid_`, `oid` (SQLite's three spellings).
isRowidAlias : String -> Bool
isRowidAlias name =
  let l = asciiFold asciiLowerChar name
  l == "rowid" || l == "_rowid_" || l == "oid"

compileWhere : (String -> Option Int) -> Option SqlExpr -> Result String (List Cell -> Bool)
compileWhere _ None = Ok (_ => True)
compileWhere lookup (Some e) = compilePred lookup e

-- ---------------------------------------------------------------------------
-- Join execution: gather tables, combined lookup, nested-loop join
-- ---------------------------------------------------------------------------

-- Per-table join info: (name, createSql, materialized cell rows, base offset,
-- column width).  The base offset is the number of columns in all PRECEDING
-- tables — so a column at index `i` in this table sits at `offset + i` in the
-- combined row.  `width` is derived from the schema's column count (NOT
-- `length (head rows)`), so it's correct even when the table has zero rows —
-- needed to null-pad a LEFT JOIN's unmatched right side.
-- Each input is `(realName, effName)`: the table is SCANNED by `realName`
-- (`findTable`/`scanTableRowsIpk`/`columnNames`) but its info tuple stores
-- `effName` in the name slot, so `mkJoinLookup` matches qualified references
-- against the alias (when present) rather than the real name.
gatherJoinInfos : Db -> List (String, String) -> Int -> List (String, String, List (List Cell), Int, Int) -> Result String (List (String, String, List (List Cell), Int, Int))
gatherJoinInfos _ [] _ acc = Ok (reverse acc)
gatherJoinInfos db ((real, eff)::rest) off acc = do
  entry <- findTable db real
  (pkIdx, rows) <- scanTableRowsIpk db real
  cols <- columnNames db real
  let width = length cols
  let cellsRows = map (rowCellsWithIpk pkIdx) rows
  gatherJoinInfos
    db
    rest
    (off + width)
    ((eff, schemaSql entry, cellsRows, off, width)::acc)

-- Project a full info tuple to the (name, createSql, offset) triple the lookup needs.
infoLookup : (String, String, List (List Cell), Int, Int) -> (String, String, Int)
infoLookup (name, sql, _, off, _) = (name, sql, off)

infoCells : (String, String, List (List Cell), Int, Int) -> List (List Cell)
infoCells (_, _, cells, _, _) = cells

infoWidth : (String, String, List (List Cell), Int, Int) -> Int
infoWidth (_, _, _, _, w) = w

-- Build the combined column resolver over the ordered table infos.  A qualified
-- `table.column` resolves within that table (offset + its column index); a bare
-- `column` searches tables in `from :: joins` order, first match wins.
mkJoinLookup : List (String, String, Int) -> String -> Option Int
mkJoinLookup infos = name => match countDots (stringToChars name) 0 (stringLength name) 0
  1 => match splitOnDot name
    (tbl, col) => lookupQualified infos tbl col
  _ => lookupBare infos name

lookupQualified : List (String, String, Int) -> String -> String -> Option Int
lookupQualified [] _ _ = None
lookupQualified ((name, sql, off)::rest) tbl col =
  if name == tbl then
    map (off + _) (colOrRowid sql col)
  else
    lookupQualified rest tbl col

lookupBare : List (String, String, Int) -> String -> Option Int
lookupBare [] _ = None
lookupBare ((_, sql, off)::rest) col = match colOrRowid sql col
  Some i => Some (off + i)
  None => lookupBare rest col

-- Resolve `col` within one table's schema: a real column first, else the
-- rowid alias → the IPK column (see `mkLookup`).  Shared by both join lookups.
colOrRowid : String -> String -> Option Int
colOrRowid sql col = match columnIndex sql col
  Some i => Some i
  None => if isRowidAlias col then pkColumnIndex sql else None

-- Nested-loop the tables left-to-right: start with the `from` table's rows,
-- then for each join apply its ON predicate (compiled over the COMBINED lookup)
-- as a cross-product filter (INNER) or cross-product-with-null-pad (LEFT) with
-- the next table's rows.  The `infos` head is the `from` table; the tail pairs
-- 1:1 with `joins`.
runJoins : (String -> Option Int) -> List (String, String, List (List Cell), Int, Int) -> List Join -> Result String (List (List Cell))
runJoins _ [] _ = Ok []
runJoins lookup (headInfo::tailInfos) js =
  nestLoop lookup (infoCells headInfo) (zipJoins js tailInfos)

-- Pair each join with its table's cells + width (parallel lists; over-length is dropped).
zipJoins : List Join -> List (String, String, List (List Cell), Int, Int) -> List (Join, List (List Cell), Int)
zipJoins [] _ = []
zipJoins _ [] = []
zipJoins (j::js) (info::infos) =
  (j, infoCells info, infoWidth info) :: zipJoins js infos

nestLoop : (String -> Option Int) -> List (List Cell) -> List (Join, List (List Cell), Int) -> Result String (List (List Cell))
nestLoop _ left [] = Ok left
nestLoop lookup left ((j, right, w)::rest) = do
  onPred <- compilePred lookup (joinOn j)
  nestLoop lookup (crossFilter (joinKind j) w onPred left right) rest

-- For each left row, for each right row, keep `left ++ right` iff `onPred` holds
-- on the combined cells.  Preserves left-major, right-minor order.  For a
-- `JLeft` join, a left row with ZERO matches still emits one row, null-padded
-- with `w` `CNull` cells on the right (SQL LEFT JOIN semantics); `JInner`
-- unmatched left rows simply vanish, unchanged from before.
crossFilter : JoinKind -> Int -> (List Cell -> Bool) -> List (List Cell) -> List (List Cell) -> List (List Cell)
crossFilter _ _ _ [] _ = []
crossFilter kind w onPred (l::lefts) rights = crossOne kind w onPred l rights
  ++ crossFilter kind w onPred lefts rights

crossOne : JoinKind -> Int -> (List Cell -> Bool) -> List Cell -> List (List Cell) -> List (List Cell)
crossOne kind w onPred l rights =
  let matches = crossOneMatches onPred l rights
  match (kind, matches)
    (JLeft, []) => [l ++ nullPad w]
    _ => matches

crossOneMatches : (List Cell -> Bool) -> List Cell -> List (List Cell) -> List (List Cell)
crossOneMatches _ _ [] = []
crossOneMatches onPred l (r::rights) =
  let combined = l ++ r
  if onPred combined then
    combined :: crossOneMatches onPred l rights
  else
    crossOneMatches onPred l rights

-- `n` `CNull` cells, used to pad an unmatched LEFT JOIN right side.
nullPad : Int -> List Cell
nullPad n = if n <= 0 then [] else CNull :: nullPad (n - 1)

-- | Three-way ordering of two Cell values following SQLite's type ordering:
--   NULL < Int/Float (numeric, interleaved) < Text (lexicographic) < Blob.
--   Used by sortRows for ORDER BY.
cellOrder : Cell -> Cell -> Ordering
cellOrder CNull CNull = Eq
cellOrder CNull _ = Lt
cellOrder _ CNull = Gt
cellOrder (CInt x) (CInt y) = compare x y
cellOrder (CFloat x) (CFloat y) = compare x y
cellOrder (CInt x) (CFloat y) = compare (intToFloat x) y
cellOrder (CFloat x) (CInt y) = compare x (intToFloat y)
cellOrder (CText x) (CText y) = compare x y
cellOrder (CBlob x) (CBlob y) = compare (arrayLength x) (arrayLength y)
cellOrder a b = compare (cellTypeRank a) (cellTypeRank b)

-- Type affinity rank: numeric=1, text=2, blob=3.  Used by cellOrder's catch-all
-- for cross-type comparisons (e.g. Int vs Text, Float vs Blob, Text vs Blob).
-- NULL (rank 0) is already handled explicitly above.
cellTypeRank : Cell -> Int
cellTypeRank CNull = 0
cellTypeRank (CInt _) = 1
cellTypeRank (CFloat _) = 1
cellTypeRank (CText _) = 2
cellTypeRank (CBlob _) = 3

-- Drop `offset` rows then keep at most `limit`.
applyOffsetLimit : Option Int -> Option Int -> List (List Cell) -> List (List Cell)
applyOffsetLimit of_ lm rows =
  let afterOffset = match of_
    Some n => drop n rows
    None => rows
  match lm
    Some n => take n afterOffset
    None => afterOffset

decodeCells : RowType a -> List (List Cell) -> List a -> Result String (List a)
decodeCells _ [] acc = Ok (reverse acc)
decodeCells rt (cells::rest) acc = do
  v <- rtDecode rt cells
  decodeCells rt rest (v::acc)

-- ---------------------------------------------------------------------------
-- Render doctests (the injection-safety regression backbone — no DB).
--
-- `renderShow` projects `render`'s `(sql, binds)` result to a plain String so
-- the doctest compares against an exact, Debug-independent string.  Every
-- literal MUST appear as a `?` in the SQL and as a bind on the right of `##`.
-- ---------------------------------------------------------------------------

-- | A simple WHERE with one comparison: the literal becomes `?` + one bind.
--
-- > renderShow (render (withWhere (eGt (eColInt "age") (eLitI 18)) (selectFrom "users")))
-- "SELECT * FROM users WHERE (age > ?) ## [LInt 18]"
--
-- Arithmetic in a WHERE comparison renders parenthesized, inner op first; each
-- literal is a `?` bind, ordered left-to-right (the `+` operand before the `>`).
--
-- > renderShow (render (withWhere (eGt (eAdd (eColInt "age") (eLitI 5)) (eLitI 30)) (selectFrom "users")))
-- "SELECT * FROM users WHERE ((age + ?) > ?) ## [LInt 5, LInt 30]"
--
-- Nested AND with a NOT NULL test, plus LIMIT/OFFSET — binds are ordered
-- left-to-right, LIMIT then OFFSET appended last.
--
-- > renderShow (render andLimitSel)
-- "SELECT * FROM users WHERE ((age > ?) AND (email IS NOT NULL)) LIMIT ? OFFSET ? ## [LInt 18, LInt 10, LInt 5]"
--
-- An OR of two comparisons plus an IS NULL node.
--
-- > renderShow (render orNullSel)
-- "SELECT * FROM t WHERE (((a = ?) OR (b < ?)) AND (c IS NULL)) ## [LText hi, LInt 3]"
--
-- A bare select (no where/limit/offset) has empty binds.
--
-- > renderShow (render (selectFrom "notes"))
-- "SELECT * FROM notes ## []"
--
-- A table alias renders as ` AS <name>`, and a per-column output alias too; the
-- literal is still a `?` bind, never inlined.
--
-- > renderShow (render (withWhere (eGt (eCol "u.age") (eLitI 20)) (withColumnsAliased [(unExpr (eColText "name"), Some "who")] (selectFromAs "users" (Some "u")))))
-- "SELECT name AS who FROM users AS u WHERE (u.age > ?) ## [LInt 20]"
--
-- An invalid alias is rejected exactly like any other identifier.
--
-- > renderShow (render (withColumnsAliased [(unExpr (eColText "name"), Some "bad name")] (selectFrom "users")))
-- "ERR render: invalid alias: bad name"
--
-- An invalid identifier is rejected (never inlined).
--
-- > renderShow (render (selectFrom "bad name"))
-- "ERR render: invalid table name: bad name"
--
-- ORDER BY ASC: clause appears after WHERE, before LIMIT/OFFSET.
--
-- > renderShow (render (withOrderBy "age" True (selectFrom "users")))
-- "SELECT * FROM users ORDER BY age ASC ## []"
--
-- ORDER BY DESC combined with WHERE: ORDER BY follows WHERE.
--
-- > renderShow (render (withOrderBy "age" False (withWhere (eGt (eColInt "age") (eLitI 0)) (selectFrom "users"))))
-- "SELECT * FROM users WHERE (age > ?) ORDER BY age DESC ## [LInt 0]"
--
-- ORDER BY before LIMIT (proves clause ordering: WHERE ORDER LIMIT OFFSET).
--
-- > renderShow (render (withOrderBy "age" True (withLimit 5 (selectFrom "users"))))
-- "SELECT * FROM users ORDER BY age ASC LIMIT ? ## [LInt 5]"
--
-- Multi-column ORDER BY: each `withOrderBy` call appends a key, so chaining
-- `withOrderBy "age" True` then `withOrderBy "name" False` renders "age ASC,
-- name DESC" — primary key first, comma-separated.
--
-- > renderShow (render (withOrderBy "name" False (withOrderBy "age" True (selectFrom "users"))))
-- "SELECT * FROM users ORDER BY age ASC, name DESC ## []"
--
-- A 2-table INNER JOIN renders the join clause (with a qualified-column ON)
-- before WHERE; ON binds precede WHERE binds.
--
-- > renderShow (render (withWhere (eGt (eColInt "orders.amount") (eLitI 100)) (innerJoin "orders" (eEq (eColInt "users.id") (eColInt "orders.uid")) (selectFrom "users"))))
-- "SELECT * FROM users INNER JOIN orders ON (users.id = orders.uid) WHERE (orders.amount > ?) ## [LInt 100]"
--
-- A 3-table chained INNER JOIN renders both join clauses in order, then ORDER BY.
--
-- > renderShow (render (withOrderBy "tc.cid" True (innerJoin "tc" (eEq (eColInt "tb.bid") (eColInt "tc.bref")) (innerJoin "tb" (eEq (eColInt "ta.aid") (eColInt "tb.aref")) (selectFrom "ta")))))
-- "SELECT * FROM ta INNER JOIN tb ON (ta.aid = tb.aref) INNER JOIN tc ON (tb.bid = tc.bref) ORDER BY tc.cid ASC ## []"
--
-- `withDistinct` inserts `DISTINCT` right after `SELECT`; the rest of the
-- clause order (WHERE, ORDER BY, LIMIT/OFFSET) is unaffected. Note `render`
-- ONLY affects the emitted SQL text (for the oracle/display) — execution of
-- DISTINCT semantics goes through `queryDistinct`, not `render`/`query`.
--
-- > renderShow (render (withOrderBy "age" True (withDistinct (selectFrom "users"))))
-- "SELECT DISTINCT * FROM users ORDER BY age ASC ## []"
--
-- A non-empty `withColumns` list renders `SELECT <e1>, <e2>, …` (comma-joined,
-- each via the expr renderer) instead of `SELECT *`; column binds precede WHERE
-- binds. Empty (`SELECT *`) is unchanged (all doctests above).
--
-- > renderShow (render (withColumns [unExpr (eAdd (eColInt "a") (eColInt "b")), unExpr (eColText "name")] (selectFrom "t")))
-- "SELECT (a + b), name FROM t ## []"
--
-- An aggregate renders as its canonical SQL text: `count(*)` for the operand-less
-- `EAgg FnCount None`, `sum(<expr>)` for the rest. GROUP BY follows WHERE.
--
-- > renderShow (render (withColumns [unExpr (eColText "dept"), unExpr aCountStar] (withGroupCols ["dept"] (selectFrom "emp"))))
-- "SELECT dept, count(*) FROM emp GROUP BY dept ## []"
--
-- Full clause order: SELECT … FROM … WHERE … GROUP BY … HAVING … ORDER BY … LIMIT.
-- ORDER BY names an AGGREGATE here — impossible before the engines were unified.
--
-- > renderShow (render topDepts)
-- "SELECT dept, count(*) FROM emp WHERE (active = ?) GROUP BY dept HAVING (count(*) > ?) ORDER BY count(*) DESC LIMIT ? ## [LInt 1, LInt 2, LInt 5]"
--
-- ORDER BY on a COMPUTED column — the retired v1 limitation. Sort keys are
-- expressions, so they render (and carry binds) exactly like any other.
--
-- > renderShow (render (withOrderByExpr (unExpr (eMul (eColInt "price") (eColInt "qty"))) False (selectFrom "orders")))
-- "SELECT * FROM orders ORDER BY (price * qty) DESC ## []"
--
-- An aggregate over an EXPRESSION (`sum(price * qty)`) — the legacy `Agg` could
-- only aggregate a bare column name.
--
-- > renderShow (render (withColumns [unExpr (aSum (eMul (eColInt "price") (eColInt "qty")))] (selectFrom "orders")))
-- "SELECT sum((price * qty)) FROM orders ## []"
--
-- `||` concatenation, `LIKE`, `IN`, `BETWEEN` (which renders as the AND-of-
-- comparisons it desugars to — see the `SqlExpr` doc comment), `COALESCE`, and
-- a scalar string function all render with their own `?`-bind literals.
--
-- > renderShow (render (withColumns [unExpr (eConcat (eColText "first") (eLitT " "))] (selectFrom "users")))
-- "SELECT (first || ?) FROM users ## [LText  ]"
--
-- > renderShow (render (withWhere (eLike (eColText "name") (eLitT "a%")) (selectFrom "users")))
-- "SELECT * FROM users WHERE (name LIKE ?) ## [LText a%]"
--
-- > renderShow (render (withWhere (eIn (eColInt "age") [eLitI 20, eLitI 30]) (selectFrom "users")))
-- "SELECT * FROM users WHERE (age IN (?, ?)) ## [LInt 20, LInt 30]"
--
-- > renderShow (render (withWhere (eBetween (eColInt "age") (eLitI 20) (eLitI 30)) (selectFrom "users")))
-- "SELECT * FROM users WHERE ((age >= ?) AND (age <= ?)) ## [LInt 20, LInt 30]"
--
-- > renderShow (render (withColumns [unExpr (eCoalesce [eColText "nick", eColText "name"])] (selectFrom "users")))
-- "SELECT coalesce(nick, name) FROM users ## []"
--
-- > renderShow (render (withColumns [unExpr (eUpper (eColText "name"))] (selectFrom "users")))
-- "SELECT upper(name) FROM users ## []"
export renderShow : Result String (String, List Literal) -> String
renderShow (Err e) = "ERR \{e}"
renderShow (Ok (sql, binds)) = "\{sql} ## \{showBinds binds}"

andLimitSel : Select
andLimitSel =
  withOffset
    5
    (withLimit
      10
      (withWhere
        (eAnd (eGt (eColInt "age") (eLitI 18)) (eNotNull (eColInt "email")))
        (selectFrom "users")))

-- `SELECT dept, count(*) FROM emp WHERE active = 1 GROUP BY dept
--  HAVING count(*) > 2 ORDER BY count(*) DESC LIMIT 5` — every clause at once.
topDepts : Select
topDepts = withLimit
  5
  (withOrderByExpr
    (unExpr aCountStar)
    False
    (withHavingPred
      (eGt aCountStar (eLitI 2))
      (withColumns
        [unExpr (eColText "dept"), unExpr aCountStar]
        (withGroupCols
          ["dept"]
          (withWhere (eEq (eColInt "active") (eLitI 1)) (selectFrom "emp"))))))

orNullSel : Select
orNullSel =
  withWhere
    (eAnd
      (eOr (eEq (eColText "a") (eLitT "hi")) (eLt (eColInt "b") (eLitI 3)))
      (eIsNull (eColInt "c")))
    (selectFrom "t")

-- Render a bind list as `[LInt 18, LInt 10]` (Debug-independent).
showBinds : List Literal -> String
showBinds binds = "[\{showBindsGo binds True}]"

showBindsGo : List Literal -> Bool -> String
showBindsGo [] _ = ""
showBindsGo (x::rest) first =
  let sep = if first then "" else ", "
  "\{sep}\{showLit x}\{showBindsGo rest False}"

showLit : Literal -> String
showLit (LInt n) = "LInt \{n}"
showLit (LText s) = "LText \{s}"
showLit (LFloat f) = "LFloat \{f}"
showLit (LBlob _) = "LBlob"
showLit LNull = "LNull"
