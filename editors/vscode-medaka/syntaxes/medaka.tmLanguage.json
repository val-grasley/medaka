{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Medaka",
  "scopeName": "source.medaka",
  "fileTypes": ["mdk"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#char" },
    { "include": "#effect-annotation" },
    { "include": "#interface-name" },
    { "include": "#interface-constraint" },
    { "include": "#impl-named-decl" },
    { "include": "#impl-decl" },
    { "include": "#data-decl" },
    { "include": "#block-constructor" },
    { "include": "#record-name" },
    { "include": "#type-param" },
    { "include": "#pipe-constructor" },
    { "include": "#deriving-iface" },
    { "include": "#type-signature" },
    { "include": "#keyword" },
    { "include": "#bool-literal" },
    { "include": "#number" },
    { "include": "#uppercase-ident" },
    { "include": "#impl-selection" },
    { "include": "#operator" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-dash.medaka",
          "match": "--.*$"
        },
        {
          "name": "comment.block.medaka",
          "begin": "\\{-",
          "end": "-\\}",
          "patterns": [{ "include": "#comment-block-nested" }]
        }
      ]
    },
    "comment-block-nested": {
      "name": "comment.block.medaka",
      "begin": "\\{-",
      "end": "-\\}",
      "patterns": [{ "include": "#comment-block-nested" }]
    },
    "string": {
      "name": "string.quoted.double.medaka",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "comment": "\\{expr} string interpolation — highlight the embedded expression as code",
          "name": "meta.template.expression.medaka",
          "begin": "\\\\\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.medaka" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.medaka" }
          },
          "patterns": [
            { "include": "$self" },
            {
              "comment": "embedded identifiers — give them a non-string scope so they render as code, not string text",
              "match": "[a-z_][a-zA-Z0-9_']*",
              "name": "variable.other.medaka"
            }
          ]
        },
        {
          "name": "constant.character.escape.medaka",
          "match": "\\\\(?:[\\\\\"/nrtb0]|u\\{[0-9a-fA-F]+\\})"
        }
      ]
    },
    "char": {
      "name": "string.quoted.single.medaka",
      "match": "'[^'\\\\]'|'\\\\.[^']*'"
    },
    "effect-annotation": {
      "match": "(<)(?:[A-Z][a-zA-Z0-9_']*,?\\s*)+(>)",
      "captures": {
        "0": { "name": "storage.modifier.effect.medaka" }
      }
    },

    "interface-name": {
      "comment": "interface Eq a — color the interface name being declared",
      "match": "\\b(interface)\\s+([A-Z][a-zA-Z0-9_']*)",
      "captures": {
        "1": { "name": "keyword.declaration.medaka" },
        "2": { "name": "entity.name.class.medaka" }
      }
    },

    "interface-constraint": {
      "comment": "requires Eq a / of Eq a — color the constraint interface name",
      "match": "\\b(requires|of)\\s+([A-Z][a-zA-Z0-9_']*)",
      "captures": {
        "1": { "name": "keyword.other.medaka" },
        "2": { "name": "entity.name.class.medaka" }
      }
    },

    "impl-named-decl": {
      "comment": "impl name of Interface Type — named impl",
      "match": "\\b(impl)\\s+([a-z_][a-zA-Z0-9_']*)\\s+(of)\\s+([A-Z][a-zA-Z0-9_']*)",
      "captures": {
        "1": { "name": "keyword.declaration.medaka" },
        "2": { "name": "entity.name.function.medaka" },
        "3": { "name": "keyword.other.medaka" },
        "4": { "name": "entity.name.class.medaka" }
      }
    },

    "impl-decl": {
      "comment": "impl Interface Type — color the interface name",
      "match": "\\b(impl)\\s+([A-Z][a-zA-Z0-9_']*)",
      "captures": {
        "1": { "name": "keyword.declaration.medaka" },
        "2": { "name": "entity.name.class.medaka" }
      }
    },

    "data-decl": {
      "comment": "A `data`/`newtype` declaration line. Spans to end of line and highlights the type name (uppercase), header + constructor-argument type variables (lowercase), constructor names (uppercase after =/|), and argument type constructors. Keying on the `data` keyword is what makes it safe to color lowercase identifiers as type variables here without misfiring on value bindings. Block-form constructor clauses on following lines are handled by #block-constructor.",
      "begin": "\\b(data|newtype)\\b",
      "end": "$",
      "beginCaptures": {
        "1": { "name": "keyword.declaration.medaka" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#effect-annotation" },
        { "include": "#constructor-clause" },
        {
          "comment": "the type name being declared, plus any argument type constructors not caught by a constructor clause",
          "match": "\\b[A-Z][a-zA-Z0-9_']*\\b",
          "name": "entity.name.type.medaka"
        },
        {
          "comment": "type variables — header params and constructor-argument type vars",
          "match": "\\b[a-z_][a-zA-Z0-9_']*\\b",
          "name": "variable.parameter.type.medaka"
        },
        { "include": "#punctuation" }
      ]
    },

    "block-constructor": {
      "comment": "Block-form data constructor on its own line: a leading `=` or `|` followed by an uppercase constructor. Line-leading `=`/`|` before an uppercase name occurs only in block-form data declarations — value bindings are `name = …`, guard arms start with a lowercase condition (`| otherwise = …`), and pipe continuations are `|>`. So this never fires outside a data declaration.",
      "begin": "^\\s*(?=[=|]\\s*[A-Z])",
      "end": "$",
      "patterns": [{ "include": "#constructor-clause" }]
    },

    "constructor-clause": {
      "comment": "`= Con args` or `| Con args` — a data constructor and its argument types. Shared by #data-decl and #block-constructor. Ends before the next `|`/`=` (next clause) or end of line.",
      "begin": "([=|])\\s*([A-Z][a-zA-Z0-9_']*)",
      "end": "(?=[=|]|$)",
      "beginCaptures": {
        "1": { "name": "keyword.operator.medaka" },
        "2": { "name": "entity.name.function.medaka" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#effect-annotation" },
        {
          "comment": "argument type constructors",
          "match": "\\b[A-Z][a-zA-Z0-9_']*\\b",
          "name": "entity.name.type.medaka"
        },
        {
          "comment": "argument type variables",
          "match": "\\b[a-z_][a-zA-Z0-9_']*\\b",
          "name": "variable.parameter.type.medaka"
        },
        { "include": "#punctuation" }
      ]
    },

    "record-name": {
      "comment": "record TypeName — color the type name being declared",
      "match": "\\b(record)\\s+([A-Z][a-zA-Z0-9_']*)",
      "captures": {
        "1": { "name": "keyword.declaration.medaka" },
        "2": { "name": "entity.name.type.medaka" }
      }
    },

    "type-param": {
      "comment": "type params in declaration headers and constraint positions",
      "match": "(?<=\\b(?:data|record|interface)\\s{1,40}[A-Za-z0-9_']{1,40}\\s{1,10}|\\b(?:data|record|interface)\\s{1,40}[A-Za-z0-9_']{1,40}(?:\\s{1,10}[a-z][a-zA-Z0-9_']*){1}\\s{1,10}|\\b(?:data|record|interface)\\s{1,40}[A-Za-z0-9_']{1,40}(?:\\s{1,10}[a-z][a-zA-Z0-9_']*){2}\\s{1,10}|\\b(?:data|record|interface)\\s{1,40}[A-Za-z0-9_']{1,40}(?:\\s{1,10}[a-z][a-zA-Z0-9_']*){3}\\s{1,10}|\\b(?:requires|of)\\s{1,20}[A-Z][a-zA-Z0-9_']{0,40}\\s{1,10}|\\b(?:requires|of)\\s{1,20}[A-Z][a-zA-Z0-9_']{0,40}(?:\\s{1,10}[a-z][a-zA-Z0-9_']*){1}\\s{1,10})(?!(?:where|requires|of|deriving|let|in|if|then|else|match|do|mut|as|import|export|data|record|interface|impl|default|extern)\\b)([a-z][a-zA-Z0-9_']*)",
      "captures": {
        "1": { "name": "variable.parameter.type.medaka" }
      }
    },

    "type-signature": {
      "comment": "Type context after a single `:` (top-level signatures `f : T`, inline annotations `(x : T)`, annotated `let x : T = …`). Everything here is a type, so lowercase identifiers are type variables and get their own scope. Begins at a lone `:` (not `::`), ends before a binding `=` (but not the `=>` constraint arrow) or at end of line — type signatures never wrap.",
      "begin": "(?<!:):(?!:)",
      "end": "(?==(?!>))|$",
      "beginCaptures": {
        "0": { "name": "keyword.operator.medaka" }
      },
      "patterns": [
        { "include": "#comment" },
        { "include": "#effect-annotation" },
        {
          "comment": "constraint interface name — an uppercase name applied to type vars and standing before the `=>` constraint arrow (e.g. `Eq a =>`). Colored like the interface declaration, not like an ordinary type.",
          "match": "\\b[A-Z][a-zA-Z0-9_']*\\b(?=(?:\\s+[a-z][a-zA-Z0-9_']*)*\\s*(?:,|=>))",
          "name": "entity.name.class.medaka"
        },
        {
          "comment": "type constructors",
          "match": "\\b[A-Z][a-zA-Z0-9_']*\\b",
          "name": "entity.name.type.medaka"
        },
        {
          "comment": "type variables — lowercase identifiers in type position",
          "match": "\\b[a-z_][a-zA-Z0-9_']*\\b",
          "name": "variable.parameter.type.medaka"
        },
        {
          "name": "keyword.operator.medaka",
          "match": "->|=>|\\|"
        }
      ]
    },

    "pipe-constructor": {
      "comment": "| ConName — data constructor after pipe, inline or block",
      "match": "\\|\\s*([A-Z][a-zA-Z0-9_']*)",
      "captures": {
        "1": { "name": "entity.name.function.medaka" }
      }
    },

    "deriving-iface": {
      "comment": "deriving (Eq, Show) — color each interface name inside parens",
      "match": "\\b(deriving)\\s*\\(([A-Z][a-zA-Z0-9_']*(?:\\s*,\\s*[A-Z][a-zA-Z0-9_']*)*)\\)",
      "captures": {
        "1": { "name": "keyword.other.medaka" },
        "2": { "name": "entity.name.class.medaka" }
      }
    },

    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.medaka",
          "match": "\\b(if|then|else|match|do|let|in|mut|rec|with)\\b"
        },
        {
          "name": "keyword.declaration.medaka",
          "match": "\\b(data|record|interface|impl|default|extern|type|newtype|prop|bench|function)\\b"
        },
        {
          "name": "keyword.modifier.medaka",
          "match": "\\b(export|public)\\b"
        },
        {
          "name": "keyword.import.medaka",
          "match": "\\b(import)\\b"
        },
        {
          "name": "keyword.other.medaka",
          "match": "\\b(where|of|as|requires|deriving)\\b"
        }
      ]
    },

    "bool-literal": {
      "name": "constant.language.medaka",
      "match": "\\b(True|False)\\b"
    },

    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.medaka",
          "match": "\\b[0-9]+\\.[0-9]+(?:[eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.medaka",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "uppercase-ident": {
      "comment": "General uppercase identifier — type constructors and data constructors in expression/type position",
      "name": "entity.name.type.medaka",
      "match": "\\b[A-Z][a-zA-Z0-9_']*\\b"
    },

    "impl-selection": {
      "name": "entity.name.class.medaka",
      "match": "@[A-Z][a-zA-Z0-9_']*"
    },

    "operator": {
      "name": "keyword.operator.medaka",
      "match": "\\|>|>>|<<|\\+\\+|<>|::|==|!=|<=|>=|<-|=>|->|[+\\-*/%<>!&|=:]"
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.bracket.medaka",
          "match": "[\\(\\)\\[\\]\\{\\}]|\\[\\||\\|\\]"
        },
        {
          "name": "punctuation.delimiter.medaka",
          "match": "[,.]"
        }
      ]
    }
  }
}
