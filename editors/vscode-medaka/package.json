{
  "name": "medaka",
  "displayName": "Medaka",
  "description": "Syntax highlighting and language server support for the Medaka programming language (.mdk)",
  "version": "0.2.0",
  "publisher": "medaka-lang",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:medaka"],
  "main": "./client.js",
  "contributes": {
    "languages": [
      {
        "id": "medaka",
        "aliases": ["Medaka", "mdk"],
        "extensions": [".mdk"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/medaka-light.svg",
          "dark": "./icons/medaka-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "medaka",
        "scopeName": "source.medaka",
        "path": "./syntaxes/medaka.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Medaka",
      "properties": {
        "medaka.serverPath": {
          "type": "string",
          "default": "medaka",
          "description": "Path to the medaka binary. Must support the `lsp` subcommand."
        },
        "medaka.root": {
          "type": "string",
          "default": "",
          "description": "MEDAKA_ROOT for the language server (where stdlib/ lives). The native server reads stdlib from disk; defaults to the first workspace folder when empty."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0"
  }
}
