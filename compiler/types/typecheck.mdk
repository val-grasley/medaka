-- Self-hosted typecheck stage — port of lib/typecheck.ml's HM core.  SLICE 1:
-- the Hindley-Milner engine — monotypes with Ref-based union-find tyvars,
-- level-based generalization, unification (occurs-check + level adjust),
-- instantiation, and inference for literals, variables, application, lambdas,
-- let (let-polymorphism), if, tuples, lists, annotations, ADT constructors, and
-- match/pattern inference. Validated WITHOUT the prelude (engine only) against
-- dev/tc_probe.exe — so it needs only the HM core, not the typeclass /
-- dict-passing layer (the === TYPES === rendering drops constraints).
--
-- Deferred to later slices: operators (EBinOp/EInfix route through Num/Eq from
-- the prelude), effect rows, records, interfaces/impls + constraint solving,
-- and explicit type signatures.

import frontend.ast.{
  Lit(..),
  Ty(..),
  Constraint(..),
  Route(..),
  Pat(..),
  RecPatField(..),
  Guard(..),
  Arm(..),
  DoStmt(..),
  FunClause(..),
  FieldAssign(..),
  LetBind(..),
  Expr(..),
  Loc(..),
  ConPayload(..),
  Field(..),
  Variant(..),
  IfaceMethod(..),
  MethodDefault(..),
  Require(..),
  Super(..),
  ImplMethod(..),
  DataVis(..),
  Decl(..),
  PropParam(..),
  Section(..),
  InterpPart(..),
  GuardArm(..),
  UsePath(..),
  UseMember(..),
  useMemberOrigin,
  useMemberLocal,
  useMemberAlias,
  qualifiedLocal,
}
import frontend.desugar.{mapProg}
import frontend.marker.{localBoundNames}
-- The type-aware non-exhaustive-`match` check (`check_match` in lib/exhaust.ml)
-- reuses the Maranget matrix machinery already ported in exhaust.mdk — the only
-- difference from the guard-coverage pass is the ctor oracle (here it comes from
-- the typechecked program's data decls + the inferred scrutinee type).
import frontend.exhaust.{
  Oracle,
  buildOracle,
  useful,
  patUnreachable,
  patHasRange,
  usefulWitness,
  renderWitness,
  desugarPat,
}
import support.char.{isUpper}
import backend.private_mangle.{mangledName}
import support.ordmap.{
  OrdMap,
  omEmpty,
  omInsert,
  omLookup,
  omHasKey,
  omFromPairs,
}
import list.{replicate}
import support.util.{
  listLen,
  lookupAssoc,
  contains,
  endsWith,
  reverseL,
  joinWith,
  joinNl,
  joinDot,
  filterList,
  anyList,
  allList,
  initList,
  isEmptyL,
  isNonEmptyL,
  minI,
  isSome,
  zipL,
  dedup,
  sortUniqS,
  startsWith,
  escStr,
  editDistance,
}

-- ── monotypes & schemes ───────────────────────────────────────────────────
public export data Mono =
  | TVar (Ref Tyvar)
  | TCon String
  | TApp Mono Mono
  | TFun Mono EffRow Mono
  -- arg -> <effect row> result
  | TEff EffRow
-- An effect row occupying a type-CONSTRUCTOR ARGUMENT slot, for a data type
-- with an effect-row parameter (`data Async e a = … <e> …`).  Produced ONLY
-- by kind-directed elaboration at a Row-kinded param position; consumed only
-- by unifyN's TApp~TApp recursion.  Never appears in code lacking an
-- effect-poly data type, so its addition is purely additive.

public export data Tyvar =
  | Unbound Int Int  -- Unbound id level | Link
  | Link Mono

-- An effect row (Phase 79/146): a set of concrete effect labels plus an optional
-- tail variable.
--   tail = None    ⇒ closed row, exactly [labels].
--   tail = Some v  ⇒ open row <labels | v>: v can absorb further effects.
-- Inference-synthesized arrows use open rows so effect-subsumption survives
-- equality unification; user annotations are closed unless they name a tail.
public export data EffRow = EffRow (List Atom) (Option (Ref Effvar))
public export data Effvar =
  | EUnbound Int Int  -- EUnbound id level | link
  | ELink EffRow

-- ── Effect refinement domains (capability-effects v2, Stage 1) ─────────────
-- An effect label may carry a PARAMETER drawn from its declared refinement
-- DOMAIN — a small lattice of data-shaped values with a top ⊤ (unconstrained).
-- Stage 1 is the REPRESENTATION only: every param is built at ⊤, so the row is
-- byte-identical to the v1 set-of-bare-labels.  Stage 2 adds the Prefix domain's
-- analysis with NO change to this row code.  (Mirror of lib/typecheck.ml.)
-- WS-4: a PRODUCT refinement domain — a label refined on several named AXES at
-- once, each axis a value in an existing sub-domain (e.g. structured `Net` =
-- `Host(Prefix) × Method(Set)`).  Represented as a sorted assoc-list keyed by
-- axis name; an axis ABSENT from the list is ⊤ on that axis, and `PProduct []`
-- is the product ⊤ (no axis constrained).  The lattice ops are POINTWISE
-- (`dsubN`/`djoinN`/`drenderN` below).  No `dmeetN`/⊥ arm: the escape check and
-- policy compare only ever call `dsub`/`djoin` — ⊓ is unreachable today and is
-- deliberately omitted (model ⊥ as `Option Param`→`None` if ever needed).
public export data Param =
  | PUnit
  | PPrefix (Option String)
  | PSet (Option (List String))
  | PProduct (List (String, Param))

-- v2 Stage 2b inferred-hole marker (mirror of lib/typecheck.ml).  A leaf
-- extern's `<Net _>` parses to the param string "_" (`effHoleSrc`), which
-- `atomOfWritten` keeps as `PPrefix (Some "_")` — the hole the call-site α
-- overwrites.  "_" is unambiguous: it can never be a valid written pattern
-- (fails `prefixPatternOk`).  An un-filled hole degrades to ⊤ for all domain
-- ops (sound over-approximation), so a surviving hole never leaks.
effHoleSrc : String
effHoleSrc = "_"

isHoleStr : String -> Bool
isHoleStr s = s == effHoleSrc

isHoleParam : Param -> Bool
isHoleParam (PPrefix (Some s)) = isHoleStr s
isHoleParam _ = False

normHole : Param -> Param
normHole (PPrefix (Some s)) =
  if isHoleStr s then
    PPrefix None
  else
    PPrefix (Some s)
normHole p = p
-- WS-4: per-axis holes are out of scope (the hole marker stays at the whole-atom
-- `Param` level, not per axis), so `normHole (PProduct …)` is the identity — the
-- explicit clause above (`normHole p = p`) already covers it.  Documented so a
-- reader doesn't mistake the absence for an oversight.
-- an atom = a label applied to a domain parameter.  A v1 atomic label `Foo` is
-- exactly `Atom "Foo" (dtopFor "Foo")` (= PUnit in Stage 1).
public export data Atom = Atom String Param

export atomLabel : Atom -> String
atomLabel (Atom l _) = l

export atomParam : Atom -> Param
atomParam (Atom _ p) = p

-- ── effect-label DOMAIN registry (v2 Stage 2a) ─────────────────────────────
-- Maps a label to the ⊤-param of its declared domain.  A `PPrefix None` entry
-- means "Prefix-domain (carries a pattern)"; absence ⇒ atomic (Unit).  Seeded
-- with the builtin Prefix labels (Net/FileRead/FileWrite) and extended per
-- program from `effect Net Prefix` decls.  An assoc-list Ref (the label set is
-- tiny).  (Mirror of lib/typecheck.ml's effect_domains Hashtbl.)
effectDomains : Ref (List (String, Param))
effectDomains = Ref []

seedEffectDomains : Unit -> Unit
seedEffectDomains _ = setRef
  effectDomains
  [
    ("Net", PPrefix None),
    ("FileRead", PPrefix None),
    ("FileWrite", PPrefix None),
    ("Env", PSet None),
    ("Exec", PPrefix None),
  ]

-- register a label's domain from its `effect` decl: Some "Prefix" ⇒ Prefix;
-- None ⇒ atomic.
registerEffectDomain : String -> Option String -> Unit
registerEffectDomain name domain =
  setRef effectDomains ((name, domainParam domain)::effectDomains.value)

-- the ⊤-param a declared label carries: atomic ⇒ PUnit; Prefix ⇒ PPrefix None.
domainParam : Option String -> Param
domainParam (Some "Prefix") = PPrefix None
domainParam (Some "Set") = PSet None
domainParam (Some "Product") = PProduct []  -- WS-4: structured (multi-axis) domain ⊤
domainParam _ = PUnit

-- re-seed to the builtins, then register every `effect …` decl in the program.
populateEffectDomains : List Decl -> Unit
populateEffectDomains decls =
  let _ = seedEffectDomains ()
  populateGo decls

populateGo : List Decl -> Unit
populateGo [] = ()
populateGo ((DEffect _ name domain)::rest) =
  let _ = registerEffectDomain name domain
  populateGo rest
populateGo (_::rest) = populateGo rest

lookupDomain : String -> List (String, Param) -> Param
lookupDomain _ [] = PUnit
lookupDomain l ((k, p)::rest) = if l == k then p else lookupDomain l rest

-- ── RefinementDomain interface (design §2.1): dtop/dsub/djoin/dmeet/drender ──
-- Stage 1: only ⊤ params (PUnit / PPrefix None) ever occur; the STRUCTURE is
-- what Stage 2's Prefix analysis plugs into.  A label's domain is fixed by its
-- declaration; dtopFor picks the ⊤ of the label's domain (all PUnit in Stage 1).
-- ⊤ parameter for a label's domain (design §2.1): consults the registry;
-- labels with no Prefix entry are atomic ⇒ PUnit.
dtopFor : String -> Param
dtopFor label = match lookupDomain label effectDomains.value
  PPrefix None => PPrefix None
  PSet None => PSet None
  PProduct _ => PProduct []     -- WS-4: product domain ⊤ (no axis constrained)
  _ => PUnit

-- the concrete (literal) part of a Prefix pattern: drop a single trailing `*`
-- wildcard ("a.com/*" → "a.com/"); a pattern with no `*` is concrete as-is.
prefixConcrete : String -> String
prefixConcrete s =
  let n = stringLength s
  if n > 0 && stringSlice (n - 1) n s == "*" then stringSlice 0 (n - 1) s else s

-- p1 ⊑ p2 : is p1 at least as constrained (more specific) as p2?  In the Prefix
-- domain, p1 ⊑ p2 iff p1's concrete part starts with p2's concrete part.
export dsub : Param -> Param -> Bool
dsub p1 p2 = dsubN (normHole p1) (normHole p2)

dsubN : Param -> Param -> Bool
dsubN PUnit PUnit = True
dsubN _ (PPrefix None) = True  -- anything ⊑ ⊤
dsubN (PPrefix (Some a)) (PPrefix (Some b)) =
  startsWith (prefixConcrete b) (prefixConcrete a)
dsubN (PPrefix None) (PPrefix (Some _)) = False
dsubN _ (PSet None) = True  -- anything ⊑ ⊤ (Set domain)
dsubN (PSet (Some a)) (PSet (Some b)) = subsetStr a b  -- a ⊆ b
dsubN (PSet None) (PSet (Some _)) = False
-- WS-4: PRODUCT subsumption is POINTWISE.  `a ⊑ b` iff for EVERY axis CONSTRAINED
-- in `b`, a's value on that axis ⊑ b's value.  SOUNDNESS-CRITICAL: an axis absent
-- from `a` means a is UNCONSTRAINED (⊤) on that axis, which is NOT ⊑ a constrained
-- b-axis — so a missing a-axis must be looked up against the SUB-DOMAIN ⊤ of the
-- b-axis (`subTopOf bp`), not silently skipped.  (Skipping it would under-
-- approximate the escape check ⇒ unsound: an `a` silent on Method would falsely
-- subsume a `b` that confines Method.)  Axes constrained in `a` but ⊤ in `b` need
-- no check (anything ⊑ ⊤), so we iterate b's axes only.
dsubN _ (PProduct []) = True  -- anything ⊑ product-⊤
dsubN (PProduct ax) (PProduct bx) = allList (axisSub ax) bx
dsubN _ _ = False  -- domain mismatch — never happens (one domain per label)

-- one b-axis ⊑ check: a's value on `name` (its sub-domain ⊤ when a is silent) ⊑ bp.
axisSub : List (String, Param) -> (String, Param) -> Bool
axisSub ax (name, bp) = dsubN (lookupAxisOrTop name ax bp) bp

-- a's value for axis `name`, or the SUB-DOMAIN ⊤ of `bp` when `a` is silent (the
-- soundness default — a missing axis is ⊤ on that axis, NOT ⊑ a constrained bound).
lookupAxisOrTop : String -> List (String, Param) -> Param -> Param
lookupAxisOrTop name ax bp = match lookupAxis name ax
  Some v => v
  None => subTopOf bp

-- the ⊤ of a sub-domain param's domain.
subTopOf : Param -> Param
subTopOf (PPrefix _) = PPrefix None
subTopOf (PSet _) = PSet None
subTopOf (PProduct _) = PProduct []
subTopOf _ = PUnit

lookupAxis : String -> List (String, Param) -> Option Param
lookupAxis _ [] = None
lookupAxis name ((k, v)::rest) =
  if name == k then
    Some v
  else
    lookupAxis name rest

-- total `all` over a list (avoids relying on a stdlib import in compiler).
allList : (a -> Bool) -> List a -> Bool
allList _ [] = True
allList f (x::xs) = if f x then allList f xs else False

-- a ⊆ b for string sets (lists treated as sets)
subsetStr : List String -> List String -> Bool
subsetStr [] _ = True
subsetStr (x::xs) b = if contains x b then subsetStr xs b else False

-- least upper bound (over-approximation)
djoin : Param -> Param -> Param
djoin p1 p2 = djoinN (normHole p1) (normHole p2)

djoinN : Param -> Param -> Param
djoinN PUnit PUnit = PUnit
djoinN (PPrefix None) _ = PPrefix None
djoinN _ (PPrefix None) = PPrefix None
djoinN (PPrefix (Some a)) (PPrefix (Some b)) =
  let k = commonPrefixLen a b 0
  if k == 0 then PPrefix None else PPrefix (Some (stringSlice 0 k a))
djoinN (PSet None) _ = PSet None
djoinN _ (PSet None) = PSet None
djoinN (PSet (Some a)) (PSet (Some b)) =
  -- ∪, saturating to ⊤ (PSet None) past the cardinality cap (setCardCap = 16)
  let u = sortUniqS (a ++ b)
  if listLen u > setCardCap then PSet None else PSet (Some u)
-- WS-4: PRODUCT join is POINTWISE — for every axis present in EITHER side, join
-- the two sub-params (a side silent on an axis = sub-⊤ there, which makes the join
-- ⊤ on that axis — correct over-approximation).  `productNorm` then drops axes
-- that joined to sub-⊤ and re-sorts; all-⊤ collapses to `PProduct []`.  Component
-- saturation (prefix→LCP→⊤, set→card-cap→⊤) is inherited from the recursive calls.
djoinN (PProduct ax) (PProduct bx) =
  productNorm (map (joinAxis ax bx) (axisUnion ax bx))
djoinN p _ = p  -- domain mismatch — never happens

-- join the two sides' values on axis `name` (missing side = sub-⊤).  The sub-⊤
-- to use is taken from whichever side HAS the axis (both sides' axes are sub-⊤
-- compatible since one label has one product shape).
joinAxis : List (String, Param) -> List (String, Param) -> String -> (String, Param)
joinAxis ax bx name = match (lookupAxis name ax, lookupAxis name bx)
  (Some pa, Some pb) => (name, djoinN pa pb)
  (Some pa, None) => (name, djoinN pa (subTopOf pa))
  (None, Some pb) => (name, djoinN (subTopOf pb) pb)
  (None, None) => (name, PUnit)  -- unreachable (name ∈ union)

-- the sorted union of axis NAMES present in either side.
axisUnion : List (String, Param) -> List (String, Param) -> List String
axisUnion ax bx = sortUniqS (map fst ax ++ map fst bx)

-- canonicalize a product: drop axes whose value is its sub-domain ⊤ (unconstrained
-- ⇒ omit), sort by axis name; all-⊤ ⇒ `PProduct []` (the product ⊤).
productNorm : List (String, Param) -> Param
productNorm axes =
  PProduct (sortAxes (filterList (p => not (isSubTop (snd p))) axes))

-- is a sub-param the ⊤ of its sub-domain?
isSubTop : Param -> Bool
isSubTop (PPrefix None) = True
isSubTop (PSet None) = True
isSubTop (PProduct []) = True
isSubTop PUnit = True
isSubTop _ = False

-- sort an axis assoc-list by axis name (insertion sort — the axis count is tiny).
sortAxes : List (String, Param) -> List (String, Param)
sortAxes [] = []
sortAxes (x::xs) = insertAxis x (sortAxes xs)

insertAxis : (String, Param) -> List (String, Param) -> List (String, Param)
insertAxis x [] = [x]
insertAxis x (y::ys) = match stringCompare (fst x) (fst y)
  Gt => y :: insertAxis x ys
  _ => x :: y::ys

-- Set-domain cardinality cap: a join whose union exceeds this many distinct
-- authority elements saturates to ⊤ (PSet None), bounding the lattice height.
setCardCap : Int
setCardCap = 16

-- length of the longest common prefix of two strings (Stage-2 djoin support)
commonPrefixLen : String -> String -> Int -> Int
commonPrefixLen a b i =
  if i >= stringLength a || i >= stringLength b then
    i
  else if stringSlice i (i + 1) a == stringSlice i (i + 1) b then
    commonPrefixLen a b (i + 1)
  else
    i

-- manifest / error text for a param.  ⊤ renders as empty so a ⊤-param atom
-- renders as JUST its label — byte-identical to v1.
export drender : Param -> String
drender p = drenderN (normHole p)

drenderN : Param -> String
drenderN PUnit = ""
drenderN (PPrefix None) = ""
drenderN (PPrefix (Some s)) = " \"" ++ s ++ "\""
drenderN (PSet None) = ""  -- ⊤ renders empty (like the others)
drenderN (PSet (Some xs)) = " {" ++ joinWith ", " (map quoteStr xs) ++ "}"
-- WS-4: render a product as the chosen USER SURFACE (keyword-axes, capitalized:
-- `Host="…" Method={…}`) so error/manifest text round-trips back through the
-- parser.  Product-⊤ (`PProduct []`) renders empty, like every other ⊤.
drenderN (PProduct []) = ""
drenderN (PProduct ax) = " " ++ renderProductLit ax

quoteStr : String -> String
quoteStr s = "\"" ++ s ++ "\""

-- WS-4: render a product's constrained axes as `Host="…" Method={…}` (space-
-- separated, axis-sorted) — the Option-A keyword-axes user surface.  Each axis
-- value renders via its sub-domain (`drenderN` drops the leading space, which we
-- supply per axis as `Name=`).  Only constrained axes appear (⊤ axes are absent
-- by `productNorm`), so the surface is minimal.
renderProductLit : List (String, Param) -> String
renderProductLit ax = joinWith " " (map renderAxis ax)

renderAxis : (String, Param) -> String
renderAxis (name, p) = "\{name}=\{renderAxisVal p}"

-- an axis value WITHOUT the leading-space that `drenderN` prefixes (we reuse the
-- sub-domain rendering but strip the space, so Host="a/*" / Method={"GET"}).
renderAxisVal : Param -> String
renderAxisVal (PPrefix (Some s)) = "\"" ++ s ++ "\""
renderAxisVal (PSet (Some xs)) = "{" ++ joinWith ", " (map quoteStr xs) ++ "}"
renderAxisVal _ = ""  -- a ⊤ axis never reaches here (productNorm drops it)

-- ── atom-set helpers (replace the v1 String-set ops) ───────────────────────
-- render one atom: label + domain refinement text (⊤ ⇒ just the label)
renderAtom : Atom -> String
renderAtom a = atomLabel a ++ drender (atomParam a)

-- render a set of atoms as the comma-separated body of a `<…>`, label-sorted —
-- byte-identical to v1 when all params are ⊤.
renderAtoms : List Atom -> String
renderAtoms atoms = joinWith ", " (map renderAtom (atomsNorm atoms))

-- insert an atom into a label-sorted set, joining same-label params (djoin).
-- With all-⊤ params this is exactly v1's sortInsertS over labels.
atomInsert : Atom -> List Atom -> List Atom
atomInsert x [] = [x]
atomInsert x (y::ys) = match stringCompare (atomLabel x) (atomLabel y)
  Lt => x :: y::ys
  Eq => Atom (atomLabel y) (djoin (atomParam x) (atomParam y)) :: ys
  Gt => y :: atomInsert x ys

-- canonical form: ≤ one atom per label (same-label params joined), label-sorted.
atomsNorm : List Atom -> List Atom
atomsNorm xs = atomsNormGo xs []

atomsNormGo : List Atom -> List Atom -> List Atom
atomsNormGo [] acc = acc
atomsNormGo (x::xs) acc = atomsNormGo xs (atomInsert x acc)

-- union of two atom sets, joining same-label params
atomsUnion : List Atom -> List Atom -> List Atom
atomsUnion a b = atomsNorm (a ++ b)

-- set difference: atoms of [a] whose label is absent from [b], OR present but
-- NOT subsumed (`not (dsub pa pb)`) — the Stage-2 escape direction.  In Stage 1
-- (all ⊤) "present" always means subsumed ⇒ pure label-set diff.
atomsDiff : List Atom -> List Atom -> List Atom
atomsDiff [] _ = []
atomsDiff (x::xs) ys = match findAtom (atomLabel x) ys
  None => x :: atomsDiff xs ys
  Some y =>
    if dsub (atomParam x) (atomParam y) then
      atomsDiff xs ys
    else
      x :: atomsDiff xs ys

findAtom : String -> List Atom -> Option Atom
findAtom _ [] = None
findAtom l (y::ys) = if l == atomLabel y then Some y else findAtom l ys

-- lift a bare AST label to a ⊤-param atom (Stage 1: every annotation atomic)
atomOfLabel : String -> Atom
atomOfLabel l = Atom l (dtopFor l)

-- ── v2 Stage 3: the `IO` widening union alias (design §3.2) ─────────────────
-- `IO` is the coarse security alias: in a BOUND/annotation row it stands for
-- the join of every narrow security label at ⊤.  ioAliasLabels lists them
-- (every minted security label EXCEPT IO itself); internal labels (Mut/Panic)
-- are NOT members, so they are tracked independently of IO.  (Mirror of
-- lib/typecheck.ml's io_alias_labels.)
ioAliasLabels : List String
ioAliasLabels = [
  "Stdout",
  "Stderr",
  "Stdin",
  "Clock",
  "Env",
  "Exec",
  "Rand",
  "Net",
  "FileRead",
  "FileWrite",
]

-- expand a bound `IO` atom into the security-label alias before an escape
-- check, so a NARROW inferred row is subsumed by an `<IO>` bound (narrow ⊑ IO
-- accepts).  Sound in reverse: an inferred raw `IO` against a NARROW bound is
-- never expanded (the bound has no IO) ⇒ escapes (IO ⊑ narrow rejects).  `IO`
-- stays in the expansion (atomsNorm keeps it) so inferred IO-vs-IO matches.
expandIoInBound : List Atom -> List Atom
expandIoInBound b = match findAtom "IO" b
  None => b
  Some _ => atomsNorm (b ++ map atomOfLabel ioAliasLabels)

-- escape-direction difference: inferred [a] not permitted by bound [b], with
-- the bound's `IO` widened to its security-label alias first.
atomsEscape : List Atom -> List Atom -> List Atom
atomsEscape a b = atomsDiff a (expandIoInBound b)

-- build an atom from a WRITTEN annotation label, threading its optional param.
-- A bare label takes the domain ⊤; a written param becomes PPrefix (Some pat)
-- when the label's domain is Prefix, else (atomic label) stays ⊤ (the param is
-- diagnosed + dropped by checkEffectParams).  Pure: validation is a separate pass.
atomOfWritten : (String, Option String) -> Atom
atomOfWritten (l, None) = Atom l (dtopFor l)
atomOfWritten (l, Some pat) =
  -- the universal inferred-hole marker `_`: recognized REGARDLESS of the label's
  -- domain (a Set-domain `<Env _>` must stay a hole, not become `PSet ["_"]`).
  -- The domain-directed fillHoleAtom replaces it with the correct domain param.
  if isHoleStr pat then Atom l (PPrefix (Some pat))
  else match dtopFor l
    PPrefix None => Atom l (PPrefix (Some pat))
    PSet None => Atom l (PSet (Some (decodeSetParam pat)))
    PProduct _ => Atom l (decodeProductParam pat)
    _ => Atom l (dtopFor l)

-- A Set-domain written param is carried in the `Option String` carrier as a
-- brace-delimited, comma-separated literal `{a,b,c}` (the parser's `effParamFor`
-- TLBrace clause builds exactly this).  Decode it back to the element list.
-- (Keeps the carrier type `Option String`, so no AST `TyEffect` ripple.)
export decodeSetParam : String -> List String
decodeSetParam s =
  let n = stringLength s
  if n >= 2 && stringSlice 0 1 s == "{" && stringSlice (n - 1) n s == "}" then
    sortUniqS (filterList (!= "") (splitOnComma (stringSlice 1 (n - 1) s)))
  else
    sortUniqS (filterList (!= "") (splitOnComma s))

-- WS-4: a PRODUCT written param is carried in the `Option String` carrier as a
-- structured SENTINEL string the parser's `effParamFor` product clause builds:
--
--   @P{Host="idp.example.com/*";Method={GET,POST}}
--
-- Grammar (internal wire form, NOT user syntax — that is §4 of WS-4-DESIGN.md):
--   @P{                         -- product sentinel prefix
--     <Axis>=<val>              -- one or more axes, ';'-separated
--   }                           -- closing brace
-- where <val> is either `"…"` (a Prefix sub-param) or `{a,b}` (a Set sub-param).
-- A PLAIN string with NO `@P{` sentinel is the §3 "host-axis lift": a bare
-- `<Net "a.com/*">` under a Product-registered Net means Host=a.com/*, Method=⊤.
-- (A *third* nested level would make this encoding fiddly — WS-4 is the natural
-- stopping point for the carrier hack; widen the AST carrier THEN, not piecemeal.)
export decodeProductParam : String -> Param
decodeProductParam s =
  let n = stringLength s
  if n >= 4 && stringSlice 0 3 s == "@P{" && stringSlice (n - 1) n s == "}" then
    productNorm (map decodeAxis (splitOnSemi (stringSlice 3 (n - 1) s)))
  else
    productNorm [("Host", PPrefix (Some s))]

-- decode one `Axis=val` axis spec.  val = `"…"` ⇒ Prefix; `{a,b}` ⇒ Set.
decodeAxis : String -> (String, Param)
decodeAxis spec = match splitOnFirstEqStr spec
  None => (spec, PUnit)          -- malformed (no '='): treated as ⊤ ⇒ dropped by productNorm
  Some i =>
    let name = stringSlice 0 i spec
    let rhs = stringSlice (i + 1) (stringLength spec) spec
    (name, decodeAxisVal rhs)

decodeAxisVal : String -> Param
decodeAxisVal rhs =
  let n = stringLength rhs
  if n >= 2 && stringSlice 0 1 rhs == "{" && stringSlice (n - 1) n rhs == "}" then
    PSet (Some (decodeSetParam rhs))
  else if n >= 2 && stringSlice 0 1 rhs == "\"" && stringSlice (n - 1) n rhs == "\"" then
    PPrefix (Some (stringSlice 1 (n - 1) rhs))
  else
    PPrefix (Some rhs)

-- index of the first '=' in a string, or None.
splitOnFirstEqStr : String -> Option Int
splitOnFirstEqStr s = splitOnFirstEqGo s 0 (stringLength s)

splitOnFirstEqGo : String -> Int -> Int -> Option Int
splitOnFirstEqGo s i n =
  if i >= n then
    None
  else if stringSlice i (i + 1) s == "=" then
    Some i
  else
    splitOnFirstEqGo s (i + 1) n

-- split a string on ';' (product-axis separator).
splitOnSemi : String -> List String
splitOnSemi s = splitOnSemiGo s 0 0 []

splitOnSemiGo : String -> Int -> Int -> List String -> List String
splitOnSemiGo s start i acc =
  let n = stringLength s
  if i >= n then
    reverseL (stringSlice start n s :: acc)
  else if stringSlice i (i + 1) s == ";" then
    splitOnSemiGo s (i + 1) (i + 1) (stringSlice start i s :: acc)
  else
    splitOnSemiGo s start (i + 1) acc

-- split a string on ',' (Set-element separator; authority tokens contain none)
splitOnComma : String -> List String
splitOnComma s = splitOnCommaGo s 0 0 []

splitOnCommaGo : String -> Int -> Int -> List String -> List String
splitOnCommaGo s start i acc =
  let n = stringLength s
  if i >= n then
    reverseL (stringSlice start n s :: acc)
  else if stringSlice i (i + 1) s == "," then
    splitOnCommaGo s (i + 1) (i + 1) (stringSlice start i s :: acc)
  else
    splitOnCommaGo s start (i + 1) acc

atomsOfWritten : List (String, Option String) -> List Atom
atomsOfWritten ls = atomsNorm (map atomOfWritten ls)

-- ── v2 Stage 2b: known-literal-prefix abstract analysis α (design §2.4) ─────
-- Abstract a DESUGARED core string-producing expr to a known literal prefix or
-- Unknown.  Intraprocedural (fork (c)): EApp results, fn-parameter EVars, field
-- access ⇒ Unknown ⇒ ⊤.  `lets` carries let-bound RHSs in scope for the EVar
-- rule.  (Mirror of lib/typecheck.ml's `alpha`.)
data KP = Known String | Unknown

-- longest common prefix as a KP (Unknown if empty)
kpLcp : String -> String -> KP
kpLcp a b =
  let k = commonPrefixLen a b 0
  if k == 0 then Unknown else Known (stringSlice 0 k a)

-- `++`: the left operand's known prefix is fixed regardless of the right (§2.4)
alphaLeftPrefix : KP -> KP
alphaLeftPrefix (Known pa) = Known pa
alphaLeftPrefix Unknown = Unknown

alpha : List (String, Expr) -> Expr -> KP
alpha lets (ELoc _ e) = alpha lets e
alpha lets (EDoOrigin _ e) = alpha lets e
alpha lets (EAnnot e _) = alpha lets e
alpha lets (EHeadAnnot e _) = alpha lets e
alpha _ (ELit (LString s)) = Known s
alpha lets (EBinOp op a _ _)
  | op == "++" = alphaLeftPrefix (alpha lets a)
alpha _ (EBinOp _ _ _ _) = Unknown
alpha lets (EVar x) = match lookupAssoc x lets
  Some rhs => alpha lets rhs
  None => Unknown
alpha lets (ELet _ _ (PVar x) e1 e2) = alpha ((x, e1)::lets) e2
alpha lets (ELet _ _ _ _ e2) = alpha lets e2
alpha lets (ELetGroup binds body) = alpha (alphaCollectBinds binds lets) body
alpha lets (EIf _ t f) = match alpha lets t
  Known a => match alpha lets f
    Known b => kpLcp a b
    Unknown => Unknown
  Unknown => Unknown
alpha lets (EMatch _ arms) = alphaArms lets None arms
alpha _ _ = Unknown

-- propagate single-clause zero-param where-bindings (`x = e`) into scope
alphaCollectBinds : List LetBind -> List (String, Expr) -> List (String, Expr)
alphaCollectBinds [] acc = acc
alphaCollectBinds ((LetBind n clauses)::rest) acc = match clauses
  [FunClause [] rhs] => alphaCollectBinds rest ((n, rhs)::acc)
  _ => alphaCollectBinds rest acc

-- LCP of all arm results if every arm is Known; else Unknown
alphaArms : List (String, Expr) -> Option String -> List Arm -> KP
alphaArms _ (Some s) [] = Known s
alphaArms _ None [] = Unknown
alphaArms lets acc ((Arm _ _ rhs)::rest) = match alpha lets rhs
  Unknown => Unknown
  Known s => match acc
    None => alphaArms lets (Some s) rest
    Some a => match kpLcp a s
      Known c => alphaArms lets (Some c) rest
      Unknown => Unknown

-- the FIRST argument of an application spine: `f a b c` ⇒ Some a (locked dec 1)
spineFirstArg : Expr -> Option Expr
spineFirstArg (ELoc _ e) = spineFirstArg e
spineFirstArg (EDoOrigin _ e) = spineFirstArg e
spineFirstArg (EApp f x) = match spineHeadIsApp f
  True => spineFirstArg f
  False => Some x
spineFirstArg _ = None

-- is the application head itself a (curried) application?  `EApp (EApp ..) _`
-- ⇒ recurse left; `EApp (EVar/leaf) x` ⇒ x is the first arg.
spineHeadIsApp : Expr -> Bool
spineHeadIsApp (ELoc _ e) = spineHeadIsApp e
spineHeadIsApp (EDoOrigin _ e) = spineHeadIsApp e
spineHeadIsApp (EApp _ _) = True
spineHeadIsApp _ = False

-- the delimiter footgun guard (design §2.5 / fork (b)): a written Prefix pattern
-- must end in `*` or contain a `/` delimiter; a bare prefix is ambiguous.
prefixPatternOk : String -> Bool
prefixPatternOk s =
  let n = stringLength s
  n > 0 && (stringSlice (n - 1) n s == "*" || strHasSlash s)

strHasSlash : String -> Bool
strHasSlash s = strHasSlashGo s 0 (stringLength s)

strHasSlashGo : String -> Int -> Int -> Bool
strHasSlashGo s i n =
  if i >= n then
    False
  else if stringSlice i (i + 1) s == "/" then
    True
  else
    strHasSlashGo s (i + 1) n

-- forall <quantified tyvar ids> <quantified effvar ids>. mono
public export data Scheme = Forall (List Int) (List Int) Mono

-- ── global inference state ────────────────────────────────────────────────
tyvarCounter : Ref Int
tyvarCounter = Ref 0

currentLevel : Ref Int
currentLevel = Ref 0

newTyvarId : Unit -> Int
newTyvarId _ =
  let n = tyvarCounter.value
  let _ = setRef tyvarCounter (n + 1)
  n

freshVar : Unit -> Mono
freshVar _ = TVar (Ref (Unbound (newTyvarId ()) currentLevel.value))

-- ── effect variables + rows (Phase 79/146) ────────────────────────────────
effvarCounter : Ref Int
effvarCounter = Ref 0

newEffvarId : Unit -> Int
newEffvarId _ =
  let n = effvarCounter.value
  let _ = setRef effvarCounter (n + 1)
  n

-- the empty closed row — a pure arrow
pureRow : EffRow
pureRow = EffRow [] None

freshEffvar : Unit -> Ref Effvar
freshEffvar _ = Ref (EUnbound (newEffvarId ()) currentLevel.value)

freshEffvarAt : Int -> Ref Effvar
freshEffvarAt lvl = Ref (EUnbound (newEffvarId ()) lvl)

-- an open row with a fresh tail variable
openRow : Unit -> EffRow
openRow _ = EffRow [] (Some (freshEffvar ()))

-- follow ELink tails (merging labels) to a canonical row whose tail, if present,
-- is an unbound effvar
effrowNorm : EffRow -> EffRow
effrowNorm (EffRow labels tail) = match tail
  Some cell => match cell.value
    ELink r2 =>
      let nr = effrowNorm r2
      match nr
        EffRow ls2 t2 => EffRow (atomsUnion labels ls2) t2
    EUnbound _ _ => EffRow labels tail
  None => EffRow labels tail

-- the concrete labels (atoms) currently known for a row (ignores the open tail)
export effrowLabels : EffRow -> List Atom
effrowLabels r = match effrowNorm r
  EffRow labels _ => labels

-- v2 Stage 2b: fill inferred-hole atoms in a freshly-incurred call effect row.
-- Returns a row whose head labels have every hole atom replaced by α of the
-- call's first spine argument (Unknown / no-arg ⇒ ⊤); non-hole atoms and the
-- open tail are preserved.  When no hole is present the row is unchanged.
-- `lets` is the enclosing function body's α-let scope (EFFECTS WS-2): seeded into
-- α so an outer-body `let dest = "…"; fetch dest` recovers the literal prefix.
-- (Mirror of lib/typecheck.ml's fill_holes_in_row.)
fillHolesInRow : List (String, Expr) -> EffRow -> Option Expr -> EffRow
fillHolesInRow lets eff firstArg = match effrowNorm eff
  EffRow labels tail =>
    if anyHoleAtom labels then
      EffRow (map (fillHoleAtom lets firstArg) labels) tail
    else
      eff

anyHoleAtom : List Atom -> Bool
anyHoleAtom [] = False
anyHoleAtom (a::rest) =
  if isHoleParam (atomParam a) then
    True
  else
    anyHoleAtom rest

fillHoleAtom : List (String, Expr) -> Option Expr -> Atom -> Atom
fillHoleAtom lets firstArg a =
  if isHoleParam (atomParam a) then
    Atom (atomLabel a) (holeFillParam (atomLabel a) lets firstArg)
  else
    a

-- DOMAIN-DIRECTED hole fill (WS-3b): the recovered literal becomes the right
-- shape for the LABEL's domain.  Prefix-domain (Net/Exec) ⇒ `PPrefix (Some s)`;
-- Set-domain (Env) ⇒ a singleton authority set `PSet (Some [s])`.  No recovery
-- (no arg / Unknown) ⇒ the domain's ⊤ (`dtopFor label`), NOT a hardcoded
-- `PPrefix None` — an unfilled Env hole must degrade to `PSet None`, not Prefix-⊤.
-- WS-4: Product-domain (Net) ⇒ Host=recovered-literal, Method=⊤ (α has no method
-- info — a sound over-approximation).
holeFillParam : String -> List (String, Expr) -> Option Expr -> Param
holeFillParam label lets (Some e) = match alpha lets e
  Known s => match dtopFor label
    PSet None => PSet (Some (sortUniqS [s]))
    PPrefix None => PPrefix (Some s)
    PProduct _ => productNorm [("Host", PPrefix (Some s))]
    _ => dtopFor label
  Unknown => dtopFor label
holeFillParam label _ None = dtopFor label

effvarLevel : Ref Effvar -> Int
effvarLevel cell = match cell.value
  EUnbound _ l => l
  ELink _ => 0

-- sorted + deduplicated string set (canonical effect-label order, matching the
-- OCaml `List.sort_uniq String.compare` so multi-label rows render identically)
-- sortUniqS / sortUniqSGo / sortInsertS moved to support/util.mdk (imported above).

enterLevel : Unit -> Unit
enterLevel _ = setRef currentLevel (currentLevel.value + 1)

exitLevel : Unit -> Unit
exitLevel _ = setRef currentLevel (currentLevel.value - 1)

-- ── effect propagation (Phase 79) ─────────────────────────────────────────
-- the latent effect of the function body currently being inferred: application
-- arms widen it; entering a lambda saves+reopens it, and the accumulated row
-- becomes the lambda's arrow effect.  A closed (tail=None) ambient is a SINK that
-- discards effects — the top-level state where a value binding's effects drop.
curEffect : Ref EffRow
curEffect = Ref (EffRow [] None)

-- the unbound-tail id of an effvar cell (-1 once linked); unique like tyvar ids,
-- so id-equality stands in for the reference's physical `==` on effvars
effvarId : Ref Effvar -> Int
effvarId cell = match cell.value
  EUnbound id _ => id
  ELink _ => 0 - 1

-- record that the current context performs row [eff]'s effects, widening ambient
-- [cur] WITHOUT closing its tail (so the next performed effect can still be
-- absorbed).  A closed ambient is a sink and discards.  An open [eff] is tied to
-- the ambient through a shared fresh tail.
performEffect : Ref EffRow -> EffRow -> Unit
performEffect cur eff = match effrowNorm cur.value
  EffRow _ None => ()
  EffRow curLabels (Some ct) => match effrowNorm eff
    EffRow effLabels effTail =>
      let _ = setRef cur (EffRow (atomsUnion curLabels effLabels) (Some ct))
      match effTail
        Some et => if effvarId et == effvarId ct then () else performLink ct et
        None => ()

performLink : Ref Effvar -> Ref Effvar -> Unit
performLink ct et =
  let v3 = freshEffvarAt (minI (effvarLevel ct) (effvarLevel et))
  let _ = setRef ct (ELink (EffRow [] (Some v3)))
  setRef et (ELink (EffRow [] (Some v3)))

-- unify two effect rows.  PERMISSIVE (Phase 79): an open row absorbs the other
-- side's labels by binding its tail; two open rows route through one shared fresh
-- tail.  Differing closed rows / an open row whose labels exceed a closed bound
-- are left as-is (the laundering subset check lands in Phase 146, Stage D).
unifyRow : EffRow -> EffRow -> Unit
unifyRow r1 r2 = unifyRowN (effrowNorm r1) (effrowNorm r2)

unifyRowN : EffRow -> EffRow -> Unit
unifyRowN (EffRow l1 (Some v1)) (EffRow l2 (Some v2))
  | effvarId v1 == effvarId v2 = ()
  | otherwise =
    let v3 = freshEffvarAt (minI (effvarLevel v1) (effvarLevel v2))
    let _ = setRef v1 (ELink (EffRow (atomsDiff l2 l1) (Some v3)))
    setRef v2 (ELink (EffRow (atomsDiff l1 l2) (Some v3)))
unifyRowN (EffRow l1 (Some v1)) (EffRow l2 None) =
  let _ = effectLeakCheck (atomsEscape l1 l2) l2
  setRef v1 (ELink (EffRow (atomsDiff l2 l1) None))
unifyRowN (EffRow l1 None) (EffRow l2 (Some v2)) =
  let _ = effectLeakCheck (atomsEscape l2 l1) l1
  setRef v2 (ELink (EffRow (atomsDiff l1 l2) None))
unifyRowN (EffRow _ None) (EffRow _ None) = ()

-- SOUNDNESS (Phase 146): an open row (an inference-synthesized arrow, i.e. a
-- concrete value's latent effect) meeting a closed bound — its own labels must
-- not exceed the bound, else they escape.  [escaping] = open labels \ bound.
effectLeakCheck : List Atom -> List Atom -> Unit
effectLeakCheck [] bound = ()
effectLeakCheck escaping bound =
  pushTypeError "T-EFFECT-LEAK" (effectLeakMsg bound escaping)

effectLeakMsg : List Atom -> List Atom -> String
effectLeakMsg bound extras = "Effectful value used where <\{renderAtoms bound}> is allowed, but it performs <\{renderAtoms extras}>"

-- v2 Stage 2a: diagnostic for a rejected written effect param (mirror of
-- lib/typecheck.ml's EffectParam message).
effectParamMsg : String -> String -> String
effectParamMsg label why = "Invalid effect parameter on <\{label}>: \{why}"

-- Runtime B1 dedup: the shared "must end in '*' or contain a '/'…" rationale for
-- a bare prefix param, parameterized by the noun (`pattern` for a top-level
-- Prefix param, `Host pattern` for a product's Host axis).
prefixPatternErrMsg : String -> String -> String
prefixPatternErrMsg noun pat = "\{noun} \"\{pat}\" must end in '*' or contain a '/' delimiter (a bare prefix would admit a sibling host/path)"

-- validate every written effect param in a program's type annotations against
-- the registry: a Prefix label's pattern must pass prefixPatternOk; an atomic
-- label rejects a param outright.  Runs as a <Mut> pass (errors via
-- pushTypeError) — the OCaml side does this inline in atom_of_written.
checkEffectParams : List Decl -> Unit
checkEffectParams [] = ()
checkEffectParams (d::rest) =
  let _ = checkEffectParamsDecl d
  checkEffectParams rest

checkEffectParamsDecl : Decl -> Unit
checkEffectParamsDecl (DTypeSig _ _ t) = checkEffectParamsTy t
checkEffectParamsDecl (DExtern _ _ t) = checkEffectParamsTy t
checkEffectParamsDecl (DAttrib _ d) = checkEffectParamsDecl d
checkEffectParamsDecl _ = ()

checkEffectParamsTy : Ty -> Unit
checkEffectParamsTy (TyFun a b) =
  let _ = checkEffectParamsTy a
  checkEffectParamsTy b
checkEffectParamsTy (TyApp a b) =
  let _ = checkEffectParamsTy a
  checkEffectParamsTy b
checkEffectParamsTy (TyTuple ts) = checkEffectParamsTys ts
checkEffectParamsTy (TyEffect labels _ t) =
  let _ = checkEffectAtoms labels
  checkEffectParamsTy t
checkEffectParamsTy (TyConstrained _ t) = checkEffectParamsTy t
checkEffectParamsTy _ = ()

checkEffectParamsTys : List Ty -> Unit
checkEffectParamsTys [] = ()
checkEffectParamsTys (t::ts) =
  let _ = checkEffectParamsTy t
  checkEffectParamsTys ts

checkEffectAtoms : List (String, Option String) -> Unit
checkEffectAtoms [] = ()
checkEffectAtoms ((_, None)::rest) = checkEffectAtoms rest
checkEffectAtoms ((l, Some pat)::rest) =
  let _ = checkOneEffectParam l pat
  checkEffectAtoms rest

checkOneEffectParam : String -> String -> Unit
checkOneEffectParam l pat = match dtopFor l
  PPrefix None =>
    -- v2 Stage 2b: the inferred hole "_" carries no written pattern to validate.
    if isHoleStr pat then ()
    else if prefixPatternOk pat then ()
    else pushTypeError "T-EFFECT-PARAM" (effectParamMsg l (prefixPatternErrMsg "pattern" pat))
  PSet None =>
    -- Set-domain param is a brace-set literal `{a,b}` (parser-encoded); always well-formed.
    ()
  PProduct _ =>
    checkProductAxes l (decodeProductParam pat)
  _ => pushTypeError "T-EFFECT-PARAM" (effectParamMsg l
    "label '\{l}' is atomic and takes no parameter (declare it `effect \{l} Prefix` to parameterize)")

-- WS-4: validate a decoded product's axes: a Host (Prefix) axis must pass
-- prefixPatternOk; a Method (Set) axis is always well-formed; any other axis name
-- is rejected (only Host/Method are known product axes for Net).
checkProductAxes : String -> Param -> Unit
checkProductAxes l (PProduct axes) = checkProductAxesGo l axes
checkProductAxes _ _ = ()

checkProductAxesGo : String -> List (String, Param) -> Unit
checkProductAxesGo _ [] = ()
checkProductAxesGo l ((name, p)::rest) =
  let _ = checkOneAxis l name p
  checkProductAxesGo l rest

checkOneAxis : String -> String -> Param -> Unit
checkOneAxis l "Host" (PPrefix (Some pat)) =
  if prefixPatternOk pat then
    ()
  else
    pushTypeError "T-EFFECT-PARAM" (effectParamMsg l (prefixPatternErrMsg "Host pattern" pat))
checkOneAxis _ "Method" _ = ()
checkOneAxis l name _ =
  pushTypeError
    "T-EFFECT-PARAM"
    (effectParamMsg
      l
      ("unknown product axis '" ++ name ++ "' (known axes: Host, Method)"))

-- replace a row's bound tail effvar with its fresh instance from [esub], so each
-- call site of a polymorphic HOF gets its own effect variable
substRow : List (Int, Ref Effvar) -> EffRow -> EffRow
substRow esub r = match effrowNorm r
  EffRow labels (Some v) => match v.value
    EUnbound id _ => match lookupAssocI id esub
      Some v2 => EffRow labels (Some v2)
      None => EffRow labels (Some v)
    ELink _ => EffRow labels (Some v)
  EffRow labels None => EffRow labels None

-- lower a row's tail effvar level to <= [level] alongside the tyvar being bound
lowerRowLevels : Int -> EffRow -> Unit
lowerRowLevels level r = match effrowNorm r
  EffRow _ (Some v) => match v.value
    EUnbound id lvl => if lvl > level then setRef v (EUnbound id level) else ()
    ELink _ => ()
  EffRow _ None => ()

-- build a curried arrow carrying the body's latent effect [eff] on the LAST arrow
-- only; intermediate arrows stay pure-open (partial application performs nothing)
arrowsWithLastEffect : List Mono -> EffRow -> Mono -> Mono
arrowsWithLastEffect [] _ ret = ret
arrowsWithLastEffect [pt] eff ret = TFun pt eff ret
arrowsWithLastEffect (pt::rest) eff ret =
  TFun pt (openRow ()) (arrowsWithLastEffect rest eff ret)

-- free generalizable effect variables: a row tail effvar deeper than the current
-- scope (deduped by the caller, mirroring freeGenVars)
freeEffvars : Mono -> List Int
freeEffvars t = match normalize t
  TVar cell => match cell.value
    Link t2 => freeEffvars t2
    Unbound _ _ => []
  TCon _ => []
  TApp a b => freeEffvars a ++ freeEffvars b
  TFun a r b => freeEffvars a ++ rowFreeEffvars r ++ freeEffvars b
  TEff r => rowFreeEffvars r

rowFreeEffvars : EffRow -> List Int
rowFreeEffvars r = match effrowNorm r
  EffRow _ (Some v) => match v.value
    EUnbound id lvl => if lvl > currentLevel.value then [id] else []
    ELink _ => []
  EffRow _ None => []

-- the declared concrete effect set of a signature: labels on the first `<…>`
-- reached walking down the return side (Phase 79e escape check)
declaredEffects : Ty -> List Atom
declaredEffects (TyFun _ ret) = declaredEffects ret
declaredEffects (TyEffect effs _ _) = atomsOfWritten effs
declaredEffects (TyConstrained _ t) = declaredEffects t
declaredEffects _ = []

-- record metadata: name → (quantified param ids, result mono, field types).  A
-- global Ref (like the reference's record table) so field access / create /
-- update / patterns can look records up without threading an env field.
public export data RecordInfo = RecordInfo (List Int) Mono (List (String, Mono))

recordsRef : Ref (List (String, RecordInfo))
recordsRef = Ref []

-- Kind of a data-type parameter, inferred from usage: KRow iff the param name
-- appears in a field's effect-tail position (`<e>`), else KType.  Drives
-- kind-aware type-app elaboration (a KRow arg becomes a TEff row, not a TApp
-- tyvar) and ctor-result-type construction.  Per-type, positional.
public export data Kind = KType | KRow

dataParamKindsRef : Ref (List (String, List Kind))
dataParamKindsRef = Ref []

-- Transparent type aliases (`type Foo = Int`, `type Pair a = (a, a)`).  Keyed by
-- alias name → (params, RHS surface type).  Populated in a pre-pass by
-- `registerData`'s DTypeAlias arm (mirrors `dataParamKindsRef`); consulted
-- on-demand at the `Ty→Mono` seam (`fromAstTypeE`) to expand an alias to its RHS.
-- The param list is stored even though stage 2 only expands the zero-param case,
-- so parameterized expansion (stage 3) can extend this without reshaping the table.
aliasTableRef : Ref (List (String, (List String, Ty)))
aliasTableRef = Ref []

-- Names of record/named-field types exported ABSTRACTLY (`export data`/`export
-- record` without `public`).  Seeded ONCE (over EVERY module's decls, prelude
-- included) by the multi-module check drivers, BEFORE per-module checking, and
-- deliberately NOT cleared by resetState — it is whole-program metadata, not a
-- per-module accumulator.  An abstract export brings the type NAME into scope but
-- never registers its fields (publicDataDecls drops VisAbstract decls, so they
-- reach neither recordsRef nor dataParamKindsRef in an importer).  A dot-access on
-- such a type therefore lands at resolveFieldRecord's `head known but no record
-- info` branch with the type name still recoverable as the receiver's head tycon;
-- membership here distinguishes that case (clear abstract-export diagnostic) from a
-- genuinely-unknown field on an unbound receiver (the `<unknown>` message).  This
-- mirrors resolve's destructure-side AbstractFieldAccess signal (env.types ∋ owner
-- ∧ owner owns no field) without threading anything new through the import seed.
abstractRecordTypesRef : Ref (List String)
abstractRecordTypesRef = Ref []

-- collect the names of all VisAbstract record-shaped (a DData whose variants
-- carry named fields) decls across the given decl list.  Only
-- record-shaped abstract types can be a dot-access receiver, but harvesting any
-- abstract DData name too is harmless (a positional ADT can't reach the abstract
-- branch with a field access — its fields never exist).
collectAbstractRecordTypes : List Decl -> List String
collectAbstractRecordTypes [] = []
collectAbstractRecordTypes ((DData VisAbstract n _ _ _)::rest) =
  n :: collectAbstractRecordTypes rest
collectAbstractRecordTypes (_::rest) = collectAbstractRecordTypes rest

-- seed abstractRecordTypesRef from every module's decls (the per-module progs plus
-- the prelude/core decls), once, before checking begins.
seedAbstractRecordTypes : List Decl -> List (String, List Decl) -> Unit
seedAbstractRecordTypes coreDecls modules =
  setRef
    abstractRecordTypesRef
    (collectAbstractRecordTypes coreDecls ++ flatMap (m => collectAbstractRecordTypes (snd m)) modules)

-- return-position method sites discovered during inference: (method name, the
-- EMethodAt route ref to fill, the EMethodAt impl-dicts ref to fill, the method's
-- result mono).  After the whole program is inferred, each result mono's head
-- tycon is the concrete impl tag the site dispatches to (RKey) — or, when it is a
-- constrained function's constraint variable, that function's dict parameter
-- (RDict).  The impl-dicts ref is filled (single-module elaborate path only) when
-- the route is a parametric impl with a `requires` — one route per requires.
pendingSites : Ref (List (String, Ref Route, Ref (List Route), Mono, Mono, String))
pendingSites = Ref []

-- Phase 151 / Gap G: comparison/equality OPERATOR sites discovered during
-- inference: (method name, the EBinOp route ref to fill, the operand mono).
-- After inference resolveBinopSites stamps each ref with the resolved Eq/Ord impl
-- route (RKey) — but ONLY when the operand grounds to a NON-primitive type; the
-- structural-builtin EBinOp eval path handles primitive / ungroundable operands
-- (so `eq a b = a == b` on Int never recurses).  dictPass then rewrites the
-- stamped node into the method application.
-- (method, route ref, operand mono, inImpl-flag, enclosing-fn name).  The 5th
-- field is currentFn at record time: for a TOP-LEVEL constrained fn an operator on
-- its own constraint var routes RDict $dict_<encl>_<slot> (via enclDictVarOf), the
-- operator analogue of the direct `eq x y` arg-stamp path.
pendingBinopSites : Ref (List (String, Ref Route, Mono, Bool, String))
pendingBinopSites = Ref []

-- Roadmap #18c: the EUnOp analogue of pendingBinopSites — `-` (Num's `negate`)
-- sites discovered during inference.  Same tuple shape/fields, same resolve/
-- rewrite seam (resolveUnopSites / rewriteUnopExpr), one operand instead of two.
pendingUnopSites : Ref (List (String, Ref Route, Mono, Bool, String))
pendingUnopSites = Ref []

-- SHARED-FLOAT-RESIDUAL §3(C): arithmetic EBinOp sites whose operand type may
-- ground to a concrete primitive.  Recorded during inference (operand Mono + the
-- node's route ref); resolveArithSites zonks each Mono after the whole module is
-- inferred and, ONLY when it grounds to concrete Float, stamps RScalar "Float" so
-- lowering carries the scalar type into CBinPrim and the native emitter picks the
-- Float primitive without re-deriving the operand LTy structurally.  A still-
-- polymorphic (Num a) operand never grounds → stays RNone → today's dict path
-- (mirrors resolveBinopSite's grounded-only guard, so dict-routed arithmetic is
-- untouched).  Int operands are left unstamped (RNone ⇒ the Int primitive is the
-- default anyway) to avoid perturbing every integer binop's IR.
pendingArithSites : Ref (List (Ref Route, Mono))
pendingArithSites = Ref []

-- Error-path BLOCKER B4 (audit finding D3): missing-impl dispatch obligations.
-- methodIfaceParamsRef maps each interface method NAME → (iface name, the iface's
-- typarams, the method's declared AST type).  Built once per checkProgramSeeded
-- from the program's DInterface decls.  At each EVar/EMethodAt occurrence of a
-- registered method, recordImplObligation captures the OCCURRENCE mono so that,
-- after inference, checkImplObligations can read what the interface params
-- resolved to (parallel-walking the declared type against the normalized
-- occurrence mono) and reject the call when those concrete head types have NO
-- matching impl in the program — mirroring lib/typecheck.ml's check_method_usages
-- (`No impl of … for …`, lib/typecheck.ml:3845).  Skips while a param is still a
-- polymorphic tyvar (deferred to the caller, exactly like the oracle).
-- #147: keyed by method NAME (was a program-sized assoc List scanned linearly on
-- hot per-node paths).  omInsert is last-write-wins and the register site inserts
-- in the SAME order the old List prepended, so on a method-name collision the
-- latest-registered entry wins — identical to the old `lookupAssoc` first-match.
methodIfaceParamsRef : Ref (OrdMap (String, List String, Ty))
methodIfaceParamsRef = Ref omEmpty

-- #147: cached SET of iface names with ≥1 method registered above, so
-- `ifaceRegistered` is an O(log n) membership test instead of a full linear scan
-- of the method table per operator/numeric-literal.  A separate key (iface name,
-- not method name) and NOT derived from the method map: two interfaces sharing a
-- method name collapse to one entry in the (name-keyed) map, but BOTH must stay
-- registered here — matching the old full-List scan.  Maintained in lockstep at
-- the two mutation sites (registerMethodIfaceParamsMethods and resetState).
registeredIfacesRef : Ref (OrdMap Unit)
registeredIfacesRef = Ref omEmpty

-- C5 (TYPECHECK-AUDIT / Phase 112): names that are BOTH an interface method AND a
-- cross-module-imported standalone top-level function (e.g. box's `toList`/`isEmpty`
-- shadowing Foldable's).  Populated per module by elabModuleStamp from the full graph
-- (a top-level funDef name that is also a method name and is NOT defined in the
-- current module).  resolveSite consults it: a method site at a concrete receiver
-- with NO impl, whose name is here, routes RLocal (eval reads the standalone) instead
-- of RKey<head> (which would panic with no impl).  Mirrors lib/typecheck.ml's
-- env.standalone_values + the EApp RLocal stamp (typecheck.ml:1603-1640,4585).
-- NOT cleared by resetState — elabModuleStamp rebuilds it per module.
standaloneValuesRef : Ref (List String)
standaloneValuesRef = Ref []

-- DEFINER-shadow names (facet 2): the names THIS module declares as a top-level
-- funDef that ALSO name an interface method (buildDefinerShadows) — e.g. a user
-- `eq : List Int -> List Int -> Bool`.  A DIRECT call `eq [1] [2]` in user code
-- must resolve to the user's OWN definition (RLocal), NOT to a method impl, even
-- when the receiver's head HAS an impl of the interface (`List` has `Eq`).  The
-- arg-stamp pass would otherwise stamp `RKey:List` (the impl), making the eval path
-- dispatch to the prelude `Eq (List a)` impl (`[1] ≠ [2]` → False) instead of the
-- user's fn (True) — a run≠build divergence (the EMIT path already routes to the
-- user's def).  resolveRLocalSite stamps these RLocal unconditionally.  Populated
-- per-module in checkModuleFullImpl from buildDefinerShadows; reset by resetState.
definerShadowNamesRef : Ref (List String)
definerShadowNamesRef = Ref []

-- P0-19: the declared top-level SIGNATURES of definer-shadow standalones
-- (`size : Int -> Int`), keyed by name.  When a definer-shadow occurrence resolves
-- to the STANDALONE (no visible impl for the grounded receiver, or an ungrounded
-- receiver), inferDefinerShadowApp enforces this declared domain against the actual
-- argument — closing the S2/S5 "must then type against the standalone's domain" hole
-- that let `size "hi"` / a poly wrapper `useIt x = size x; useIt (Box 3)` type against
-- the permissive method scheme and reach codegen as garbage.  Set per-path from
-- `sigsOf prog`; empty for an unsignatured standalone (no domain to enforce → the old
-- permissive behavior, unchanged).
definerShadowSigsRef : Ref (List (String, Ty))
definerShadowSigsRef = Ref []

-- P0-19 d4b (S4): True while inferring the HEAD of a definer-shadow APPLICATION
-- (`size (Box 3)`) — set around the head-infer call in inferDefinerShadowVarApp /
-- inferDefinerShadowApp.  A shadow occurrence reaches inferVar / inferMethodAt in
-- two shapes: as an application head (dispatch-vs-standalone decided per-receiver by
-- the surrounding shadow-app machinery, so the head must keep the permissive METHOD
-- scheme `a -> Int`) OR in bare VALUE position (`map size xs`, `let f = size`), which
-- S4 says ALWAYS denotes the standalone.  This flag distinguishes the two so only the
-- value-position occurrence is pinned to the standalone scheme.  Default/reset False.
shadowHeadCtxRef : Ref Bool
shadowHeadCtxRef = Ref False

-- P0-18 (EMIT path only): the mangler (`mangleUnits`) renames a definer-shadow
-- standalone def + its call sites to `<mid>__name` BEFORE marking, but (correctly)
-- leaves the interface method name bare — so the mark pass's NAME-based shadow
-- detector (buildStandaloneShadowsGraph / buildDefinerShadows, keyed on
-- funDef-name ∩ iface-method-name) no longer sees a shadow and the occurrence never
-- becomes an `EMethodAt` dispatch site (→ a silent direct call to the standalone =
-- the build miscompile).  elaborateModules recovers the shadow post-mangle by
-- forward-constructing `mangledName mid method` for every (module, iface-method)
-- pair and checking it against the module's actual funDef names; each hit is a
-- `(mangledSymbol ↦ bareMethod)` entry recorded here.  The mark pass then (a) marks
-- the mangled occurrence `EMethodAt` with the BARE dispatch name (so `implFor` finds
-- the impl for a receiver that HAS one) and (b) carries the mangled symbol in the
-- route's `RLocal <symbol>` fallback for a receiver that does NOT.  EMPTY on the
-- un-mangled run/check path (forward-construction never matches a bare funDef), so
-- every non-emit path is byte-identical.  Set once at the top of elaborateModules;
-- deliberately NOT cleared by resetState (checkModuleFullImpl's per-module resetState
-- must not wipe it mid-graph) — the forward-construction membership check makes a
-- stale value inert (no funDef matches → no entry).
mangledShadowMapRef : Ref (List (String, String))
mangledShadowMapRef = Ref []

-- the MANGLED standalone symbol a route's RLocal fallback should call, or "" for
-- the bare-name (un-mangled) case.  Read off the marked EMethodAt route at record
-- time (before resolveArgStamps may overwrite the ref with an RKey) so the mangled
-- symbol survives into the pendingRLocalSites entry.
routeLocalSym : Route -> String
routeLocalSym (RLocal s _) = s
routeLocalSym _ = ""

-- Bug C: importer-shadow method names → their IMPORTED STANDALONE scheme (e.g.
-- `toList` → `Map k v -> List (k, v)`).  env1 rebinds these names to the polymorphic
-- INTERFACE-METHOD scheme (so a genuine method call types polymorphically), which
-- loses the standalone's concrete result element type — typing `toList m : List a`
-- (a free) instead of `List (String, Int)`, so a downstream `debug` dispatches on the
-- ungrounded element and renders garbage.  inferAppExpr's standalone-shadow arm reads
-- THIS to recover the standalone result type when the receiver has no impl, mirroring
-- lib/typecheck.ml:2312 (`instantiate_raw (lookup_var env mname)`, where the oracle's
-- env.standalone_values keeps the var bound to the standalone).  Populated per module
-- in checkModuleFullImpl from seedVars (the import seed, pre-rebind).
shadowStandaloneSchemesRef : Ref (List (String, Scheme))
shadowStandaloneSchemesRef = Ref []

-- Bug C: the impl key table for the CURRENT module's full impl universe, stashed at
-- module start so inferAppExpr's standalone-shadow arm can ask, DURING inference,
-- whether a concrete receiver head has an impl of the method's interface (the static
-- analogue of resolveRLocalSite's post-inference check, but needed eagerly so the
-- call's RESULT type unifies against the standalone — not the method scheme — before
-- a downstream `debug` dispatches on it).  Set in checkModuleFullImpl from implDecls.
shadowKeyTableRef : Ref KeyBuckets
shadowKeyTableRef = Ref omEmpty

-- P0-19 (constrained-receiver arm): the `=>`-constraint variables of the top-level
-- group CURRENTLY being inferred, as (interface name, the constraint's instantiated
-- mono).  Set by processSCC between preunifySigsEx (which instantiates the sigs) and
-- inferMembers (which infers the bodies), cleared right after — funConstraintsRef /
-- activeDictVars are only registered AFTER inference (they need the surviving
-- union-find root), so the bodies themselves cannot ask those which of their tyvars
-- are dict-bound.  Read by definerReceiverIsDictVar: a definer-shadow occurrence whose
-- receiver is one of these vars DISPATCHES through the dict and is NOT a standalone.
groupConstraintMonosRef : Ref (List (String, Mono))
groupConstraintMonosRef = Ref []

-- C5: method name → dispatch-arg index, built graph-wide from ALL interface decls
-- (so a PRELUDE method like Foldable's `toList` — absent from a user module's own
-- decls — still resolves its index during that module's check).  Set per module by
-- checkModuleFullImpl from [implDecls].  Independent of methodIfaceParamsRef (which
-- the module path populates only for the module's OWN interfaces).
methodDispatchIdxRef : Ref (List (String, Int))
methodDispatchIdxRef = Ref []

-- FLAT-PATH SHADOW FIX (facet 1): interface-method names that a USER top-level fn
-- shadows on the single-file flat check path.  processSCC drops a scheme with one
-- of these names from the env it THREADS FORWARD, so a later prelude binding
-- (`neq x y = not (eq x y)`) resolves the name to the METHOD scheme (kept in the
-- base env / globalS) rather than the user's shadowing fn.  Set by checkProgramSeeded
-- right before processTopGroups; empty everywhere else (multi-module path checks
-- core in isolation and never needs this).  See checkProgramSeeded for rationale.
methodShadowNamesRef : Ref (List String)
methodShadowNamesRef = Ref []

-- FLAT-PATH SHADOW SCOPING (SHADOW-SEMANTICS S1: shadow-hood is per-module, per-name).
-- The flat path hands checkProgramSeededSplit ONE program, `core ++ user`, and then
-- applied the definer-shadow name set to EVERY occurrence in it — INCLUDING the
-- prelude's own bodies.  So a user file that merely DEFINES (and never uses)
-- `map : Int -> Int` made core's `map2`/`map3`/`replaceWith`/`discard` type their own
-- `map` calls against the USER's `map`, yielding 14 errors — all inside core, all
-- reported at a fabricated `1:0` on the user's signature.  (Once SHADOW-SEMANTICS S2 is
-- inverted so a standalone WINS over a same-named method, the same leak stops merely
-- mistyping and starts ROUTING the prelude's calls into user code — a silent miscompile
-- of the prelude.)  The multi-module path never had this: checkModuleFullImpl seeds the
-- shadow set PER MODULE and checks core in ISOLATION.
--
-- These three refs reproduce that isolation on the flat path WITHOUT splitting the
-- inference: definerShadowNamesRef is toggled OFF while a CORE-owned letrec group (and
-- core's impl/default/prop/test bodies) is inferred and back ON for the user's, so every
-- consumer of that ref (definerShadowVarHead / definerShadowArgHead /
-- maybeStandaloneValueMono / recordImplObligation / resolveRLocalSite) becomes
-- per-module for free.  Empty/False on every other path — resetState clears them and
-- ONLY a checkProgramSeededSplit with a NON-EMPTY prelude sets them — so the
-- multi-module path and the prelude-free probe paths are byte-identical.
flatShadowScopingRef : Ref Bool
flatShadowScopingRef = Ref False

-- the prelude's own top-level fn names (a set: this is consulted once per letrec group).
flatCoreFnNamesRef : Ref (OrdMap Unit)
flatCoreFnNamesRef = Ref omEmpty

-- the definer-shadow names of the USER module only — what definerShadowNamesRef holds
-- whenever a user-owned group/body is being inferred.
flatUserShadowNamesRef : Ref (List String)
flatUserShadowNamesRef = Ref []

-- C5: arg-position method occurrences whose name is a standalone-shadow, recorded
-- UNGATED (the ordinary arg-stamp machinery is emit-path-only, but eval also
-- arg-tag-dispatches and panics on a receiver with no impl — box's `toList b`).
-- Each entry is (name, route ref, the discriminating-argument mono CELL);
-- resolveRLocalSites reads the cell post-inference and stamps RLocal when the
-- receiver grounds to a head with no impl.
-- Mirrors lib/typecheck.ml's EApp-receiver RLocal stamp.  Reset by resetState.
-- (name, routeRef, receiverMono, mangledSym, forceLocal) — mangledSym (P0-18) is the
-- mangled standalone symbol read off the marked route at record time; resolveRLocalSite
-- stamps `RLocal mangledSym` for a no-impl receiver.  "" on the un-mangled path.
-- P0-20: forceLocal — the definer-shadow APP path (inferDefinerShadowApp) has ALREADY
-- committed the site's TYPE to the standalone's scheme, so its route is not open to
-- re-derivation: post-inference the receiver can ground to a head that HAS an impl (Num
-- defaulting on an unsignatured standalone) and resolveRLocalSite would dispatch a site
-- typed as the standalone — check says one thing, the binary does another.  True pins
-- the route to RLocal.  recordRLocalSite (value position / importer shadows) pushes
-- False and keeps the old per-receiver re-derivation.
-- S-1: `dictMonos`/`dictIfaces` are the SHADOWING STANDALONE's own `=>`-constraint
-- slots (slot-parallel, expanded-supers, from shadowStandaloneDicts), carried here so
-- the stamp can turn them into dict Routes.  They are read INSIDE resolveRLocalSites
-- via routesOfMonosTop — a PURE function of the union-find-solved monos — rather than
-- pushed through pendingDictApps, because resolveRLocalSites runs BEFORE
-- resolveDictApps in elabModuleStamp: routing them through pendingDictApps would read
-- `[]` and reproduce the S-1 bug with more code.  This way the fix is ordering-immune
-- and the route has a single writer.  Empty for an unconstrained standalone.
-- (A record, not a 6/7-tuple: Medaka tuples top out at arity 5.)
public export data RLocalSite =
  | RLocalSite String (Ref Route) Mono String Bool (List Mono) (List String)

pendingRLocalSites : Ref (List RLocalSite)
pendingRLocalSites = Ref []

-- P0-18: while typing a definer-shadow method occurrence that heads a single-arg
-- application (`size (Box 3)`), suppress recordRLocalSite's default push — the
-- standalone scheme's declared domain (`Int`) is NOT the actual receiver type.
-- inferDefinerShadowApp instead records the ACTUAL argument mono so per-receiver
-- routing sees `Box` (which has a `Sizeable` impl → method) vs `Int` (no impl →
-- standalone).  Set only around that occurrence's `infer env f`; false everywhere else.
suppressRLocalRecord : Ref Bool
suppressRLocalRecord = Ref False

-- P0-18: same idea as suppressRLocalRecord for the EMIT path — while typing a
-- definer-shadow method occurrence heading an application, suppress recordArgStamp's
-- default push (standalone declared domain) so inferDefinerShadowApp can record the
-- ACTUAL argument mono into pendingArgStamps instead.
suppressArgStamp : Ref Bool
suppressArgStamp = Ref False

-- one entry per occurrence of a registered interface method: (iface, typarams,
-- declared method Ty, the occurrence's instantiated mono).  Resolved post-inference.
-- B.10.2c: the 5th element is the `currentLoc` span snapshotted at the RECORD
-- site (during inference, when the ELoc context is live), so the post-HM
-- obligation check (checkImplObligations) can pair a `No impl of …` reject with
-- the offending expression's range — mirror of lib/typecheck.ml capturing
-- `!current_loc` into method_usages / constraint_obligations at record time
-- rather than reading the stale global at the post-HM raise.
pendingImplObligations : Ref (List (String, List String, Ty, Mono, Option Loc))
pendingImplObligations = Ref []

-- PERF: the obligation list's length, in O(1).  That list grows with every
-- constrained occurrence in the program and is NEVER trimmed, yet each top-level
-- group brackets its inference with a length-before / length-after pair to recover
-- the obligations IT added (they are consed on the front, so `takeFirst` recovers
-- them).  Measuring that length by walking the list was O(N) over an O(N) list once
-- per group — O(N²), and the single hottest symbol in the typecheck stage on a large
-- file.  This counter mirrors the list's length exactly; the ONLY mutators of the
-- list are `resetState` (clears both), `pushPendingObl` (extends both), and
-- inferDefaultMethodBody's error rollback (restores both from a snapshot).
pendingImplObligationsN : Ref Int
pendingImplObligationsN = Ref 0

-- The one and only way to add an obligation: keeps the length counter in step.
pushPendingObl : (String, List String, Ty, Mono, Option Loc) -> Unit
pushPendingObl obl =
  let _ = setRef pendingImplObligations (obl::pendingImplObligations.value)
  setRef pendingImplObligationsN (pendingImplObligationsN.value + 1)

-- PLAN.md #11: one entry per source integer literal (ENumLit):
-- (litVar, fref, n, dref).  [litVar] is the literal's fresh Num-obligated type var;
-- [fref] is the node's own Option Float cell; [n] the int value; [dref] is the
-- node's `fromInt`-route cell (filled by resolveSites — the literal is modelled as a
-- `fromInt n` method occurrence).  After defaulting + grounding, the post-HM pass
-- setNumlitFloats decides the runtime rep (mirror of lib/typecheck.ml's
-- set_numlit_floats): litVar ground Float ⇒ fref Some, dref cleared ⇒ ELit (LFloat f);
-- litVar ground Int ⇒ both cleared ⇒ ELit (LInt n); litVar still polymorphic `Num a`
-- (the soundness case — `1` in `inc x = x + 1`) ⇒ dref KEPT (RDictFwd onto the
-- enclosing Num dict) ⇒ dictPass emits `EApp (EMethodAt "fromInt" …) (ELit (LInt n))`.
numlitRefs : Ref (List (Mono, Ref (Option Float), Int, Ref Route))
numlitRefs = Ref []

-- Chunk A (error framing): the union-find root ids of every type var that took
-- part in a unification failure (`typeMismatch`).  Consulted ONLY by
-- `checkUndeterminedObligation` to SUPPRESS a secondary `ambiguous instance`
-- cascade on a var the primary mismatch already explained — never read on the
-- inference path, so a well-typed program (no mismatch) never poisons anything
-- and behaves identically.
poisonedVars : Ref (List Int)
poisonedVars = Ref []

-- Chunk D (Num mis-framing): (litVar, loc) for every numeric literal whose var
-- carried a Num obligation — captured at inferNumLit/inferNumLitBare record time
-- while the var is still unbound.  Lets checkOneImplObligation reframe a purely
-- literal Num obligation forced to a concrete non-Num type (`Type mismatch: Int vs
-- T`) while an OPERATOR-sourced one (`x + 1`) keeps `No impl of Num for T`.  Storing
-- the VAR (not just the loc) lets the operator-taint pass below share a root through
-- `normalize`, so `1 + x` and `x + 1` are both recognised as operator-sourced
-- regardless of unify direction.  Error-path only; reset per run.
numlitVarLocs : Ref (List (Mono, Loc))
numlitVarLocs = Ref []

-- PERF: the literals that are NOT YET operator-tainted.  `markNumlitOpTaint` scans
-- THIS instead of the full `numlitVarLocs` (which is never trimmed).  Sound because
-- tainting is idempotent: it appends a loc to `numlitOpLocs`, whose only reader
-- (`numlitReframeLoc`) does a membership test — so re-tainting an already-tainted
-- literal cannot change any outcome, and a tainted literal may leave the worklist.
-- Scanning EVERY literal ever recorded on EVERY arithmetic operand was O(N²), and
-- after the allocation fix (see `rootIdOf`) it was still the typecheck stage's
-- dominant remaining cost on a large file.
--
-- `numlitVarLocs` itself keeps every literal — `numlitReframeLoc` and
-- `tagLitLocsWithRoot` both still need the complete list.
numlitUntainted : Ref (List (Mono, Loc))
numlitUntainted = Ref []

-- Chunk D: locs of literals whose var was ALSO an operand of an arithmetic op
-- (recordIfaceObligation).  Such a literal keeps the Num message — the operator is the
-- real culprit — so the reframe skips it (it reframes `litLocs \ opLocs`).
numlitOpLocs : Ref (List Loc)
numlitOpLocs = Ref []

-- Chunk D: (literalLoc, contextKind) recorded when inferIf / inferListLit / consOp
-- is about to force a still-unbound literal var against a concrete sibling type —
-- lets the reframe pick site-specific wording (if-branches / list elements / cons
-- head-vs-element) over the bare `Type mismatch: Int vs T`.
numlitCtxTags : Ref (List (Loc, String))
numlitCtxTags = Ref []

-- LSP hover: every local binding (let-bound name, lambda param, function-clause
-- param, match-arm binder) flows through inferPat's PVar/PAs arms.  Capture
-- (name, mono var) here so hover can render a *local* variable's inferred type:
-- `checkProgramSchemes` only returns top-level + global schemes, so without this
-- a hover over e.g. a `let input = …` name finds nothing and returns null.  The
-- mono var is union-find-solved by the time inference ends; checkProgramSeeded
-- then generalizes each into `localSchemesOut`, which the LSP reads as a hover
-- fallback.  This side-channel does NOT enter the returned env, so completion and
-- inlay-hint output (which consume the env directly) are unaffected.
localBindRefs : Ref (List (String, Mono))
localBindRefs = Ref []

localSchemesOut : Ref (List (String, Scheme))
localSchemesOut = Ref []

-- Hover side-channel for the SEED (runtime.mdk externs: putStrLn, readLine, …).
-- checkProgramSeeded keeps the seed in scope for inference but excludes it from
-- the returned env (see its comment), so externs aren't otherwise hoverable.
seedSchemesOut : Ref (List (String, Scheme))
seedSchemesOut = Ref []

-- Getters for the LSP (cross-module).  The raw Refs are nullary value globals
-- (@mdk_g_), which the import-aware mangling map doesn't carry, so expose them
-- through functions — the form every other tools→typecheck import already uses.
export currentLocalSchemes : Unit -> List (String, Scheme)
currentLocalSchemes _ = localSchemesOut.value

export currentSeedSchemes : Unit -> List (String, Scheme)
currentSeedSchemes _ = seedSchemesOut.value

recordLocalBind : String -> Mono -> Unit
recordLocalBind name v = setRef localBindRefs ((name, v)::localBindRefs.value)

-- dict-passing state (the typed pipeline's `=>`-constraint layer):
--   activeDictVars   : constraint tyvar id → the dict parameter name a method
--                      occurrence at that variable's type reads (RDict).
--   funConstraintsRef: constrained fn name → its constraints' quantified tyvar
--                      ids (one per `=>` constraint, in slot order) — a call site
--                      maps each to its fresh instantiation var to pick a route.
--   pendingDictApps  : a constrained-fn occurrence's routes ref + the instantiated
--                      constraint monos, resolved to RKey/RDict after inference.
activeDictVars : Ref (List (Int, String))
activeDictVars = Ref []

funConstraintsRef : Ref (List (String, List Int))
funConstraintsRef = Ref []

-- WS-1b: the program decls (interfaces) the supers-expansion reads.  Set by each
-- driver (elaborateDict / the module path) BEFORE inference; read by inferDictAtFound
-- to expand a call site's constraint slots with their transitive supers.  Read-only
-- during inference, so it needs no reset-lifecycle care.
superDeclsRef : Ref (List Decl)
superDeclsRef = Ref []

-- WS-1b: the USER-module interface names (NOT core/prelude).  Super-expansion is
-- gated to user interfaces only: a prelude super chain (Ord requires Eq) is already
-- serviced by arg-tag dispatch and is NOT dict-passed on the eval path, so adding an
-- Eq slot to `clamp : Ord a =>` would desync its def arity from its arg-tag call sites
-- (the prior-attempt clamp regression).  User interfaces (Sub requires Sup) ARE
-- dict-passed and need the super slot.  Set by elaborateModules.
userIfaceNamesRef : Ref (List String)
userIfaceNamesRef = Ref []

-- #11 soundness (native obligation hole): the INTERFACE names of a constrained
-- fn's `=>` constraints, slot-parallel to funConstraintsRef's ids.  funConstraintsRef
-- keeps only the tyvar ids (enough to pick a dict route); but to record a real impl
-- obligation when a constrained fn is INSTANTIATED at a concrete type (`g = f "hello"`
-- where `f : Num a => a -> a`), the call site needs the iface ("Num") so it can check
-- `Num String` against the impl table.  Mirrors lib/typecheck.ml's fun_constraints
-- carrying the iface name into check_constraint_obligations.  Populated at the SAME
-- three sites as funConstraintsRef (registerMember / registerInferredFor /
-- seedDictAritiesFromSigs), with the SAME cross-module accumulate+reseed lifecycle.
funConstraintIfacesRef : Ref (List (String, List String))
funConstraintIfacesRef = Ref []

-- a constrained-fn CALL site's instantiated constraint obligations: (iface, the
-- call's instantiated constraint mono).  Resolved after inference (when the mono is
-- ground) by checkCallObligations — a CONCRETE-head mono with no matching impl is an
-- ERROR; a still-polymorphic head is DEFERRED (left to a further-out caller).  This
-- is the compiler analog of the oracle's constraint_obligations + check_constraint_
-- obligations: pendingDictApps routes the dict, this list checks the impl exists.
pendingCallObligations : Ref (List (String, Mono, Option Loc))
pendingCallObligations = Ref []

-- PERF: `pendingCallObligations`' length in O(1) — see `pendingImplObligationsN`.
-- processSCC brackets each top-level group with a length-before / length-after pair
-- (three reads per group), and this list is never trimmed, so walking it to measure
-- its length was O(N) per group — O(N²) over a large file.  Mutated ONLY by
-- `resetState` and `pushCallObl`.
pendingCallObligationsN : Ref Int
pendingCallObligationsN = Ref 0

pushCallObl : (String, Mono, Option Loc) -> Unit
pushCallObl obl =
  let _ = setRef pendingCallObligations (obl::pendingCallObligations.value)
  setRef pendingCallObligationsN (pendingCallObligationsN.value + 1)

-- #11 soundness (native obligation hole, ALWAYS-ON, independent of the dict-
-- elaboration machinery): per top-level binding, the deferred impl obligations it
-- generalizes over — (iface, the quantified-var id the obligation discriminates on).
-- Populated UNCONDITIONALLY at generalization in processSCC/processTopGroups (unlike
-- funConstraintsRef, which the check path leaves empty because its inferred-constraint
-- registration is gated on dictEligibleSetRef).  At a USE site (inferVar) the binding's
-- entry is freshened through the call's instantiation subst and checked against the
-- impl table — the compiler analog of lib/typecheck.ml's inferred_constraints carried
-- on a scheme and re-checked at every instantiation.
schemeObligationsRef : Ref (List (String, List (String, Int)))
schemeObligationsRef = Ref []

-- E6 (module emit path only): funConstraintsRef is wiped by resetState at the start
-- of EACH module's typecheck, but a cross-module `=>`-constrained CALL site (entry
-- calling an imported `clampU`) must still find the callee's generalized constraint
-- ids so inferDictAt records a real pendingDictApp (→ the call gets its dict ARG).
-- This ref ACCUMULATES every module's registered fn-constraints across the graph and
-- is NOT cleared by resetState; checkModuleFullImpl re-seeds funConstraintsRef from
-- it after the per-module reset (gated emitArgStampPasses — empty + unused when OFF, so
-- the golden module drivers are byte-identical).  The DEFINING module's entry (real
-- ids, registered first) wins the lookupAssocSL2 first-match.
crossModuleFunConstraintsRef : Ref (List (String, List Int))
crossModuleFunConstraintsRef = Ref []

-- WS-2/D2: module-attributed mirror of crossModuleFunConstraintsRef.  Keyed by
-- (owning module id, fn name) so the FINAL dict-pass (scopeArities) can keep only
-- the inferred-arity entry whose DEFINING module is in the dict-passed module's
-- scope.  Without this, two distinct top-level fns sharing a bare name but with
-- different `=>`-constraint arity (e.g. `wrap : Tag a => …` in module A vs
-- `wrap : (P a, Q a) => …` in module B) both land in the bare cross-module table;
-- scopeArities keeps both (both pass the bare scopeNames membership), and
-- dictArityOf's first-match returns the WRONG module's arity → a call site in A's
-- importer is sized to B's 2 dict params (over-application) → run-path crash while
-- the emit path's arg-stamp recovers (the §1 D2 repro).  Populated per-module in
-- checkModuleFullImpl (each fn DEFINED in this module's `prog` is attributed to mid);
-- consumed by scopeAritiesQual.  The bare crossModuleFunConstraintsRef is KEPT — the
-- per-module reseed at checkModuleFullImpl:7546 needs the bare form for the current
-- module's E6 cross-module call-site discovery.
crossModuleFunConstraintsQualRef : Ref (List ((String, String), List Int))
crossModuleFunConstraintsQualRef = Ref []

-- cross-module accumulator for funConstraintIfacesRef, mirroring
-- crossModuleFunConstraintsRef exactly (accumulate across the graph, NOT cleared by
-- resetState, re-seeded after the per-module reset).
crossModuleFunConstraintIfacesRef : Ref (List (String, List String))
crossModuleFunConstraintIfacesRef = Ref []

-- WS-2/D2 (ifaces analog of crossModuleFunConstraintsQualRef): module-attributed
-- mirror of crossModuleFunConstraintIfacesRef, keyed by (DEFINER module id, fn name),
-- slot-parallel to crossModuleFunConstraintsQualRef.  inferDictAtFound reads the
-- callee's dict ids AND their ifaces from the SAME qualified (definer,name) source so
-- the two stay aligned across a bare-name cross-module collision (a foreign same-named
-- fn of different `=>`-arity must not contribute its ifaces).  Populated/reset in
-- lockstep with the ids qual ref (checkModuleFullImpl / elaborateModules).
crossModuleFunConstraintIfacesQualRef : Ref (List ((String, String), List String))
crossModuleFunConstraintIfacesQualRef = Ref []

-- WS-2/D2: the current module's imported VALUE name → its source module id (the dotted
-- id its `import` form names == the loader mid == the qual tables' DEFINER key for a
-- DIRECT import).  Lets inferDictAtFound resolve a cross-module constrained callee's
-- dict arity by MODULE IDENTITY (the (definer,name)-keyed qual tables) instead of the
-- bare-name first-match over the jointly-seeded funConstraintsRef — which picks the
-- MOST-RECENTLY-PREPENDED same-named entry, i.e. a FOREIGN module's `wrap` when the
-- importer merely imports a different `wrap`.  That bare-name collision is an
-- observable run-crash today (`applied non-function`) on `medaka run` of a direct
-- cross-module import of two same-named, different-`=>`-arity constrained fns, while
-- `check` accepts and `build` is saved by universal mangling.  Set per-module in
-- checkModuleFullImpl from `prog`'s DUse decls; only EXPLICIT imports
-- (UseName/UseGroup/UseAlias) are mapped — a wildcard `import mod.*` can't enumerate
-- names here, and a re-exported fn's import source ≠ its definer, so both fall back to
-- the bare table (correct, byte-identical; the qual path is the fix for the common
-- direct-import case).  Reset by resetState (per module).
currentImportDefinersRef : Ref (List (String, String))
currentImportDefinersRef = Ref []

-- WS-1c: the third field is the slot-parallel interface-name list (one per mono),
-- so resolveDictApps can resolve an UNDETERMINED top-level constraint (a constraint
-- tyvar pinned by neither arg nor result) by counting that interface's impls: sole
-- impl → a concrete RKey to it; ≥2 → an AmbiguousImpl error.  Recorded from the same
-- `expanded` (iface, id) pairing inferDictAtFound already builds for recordCallObligations.
pendingDictApps : Ref (List (Ref (List Route), List Mono, List String))
pendingDictApps = Ref []

-- PERF: `pendingDictApps`' length in O(1) — same O(N²)-per-group length scan as
-- `pendingCallObligationsN`.  Mutated ONLY by `resetState` and `pushDictApp`.
pendingDictAppsN : Ref Int
pendingDictAppsN = Ref 0

pushDictApp : (Ref (List Route), List Mono, List String) -> Unit
pushDictApp app =
  let _ = setRef pendingDictApps (app::pendingDictApps.value)
  setRef pendingDictAppsN (pendingDictAppsN.value + 1)

-- method-level-constraint dict-passing (the reference's res_method_dicts, Phase
-- 69.x-e).  An interface method whose signature carries a `=>` constraint over a
-- tyvar that is NOT the interface param (canonically `foldMap : Monoid m => …`,
-- where `Monoid m` constrains the result monoid, not the container `t`):
--   methodConstraintsRef : method name → one tyvar id per such constraint, in slot
--                          order.  Captured while BUILDING the env method schemes
--                          (ifaceMethodSchemes) so the ids are the SAME quantified
--                          ids a call-site instantiation maps through its subst.
--   pendingMethodDicts   : a method occurrence's method-dicts ref to fill + the
--                          instantiated constraint monos (mirrors pendingDictApps),
--                          routed by resolveMethodDicts after inference.
methodConstraintsRef : Ref (List (String, List Int))
methodConstraintsRef = Ref []

-- Per method name, the POSITIONS (indices into the scheme's ordered quantified id
-- list) of its constraint slots.  Positions are allocation-INDEPENDENT: the env
-- scheme and the registry scheme are separate `sigToSchemeTvs mty` instantiations
-- with DIFFERENT fresh ids, but the SAME var order, so a slot's index is stable.
-- recordMethodDicts indexes THIS occurrence's ordered subst at these positions to
-- get the exact live constraint monos — sidestepping the cross-sweep/parametric-
-- sibling id-overlap that defeats countInSubst's overlap heuristic (a stale id can
-- land in the live range mapping to the container `t` instead of the applicative
-- `m`; the position never confuses the two).  One entry per method (dedup);
-- cleared in resetState.  Absent ⇒ fall back to alignedMethodConstraintIds.
methodConstraintPositionsRef : Ref (List (String, List Int))
methodConstraintPositionsRef = Ref []

-- Cross-module analog of methodConstraintsRef, mirroring crossModuleFunConstraintsRef
-- exactly.  resetState wipes methodConstraintsRef at each module start, then
-- checkModuleFullImpl re-registers via `ifaceMethodSchemes prog` over the CURRENT
-- module's decls only — so a method declared in an imported module (canonically
-- core's `foldMap : Monoid m =>` on `Foldable`) is absent during a later USER
-- module's pass, and its dict never gets recorded.  This ref ACCUMULATES every
-- module's registered method-constraints across the graph and is NOT cleared by
-- resetState; checkModuleFullImpl re-seeds methodConstraintsRef from it after the
-- per-module reset+registration (MERGE, the per-module entry wins first-match).
crossModuleMethodConstraintsRef : Ref (List (String, List Int))
crossModuleMethodConstraintsRef = Ref []

-- WS-2/D2 (method-level analog of crossModuleFunConstraintsQualRef): module-attributed
-- mirror of crossModuleMethodConstraintsRef, keyed by (owning interface's module id,
-- method name).  Without it, two modules declaring distinct interfaces that share a
-- bare METHOD name but with different method-level `=>`-constraint arity (e.g.
-- `shape : Num e => …` in module A vs `shape : (Num e, Num f) => …` in module B) both
-- land in the bare methodConstraintsRef; methodDictArityOf's first-match returns the
-- WRONG module's arity → an impl/default method in one module is sized to the other's
-- dict-param count → a dict is mis-bound into a value parameter (`unknown op '+'` /
-- garbage / run≠build — the method-level twin of the §1 D2 fn repro, which `check`
-- accepts).  Populated per-module in checkModuleFullImpl (each method whose INTERFACE
-- is declared in this module's `prog`); consumed by scopeMethodArities in the final
-- per-scope dict-pass.  The bare crossModuleMethodConstraintsRef is KEPT — the
-- per-module reseed at checkModuleFullImpl needs the bare form for the current module's
-- cross-module call-site discovery (recordMethodDicts), exactly like the fn side.
crossModuleMethodConstraintsQualRef : Ref (List ((String, String), List Int))
crossModuleMethodConstraintsQualRef = Ref []

-- ── the ONE lifecycle owner for the six cross-module accumulators (#143/#144) ──
-- These six deliberately SURVIVE the per-module `resetState` (so dict arities/ifaces
-- cross module boundaries within one graph — see the declaration comments above), but
-- they must NOT survive a whole multi-module RUN: a long-lived process (LSP, playground,
-- snapshot runner) drives the analyze/elaborate path repeatedly, and without a per-run
-- reset run K+1 seeds `funConstraintsRef`/`funConstraintIfacesRef` from run K's residue
-- (checkModuleFullImpl reads them for the FIRST module before any fresh snapshot lands),
-- while the `*Qual` mirrors are prepend-appended and never truncated → unbounded growth.
-- Give them exactly ONE reset owner, called at the top of EVERY multi-module entry
-- (`checkModules`, `checkModulesDiags`, `checkModulesEntryFull`, `elaborateModules`), so
-- the next entry added cannot silently miss one — and so all six are cleared symmetrically
-- (the pre-#144 elaborateModules clear block omitted `crossModuleFunConstraintIfacesRef`).
-- Scoped to exactly these six; do NOT fold into `resetState` (they must survive THAT).
resetCrossModuleState : Unit -> Unit
resetCrossModuleState _ =
  let _ = setRef crossModuleFunConstraintsRef []
  let _ = setRef crossModuleFunConstraintsQualRef []
  let _ = setRef crossModuleFunConstraintIfacesRef []
  let _ = setRef crossModuleFunConstraintIfacesQualRef []
  let _ = setRef crossModuleMethodConstraintsRef []
  setRef crossModuleMethodConstraintsQualRef []

pendingMethodDicts : Ref (List (Ref (List Route), List Mono))
pendingMethodDicts = Ref []

-- self/mutually-recursive constrained-fn call sites.  At such a site the callee's
-- own constraints are not yet registered (its letrec group is still inferring),
-- so funConstraintsRef can't map its routes inline.  Defer them: RecDictApp holds
-- (routes ref to fill, callee name, the ENCLOSING fn's name, the live occurrence
-- mono).  realizeRecDictApps fills the routes after inference, forwarding the
-- enclosing fn's OWN dict parameter (RDict) for each constraint — the dict already
-- in scope in its body — rather than rebuilding one (which it cannot, the type is
-- still the constraint variable).  Mirrors the reference's recursive_promoted_usages
-- / realize_recursive_dict_apps (Phase 115/136).
public export data RecDictApp = RecDictApp (Ref (List Route)) String String Mono

pendingRecDictApps : Ref (List RecDictApp)
pendingRecDictApps = Ref []

-- the top-level fn whose body is currently being inferred ("" = none); captured
-- into a deferred RecDictApp so its recursive calls forward the right dict param.
currentFn : Ref String
currentFn = Ref ""

-- G4: True while inferring an impl method BODY (set around inferImplMethod).  A
-- comparison/equality OPERATOR site records this flag so resolveBinopSite consults
-- `activeDictVarOf` (→ route the impl's threaded element dict, RDict) ONLY for sites
-- genuinely inside an impl body.  A TOP-LEVEL `<=`/`==` must NOT — its operand could
-- normalize to an unsolved tyvar whose id collides with a stale activeDictVars entry
-- left by a previously-inferred impl, spuriously routing it RDict (which flipped the
-- repl's String-keyed `:browse` sort).  activeDictVars is global + uncleared, so the
-- flag is the scope gate the id-lookup alone cannot provide.
currentImplBody : Ref Bool
currentImplBody = Ref False

-- INFERRED (unsignatured) `=>`-constraint promotion (the reference's two-pass
-- Elaborate / Phase 83/84/115).  An unsignatured fn whose body uses a
-- return-position method — or calls a constrained fn — at one of its OWN
-- generalized tyvars carries a constraint only AFTER inference.  We discover this
-- by recording, per occurrence, the enclosing fn (currentFn) and the live mono,
-- then (post-generalization) intersecting with the fn's quantified ids.
--   methodSiteFns : (enclosing fn, a return-position method site's result mono)
--   dictAppFns    : (enclosing fn, a constrained-fn call's instantiated constraint
--                   monos) — propagates a constraint to an unsignatured CALLER
--   promotedRef   : fns discovered THIS pass to carry an inferred constraint; read
--                   by elaborateDict to grow the dict-passed set on the next pass
--   dictEligibleRef: the USER fn names eligible for promotion (the prelude's
--                   constrained fns stay arg-tag/RKey — out of scope).  Set by
--                   elaborateDict; NOT cleared by resetState (constant per run).
--
-- PERF: both are INDEXED BY ENCLOSING FN rather than kept as flat (fn, mono) assoc
-- lists.  Their sole reader, `inferredConstraintIds`, selects the entries of ONE fn,
-- and it runs once per member of every top-level group — so scanning a flat list that
-- accumulates a site for every constrained occurrence in the whole file was O(N²).
-- Each key's list is built by consing, exactly like the flat lists were, so a fn's
-- sites keep the same most-recent-first order the old scan produced.
methodSiteFns : Ref (OrdMap (List Mono))
methodSiteFns = Ref omEmpty

dictAppFns : Ref (OrdMap (List (List Mono)))
dictAppFns = Ref omEmpty

-- cons [x] onto the entry for [fn] (absent ⇒ a fresh single-element entry)
consSiteFn : String -> a -> OrdMap (List a) -> OrdMap (List a)
consSiteFn fn x idx = omInsert fn (x :: sitesFor fn idx) idx

-- the sites recorded for [fn], most-recent-first
sitesFor : String -> OrdMap (List a) -> List a
sitesFor fn idx = fromOption [] (omLookup fn idx)

promotedRef : Ref (List String)
promotedRef = Ref []

dictEligibleRef : Ref (List String)
dictEligibleRef = Ref []

-- O(log n) membership mirror of dictEligibleRef (set in lockstep at both set
-- sites).  maybeInferConstraint tests it per SCC member per discovery pass — an
-- O(members × eligible) scan over the whole program when it was a list.
dictEligibleSetRef : Ref (OrdMap Unit)
dictEligibleSetRef = Ref omEmpty

-- Whether checkProgramSeeded ALSO infers each parametric impl's return-position
-- method bodies (instance-`requires` dict-passing, Phase 83/84 single-level).  ON
-- only for the elaborate / dict path (elaborateDict sets it); OFF for the
-- `=== TYPES ===` golden path (checkProgram) and the multi-module path
-- (elaborateModules) so their scheme output stays byte-identical.  Deliberately
-- NOT reset by resetState — the entrypoint that owns the path sets it.
implInferEnabled : Ref Bool
implInferEnabled = Ref False

-- ── D0.5 arg-position dispatch MEASUREMENT (probe-only) ─────────────────────
-- Classify every ARGUMENT-position interface-method occurrence (the bare-EVar
-- arg-tag population D0 counted, upper bound 1065) by the inferred type of its
-- DISCRIMINATING argument: concrete-primitive / concrete-ADT / type-variable.
-- Mirrors recordSite/resolveSites (which stamp RETURN-position sites) but for
-- arg-position sites it MEASURES, never stamps.  An arg-position method is exactly
-- one that reached inferVar (return-position + method-constrained methods were
-- already rewritten to EMethodAt/EDictAt by prePassDict, so they never arrive there).

-- method name → 0-based index of its first argument mentioning the interface
-- typaram (its dispatch position).  Set by the probe before elaboration; absence
-- of a name means "not an arg-position interface method" → not measured.
argDispatchIdxRef : Ref (List (String, Int))
argDispatchIdxRef = Ref []

-- ── D3a arg-position dispatch STAMPING (Native backend, emit + eval paths) ──────
-- The action analog of the D0.5 measurement: instead of classifying each
-- ARGUMENT-position interface-method occurrence, STAMP a static `RKey <head>` for
-- every one whose discriminating-argument type resolves to a concrete head (the
-- 903 concrete sites = 25 primitive + 878 ADT).  Type-variable occurrences (the
-- 110 D3b sites) stay RNone → the emitter falls back to runtime arg-tag dispatch.
-- OFF by default; the emit AND eval drivers both turn it ON; the `=== TYPES ===`
-- / Core-IR golden + ceval-oracle paths leave it off so those paths stay
-- byte-identical: with it OFF, prePassDictArg leaves arg-position uses as bare
-- EVar (no extra EMethodAt nodes) and inferMethodAt never reaches the stamp arm.
emitArgStampPasses : Ref Bool
emitArgStampPasses = Ref False

-- enable arg-position stamping for the current elaboration (the emit path flips
-- this before elaborateDict; the golden/oracle drivers leave it off).
export enableEmitArgStampPasses : Unit -> Unit
enableEmitArgStampPasses _ = setRef emitArgStampPasses True

-- SET the flag either way.  Every OTHER driver is single-mode — a probe binary is
-- an emit driver OR an eval/golden driver, never both, so it only ever needs to
-- flip this ON once and `resetState` deliberately leaves it alone ("set by the
-- driver, constant").  The snapshot runner (compiler/tools/snapshot.mdk) breaks
-- that assumption: it renders the OFF-mode stages (TYPES / CORE_IR / EVAL) *and*
-- the ON-mode stages (LLVM / WASM) for many fixtures in ONE process, so it must
-- restore the OFF default between fixtures — otherwise fixture #1's LLVM emit
-- would silently leave every later fixture's TYPES/CORE_IR/EVAL on the emit path.
-- (Measured: those three stages render byte-identically either way on 204/204
-- fixtures today, so this is defence against a future divergence, not a live bug.)
export setEmitArgStampPasses : Bool -> Unit
setEmitArgStampPasses b = setRef emitArgStampPasses b

-- #55 EVAL residual: active on the multi-module EVAL path (elaborateModules with
-- emitArgStampPasses OFF) when there is a RETURN-position constrained fn to dict-pass
-- (sum/product via `fromInt`, when/unless via `pure`).  Distinct from emitArgStampPasses:
-- it turns on the constrained-FUNCTION dict layer (mark call sites EDictAt + resolve
-- routes + prepend define params + thread crossModuleFunConstraintsRef) for the eval
-- interpreter — WITHOUT the emit path's arg-position stamping or its
-- discoverPromotedModules snapshot.  elaborateModules sets it per run; reset to False
-- at the top of elaborateModules so a prior emit run can't leak it.
-- ARGSTAMP-UNIFY Phase 4 (RETIRED): post-unification eval threads dicts fully, so
-- `evalDictLayerActive = not emitArgStampPasses` made every `emitArgStampPasses || …` guard
-- an always-True tautology.  Flag deleted; those guards are now unconditional.

-- the route refs awaiting an arg-position stamp + their discriminating-argument
-- mono (captured during inference, resolved by resolveArgStamps while the tyvar
-- cells are still bound).  Reset per pass by resetState, like pendingSites.
-- D3b-1: also carries the method name + the EMethodAt impl-dicts ref, so a
-- concrete site whose head names a parametric `requires` impl can thread the
-- element dict (resolveArgStamp → argImplDictRoutesFor), exactly as the
-- return-position pendingSites carry implRef for resolveSite.
pendingArgStamps : Ref (List (String, Ref Route, Ref (List Route), Mono, String))
pendingArgStamps = Ref []

-- the dispatch-index registry: each interface method → index of its first arg
-- mentioning the interface typaram.  Methods with NO such arg (return-position)
-- contribute nothing.  Computed structurally from interface decls.
export argDispatchIndices : List Decl -> List (String, Int)
argDispatchIndices prog = flatMap argDispatchOfDecl prog

argDispatchOfDecl : Decl -> List (String, Int)
argDispatchOfDecl (DAttrib _ d) = argDispatchOfDecl d
argDispatchOfDecl (DInterface { typarams, methods, ... }) =
  flatMap (argDispatchOfMethod typarams) methods
argDispatchOfDecl _ = []

argDispatchOfMethod : List String -> IfaceMethod -> List (String, Int)
argDispatchOfMethod typarams (IfaceMethod mname mty _) = match firstDispatchIdx (dispatchTyparams typarams) 0 (methodArgs mty)
  Some i => [(mname, i)]
  None => []

-- The DISCRIMINATING (receiver) typaram(s) of an interface — its FIRST typaram.
-- A multi-param interface (`FromEntries c e`) dispatches on its head/receiver
-- param `c`; the trailing `e` is a phantom element param that may appear in
-- argument types (`List e`) WITHOUT making the method arg-position dispatched.
-- Classifying by ALL typarams mis-routes `fromEntries : List e -> c` to its `List`
-- argument (an arg-tag site that has no `List` impl) instead of return-position
-- dispatch on `c`.  Single-param interfaces are unaffected (`take 1` is identity).
dispatchTyparams : List String -> List String
dispatchTyparams [] = []
dispatchTyparams (p::_) = [p]

firstDispatchIdx : List String -> Int -> List Ty -> Option Int
firstDispatchIdx _ _ [] = None
firstDispatchIdx typarams i (ty::rest)
  | argMentions typarams ty = Some i
  | otherwise = firstDispatchIdx typarams (i + 1) rest

nthArgMono : Int -> Mono -> Option Mono
nthArgMono 0 m = match normalize m
  TFun a _ _ => Some a
  _ => None
nthArgMono n m = match normalize m
  TFun _ _ b => nthArgMono (n - 1) b
  _ => None

-- D3a: queue an arg-position occurrence's route ref for stamping, keyed on the
-- inferred type of its discriminating argument (the dispatch-position arg mono).
-- The cell is read later (resolveArgStamps), once inference has solved it.  D3b-1:
-- also carry [name] + the impl-dicts ref so a concrete-head site can thread the
-- element dict for a parametric `requires` impl.
recordArgStamp : String -> Ref Route -> Ref (List Route) -> Int -> Mono -> Unit
recordArgStamp name tagRef implRef idx mono
  | suppressArgStamp.value = ()
  | otherwise = match nthArgMono idx mono
    Some am => setRef pendingArgStamps ((name, tagRef, implRef, am, currentFn.value)::pendingArgStamps.value)
    None => ()

-- Cause-A prerequisite: an ARG-position method occurrence's discriminating-arg
-- mono, keyed by the enclosing fn (currentFn), pushed into methodSiteFns — the
-- arg-position analogue of recordSite's return-position push.  inferredConstraintIds
-- reads methodSiteFns to discover the enclosing fn's INFERRED constraint, so this
-- lets `f s = display s` promote `f` to a dict-passed fn (it had no signature, so
-- the constraint is inferred, not declared).  Idx-th arg mono = the receiver whose
-- (constraint) tyvar must be discovered.
recordArgSiteFn : String -> Int -> Mono -> Unit
recordArgSiteFn _ idx mono = match nthArgMono idx mono
  Some am =>
    setRef methodSiteFns (consSiteFn currentFn.value am methodSiteFns.value)
  None => ()

-- D3a/D3b-1: stamp each queued arg-position route from its now-resolved
-- discriminating arg mono.  D3b-1 first: a mono pinned to an impl's `requires`
-- element tyvar (registered in activeDictVars by registerImplRequires) → the
-- element dict param RDict $dict_<method>_<slot> — the ARGUMENT-position analogue
-- of resolveSite's return-position RDict.  Else (D3a): a concrete head
-- (Int/String/Float/… or any ADT tycon) → a static `RKey tag …`, and when that
-- head names a parametric impl WITH a requires, fill the impl-dicts ref so the
-- call threads the element dict (concrete element → RKey Int; a recursive element
-- of the SAME parametric type → RDict forwarding the in-scope dict param).  A
-- still-unsolved free type variable → left RNone (the emitter arg-tag-dispatches).
resolveArgStamps : ImplBuckets -> KeyBuckets -> List (String, Ref Route, Ref (List Route), Mono, String) -> Unit
resolveArgStamps _ _ [] = ()
resolveArgStamps implTable keyTable ((name, tagRef, implRef, am, encl)::rest) =
  let _ = resolveArgStamp implTable keyTable name tagRef implRef am encl
  resolveArgStamps implTable keyTable rest

resolveArgStamp : ImplBuckets -> KeyBuckets -> String -> Ref Route -> Ref (List Route) -> Mono -> String -> Unit
resolveArgStamp implTable keyTable name tagRef implRef am encl = match activeDictVarOfEncl am encl
  Some dname => setRef tagRef (RDict dname)
  None => match headTyconMono am
    Some tag =>
      -- TYPECHECK-AUDIT C7 (arg-position): when ≥2 impls of this method share head
      -- tycon [tag] but differ in type ARGS (e.g. `MyPair Int Bool` vs `MyPair Bool
      -- Int`), bare-head `RKey tag` narrows to the FIRST impl (eval's hasTag matches
      -- the head `t`).  `keyForSite` upgrades to the canonical full-type impl key
      -- (matched against [am]) so eval's hasTag matches the right impl's `k`.  No
      -- collision (the common single-impl case) → None → bare head, unchanged path.
      let routeKey = fromOption tag (keyForSite keyTable name am)
      let _ = setRef tagRef (RKey routeKey [])
      let dictName = if implDefinesMethodAt implTable name tag then name else innerDefaultMethod name
      setRef implRef (argImplDictRoutesForEncl implTable encl dictName tag am)
    None => ()

-- Native Gap C (parametric default-method dict-synthesis, 2026-06-12): a BY-NAME
-- relational method (`lt`/`gt`/…) at a parametric Ord head (tuple/`List a`/`Box a`)
-- has NO own impl, so its element `requires` dicts must be keyed off the inner
-- `compare` (whose impl carries them).  emitDefaultDefine eta-prepends matching
-- dict params; emitDefaultRKey forwards these words.  Concrete head / a method
-- with its own impl ⇒ same key as before (empty for non-parametric), unchanged.

-- ── type-error accumulator ─────────────────────────────────────────────────
-- Unification failures record diagnostics here instead of panicking, so
-- ill-typed programs emit matching `TYPE ERROR: …` lines.  occursCheckFailed
-- is a per-bindVar flag: occursAdjustUnbound sets it so bindVar can skip the
-- actual link (preventing a cyclic union-find entry).
-- B.10.2b: each accumulated error is paired with the `currentLoc` span in
-- effect at the push site (its `Option Loc`), mirroring lib/typecheck.ml binding
-- `!current_loc` into `Type_error (e, !current_loc)` at the RAISE site rather
-- than reading the global last-entered loc afterwards.  `pushTypeError` captures
-- `currentLoc.value` so locs don't drift as inference continues past the error.
typeErrors : Ref (List (String, String, Option Loc))
typeErrors = Ref []

-- G1 (SOUNDNESS): a STICKY mirror of typeErrors that resetState does NOT clear.
-- The multi-module elaborate path (elaborateModules → checkModuleFullImpl) calls
-- resetState at the start of EACH module, wiping `typeErrors`, so after the whole
-- graph only the LAST module's errors survive there.  build/run must abort on a
-- type error in ANY module, so `pushTypeError` also records into this accumulator,
-- which only `resetTypeErrorsSticky` clears (the driver, once, before a run).  Read
-- via `hadTypeErrors` to gate the CLI exit code BEFORE emit/eval.
typeErrorsSticky : Ref Bool
typeErrorsSticky = Ref False

-- Clear the sticky accumulator.  Call once at the start of a build/run pipeline.
export resetTypeErrorsSticky : Unit -> Unit
resetTypeErrorsSticky _ = setRef typeErrorsSticky False

-- True iff any type error was pushed since the last resetTypeErrorsSticky.
export hadTypeErrors : Unit -> Bool
hadTypeErrors _ = typeErrorsSticky.value

-- Push one type-error message, snapshotting the current ELoc span (B.10.2b).
pushTypeError : String -> String -> Unit
pushTypeError code msg =
  let _ = setRef typeErrorsSticky True
  setRef typeErrors ((code, msg, currentLoc.value)::typeErrors.value)

-- The message field of an accumulated (code, msg, loc) type-error entry.
teErrMsg : (String, String, Option Loc) -> String
teErrMsg (_, m, _) = m

-- #11 soundness: push an obligation error only if the SAME message isn't already
-- accumulated.  A single missing impl can be detected by both checkImplObligations
-- (the original deferred obligation, once it grounds) and checkCallObligations (the
-- call-site instantiation) — the oracle raises ONE error per missing impl, so dedup
-- by message to keep native == oracle (one TYPE ERROR line).
pushTypeErrorOnce : String -> String -> Unit
pushTypeErrorOnce code msg =
  if anyList (e => teErrMsg e == msg) typeErrors.value then
    ()
  else
    pushTypeError code msg

-- B.10.2c: push a deduped type error attributing it to the supplied loc rather
-- than the live `currentLoc` (which is stale during the post-HM obligation
-- check — inference has long since left the offending ELoc).  The loc was
-- snapshotted into the obligation tuple at the record site.  `None` falls back
-- to the live `currentLoc` (the old behaviour) so an obligation that never
-- captured a span is unchanged.
pushTypeErrorOnceAt : String -> Option Loc -> String -> Unit
pushTypeErrorOnceAt code loc msg =
  if anyList (e => teErrMsg e == msg) typeErrors.value then ()
  else
    let _ = setRef typeErrorsSticky True
    setRef
      typeErrors
      ((code, msg, orElseLoc loc currentLoc.value)::typeErrors.value)

-- ── structured help/fix side channel (ERROR-QUALITY dim F) ─────────────────
-- `typeErrors` is a plain (code, msg, loc) triple, and that shape is threaded
-- through a dozen signatures across this file + driver/diagnostics.mdk
-- (checkProgramDiags, checkModuleFullDiags, checkModulesDiags, …).  Widening
-- it to carry `help`/`fix` too would touch all of those.  Instead, record any
-- help/fix keyed by the error's (already-the-dedup-key) message text in this
-- side ref; driver/diagnostics.mdk's Diag-construction sites look it up by
-- message when building the final `Diag` for CLI/--json.  `Fix`/`Diag` live in
-- driver/diagnostics.mdk, which already imports this module — importing them
-- back here would cycle — so the fix is carried as a plain (Loc, String)
-- span+replacement pair, converted to a real `Fix` on the diagnostics.mdk side.
typeErrorHelpFix : Ref (List (String, String, Option (Loc, String)))
typeErrorHelpFix = Ref []

-- Look up the help text + optional (loc, replacement) fix recorded for a
-- pushed type-error message, if any.  `None` for the overwhelming majority of
-- type errors, which carry no structured help/fix yet.
export lookupTypeErrorHelpFix : String -> Option (String, Option (Loc, String))
lookupTypeErrorHelpFix msg = findHelpFixEntry msg typeErrorHelpFix.value

findHelpFixEntry : String -> List (String, String, Option (Loc, String)) -> Option (String, Option (Loc, String))
findHelpFixEntry _ [] = None
findHelpFixEntry msg ((m, help, fix)::rest)
  | m == msg = Some (help, fix)
  | otherwise = findHelpFixEntry msg rest

-- Push a deduped type error (same dedup rule as pushTypeErrorOnceAt) that also
-- carries a human `help` string and an optional machine-applicable `fix`.
pushTypeErrorHelpFixAt : String -> Option Loc -> String -> String -> Option (Loc, String) -> Unit
pushTypeErrorHelpFixAt code loc msg help fix =
  if anyList (e => teErrMsg e == msg) typeErrors.value then ()
  else
    let _ = setRef typeErrorsSticky True
    let _ = setRef typeErrors ((code, msg, orElseLoc loc currentLoc.value)::typeErrors.value)
    setRef typeErrorHelpFix ((msg, help, fix)::typeErrorHelpFix.value)

-- the first `Some` loc, else the second (so a captured record-site span wins,
-- and a `None` capture still degrades to the live currentLoc).
orElseLoc : Option Loc -> Option Loc -> Option Loc
orElseLoc (Some l) _ = Some l
orElseLoc None fallback = fallback

-- Source-location attribution (Phase B.10.2): the innermost ELoc span the
-- `infer` walk has entered.  Set by infer's transparent ELoc arm before
-- recursing (mirror of lib/typecheck.ml's `current_loc` ref, set in its ELoc
-- arm; cf. `fail e = raise (Type_error (e, !current_loc))`).  Surfaced through
-- Diag / the LSP via `pushTypeError`.  `None` until the first ELoc is entered
-- (top-level decls aren't ELoc-wrapped).
currentLoc : Ref (Option Loc)
currentLoc = Ref None

currentDoOrigin : Ref (Option Loc)
currentDoOrigin = Ref None

-- C8b Gap 2 (diagnostic-quality parity): set to `Some methodName` around the
-- OUTER unify of an interface default body against its declared return type, so a
-- leaf TypeMismatch is reported as the oracle's specialized single line
-- `Method '<name>': expected type <e> but got <a>` (lib/typecheck.ml's
-- MethodTypeMismatch catch, :3904-3907) instead of a bare `Type mismatch: …`.
currentMethodMismatch : Ref (Option String)
currentMethodMismatch = Ref None

occursCheckFailed : Ref Bool
occursCheckFailed = Ref False

-- ASYNC-DESIGN Stage 2 (D5): the entry program's inferred `main` scheme, stashed
-- by elabModulesGo on the EVAL path so the native `run` driver can detect a
-- `main : Async _` and route it through `runAsync` (perform its row) instead of
-- forcing it to an inert Async value.  Last module wins (the entry is last in
-- dependency order), matching bin/main.ml's `final_schemes` lookup.  `None` until
-- a module binding `main` is elaborated; reset at the top of elaborateModules so a
-- prior run can't leak.  Type-level only → no emitted IR changes → fixpoint-safe.
mainSchemeRef : Ref (Option Scheme)
mainSchemeRef = Ref None

-- Head type-constructor of a (possibly applied) mono: walk the TApp left spine to
-- the constructor.  `Async e Unit` → Some "Async".
monoHeadCon : Mono -> Option String
monoHeadCon m = match normalize m
  TCon n => Some n
  TApp a _ => monoHeadCon a
  _ => None

-- Stage 2 query: did the last-elaborated `main` infer to an `Async`-headed type?
export mainTypeIsAsync : Unit -> Bool
mainTypeIsAsync _ = match mainSchemeRef.value
  Some (Forall _ _ t) => monoHeadCon t == Some "Async"
  None => False

-- Stage 3 query: did the last-elaborated `main` infer to a bare Unit return type
-- (with effects stripped at each arrow, mono resolves to TCon "Unit")?  Used by
-- the LLVM emitter to suppress the auto-print of Unit-returning mains even when no
-- explicit `main : <IO> Unit` annotation is present — e.g. `main = applyEff f 42`
-- where `applyEff : (a -> <IO> b) -> a -> <IO> b` and `f : Int -> <IO> Unit`.
export mainTypeIsUnit : Unit -> Bool
mainTypeIsUnit _ = match mainSchemeRef.value
  Some (Forall _ _ t) => match normalize t
    TCon "Unit" => True
    _ => False
  None => False

-- Stage 4 query: did the last-elaborated `main` infer to a bare Float return type?
-- Used by the LLVM/WasmGC emitters to render a bare Float value main correctly
-- even when the structural `mainKind`/`refMainKind` can't see through a polymorphic
-- HOF's return type (e.g. `main = fold (acc x => acc + x) 0.0 [1.0, 2.0, 3.0]`).
export mainTypeIsFloat : Unit -> Bool
mainTypeIsFloat _ = match mainSchemeRef.value
  Some (Forall _ _ t) => match normalize t
    TCon "Float" => True
    _ => False
  None => False

-- ── non-exhaustive-match warning accumulator (the type-aware `check_match`) ──
-- `inferMatch` pushes a warning here for every `match` whose non-guarded arms
-- don't cover the scrutinee's type.  `matchOracle` is the ctor oracle the matrix
-- recursion consults; the `checkMatchToLines` driver sets it from the program's
-- data decls (so it sees the same user + builtin ctors check_match does) before
-- inference runs.  Neither is touched by `resetState` — the driver seeds them and
-- reads `matchWarnings` after the typecheck pass; runs that ignore match warnings
-- (the schemes/selfproc paths) simply never read it.
matchWarnings : Ref (List String)
matchWarnings = Ref []

-- True iff the last typecheck pass pushed any match warning.  Read by the snapshot
-- runner (`tools/snapshot.mdk`) to decide whether a rendered `# TYPES` section carries
-- diagnostic prose — a `W-*` warning is graded by `compiler/ERROR-QUALITY.md` exactly
-- like an error is, so a `# TYPES` section holding one is NOT `--bless`-able.  Keyed on
-- the accumulator rather than sniffing the rendered text: the renderer must not have to
-- guess which of its own lines are diagnostics.
export hadMatchWarnings : Unit -> Bool
hadMatchWarnings _ = matchWarnings.value != []

-- Stage-C (S4): the `currentLoc` span snapshotted at each non-exhaustive-match
-- push, parallel to `matchWarnings` (same length, same order).  The diagnostics
-- path (`checkProgramDiags`) zips the two so the CLI/--json warning carries a
-- span like the OCaml oracle's `pp_loc match_loc`.  String-only readers
-- (schemes/selfproc/diff_compiler_diagnostics) ignore it.
matchWarningLocs : Ref (List (Option Loc))
matchWarningLocs = Ref []

matchOracle : Ref Oracle
matchOracle = Ref (buildOracle [])

-- Structured-help side channel for the non-exhaustive-match warning (mirrors
-- `typeErrorHelpFix` above, same rationale: widening `matchWarnings`'s element
-- type would touch every reader of the plain `List String`).  Keyed by the
-- exact warning message text (post-hint-append, since that's the dedup key a
-- lookup by message needs to match); `driver/diagnostics.mdk` looks this up
-- when building the `Diag` for `--json`'s `help` field.
matchWarningHelp : Ref (List (String, String))
matchWarningHelp = Ref []

export lookupMatchWarningHelp : String -> Option String
lookupMatchWarningHelp msg =
  findMatchWarningHelpEntry msg matchWarningHelp.value

findMatchWarningHelpEntry : String -> List (String, String) -> Option String
findMatchWarningHelpEntry _ [] = None
findMatchWarningHelpEntry msg ((m, help)::rest)
  | m == msg = Some help
  | otherwise = findMatchWarningHelpEntry msg rest

resetState : Unit -> Unit
resetState _ =
  let _ = setRef tyvarCounter 0
  let _ = seedEffectDomains ()
  let _ = setRef effvarCounter 0
  let _ = setRef curEffect (EffRow [] None)
  let _ = setRef recordsRef []
  let _ = setRef dataParamKindsRef []
  let _ = setRef aliasTableRef []
  let _ = setRef pendingSites []
  let _ = setRef pendingRLocalSites []
  let _ = setRef shadowStandaloneSchemesRef []
  let _ = setRef definerShadowNamesRef []
  let _ = setRef definerShadowSigsRef []
  let _ = setRef shadowHeadCtxRef False
  let _ = setRef shadowKeyTableRef omEmpty
  let _ = setRef pendingBinopSites []
  let _ = setRef pendingUnopSites []
  let _ = setRef pendingArithSites []
  let _ = setRef methodIfaceParamsRef omEmpty
  let _ = setRef registeredIfacesRef omEmpty
  let _ = setRef pendingImplObligations []
  let _ = setRef pendingImplObligationsN 0
  let _ = setRef numlitRefs []  -- PLAN.md #11
  let _ = setRef poisonedVars []  -- Chunk A: reset error-path cascade suppression
  let _ = setRef tupleCallCandidates []  -- P0-16: reset beginner tuple-call hints
  let _ = setRef numlitVarLocs []  -- Chunk D: reset Num-mis-framing provenance
  let _ = setRef numlitUntainted []
  let _ = setRef numlitOpLocs []  -- Chunk D
  let _ = setRef numlitCtxTags []  -- Chunk D
  let _ = setRef localBindRefs []
  let _ = setRef localSchemesOut []
  let _ = setRef seedSchemesOut []
  let _ = setRef pendingArgStamps []
  let _ = setRef activeDictVars []
  let _ = setRef funConstraintsRef []
  let _ = setRef funConstraintIfacesRef []
  let _ = setRef currentImportDefinersRef []
  let _ = setRef pendingDictApps []
  let _ = setRef pendingDictAppsN 0
  let _ = setRef pendingCallObligations []
  let _ = setRef pendingCallObligationsN 0
  let _ = setRef schemeObligationsRef []
  let _ = setRef methodConstraintsRef []
  let _ = setRef methodConstraintPositionsRef []
  let _ = setRef pendingMethodDicts []
  let _ = setRef pendingRecDictApps []
  let _ = setRef currentFn ""
  let _ = setRef currentImplBody False
  let _ = setRef methodSiteFns omEmpty
  let _ = setRef dictAppFns omEmpty
  let _ = setRef promotedRef []
  let _ = setRef methodShadowNamesRef []
  let _ = setRef flatShadowScopingRef False
  let _ = setRef flatCoreFnNamesRef omEmpty
  let _ = setRef flatUserShadowNamesRef []
  let _ = setRef groupConstraintMonosRef []
  let _ = setRef typeErrors []
  let _ = setRef typeErrorHelpFix []
  let _ = setRef matchWarningHelp []
  let _ = setRef occursCheckFailed False
  setRef currentLevel 0

-- ── small helpers ─────────────────────────────────────────────────────────
lookupAssocI : Int -> List (Int, b) -> Option b
lookupAssocI _ [] = None
lookupAssocI k ((k2, v)::rest)
  | k == k2 = Some v
  | otherwise = lookupAssocI k rest

containsI : Int -> List Int -> Bool
containsI _ [] = False
containsI x (y::ys) = x == y || containsI x ys

-- `support/util`'s `anyList` takes a PURE predicate, so it cannot carry the
-- path-compressing (hence `<Mut>`) mono predicates below — `monoIsFunction`,
-- `numUnimplementableHead`, … all normalize.  Same short-circuiting `||` fold, one
-- effect row wider.  (Medaka has no effect-polymorphic HOFs, so this must be a
-- second definition rather than a reuse of `anyList`.)
anyListM : (a -> Bool) -> List a -> Bool
anyListM _ [] = False
anyListM p (x::xs) = p x || anyListM p xs

-- ── union-find core ───────────────────────────────────────────────────────
-- PERF (issue #115): this is a union-find FIND, and it PATH-COMPRESSES.  Without
-- compression it was the compiler's worst performance defect: `unifyVars` links the
-- current root to the *fresh* var it meets (`bindVar c1 (TVar c2)`), so inferring a
-- single large declaration — an N-arm `match` whose arms all unify against one
-- result var, an N-element list literal — builds a Link chain of length N.  Every
-- later `normalize`/`rootIdOf` of any var in that class then walked O(N) links, and
-- the post-inference walkers (`walkDispatch`, `setNumlitFloatsGo`, `monoUnboundIds`)
-- plus the Chunk-D numlit scans do that once per literal ⇒ O(N²) link steps, on a
-- non-allocating hot loop that no allocation-graded gate could see.  Compression
-- makes it amortized near-O(1) and leaves the ROOT IDENTITY untouched — this is a
-- representation change only, so no program's inferred type moves.
--
-- Returns the ARGUMENT ITSELF (never a rebuilt `TVar`) when already at a root, so
-- the overwhelmingly common case allocates nothing — the old multi-clause form's
-- `Unbound _ _ => TVar cell` rebuilt a cell on every call.  That is why this matches
-- on the whole parameter instead of destructuring it in the head: a multi-clause
-- definition cannot name the value it matched, so it cannot give it back unchanged.
export normalize : Mono -> Mono
-- lint-disable-next-line rule-match-on-param
normalize m = match m
  TVar cell => match cell.value
    Link t => normalizeLink cell t
    Unbound _ _ => m
  _ => m

-- [cell] is a `Link` to [t]: resolve [t] to its root, re-point [cell] STRAIGHT at
-- that root, and return it.  The write happens only when the chain is longer than
-- one hop — a direct link is already compressed, so re-writing it would be pure cost.
-- Matches on the whole [t] for the same no-rebuild reason as `normalize` above.
normalizeLink : Ref Tyvar -> Mono -> Mono
-- lint-disable-next-line rule-match-on-param
normalizeLink cell t = match t
  TVar c2 => match c2.value
    Unbound _ _ => t
    Link t2 =>
      let r = normalizeLink c2 t2
      let _ = setRef cell (Link r)
      r
  _ => t

tyvarId : Ref Tyvar -> Int
tyvarId cell = match cell.value
  Unbound id _ => id
  Link _ => 0 - 1

tyvarLevel : Ref Tyvar -> Int
tyvarLevel cell = match cell.value
  Unbound _ lvl => lvl
  Link _ => 0

-- occurs-check + lower the levels of vars in [t] to <= [level] (Phase: Rémy levels)
occursAdjust : Int -> Int -> Mono -> Unit
occursAdjust id level t = match normalize t
  TVar cell => occursAdjustVar id level cell
  TCon _ => ()
  TApp a b =>
    let _ = occursAdjust id level a
    occursAdjust id level b
  TFun a r b =>
    let _ = occursAdjust id level a
    let _ = lowerRowLevels level r
    occursAdjust id level b
  TEff r => lowerRowLevels level r

occursAdjustVar : Int -> Int -> Ref Tyvar -> Unit
occursAdjustVar id level cell = match cell.value
  Unbound id2 lvl2 => occursAdjustUnbound id level cell id2 lvl2
  Link t => occursAdjust id level t

occursAdjustUnbound : Int -> Int -> Ref Tyvar -> Int -> Int -> Unit
occursAdjustUnbound id level cell id2 lvl2
  | id2 == id =
    let _ = setRef occursCheckFailed True
    pushTypeError
      "T-INFINITE-TYPE"
      ("Cannot construct infinite type involving " ++ ppMono (TVar cell))
  | lvl2 > level = setRef cell (Unbound id2 level)
  | otherwise = ()

unify : Mono -> Mono -> Unit
unify a b = unifyN (normalize a) (normalize b)

unifyN : Mono -> Mono -> Unit
unifyN (TVar c1) (TVar c2) = unifyVars c1 c2
unifyN (TVar c) t = bindVar c t
unifyN t (TVar c) = bindVar c t
unifyN (TCon a) (TCon b) = if a == b then () else typeMismatch (TCon a) (TCon b)
-- A tuple TYPE is now a `__tupleN__`-headed `TApp` spine; when it clashes with a
-- differing-arity tuple or with a concrete non-tuple head, report the FULL types
-- (which render `(a, b)` via ppGo) instead of letting the generic `TApp~TApp`
-- recursion bottom out on a partial sub-spine — preserving the pre-refactor
-- tuple mismatch wording.  Guard is False when the other side is a TVar-headed
-- spine (so `p a b` unifying with a tuple still flows through the generic arm).
unifyN t1 t2
  | tupleUnifyClash t1 t2 = typeMismatch t1 t2
unifyN (TApp a1 b1) (TApp a2 b2) =
  let _ = unify a1 a2
  unify b1 b2
unifyN (TFun a1 r1 b1) (TFun a2 r2 b2) =
  let _ = unify a1 a2
  let _ = unifyRow r1 r2
  unify b1 b2
unifyN (TEff r1) (TEff r2) = unifyRow r1 r2
unifyN a b = typeMismatch a b

unifyVars : Ref Tyvar -> Ref Tyvar -> Unit
unifyVars c1 c2 = if tyvarId c1 == tyvarId c2 then () else bindVar c1 (TVar c2)

bindVar : Ref Tyvar -> Mono -> Unit
bindVar cell t =
  let _ = setRef occursCheckFailed False
  let _ = occursAdjust (tyvarId cell) (tyvarLevel cell) t
  if occursCheckFailed.value then () else setRef cell (Link t)

-- Chunk A: record the union-find roots of every free var on either side of a
-- unification failure so a later obligation check can suppress a secondary
-- `ambiguous instance` cascade on the same (already-errored) var.
poisonMismatchVars : Mono -> Mono -> Unit
poisonMismatchVars a b =
  setRef
    poisonedVars
    (monoUnboundIds a ++ monoUnboundIds b ++ poisonedVars.value)

typeMismatch : Mono -> Mono -> Unit
typeMismatch a b =
  let _ = poisonMismatchVars a b
  typeMismatchReport a b

typeMismatchReport : Mono -> Mono -> Unit
typeMismatchReport a b = match currentMethodMismatch.value
  Some mname => pushTypeError "T-METHOD-MISMATCH" "Method '\{mname}': expected type \{ppMono a} but got \{ppMono b}"
  None => match currentDoOrigin.value
    Some doLoc => typeMismatchInDo a b doLoc
    None => match firstTupleCallHint [a, b]
      -- P0-16: one side is a tuple-call residual (e.g. `z : Int; z = add(1, 2)`
      -- → `Type mismatch: Int vs (a, b) -> (a, b)`) — append the call-syntax hint.
      Some (help, fix) =>
        pushTypeErrorHelpFixAt "T-TYPE-MISMATCH" currentLoc.value "Type mismatch: \{ppMono a} vs \{ppMono b} — \{help}" help fix
      None => pushTypeError "T-TYPE-MISMATCH" "Type mismatch: \{ppMono a} vs \{ppMono b}"

-- a mismatch inside a do-lowered chain: if it is the monad-shape (`m b`) vs
-- non-monad obligation, retarget to the tailored "do requires a monad" error;
-- otherwise fall back to the plain mismatch (the loc stays the do-block's).
typeMismatchInDo : Mono -> Mono -> Loc -> Unit
typeMismatchInDo a b doLoc
  | monoIsApp (normalize a) != monoIsApp (normalize b) =
    recordDoMonadError doLoc
  | otherwise =
    pushTypeError "T-TYPE-MISMATCH" "Type mismatch: \{ppMono a} vs \{ppMono b}"

recordDoMonadError : Loc -> Unit
recordDoMonadError doLoc =
  let _ = setRef currentDoOrigin None
  let _ = setRef typeErrorsSticky True
  setRef
    typeErrors
    (("T-DO-NOT-MONAD", doRequiresMonadMsg, Some doLoc)::typeErrors.value)

monoIsApp : Mono -> Bool
monoIsApp (TApp _ _) = True
monoIsApp _ = False

doRequiresMonadMsg : String
doRequiresMonadMsg = "`do` requires a Thenable impl (e.g. `Option`/`Result`). For IO sequencing use a bare indented block, not `do`"

-- SYMMETRIC complement of doRequiresMonadMsg: a `<-` bind reached a bare
-- (non-`do`) block.  `<-` is monadic-`do`-only; a bare indented block is IO
-- sequencing and does not allow it (language-design.md; "IO is not a monad").
bindOutsideDoMsg : String
bindOutsideDoMsg = "`<-` bind is only valid inside a `do` block. For IO sequencing use a bare indented block without `<-`"

-- ── generalization & instantiation ────────────────────────────────────────
generalize : Mono -> Scheme
generalize t =
  Forall (dedupI (freeGenVars currentLevel.value t)) (dedupI (freeEffvars t)) t

-- Generalize each captured local binding's (now-solved) mono into a Scheme for
-- the LSP hover fallback (see localBindRefs).  Runs at the end of inference when
-- currentLevel is back at the top, so a still-free local var quantifies cleanly
-- to `a`; a ground var (e.g. a `let` bound to a String) renders concretely.
mapLocalSchemes : List (String, Mono) -> List (String, Scheme)
mapLocalSchemes [] = []
mapLocalSchemes ((n, m)::rest) = (n, generalize m) :: mapLocalSchemes rest

-- ── value restriction (T1) ────────────────────────────────────────────────
-- A binding RHS is *non-expansive* (a syntactic value) iff it cannot allocate a
-- mutable cell: literals, variables and lambdas are values; annotations are
-- transparent; tuples/lists are values iff their elements are.  Constructor
-- applications of non-expansive arguments are non-expansive (SML value
-- restriction relaxation, Phase 66 extension) EXCEPT `Ref`, which is the sole
-- uppercase constructor that builds a mutable cell (`extern Ref : a -> Ref a` in
-- stdlib/runtime.mdk).  Generalizing `Ref x` would be unsound (polymorphic
-- reference: write at one type, read at another).  ANY future uppercase
-- mutable-cell extern MUST be added to the exclusion in `isCtorAppHead` below
-- — audit with `grep '^extern [A-Z]' stdlib/runtime.mdk` to find candidates.
-- Record creates are non-expansive iff all field expressions are.
-- Note: this ignores the `mut` flag (like the oracle), so `let mut x = []`
-- generalizes — the separate `mut`-gen hole is a both-sides follow-up (T1b).
isNonexpansive : Expr -> Bool
isNonexpansive (ELoc _ e) = isNonexpansive e
isNonexpansive (EDoOrigin _ e) = isNonexpansive e
isNonexpansive (ELit _) = True
isNonexpansive (EVar _) = True
isNonexpansive (ELam _ _) = True
isNonexpansive (EAnnot e _) = isNonexpansive e
isNonexpansive (EHeadAnnot e _) = isNonexpansive e
isNonexpansive (ETuple es) = allList isNonexpansive es
isNonexpansive (EListLit es) = allList isNonexpansive es
-- Constructor application: non-expansive iff the spine head is an
-- uppercase-initial EVar (a data/record constructor) that is NOT `Ref`, and
-- every spine argument is itself non-expansive.  Partial ctor applications
-- (e.g. `MkTwo []`) are also non-expansive — they are closures, not mutable
-- cells.  `isCtorAppHead` strips ELoc/EDoOrigin wrappers before testing.
isNonexpansive (EApp f x) = isCtorAppHead (EApp f x) && isNonexpansive x
-- Record creation: non-expansive iff every field expression is non-expansive.
isNonexpansive (ERecordCreate _ fs) = allList
  (fa => match fa
    FieldAssign _ e => isNonexpansive e)
  fs
isNonexpansive _ = False

-- Walk the left spine of an application to its head and test whether the
-- head is a data/record constructor (uppercase-initial EVar) that is safe to
-- generalize.  `Ref` is excluded because it is the only uppercase extern that
-- builds a mutable cell — see the comment on `isNonexpansive` above.
isCtorAppHead : Expr -> Bool
isCtorAppHead (ELoc _ e) = isCtorAppHead e
isCtorAppHead (EDoOrigin _ e) = isCtorAppHead e
isCtorAppHead (EApp f _) = isCtorAppHead f
isCtorAppHead (EVar name) = name != "Ref" && ctorHeadIsUpper name
isCtorAppHead _ = False

-- True iff the first character of a name is an ASCII uppercase letter,
-- i.e. the name looks like a data constructor or type name.
ctorHeadIsUpper : String -> Bool
ctorHeadIsUpper name =
  let cs = stringToChars name
  arrayLength cs > 0 && isUpper (arrayGetUnsafe 0 cs)

-- Lower every unbound var in [t] deeper than the current level down to the
-- current level, so a value-restricted (non-generalized) binding's vars can't be
-- picked up by an enclosing let's generalize.  Mirrors the lowering `unify`
-- performs via occursAdjust in the non-PVar pattern path (oracle
-- `lib/typecheck.ml:555-565`).
lowerToCurrent : Mono -> Unit
lowerToCurrent t = match normalize t
  TVar cell => match cell.value
    Unbound id lvl =>
      if lvl > currentLevel.value then
        setRef cell (Unbound id currentLevel.value)
      else
        ()
    Link t2 => lowerToCurrent t2
  TCon _ => ()
  TApp a b =>
    let _ = lowerToCurrent a
    lowerToCurrent b
  TFun a r b =>
    let _ = lowerToCurrent a
    let _ = lowerRowLevels currentLevel.value r
    lowerToCurrent b
  TEff r =>
    let _ = lowerRowLevels currentLevel.value r
    ()

-- Generalize a value RHS; value-restrict (monomorphize, lowering free vars)
-- otherwise.  monoScheme leaves the mono ungeneralized.  Oracle
-- `lib/typecheck.ml:569-571`.
genRestricted : Bool -> Mono -> Scheme
genRestricted isValue t
  | isValue = generalize t
  | otherwise =
    let _ = lowerToCurrent t
    monoScheme t

freeGenVars : Int -> Mono -> List Int
freeGenVars lvl t = match normalize t
  TVar cell => if tyvarLevel cell > lvl then [tyvarId cell] else []
  TCon _ => []
  TApp a b => freeGenVars lvl a ++ freeGenVars lvl b
  TFun a _ b => freeGenVars lvl a ++ freeGenVars lvl b
  TEff _ => []

dedupI : List Int -> List Int
dedupI xs = dedupIGo xs []

dedupIGo : List Int -> List Int -> List Int
dedupIGo [] _ = []
dedupIGo (x::xs) seen
  | containsI x seen = dedupIGo xs seen
  | otherwise = x :: dedupIGo xs (x::seen)

instantiate : Scheme -> Mono
instantiate (Forall ids evars t) =
  substMonoP True (freshSubst ids) (freshEffSubst evars) t

freshSubst : List Int -> List (Int, Mono)
freshSubst [] = []
freshSubst (id::rest) = (id, freshVar ()) :: freshSubst rest

freshEffSubst : List Int -> List (Int, Ref Effvar)
freshEffSubst [] = []
freshEffSubst (id::rest) = (id, freshEffvar ()) :: freshEffSubst rest

substMono : List (Int, Mono) -> List (Int, Ref Effvar) -> Mono -> Mono
substMono subst esub t = match normalize t
  TVar cell => fromOption (TVar cell) (lookupAssocI (tyvarId cell) subst)
  TCon n => TCon n
  TApp a b => TApp (substMono subst esub a) (substMono subst esub b)
  TFun a eff b =>
    TFun (substMono subst esub a) (substRow esub eff) (substMono subst esub b)
  TEff r => TEff (substRow esub r)

-- Phase 146 variance-aware re-open: when instantiating a generalized scheme,
-- re-open a CLOSED row carrying concrete labels (`EffRow labels None`) at a
-- COVARIANT (positive) position — an arrow the value itself produces.  This turns
-- a concrete effectful value (`putStrLn : String -> <IO> Unit`) meeting a pure
-- closed bound into the open-row subset check, rejecting the laundering escape.
-- Contravariant rows (a parameter / ctor field the scheme accepts) stay closed so
-- a legitimately pure argument in an effect-allowing slot still subsumes.  Pure
-- (label-less) rows are never re-opened — nothing to leak.
reopenRow : Bool -> EffRow -> EffRow
reopenRow pos r = reopenRowN pos (effrowNorm r)

reopenRowN : Bool -> EffRow -> EffRow
reopenRowN True (EffRow (l::ls) None) = EffRow (l::ls) (Some (freshEffvar ()))
reopenRowN _ r = r

-- positional twin of substMono used by scheme instantiation: flips variance on
-- the arrow domain and re-opens covariant closed-with-labels rows (start pos=True)
substMonoP : Bool -> List (Int, Mono) -> List (Int, Ref Effvar) -> Mono -> Mono
substMonoP pos subst esub t = match normalize t
  TVar cell => fromOption (TVar cell) (lookupAssocI (tyvarId cell) subst)
  TCon n => TCon n
  TApp a b => TApp (substMonoP pos subst esub a) (substMonoP pos subst esub b)
  TFun a eff b => TFun (substMonoP (not pos) subst esub a) (reopenRow pos (substRow esub eff)) (substMonoP pos subst esub b)
  TEff r => TEff (substRow esub r)

-- ── rendering (mirrors lib/typecheck.ml pp_mono byte-for-byte) ─────────────
export ppScheme : Scheme -> String
ppScheme (Forall _ _ t) = ppMono t

-- Render a scheme WITH its constraint context (`Num a => a -> a -> a`).  The
-- constraint tyvar ids are threaded through the SAME ctx/cnt that renders the
-- body, so a constraint's letter matches the body's (id → letter shared).  The
-- body is rendered FIRST so ctx already carries the body's letter assignments
-- when the constraints reuse it via nameOf.  Constraints are rendered+sorted+
-- deduped for a stable display order.  Empty list ⇒ plain ppScheme (no `=>`).
-- Single-vs-multiple form mirrors ppConstrDoc in tools/doc.mdk (`Num a =>` /
-- `(Num a, Ord b) =>`).
export ppSchemeCon : List (String, Int) -> Scheme -> String
ppSchemeCon [] s = ppScheme s
ppSchemeCon cons (Forall _ _ t) =
  let ctx = Ref []
  let cnt = Ref 0
  let body = ppGo ctx cnt 0 t
  let rendered = sortUniqS (renderConstraintCtx ctx cnt cons)
  let ctxStr = match rendered
    [c] => c
    _ => "(" ++ joinWith ", " rendered ++ ")"
  "\{ctxStr} => \{body}"

renderConstraintCtx : Ref (List (Int, String)) -> Ref Int -> List (String, Int) -> List String
renderConstraintCtx _ _ [] = []
renderConstraintCtx ctx cnt ((iface, id)::rest) =
  let s = "\{iface} \{nameOf ctx cnt id}"
  s :: renderConstraintCtx ctx cnt rest

-- Render a binding's scheme WITH its inferred/declared constraint context, looked
-- up by NAME from schemeObligationsRef (the always-on obligation side-channel the
-- most-recent typecheck left populated).  A name with no recorded obligations
-- renders as plain ppScheme.  Used by schemeLines (`check --types`) and the LSP
-- hover/completion/inlay renderers so all display surfaces show `Num a => …`.
export ppSchemeNamed : String -> Scheme -> String
ppSchemeNamed n s =
  ppSchemeCon (fromOption [] (lookupAssocS2 n schemeObligationsRef.value)) s

ppMono : Mono -> String
ppMono t =
  let ctx = Ref []
  let cnt = Ref 0
  ppGo ctx cnt 0 t

letters : String
letters = "abcdefghijklmnopqrstuvwxyz"

nameOf : Ref (List (Int, String)) -> Ref Int -> Int -> String
nameOf ctx cnt id = match lookupAssocI id ctx.value
  Some s => s
  None => assignName ctx cnt id

assignName : Ref (List (Int, String)) -> Ref Int -> Int -> String
assignName ctx cnt id =
  let n = cnt.value
  let _ = setRef cnt (n + 1)
  let s = if n < 26 then stringSlice n (n + 1) letters else "t" ++ intToString n
  let _ = setRef ctx ((id, s)::ctx.value)
  s

ppGo : Ref (List (Int, String)) -> Ref Int -> Int -> Mono -> String
ppGo ctx cnt prec t = match normalize t
  TVar cell => ppVar ctx cnt cell
  TCon n => ppConName n
  TApp a b => ppApp ctx cnt prec a b
  TFun a eff b => ppFun ctx cnt prec a eff b
  TEff r => ppEffArg ctx cnt r

-- Render a row sitting in type-argument position (the `e` of `Async e a`).  Bare
-- open tail → the row var's name (reads `Async e a`); labels → `<IO>`/`<IO | e>`;
-- closed empty → `<>`.  Effvar ids are offset into a private letter namespace so
-- they never collide with tyvar letters.  Mirrors lib/typecheck.ml pp_mono TEff.
ppEffArg : Ref (List (Int, String)) -> Ref Int -> EffRow -> String
ppEffArg ctx cnt r = match effrowNorm r
  EffRow labels tail =>
    let lbl = match labels
      [] => ""
      ls => renderAtoms ls
    let tailS = match tail
      Some cell => match cell.value
        EUnbound id _ => nameOf ctx cnt (id + 1000000)
        ELink _ => ""
      None => ""
    ppEffArgFmt lbl tailS

ppEffArgFmt : String -> String -> String
ppEffArgFmt l t
  | l == "" && t == "" = "<>"
  | l == "" = t
  | t == "" = "<" ++ l ++ ">"
  | otherwise = "<\{l} | \{t}>"

ppVar : Ref (List (Int, String)) -> Ref Int -> Ref Tyvar -> String
ppVar ctx cnt cell = match cell.value
  Unbound id _ => nameOf ctx cnt id
  Link _ => "_"

ppApp : Ref (List (Int, String)) -> Ref Int -> Int -> Mono -> Mono -> String
ppApp ctx cnt prec a b = match tupleSpine (TApp a b)
  -- a fully-saturated `__tupleN__` spine renders back to surface `(e1, …, eN)`
  Some ts => "(" ++ joinWith ", " (ppEach ctx cnt 0 ts) ++ ")"
  None =>
    let sa = ppGo ctx cnt 2 a
    let sb = ppGo ctx cnt 3 b
    wrapIf (prec > 2) "\{sa} \{sb}"

ppFun : Ref (List (Int, String)) -> Ref Int -> Int -> Mono -> EffRow -> Mono -> String
ppFun ctx cnt prec a eff b =
  let sa = ppGo ctx cnt 2 a
  let sb = ppGo ctx cnt 1 b
  wrapIf (prec > 1) "\{sa} -> \{effStr (effrowLabels eff)}\{sb}"

effStr : List Atom -> String
effStr [] = ""
effStr labels = "<" ++ renderAtoms labels ++ "> "

stripEff : Ty -> Ty
stripEff (TyEffect _ _ t) = t
stripEff t = t

ppEach : Ref (List (Int, String)) -> Ref Int -> Int -> List Mono -> List String
ppEach _ _ _ [] = []
ppEach ctx cnt prec (t::ts) =
  let s = ppGo ctx cnt prec t
  s :: ppEach ctx cnt prec ts

wrapIf : Bool -> String -> String
wrapIf True s = "(" ++ s ++ ")"
wrapIf False s = s

-- ── AST type → mono (for ADT field types / annotations / signatures) ──────
-- free type-variable NAMES in the type map to fresh tyvars (a signature's `a`
-- is a variable, not a TCon)
tyVarNames : Ty -> List String
tyVarNames (TyVar n) = [n]
tyVarNames (TyCon _ _) = []
tyVarNames (TyApp a b) = tyVarNames a ++ tyVarNames b
tyVarNames (TyFun a b) = tyVarNames a ++ tyVarNames b
tyVarNames (TyTuple ts) = flatMap tyVarNames ts
tyVarNames (TyEffect _ _ t) = tyVarNames t
tyVarNames (TyConstrained _ t) = tyVarNames t

-- WS-1c: the tyvar names appearing in a signature's `=>` CONSTRAINTS (not the value
-- type).  `tyVarNames` deliberately skips TyConstrained's constraints, so a constraint
-- var that NEVER appears in the value type (`Mk a => Int -> Int` — `a` only in `Mk a`)
-- was dropped from the fresh-var map and the generalized scheme: the scheme didn't
-- quantify `a`, so a call-site instantiation couldn't pin it (anyIdPinned False), the
-- call fell to the recursive-app path with empty ids → an empty dict → runtime
-- `intToString: not an Int` / a null build dict.  Including these names (deduped
-- against tyVarNames, so a constraint var ALSO in the value type is unaffected) lets
-- the constraint var be freshened + quantified like any other, so the undetermined
-- call routes through the normal pendingDictApps path (routeUndeterminedTop).
constraintVarNamesTy : Ty -> List String
constraintVarNamesTy (TyConstrained cs t) = flatMap constraintArgVarNames cs
  ++ constraintVarNamesTy t
constraintVarNamesTy (TyEffect _ _ t) = constraintVarNamesTy t
constraintVarNamesTy _ = []

constraintArgVarNames : Constraint -> List String
constraintArgVarNames (Constraint _ tys) = flatMap tyVarNames tys

-- tyVarNames PLUS the signature's constraint-only vars (deduped).
tyVarNamesWithConstraints : Ty -> List String
tyVarNamesWithConstraints ty = dedup (tyVarNames ty ++ constraintVarNamesTy ty)

-- ── alias cycle detection (stage 4) ──────────────────────────────────────────
-- Collect all TyCon (type-constructor) names referenced anywhere in a surface
-- Ty.  Mirrors tyVarNames but for constructor slots.  TyVar names are alias
-- params and never alias dependencies, so they are excluded.
tyConNamesInTy : Ty -> List String
tyConNamesInTy (TyCon n _) = [n]
tyConNamesInTy (TyVar _) = []
tyConNamesInTy (TyApp a b) = tyConNamesInTy a ++ tyConNamesInTy b
tyConNamesInTy (TyFun a b) = tyConNamesInTy a ++ tyConNamesInTy b
tyConNamesInTy (TyTuple ts) = flatMap tyConNamesInTy ts
tyConNamesInTy (TyEffect _ _ t) = tyConNamesInTy t
tyConNamesInTy (TyConstrained cs t) = flatMap tyConNamesInConstraint cs
  ++ tyConNamesInTy t

tyConNamesInConstraint : Constraint -> List String
tyConNamesInConstraint (Constraint iname tys) =
  iname :: flatMap tyConNamesInTy tys

-- Collect all elements from the HEAD of a list up to and including `target`.
-- The on-stack list is newest-first; when a back-edge to `target` is detected,
-- everything from the head down to `target` (inclusive) is on the cycle path.
takeUntilInclusiveS : String -> List String -> List String
takeUntilInclusiveS _ [] = []
takeUntilInclusiveS target (x::xs) =
  if x == target then
    [x]
  else
    x :: takeUntilInclusiveS target xs

-- Build the alias-dependency entry for one table entry: alias name → list of
-- other alias keys mentioned in its RHS (the dependency edges).
buildAliasGraphEntry : List String -> (String, (List String, Ty)) -> (String, List String)
buildAliasGraphEntry aliasKeys (name, paramsRhs) =
  let rhs = snd paramsRhs
  (name, filterList (k => contains k aliasKeys) (dedup (tyConNamesInTy rhs)))

-- DFS over the alias dependency graph.  Detects back-edges (a node is reached
-- while it is already on the current path) → cycle.  On a back-edge to `target`,
-- marks every node on the stack from the head down to and including `target` as
-- cyclic (they are all on the same cycle path).
aliasDfsVisit : List (String, List String) -> Ref (List String) -> Ref (List String) -> Ref (List String) -> String -> Unit
aliasDfsVisit graph visitedRef onStackRef cyclicOut name =
  if contains name visitedRef.value then ()
  else
    if contains name onStackRef.value then setRef cyclicOut (dedup (takeUntilInclusiveS name onStackRef.value ++ cyclicOut.value))
    else
      let _ = setRef onStackRef (name::onStackRef.value)
      let _ = aliasDfsVisitNeighbors graph visitedRef onStackRef cyclicOut (fromOption [] (lookupAssoc name graph))
      let _ = setRef onStackRef (filterList (!= name) onStackRef.value)
      setRef visitedRef (name::visitedRef.value)

aliasDfsVisitNeighbors : List (String, List String) -> Ref (List String) -> Ref (List String) -> Ref (List String) -> List String -> Unit
aliasDfsVisitNeighbors _ _ _ _ [] = ()
aliasDfsVisitNeighbors graph visitedRef onStackRef cyclicOut (n::ns) =
  let _ = aliasDfsVisit graph visitedRef onStackRef cyclicOut n
  aliasDfsVisitNeighbors graph visitedRef onStackRef cyclicOut ns

aliasDfsVisitAll : List (String, List String) -> Ref (List String) -> Ref (List String) -> Ref (List String) -> List String -> Unit
aliasDfsVisitAll _ _ _ _ [] = ()
aliasDfsVisitAll graph visitedRef onStackRef cyclicOut (k::ks) =
  let _ = aliasDfsVisit graph visitedRef onStackRef cyclicOut k
  aliasDfsVisitAll graph visitedRef onStackRef cyclicOut ks

emitCyclicAliasErrors : List String -> Unit
emitCyclicAliasErrors [] = ()
emitCyclicAliasErrors (name::rest) =
  let _ = pushTypeErrorOnce "T-RECURSIVE-ALIAS" ("Recursive type alias `" ++ name ++ "`. Type aliases cannot be recursive or cyclic")
  emitCyclicAliasErrors rest

-- Cycle-detection pre-pass over aliasTableRef.  MUST run immediately after
-- registerAllData has fully populated the table and BEFORE any fromAstType*
-- call (which would infinite-loop on a cyclic alias via the recursive expansion
-- added in stages 2–3).  For each alias found on a cycle:
--   (1) emits a deduped type_error naming the offending alias;
--   (2) removes it from aliasTableRef so the expansion seam falls through to an
--       opaque TCon and cannot recurse → no stack overflow.
rejectCyclicAliases : Unit -> Unit
rejectCyclicAliases _ =
  let table = aliasTableRef.value
  let aliasKeys = map fst table
  let graph = map (buildAliasGraphEntry aliasKeys) table
  let visitedRef = Ref []
  let onStackRef = Ref []
  let cyclicOut = Ref []
  let _ = aliasDfsVisitAll graph visitedRef onStackRef cyclicOut aliasKeys
  let cyclic = cyclicOut.value
  let _ = emitCyclicAliasErrors cyclic
  setRef
    aliasTableRef
    (filterList (entry => not (contains (fst entry) cyclic)) table)

-- like astTypeFresh but also returns the name→fresh-tyvar map (the same fresh
-- vars used in the Mono), so a caller can check post-unify whether each
-- annotation tyvar stayed a distinct unbound var (C3 AnnotationTooGeneral).
astTypeFreshTbl : Ty -> (Mono, List (String, Mono))
astTypeFreshTbl ty =
  let etbl = freshEffMap (dedup (effTailNames ty ++ rowArgNames ty))
  let tvs = freshTvMap (removeAllS (rowArgNames ty) (dedup (tyVarNames ty)))
  (fromAstTypeE etbl tvs ty, tvs)

freshTvMap : List String -> List (String, Mono)
freshTvMap [] = []
freshTvMap (n::rest) = (n, freshVar ()) :: freshTvMap rest

-- a signature → a scheme quantifying its free tyvars
sigToScheme : Ty -> Scheme
sigToScheme ty = fst (sigToSchemeTvs ty)

-- like sigToScheme but also returns the name→tyvar map it built, so a caller can
-- recover the id of a specific constraint variable (methodConstraintsRef) — the
-- SAME quantified ids the returned scheme carries, so a call-site instantiation's
-- subst maps them.
sigToSchemeTvs : Ty -> (Scheme, List (String, Mono))
sigToSchemeTvs ty =
  let tvs = freshTvMap (removeAllS (rowArgNames ty) (tyVarNamesWithConstraints ty))
  let etbl = freshEffMap (dedup (effTailNames ty ++ rowArgNames ty))
  (
    Forall (map monoTyvarId (map snd tvs)) (map effvarIdOf etbl) (fromAstTypeE etbl tvs ty),
    tvs,
  )

-- tvs maps a declared type-parameter name to its tyvar
-- named effect-tail variables in a signature (`<IO | e>` → ["e"]); the same
-- source name must share one effvar across the whole signature, linking a HOF's
-- callback effect to its result effect
effTailNames : Ty -> List String
effTailNames (TyVar _) = []
effTailNames (TyCon _ _) = []
effTailNames (TyApp a b) = effTailNames a ++ effTailNames b
effTailNames (TyFun a b) = effTailNames a ++ effTailNames b
effTailNames (TyTuple ts) = flatMap effTailNames ts
effTailNames (TyEffect _ tail t) = tailNameList tail ++ effTailNames t
effTailNames (TyConstrained _ t) = effTailNames t

tailNameList : Option String -> List String
tailNameList None = []
tailNameList (Some n) = [n]

freshEffMap : List String -> List (String, Ref Effvar)
freshEffMap [] = []
freshEffMap (n::rest) = (n, freshEffvar ()) :: freshEffMap rest

effvarIdOf : (String, Ref Effvar) -> Int
effvarIdOf (_, cell) = effvarId cell

-- build a row from an arrow's return-position AST type; a named tail resolves
-- through [etbl] for sharing, an absent/anonymous one is closed
astEffrowE : List (String, Ref Effvar) -> Ty -> EffRow
astEffrowE etbl (TyEffect labels tail _) =
  EffRow (atomsOfWritten labels) (tailCell etbl tail)
astEffrowE _ _ = pureRow

tailCell : List (String, Ref Effvar) -> Option String -> Option (Ref Effvar)
tailCell _ None = None
tailCell etbl (Some n) = lookupAssoc n etbl

fromAstType : List (String, Mono) -> Ty -> Mono
fromAstType tvs ty = fromAstTypeE [] tvs ty

-- un-curry a left-nested TyApp chain into (head, args).  `headTyconTy` only
-- returns the head; this also keeps the spine for kind-directed elaboration.
tyAppSpine : Ty -> (Ty, List Ty)
tyAppSpine (TyApp a b) = match tyAppSpine a
  (head, args) => (head, args ++ [b])
tyAppSpine t = (t, [])

fromAstTypeE : List (String, Ref Effvar) -> List (String, Mono) -> Ty -> Mono
fromAstTypeE etbl tvs (TyCon n _) = match lookupAssoc n aliasTableRef.value
  -- Transparent non-parameterized alias (`type Foo = Int`): expand to its RHS,
  -- recursively so alias-of-alias (`type A = Int; type B = A`) flattens.  Cycle
  -- rejection is deferred (stage 4); the non-cyclic corpus terminates.
  Some (params, rhs) if listLen params == 0 => fromAstTypeE etbl tvs rhs
  -- A parameterized alias used UNAPPLIED (`x : Pair`): a type alias is not a
  -- first-class type constructor (DESIGN §3/§9 fork 2), so it must be saturated.
  -- Reject with an arity error and keep the bare TCon so inference continues.
  Some (params, _) =>
    let _ = pushTypeErrorOnce "T-ALIAS-ARITY" (aliasArityMsg n (listLen params) 0)
    TCon n
  _ => TCon n
fromAstTypeE etbl tvs (TyVar n) = fromOption (TCon n) (lookupAssoc n tvs)
fromAstTypeE etbl tvs (TyApp a b) = match tyAppSpine (TyApp a b)
  (TyCon n _, args) => fromAstTypeApp etbl tvs n args
  _ => TApp (fromAstTypeE etbl tvs a) (fromAstTypeE etbl tvs b)
fromAstTypeE etbl tvs (TyFun a b) =
  TFun
    (fromAstTypeE etbl tvs a)
    (astEffrowE etbl b)
    (fromAstTypeE etbl tvs (stripEff b))
fromAstTypeE etbl tvs (TyTuple ts) = tupleMono (map (fromAstTypeE etbl tvs) ts)
fromAstTypeE etbl tvs (TyEffect _ _ t) = fromAstTypeE etbl tvs t
fromAstTypeE etbl tvs (TyConstrained _ t) = fromAstTypeE etbl tvs t

-- A type alias applied to the wrong number of arguments — over-applied,
-- under-applied, or (got=0) used unapplied.  v1 requires a parameterized alias
-- to be saturated; an alias is not a first-class type constructor (DESIGN §3/§9
-- fork 2).  Deduped (pushTypeErrorOnce) since a signature's `Ty` is converted to
-- `Mono` repeatedly during inference.
aliasArityMsg : String -> Int -> Int -> String
aliasArityMsg n expected got = "Type alias `\{n}` expects \{intToString expected} argument(s), got \{intToString got}"

-- the opaque fall-through for a TyCon-headed spine: keep the head as a bare
-- `TCon n` and apply the (alias-expanded) argument Monos left-nested.  This is
-- byte-identical to the legacy `TApp (fromAstTypeE a) (fromAstTypeE b)` recursion
-- for a non-alias head, but it does NOT re-dispatch the head through
-- `fromAstTypeE` — critical now that the head being an *alias* has side-effects
-- (the unapplied-alias arity error), and Medaka is strict so a pre-built fallback
-- would fire that error even on the expansion path.
appFallback : List (String, Ref Effvar) -> List (String, Mono) -> String -> List Ty -> Mono
appFallback _ _ n [] = TCon n
appFallback etbl tvs n (a::as2) =
  foldAppFallback etbl tvs (TApp (TCon n) (fromAstTypeE etbl tvs a)) as2

foldAppFallback : List (String, Ref Effvar) -> List (String, Mono) -> Mono -> List Ty -> Mono
foldAppFallback _ _ acc [] = acc
foldAppFallback etbl tvs acc (a::as2) =
  foldAppFallback etbl tvs (TApp acc (fromAstTypeE etbl tvs a)) as2

-- a TyCon-headed type-app: a parameterized type-ALIAS head is expanded by binding
-- its params to the supplied argument Monos and recursing on the RHS (transparent,
-- transitive — an alias RHS that names another alias re-expands).  Otherwise: when
-- the head is a data type with a KRow param, refold the spine kind-directed (KRow
-- arg → TEff row); else the opaque `appFallback`.
fromAstTypeApp : List (String, Ref Effvar) -> List (String, Mono) -> String -> List Ty -> Mono
fromAstTypeApp etbl tvs n args = match lookupAssoc n aliasTableRef.value
  -- Saturated parameterized alias: bind params → arg Monos (alias params shadow
  -- outer tvs of the same name) and expand the RHS through the same seam.
  Some (params, rhs) if listLen params == listLen args =>
    fromAstTypeE etbl (zipL params (map (fromAstTypeE etbl tvs) args) ++ tvs) rhs
  -- Alias applied to the wrong arity: reject, keep the opaque fallback.
  Some (params, _) =>
    let _ = pushTypeErrorOnce "T-ALIAS-ARITY" (aliasArityMsg n (listLen params) (listLen args))
    appFallback etbl tvs n args
  _ => match lookupAssoc n dataParamKindsRef.value
    Some kinds if listLen kinds == listLen args =>
      foldAppKinds etbl tvs (TCon n) kinds args
    _ => appFallback etbl tvs n args

-- refold a kinded type-app spine: a KType arg recurses, a KRow arg becomes a
-- TEff row (resolved through the shared etbl, so it aliases the field/sig tail).
foldAppKinds : List (String, Ref Effvar) -> List (String, Mono) -> Mono -> List Kind -> List Ty -> Mono
foldAppKinds _ _ acc [] [] = acc
foldAppKinds etbl tvs acc (k::ks) (a::as2) =
  foldAppKinds etbl tvs (TApp acc (kindArgMono etbl tvs k a)) ks as2
foldAppKinds _ _ acc _ _ = acc

kindArgMono : List (String, Ref Effvar) -> List (String, Mono) -> Kind -> Ty -> Mono
kindArgMono etbl tvs KType arg = fromAstTypeE etbl tvs arg
kindArgMono etbl tvs KRow arg = TEff (rowArgOf etbl arg)

-- a row sitting in a KRow type-app slot: a bare name resolves through the shared
-- etbl (seeded by the caller so the cell aliases the field/sig tail); an explicit
-- `<…>` builds directly; anything else is the pure closed row.
rowArgOf : List (String, Ref Effvar) -> Ty -> EffRow
rowArgOf etbl (TyVar n) = match lookupAssoc n etbl
  Some cell => EffRow [] (Some cell)
  None => pureRow
rowArgOf etbl (TyEffect labels tail _) =
  EffRow (atomsOfWritten labels) (tailCell etbl tail)
rowArgOf _ _ = pureRow

-- names a type uses in a KRow type-app argument slot (so a caller can seed them
-- into an etbl with shared effvars before elaborating).  Walks the whole type.
rowArgNames : Ty -> List String
rowArgNames (TyApp a b) = match tyAppSpine (TyApp a b)
  (TyCon n _, args) => rowArgNamesApp n args (rowArgNames a ++ rowArgNames b)
  _ => rowArgNames a ++ rowArgNames b
rowArgNames (TyFun a b) = rowArgNames a ++ rowArgNames b
rowArgNames (TyTuple ts) = flatMap rowArgNames ts
rowArgNames (TyEffect _ _ t) = rowArgNames t
rowArgNames (TyConstrained _ t) = rowArgNames t
rowArgNames _ = []

rowArgNamesApp : String -> List Ty -> List String -> List String
rowArgNamesApp n args fallback = match lookupAssoc n dataParamKindsRef.value
  Some kinds if listLen kinds == listLen args => krowArgVarNames kinds args
    ++ flatMap rowArgNames args
  _ => fallback

krowArgVarNames : List Kind -> List Ty -> List String
krowArgVarNames [] _ = []
krowArgVarNames _ [] = []
krowArgVarNames (KRow::ks) ((TyVar n)::as2) = n :: krowArgVarNames ks as2
krowArgVarNames (_::ks) (_::as2) = krowArgVarNames ks as2

-- ── environment ───────────────────────────────────────────────────────────
-- The type environment uses the shared `OrdMap` (support.ordmap): a persistent
-- String-keyed weight-balanced tree.  The env is looked up on EVERY variable
-- occurrence and carries the whole prelude + every imported module's public
-- bindings, so an assoc-list env made inference O(n^2); OrdMap gives O(log n)
-- lookup and structure-sharing inserts (the branching/backtracking inference env
-- stays valid).  Insert OVERWRITES on equal keys, matching the old assoc-list
-- "newest binding shadows older" semantics (prepend + first-match).
-- alphaLets (3rd field, EFFECTS WS-2 / E3 precision): same-function-body
-- `let`-bound (name, rhs) pairs in scope, seeded into α's known-prefix analysis
-- so an outer-body `let dest = "idp.example.com/page"` then `fetch dest` recovers
-- the literal prefix instead of collapsing to ⊤.  Intraprocedural ONLY —
-- accumulated as infer descends ELet/ELetGroup/block lets (PVar / single-clause
-- zero-arg only, mirroring α's own binding rule); read at the fill site via α's
-- initial `lets`.  A literal laundered through a helper stays ⊤ (spec §5
-- non-goal).  Sound: only turns over-rejections into acceptances.  (Mirror of
-- lib/typecheck.ml's env.alpha_lets.)
public export data TcEnv =
  | TcEnv (OrdMap Scheme) (OrdMap Scheme) (List (String, Expr))  -- vars, ctors, alphaLets

lookupVar : TcEnv -> String -> Option Scheme
lookupVar (TcEnv vs cs _) n = match omLookup n vs
  Some s => Some s
  None => omLookup n cs

lookupCtor : TcEnv -> String -> Option Scheme
lookupCtor (TcEnv _ cs _) n = omLookup n cs

extendVar : TcEnv -> String -> Scheme -> TcEnv
extendVar (TcEnv vs cs al) n s = TcEnv (omInsert n s vs) cs al

extendVars : TcEnv -> List (String, Scheme) -> TcEnv
extendVars env [] = env
extendVars env ((n, s)::rest) = extendVars (extendVar env n s) rest

addCtor : TcEnv -> String -> Scheme -> TcEnv
addCtor (TcEnv vs cs al) n s = TcEnv vs (omInsert n s cs) al

-- EFFECTS WS-2: seed α's known-prefix scope with a same-function-body let RHS.
-- Prepended (most-recent-first) to mirror α's own `(x,e1)::lets` accumulation.
seedAlphaLets : TcEnv -> String -> Expr -> TcEnv
seedAlphaLets (TcEnv vs cs al) n rhs = TcEnv vs cs ((n, rhs)::al)

-- read the accumulated α-let scope (for the hole-fill site)
envAlphaLets : TcEnv -> List (String, Expr)
envAlphaLets (TcEnv _ _ al) = al

monoScheme : Mono -> Scheme
monoScheme t = Forall [] [] t

-- ── pattern inference: returns the pattern's type + the bindings it adds ───
inferPat : TcEnv -> Pat -> (Mono, List (String, Scheme))
inferPat _ (PVar x) =
  let v = freshVar ()
  let _ = recordLocalBind x v
  (v, [(x, monoScheme v)])
inferPat _ PWild = (freshVar (), [])
inferPat _ (PLit l) = (litType l, [])
inferPat env (PCon name pats) = inferPatCon env name pats
inferPat env (PTuple pats) = inferPatTuple env pats
inferPat env (PCons h t) = inferPatCons env h t
inferPat env (PList pats) = inferPatList env pats
inferPat env (PAs x p) = inferPatAs env x p
inferPat env (PRec name fields _) = inferPatRec env name fields
inferPat _ (PRng lo hi _) = inferPatRng lo hi
inferPat _ _ = panic "typecheck: unsupported pattern (slice 1)"

-- range pattern `lo..hi` / `lo..=hi`: only Int and Char bounds are valid
-- (mirrors lib/typecheck.ml PRng arm); binds no variables
inferPatRng : Lit -> Lit -> (Mono, List (String, Scheme))
inferPatRng (LInt _) (LInt _) = (TCon "Int", [])
inferPatRng (LChar _) (LChar _) = (TCon "Char", [])
inferPatRng lo hi =
  let _ = pushTypeError "T-TYPE-MISMATCH" "Type mismatch: \{ppMono (litType lo)} vs \{ppMono (litType hi)}"
  (TCon "Int", [])

inferPatRec : TcEnv -> String -> List RecPatField -> (Mono, List (String, Scheme))
inferPatRec env name fields = match lookupRecordByName name
  None =>
    let _ = pushTypeError "T-UNKNOWN-RECORD" (unknownRecordMsg name)
    (freshVar (), bindRecPatFieldsFresh env fields)
  Some ri => inferPatRecWith env name ri fields
-- bind the field pattern vars with fresh types (no field-type info) so the
-- arm body still typechecks; the oracle fails fast on the unknown record, we
-- accumulate, so dropping the bindings would raise spurious unbound-var errors

-- bind a record pattern's fields against fresh types, NO unknown-field check
-- (the record itself is already-reported unknown; see inferPatRec error path)
bindRecPatFieldsFresh : TcEnv -> List RecPatField -> List (String, Scheme)
bindRecPatFieldsFresh _ [] = []
bindRecPatFieldsFresh env ((RecPatField fname mp)::rest) = inferRecPatFieldWith env (freshVar ()) fname mp
  ++ bindRecPatFieldsFresh env rest

inferPatRecWith : TcEnv -> String -> RecordInfo -> List RecPatField -> (Mono, List (String, Scheme))
inferPatRecWith env rname ri fields =
  let ir = instantiateRecord ri
  (fst ir, inferRecPatFields env rname (snd ir) fields)

inferRecPatFields : TcEnv -> String -> List (String, Mono) -> List RecPatField -> List (String, Scheme)
inferRecPatFields _ _ _ [] = []
inferRecPatFields env rname fieldTypes ((RecPatField fname mp)::rest) = inferRecPatField env rname fieldTypes fname mp
  ++ inferRecPatFields env rname fieldTypes rest

inferRecPatField : TcEnv -> String -> List (String, Mono) -> String -> Option Pat -> List (String, Scheme)
inferRecPatField env rname fieldTypes fname mp = match lookupAssoc fname fieldTypes
  None =>
    let _ = pushTypeError "T-UNKNOWN-FIELD" (unknownFieldMsg fname rname)
    inferRecPatFieldWith env (freshVar ()) fname mp
  Some ft => inferRecPatFieldWith env ft fname mp
-- bind the field's pattern vars against a fresh type so the arm body still
-- typechecks (the oracle fails fast on the unknown field; we accumulate, so
-- skipping the binding would raise spurious downstream unbound-variable errors)

inferRecPatFieldWith : TcEnv -> Mono -> String -> Option Pat -> List (String, Scheme)
inferRecPatFieldWith _ ft fname None = [(fname, monoScheme ft)]
inferRecPatFieldWith env ft _ (Some p) =
  let pr = inferPat env p
  let _ = unify (fst pr) ft
  snd pr

litType : Lit -> Mono
litType (LInt _) = TCon "Int"
litType (LFloat _) = TCon "Float"
litType (LString _) = TCon "String"
litType (LChar _) = TCon "Char"
litType (LBool _) = TCon "Bool"
litType LUnit = TCon "Unit"

inferPatCon : TcEnv -> String -> List Pat -> (Mono, List (String, Scheme))
inferPatCon env name pats = match lookupCtor env name
  None =>
    let _ = pushTypeError "T-UNKNOWN-CTOR" (unknownCtorMsg name)
    let pr = inferPats env pats
    (freshVar (), snd pr)
  Some scheme => inferPatConWith env scheme pats
-- still infer the sub-patterns so their bindings reach the arm body
-- (else the continued path raises spurious unbound-variable errors the
-- oracle never reaches — it fails fast on the unknown constructor)

inferPatConWith : TcEnv -> Scheme -> List Pat -> (Mono, List (String, Scheme))
inferPatConWith env scheme pats =
  let ctorType = instantiate scheme
  let pr = inferPats env pats
  let resultVar = freshVar ()
  let _ = unify ctorType (foldrFun (fst pr) resultVar)
  (resultVar, snd pr)

inferPats : TcEnv -> List Pat -> (List Mono, List (String, Scheme))
inferPats _ [] = ([], [])
inferPats env (p::ps) =
  let pr = inferPat env p
  let rest = inferPats env ps
  (fst pr :: fst rest, snd pr ++ snd rest)

foldrFun : List Mono -> Mono -> Mono
foldrFun [] result = result
foldrFun (a::rest) result = TFun a pureRow (foldrFun rest result)

inferPatTuple : TcEnv -> List Pat -> (Mono, List (String, Scheme))
inferPatTuple env pats =
  let pr = inferPats env pats
  (tupleMono (fst pr), snd pr)

inferPatCons : TcEnv -> Pat -> Pat -> (Mono, List (String, Scheme))
inferPatCons env h t =
  let hr = inferPat env h
  let tr = inferPat env t
  let listTy = TApp (TCon "List") (fst hr)
  let _ = unify (fst tr) listTy
  (listTy, snd hr ++ snd tr)

inferPatList : TcEnv -> List Pat -> (Mono, List (String, Scheme))
inferPatList env pats =
  let elem = freshVar ()
  let pr = inferPats env pats
  let _ = unifyAll elem (fst pr)
  (TApp (TCon "List") elem, snd pr)

inferPatAs : TcEnv -> String -> Pat -> (Mono, List (String, Scheme))
inferPatAs env x p =
  let pr = inferPat env p
  let _ = recordLocalBind x (fst pr)
  (fst pr, (x, monoScheme (fst pr)) :: snd pr)

unifyAll : Mono -> List Mono -> Unit
unifyAll _ [] = ()
unifyAll t (x::xs) =
  let _ = unify t x
  unifyAll t xs

-- ── expression inference ──────────────────────────────────────────────────
infer : TcEnv -> Expr -> Mono
infer _ (ELit l) = litType l
-- PLAN.md #11: a source integer literal is `Num a` for a fresh `a`.  With the
-- prelude loaded (Num registered + `fromInt` in scope), model the literal exactly
-- as `fromInt n` — mirror of lib/typecheck.ml's e7031e6 ENumLit arm.  inferMethodAt
-- "fromInt" records the Num impl obligation AND a pendingSite keyed on [dref] (the
-- node's route cell), so resolveSites later stamps [dref]: RKey when the literal's
-- type grounds to a concrete Num head, RDictFwd onto the enclosing `Num a` dict when
-- it stays polymorphic (the soundness case, `1` in `inc x = x + 1` — exactly the
-- route `fromInt 0` in `sum` gets).  Apply the `Int -> a` method type to an Int arg
-- (mirror OCaml's `unify from_int_ty (TFun t_int … a)`) to recover the result var
-- [a], and stash (a, fref, n, dref) in numlitRefs so the post-HM setNumlitFloats can
-- decide concrete-Float / concrete-Int / still-poly.  Recording the obligation here
-- AND (when under `+`) in numArithOp is harmless: both unify the same var, both
-- demand `Num`.  Without the prelude (bare-HM oracle, `ifaceRegistered` False)
-- `fromInt` is unbound: fall back to a plain fresh var, dref stays RNone (⇒ Int).
infer env (ENumLit n fref dref) = inferNumLit env n fref dref
infer env (EVar x) = inferVar env x
infer env (EApp f x) = inferAppExpr env f x
infer env (ELam pats body) = inferLam env pats body
infer env (ELet isMut isFun pat e1 e2) = inferLet env isMut isFun pat e1 e2
infer env (ELetGroup binds body) = inferLetGroup env binds body
infer env (EIf c t e) = inferIf env c t e
infer env (EMatch scrut arms) = inferMatch env (infer env scrut) arms
infer env (ETuple es) = tupleMono (inferEach env es)
infer env (EListLit es) = inferListLit env es
infer env (EAnnot e ty) = inferAnnot env e ty
infer env (EBinOp op l r dref) = inferBinopE env op l r dref
infer env (EUnOp op e dref) = inferUnopE env op e dref
infer env (EInfix op l r) = inferInfix env op l r
infer env (ERecordCreate name fields) = inferRecordCreate env name fields
infer env (EFieldAccess e fname r) = inferFieldAccess env e fname r
infer env (ERecordUpdate base fields r) = inferRecordUpdate env base fields r
infer env (EVariantUpdate cname base fields) =
  inferVariantUpdate env cname base fields
infer env (EBlock stmts) = inferBlock env stmts
infer env (EMethodAt name tagRef implRef methodRef) =
  inferMethodAt env name tagRef implRef methodRef
infer env (EDictAt name routesRef) = inferDictAt env name routesRef
infer env (EArrayLit es) = inferArrayLit env es
infer env (ERangeList lo hi _) = inferIntRange env lo hi (TCon "List")
infer env (ERangeArray lo hi _) = inferIntRange env lo hi (TCon "Array")
-- EIndex is desugared to an `index` method call before typecheck (Phase #16b);
-- the built-in index-inference path is retired, so no `EIndex` arm here.
infer env (ESlice arr lo hi _ r) = inferSlice env arr lo hi r
infer env (EHeadAnnot e ty) = inferHeadAnnot env e ty
-- ELoc is transparent: capture the span in `currentLoc` (so any type error
-- recorded while inferring the wrapped expr is attributable to this position,
-- mirror of lib/typecheck.ml's ELoc arm), then infer the inner expr.
infer env (ELoc l e) =
  let _ = setRef currentLoc (Some l)
  infer env e
-- Phase 150: a do-lowered chain.  Record the do-block loc so a monad-shape
-- mismatch during inference is retargeted to the tailored "do requires a monad"
-- error (see typeMismatch); clear it afterwards so sibling code isn't mis-blamed.
infer env (EDoOrigin l e) =
  let _ = setRef currentDoOrigin (Some l)
  let t = infer env e
  let _ = setRef currentDoOrigin None
  t
infer _ _ = panic "typecheck: unsupported expression (slice 1)"

inferArrayLit : TcEnv -> List Expr -> Mono
inferArrayLit env es =
  let elem = freshVar ()
  let _ = unifyAll elem (inferEach env es)
  TApp (TCon "Array") elem

-- [lo..hi] : List Int, [|lo..hi|] : Array Int
inferIntRange : TcEnv -> Expr -> Expr -> Mono -> Mono
inferIntRange env lo hi container =
  let _ = unify (infer env lo) (TCon "Int")
  let _ = unify (infer env hi) (TCon "Int")
  TApp container (TCon "Int")

-- receiver-kind discriminator stamped onto the ESlice Ref: lowering routes
-- "String" to CStringSlice; "List"/"Array" stay on the array path.
indexKind : Mono -> String
indexKind (TCon "String") = "String"
indexKind (TApp (TCon "List") _) = "List"
indexKind _ = "Array"

-- a.[lo..hi] : same container type as a
inferSlice : TcEnv -> Expr -> Expr -> Expr -> Ref String -> Mono
inferSlice env arr lo hi r =
  let _ = unify (infer env lo) (TCon "Int")
  let _ = unify (infer env hi) (TCon "Int")
  let at = infer env arr
  let _ = setRef r (indexKind (normalize at))
  at

-- a method occurrence.  Return-position: record (routeRef, result mono) so
-- resolveSites can stamp RKey/RDict.  D3a arg-position (emitArgStampPasses + name in
-- argDispatchIdxRef): the dispatch is decided by the DISCRIMINATING-ARGUMENT type,
-- not the result, so queue recordArgStamp on the arg-position mono instead — it is
-- NOT a pendingSites/methodSiteFns return-position site.
inferMethodAt : TcEnv -> String -> Ref Route -> Ref (List Route) -> Ref (List Route) -> Mono
inferMethodAt env name tagRef implRef methodRef = match lookupVar env name
  None => panic ("unbound method: " ++ name)
  Some s =>
    let inst = instantiateTracked s
    let _ = recordMethodDicts name methodRef (snd inst)
    let _ = recordImplObligation name (fst inst)
    let _ = recordRLocalSite env name tagRef (fst inst)
    let ret = match argDispatchOf name
      Some idx =>
        let _ = recordArgStamp name tagRef implRef idx (fst inst)
        let _ = recordArgSiteFn name idx (fst inst)
        fst inst
      None => recordSite name tagRef implRef (fst inst)
    -- P0-19 d4b (S4): a bare value-position definer shadow (`map size xs`, marked to
    -- `EMethodAt`) denotes the STANDALONE — return its declared scheme type so the type
    -- mismatches live-impl elements (Box vs Int) instead of dispatching, while the route
    -- side-effects above still stamp RLocal (ungrounded receiver) so `map size [1,2,3]`
    -- runs the standalone.  Inert for an application head (shadowHeadCtxRef True).
    match maybeStandaloneValueMono name
      Some m => m
      None => ret
-- C5: if [name] is a standalone-shadow method, record its discriminating-arg
-- mono cell UNGATED so resolveRLocalSites can route RLocal when the receiver
-- grounds to a no-impl head (the arg-stamp path would otherwise leave it RNone
-- → arg-tag panic on a receiver with no impl).

-- Cause-A prerequisite: ALSO record the discriminating-arg mono into
-- methodSiteFns keyed by currentFn (mirroring recordSite, which only fires
-- for return-position).  Without this, an unsignatured fn whose body
-- dispatches a method in ARGUMENT position (`f s = display s`) never
-- surfaces its inferred constraint to inferredConstraintIds → never gets
-- promoted → no leading dict param on the build path → dict word 0 (SIGSEGV/
-- silent).  Inert unless promotion (discoverPromotedModules) consumes it.

-- C5: queue a standalone-shadow method occurrence's discriminating-arg mono cell so
-- resolveRLocalSites can stamp RLocal once inference grounds the receiver.  Only
-- shadows (standaloneValuesRef) are recorded — every other method occurrence is
-- untouched (no entry → byte-identical).  The dispatch index comes from the method's
-- declared interface type (methodDispatchIdx), independent of emitArgStampPasses.
-- S-1: this is the GENERAL shadow-occurrence recorder, and it is the path that a
-- VALUE-position shadow (`map size [1,2,3]`) and an IMPORTER shadow on an UNGROUNDED
-- receiver (`size 3`, where the Num literal is not yet grounded so inferShadowApp's
-- standalone arm is never reached) both take.  Both must carry the standalone's dicts or
-- they under-apply exactly like the headline bug.  Slots only — NOT obligations; see
-- shadowStandaloneDictSlotsAt.
recordRLocalSite : TcEnv -> String -> Ref Route -> Mono -> Unit
recordRLocalSite env name tagRef inst
  | suppressRLocalRecord.value = ()
  | not (contains name standaloneValuesRef.value) = ()
  | otherwise = match methodDispatchIdx name
    None => ()
    Some idx => match nthArgMono idx inst
      Some am =>
        let sym = routeLocalSym tagRef.value
        let dicts = shadowStandaloneDictSlotsAt (standaloneSchemeFor env name sym) (if sym == "" then name else sym) am
        setRef
          pendingRLocalSites
          (RLocalSite name tagRef am sym False (fst dicts) (snd dicts) :: pendingRLocalSites.value)
      None => ()

-- the SHADOWING STANDALONE's scheme.  An IMPORTER shadow's bare name is rebound by env1
-- to the interface-METHOD scheme, so it must come from shadowStandaloneSchemesRef; a
-- DEFINER shadow's comes from the env (under the mangled symbol on the emit path).
standaloneSchemeFor : TcEnv -> String -> String -> Option Scheme
standaloneSchemeFor env name sym = match lookupAssoc name shadowStandaloneSchemesRef.value
  Some s => Some s
  None => lookupVar env (if sym == "" then name else sym)

-- C5: the dispatch-arg index of an interface method, from the graph-wide map
-- methodDispatchIdxRef (built by checkModuleFullImpl from every interface decl).
-- Ungated, unlike argDispatchOf — RLocal detection must run on the eval path too.
methodDispatchIdx : String -> Option Int
methodDispatchIdx name = lookupAssoc name methodDispatchIdxRef.value

-- the dispatch-arg index of an arg-position method, but only when stamping is
-- enabled (the emit path) — off, every EMethodAt is a return-position site.
argDispatchOf : String -> Option Int
argDispatchOf name = lookupAssoc name argDispatchIdxRef.value

-- Phase 69.x-e: if [name] is a method with method-level constraints (foldMap's
-- `Monoid m`), map each constraint's scheme id through this occurrence's
-- instantiation subst to its concrete mono and record the (methodRef, monos) so
-- resolveMethodDicts can route them after inference.  A method with no method-level
-- constraint records nothing — methodRef stays [], eval's fold is a no-op.
recordMethodDicts : String -> Ref (List Route) -> List (Int, Mono) -> Unit
recordMethodDicts name methodRef subst = match alignedMethodConstraintIds name subst
  None => ()
  Some ids => setRef pendingMethodDicts ((methodRef, constraintMonosOf ids subst)::pendingMethodDicts.value)

-- D2: the constraint-slot ids of method [name] that line up with THIS occurrence's
-- instantiation [subst].  methodConstraintsRef can hold MULTIPLE entries for one
-- (uniquely-named) method, each registered with its own FRESH ids by a different
-- elaborate sweep (discoverPromotedModules' discovery sweep, then the real
-- elabModulesGo sweep) — crossModuleMethodConstraintsRef accumulates them across
-- sweeps and is not re-keyed before recordMethodDicts reads it.  A plain bare-name
-- first-match (lookupAssocSL2) returns whichever entry is frontmost, which after the
-- discovery sweep is a STALE entry whose ids belong to a dead id range, disjoint from
-- the live [subst] keys → constraintMonosOf drops them all → empty route → the
-- cross-module method-level dict is never threaded ("no matching impl" at run /
-- SIGSEGV at build).  The LIVE entry is the one the call's instantiateTracked actually
-- quantified — i.e. whose ids are keys of [subst].  Pick the entry with the most ids
-- present in [subst] (>0); fall back to bare first-match when none overlap (preserves
-- the single-entry / no-instantiation goldens byte-for-byte).  Diamond-safe: a method
-- re-exported through an intermediate keeps the ORIGINAL definer's scheme ids (seedVars
-- threads the scheme object verbatim), so its [subst] keys match the original entry,
-- which alignment selects regardless of intermediate sweeps.
alignedMethodConstraintIds : String -> List (Int, Mono) -> Option (List Int)
alignedMethodConstraintIds name subst = match positionMatch name subst methodConstraintPositionsRef.value
  Some ids => Some ids
  None =>
    let entries = filterList (e => fst e == name) methodConstraintsRef.value
    match entries
      [] => None
      _ => match bestAlignedEntry subst entries (0 - 1) None
        Some ids => Some ids
        None => lookupAssocSL2 name methodConstraintsRef.value

-- The DEFINITIVE slot ids for THIS occurrence: index the occurrence's ORDERED subst
-- (instantiateTracked keys subst by the scheme's own ids via freshSubst, preserving
-- var order) at the method's stable constraint-slot POSITIONS.  Allocation-
-- independent, so it picks the applicative `m` slot regardless of cross-sweep id
-- overlap (where a stale id maps to the container `t` — both Thenable).  None when
-- the method has no recorded positions, or a position is out of range (e.g. an empty
-- subst from a monomorphic recursive call) ⇒ caller falls back to countInSubst.
positionMatch : String -> List (Int, Mono) -> List (String, List Int) -> Option (List Int)
positionMatch name subst positionsTbl = match lookupAssocSL2 name positionsTbl
  None => None
  Some positions =>
    let keys = map fst subst
    let n = listLen keys
    if allInRange positions n then
      Some (map (p => nthInt p keys) positions)
    else
      None

allInRange : List Int -> Int -> Bool
allInRange [] _ = True
allInRange (p::rest) n = p >= 0 && p < n && allInRange rest n

nthInt : Int -> List Int -> Int
nthInt _ [] = 0 - 1
nthInt 0 (x::_) = x
nthInt i (_::xs) = nthInt (i - 1) xs

-- among [entries] (all the same-named method-constraint records), the ids of the one
-- with the most slots present in [subst]; None until a positive-overlap entry is seen.
bestAlignedEntry : List (Int, Mono) -> List (String, List Int) -> Int -> Option (List Int) -> Option (List Int)
bestAlignedEntry _ [] _ best = best
bestAlignedEntry subst ((_, ids)::rest) bestN best =
  let n = countInSubst ids subst
  if n > 0 && n > bestN then
    bestAlignedEntry subst rest n (Some ids)
  else
    bestAlignedEntry subst rest bestN best

countInSubst : List Int -> List (Int, Mono) -> Int
countInSubst [] _ = 0
countInSubst (id::rest) subst =
  (match lookupAssocI id subst
      Some _ => 1
      None => 0) +
    countInSubst rest subst

-- record a return-position method occurrence: resolveSite later stamps its route
-- (RKey/RDict) once inference grounds the result mono.
recordSite : String -> Ref Route -> Ref (List Route) -> Mono -> Mono
recordSite name tagRef implRef methodType =
  let stripped = stripArrows methodType
  let _ = setRef pendingSites ((name, tagRef, implRef, stripped, methodType, currentFn.value)::pendingSites.value)
  let _ = setRef methodSiteFns (consSiteFn currentFn.value stripped methodSiteFns.value)
  methodType

-- a constrained-function occurrence (`f` where `f : C a => …`): instantiate f's
-- scheme (the call's type), and record the routes ref + the instantiated
-- constraint monos so resolveDictApps can pick a dict route once the call's args
-- pin those monos.  funConstraintsRef[f] gives f's constraint tyvar ids, mapped
-- through the instantiation subst to this call's fresh vars.
inferDictAt : TcEnv -> String -> Ref (List Route) -> Mono
inferDictAt env name routesRef = match lookupVar env name
  None => panic ("unbound constrained fn: " ++ name)
  Some scheme => inferDictAtFound name routesRef (instantiateTracked scheme)

-- The callee's constraints are registered (funConstraintsRef has it) ⇒ a normal
-- call: map each constraint id through the instantiation subst to this call's
-- monos.  Absent ⇒ a self/mutually-recursive call (the callee is still inferring
-- in the same group); defer it for realizeRecDictApps to forward the enclosing
-- fn's dict.
-- A constrained callee in funConstraintsRef is reached two ways: (1) a NORMAL call
-- to an already-generalized fn — instantiateTracked pins each of its constraint ids
-- to a fresh occurrence var, so `snd inst` carries them; route via pendingDictApps.
-- (2) a SELF/MUTUALLY-RECURSIVE call — the callee is still the group's monomorphic
-- PLACEHOLDER (Forall [] [] v), so `snd inst` is empty (none of [ids] appear).  Here
-- the constraint var lives in the ENCLOSING fn's own type and the callee's REGISTERED
-- ids only become valid after this pass's registerInferredConstraints re-registers
-- them; defer to realizeRecDictApps (which forwards the enclosing dict).  We MUST NOT
-- take the normal branch here (as a stale cross-module funConstraintsRef seed makes us
-- do): constraintMonosOf maps the registered ids through the empty subst → [] → the
-- recursive call's route ref stays empty while dictPass still prepends the param → the
-- call under-applies → dispatch fails.  Detect (2) as "no registered id is pinned by
-- the instantiation subst" (mirrors the oracle's empty-`sub` self-recursion case).
-- WS-2/D2: a cross-module constrained callee's (dict ids, slot-parallel ifaces) by
-- MODULE IDENTITY.  When [name] is an EXPLICITLY-imported value (currentImportDefinersRef)
-- whose import SOURCE module owns a (source,name) entry in the qualified arity tables,
-- return that entry — the definer-keyed arity, immune to the bare-name most-recent-prepend
-- collision in the jointly-seeded funConstraintsRef.  None ⇒ local fn / wildcard import /
-- re-export / check path (mid ""): inferDictAtFound falls back to the bare funConstraintsRef
-- + funConstraintIfacesRef path (today's behavior; byte-identical when no collision, since
-- the qual entry is the same module's same ids the bare first-match returns sans collision).
qualConstraintFor : String -> Option (List Int, List String)
qualConstraintFor name = match lookupAssoc name currentImportDefinersRef.value
  None => None
  Some src => map (ids => (
    ids,
    fromOption [] (lookupQualIfaces src name crossModuleFunConstraintIfacesQualRef.value),
  )) (lookupQualArity src name crossModuleFunConstraintsQualRef.value)

lookupQualArity : String -> String -> List ((String, String), List Int) -> Option (List Int)
lookupQualArity _ _ [] = None
lookupQualArity src name (((m, n), v)::rest)
  | m == src && n == name = Some v
  | otherwise = lookupQualArity src name rest

lookupQualIfaces : String -> String -> List ((String, String), List String) -> Option (List String)
lookupQualIfaces _ _ [] = None
lookupQualIfaces src name (((m, n), v)::rest)
  | m == src && n == name = Some v
  | otherwise = lookupQualIfaces src name rest

-- WS-2/D2: a constrained callee's declared (constraint tyvar ids, iface names).  Prefer
-- the (import-source, name)-keyed QUAL table for a cross-module callee; fall back to the
-- bare-name funConstraintsRef first-match for local / wildcard / re-export.
-- S-1: shared with shadowStandaloneDictSlots — an IMPORTED constrained standalone that
-- shadows a method is exactly a cross-module callee, so it needs the SAME resolution.
-- Reading only the bare-name table there left the importer shadow's dicts EMPTY on `run`
-- (funConstraintsRef is reset per module and only re-seeded from the cross-module table
-- on the EMIT path), so `build` was right and `run` was wrong — the inverse skew.
declaredConstraintSlots : String -> (List Int, List String)
declaredConstraintSlots name = match qualConstraintFor name
  Some (ids, ifs) => (ids, ifs)
  None => (
    fromOption [] (lookupAssocSL2 name funConstraintsRef.value),
    fromOption [] (lookupAssocS name funConstraintIfacesRef.value),
  )

inferDictAtFound : String -> Ref (List Route) -> (Mono, List (Int, Mono)) -> Mono
inferDictAtFound name routesRef inst =
  let q = qualConstraintFor name
  let slots = declaredConstraintSlots name
  let declaredIds = fst slots
  let declaredIfaces = snd slots
  let known = match q
        Some _ => True
        None => hasKeySL2 name funConstraintsRef.value
  if known && anyIdPinned declaredIds (snd inst) then
    -- WS-1b: expand the callee's constraint slots with their transitive supers HERE
    -- (the global table isn't expanded until expandSupersTable runs after inference),
    -- so this call site applies one dict per EXPANDED slot — matching the def params
    -- dictArityOf/dictPass will prepend from the expanded table.  Each super slot's id
    -- equals its sub slot's id (shared type param), still pinned in [snd inst].
    let expanded = expandSupersPairs superDeclsRef.value (zipL declaredIfaces declaredIds)
    let ids = map snd expanded
    let monos = constraintMonosOf ids (snd inst)
    let ifaces = map fst expanded
    let _ = pushDictApp (routesRef, monos, ifaces)
    let _ = setRef dictAppFns (consSiteFn currentFn.value monos dictAppFns.value)
    -- #11 soundness: record this call's instantiated impl obligations (iface paired
    -- with the call's constraint mono), checked after inference by checkCallObligations.
    -- The iface list is slot-parallel to [monos]; a concrete-head mono with no impl
    -- (`Num String` from `f "hello"` where `f : Num a => a -> a`) becomes an error.
    let _ = recordCallObligations ifaces monos
    fst inst
  else
    let _ = setRef pendingRecDictApps (RecDictApp routesRef name currentFn.value (fst inst) :: pendingRecDictApps.value)
    fst inst

-- True iff at least one of [ids] (the callee's registered constraint tyvar ids) is
-- a key of the instantiation subst — i.e. instantiateTracked actually quantified it,
-- so this is a normal generalized call.  False ⇒ the callee is a monomorphic
-- placeholder (self/mutual recursion); subst can't carry its constraint occurrence.
anyIdPinned : List Int -> List (Int, Mono) -> Bool
anyIdPinned [] _ = False
anyIdPinned (id::rest) subst = match lookupAssocI id subst
  Some _ => True
  None => anyIdPinned rest subst

-- pair each iface with its slot-parallel instantiated constraint mono, pushing onto
-- pendingCallObligations.  Length-zips defensively (an iface list shorter than the
-- mono list — e.g. a multi-param constraint whose ifaces weren't recorded — just
-- stops, never over-rejecting).
recordCallObligations : List String -> List Mono -> Unit
recordCallObligations [] _ = ()
recordCallObligations _ [] = ()
recordCallObligations (iface::ifs) (mono::ms)
  | iface == "" = recordCallObligations ifs ms
  | otherwise =
    let _ = pushCallObl (iface, mono, currentLoc.value)
    recordCallObligations ifs ms

-- String-keyed assoc lookup over funConstraintIfacesRef (returns the iface name list).
lookupAssocS : String -> List (String, List String) -> Option (List String)
lookupAssocS _ [] = None
lookupAssocS k ((k2, v)::rest)
  | k == k2 = Some v
  | otherwise = lookupAssocS k rest

hasKeySL2 : String -> List (String, List Int) -> Bool
hasKeySL2 _ [] = False
hasKeySL2 k ((k2, _)::rest)
  | k == k2 = True
  | otherwise = hasKeySL2 k rest

-- instantiate a scheme, returning both the mono and the (quantified id → fresh
-- var) substitution, so a caller can recover specific quantified variables
instantiateTracked : Scheme -> (Mono, List (Int, Mono))
instantiateTracked (Forall ids evars t) =
  let subst = freshSubst ids
  (substMonoP True subst (freshEffSubst evars) t, subst)

constraintMonosOf : List Int -> List (Int, Mono) -> List Mono
constraintMonosOf [] _ = []
constraintMonosOf (id::rest) subst = match lookupAssocI id subst
  Some m => m :: constraintMonosOf rest subst
  None => constraintMonosOf rest subst

lookupAssocSL2 : String -> List (String, List Int) -> Option (List Int)
lookupAssocSL2 _ [] = None
lookupAssocSL2 k ((k2, v)::rest)
  | k == k2 = Some v
  | otherwise = lookupAssocSL2 k rest

-- ── WS-1b: superclass-evidence flatten (port of lib/typecheck.ml expand_supers) ──
-- A `=>`-constrained fn whose body calls a SUPERCLASS method (e.g. `build : Sub a =>`
-- calls `mk`, a Sup method, where `Sub a requires Sup a`) needs an honest super-dict
-- slot threaded through.  Inference registers only the DECLARED constraints in
-- funConstraintsRef/funConstraintIfacesRef; this pass APPENDS, per entry, one extra
-- slot for each (transitive) superinterface, mapping the super's decl param-names to
-- the constraint's instantiated tyvar ids positionally (`Sub a`/`Sup a` share `a`, so
-- the super id == the sub id).  Appended AFTER the declared slots so existing slot
-- indices are unchanged; deduped by (iface, id) within an entry.  Because the dict
-- VALUE is just a type tag (VDict "Widget"), the super slot's route is identical to
-- the sub slot's — no separate projection is needed; the slot just has to EXIST so the
-- call site applies a matching dict and the def binds a matching param.
--
-- Mutates the TABLE refs themselves at ONE finalization point (after inference, before
-- realizeRecDictApps/dictPass) so EVERY reader — define-side dictArityOf and call-side
-- recRoutes/recRoute/inferDictAtFound — sees identical expanded entries automatically.
-- Transitive: a fixpoint over the constraint set (the WS-4a acyclic-supers guard makes
-- it terminate), so `Top` reaches `Base` through `Mid` (chain3b).
expandSupersTable : List Decl -> Unit
expandSupersTable allDecls =
  let _ = setRef funConstraintsRef (map (expandSupersEntry allDecls funConstraintIfacesRef.value) funConstraintsRef.value)
  let _ = setRef funConstraintIfacesRef (map (expandSupersIfaceEntry allDecls) funConstraintIfacesRef.value)
  ()

-- as expandSupersTable but operates on the cross-module snapshot pair (so a
-- cross-module constrained fn gets the same expansion — else it under-fills).
expandSupersCross : List Decl -> List (String, List Int) -> List (String, List String) -> (List (String, List Int), List (String, List String))
expandSupersCross allDecls idsTbl ifacesTbl = (
  map (expandSupersEntry allDecls ifacesTbl) idsTbl,
  map (expandSupersIfaceEntry allDecls) ifacesTbl,
)

-- expand one (fn, ids) entry: the parallel iface list is looked up by fn name.
expandSupersEntry : List Decl -> List (String, List String) -> (String, List Int) -> (String, List Int)
expandSupersEntry allDecls ifacesTbl (fn, ids) =
  let ifaces = fromOption [] (lookupAssocS fn ifacesTbl)
  let pairs = expandSupersPairs allDecls (zipL ifaces ids)
  (fn, map snd pairs)

-- expand one (fn, ifaces) entry the SAME way, returning the parallel iface names.
expandSupersIfaceEntry : List Decl -> (String, List String) -> (String, List String)
expandSupersIfaceEntry allDecls (fn, ifaces) =
  let ids = idsForIfaceSlots ifaces
  let pairs = expandSupersPairs allDecls (zipL ifaces ids)
  (fn, map fst pairs)

-- a synthetic id list parallel to the iface list when only the iface entry is in
-- hand (the iface-entry expansion must produce the same iface SEQUENCE as the id
-- entry; positions, not values, must agree).  Uses slot index as the id so the
-- super-name substitution + dedup walk identically.  NOTE: this works because in a
-- `requires` chain every slot in one fn's expansion shares its declared tyvar — but
-- DISTINCT declared constraints get distinct synthetic ids, so two unrelated
-- constraints sharing a super still dedup correctly per chain.
idsForIfaceSlots : List String -> List Int
idsForIfaceSlots ifaces = idsForIfaceSlotsGo 0 ifaces

idsForIfaceSlotsGo : Int -> List String -> List Int
idsForIfaceSlotsGo _ [] = []
idsForIfaceSlotsGo i (_::rest) = i :: idsForIfaceSlotsGo (i + 1) rest

-- transitive super-closure over the declared (iface, id) slots: start from the
-- declared slots, repeatedly append direct supers of every current slot until no
-- new (iface, id) pair appears.  Result is the declared slots first (order/indices
-- preserved) then the appended supers, deduped by (iface, id).
expandSupersPairs : List Decl -> List (String, Int) -> List (String, Int)
expandSupersPairs allDecls declared = expandSupersFix allDecls declared declared

expandSupersFix : List Decl -> List (String, Int) -> List (String, Int) -> List (String, Int)
expandSupersFix allDecls acc frontier =
  let next = dedupPairs (acc ++ flatMap (superSlotsOf allDecls) frontier)
  if listLen next == listLen acc then
    acc
  else
    expandSupersFix allDecls next (dropPairs (listLen acc) next)

-- the direct super slots of one (iface, id) slot: look up iface's (typarams, supers);
-- the super-param NAMES index into typarams, which map positionally to [id] (a single
-- shared id since constraints in a `requires` chain are over the same type param).
superSlotsOf : List Decl -> (String, Int) -> List (String, Int)
superSlotsOf allDecls (iface, id)
  | not (contains iface userIfaceNamesRef.value) = []   -- WS-1b: only expand USER interface supers (prelude chains stay arg-tag)
  | otherwise = match ifaceSupersOf allDecls iface
    None => []
    Some (typarams, supers) =>
      let subst = zipL typarams (replicate (listLen typarams) id)
      flatMap (superSlotOf subst) supers

-- one `Super superName params`: map each param name through subst → its id; emit the
-- super slot only if ALL params resolved (matches the oracle's length guard).
superSlotOf : List (String, Int) -> Super -> List (String, Int)
superSlotOf subst (Super superName params) =
  let mapped = filterMaybeIds (map (p => lookupAssoc p subst) params)
  if listLen mapped == listLen params then
    (superName, firstOrZero mapped)::[]
  else
    []

-- every super slot in a `requires` chain carries the SAME id; represent the slot by it.
firstOrZero : List Int -> Int
firstOrZero [] = 0
firstOrZero (x::_) = x

filterMaybeIds : List (Option Int) -> List Int
filterMaybeIds [] = []
filterMaybeIds ((Some x)::rest) = x :: filterMaybeIds rest
filterMaybeIds (None::rest) = filterMaybeIds rest

dropPairs : Int -> List (String, Int) -> List (String, Int)
dropPairs n xs
  | n <= 0 = xs
  | otherwise = match xs
    [] => []
    _::rest => dropPairs (n - 1) rest

-- dedup (iface, id) pairs, keeping first occurrence (so declared slots stay leading).
dedupPairs : List (String, Int) -> List (String, Int)
dedupPairs xs = dedupPairsGo xs []

dedupPairsGo : List (String, Int) -> List (String, Int) -> List (String, Int)
dedupPairsGo [] _ = []
dedupPairsGo (p::rest) seen
  | anyList (q => fst q == fst p && snd q == snd p) seen =
    dedupPairsGo rest seen
  | otherwise = p :: dedupPairsGo rest (p::seen)

-- the type a method ultimately returns (strip its argument arrows); the impl is
-- chosen by this type's head tycon (pure : a -> f a → f a; empty : f a → f a)
stripArrows : Mono -> Mono
stripArrows (TFun _ _ b) = stripArrows b
stripArrows t = t

-- bare sequential block: value of the last statement; earlier statements typed
-- for effect; let/assign extend the env
inferBlock : TcEnv -> List DoStmt -> Mono
inferBlock _ [] = TCon "Unit"
inferBlock env [s] = inferLastStmt env s
inferBlock env (s::rest) = inferBlock (inferStmt env s) rest

inferLastStmt : TcEnv -> DoStmt -> Mono
inferLastStmt env (DoExpr e) = infer env e
inferLastStmt env s =
  let _ = inferStmt env s
  TCon "Unit"

inferStmt : TcEnv -> DoStmt -> TcEnv
inferStmt env (DoExpr e) =
  let _ = infer env e
  env
inferStmt env (DoLet _ True (PVar x) e) = blockRecLet env x e
inferStmt env (DoLet _ _ pat e) = blockLet env pat e
inferStmt env (DoAssign x e) = extendVar env x (monoScheme (infer env e))
-- A `<-` bind (DoBind) reaching a bare block is a user error: `<-` is
-- monadic-`do`-only, and a monadic `do` lowers to EDo (desugared before
-- typecheck), so only a bare-block `<-` arrives here.  Emit a clean LOCATED
-- error (symmetric with doRequiresMonadMsg) instead of panicking; infer the RHS
-- for effect (surfacing its own errors + snapshotting its ELoc span for the
-- caret) and bind the pattern's vars into env so downstream statements don't
-- cascade spurious `Unbound variable` errors (mirrors inferRecPatField).
inferStmt env (DoBind pat e) =
  let t = infer env e
  let _ = pushTypeError "T-BIND-OUTSIDE-DO" bindOutsideDoMsg
  let pr = inferPat env pat
  let _ = unify (fst pr) t
  extendVars env (snd pr)
inferStmt _ _ = panic "typecheck: unsupported block statement"

blockRecLet : TcEnv -> String -> Expr -> TcEnv
blockRecLet env x e =
  let _ = enterLevel ()
  let oblN0 = pendingImplObligationsN.value
  let placeholder = freshVar ()
  let envSelf = extendVar env x (monoScheme placeholder)
  let t1 = infer envSelf e
  let _ = unify placeholder t1
  let _ = exitLevel ()
  let addedObls = takeFirst (pendingImplObligationsN.value - oblN0) pendingImplObligations.value
  let _ = defaultAmbiguousNum addedObls t1  -- PLAN.md #11
  let _ = registerAmbiguousConstraints addedObls [t1]  -- RETPOS soundness
  let _ = recordLocalBind x t1  -- LSP hover (block rec-let bypasses inferPat)
  seedAlphaLets (extendVar env x (generalize t1)) x e  -- WS-2: α scope-seed

blockLet : TcEnv -> Pat -> Expr -> TcEnv
blockLet env (PVar x) e =
  let _ = enterLevel ()
  let oblN0 = pendingImplObligationsN.value
  let t = infer env e
  let _ = exitLevel ()
  let addedObls = takeFirst (pendingImplObligationsN.value - oblN0) pendingImplObligations.value
  let _ = defaultAmbiguousNum addedObls t   -- PLAN.md #11
  let _ = registerAmbiguousConstraints addedObls [t]   -- RETPOS soundness
  let _ = recordLocalBind x t   -- LSP hover (block let bypasses inferPat)
  -- WS-2: α scope-seed — bindings are immutable, so the prefix is stable.
  let env1 = extendVar env x (genRestricted (isNonexpansive e) t)
  seedAlphaLets env1 x e
blockLet env pat e =
  let t = infer env e
  let pr = inferPat env pat
  let _ = unify (fst pr) t
  extendVars env (snd pr)

inferRecordCreate : TcEnv -> String -> List FieldAssign -> Mono
inferRecordCreate env name fields = match lookupRecordByName name
  None => unknownRecordFresh name
  Some ri => inferRecordCreateWith env name ri fields

inferRecordCreateWith : TcEnv -> String -> RecordInfo -> List FieldAssign -> Mono
inferRecordCreateWith env rname ri fields =
  let ir = instantiateRecord ri
  let _ = checkMissingFields rname (snd ir) fields
  let _ = unifyFieldAssigns env rname (snd ir) fields
  fst ir

unifyFieldAssigns : TcEnv -> String -> List (String, Mono) -> List FieldAssign -> Unit
unifyFieldAssigns _ _ _ [] = ()
unifyFieldAssigns env rname fieldTypes ((FieldAssign fn val)::rest) =
  let _ = unifyFieldAssign env rname fieldTypes fn val
  unifyFieldAssigns env rname fieldTypes rest

unifyFieldAssign : TcEnv -> String -> List (String, Mono) -> String -> Expr -> Unit
unifyFieldAssign env rname fieldTypes fn val = match lookupAssoc fn fieldTypes
  None => pushTypeError "T-UNKNOWN-FIELD" (unknownFieldMsg fn rname)
  Some ft => unify (infer env val) ft

-- TYPECHECK-AUDIT OBS4: every declared field must be supplied in a record
-- construction (mirrors lib/typecheck.ml ERecordCreate "Every declared field
-- must be supplied" loop).  Walk `declaredFields`, check each name is present
-- among the supplied `FieldAssign` list; push MissingField for any absent one.
checkMissingFields : String -> List (String, Mono) -> List FieldAssign -> Unit
checkMissingFields _ [] _ = ()
checkMissingFields rname ((fname, _)::rest) supplied
  | fieldAssignContains fname supplied = checkMissingFields rname rest supplied
  | otherwise =
    let _ = pushTypeError "T-MISSING-FIELD" (missingFieldMsg fname rname)
    checkMissingFields rname rest supplied

fieldAssignContains : String -> List FieldAssign -> Bool
fieldAssignContains _ [] = False
fieldAssignContains fname ((FieldAssign fn _)::rest)
  | fname == fn = True
  | otherwise = fieldAssignContains fname rest

-- Phase 72 / TYPECHECK-AUDIT C2: receiver-directed field resolution.  Infer the
-- receiver FIRST, then pick the owning record by its head tycon when known; if
-- the receiver is still an unbound var and the field is owned by several
-- records, the access is ambiguous (mirrors lib/typecheck.ml's EFieldAccess +
-- field_owners multimap).  `value` keeps the Ref-projection special case (no
-- record in compiler/stdlib declares a `value` field, so this matches the
-- oracle's structural `(Ref a).value → a`).
inferFieldAccess : TcEnv -> Expr -> String -> Ref String -> Mono
inferFieldAccess env e fname r
  | fname == "value" = inferValueField env e
  | otherwise =
    let te = normalize (infer env e)
    match resolveFieldRecord te fname
      None => freshVar ()
      Some (rname, ri) =>
        let _ = setRef r rname
        inferFieldOfRecord te rname ri fname

-- `cell.value` projects a Ref's contents.  Unify the receiver with `Ref a`
-- (forcing it, like the reference's `(Ref a).value → a` special case) and return
-- `a` — done by unification, not a structural match, so it also works when the
-- receiver's type is still an unsolved tyvar at this point (the self-hosted
-- typecheck infers function params as fresh vars, not yet pinned to their sig).
inferValueField : TcEnv -> Expr -> Mono
inferValueField env e =
  let et = infer env e
  let inner = freshVar ()
  let _ = unify et (TApp (TCon "Ref") inner)
  inner

-- the field's type from a resolved record `rname`, given the (already-inferred)
-- receiver type `te` to unify against the record's instantiated result type.  A
-- field absent from a KNOWN record names it (mirrors the oracle's `resolve_in`,
-- which raises UnknownField with the resolved record name).
inferFieldOfRecord : Mono -> String -> RecordInfo -> String -> Mono
inferFieldOfRecord te rname ri fname =
  let ir = instantiateRecord ri
  let _ = unify te (fst ir)
  match lookupAssoc fname (snd ir)
    Some ft => ft
    None => unknownFieldFresh fname rname (map fst (snd ir))

-- field_owners (Phase 72): every registry KEY whose RecordInfo declares `fname`,
-- sorted + deduped (mirrors lib/typecheck.ml's `field_candidates` +
-- `List.sort_uniq compare`).  For a plain record the key is its type name; for a
-- named-field variant it's the constructor name — matching the oracle, whose
-- field_owners maps to the record's type name and the variant's con_name.
fieldOwnerNames : String -> List String
fieldOwnerNames fname = sortUniqS (fieldOwnerNamesGo fname recordsRef.value)

fieldOwnerNamesGo : String -> List (String, RecordInfo) -> List String
fieldOwnerNamesGo _ [] = []
fieldOwnerNamesGo fname ((key, ri)::rest)
  | recordHasField fname ri = key :: fieldOwnerNamesGo fname rest
  | otherwise = fieldOwnerNamesGo fname rest

-- Resolve the record (name + info) that owns `fname` for a receiver of type `te`
-- (normalized).
-- (a) receiver head tycon is a known record → that record;
-- (b) receiver is an undetermined var → 0 owners = unknown field, 1 = that one,
--     >1 = ambiguous (push AmbiguousField, return None);
-- (c) receiver is a concrete non-record → first owner (so the later unify raises
--     the usual mismatch), or unknown field if none.
-- On error it pushes the matching type error and returns None.
resolveFieldRecord : Mono -> String -> Option (String, RecordInfo)
resolveFieldRecord te fname = match headTyconMono te
  Some r => match lookupRecordByName r
    Some ri => Some (r, ri)
    None => match lookupRecordByMangledHead r fname
      Some pair => Some pair
      None => if contains r abstractRecordTypesRef.value then
        let _ = pushTypeError "T-ABSTRACT-FIELD" (abstractFieldMsg r fname)
        None
      else resolveFieldByOwners te fname
  None => resolveFieldByOwners te fname

-- Mangle-aware record lookup for the emit path.  `backend/private_mangle.mdk`
-- renames a record's DECL name (a record's name IS its constructor) to
-- `<mid>__<name>`, so `recordsRef` is keyed by the mangled name — but a TYPE
-- reference like `r : Rule` is NOT mangled, so the receiver's head tycon stays
-- `Rule` and the exact `lookupRecordByName` above misses.  Recover by finding the
-- registry entry whose key suffix-matches `__<head>` AND owns `fname`; only when
-- it is UNIQUE (else ambiguous → None, so the caller's owners path keeps today's
-- behavior).  No-op off the emit path (unmangled key hits the exact lookup).
lookupRecordByMangledHead : String -> String -> Option (String, RecordInfo)
lookupRecordByMangledHead head fname = match mangledHeadCandidates head fname recordsRef.value
  [pair] => Some pair
  _ => None

mangledHeadCandidates : String -> String -> List (String, RecordInfo) -> List (String, RecordInfo)
mangledHeadCandidates _ _ [] = []
mangledHeadCandidates head fname ((key, ri)::rest)
  | endsWith ("__" ++ head) key && recordHasField fname ri =
    (key, ri) :: mangledHeadCandidates head fname rest
  | otherwise = mangledHeadCandidates head fname rest

resolveFieldByOwners : Mono -> String -> Option (String, RecordInfo)
resolveFieldByOwners te fname = match fieldOwnerNames fname
  [] =>
    let _ = pushUnknownField fname "<unknown>"
    None
  [r] => pairRecordByName r
  r::rest => resolveFieldAmbiguous te fname (r::rest)

-- multiple owners: receiver still an unbound var ⇒ genuinely ambiguous; a
-- concrete (non-record) receiver ⇒ pick the first owner so the later unify
-- surfaces the type mismatch (mirrors the oracle's two `_` sub-branches).
resolveFieldAmbiguous : Mono -> String -> List String -> Option (String, RecordInfo)
resolveFieldAmbiguous te fname owners = match normalize te
  TVar _ =>
    let _ = pushTypeError "T-AMBIGUOUS-FIELD" (ambiguousFieldMsg fname owners)
    None
  _ => pairRecordByName (headL owners)

pairRecordByName : String -> Option (String, RecordInfo)
pairRecordByName r = map (ri => (r, ri)) (lookupRecordByName r)

headL : List String -> String
headL [] = ""
headL (x::_) = x

pushUnknownField : String -> String -> Unit
pushUnknownField fname rname =
  pushTypeError "T-UNKNOWN-FIELD" (unknownFieldMsg fname rname)

-- `declared`: the record's own field names, so a genuine typo (`aeg` for
-- `age`) can be suggested (ERROR-QUALITY dim F).  When a close-enough
-- candidate exists the error gets a structured `help` + a machine `fix` that
-- replaces the bad field name's span with the suggestion; otherwise unchanged.
unknownFieldFresh : String -> String -> List String -> Mono
unknownFieldFresh fname rname declared =
  let _ = pushUnknownFieldMaybeSuggest fname rname declared
  let v = freshVar ()
  -- Chunk A: the field error already explained this access; poison its result
  -- var so a downstream `debug`/method use doesn't pile on a secondary
  -- `ambiguous instance` cascade (record_wrong_field).
  let _ = poisonMismatchVars v v
  v

pushUnknownFieldMaybeSuggest : String -> String -> List String -> Unit
pushUnknownFieldMaybeSuggest fname rname declared = match suggestField fname declared
  None => pushTypeError "T-UNKNOWN-FIELD" (unknownFieldMsg fname rname)
  Some sug => pushTypeErrorHelpFixAt "T-UNKNOWN-FIELD" currentLoc.value (unknownFieldMsg fname rname ++ ". Did you mean '\{sug}'?") "did you mean '\{sug}'?" (fieldFixFrom currentLoc.value sug)

-- "did you mean" for a record field: nearest declared field name by
-- Levenshtein distance, within a fixed distance of 2.  Skip names < 3 chars
-- (too noisy at that length, same floor as resolve.mdk's `suggestName`).
-- Unlike `suggestName` — which searches EVERY in-scope name and so scales its
-- threshold down with length to avoid noise in a large candidate pool — the
-- candidate pool here is one record's OWN declared fields (typically a
-- handful), so a flat distance-2 budget is safe: it's what's needed to catch
-- a two-letter transposition (`aeg` vs `age`, distance 2) without the
-- length-scaled cap resolve.mdk uses (which would reject that exact case:
-- min(2, max(1, 3/3)) = 1).  Ties favor the lexicographically-first candidate.
-- A small local copy rather than importing resolve.mdk's `suggestName`, which
-- would cycle (nothing here imports resolve.mdk today, and this file is a
-- dependency of the pipeline stage that runs after it).
suggestField : String -> List String -> Option String
suggestField fname declared
  | stringLength fname < 3 = None
  | otherwise = map fst (bestFieldCandidate fname 2 declared None)

bestFieldCandidate : String -> Int -> List String -> Option (String, Int) -> Option (String, Int)
bestFieldCandidate _ _ [] acc = acc
bestFieldCandidate fname lim (c::cs) acc
  | c == fname = bestFieldCandidate fname lim cs acc
  | editDistance fname c > lim = bestFieldCandidate fname lim cs acc
  | otherwise = bestFieldCandidate fname lim cs (keepBetterField c (editDistance fname c) acc)

keepBetterField : String -> Int -> Option (String, Int) -> Option (String, Int)
keepBetterField c d None = Some (c, d)
keepBetterField c d (Some (bc, bd)) =
  if d < bd || d == bd && c < bc then
    Some (c, d)
  else
    Some (bc, bd)

-- The field name itself carries no Loc in the AST (`EFieldAccess Expr String
-- (Ref String)` — no per-field span).  `currentLoc` at the unknown-field site
-- is instead the RECEIVER's own span (infer walks into the receiver first,
-- and nothing re-enters an ELoc between there and here) — verified empirically:
-- `p.aeg` reports receiver span (sc, sc+1) for `p`, `somebody.aeg` reports
-- (sc, sc+8) for `somebody`.  The field name immediately follows the
-- receiver's end column + the `.`, so its span is computable from the
-- receiver's end column.  Valid for the common single-level `recv.field`
-- access; a chained `a.b.cty` receiver is itself a field access with no own
-- ELoc, so this would misplace the fix there — accepted for now (the
-- common-case gain is worth the narrow miss).
fieldFixFrom : Option Loc -> String -> Option (Loc, String)
fieldFixFrom (Some (Loc f _ _ el ec)) sug =
  Some (Loc f el (ec + 1) el (ec + 1 + stringLength sug), sug)
fieldFixFrom None _ = None

-- byte-for-byte with lib/typecheck.ml UnknownField / AmbiguousField / MissingField messages.
unknownFieldMsg : String -> String -> String
unknownFieldMsg fname rname =
  "Field '\{fname}' does not belong to record '\{rname}'"

-- Dot-access on a type exported abstractly: byte-identical to resolve.mdk's
-- AbstractFieldAccess ppResError, so a destructure (`Point { x }`, caught in
-- resolve) and a dot-access (`p.x`, caught here in typecheck) read the same.
abstractFieldMsg : String -> String -> String
abstractFieldMsg tname fname = "'\{tname}' is exported abstractly. Field '\{fname}' is not accessible; declare it `public export` to expose its fields"

-- TYPECHECK-AUDIT OBS4: mirrors lib/typecheck.ml MissingField message byte-for-byte.
missingFieldMsg : String -> String -> String
missingFieldMsg fname rname =
  "Missing field '\{fname}' in construction of record '\{rname}'"

ambiguousFieldMsg : String -> List String -> String
ambiguousFieldMsg fname owners = "Ambiguous field access: '.\{fname}' is declared by \{joinWith ", " owners}; the record type is undetermined. Add a type annotation (e.g. '(r : \{headL owners}).\{fname}')"

-- TYPECHECK-AUDIT D1: convert resolve-not-pre-screened error shapes (unknown
-- record / constructor, unbound variable) from uncatchable interpreter panics
-- into accumulated typeErrors + a fresh-var placeholder, so inference continues
-- (mirrors lib/typecheck.ml, which `fail`s with these byte-identical messages).
unknownRecordMsg : String -> String
unknownRecordMsg name = "Unknown record type: " ++ name

unknownCtorMsg : String -> String
unknownCtorMsg name = "Unknown constructor: " ++ name

unboundVarMsg : String -> String
unboundVarMsg name = "Unbound variable: " ++ name

-- push the message + return a fresh placeholder type so the continued path stays
-- in a valid state (the oracle accumulate-and-continue analog for these shapes).
unknownRecordFresh : String -> Mono
unknownRecordFresh name =
  let _ = pushTypeError "T-UNKNOWN-RECORD" (unknownRecordMsg name)
  freshVar ()

unboundVarFresh : String -> Mono
unboundVarFresh name =
  let _ = pushTypeError "T-UNBOUND" (unboundVarMsg name)
  freshVar ()

inferRecordUpdate : TcEnv -> Expr -> List FieldAssign -> Ref String -> Mono
inferRecordUpdate env base fields r = match firstFieldName fields
  None => panic "empty record update"
  Some fn => inferRecordUpdateField env base fields fn r

-- `Con { base | f = v, … }` — a named-field-variant update (e.g. desugar's
-- `DInterface { d | methods = … }`).  Resolve the variant's field layout by the
-- CONSTRUCTOR name (registered via registerNamedFieldVariants); both `base` and
-- the result have the variant's DATA type, only the provided fields are typed.
inferVariantUpdate : TcEnv -> String -> Expr -> List FieldAssign -> Mono
inferVariantUpdate env cname base fields = match lookupRecordByName cname
  None => unknownRecordFresh cname
  Some ri => inferRecordUpdateWith env cname base fields ri

firstFieldName : List FieldAssign -> Option String
firstFieldName [] = None
firstFieldName ((FieldAssign fn _)::_) = Some fn

-- receiver-directed (Phase 72), like inferFieldAccess: infer base first, then
-- pick the owning record by the base's head tycon, falling back to the first
-- update field's owners.
inferRecordUpdateField : TcEnv -> Expr -> List FieldAssign -> String -> Ref String -> Mono
inferRecordUpdateField env base fields fn r =
  let bt = normalize (infer env base)
  match resolveFieldRecord bt fn
    None => freshVar ()
    Some (rname, ri) =>
      -- stamp the RESOLVED receiver record onto the node (bug #38): both emitters
      -- read it to pick the record by name, instead of guessing from the first
      -- update label (which picks the wrong record — and so the wrong slot — when
      -- two records share a field name at different indices).
      let _ = setRef r rname
      inferRecordUpdatePicked rname bt env fields ri

inferRecordUpdatePicked : String -> Mono -> TcEnv -> List FieldAssign -> RecordInfo -> Mono
inferRecordUpdatePicked rname bt env fields ri =
  let ir = instantiateRecord ri
  let _ = unify bt (fst ir)
  let _ = unifyFieldAssigns env rname (snd ir) fields
  fst ir

inferRecordUpdateWith : TcEnv -> String -> Expr -> List FieldAssign -> RecordInfo -> Mono
inferRecordUpdateWith env rname base fields ri =
  let ir = instantiateRecord ri
  let _ = unify (infer env base) (fst ir)
  let _ = unifyFieldAssigns env rname (snd ir) fields
  fst ir

-- operators infer by SHAPE (the typeclass constraint they carry — Num/Eq/… — is
-- tracked at the value level but never rendered in a scheme, so it's irrelevant
-- to the === TYPES === output; numeric literals are Int, not polymorphic)
inferBinopE : TcEnv -> String -> Expr -> Expr -> Ref Route -> Mono
inferBinopE env op l r dref =
  let lt = infer env l
  let rt = infer env r
  -- Type-error span (Bite 2, fork 1 = WHOLE BINOP): after inferring both
  -- operands, the live `currentLoc` is the LAST operand atom (ELoc wraps
  -- leaves, not the binop level).  Point mismatches at the whole `l <op> r`
  -- span (l's start .. r's end) so both the Num-obligation errors and the
  -- comparison/Eq/Ord `typeMismatch` binop errors squiggle the operator
  -- expression rather than a lone operand.
  let _ = match binopSpanLoc l r
    Some sp => setRef currentLoc (Some sp)
    None => ()
  let _ = recordBinopSite op dref lt
  let _ = recordArithSite op dref lt
  inferBinop op lt rt

-- Synthesize the whole-binop span from its operand Exprs: file + start of the
-- left operand, end of the right operand.  Falls back to whichever single
-- operand loc is available (None only when neither operand is ELoc-wrapped).
binopSpanLoc : Expr -> Expr -> Option Loc
binopSpanLoc l r = match (exprLoc l, exprLoc r)
  (Some (Loc f sl sc _ _), Some (Loc _ _ _ el ec)) => Some (Loc f sl sc el ec)
  (Some ll, None) => Some ll
  (None, Some rr) => Some rr
  (None, None) => None
-- Phase 151 / Gap G: record a binop site for the comparison/equality operators
-- so resolveBinopSites can stamp [dref] once the operand type grounds.  The
-- operand mono is [lt] (unified with [rt] by eqCompareOp/ordCompareOp below).

-- Map a comparison/equality operator to its Eq/Ord method and stash a pending
-- binop site; non-comparison operators record nothing.  G4: snapshot
-- currentImplBody so resolveBinopSite gates the RDict element-dict route to genuine
-- in-impl-body sites (a top-level operand may collide with stale activeDictVars ids).
recordBinopSite : String -> Ref Route -> Mono -> Unit
recordBinopSite op dref m = match binopMethod op
  Some method => setRef pendingBinopSites ((method, dref, m, currentImplBody.value, currentFn.value)::pendingBinopSites.value)
  None => ()

-- SHARED-FLOAT-RESIDUAL §3(C): stash an arithmetic binop's operand mono + route
-- ref for the deferred scalar-type stamp.  Non-arithmetic operators record
-- nothing (their route is handled by recordBinopSite or left RNone).  The operand
-- mono is [lt] (unified with [rt] by inferBinop).
isArithBinop : String -> Bool
-- Intentional cross-file duplicate of the same helper in wasm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
isArithBinop op = contains op ["+", "-", "*", "/", "%"]

recordArithSite : String -> Ref Route -> Mono -> Unit
recordArithSite op dref m
  | isArithBinop op =
    setRef pendingArithSites ((dref, m)::pendingArithSites.value)
  | otherwise = ()

-- Roadmap #18a: `++` is the surface operator for `Semigroup`'s `append`, so it
-- joins the comparison operators on the recordBinopSite/resolveBinopSites seam —
-- a ground non-builtin operand (a user `impl Semigroup MyRope`) gets its route
-- stamped and rewriteBinopExpr turns the EBinOp into an `EMethodAt "append"`
-- application.  The builtin String/List appends never route (binopBuiltinHead) —
-- see the recursion note there.
binopMethod : String -> Option String
binopMethod "==" = Some "eq"
binopMethod "!=" = Some "eq"
binopMethod "<" = Some "lt"
binopMethod ">" = Some "gt"
binopMethod "<=" = Some "lte"
binopMethod ">=" = Some "gte"
binopMethod "++" = Some "append"
binopMethod _ = None

-- Roadmap #18c: `-` (unary minus) is the surface operator for `Num`'s `negate`,
-- joining `++`/comparisons on the record*Site/resolve*Sites/rewrite*Expr seam.
-- `!` never routes — Bool negation is not a typeclass method.
unopMethod : String -> Option String
unopMethod "-" = Some "negate"
unopMethod _ = None

-- The EUnOp analogue of recordBinopSite: stash a pending unop site for `-`
-- (nothing for `!`).  Same currentImplBody/currentFn snapshot, same reason.
recordUnopSite : String -> Ref Route -> Mono -> Unit
recordUnopSite op dref m = match unopMethod op
  Some method => setRef pendingUnopSites ((method, dref, m, currentImplBody.value, currentFn.value)::pendingUnopSites.value)
  None => ()

-- The EUnOp analogue of inferBinopE: infer the single operand, record its
-- pending unop site (for `-`), then dispatch to inferUnop for the actual
-- obligation/unification work (negateOp for `-`, Bool-unify for `!`).
inferUnopE : TcEnv -> String -> Expr -> Ref Route -> Mono
inferUnopE env op e dref =
  let t = infer env e
  let _ = recordUnopSite op dref t
  inferUnop op t

inferBinop : String -> Mono -> Mono -> Mono
inferBinop "+" lt rt = numArithOp lt rt
inferBinop "-" lt rt = numArithOp lt rt
inferBinop "*" lt rt = numArithOp lt rt
inferBinop "/" lt rt = numArithOp lt rt
inferBinop "%" lt rt = numArithOp lt rt
inferBinop "++" lt rt = appendOp lt rt
inferBinop "==" lt rt = eqCompareOp lt rt
inferBinop "!=" lt rt = eqCompareOp lt rt
inferBinop "<" lt rt = ordCompareOp lt rt
inferBinop ">" lt rt = ordCompareOp lt rt
inferBinop "<=" lt rt = ordCompareOp lt rt
inferBinop ">=" lt rt = ordCompareOp lt rt
inferBinop "&&" lt rt = boolOp lt rt
inferBinop "||" lt rt = boolOp lt rt
inferBinop "::" lt rt = consOp lt rt
inferBinop "|>" lt rt = pipeOp lt rt
inferBinop ">>" lt rt = composeOp lt rt False
inferBinop "<<" lt rt = composeOp lt rt True
inferBinop op _ _ = panic ("typecheck: unsupported operator " ++ op)

-- Roadmap #18a: `++` (append) carries a `Semigroup` obligation on its (unified)
-- operand type — a verbatim mirror of `eqCompareOp`/`recordIfaceObligation` for `==`,
-- and the reason `"x" ++ Box 1` is now a located `No impl of Semigroup for Box`
-- reject at CHECK time rather than an eval-time `E-PANIC`.  Reuses the same
-- pendingImplObligations / checkImplObligations path: a synthetic Semigroup
-- obligation with a bare iface-param declared type (`TyVar "a"`, typaram ["a"]) so
-- dispatchMonosOf recovers exactly the operand mono.  `Monoid a requires Semigroup
-- a`, so a declared `Monoid a =>` constraint superclass-closes to satisfy it (this
-- is what keeps core.mdk's `foldMap f = fold (acc x => acc ++ f x) empty` typing).
-- A still-polymorphic operand defers to the caller, exactly like Num/Eq/Ord.
--
-- Gated on the `Semigroup` interface being REGISTERED (prelude loaded), via
-- ifaceRegistered: the bare-HM no-prelude oracle (tc_probe /
-- typecheck_main.mdk) has no `Semigroup` class, so recording the obligation only
-- when it exists keeps those drivers byte-identical while `medaka check` rejects.
appendOp : Mono -> Mono -> Mono
appendOp lt rt =
  let _ = unify lt rt
  let _ = recordIfaceObligation "Semigroup" lt
  lt

-- #146: unified operator-obligation recorder.  The arithmetic (`+ - * / %`, unary
-- `-`), comparison (`== != < > <= >=`) and append (`++`) operators each carry an
-- interface obligation on their (unified) operand type via pushPendingObl — a
-- synthetic obligation with a bare iface-param declared type (`TyVar "a"`, typaram
-- ["a"]) so dispatchMonosOf recovers exactly the operand mono.  Gated on that
-- interface being REGISTERED (prelude loaded): the bare-HM no-prelude oracle
-- (tc_probe / typecheck_main.mdk) registers none of Num/Eq/Ord/Semigroup, so
-- recording only when the interface exists keeps those drivers byte-identical while
-- full check_main (prelude) rejects, matching `medaka check`.  Callers:
-- numArithOp/negateOp ("Num"), eqCompareOp ("Eq"), ordCompareOp ("Ord"), appendOp
-- ("Semigroup").
recordIfaceObligation : String -> Mono -> Unit
recordIfaceObligation iface lt
  | ifaceRegistered iface =
    pushPendingObl (iface, ["a"], TyVar "a", lt, currentLoc.value)
  | otherwise = ()

-- True iff `iface` is registered (has ≥1 method registered from the DInterface
-- decls — present once core.mdk is loaded).  #147: an O(log n) membership test on
-- the cached registeredIfacesRef set, replacing the old full linear scan of the
-- method table per operator/numeric-literal.
ifaceRegistered : String -> Bool
ifaceRegistered iface = omHasKey iface registeredIfacesRef.value

-- G2: arithmetic `+ - * / %` carry a `Num` obligation on their (unified) operand
-- type — mirrors the oracle's `No impl of Num for <T>` reject (lib/typecheck.ml).
-- `++` (append) is NOT Num — it carries a `Semigroup` obligation instead (appendOp
-- above).  We reuse the
-- existing pendingImplObligations / checkImplObligations path: a synthetic Num
-- obligation with a bare iface-param declared type (`TyVar "a"`, typaram ["a"]) so
-- dispatchMonosOf recovers exactly the operand mono.  When it grounds to a concrete
-- non-Num head (String/Bool) with no `impl Num`, the post-inference check rejects;
-- while still a polymorphic var (a `Num a =>` site) allConcreteHeads defers it to
-- the caller — exactly the oracle's behaviour.
--
-- Gated on the `Num` interface being REGISTERED (prelude loaded): the bare-HM,
-- no-prelude oracle (tc_probe / typecheck_main.mdk) imposes NO class constraint on
-- `+`, so `1 + 2 : Int` and `"a" - "b" : String` both type there.  Recording the
-- obligation only when Num exists keeps the no-prelude drivers byte-identical to
-- that oracle while the full check_main (prelude) path rejects, matching `medaka
-- check`.
numArithOp : Mono -> Mono -> Mono
numArithOp lt rt =
  -- Chunk D: taint any literal operand BEFORE the unify grounds it — so a literal
  -- fed to an arithmetic op (`1 + "x"`, `x + 1`, `1 + x`) keeps `No impl of Num for
  -- T` (the `+` is the culprit) rather than being reframed as a bare mismatch.
  let _ = markNumlitOpTaint lt
  let _ = markNumlitOpTaint rt
  let _ = unify lt rt
  let _ = recordIfaceObligation "Num" lt
  lt

-- PLAN.md #11 soundness arm: model an integer literal as a `fromInt n` method
-- occurrence so its route cell [dref] gets stamped (RKey ground / RDictFwd poly) by
-- resolveSites — exactly like core.mdk's `fromInt 0` in `sum`.  Direct mirror of
-- lib/typecheck.ml's ENumLit infer arm.  Gated on the prelude (`Num` registered AND
-- `fromInt` bound): with no prelude (bare-HM oracle) fall back to a plain fresh
-- Num-obligated var, leaving [dref] RNone (⇒ a static Int literal at rewrite time).
inferNumLit : TcEnv -> Int -> Ref (Option Float) -> Ref Route -> Mono
inferNumLit env n fref dref
  | ifaceRegistered "Num" = match lookupVar env "fromInt"
    None => inferNumLitBare n fref
    Some _ =>
      -- inferMethodAt records the Num impl obligation + a pendingSite on [dref].
      let fromIntTy = inferMethodAt env "fromInt" dref (Ref []) (Ref [])
      let a = freshVar ()
      let _ = unify fromIntTy (TFun (TCon "Int") (openRow ()) a)
      let _ = setRef numlitRefs ((a, fref, n, dref) :: numlitRefs.value)
      let _ = recordNumlitLoc a  -- Chunk D: literal provenance for Num mis-framing
      a
  | otherwise = inferNumLitBare n fref

-- no-prelude fallback: a fresh var, no route (dref untouched ⇒ stays RNone ⇒ Int).
-- PLAN.md #11 (locked §0.2): a numeric literal is ALWAYS a `fromInt n` occurrence,
-- so it carries a `Num` obligation on its var unconditionally — exactly the OCaml
-- oracle, whose ENumLit infer arm `infer env (EVar "fromInt")` records the Num
-- usage even no-prelude (`initial_env` seeds `fromInt`/`Num`).  Recording it here
-- (vs. the prelude-gated `recordIfaceObligation`) lets value-level defaulting ground
-- an AMBIGUOUS literal var to Int (`nums = [1,2,3] : List Int`) so the no-prelude
-- `typecheck_main` matches the prelude-aware oracle golden.  The matching reject is
-- SUPPRESSED no-prelude in checkOneImplObligation (no-prelude imposes no Num impl
-- constraint — see its `ifaceRegistered` guard), so a literal still types Int
-- without a spurious `No impl of Num for Int`.
inferNumLitBare : Int -> Ref (Option Float) -> Mono
inferNumLitBare n fref =
  let a = freshVar ()
  let _ = pushPendingObl ("Num", ["a"], TyVar "a", a, currentLoc.value)
  let _ = setRef numlitRefs ((a, fref, n, Ref RNone)::numlitRefs.value)
  let _ = recordNumlitLoc a  -- Chunk D: literal provenance for Num mis-framing
  a

-- ── Chunk D: Num mis-framing provenance (error-path only) ──────────────────
-- Record a literal's (var, loc) so a later Num-obligation reframe can tell a bare
-- literal from an arithmetic-operator operand.  [currentLoc] is the ENumLit span.
recordNumlitLoc : Mono -> Unit
recordNumlitLoc a = match currentLoc.value
  Some l =>
    let _ = setRef numlitVarLocs ((a, l)::numlitVarLocs.value)
    setRef numlitUntainted ((a, l)::numlitUntainted.value)
  None => ()

-- Called from recordIfaceObligation (arithmetic `+`/`-`/`*`/`/`/`%`): any recorded
-- literal whose var shares a union-find root with [m] was an operand of an op, so
-- mark its loc — the reframe then keeps `No impl of Num for T` for it.  Runs during
-- inference (vars still unbound), so `normalize` reveals the shared root regardless
-- of which operand became the root at unify time.
markNumlitOpTaint : Mono -> Unit
markNumlitOpTaint m =
  let id = rootIdOf m
  if id < 0 || not (anyRootMatch id numlitUntainted.value) then
    ()
  else
    setRef numlitUntainted (taintAndDrop id numlitUntainted.value)

-- True iff SOME worklist literal shares the union-find root [id].  Short-circuits via
-- `||` and allocates nothing, so the common case (this operand taints no literal)
-- leaves the worklist alone — rebuilding it unconditionally would put back an O(N)
-- allocation per operand, which is the very thing `rootIdOf` removed.
anyRootMatch : Int -> List (Mono, Loc) -> Bool
anyRootMatch _ [] = False
anyRootMatch id ((v, _)::rest) = sameRootId id v || anyRootMatch id rest

-- Taint every worklist literal sharing the root [id] (record its loc as
-- operator-tainted) and DROP it from the worklist; keep the others.
taintAndDrop : Int -> List (Mono, Loc) -> List (Mono, Loc)
taintAndDrop _ [] = []
taintAndDrop id ((v, l)::rest)
  | sameRootId id v =
    let _ = setRef numlitOpLocs (l::numlitOpLocs.value)
    taintAndDrop id rest
  | otherwise = (v, l) :: taintAndDrop id rest

-- The union-find ROOT id of [v]; -1 if it does not normalize to a type variable.
-- NON-ALLOCATING (it reads the root's id rather than rebuilding a `TVar` for it) and
-- PATH-COMPRESSING (it goes through `normalizeLink`, so a walked chain is flattened).
-- PERF: `sameRootId` is applied to EVERY recorded literal on EVERY arithmetic /
-- comparison operand (markNumlitOpTaint and tagLitLocsWithRoot each scan the whole,
-- never-trimmed `numlitVarLocs` list), so an uncompressed chain made this the single
-- hottest symbol in the compiler — 57% of a large-declaration typecheck (issue #115).
-- Tyvar ids come from a counter that starts at 0 (`newTyvarId`), so -1 can never
-- collide with a real id.
rootIdOf : Mono -> Int
rootIdOf (TVar cell) = match cell.value
  Unbound id _ => id
  Link t => rootVarId (normalizeLink cell t)
rootIdOf _ = 0 - 1

-- The id of an ALREADY-NORMALIZED mono: its root tyvar's id, or -1 if it is not a
-- type variable at all.  (`normalizeLink` never returns a `Link`, so that arm is
-- unreachable; it folds into the not-a-tyvar answer.)
rootVarId : Mono -> Int
rootVarId (TVar cell) = match cell.value
  Unbound id _ => id
  Link _ => 0 - 1
rootVarId _ = 0 - 1

-- True iff [v] normalizes to the unbound var [id] (same union-find root).
sameRootId : Int -> Mono -> Bool
sameRootId id v = rootIdOf v == id

-- Chunk D: if one of [a]/[b] is a still-unbound literal var and the other is
-- concrete-headed, tag that literal's loc with [kind] so the reframe can use
-- site-specific wording.  Pure state capture — never alters unification.
noteNumlitCtx : Mono -> Mono -> String -> Unit
noteNumlitCtx a b kind =
  let _ = tagNumlitCtxIf a b kind
  tagNumlitCtxIf b a kind

-- Tag EVERY literal whose var shares [v]'s root (not just the first) when [other]
-- has a concrete head — so a heterogeneous list forcing several literals to one
-- type tags them all with the same [kind], letting their reframed messages dedup to
-- a single "list elements have different types" line.
tagNumlitCtxIf : Mono -> Mono -> String -> Unit
tagNumlitCtxIf v other kind
  | isSome (monoHeadCon other) = tagAllLitLocs v kind
  | otherwise = ()

tagAllLitLocs : Mono -> String -> Unit
tagAllLitLocs v kind = match normalize v
  TVar cell => tagLitLocsWithRoot (tyvarId cell) kind numlitVarLocs.value
  _ => ()

tagLitLocsWithRoot : Int -> String -> List (Mono, Loc) -> Unit
tagLitLocsWithRoot _ _ [] = ()
tagLitLocsWithRoot id kind ((mv, l)::rest) =
  let _ = if sameRootId id mv then
    setRef numlitCtxTags ((l, kind)::numlitCtxTags.value)
  else
    ()
  tagLitLocsWithRoot id kind rest

-- Stage-1 Eq dispatch (EQ-DISPATCH-DESIGN.md §2.1): `==`/`!=` carry an `Eq`
-- obligation on their (unified) operand type — a verbatim mirror of
-- `recordIfaceObligation` for `+`.  We reuse the existing pendingImplObligations /
-- checkImplObligations path: a synthetic Eq obligation with a bare iface-param
-- declared type (`TyVar "a"`, typaram ["a"]) so dispatchMonosOf recovers exactly
-- the operand mono.  When it grounds to a concrete non-Eq head (a function, an
-- un-derived ADT) with no `impl Eq`, the post-inference check rejects; while still
-- a polymorphic var (an `Eq a =>` site) allConcreteHeads defers it to the caller
-- — exactly the Num behaviour.  `<`/`>`/`<=`/`>=` carry the sibling `Ord`
-- obligation via `ordCompareOp` below.  `!=` shares this seam and lowers to
-- `not (eq …)` at the dict layer (binopMethodApp), so it does not double-report.
--
-- Gated on the `Eq` interface being REGISTERED (prelude loaded), mirroring
-- `ifaceRegistered`: the bare-HM no-prelude oracle (tc_probe / typecheck_main)
-- has no `Eq` class, so recording the obligation only when Eq exists keeps those
-- drivers byte-identical while full check_main (prelude) rejects.
eqCompareOp : Mono -> Mono -> Mono
eqCompareOp lt rt =
  let _ = unify lt rt
  let _ = recordIfaceObligation "Eq" lt
  TCon "Bool"

-- Stage-1 Ord dispatch (EQ-DISPATCH-DESIGN.md §"sibling Ord follow-up"): the four
-- ordering comparisons `<`/`>`/`<=`/`>=` carry an `Ord` obligation on their
-- (unified) operand type — a verbatim mirror of `eqCompareOp` for `==`.  Reuses the
-- same pendingImplObligations / checkImplObligations path.  `Ord` supersets `Eq`
-- (`interface Ord a requires Eq a`), so a declared `Ord a =>` constraint already
-- superclass-closes to satisfy BOTH the `<`→Ord and a sibling `==`→Eq obligation;
-- an `Eq a =>` declaration does NOT close upward, so a bare `<` under `Eq a =>` is
-- correctly rejected as needing `Ord a`.  When the operand grounds to a concrete
-- non-Ord head (a function, an un-derived ADT) with no `impl Ord`, the
-- post-inference check rejects; while still a polymorphic var it defers to the
-- caller — exactly the Eq/Num behaviour.  NO change to eval/emit: `<` still lowers
-- to `EMethodAt "lt"` at the dict layer, so runtime/emit dispatch is unchanged.
--
-- Gated on the `Ord` interface being REGISTERED (prelude loaded), mirroring
-- `ifaceRegistered`.
ordCompareOp : Mono -> Mono -> Mono
ordCompareOp lt rt =
  let _ = unify lt rt
  let _ = recordIfaceObligation "Ord" lt
  TCon "Bool"

boolOp : Mono -> Mono -> Mono
boolOp lt rt =
  let _ = unify lt (TCon "Bool")
  let _ = unify rt (TCon "Bool")
  TCon "Bool"

consOp : Mono -> Mono -> Mono
consOp lt rt =
  let listTy = TApp (TCon "List") lt
  let _ = noteNumlitCtx lt rt "cons"  -- Chunk D: tag cons head-vs-list Num mismatch
  let _ = unify rt listTy
  listTy

pipeOp : Mono -> Mono -> Mono
pipeOp lt rt =
  let res = freshVar ()
  let eff = openRow ()
  let _ = unify rt (TFun lt eff res)
  let _ = performEffect curEffect eff
  res

-- g >> h : (a->b) -> (b->c) -> (a->c)  [flipped=False]
-- g << h : (a->b) -> (c->a) -> (c->b)  [flipped=True]
composeOp : Mono -> Mono -> Bool -> Mono
composeOp gt ht False =
  let a = freshVar ()
  let b = freshVar ()
  let c = freshVar ()
  let _ = unify gt (TFun a (openRow ()) b)
  let _ = unify ht (TFun b (openRow ()) c)
  TFun a (openRow ()) c
composeOp gt ht True =
  let a = freshVar ()
  let b = freshVar ()
  let c = freshVar ()
  let _ = unify gt (TFun a (openRow ()) b)
  let _ = unify ht (TFun c (openRow ()) a)
  TFun c (openRow ()) b

inferUnop : String -> Mono -> Mono
inferUnop "-" t = negateOp t
inferUnop "!" t =
  let _ = unify t (TCon "Bool")
  TCon "Bool"
inferUnop op _ = panic ("typecheck: unsupported unary op " ++ op)

-- Roadmap #18c: unary minus `-x` carries a `Num` obligation on its operand type —
-- a verbatim mirror of `numArithOp`/`recordIfaceObligation` for binary `+`/`-`/…,
-- and the reason `-"x"` is now a located `No impl of Num for String` reject at
-- CHECK time rather than an eval-time `panic "unary minus on non-number"`.
-- markNumlitOpTaint keeps the same Chunk-D literal-provenance error framing as
-- the binary arithmetic operators (`-"x"` blames the operator, not a bare
-- literal-vs-String mismatch).
negateOp : Mono -> Mono
negateOp t =
  let _ = markNumlitOpTaint t
  let _ = recordIfaceObligation "Num" t
  t

-- backtick infix `x `f` y` is just f applied to x then y
inferInfix : TcEnv -> String -> Expr -> Expr -> Mono
inferInfix env op l r =
  let ft = inferVar env op
  let lt = infer env l
  let rt = infer env r
  -- reconstruct the equivalent app spine so a hole-bearing extern fills from
  -- its FIRST arg (l) — mirror of the EApp path (v2 Stage 2b).
  let inner = EApp (EVar op) l
  inferApp (envAlphaLets env) (EApp inner r) (inferApp (envAlphaLets env) inner ft lt) rt

inferVar : TcEnv -> String -> Mono
inferVar env x = match maybeStandaloneValueMono x
  -- P0-19 d4b (S4): bare value-position definer shadow → the standalone scheme.
  Some m => m
  None => inferVarPlain env x

inferVarPlain : TcEnv -> String -> Mono
inferVarPlain env x = match lookupVar env x
  Some s =>
    let mono = instantiateVarTracked x s
    recordImplObligation x mono
  None => unboundVarFresh x

-- #11 soundness (native obligation hole, plain check path): a constrained binding used
-- as a plain EVar (`g = f "hello"`) instantiates its DEFERRED obligations at the call.
-- schemeObligationsRef (always-on, unlike funConstraintsRef) records each binding's
-- (iface, quantified-var-id); here we instantiate TRACKED so each obligation var maps
-- to this call's fresh mono, recorded as a call obligation checked after inference.
-- A binding with no recorded obligations takes the plain instantiate path (identical
-- mono).  Mirrors lib/typecheck.ml re-checking inferred_constraints at every use.
instantiateVarTracked : String -> Scheme -> Mono
instantiateVarTracked x s = match lookupAssocS2 x schemeObligationsRef.value
  None => instantiate s
  Some obs =>
    let inst = instantiateTracked s
    let _ = recordSchemeCallObligations obs (snd inst)
    fst inst

-- map each (iface, scheme-var-id) through the instantiation subst to this call's mono,
-- pushing onto pendingCallObligations.  An id absent from the subst (shouldn't happen
-- for a quantified var) is skipped.
recordSchemeCallObligations : List (String, Int) -> List (Int, Mono) -> Unit
recordSchemeCallObligations [] _ = ()
recordSchemeCallObligations ((iface, id)::rest) subst = match lookupAssocI id subst
  Some mono =>
    let _ = pushCallObl (iface, mono, currentLoc.value)
    recordSchemeCallObligations rest subst
  None => recordSchemeCallObligations rest subst

-- String-keyed lookup over schemeObligationsRef.
lookupAssocS2 : String -> List (String, List (String, Int)) -> Option (List (String, Int))
lookupAssocS2 _ [] = None
lookupAssocS2 k ((k2, v)::rest)
  | k == k2 = Some v
  | otherwise = lookupAssocS2 k rest

-- Error-path B4: if [x] is a registered interface method, record this occurrence's
-- (post-instantiation) mono so checkImplObligations can verify a matching impl
-- exists once the dispatch type is resolved.  Returns the mono unchanged.  A
-- non-method name records nothing (the common case).  The marked path records the
-- same via inferMethodAt; the bare typecheck_main path records here.
recordImplObligation : String -> Mono -> Mono
recordImplObligation x mono
  -- A standalone shadow (a top-level funDef that reuses an interface-method name)
  -- resolves in-scope to that standalone, not the method — the scope-blind marker
  -- still rewrites its occurrences to EMethodAt, but a NO-IMPL receiver legitimately
  -- falls back to the standalone (resolveRLocalSite stamps RLocal), so there is no
  -- impl obligation.  Recording one surfaces a spurious `No impl of <Iface> for <T>`
  -- under checkImplObligations (the build path skips that check, so it only bites
  -- `check`).  Skip for EVERY standalone shadow — definer (`definerShadowNamesRef`)
  -- AND importer (an imported standalone; `standaloneValuesRef` holds both).  P0-18:
  -- this closes the `check`-side of the importer-shadow-on-a-no-impl-receiver residual
  -- (`size 3` where `size` is imported) which was REJECTED while `run` correctly
  -- returned the standalone.  Sound: the name genuinely has a standalone fallback, so
  -- a no-impl receiver is not an error — the route decides impl-vs-standalone per
  -- receiver; a receiver WITH an impl still dispatches (and that impl exists).
  -- Check BOTH refs: the single-file check path (checkProgram) sets only
  -- `definerShadowNamesRef`, while the multi-module path sets `standaloneValuesRef`
  -- (importer ∪ definer) — so either alone would miss one path's shadows.
  | contains x definerShadowNamesRef.value || contains x standaloneValuesRef.value =
    mono
  | otherwise = match omLookup x methodIfaceParamsRef.value
    None => mono
    Some (iface, typarams, mty) =>
      let _ = pushPendingObl (iface, typarams, mty, mono, currentLoc.value)
      mono

-- Expected-type propagation for an application whose argument is a lambda.
-- Inferring `andThen e (stream => Ok [JArray stream])` naively infers the lambda
-- BODY first with `stream : freshVar`, so a downstream conflicting use inside the
-- body (`JArray stream` wants `Array Json`) pins `stream` to the WRONG type before
-- the function's declared param type (`List Json`) is ever reconciled — the later
-- reconciliation then fails at the application with no good site, and the hover
-- side-channel records the wrong `stream` type.  Fix (bidirectional "checking"
-- mode, the do-bind/higher-order case): infer `f` first, peel its parameter type,
-- and unify it onto the lambda's parameter BEFORE inferring the body.  Then the
-- body sees `stream : List Json` and the type error localizes to the `JArray`
-- USE, and recordLocalBind captures the right hover type.  Purely additive: the
-- final `unify ft (TFun xt …)` in inferApp imposes the same equality regardless,
-- so the solution is unchanged — we only make it available earlier.
-- ── Batch B #5: swapped-argument detection (2-arg transposition) ───────────
-- A 2-arg application whose in-order arg/param types clash but whose
-- TRANSPOSITION type-checks is almost always a caller who wrote the arguments
-- in the wrong order (`greet 3 "Alice"` for `greet : String -> Int -> …`).
-- Detect that shape UPSTREAM in inferAppExpr — where the callee name + BOTH
-- args are still in scope — and emit ONE actionable diagnostic naming the
-- swapped call, instead of letting the two per-arg `inferApp` mismatches leak
-- (`Int vs String` + `Int literal vs String`) with no hint that a swap fixes it.
--
-- SOUNDNESS (a wrong "swap" suggestion is worse than the status quo): fire ONLY
-- when the transposition GENUINELY type-checks.  Two guards make the structural
-- test exact — never a wildcard-var approximation:
--   (1) both callee params must be fully CONCRETE (no free tyvars).  A
--       polymorphic param accepts any argument, so a "swap" past it is
--       meaningless AND its fit can't be decided structurally.
--   (2) both arguments must be LITERALS.  A literal's type is known exactly
--       from its syntax (WITHOUT re-inference side effects), so `argLitFits`
--       decides the transposition's type-fit structurally.  A numeric literal
--       (`ENumLit`/`LInt`) fits any `Int`/`Float` param (it is `Num`-poly); a
--       float literal fits only `Float`; other literals fit their exact type.
-- Under both guards, `(not in-order) && swapped` holds only for a real
-- transposition, so the suggested swap always type-checks.  We further require
-- the two params to DIFFER (same-type params ⇒ order is irrelevant, no swap).
-- Anything outside this scope (>2 args, non-literal args, polymorphic params,
-- same-type params) falls through to the normal per-arg path unchanged.

unlocExpr : Expr -> Expr
unlocExpr (ELoc _ e) = unlocExpr e
unlocExpr (EDoOrigin _ e) = unlocExpr e
unlocExpr e = e

exprLoc : Expr -> Option Loc
exprLoc (ELoc l _) = Some l
exprLoc (EDoOrigin l _) = Some l
exprLoc _ = None

-- The span of an application's outermost argument (Bite 3): peel any ELoc
-- wrapper on the `EApp` head, then read the argument Expr's loc.  Non-EApp
-- shapes (never passed as `appExpr`) return None.
appArgLoc : Expr -> Option Loc
appArgLoc (ELoc _ e) = appArgLoc e
appArgLoc (EApp _ x) = exprLoc x
appArgLoc _ = None

-- True iff [m] has NO unbound tyvar anywhere (a fully concrete type).
monoConcrete : Mono -> Bool
monoConcrete m = match normalize m
  TVar _ => False
  TCon _ => True
  TApp a b => monoConcrete a && monoConcrete b
  TFun a _ b => monoConcrete a && monoConcrete b
  TEff _ => True

-- structural equality of two concrete monos (both guaranteed var-free here)
monoSameShape : Mono -> Mono -> Bool
monoSameShape a b = match normalize a
  TCon x => match normalize b
    TCon y => x == y
    _ => False
  TApp a1 b1 => match normalize b
    TApp a2 b2 => monoSameShape a1 a2 && monoSameShape b1 b2
    _ => False
  TFun a1 _ b1 => match normalize b
    TFun a2 _ b2 => monoSameShape a1 a2 && monoSameShape b1 b2
    _ => False
  _ => False

monoIsNumeric : Mono -> Bool
monoIsNumeric m = match normalize m
  TCon "Int" => True
  TCon "Float" => True
  _ => False

monoIsFloat : Mono -> Bool
monoIsFloat m = match normalize m
  TCon "Float" => True
  _ => False

isLitArg : Expr -> Bool
isLitArg e = match unlocExpr e
  ENumLit _ _ _ => True
  ELit _ => True
  _ => False

-- does the LITERAL argument [e] fit the CONCRETE param type [pt]?
argLitFits : Expr -> Mono -> Bool
argLitFits e pt = match unlocExpr e
  ENumLit _ _ _ => monoIsNumeric pt
  ELit (LInt _) => monoIsNumeric pt
  ELit (LFloat _) => monoIsFloat pt
  ELit l => monoSameShape (litType l) pt
  _ => False

-- render a literal argument back to its source text (for the swapped-call hint)
renderLitArg : Expr -> Option String
renderLitArg e = match unlocExpr e
  ENumLit n _ _ => Some (intToString n)
  ELit (LInt n) => Some (intToString n)
  ELit (LFloat f) => Some (floatToString f)
  ELit (LString s) => Some ("\"" ++ s ++ "\"")
  ELit (LChar c) => Some ("'" ++ c ++ "'")
  ELit (LBool b) => Some (if b then "True" else "False")
  ELit LUnit => Some "()"
  _ => None

-- the two param types of a function of arity EXACTLY 2 (result NOT an arrow).
-- Requiring exact arity 2 keeps the detector off a >2-arg call's inner 2-arg
-- SUB-spine: currying makes `g 3 "Alice"` a real inferAppExpr node inside
-- `g 3 "Alice" True`, and firing there would suggest `g "Alice" 3`, silently
-- dropping the third argument.  A 3-param `g` has a `Bool -> String` result
-- after two params, so it bails here; only a genuinely 2-param callee matches.
funParams2 : Mono -> Option (Mono, Mono)
funParams2 m = match normalize m
  TFun p1 _ rest => match normalize rest
    TFun p2 _ result => match normalize result
      TFun _ _ _ => None
      _ => Some (p1, p2)
    _ => None
  _ => None

-- Machine fix: replace the span from arg1's start to arg2's end with the
-- swapped source text.  Requires both args to carry real source spans.
swapArgFix : Expr -> Expr -> String -> Option (Loc, String)
swapArgFix a1 a2 repl = match (exprLoc a1, exprLoc a2)
  (Some (Loc f sl sc _ _), Some (Loc _ _ _ el ec)) =>
    Some (Loc f sl sc el ec, repl)
  _ => None

-- If [f] is exactly `<callee> arg1` (a 2-arg call's function part — the callee
-- applied to just its first argument, NOT itself a nested application), resolve
-- the callee to its NAME and its two concrete param types.  `None` for any
-- other shape (nested spine, unbound callee, non-arity-2 type).
twoArgCallee : TcEnv -> Expr -> Option (String, Expr, Mono, Mono)
twoArgCallee env f = match unlocExpr f
  EApp g a1 => match unlocExpr g
    EApp _ _ => None                           -- 3+ args: out of scope
    gHead =>
      do
        name <- appSpineName gHead
        scheme <- lookupVar env name
        (p1, p2) <- funParams2 (instantiate scheme)
        Some (name, a1, p1, p2)
  _ => None

-- Detect a 2-argument transposition on `f x` (`f` = callee applied to arg1, `x`
-- = arg2).  Returns `Some resultVar` (poisoned, so no cascade) when it fires and
-- has emitted the diagnostic; `None` to fall through to the normal path.
detectSwappedArgs2 : TcEnv -> Expr -> Expr -> Option Mono
detectSwappedArgs2 env f a2
  | not (isLitArg a2) = None
  | otherwise = match twoArgCallee env f
    None => None
    Some (name, a1, p1, p2) =>
      if not (isLitArg a1) then
        None
      else
        trySwapReport name a1 a2 p1 p2

trySwapReport : String -> Expr -> Expr -> Mono -> Mono -> Option Mono
trySwapReport name a1 a2 p1 p2
  | not (monoConcrete p1 && monoConcrete p2) = None
  | monoSameShape p1 p2 = None                 -- same-type params: order is moot
  | otherwise =
    let inOrder = argLitFits a1 p1 && argLitFits a2 p2
    let swapped = argLitFits a2 p1 && argLitFits a1 p2
    if (not inOrder) && swapped then emitSwapDiag name a1 a2 else None

emitSwapDiag : String -> Expr -> Expr -> Option Mono
emitSwapDiag name a1 a2 = match (renderLitArg a1, renderLitArg a2)
  (Some s1, Some s2) =>
    let swappedCall = "\{name} \{s2} \{s1}"
    let msg = "Arguments to '\{name}' are in the wrong order. Try '\{swappedCall}'"
    let help = "swap the arguments: \{swappedCall}"
    let fix = swapArgFix a1 a2 "\{s2} \{s1}"
    let _ = pushTypeErrorHelpFixAt "T-TYPE-MISMATCH" (orElseLoc (exprLoc a1) currentLoc.value) msg help fix
    let v = freshVar ()
    let _ = poisonMismatchVars v v
    Some v
  _ => None

inferAppExpr : TcEnv -> Expr -> Expr -> Mono
inferAppExpr env f x = match lamUnderLoc x
    Some (loc, pats, body) =>
      let ft = infer env f
      let _ = setLocIfSome loc
      -- ft is `(lamType) -> result`; its FIRST domain is the lambda's expected
      -- type.  Peel that, then peel the lambda type itself for its per-param types.
      let lamExpected = funDomain (normalize ft)
      let xt = inferLamChecked env (expectedParamTypes lamExpected (listLen pats)) pats body
      inferApp (envAlphaLets env) (EApp f x) ft xt
    None => match shadowStandaloneHead env f
      Some (mname, tagRefs) => inferShadowApp env mname tagRefs f x
      None => match definerShadowArgHead f
       Some (dname, dtagRef, dimplRef) => inferDefinerShadowApp env dname dtagRef dimplRef f x
       None => match definerShadowVarHead f
        Some dname => inferDefinerShadowVarApp env dname f x
        None => match detectSwappedArgs2 env f x
         Some swapResult => swapResult
         None =>
          let ft = infer env f
          let xt = infer env x
          -- P0-16: detect `f(1, 2)` on the PRISTINE ft (before inferApp unifies
          -- its domain with the tuple), then record the residual result so a
          -- downstream no-impl / mismatch can surface the tailored hint.
          let pend = tupleCallShapeHint f x ft
          let res = inferApp (envAlphaLets env) (EApp f x) ft xt
          let _ = match pend
            Some (help, fix) => setRef tupleCallCandidates ((res, help, fix)::tupleCallCandidates.value)
            None => ()
          res

-- @Impl: if [x] is an `@Name` disambiguation hint (a bare `EVar "@Name"`, possibly
-- under an ELoc wrapper), return the name with the leading `@` stripped.  Mirrors
-- the two oracle arms `EApp(f, EVar h)` and `EApp(f, ELoc(_, EVar h))` with
-- `h.[0]='@'`.  Anything else → None → the ordinary application path.

-- Bug C (mirror lib/typecheck.ml:2293-2329): peel a single-argument application's
-- head to a standalone-shadow interface-method reference (`toList m` where `toList`
-- is BOTH a Foldable method AND an imported `Map` standalone).  Handles BOTH the
-- MARKED form (`EMethodAt`, the eval/build path — carries a route ref to stamp RLocal)
-- and the UNMARKED form (`EVar`, the `check` path — no route ref; the empty list).
-- Only fires for a SINGLE-param interface method whose name is a registered importer
-- shadow with a stashed standalone scheme — exactly the oracle's guard.  Everything
-- else (no shadow, multi-param iface, non-method head) returns None → the ordinary path.
shadowStandaloneHead : TcEnv -> Expr -> Option (String, List (Ref Route))
shadowStandaloneHead env (ELoc _ f) = shadowStandaloneHead env f
shadowStandaloneHead env (EMethodAt name tagRef _ _)
  | isShadowStandalone name = Some (name, [tagRef])
  | otherwise = None
shadowStandaloneHead env (EVar name)
  | isShadowStandalone name = Some (name, [])
  | otherwise = None
shadowStandaloneHead _ _ = None

-- a name that is BOTH a registered importer shadow (standaloneValuesRef), has a
-- stashed standalone scheme, and names a SINGLE-param interface method.
isShadowStandalone : String -> Bool
isShadowStandalone name = contains name standaloneValuesRef.value
  && isSome (lookupAssoc name shadowStandaloneSchemesRef.value)
  && singleParamIfaceMethod name

-- True iff [name]'s interface (in methodIfaceParamsRef) takes exactly ONE type
-- parameter (the receiver-directed single-arg case the oracle scopes the fallback to).
singleParamIfaceMethod : String -> Bool
singleParamIfaceMethod name = match omLookup name methodIfaceParamsRef.value
  Some (_, typarams, _) => listLen typarams == 1
  None => False

-- Bug C: type `toList m` for a no-impl receiver against the imported STANDALONE
-- scheme (giving the concrete result element type, e.g. `List (String, Int)`) and
-- stamp the route RLocal (when marked); if the receiver DOES have an impl (or its head
-- is not yet concrete) fall through to ordinary dispatch (typed against the method
-- scheme the env rebound the name to).  Mirror of lib/typecheck.ml:2308-2329.
--
-- ✅ S1-RESIDUAL-B CLOSED (2026-07-14).  This function used to have NO groundShadowReceiver
-- call, unlike its definer peer inferDefinerShadowApp (which P0-20 gave one).  An UNGROUNDED
-- receiver — a bare `Num` LITERAL is the everyday case, it is `Num a => a`, not `Int` — so
-- never reached the standalone arm below (headTyconMono is None) and fell to the
-- ordinary-app arm, which types against the METHOD scheme the env rebound the name to.
--
--   -- lib/prov.mdk:  export isEmpty : Int -> Bool
--   import lib.prov.{isEmpty}
--   main = println (debug (isEmpty 0))     -- Type mismatch: Int literal vs Int Int
--
-- The `Int Int` in that message is the tell: the PRELUDE's `Foldable.isEmpty : t a -> Bool`
-- is higher-kinded, so unifying `t a` with the literal's tyvar solved `t := Int, a := Int`.
-- The user's imported `isEmpty : Int -> Bool` was never consulted.  (Filed as "under-applies
-- on run" for a CONSTRAINED standalone; the root is broader — it breaks an UNCONSTRAINED one
-- at `check` too, whenever the shadowed method is higher-kinded.)
--
-- Fix, exactly as filed: ground an ungrounded receiver to the IMPORTED standalone's declared
-- domain BEFORE asking the S2 impl question, so typecheck and the post-inference route
-- resolver ask it about the SAME head.  That symmetry is the whole P0-20 lesson — a decision
-- derived twice, at two different times, over a receiver that changed in between.
--
-- ⚠️ NOT affected by the S2 inversion: an IMPORTER shadow keeps the per-receiver rule
-- (Fork 1).  Grounding only decides WHICH head the rule is applied to; a grounded head with
-- a live impl still dispatches (`isEmpty [1, 2]` → `Foldable.isEmpty`, fixture i4).
inferShadowApp : TcEnv -> String -> List (Ref Route) -> Expr -> Expr -> Mono
inferShadowApp env mname tagRefs f x =
  -- capture the application's loc BEFORE inferring the argument (which moves currentLoc),
  -- so a domain mismatch localizes to the call site, not the argument.
  let dloc = currentLoc.value
  let tx = infer env x
  -- The dict-var carve-out (S5/Fork 2) applies to importer shadows too: a receiver that is
  -- the enclosing fn's `=>`-bound constraint var DISPATCHES through that dict, so it must
  -- NOT be ground to the standalone's domain (that would monomorphise the written signature).
  -- groundShadowReceiver is also inert on an already-grounded receiver, so i1/i3/i4 (all
  -- concrete receivers) are byte-identical.
  let _ = groundShadowReceiver (importerShadowDomain mname) tx (definerReceiverIsDictVar mname tx) dloc
  match headTyconMono tx
    Some head => if implExistsForHead shadowKeyTableRef.value mname head then inferApp (envAlphaLets env) (EApp f x) (infer env f) tx
    else match lookupAssoc mname shadowStandaloneSchemesRef.value
      Some sscheme =>
        let smono = instantiate sscheme
        let r = freshVar ()
        let eff = openRow ()
        let _ = unify smono (TFun tx eff r)
        let _ = performEffect curEffect eff
        let _ = stampRoutes tagRefs
        -- S-1 (Fork D — the importer half): an IMPORTED constrained standalone shadowing
        -- a method breaks identically to a local one (its def is dict-passed in its own
        -- module; this call must supply the dicts).  Compute them off the head type we
        -- just unified, and defer the ROUTE stamp to resolveRLocalSites — stampRoutes
        -- above ran mid-inference, when the receiver is not yet solved, so it could only
        -- write `RLocal sym []`.  forceLocal=True: this arm has already committed the
        -- site's TYPE to the standalone, so its route is not open to re-derivation.
        let _ = recordImporterShadowDicts env mname tagRefs tx
        r
      None => inferApp (envAlphaLets env) (EApp f x) (infer env f) tx
    None => inferApp (envAlphaLets env) (EApp f x) (infer env f) tx

-- S1-RESIDUAL-B: the IMPORTED standalone's declared domain — the first arrow domain of the
-- scheme stashed in shadowStandaloneSchemesRef (the concrete-head pick made per module by
-- checkModuleFullImpl).  The importer peer of shadowDomainFor's mangled arm, and it must NOT
-- be `lookupVar env mname`: env1 rebound the bare name to the interface METHOD, which is the
-- very scheme whose higher-kinded domain caused the bug.
--
-- None (⇒ grounding is a no-op) when the name has no stashed standalone scheme, or when that
-- standalone's own first parameter is itself polymorphic (`f : a -> Bool`) — unifying a bare
-- tyvar domain with an ungrounded receiver leaves it ungrounded anyway, so the caller's
-- headTyconMono still says None and the old ordinary-app arm runs, byte-identically.
importerShadowDomain : String -> Option Mono
importerShadowDomain mname = match lookupAssoc mname shadowStandaloneSchemesRef.value
  None => None
  Some s => match normalize (instantiate s)
    TFun a _ _ => Some a
    _ => None

-- S-1 (importer half): re-record each of the importer shadow's route refs as an
-- RLocalSite carrying the imported standalone's own constraint dicts, so
-- resolveRLocalSites re-stamps the ref post-inference with the dicts filled in.
-- forceLocal=True — inferShadowApp's standalone arm already committed the site's type.
-- Inert (no dicts, same RLocal stamp) for an unconstrained imported standalone.
recordImporterShadowDicts : TcEnv -> String -> List (Ref Route) -> Mono -> Unit
recordImporterShadowDicts _ _ [] _ = ()
recordImporterShadowDicts env mname (r::rest) tx =
  -- the IMPORTED standalone's scheme, NOT `lookupVar env mname` (which env1 rebound to
  -- the interface method) — see shadowStandaloneDictsWith.
  let dicts = shadowStandaloneDictsWith
    (lookupAssoc mname shadowStandaloneSchemesRef.value)
    mname
    (routeLocalSym r.value)
    tx
  let _ = setRef pendingRLocalSites
    (RLocalSite mname r tx (routeLocalSym r.value) True (fst dicts) (snd dicts)
      ::pendingRLocalSites.value)
  recordImporterShadowDicts env mname rest tx

-- P0-18: peel a single-argument application's head to a DEFINER-shadow interface-
-- method occurrence (the user's OWN top-level fn reuses a single-param interface
-- method name, e.g. this module's `size : Int -> Int` shadowing `Sizeable`'s
-- `size`).  Unlike importer shadows (shadowStandaloneHead / inferShadowApp), the
-- user's definition SHADOWS the method in scope, so the occurrence is typed against
-- the standalone scheme whose declared domain (`Int`) is NOT the actual receiver.
-- Returning the route ref lets inferDefinerShadowApp record the REAL argument mono
-- for per-receiver routing (`Box` has a `Sizeable` impl → method; `Int` → standalone).
-- P0-18 (importer residual): on the EMIT path a definer shadow's bare name is NOT
-- in definerShadowNamesRef when the standalone is IMPORTED from another module (that
-- ref is keyed on module-local funDefs).  But the mark pass ALREADY seeded such an
-- occurrence's route with the mangled standalone symbol (`RLocal <sym>`), so a
-- non-empty route symbol is an equally-good "this is a shadow" signal that works
-- cross-module.  Firing here routes the occurrence through inferDefinerShadowApp,
-- which types it against the standalone scheme and records the per-receiver mono —
-- so an importer shadow on a live-impl receiver dispatches to the impl, and one on a
-- no-impl receiver falls back to the standalone (RLocal <sym>), exactly like a
-- definer shadow.  On the un-mangled run/check path the route is RNone (sym ""), so
-- this branch is inert there and the ordinary definerShadowNames branch governs.
definerShadowArgHead : Expr -> Option (String, Ref Route, Ref (List Route))
definerShadowArgHead (ELoc _ f) = definerShadowArgHead f
definerShadowArgHead (EMethodAt name tagRef implRef _)
  | singleParamIfaceMethod name && (contains name definerShadowNamesRef.value || routeLocalSym tagRef.value != "") = Some (name, tagRef, implRef)
  | otherwise = None
definerShadowArgHead _ = None

-- P0-18: type `size (Box 3)` exactly as the ordinary path (against the standalone
-- scheme the env rebound `size` to, preserving program types), but record the
-- ACTUAL argument mono (`Box`) as this site's receiver so resolveRLocalSite routes
-- per-receiver: a receiver head WITH an impl of the shadowed interface dispatches to
-- the method (route left untouched → eval arg-tag / emit RKey), one WITHOUT an impl
-- stays the standalone (RLocal).  suppressRLocalRecord stops recordRLocalSite from
-- ALSO pushing the standalone's declared domain (which would mis-route `Box`→`Int`).
inferDefinerShadowApp : TcEnv -> String -> Ref Route -> Ref (List Route) -> Expr -> Expr -> Mono
inferDefinerShadowApp env name tagRef implRef f x =
  let sym = routeLocalSym tagRef.value
  -- P0-19: capture the application's location BEFORE inferring the argument (which
  -- moves currentLoc), so a standalone-domain mismatch reports at the call site.
  let dloc = currentLoc.value
  -- P0-19 d8 (S2/S6): infer the argument FIRST so the head scheme is chosen PER
  -- RECEIVER.  A receiver with a VISIBLE impl of the shadowed interface (impl universe
  -- is GLOBAL — shadowKeyTableRef spans local ∪ imported ∪ prelude) DISPATCHES → type
  -- the head against the METHOD scheme; else it is the STANDALONE.  Without this the
  -- mangled emit path (sym != "") ALWAYS typed against the standalone scheme
  -- (`Int -> Int`), so a definer shadow whose impl is IMPORTED (`size (Box 3)`, d8)
  -- rejected `Int vs Box` at build/run instead of dispatching to the imported impl.
  let xt = infer env x
  -- P0-19 (constrained-receiver arm): an ungrounded receiver that is a dict-bound
  -- constraint var dispatches through that dict — it must neither be typed against the
  -- standalone scheme nor stamped RLocal (which would send eval/emit to the standalone
  -- and, e.g., apply `sz n = n + 1` to a Bool).
  let isDictVar = definerReceiverIsDictVar name xt
  -- P0-20: ground an ungrounded receiver to the standalone's declared domain BEFORE the
  -- dispatch decision, so typecheck asks the impl question about the SAME head the
  -- post-inference route resolver will.  See groundShadowReceiver.
  let _ = groundShadowReceiver (shadowDomainFor env name sym) xt isDictVar dloc
  let dispatches = definerReceiverDispatches name xt
  let _ = setRef suppressRLocalRecord True
  let _ = setRef suppressArgStamp True
  -- P0-19 d4b: this is an application head (marked EMethodAt on run/build) → keep the
  -- method scheme for per-receiver dispatch; suppress the value-position standalone pin.
  let _ = setRef shadowHeadCtxRef True
  -- P0-18: for the STANDALONE arm, type the head against the STANDALONE scheme.  On the
  -- un-mangled run/check path `infer env f` already resolves the bare name to the
  -- standalone (which shadows the method in scope).  On the EMIT path the bare name
  -- resolves to the interface METHOD scheme instead (the standalone was renamed to
  -- `<mid>__name`), whose result loses the concrete element type — e.g. Map's `toList`
  -- would type `List a` not `List (k, v)`, so a downstream `debug (toList m)` resolves
  -- the WRONG element dict and SIGSEGVs.  When we carry the mangled symbol, instantiate
  -- its (standalone) scheme directly so the impl-body types exactly as the run path
  -- does.  For the DISPATCH arm, type against the METHOD scheme (`definerShadowHeadType
  -- env ""`) so a live-impl receiver unifies and the result comes from the method.
  -- DISPATCH arm: the interface METHOD scheme, fetched EXPLICITLY from
  -- methodIfaceParamsRef (which spans imported interfaces) — NOT `infer env f`, because
  -- on the multi-module path the env rebinds the bare method name to the LOCAL
  -- standalone (`Int -> Int`), so inferMethodAt's lookupVar would hand back `Int -> Int`
  -- and reject a live-impl receiver (`Box`).  STANDALONE arm: the standalone scheme
  -- (mangled sym on the emit path preserves the concrete result type).
  let ft = if dispatches then shadowVarHeadMethodScheme env name f else definerShadowHeadType env sym f
  let _ = setRef shadowHeadCtxRef False
  let _ = setRef suppressRLocalRecord False
  let _ = setRef suppressArgStamp False
  -- S-1: on the STANDALONE arm ONLY, compute that standalone's own `=>`-constraint
  -- dicts (and record its call obligations).  The DISPATCH arm typed `ft` against the
  -- interface METHOD scheme, whose dicts are the method's, not the standalone's — asking
  -- there would be meaningless.  A dict-var receiver dispatches through its dict and is
  -- likewise not the standalone.  ([], []) for an unconstrained standalone.
  let dicts = if dispatches || isDictVar then ([], [])
    else shadowStandaloneDicts env name sym xt
  -- Route by the ACTUAL argument type on BOTH the eval path (pendingRLocalSites,
  -- read by resolveRLocalSites) and the emit path (pendingArgStamps, read by
  -- resolveArgStamps — only recorded when this method arg-dispatches, i.e. on the
  -- build path).  xt grounds to the real receiver post-inference; the two default
  -- pushes (recordRLocalSite / recordArgStamp) that would carry the standalone's
  -- declared domain are suppressed above.
  -- ...EXCEPT for a dict-bound constraint-var receiver: resolveRLocalSite's ungrounded
  -- arm stamps RLocal unconditionally, which would route a genuine dict dispatch to the
  -- shadowing standalone.  Not recording the site leaves the route for ordinary dispatch
  -- (RNone → eval arg-tag / emit RKey via resolveArgStamps).
  -- P0-20: the route FOLLOWS THE ARM (`not dispatches` ⇒ forceLocal).  `ft` above has
  -- already committed this site's TYPE, so re-deriving its route from a receiver mono
  -- that may ground LATER (Num defaulting on an unsignatured standalone) is exactly how
  -- `check` and the binary came to disagree.  A dispatching receiver still re-derives
  -- (its head is already ground; RKey comes from resolveArgStamps on the emit path).
  let _ = if isDictVar then ()
    else setRef pendingRLocalSites
      (RLocalSite name tagRef xt (routeLocalSym tagRef.value) (not dispatches) (fst dicts) (snd dicts)
        ::pendingRLocalSites.value)
  let _ = match argDispatchOf name
    Some _ => setRef pendingArgStamps ((name, tagRef, implRef, xt, currentFn.value)::pendingArgStamps.value)
    None => ()
  -- P0-19: on the UN-MANGLED path (sym == "") `ft` is the permissive METHOD scheme
  -- (`a -> Int`), so `inferApp ft xt` would accept ANY receiver.  When this
  -- occurrence resolves to the STANDALONE — a grounded receiver head with no visible
  -- impl of the shadowed interface, or an ungrounded receiver (S5) — impose the
  -- standalone's DECLARED domain on the argument, so a domain mismatch (`size "hi"`,
  -- or a wrapper generalized over the shadow receiver then called at a live-impl type)
  -- becomes a located reject instead of build-time garbage.  A grounded receiver WITH
  -- an impl still dispatches (no enforcement) — that arm is untouched.  On the mangled
  -- emit path (sym != "") `ft` is already the standalone scheme (definerShadowHeadType),
  -- which enforces the domain itself, so this stays inert there.
  let _ = if sym == "" then enforceStandaloneDomain env name xt dloc else ()
  inferApp (envAlphaLets env) (EApp f x) ft xt

-- S1/S2 (THE INVERSION, 2026-07-14): is [name] a DEFINER shadow — a top-level fn defined in
-- THIS module that reuses a single-param interface method's name?  This is the exact
-- predicate that decides whether the inversion applies (Fork 1: definer-only).
--
-- ⚠️ It is NOT the same question as "did we reach inferDefinerShadowApp".  That entry point
-- (definerShadowArgHead) ALSO fires for an IMPORTER shadow on the mangled emit path, where
-- the mark pass seeded the route with the provider's mangled symbol (`routeLocalSym != ""`)
-- — see its header.  Inverting on that signal would invert importer shadows too, which
-- Fork 1 forbids: it breaks the everyday `import map` pattern (`isEmpty [1,2]` must still
-- reach `Foldable.isEmpty`).  definerShadowNamesRef holds bare names on EVERY path — the
-- emit path recovers a mangled local funDef through the mangle map (buildDefinerShadows) —
-- and never holds an imported standalone, so it is the reliable definer/importer test.
--
-- The singleParamIfaceMethod conjunct mirrors definerShadowVarHead / definerShadowArgHead
-- verbatim, so every entry point agrees on which occurrences the machinery owns.  A
-- multi-TYPARAM interface (`interface Ix a i`) is deliberately still OUT of scope — that is
-- the pre-existing S-3 / row-26 bug (SHADOW-SEMANTICS.md §2), untouched by this change.
isDefinerShadow : String -> Bool
isDefinerShadow name = singleParamIfaceMethod name
  && contains name definerShadowNamesRef.value

-- S2 (THE INVERSION, 2026-07-14; SHADOW-INVERSION-DESIGN.md): True iff the shadow [name]
-- applied to a receiver of type [xt] should DISPATCH to the interface method rather than
-- call the standalone.
--
-- ⚠️ FOR A DEFINER SHADOW THE IMPL UNIVERSE IS NO LONGER CONSULTED.  It used to be: a
-- receiver whose head tycon had a visible impl of the shadowed interface dispatched, and the
-- standalone was only a FALLBACK for a no-impl head.  That rule silently ERASED the user's
-- function —
--
--   eq : List Int -> List Int -> Bool
--   eq a b = True
--   main = println (debug (eq [1] [2]))   -- printed False: `impl Eq List` won
--
-- — and `check --types` did not even report the user's signature.  Since the prelude declares
-- ~49 method names over every common type (`map`, `filter`, `length`, `compare`, `eq`, `min`,
-- `empty`, `toList`, `display`, …), that made the most natural names in the language into
-- landmines.  A top-level name written in a module is now THAT MODULE'S NAME: a definer
-- shadow is the standalone, unconditionally, and the argument must type against the
-- standalone's declared domain (a mismatch is a located reject — S2/S3/S6).
--
-- The ONE carve-out (S5, Fork 2): a receiver that is a dict-bound `=>` constraint var of the
-- enclosing function still DISPATCHES.  Writing `Sz a => …` is an explicit, written-down
-- request to resolve through the interface, and there is currently no other way to name the
-- method inside a shadowing module (SHADOW-SEMANTICS.md §1.1).  A grounded head never
-- normalizes to a TVar, so it correctly answers False for every concrete receiver.
--
-- An IMPORTER shadow reaching here (via definerShadowArgHead's mangled-sym arm) keeps the
-- OLD per-receiver rule — Fork 1.
definerReceiverDispatches : String -> Mono -> Bool
definerReceiverDispatches name xt
  | isDefinerShadow name = definerReceiverIsDictVar name xt
  | otherwise = match headTyconMono xt
    Some head => implExistsForHead shadowKeyTableRef.value name head
    None => definerReceiverIsDictVar name xt

-- P0-19 (constrained-receiver arm): True iff an UNGROUNDED definer-shadow receiver is
-- one of the ENCLOSING group's `=>`-constraint variables for the SHADOWED interface (or
-- a superinterface of it).  Such an occurrence dispatches through that dict — it is a
-- METHOD call, not the standalone — so it must be typed against the method scheme and
-- must NOT have the standalone's declared domain imposed on it.
--
-- Without this, ANY constrained function that calls the method on its own dict-bound
-- var, in a program where some top-level fn shadows that method's name, is silently
-- monomorphised to the shadow's domain.  That includes the PRELUDE's own bodies: on the
-- flat single-file path `prog` is core ++ user, so a user `eq : Int -> Int -> Int`
-- made core's `neq : Eq a => a -> a -> Bool` (`neq x y = not (eq x y)`) infer `eq x y :
-- Int` and reject with `Type mismatch: Bool vs Int` at the top of the user's file.
definerReceiverIsDictVar : String -> Mono -> Bool
definerReceiverIsDictVar name xt = match normalize xt
  TVar cell => match omLookup name methodIfaceParamsRef.value
    Some (mIface, _, _) => dictVarSatisfiesIface mIface (tyvarId cell) groupConstraintMonosRef.value
    None => False
  _ => False

-- does any of the group's constraint vars BOTH normalize to tyvar [id] AND carry an
-- interface whose (self + transitive supers) closure includes [mIface]?
dictVarSatisfiesIface : String -> Int -> List (String, Mono) -> Bool
dictVarSatisfiesIface _ _ [] = False
dictVarSatisfiesIface mIface id ((cIface, cm)::rest)
  | monoIsTyvarId cm id && contains mIface (ifaceSelfAndSupers cIface) = True
  | otherwise = dictVarSatisfiesIface mIface id rest

monoIsTyvarId : Mono -> Int -> Bool
monoIsTyvarId m id = match normalize m
  TVar cell => tyvarId cell == id
  _ => False

-- [iface] plus its transitive `requires` supers (a `Ord a =>` constraint also supplies
-- the `Eq` dict).  Reads superDeclsRef, the program's interface decls; NOT gated on
-- userIfaceNamesRef (unlike superSlotsOf, whose gate is about dict SLOTS, not about
-- which interfaces a constraint satisfies) — a PRELUDE super chain satisfies the
-- superinterface just as much, it is simply serviced by arg-tag dispatch.
ifaceSelfAndSupers : String -> List String
ifaceSelfAndSupers iface = supersFix [iface] [iface]

supersFix : List String -> List String -> List String
supersFix acc [] = acc
supersFix acc frontier =
  let next = removeAllS acc (dedup (flatMap directSupers frontier))
  supersFix (acc ++ next) next

directSupers : String -> List String
directSupers iface = match ifaceSupersOf superDeclsRef.value iface
  None => []
  Some (_, supers) => map superIfaceName supers

superIfaceName : Super -> String
superIfaceName (Super n _) = n

-- P0-19: impose a definer-shadow standalone's declared domain on the actual argument
-- [xt] WHEN the occurrence resolves to the standalone (RLocal).  No declared signature ⇒
-- nothing to enforce (permissive fallback, unchanged).  [dloc] re-points currentLoc at the
-- application so a mismatch localizes to the call, not the argument.
--
-- S2 (THE INVERSION): a definer shadow now ALWAYS resolves to the standalone, so its domain
-- is ALWAYS enforced.  This used to skip enforcement whenever the receiver's grounded head
-- had a visible impl of the shadowed interface — that head dispatched, so no domain applied.
-- That skip is precisely what let `eq [1] [2]` sail through `check` against the PRELUDE's
-- `Eq.eq` while the user's `eq : List Int -> List Int -> Bool` was discarded.  The only
-- surviving exemption is the Fork-2 dict-var carve-out: imposing a concrete domain on the
-- enclosing group's `=>`-constraint var would monomorphise its written signature.
enforceStandaloneDomain : TcEnv -> String -> Mono -> Option Loc -> Unit
enforceStandaloneDomain _ name xt dloc = match standaloneShadowDomain name
  None => ()
  Some dom =>
    if definerReceiverIsDictVar name xt then
      ()
    else
      unifyStandaloneDomain dom xt dloc

-- P0-20 (SILENT WRONG ANSWER, `eq 1 2` → the binary printed 0): typecheck's
-- dispatch-vs-standalone decision and the POST-inference route resolver
-- (resolveRLocalSite) must ask the S2 impl question about the SAME receiver head.
--
-- They did not.  A definer-shadow receiver that is not yet grounded AT INFERENCE TIME —
-- a NUMERIC LITERAL is the everyday case, it is `Num a => a`, not `Int` — took the
-- ungrounded arm (S5 ⇒ standalone) and was typed against the standalone's scheme.  That
-- typing then UNIFIES the standalone's declared domain into the receiver, so by the time
-- resolveRLocalSite runs the receiver IS grounded — to `Int` — and `Int` has `impl Eq
-- Int`, so the route resolver left the site to DISPATCH.  Result: `check` typed
-- `eq 1 2 : Int` (the user's `eq : Int -> Int -> Int`) while eval/emit called the
-- interface method and produced a `Bool` — `run` panicked (`intToString: not an Int`)
-- and `build` SILENTLY PRINTED 0.  Only literal receivers were affected: `f k = eq k 1`
-- (k : Int, already grounded) dispatched consistently on all three paths.
--
-- Fix: perform S5's monomorphisation FIRST (it is the same unification the standalone
-- arm would have done, only earlier), then decide.  With the receiver grounded to `Int`,
-- S2 sees the impl and DISPATCHES on every path — check == run == build.  A grounded
-- receiver, a dict-bound one, and an unsignatured standalone (no domain to ground to)
-- are all untouched; so is a standalone whose domain head has NO impl of the shadowed
-- interface (map's `toList : Map k v -> …` — there is deliberately no `impl Foldable
-- Map`), which is every definer shadow in the tree.
--
-- [dom] MUST come from shadowDomainFor, not standaloneShadowDomain: on the MANGLED emit
-- path the standalone was renamed `<mid>__eq`, so the bare-name sig table is empty there
-- and grounding would be silently inert — which is not a no-op, it flips the emit path to
-- the STANDALONE arm while check/run dispatch.  (Observed: `build` printed 3, `run`
-- printed False.)  Same bug, other direction.
groundShadowReceiver : Option Mono -> Mono -> Bool -> Option Loc -> Unit
groundShadowReceiver dom xt isDictVar dloc
  | isDictVar = ()
  | isSome (headTyconMono xt) = ()
  | otherwise = match dom
    None => ()
    Some d => unifyStandaloneDomain d xt dloc

-- P0-20: the definer-shadow standalone's declared domain, resolved on EITHER path.
-- Un-mangled run/check (sym == ""): the module's own sig table, keyed by the bare name.
-- Mangled emit (sym != ""): private_mangle renamed the standalone to `<mid>__name`, so
-- definerShadowSigsRef has no `name` entry — take the domain off the env binding for the
-- mangled symbol, which is the very scheme definerShadowHeadType types this site against.
shadowDomainFor : TcEnv -> String -> String -> Option Mono
shadowDomainFor _ name "" = standaloneShadowDomain name
shadowDomainFor env _ sym = match lookupVar env sym
  None => None
  Some s => match normalize (instantiate s)
    TFun a _ _ => Some a
    _ => None

-- unify the standalone domain against the argument at the call's location.
unifyStandaloneDomain : Mono -> Mono -> Option Loc -> Unit
unifyStandaloneDomain dom xt dloc =
  let _ = setRef currentLoc dloc
  unify dom xt

-- a definer-shadow standalone's declared parameter type, freshly instantiated (so a
-- polymorphic standalone domain does not leak vars across sites).  None when there is
-- no top-level signature, or the signature is not a function type.
standaloneShadowDomain : String -> Option Mono
standaloneShadowDomain name = match lookupAssoc name definerShadowSigsRef.value
  None => None
  Some ty => match normalize (instantiate (sigToScheme ty))
    TFun a _ _ => Some a
    _ => None

-- P0-19 d4b (S4): a definer-shadow occurrence in bare VALUE position (NOT the head of
-- its own application — shadowHeadCtxRef is False) denotes the STANDALONE.  Returns the
-- standalone's declared scheme freshly instantiated so a HOF sees `Int -> Int`, not the
-- permissive method scheme `a -> Int` — making `map size [Box …]` a located reject
-- (Box vs Int) while `map size [1,2,3]` still accepts.  Only fires for a single-param
-- interface-method name that is a module-local standalone WITH a declared signature;
-- everything else (app head, non-shadow, unsignatured standalone) returns None → the
-- ordinary env lookup / method scheme, unchanged.
maybeStandaloneValueMono : String -> Option Mono
maybeStandaloneValueMono name
  | shadowHeadCtxRef.value = None
  | not (singleParamIfaceMethod name) = None
  | not (contains name definerShadowNamesRef.value) = None
  | otherwise = standaloneShadowScheme name

-- P0-19: a definer-shadow standalone's full declared scheme (`Int -> Int`), freshly
-- instantiated.  None when the standalone has no top-level signature (nothing to pin —
-- the permissive fallback stays).  Used both for value-position pinning (d4b) and to
-- type a standalone-fallback application against the standalone's result type (d8).
standaloneShadowScheme : String -> Option Mono
standaloneShadowScheme name = map
  (ty => instantiate (sigToScheme ty))
  (lookupAssoc name definerShadowSigsRef.value)

-- P0-19: peel an application head to a definer-shadow interface-method occurrence on
-- the UN-MARKED path (the `check` pipeline runs no marker, so the head is a bare
-- `EVar`, not the `EMethodAt` that definerShadowArgHead matches on run/build).  Same
-- guard as definerShadowArgHead: a single-param interface method whose name is a
-- module-local standalone (definerShadowNamesRef).
definerShadowVarHead : Expr -> Option String
definerShadowVarHead (ELoc _ f) = definerShadowVarHead f
definerShadowVarHead (EVar name)
  | singleParamIfaceMethod name && contains name definerShadowNamesRef.value =
    Some name
  | otherwise = None
definerShadowVarHead _ = None

-- S2 (THE INVERSION): type an un-marked (check-path) definer-shadow application against
-- the module's OWN standalone, unconditionally.  Peer of inferDefinerShadowApp (the marked
-- run/build path); the two must agree cell-for-cell or `check` and the binary diverge (S7),
-- which is the bug class this whole arc keeps producing.
--
-- The receiver's impl universe is no longer consulted (see definerReceiverDispatches).  The
-- sole dispatch arm left is the Fork-2 carve-out: a dict-bound `=>` constraint var, which is
-- an explicit written request to resolve through the interface.  Everything else — grounded
-- live-impl head included — types against the LOCAL standalone scheme, so a domain mismatch
-- (`size (Box 3)` against `size : Int -> Int`) is a located reject at the call, not a silent
-- dispatch that erases the user's function.
inferDefinerShadowVarApp : TcEnv -> String -> Expr -> Expr -> Mono
inferDefinerShadowVarApp env name f x =
  let dloc = currentLoc.value
  let xt = infer env x
  let isDictVar = definerReceiverIsDictVar name xt
  -- P0-20: ground an ungrounded receiver to the standalone's declared domain BEFORE the
  -- dispatch decision (see groundShadowReceiver).  Still load-bearing under the inversion:
  -- it is what gives a bare `Num` literal receiver (`eq 1 2`) the standalone's domain
  -- rather than leaving it open for Num-defaulting to ground LATER, behind typecheck's back.
  let _ = groundShadowReceiver (standaloneShadowDomain name) xt isDictVar dloc
  if isDictVar then
    inferApp (envAlphaLets env) (EApp f x) (shadowVarHeadMethodScheme env name f) xt
  else
    inferDefinerStandaloneVarApp env name f x xt dloc

-- P0-19 (d8 dispatch arm): the interface METHOD scheme for [name], from
-- methodIfaceParamsRef (which spans imported interfaces) so per-receiver dispatch works
-- even when the multi-module env has rebound the bare name to the local standalone.
-- Falls back to `infer env f` (flagged as an app head so maybeStandaloneValueMono does
-- not pin it) when the method type is unavailable.
shadowVarHeadMethodScheme : TcEnv -> String -> Expr -> Mono
shadowVarHeadMethodScheme env name f = match omLookup name methodIfaceParamsRef.value
  Some (_, _, ty) => instantiate (sigToScheme ty)
  None =>
    let _ = setRef shadowHeadCtxRef True
    let ft = infer env f
    let _ = setRef shadowHeadCtxRef False
    ft

-- P0-19 (standalone arm): type the application against the LOCAL standalone scheme so
-- the result is the standalone's (S2/S5); a domain mismatch (`size "hi"`) or a wrapper
-- generalized over the shadow receiver then called at a foreign type localizes to the
-- call [dloc].  No declared signature ⇒ fall back to the permissive method-scheme head
-- + enforceStandaloneDomain (the pre-P0-19 permissive behavior, unchanged).
inferDefinerStandaloneVarApp : TcEnv -> String -> Expr -> Expr -> Mono -> Option Loc -> Mono
inferDefinerStandaloneVarApp env name f x xt dloc = match standaloneShadowScheme name
  Some smono =>
    let r = freshVar ()
    let eff = openRow ()
    let _ = setRef currentLoc dloc
    let _ = unify smono (TFun xt eff r)
    let _ = performEffect curEffect eff
    -- S-1 (REJECT direction).  standaloneShadowScheme instantiates the DECLARED SIG via
    -- sigToScheme, which DROPS the `=>` constraints entirely — so `Num String` was never
    -- asked and `check` ACCEPTED `size "hi"` against `size : Num a => a -> a`.  Re-read
    -- the constraints off the signature and record them as call obligations at the
    -- receiver, which makes it a located reject.  (This arm has a signature by
    -- construction; the no-signature arm below goes through `infer env f` → inferVarPlain
    -- → instantiateVarTracked, the ordinary obligation path.)
    let _ = recordStandaloneSigObligations name "" xt
    r
  None =>
    let _ = setRef shadowHeadCtxRef True
    let ft = infer env f
    let _ = setRef shadowHeadCtxRef False
    let _ = enforceStandaloneDomain env name xt dloc
    inferApp (envAlphaLets env) (EApp f x) ft xt

-- P0-18: the type of a definer-shadow application HEAD.  With a mangled symbol (the
-- emit path), instantiate the standalone's own scheme (bound under `<mid>__name`) so
-- the concrete result type survives; else infer the head node (the un-mangled path,
-- where the bare name already resolves to the standalone).
definerShadowHeadType : TcEnv -> String -> Expr -> Mono
definerShadowHeadType env "" f = infer env f
definerShadowHeadType env sym f = match lookupVar env sym
  Some s => instantiate s
  None => infer env f

-- stamp every route ref (one for the marked EMethodAt form, none for the unmarked
-- check-path EVar form) RLocal.  S-1: the standalone's own constraint dicts are NOT
-- resolvable here (inference has not solved the receiver yet) — the caller ALSO pushes
-- an RLocalSite so resolveRLocalSites re-stamps the same ref with the filled dicts
-- post-inference.  An unconstrained standalone never gets a second stamp that differs.
stampRoutes : List (Ref Route) -> Unit
stampRoutes [] = ()
stampRoutes (r::rest) =
  let _ = setRef r (RLocal (routeLocalSym r.value) [])
  stampRoutes rest

-- ── S-1: the shadowing standalone's OWN constraint dicts ──────────────────────
-- A `=>`-constrained top-level fn whose name collides with a visible interface method
-- (`eq : Num a => a -> a` vs the prelude's `Eq.eq`) sits in BOTH the shadow name set
-- and the dict name set.  The marking prePass is a first-match guard chain whose shadow
-- arm is tested FIRST, so the occurrence becomes `EMethodAt`, never `EDictAt` — and no
-- dict is ever computed for it.  But `dictPassDecl` (keyed on the same dict name set)
-- still prepends the dict PARAM to the definition.  Def arity 2, call arity 1 ⇒ the
-- call silently UNDER-APPLIES and the first real argument lands in the dict slot.
--
-- So: when a shadow occurrence resolves to the STANDALONE arm, compute that
-- standalone's constraint slots here — the shadowed interface decides WHICH function,
-- the standalone's own constraints decide WHICH DICTS (clause S9).
--
-- [xt] is the RECEIVER's mono.  We take a tracked instantiation of the standalone's own
-- scheme and unify it with `xt -> <fresh>`, which pins the standalone's constraint
-- variable to the receiver exactly as inferApp will pin the site's real head — so the
-- subst maps each constraint id to whatever that constraint variable becomes at THIS
-- call.  The fresh result var is a throwaway: it does NOT re-type the site (the caller's
-- own `ft`/`inferApp` still owns the site's type), it only ties the dict to the receiver.
--
-- ⚠️ Unify against the RECEIVER, not against the caller's head type `ft`.  On the
-- UN-MANGLED path `ft` is the permissive interface-METHOD scheme, not the standalone's
-- (the two doc-comments in inferDefinerShadowApp contradict each other on this; `:5050`
-- is the correct one).  Unifying the standalone's `a -> a` against the method's
-- `a -> a -> Bool` is an OCCURS-CHECK failure — "Cannot construct infinite type" on the
-- perfectly legal `eq : Num a => a -> a`.  The receiver is common to both.
--
-- Returns the slot-ordered (monos, ifaces) that routesOfMonosTop turns into Routes, and
-- records the call's impl obligations so `size "hi"` (⇒ `Num String`, which has no
-- impl) becomes a LOCATED REJECT at `check` instead of build-time garbage — the second,
-- independent hole in this same arm.  ([] , []) for an unconstrained standalone, which
-- SHORT-CIRCUITS BEFORE THE UNIFY, so an unconstrained shadow (all 5 of the compiler's
-- own) does not even perturb the substitution — the fixpoint provably cannot move.
shadowStandaloneDicts : TcEnv -> String -> String -> Mono -> (List Mono, List String)
shadowStandaloneDicts env name sym xt =
  -- P0-20's sym-awareness lesson, mirrored: on the mangled emit path the standalone is
  -- bound under `<mid>__name`, so a BARE-name lookup here would be silently inert and
  -- `build` would emit the un-dicted call while run/check dicted correctly — the same
  -- bug, mirrored.  shadowDomainFor exists for exactly this reason.
  shadowStandaloneDictsWith (lookupVar env (if sym == "" then name else sym)) name sym xt

-- as shadowStandaloneDicts, but with the standalone's scheme supplied explicitly.
-- The IMPORTER shadow needs this: in the importing module `env1` deliberately rebinds the
-- bare name to the polymorphic INTERFACE-METHOD scheme (that rebinding is the entire
-- reason shadowStandaloneSchemesRef exists), so `lookupVar env name` hands back the
-- METHOD — whose quantified ids are not the ones funConstraintsRef recorded for the
-- imported standalone, so every dict slot silently resolves to nothing.  That is why the
-- importer shadow was correct on `build`/`wasm` (which reach the standalone through the
-- MANGLED symbol) and still under-applied on `run`.
shadowStandaloneDictsWith : Option Scheme -> String -> String -> Mono -> (List Mono, List String)
shadowStandaloneDictsWith mscheme name sym xt =
  let _ = recordStandaloneSigObligations name sym xt
  shadowStandaloneDictSlotsAt mscheme (if sym == "" then name else sym) xt

-- the dict slots ONLY — no call obligations.
-- recordRLocalSite needs this: it fires for EVERY shadow method occurrence, at a point
-- where the standalone-vs-dispatch choice is NOT yet made (resolveRLocalSite decides it
-- post-inference from the grounded receiver).  Recording an obligation here would fire on
-- the DISPATCH arm too and spuriously reject `size (Box 3)` with `Num Box`.  When the
-- receiver does turn out to have an impl, stampRLocalOrFallback simply discards these
-- slots and the route dispatches as before.
shadowStandaloneDictSlotsAt : Option Scheme -> String -> Mono -> (List Mono, List String)
shadowStandaloneDictSlotsAt mscheme key xt =
  let slots = declaredConstraintSlots key
  -- REJECT direction — from the SIGNATURE, NOT from schemeObligationsRef.
  -- ⚠️ For a SIGNATURED binding the two obligation tables live in DIFFERENT ID SPACES:
  -- funConstraintsRef's ids (and the env scheme's quantified ids) come from
  -- sigToSchemeTvs over the declared signature, while schemeObligationsRef's come from
  -- GENERALIZATION.  Mapping the latter's ids through the former's substitution silently
  -- finds nothing — which is why the dict ROUTES resolved correctly (they use
  -- funConstraintsRef) while the obligation stayed unrecorded and `size "hi"` was
  -- ACCEPTED.  The signature is the one source both halves can agree on.
  -- the unconstrained standalone: nothing to solve, no unify, no perturbation at all.
  -- This short-circuit is what makes the change provably fixpoint-safe — all 5 of the
  -- compiler's own definer shadows are unconstrained and never reach the unify below.
  if isEmptyL (fst slots) then ([], [])
  else match mscheme
    None => ([], [])
    Some s =>
      let inst = instantiateTracked s
      let r = freshVar ()
      let eff = openRow ()
      let _ = unify (fst inst) (TFun xt eff r)
      shadowStandaloneDictSlots slots (snd inst)

-- the standalone's dict ROUTE slots for this call: its declared constraint ids mapped
-- through the call's instantiation subst.  Expanded with transitive supers EXACTLY as
-- inferDictAtFound does (WS-1b) — dictArityOf sizes the DEFINITION's leading dict params
-- from the same expanded table, so call and def must agree slot-for-slot or we have
-- merely moved the arity disagreement.  Empty on the plain `check` path
-- (funConstraintsRef is empty there) — check stamps no routes, so that is correct;
-- recordStandaloneSigObligations is what gives `check` its reject direction.
shadowStandaloneDictSlots : (List Int, List String) -> List (Int, Mono) -> (List Mono, List String)
shadowStandaloneDictSlots slots subst =
  if isEmptyL (fst slots) then ([], [])
  else
    let expanded = expandSupersPairs superDeclsRef.value (zipL (snd slots) (fst slots))
    (constraintMonosOf (map snd expanded) subst, map fst expanded)

-- ── S-1, REJECT direction on the plain `check` path ───────────────────────────
-- Record the standalone's declared `=>` constraints as CALL obligations, resolved from
-- its own SIGNATURE.
--
-- ⚠️ Why the SIGNATURE and not schemeObligationsRef: for a signatured binding those are
-- two different ID SPACES (sigToSchemeTvs's fresh quantification vs generalization's), so
-- schemeObligationsRef's ids are not keys of the env scheme's instantiation subst and
-- recordSchemeCallObligations silently records nothing.  That is exactly why the dict
-- ROUTES came out right (they key off funConstraintsRef, which IS the signature's id
-- space) while `check` still ACCEPTED `size "hi"` (⇒ `Num String`, which has no impl).
--
-- ⚠️ sigToSchemeTvs's `tvs` are the scheme's BOUND tyvars, and `instantiate` RE-freshens
-- them — so unifying the *instantiated* type against the receiver does not touch `tvs` at
-- all.  We must instantiateTracked and map each constraint tyvar's ID through the subst,
-- which is precisely what that function's own doc-comment prescribes ("so a caller can
-- recover the id of a specific constraint variable … a call-site instantiation's subst
-- maps them").  Getting this wrong records nothing and reads as "the fix does not work".
--
-- Keyed by the BARE name on the un-mangled run/check path and by the MANGLED symbol on
-- the emit path (sigsOf runs over the already-renamed decls there) — try both, exactly as
-- shadowDomainFor has to.
recordStandaloneSigObligations : String -> String -> Mono -> Unit
recordStandaloneSigObligations name sym xt = match standaloneShadowSigTy name sym
  None => ()
  Some ty => match sigConstraintsOf ty
    [] => ()
    cs =>
      let pr = sigToSchemeTvs ty
      let inst = instantiateTracked (fst pr)
      let r = freshVar ()
      let eff = openRow ()
      let _ = unify (fst inst) (TFun xt eff r)
      recordSigConstraintObls cs (snd pr) (snd inst)

-- the standalone's declared signature Ty, under whichever key this path stores it.
standaloneShadowSigTy : String -> String -> Option Ty
standaloneShadowSigTy name sym = match lookupAssoc name definerShadowSigsRef.value
  Some ty => Some ty
  None => if sym == "" then None else lookupAssoc sym definerShadowSigsRef.value

-- every `=>` constraint in the signature.  Recurses the spine like constraintVarNamesTy
-- rather than matching only the top node, so an effect-annotated sig still yields them.
sigConstraintsOf : Ty -> List Constraint
sigConstraintsOf (TyConstrained cs t) = cs ++ sigConstraintsOf t
sigConstraintsOf (TyEffect _ _ t) = sigConstraintsOf t
sigConstraintsOf _ = []

-- one obligation per (iface, constraint tyvar) in the signature, at that tyvar's mono in
-- THIS call's instantiation.  A constraint over something other than a plain tyvar, or a
-- tyvar absent from either map, records nothing (never over-rejects).
recordSigConstraintObls : List Constraint -> List (String, Mono) -> List (Int, Mono) -> Unit
recordSigConstraintObls [] _ _ = ()
recordSigConstraintObls ((Constraint iface args)::rest) tvs subst =
  let _ = recordSigConstraintArgs iface args tvs subst
  recordSigConstraintObls rest tvs subst

recordSigConstraintArgs : String -> List Ty -> List (String, Mono) -> List (Int, Mono) -> Unit
recordSigConstraintArgs _ [] _ _ = ()
recordSigConstraintArgs iface (a::rest) tvs subst =
  let _ = match constraintArgVarName a
    Some v => match lookupAssoc v tvs
      Some tv => match lookupAssocI (monoTyvarId tv) subst
        Some m => pushCallObl (iface, m, currentLoc.value)
        None => ()
      None => ()
    None => ()
  recordSigConstraintArgs iface rest tvs subst

-- the tyvar NAME a constraint argument mentions (`Num a` → "a"); None for a non-tyvar
-- argument (a concrete head), which carries no per-call obligation here.
constraintArgVarName : Ty -> Option String
constraintArgVarName (TyVar v) = Some v
constraintArgVarName _ = None

-- set currentLoc only when the lambda carried a span (mirror the ELoc arm), so
-- a bare unlocated lambda doesn't blank out an enclosing position.
setLocIfSome : Option Loc -> Unit
setLocIfSome None = ()
setLocIfSome (Some l) = setRef currentLoc (Some l)

-- peek through an ELoc wrapper to a lambda; returns its loc, params and body.
-- Non-lambda arguments (the common case) take the ordinary inference path.
lamUnderLoc : Expr -> Option (Option Loc, List Pat, Expr)
lamUnderLoc (ELam pats body) = Some (None, pats, body)
lamUnderLoc (ELoc l (ELam pats body)) = Some (Some l, pats, body)
lamUnderLoc _ = None

-- the function's first parameter type (the lambda's expected type), or a fresh
-- var when `ft` is not yet a concrete arrow (then nothing is pushed; the trailing
-- `unify ft (TFun xt …)` reconciles).
funDomain : Mono -> Mono
funDomain (TFun a _ _) = a
funDomain _ = freshVar ()

-- peel up to `n` arrow domains off the (normalized) lambda's expected type; those
-- domains are the lambda's expected PARAM types.  Stops early if it is not (yet)
-- an arrow — those params fall back to a fresh var in inferLamChecked, and the
-- trailing `unify ft (TFun xt …)` reconciles them.
expectedParamTypes : Mono -> Int -> List Mono
expectedParamTypes _ 0 = []
expectedParamTypes (TFun a _ b) n =
  a :: expectedParamTypes (normalize b) (n - 1)
expectedParamTypes _ _ = []

-- like inferLam, but each lambda param is unified with the corresponding expected
-- param type (from the function being applied) right after inferPat — so the body
-- and the hover side-channel see the expected type, not a bare fresh var.
inferLamChecked : TcEnv -> List Mono -> List Pat -> Expr -> Mono
inferLamChecked env expected pats body =
  let pr = inferPats env pats
  let _ = unifyParamsExpected (fst pr) expected
  let saved = curEffect.value
  let _ = setRef curEffect (openRow ())
  let bodyTy = infer (extendVars env (snd pr)) body
  let bodyEff = curEffect.value
  let _ = setRef curEffect saved
  arrowsWithLastEffect (fst pr) bodyEff bodyTy

-- unify each param type with its expected type, for the prefix both lists cover.
unifyParamsExpected : List Mono -> List Mono -> Unit
unifyParamsExpected (p::ps) (e::es) =
  let _ = unify p e
  unifyParamsExpected ps es
unifyParamsExpected _ _ = ()

-- Chunk C: recover the ultimate callee name of an application spine (the
-- leftmost head), stripping transparent wrappers.  `None` when the head is not
-- a plain variable (so no name to blame in an over-application message).
appSpineName : Expr -> Option String
appSpineName (ELoc _ e) = appSpineName e
appSpineName (EDoOrigin _ e) = appSpineName e
appSpineName (EAnnot e _) = appSpineName e
appSpineName (EApp f _) = appSpineName f
appSpineName (EVar n) = Some n
appSpineName (EVarAt n _) = Some n
appSpineName _ = None

-- Chunk C: number of arguments applied in this spine (`f a b c` ⇒ 3).
appSpineArgCount : Expr -> Int
appSpineArgCount (ELoc _ e) = appSpineArgCount e
appSpineArgCount (EDoOrigin _ e) = appSpineArgCount e
appSpineArgCount (EAnnot e _) = appSpineArgCount e
appSpineArgCount (EApp f _) = 1 + appSpineArgCount f
appSpineArgCount _ = 0

-- Chunk C messages (T-NOT-A-FUNCTION): a value of a ground non-function type is
-- being applied.  Base wording names the offending type; the context-aware
-- form names the over-applied callee and its arity.
notAFunctionMsg : String -> String
notAFunctionMsg tyName = "This expression has type \{tyName}, which is not a function, so it cannot be applied to an argument."

-- F-dimension actionable-fix hint appended to `notAFunctionMsg` (2026-07-04):
-- names the offending value when the spine head is a plain variable, else
-- falls back to a name-free phrasing.  No mechanical `fix` — the caller
-- decides whether to drop the argument or call a different function.
notAFunctionHint : Option String -> String
notAFunctionHint (Some name) = " '\{name}' is a value, not a function; remove the argument, or call a function here."
notAFunctionHint None = " This is a value, not a function; remove the argument, or call a function here."

overAppliedMsg : String -> Int -> Int -> String
overAppliedMsg name takes applied = "'\{name}' takes \{intToString takes} argument(s) but is applied to \{intToString applied}."

-- Batch B #6 reframe (2026-07-04): a container-consuming HOF whose next declared
-- parameter is a higher-kinded container `f a` (an unresolved tyvar head applied
-- to an element, i.e. `TApp (TVar …) elem`) is being handed a SCALAR argument —
-- a bare arity-0 type (`String`/`Int`/…) that has no element slot for `f` to
-- bind.  Left to the generic `unify (f a) String` sink it leaks a raw
-- tyvar-application `Type mismatch: a b vs String`.  This detector recognises the
-- shape UPSTREAM (in inferApp, where the callee name + arg loc are still in
-- scope) so the diagnostic can be reframed as container-vs-scalar.  SOUND: a
-- `TApp _ _ ~ TCon n` unification can only ever FAIL — a genuine container arg is
-- itself a `TApp` (`List a`, `Maybe a`, …) and would UNIFY the element, never
-- reaching a mismatch; the reframe therefore never hijacks a legitimate
-- higher-kinded mismatch.  Returns the scalar type's name when it fires.
containerParamScalarArg : Mono -> Mono -> Option String
containerParamScalarArg ft xt = match normalize ft
  TFun dom _ _ => match normalize dom
    TApp _ _ => match monoHeadCon dom
      None => match normalize xt
        TCon n => Some n
        _ => None
      Some _ => None
    _ => None
  _ => None

containerArgMsg : Option String -> String -> String
containerArgMsg fn argTy =
  let who = match fn
    Some n => "'\{n}'"
    None => "This function"
  "\{who} expects a container (like List or Array) here, but got \{argTy}\{containerArgHint argTy}"

-- Actionable-fix hint appended to `containerArgMsg`.  Special-cases `String`
-- (the most common scalar handed to `map`): a String's characters are reachable
-- via `string.toChars`, so name that conversion rather than a generic one.
containerArgHint : String -> String
containerArgHint "String" = ". Pass a List or Array; to work over a string's characters, convert it with `string.toChars` first."
containerArgHint argTy =
  ". Pass a List or Array, or convert the \{argTy} to one first."
-- P0-16 beginner call-syntax hint.  A newcomer writes `add(1, 2)` (C/Python/JS
-- call syntax) meaning `add 1 2`; in Medaka `(1, 2)` is a TUPLE, so `add(1, 2)`
-- applies `add` to ONE tuple argument → a partial application / no-impl error
-- whose message ("No impl of Display for ((Int, Int) -> (Int, Int))") is
-- inscrutable.  We DETECT the shape at the application site — a curried arity-N
-- function applied to a single arity-N tuple literal whose first param is NOT
-- itself an N-tuple — and record the residual result type as a candidate; the
-- no-impl + type-mismatch surface sites then append the tailored hint when the
-- offending type IS that residual.  Recording is generous (a legitimate partial
-- application like `map (const (1, 2)) xs` also records) but the hint is only
-- ever ATTACHED to a genuine downstream error, so a legit partial application —
-- whose residual is consumed WITHOUT error — never shows it.  (residualMono,
-- help, optional (span, replacement) fix); reset by resetState.
tupleCallCandidates : Ref (List (Mono, String, Option (Loc, String)))
tupleCallCandidates = Ref []

-- number of leading `->` arrows in a (normalized) type — its curried arity.
funArity : Mono -> Int
funArity m = match normalize m
  TFun _ _ r => 1 + funArity r
  _ => 0

-- the elements of a tuple-literal argument (through the transparent ELoc wrapper).
tupleArgElems : Expr -> Option (List Expr)
tupleArgElems (ELoc _ e) = tupleArgElems e
tupleArgElems (ETuple es) = Some es
tupleArgElems _ = None

-- True iff [ft]'s first parameter is itself an arity-[n] tuple type — the genuine
-- "the tuple IS the intended single argument" shape (e.g. `f (a, b) c = …`), which
-- must NOT be flagged.  Read on the PRISTINE ft (before inferApp unifies its domain
-- with the tuple arg), so the domain here is the declared param type.
domainIsTupleOfArity : Mono -> Int -> Bool
domainIsTupleOfArity ft n = match normalize ft
  TFun dom _ _ => match monoHeadCon dom
    Some c => c == "__tuple\{intToString n}__"
    None => False
  _ => False

-- render a tuple element to source-ish text for the `add 1 2` fix, for the simple
-- literal/var/negation cases; None for anything a full printer would be needed for.
renderCallArg : Expr -> Option String
renderCallArg (ELoc _ e) = renderCallArg e
renderCallArg (EAnnot e _) = renderCallArg e
renderCallArg (ENumLit n _ _) = Some (intToString n)
renderCallArg (ELit (LInt n)) = Some (intToString n)
renderCallArg (ELit (LBool True)) = Some "True"
renderCallArg (ELit (LBool False)) = Some "False"
renderCallArg (ELit (LString s)) = Some ("\"" ++ s ++ "\"")
renderCallArg (ELit (LChar c)) = Some ("'" ++ c ++ "'")
renderCallArg (EVar n) = Some n
renderCallArg (EUnOp "-" e _) = map ("-" ++ _) (renderCallArg e)
renderCallArg _ = None

-- all-or-nothing render of every tuple element.
renderCallArgs : List Expr -> Option (List String)
renderCallArgs [] = Some []
renderCallArgs (e::rest) = match renderCallArg e
  None => None
  Some s => map (s :: _) (renderCallArgs rest)

-- source span covering the whole `name(args)` call: callee start → tuple end.
tupleCallSpanLoc : Expr -> Expr -> Option Loc
tupleCallSpanLoc f x = match (exprLoc f, exprLoc x)
  (Some (Loc file sl sc _ _), Some (Loc _ _ _ el ec)) =>
    Some (Loc file sl sc el ec)
  _ => None

-- build the (help, optional fix) for a detected tuple-call.  The help names the
-- rule (Medaka calls with spaces, `(…)` is a tuple) and gives the exact rewrite;
-- when every element renders, a machine-applicable `fix` rewrites `add(1, 2)` →
-- `add 1 2` verbatim.  ERROR-QUALITY: located (caller sets loc), names the issue,
-- actionable fix, carries a code (T-NO-IMPL / T-TYPE-MISMATCH at the surface site).
buildTupleCallHint : String -> List Expr -> Expr -> Expr -> (String, Option (Loc, String))
buildTupleCallHint name es f x = match renderCallArgs es
  Some parts =>
    let argsCsv = joinWith ", " parts
    let argsSpaced = joinWith " " parts
    let spread = "\{name} \{argsSpaced}"
    let help = "Medaka calls functions with spaces, not parentheses: `\{name}(\{argsCsv})` applies `\{name}` to one tuple `(\{argsCsv})`. Did you mean `\{spread}`?"
    let fix = map (span => (span, spread)) (tupleCallSpanLoc f x)
    (help, fix)
  None =>
    let n = listLen es
    let help = "Medaka calls functions with spaces, not parentheses: `\{name}(…)` passes a single \{intToString n}-tuple, not \{intToString n} arguments. Separate them with spaces, e.g. `\{name} x y`."
    (help, None)

-- detect the tuple-call shape on the PRISTINE ft (before inferApp) and return the
-- (help, fix) to record against the residual result type, else None.  Fires only
-- when the argument is a tuple literal of arity N ≥ 2, the callee has curried arity
-- EXACTLY N (spreading the tuple would saturate it), and its first param is not
-- itself an N-tuple (the genuine tuple-arg case), and the callee is a named spine.
tupleCallShapeHint : Expr -> Expr -> Mono -> Option (String, Option (Loc, String))
tupleCallShapeHint f x ft = match tupleArgElems x
  None => None
  Some es =>
    let n = listLen es
    if n < 2 then
      None
    else if funArity ft != n then
      None
    else if domainIsTupleOfArity ft n then
      None
    else
      map (name => buildTupleCallHint name es f x) (appSpineName f)

-- surface-site lookup: does [m] (a type appearing in a no-impl / mismatch error)
-- equal a recorded tuple-call residual?  Compared by normalized rendering — the
-- residual IS the very type that flows into the error, so they render identically.
tupleCallHintFor : Mono -> Option (String, Option (Loc, String))
tupleCallHintFor m =
  findTupleCand (ppMono (normalize m)) tupleCallCandidates.value

findTupleCand : String -> List (Mono, String, Option (Loc, String)) -> Option (String, Option (Loc, String))
findTupleCand _ [] = None
findTupleCand key ((res, help, fix)::rest)
  | ppMono (normalize res) == key = Some (help, fix)
  | otherwise = findTupleCand key rest

-- first tuple-call hint matching any of the offending types in an error.
firstTupleCallHint : List Mono -> Option (String, Option (Loc, String))
firstTupleCallHint [] = None
firstTupleCallHint (m::rest) = match tupleCallHintFor m
  Some hf => Some hf
  None => firstTupleCallHint rest

inferApp : List (String, Expr) -> Expr -> Mono -> Mono -> Mono
inferApp lets appExpr ft xt =
  let r = freshVar ()
  -- Chunk C: if the callee normalizes to a concrete NON-arrow head (a known type
  -- constructor like `Int`/`List Int`, never a tyvar or an arrow), applying it
  -- is genuinely impossible.  Emit a context-aware `T-NOT-A-FUNCTION` instead of
  -- letting `unify ft (TFun …)` render a leaked `Int vs a -> b` mismatch, and
  -- poison the fresh result var so no secondary obligation cascade fires (reuses
  -- Chunk A's poisoned-var set).  Fires ONLY on a ground non-arrow head: a real
  -- function (`TFun`) or an as-yet-unresolved var (`TVar`) is unaffected.
  match monoHeadCon ft
    Some _ => inferAppNotFunction appExpr ft r
    None => match containerParamScalarArg ft xt
      Some scalarTy =>
        -- Batch B #6: container-consuming HOF handed a scalar.  Reframe here
        -- (callee name + arg loc in scope) instead of letting the generic sink
        -- leak `a b vs String`.  Skip the unify (it would push the leaked
        -- mismatch as a SECOND diagnostic) and poison `r` to suppress cascade.
        let hint = containerArgHint scalarTy
        let _ = pushTypeErrorHelpFixAt "T-TYPE-MISMATCH" currentLoc.value (containerArgMsg (appSpineName appExpr) scalarTy) hint None
        -- Poison the container tyvar + element vars (in ft) exactly as the generic
        -- unify sink would (`monoUnboundIds a ++ b`), so the dangling `Mappable f`
        -- obligation sees a poisoned var and suppresses its own cascade.
        let _ = poisonMismatchVars ft xt
        let _ = poisonMismatchVars r r
        r
      None =>
        let eff = openRow ()
        -- Type-error span (Bite 3, fork 3 = ARGUMENT): point a wrong-arg-type
        -- mismatch at the argument expression rather than the callee.  The live
        -- `currentLoc` after inferring the arg is its last atom; refine it to the
        -- whole argument span so `len 5` (len : String -> Int) squiggles the `5`.
        let _ = match appArgLoc appExpr
          Some al => setRef currentLoc (Some al)
          None => ()
        let _ = unify ft (TFun xt eff r)
        -- v2 Stage 2b: if f resolves to a leaf extern carrying an inferred-hole
        -- Prefix atom (`<Net _>`), fill it by α of the application spine's FIRST
        -- argument before the row propagates / is checked against any bound.  `lets`
        -- seeds α with the enclosing body's let scope (EFFECTS WS-2).
        let eff2 = fillHolesInRow lets eff (spineFirstArg appExpr)
        let _ = performEffect curEffect eff2
        r

-- Chunk C: the applied head is a ground non-function.  If the spine over-applies
-- a named function (callee name known AND at least one arg was consumed before
-- the type went non-arrow) use the arity-aware wording; otherwise fall back to
-- naming the non-function type.  Poison `r` to suppress downstream cascade.
inferAppNotFunction : Expr -> Mono -> Mono -> Mono
inferAppNotFunction appExpr ft r =
  let applied = appSpineArgCount appExpr
  let takes = applied - 1
  let _ = match appSpineName appExpr
    Some name => if takes >= 1 then pushTypeError "T-NOT-A-FUNCTION" (overAppliedMsg name takes applied)
    else
      let hint = notAFunctionHint (Some name)
      pushTypeErrorHelpFixAt
        "T-NOT-A-FUNCTION"
        currentLoc.value
        (notAFunctionMsg (ppMono (normalize ft)) ++ hint)
        hint
        None
    None =>
      let hint = notAFunctionHint None
      pushTypeErrorHelpFixAt
        "T-NOT-A-FUNCTION"
        currentLoc.value
        (notAFunctionMsg (ppMono (normalize ft)) ++ hint)
        hint
        None
  let _ = poisonMismatchVars r r
  r

inferLam : TcEnv -> List Pat -> Expr -> Mono
inferLam env pats body =
  -- Patterns carry no source Loc, so a pattern-level type error (e.g. an
  -- over-applied nullary constructor `A _`) would otherwise be recorded at the
  -- STALE `currentLoc` left by the previous clause/function's body inference —
  -- mis-blaming an innocent sibling clause.  Anchor `currentLoc` to THIS clause's
  -- body loc before inferring the patterns, so the error lands on the right
  -- clause (the body re-sets `currentLoc` via its own ELoc arm afterwards).
  let _ = match exprLoc body
    Some l => setRef currentLoc (Some l)
    None => ()
  let pr = inferPats env pats
  let saved = curEffect.value
  let _ = setRef curEffect (openRow ())
  let bodyTy = infer (extendVars env (snd pr)) body
  let bodyEff = curEffect.value
  let _ = setRef curEffect saved
  arrowsWithLastEffect (fst pr) bodyEff bodyTy

-- The first Bool (`mut`) is always False — `let mut` is a parser error (beta
-- mutability model), so no inline mut-let path remains here.
inferLet : TcEnv -> Bool -> Bool -> Pat -> Expr -> Expr -> Mono
inferLet env _ isFun pat e1 e2
  | isFun = match pat
    PVar x => inferRecLet env x e1 e2
    _ => inferLetSimple env pat e1 e2
  | otherwise = inferLetSimple env pat e1 e2

-- T2: a recursive inline function binding (`let go n = … in …`) must
-- pre-bind `go` with a monomorphic placeholder so the RHS can reference
-- itself, then generalize (a function is a value — oracle `:1668-1681`).

-- Self-recursive inline `let` binding (mirrors blockRecLet + the oracle is_fun
-- arm): placeholder pre-bind, infer body, unify, generalize through the body.
inferRecLet : TcEnv -> String -> Expr -> Expr -> Mono
inferRecLet env x e1 e2 =
  let _ = enterLevel ()
  let oblN0 = pendingImplObligationsN.value
  let placeholder = freshVar ()
  let envSelf = extendVar env x (monoScheme placeholder)
  let t1 = infer envSelf e1
  let _ = unify placeholder t1
  let _ = exitLevel ()
  let addedObls = takeFirst (pendingImplObligationsN.value - oblN0) pendingImplObligations.value
  let _ = defaultAmbiguousNum addedObls t1  -- PLAN.md #11
  let _ = registerAmbiguousConstraints addedObls [t1]  -- RETPOS soundness
  let _ = recordLocalBind x t1  -- LSP hover (recursive PVar let bypasses inferPat)
  infer (seedAlphaLets (extendVar env x (generalize t1)) x e1) e2  -- WS-2: α scope-seed

inferLetSimple : TcEnv -> Pat -> Expr -> Expr -> Mono
inferLetSimple env pat e1 e2 =
  let _ = enterLevel ()
  let oblN0 = pendingImplObligationsN.value
  let t1 = infer env e1
  let _ = exitLevel ()
  -- PLAN.md #11: ground an ambiguous Num-only var before this inner let
  -- generalizes, so `let z = 2 in y + z` (y:Float) is a clean type error and
  -- never leaks an unbound Num var.  Scoped to this binding's new obligations.
  let addedObls = takeFirst (pendingImplObligationsN.value - oblN0) pendingImplObligations.value
  let _ = defaultAmbiguousNum addedObls t1
  let _ = registerAmbiguousConstraints addedObls [t1]   -- RETPOS soundness
  inferLetBody env pat t1 e1 e2

inferLetBody : TcEnv -> Pat -> Mono -> Expr -> Expr -> Mono
inferLetBody env (PVar x) t1 e1 e2 =
  let _ = recordLocalBind x t1  -- LSP hover (PVar let bypasses inferPat)
  infer
    (seedAlphaLets
      (extendVar env x (genRestricted (isNonexpansive e1) t1))
      x
      e1)
    e2  -- WS-2: α scope-seed
inferLetBody env pat t1 _ e2 =
  let pr = inferPat env pat
  let _ = unify (fst pr) t1
  infer (extendVars env (snd pr)) e2

inferIf : TcEnv -> Expr -> Expr -> Expr -> Mono
inferIf env c t e =
  let _ = unify (infer env c) (TCon "Bool")
  let tt = infer env t
  let ee = infer env e
  let _ = noteNumlitCtx tt ee "if"  -- Chunk D: site-specific Num mis-framing wording
  let _ = unify tt ee
  tt

inferEach : TcEnv -> List Expr -> List Mono
inferEach _ [] = []
inferEach env (e::es) =
  let t = infer env e
  t :: inferEach env es

inferListLit : TcEnv -> List Expr -> Mono
inferListLit env es =
  let elem = freshVar ()
  let _ = unifyAllNumlit elem (inferEach env es)  -- Chunk D: tag list-element Num mismatch
  TApp (TCon "List") elem

-- Chunk D: like unifyAll but tags each element that is a still-unbound literal var
-- being forced against a concrete accumulator (or vice-versa) with the "list" ctx.
unifyAllNumlit : Mono -> List Mono -> Unit
unifyAllNumlit _ [] = ()
unifyAllNumlit t (x::xs) =
  let _ = noteNumlitCtx t x "list"
  let _ = unify t x
  unifyAllNumlit t xs

inferAnnot : TcEnv -> Expr -> Ty -> Mono
inferAnnot env e ty =
  let t = infer env e
  let pair = astTypeFreshTbl ty
  let annot = fst pair
  let _ = unify t annot
  let _ = checkAnnotTooGeneral ty (map snd (snd pair))
  annot

-- Phase 108 head-pin (`:~`, EHeadAnnot): like inferAnnot but WITHOUT the
-- checkAnnotTooGeneral skolemization guard — the pin's type variables are MEANT
-- to ground (the container literal's element types).  Fixes `e`'s head tycon to
-- the named container so `fromEntries`'s return-position dispatch resolves to
-- that container's impl.  Mirror of lib/typecheck.ml's EHeadAnnot arm.
--
-- Phase 114 (was wrongly dropped here): ignore the *arity* the lowering happened
-- to supply and apply the head tycon to its *declared* arity of fresh vars.  The
-- parser can't tell empty `Map { }` from `Set { }` — both have no entries, so
-- classifyBrace falls through to `ESetLit name []` and the desugar pins a UNARY
-- `Map _a`, the wrong arity for `Map k v` (→ `Map vs Map …`).  Looking the arity
-- up by the head tycon makes empty literals work regardless of the lowering's
-- guess; element vars stay free and ground via inference as before.
inferHeadAnnot : TcEnv -> Expr -> Ty -> Mono
inferHeadAnnot env e ty =
  let t = infer env e
  let annot = headAnnotTy ty
  let _ = unify t annot
  t

-- The head-pin's target type: if the annotation's head is a TyCon with a known
-- declared arity (from `dataParamKindsRef`), rebuild it at that arity with fresh
-- vars (so an empty literal's wrong-arity pin is corrected); otherwise fall back
-- to the literal annotation type.
headAnnotTy : Ty -> Mono
headAnnotTy ty = match tyAppSpine ty
  (TyCon n _, _) => match lookupAssoc n dataParamKindsRef.value
    Some kinds => applyParams (TCon n) (freshVars (listLen kinds))
    None => fst (astTypeFreshTbl ty)
  _ => fst (astTypeFreshTbl ty)

-- C3 (mirrors lib/typecheck.ml:1821-1842): each type variable named in the
-- annotation asserts polymorphism, so after unification it must still be a
-- DISTINCT, unbound variable.  If one ground to a concrete type, or two
-- annotation variables collapsed to the same variable, the annotation is more
-- polymorphic than the expression — reject.  `sigTvarIds` keeps only the entries
-- that normalize to a TVar, so a grounded var drops out (count shrinks) and a
-- collapse shows as a duplicate id.  EHeadAnnot is exempt (no call to this).
checkAnnotTooGeneral : Ty -> List Mono -> Unit
checkAnnotTooGeneral ty resolved =
  let ids = sigTvarIds resolved
  if listLen ids < listLen resolved || hasDupI ids then
    pushTypeError "T-TYPE-TOO-GENERAL" (annotTooGeneralMsg ty)
  else
    ()

inferMatch : TcEnv -> Mono -> List Arm -> Mono
inferMatch env scrutTy arms =
  let result = freshVar ()
  let _ = inferArms env scrutTy result arms
  let _ = checkMatchExhaustive scrutTy arms
  let _ = checkMatchRedundant scrutTy arms
  result
-- Type-aware exhaustiveness (`check_match`): run AFTER the arms have unified
-- the scrutinee type, so `scrutTy` is fully resolved when we read its head.

-- The non-exhaustive-`match` warning (note the em-dash).  The redundancy pass
-- is not ported — only the exhaustiveness warning.  When the Maranget witness
-- algorithm can name the uncovered case (`nonExhaustiveMsg`) the message is
-- specialised to name the scrutinee type + the missing constructor; this
-- generic form is the fallback if no witness is recoverable.
nonExhaustiveMatchWarning : String
nonExhaustiveMatchWarning =
  "Warning: non-exhaustive match. Not all cases are covered"

-- Warn if an all-wildcard query is still useful against the matrix of the
-- non-guarded arms — i.e. some scrutinee value escapes every arm.  Guarded arms
-- are excluded (their guard may fail at runtime), matching the reference.
checkMatchExhaustive : Mono -> List Arm -> Unit
checkMatchExhaustive scrutTy arms =
  let rows = nonGuardedRows arms
  if useful matchOracle.value (matchCol0Type scrutTy) rows [PWild] then
    let _ = setRef matchWarnings (nonExhaustiveMsg scrutTy rows :: matchWarnings.value)
    setRef matchWarningLocs (currentLoc.value::matchWarningLocs.value)
  else ()

-- ── unreachable / redundant match-arm warning (W-UNREACHABLE-ARM) ──────────
-- An arm is unreachable when its pattern is already fully covered by an EARLIER
-- *unguarded* arm: those arms fire unconditionally, so no value ever reaches
-- this one.  We fold arms left-to-right, accumulating a matrix of the preceding
-- UNGUARDED arm patterns, and flag any arm whose pattern is not `useful` against
-- it (`patUnreachable`).  Guarded predecessors are excluded (their guard may fail
-- at runtime, leaving a later same-shape arm reachable), which keeps the check
-- conservative — we flag only arms provably dead via unconditional predecessors.
-- The warning carries the ARM's own loc (its body span) so the caret points at
-- the dead arm, not the match head.
unreachableArmWarning : String
unreachableArmWarning = "Warning: unreachable match arm. This pattern is already covered by an earlier arm"

checkMatchRedundant : Mono -> List Arm -> Unit
checkMatchRedundant scrutTy arms =
  checkRedundantGo (matchCol0Type scrutTy) [] omEmpty False arms

-- PERF: `prec` accumulates the preceding arms' patterns and is PREPENDED to, so
-- it holds them in REVERSE arm order.  It used to be built with `prec ++ [[dp]]`,
-- which copies the whole accumulator once per arm — O(N²) allocation on a match
-- with many arms, and the dominant allocation source in the redundancy check.
--
-- Reversing the rows is sound because `useful` is a PREDICATE OVER THE SET of
-- matrix rows ("does some value match the query and no row?"): `specializeCon` /
-- `specializeLit` / `defaultMatrix` are row-wise filters, and the only decision
-- that reads rows in order is `inferCol0Type`, which just needs SOME column-0
-- constructor to name the column's type — and it is consulted only when `col0`
-- is `None`, i.e. when the scrutinee type has no concrete head, in which case no
-- arm carries a constructor pattern and there is no head constructor to find in
-- either order.
checkRedundantGo : Option String -> List (List Pat) -> OrdMap Unit -> Bool -> List Arm -> Unit
checkRedundantGo _ _ _ _ [] = ()
checkRedundantGo col0 prec heads offCol ((Arm pat gs body)::rest) =
  let dp = desugarPat matchOracle.value pat
  let _ = if armUnreachable col0 prec heads offCol dp then
    let _ = setRef matchWarnings (unreachableArmWarning :: matchWarnings.value)
    setRef matchWarningLocs (orElseLoc (exprLoc body) currentLoc.value :: matchWarningLocs.value)
  else ()
  -- Only UNGUARDED, range-free arms contribute to the covered set: a guarded arm
  -- may not fire, and a range collapses to a wildcard that over-states coverage
  -- (patHasRange) — either would produce a false "redundant" on a later arm.
  let contributes = armIsUnguarded gs && not (patHasRange pat)
  let prec2 = if contributes then [dp] :: prec else prec
  let heads2 = if contributes then noteHeadCtor dp heads else heads
  let offCol2 = offCol || (contributes && not (isConPat dp))
  checkRedundantGo col0 prec2 heads2 offCol2 rest

-- PERF fast path.  `patUnreachable` runs the full Maranget `useful` recursion, which
-- re-scans EVERY preceding row — so the fold as a whole is O(arms²) on a wide match.
-- But a constructor arm `C …` can only be unreachable if some preceding row could
-- match a `C` value, and the only rows that can are (a) rows headed by `C` itself and
-- (b) rows with a WILDCARD head, which match anything.  When neither exists,
-- `specializeCon C` yields the EMPTY matrix and `useful _ _ [] _` is `True` by
-- definition — the arm is reachable — so the recursion is guaranteed to say
-- "reachable" and we can skip it outright.
--
-- `heads` is the set of head constructors of the preceding contributing rows and
-- `offCol` records whether any of them has a NON-constructor head.  `offCol` is a
-- deliberate over-approximation of "has a wildcard head" (it also trips on a literal
-- head, which `specializeCon` would in fact discard): erring towards `True` only ever
-- costs us the fast path and falls back to the exact check, never an answer.
armUnreachable : Option String -> List (List Pat) -> OrdMap Unit -> Bool -> Pat -> Bool
armUnreachable col0 prec heads offCol (PCon c args)
  | not offCol && not (omHasKey c heads) = False
  | otherwise = patUnreachable matchOracle.value col0 prec (PCon c args)
armUnreachable col0 prec _ _ dp = patUnreachable matchOracle.value col0 prec dp

noteHeadCtor : Pat -> OrdMap Unit -> OrdMap Unit
noteHeadCtor (PCon c _) heads = omInsert c () heads
noteHeadCtor _ heads = heads

isConPat : Pat -> Bool
isConPat (PCon _ _) = True
isConPat _ = False

-- Only UNGUARDED arms contribute to the covered set (a guarded arm may not fire).
armIsUnguarded : List Guard -> Bool
armIsUnguarded [] = True
armIsUnguarded (_::_) = False

-- Build the specialised warning: recover a concrete uncovered pattern (the
-- Maranget witness) and name it, plus the scrutinee type when it has a real
-- head name.  Falls back to the generic wording if no witness is recoverable
-- (keeps the warning firing whenever `useful` should, never naming a wrong
-- constructor).  Actionable-fix hint (F dimension): when a witness IS
-- recoverable, append a concrete-edit suggestion using the witness string
-- VERBATIM (so `Triangle _` reads as `Triangle _`, not `Triangle`) and record
-- it in `matchWarningHelp` (keyed by the full message, mirroring
-- `typeErrorHelpFix`) so `--json`'s `help` field carries it too.
nonExhaustiveMsg : Mono -> List (List Pat) -> String
nonExhaustiveMsg scrutTy rows = match usefulWitness matchOracle.value (matchCol0Type scrutTy) rows 1
  Some (w::_) =>
    let witnessStr = renderWitness w
    let hint = "add a '\{witnessStr} => …' arm, or a '_' wildcard arm to catch the rest."
    let msg = "Warning: non-exhaustive match\{tyOfMsg (matchCol0Type scrutTy)}. Missing case: '\{witnessStr}'; \{hint}"
    let _ = setRef matchWarningHelp ((msg, hint)::matchWarningHelp.value)
    msg
  _ => nonExhaustiveMatchWarning

-- Name the scrutinee type (skip the synthetic tuple type names, which aren't
-- user-facing — the witness pattern already reads as a tuple).
tyOfMsg : Option String -> String
tyOfMsg None = ""
tyOfMsg (Some t) = if isTupleTyName t then "" else " of '\{t}'"

isTupleTyName : String -> Bool
isTupleTyName t = stringLength t >= 7 && stringSlice 0 7 t == "__tuple"

-- one single-column matrix row per non-guarded arm (its desugared pattern)
nonGuardedRows : List Arm -> List (List Pat)
nonGuardedRows [] = []
nonGuardedRows ((Arm pat [] _)::rest) =
  [desugarPat matchOracle.value pat] :: nonGuardedRows rest
nonGuardedRows ((Arm _ _ _)::rest) = nonGuardedRows rest

-- the head type name of the scrutinee, for the matrix's column-0 oracle: a
-- TCon/TApp head gives the type name; a tuple has no TCon head, so it maps to a
-- synthetic per-arity tuple type (mirrors the reference's col0_type).
matchCol0Type : Mono -> Option String
matchCol0Type ty = map (n => n) (headTyconMono ty)

inferArms : TcEnv -> Mono -> Mono -> List Arm -> Unit
inferArms _ _ _ [] = ()
inferArms env scrutTy result ((Arm pat gs body)::rest) =
  let _ = inferArm env scrutTy result pat gs body
  inferArms env scrutTy result rest

inferArm : TcEnv -> Mono -> Mono -> Pat -> List Guard -> Expr -> Unit
inferArm env scrutTy result pat gs body =
  let pr = inferPat env pat
  let _ = unify (fst pr) scrutTy
  let envBody = inferArmGuards (extendVars env (snd pr)) gs
  unify result (infer envBody body)

-- Thread an arm's guard qualifiers left-to-right (mirror of lib/typecheck.ml's
-- EMatch guard fold): a `GBool` must be `Bool` and leaves the env unchanged; a
-- `GBind p e` infers `e`, binds `p` against it, and extends the env so the bound
-- vars are in scope for LATER qualifiers and the arm body.
inferArmGuards : TcEnv -> List Guard -> TcEnv
inferArmGuards env [] = env
inferArmGuards env ((GBool g)::rest) =
  let _ = unify (infer env g) (TCon "Bool")
  inferArmGuards env rest
inferArmGuards env ((GBind p e)::rest) =
  let te = infer env e
  let pr = inferPat env p
  let _ = unify (fst pr) te
  inferArmGuards (extendVars env (snd pr)) rest

inferLetGroup : TcEnv -> List LetBind -> Expr -> Mono
inferLetGroup env binds body =
  let env2 = processLetGroup env binds
  infer env2 body

-- ── data declarations → constructor schemes ───────────────────────────────
registerData : TcEnv -> Decl -> TcEnv
registerData env (DData _ name params variants _) =
  registerVariants env name params variants
registerData env (DTypeAlias _ name params rhs) =
  let _ = setRef aliasTableRef ((name, (params, rhs))::aliasTableRef.value)
  env
registerData env (DNewtype _ name params con fty _) =
  registerVariants env name params [Variant con (ConPos [fty])]
registerData env _ = env

-- ── record metadata registration & instantiation ──────────────────────────
-- registerRecordInfoKeyed uses a distinct registry KEY and result TYPE name:
-- for a record they coincide, but a named-field data variant is keyed by its
-- constructor (DInterface) while its values have the data type (Decl).
registerRecordInfoKeyed : String -> String -> List String -> List Field -> Unit
registerRecordInfoKeyed key typeName params fields =
  let paramVars = freshVars (listLen params)
  let tvs = zipL params paramVars
  let result = applyParams (TCon typeName) paramVars
  let fieldMonos = map (recFieldMono tvs) fields
  setRef
    recordsRef
    ((key, RecordInfo (map monoTyvarId paramVars) result fieldMonos)::recordsRef.value)

recFieldMono : List (String, Mono) -> Field -> (String, Mono)
recFieldMono tvs (Field fn ty) = (fn, fromAstType tvs ty)

lookupRecordByName : String -> Option RecordInfo
lookupRecordByName name = lookupAssoc name recordsRef.value

recordHasField : String -> RecordInfo -> Bool
recordHasField fname (RecordInfo _ _ fields) = isSome (lookupAssoc fname fields)

-- instantiate a record's quantified params with fresh vars
instantiateRecord : RecordInfo -> (Mono, List (String, Mono))
instantiateRecord (RecordInfo paramIds result fields) =
  let subst = freshSubst paramIds
  (substMono subst [] result, map (substField subst) fields)

substField : List (Int, Mono) -> (String, Mono) -> (String, Mono)
substField subst (fn, fm) = (fn, substMono subst [] fm)

registerVariants : TcEnv -> String -> List String -> List Variant -> TcEnv
registerVariants env name params variants =
  let kinds = inferParamKinds params variants
  let _ = setRef dataParamKindsRef ((name, kinds)::dataParamKindsRef.value)
  let paramReprs = mintParamReprs kinds
  let tvs = ktypeTvs params kinds paramReprs
  let etbl = krowEtbl params kinds paramReprs
  let paramTyIds = collectTyIds paramReprs
  let rowEffvarIds = collectRowEffvarIds paramReprs
  let result = applyParams (TCon name) paramReprs
  let _ = registerNamedFieldVariants name params variants
  addVariants env tvs etbl paramTyIds rowEffvarIds result variants

-- A data param is KRow iff its name appears in a field's effect-tail position
-- (`<e>`); else KType (the common case).  Inferred from usage — no syntax.
inferParamKinds : List String -> List Variant -> List Kind
inferParamKinds params variants =
  let tailNames = flatMap variantFieldTailNames variants
  map (p => if contains p tailNames then KRow else KType) params

variantFieldTailNames : Variant -> List String
variantFieldTailNames (Variant _ payload) =
  flatMap effTailNames (payloadAstTypes payload)

payloadAstTypes : ConPayload -> List Ty
payloadAstTypes (ConPos tys) = tys
payloadAstTypes (ConNamed fields _) = map fieldTyOf fields

fieldTyOf : Field -> Ty
fieldTyOf (Field _ ty) = ty

-- one representation per param shared across all ctors: KType → fresh TVar,
-- KRow → a TEff wrapping a fresh effvar (the row the param stands for).
mintParamReprs : List Kind -> List Mono
mintParamReprs [] = []
mintParamReprs (KType::ks) = freshVar () :: mintParamReprs ks
mintParamReprs (KRow::ks) =
  TEff (EffRow [] (Some (freshEffvar ()))) :: mintParamReprs ks

-- KType param names → their TVar (the tvs map fromAstTypeE consults for tyvars)
ktypeTvs : List String -> List Kind -> List Mono -> List (String, Mono)
ktypeTvs (p::ps) (KType::ks) (r::rs) = (p, r) :: ktypeTvs ps ks rs
ktypeTvs (p::ps) (_::ks) (_::rs) = ktypeTvs ps ks rs
ktypeTvs _ _ _ = []

-- KRow param names → the effvar cell inside their TEff repr, so a field's `<e>`
-- and a nested `Async e a` row-arg resolve to the SAME cell the result carries.
krowEtbl : List String -> List Kind -> List Mono -> List (String, Ref Effvar)
krowEtbl (p::ps) (KRow::ks) ((TEff (EffRow _ (Some cell)))::rs) =
  (p, cell) :: krowEtbl ps ks rs
krowEtbl (p::ps) (_::ks) (_::rs) = krowEtbl ps ks rs
krowEtbl _ _ _ = []

collectTyIds : List Mono -> List Int
collectTyIds ((TVar cell)::rs) = tyvarId cell :: collectTyIds rs
collectTyIds (_::rs) = collectTyIds rs
collectTyIds [] = []

collectRowEffvarIds : List Mono -> List Int
collectRowEffvarIds ((TEff (EffRow _ (Some cell)))::rs) =
  effvarId cell :: collectRowEffvarIds rs
collectRowEffvarIds (_::rs) = collectRowEffvarIds rs
collectRowEffvarIds [] = []

-- a named-field data variant (`C { f : T, … }`, e.g. ast's DInterface) carries a
-- record-shaped payload: register its field layout keyed by the CONSTRUCTOR name
-- but with the DATA TYPE as result type, so `C { f, … }` patterns / `C { … }`
-- literals resolve (the positional ctor scheme is still added by addVariants).
registerNamedFieldVariants : String -> List String -> List Variant -> Unit
registerNamedFieldVariants _ _ [] = ()
registerNamedFieldVariants tyName params ((Variant cname (ConNamed fields _))::rest) =
  let _ = registerRecordInfoKeyed cname tyName params fields
  registerNamedFieldVariants tyName params rest
registerNamedFieldVariants tyName params (_::rest) =
  registerNamedFieldVariants tyName params rest

freshVars : Int -> List Mono
freshVars n
  | n <= 0 = []
  | otherwise = freshVar () :: freshVars (n - 1)

monoTyvarId : Mono -> Int
monoTyvarId (TVar cell) = tyvarId cell
monoTyvarId _ = 0 - 1

applyParams : Mono -> List Mono -> Mono
applyParams head [] = head
applyParams head (p::ps) = applyParams (TApp head p) ps

addVariants : TcEnv -> List (String, Mono) -> List (String, Ref Effvar) -> List Int -> List Int -> Mono -> List Variant -> TcEnv
addVariants env _ _ _ _ _ [] = env
addVariants env tvs etbl paramTyIds rowEffvarIds result ((Variant cname payload)::rest) =
  let ctorType = foldrFun (payloadTypesE etbl tvs payload) result
  let env2 = addCtor env cname (Forall paramTyIds rowEffvarIds ctorType)
  addVariants env2 tvs etbl paramTyIds rowEffvarIds result rest

payloadTypesE : List (String, Ref Effvar) -> List (String, Mono) -> ConPayload -> List Mono
payloadTypesE etbl tvs (ConPos tys) = map (fromAstTypeE etbl tvs) tys
payloadTypesE etbl tvs (ConNamed fields _) = map (fieldTypeE etbl tvs) fields

fieldTypeE : List (String, Ref Effvar) -> List (String, Mono) -> Field -> Mono
fieldTypeE etbl tvs (Field _ ty) = fromAstTypeE etbl tvs ty

-- ── top-level driver ──────────────────────────────────────────────────────
funClausePair : FunClause -> (List Pat, Expr)
funClausePair (FunClause pats body) = (pats, body)

funDefs : List Decl -> List (String, (List Pat, Expr))
funDefs [] = []
funDefs ((DFunDef _ n pats body)::rest) = (n, (pats, body)) :: funDefs rest
-- Top-level `let rec … with …` (DLetGroup): flatten each binding's clauses to
-- (name, (pats, body)) entries, exactly like a multi-clause DFunDef, so the SCC
-- builder groups the mutually-recursive members and assigns them schemes.  Mirrors
-- lib/typecheck.ml, which feeds DLetGroup bindings into the same letrec-group path.
funDefs ((DLetGroup _ binds)::rest) = letGroupDefs binds ++ funDefs rest
funDefs ((DAttrib _ d)::rest) = funDefs (d::rest)
funDefs (_::rest) = funDefs rest

letGroupDefs : List LetBind -> List (String, (List Pat, Expr))
letGroupDefs [] = []
letGroupDefs ((LetBind n clauses)::rest) = map (tcClauseDef n) clauses
  ++ letGroupDefs rest

tcClauseDef : String -> FunClause -> (String, (List Pat, Expr))
tcClauseDef n c = (n, funClausePair c)

-- D2 fix: mirrors oracle is_syntactic_lambda (lib/typecheck.ml:2518-2521).
-- True iff the expression is an explicit lambda at the top level.
isSyntacticLambda : Expr -> Bool
isSyntacticLambda (ELam _ _) = True
isSyntacticLambda _ = False

-- D2 fix: check all top-level DLetGroup declarations for non-function recursive
-- bindings, mirroring the oracle's LetRecNonFunction guard
-- (lib/typecheck.ml:2596-2602, process_letrec_group).  A binding is illegal
-- when ALL its clauses have zero params AND none is a syntactic lambda.
-- Pushes the error into typeErrors for each violating member.
checkLetRecDecls : List Decl -> Unit
checkLetRecDecls [] = ()
checkLetRecDecls ((DLetGroup _ binds)::rest) =
  let _ = checkLetBinds binds
  checkLetRecDecls rest
checkLetRecDecls (_::rest) = checkLetRecDecls rest

checkLetBinds : List LetBind -> Unit
checkLetBinds [] = ()
checkLetBinds ((LetBind name clauses)::rest) =
  let _ = checkLetBind name clauses
  checkLetBinds rest

checkLetBind : String -> List FunClause -> Unit
checkLetBind name clauses
  | allList clauseIsNonFunction clauses =
    pushTypeError "T-NONREC-VALUE-LET" (letRecNonFunctionMsg name)
  | otherwise = ()

clauseIsNonFunction : FunClause -> Bool
clauseIsNonFunction (FunClause [] rhs) = not (isSyntacticLambda rhs)
clauseIsNonFunction (FunClause _ _) = False

letRecNonFunctionMsg : String -> String
letRecNonFunctionMsg name = "'"
  ++ name
  ++ "' is bound by 'let rec' but its right-hand side is not a function"

groupNames : List (String, (List Pat, Expr)) -> OrdMap Unit -> List String
groupNames [] _ = []
groupNames ((n, _)::rest) seen = match omLookup n seen
  Some _ => groupNames rest seen
  None => n :: groupNames rest (omInsert n () seen)

-- process a let-group (where clauses): bind names, infer, generalize
processLetGroup : TcEnv -> List LetBind -> TcEnv
processLetGroup env binds =
  let _ = enterLevel ()
  let oblN0 = pendingImplObligationsN.value
  let placeholders = map letBindPlaceholder binds
  let env2 = extendVars env placeholders
  let _ = inferLetBinds env2 (zipL binds placeholders)
  let _ = exitLevel ()
  -- PLAN.md #11: ground ambiguous Num-only vars (not arg-reachable from any
  -- where-binding's type) before this group generalizes.  Scoped to this group's
  -- newly added obligations.
  let addedObls = takeFirst (pendingImplObligationsN.value - oblN0) pendingImplObligations.value
  let _ = defaultGroupNum addedObls (map (p => schemeMono (snd p)) placeholders)
  let _ = registerAmbiguousConstraints addedObls (map (p => schemeMono (snd p)) placeholders)   -- RETPOS soundness
  generalizeGroup env (zipL binds placeholders)

letBindPlaceholder : LetBind -> (String, Scheme)
letBindPlaceholder (LetBind name _) = (name, monoScheme (freshVar ()))

inferLetBinds : TcEnv -> List (LetBind, (String, Scheme)) -> Unit
inferLetBinds _ [] = ()
inferLetBinds env ((LetBind _ clauses, (_, sch))::rest) =
  let _ = unify (schemeMono sch) (inferClauses env (map funClausePair clauses))
  inferLetBinds env rest

schemeMono : Scheme -> Mono
schemeMono (Forall _ _ t) = t

-- Phase / GAP-2 phase-a: the tyvar ids that some ARG-position method occurrence
-- discriminates on (the receiver monos queued in pendingArgStamps).  A where-helper
-- whose own type shares one of these is *method-constrained by the enclosing fn's
-- dispatch* — its receiver var unifies (at the helper's call site) with the
-- enclosing fn's constraint var that activeDictVars maps to a dict param.  We must
-- NOT generalize over such a var, or the helper instantiates a fresh (id != the
-- enclosing constraint var) so resolveArgStamp can't see the in-scope dict → the
-- in-body method route degrades to RNone → arg-tag → native panic on a primitive
-- receiver.  Keeping it monomorphic links the ids (normalize collapses them) so the
-- existing resolveArgStamp routes RDict and dict_pass threads the enclosing dict in.
-- Sound: an UNconstrained helper var (e.g. `pair x = (x,x)`) never appears in a
-- method-usage mono, so it still generalizes; only dispatch-constrained vars (which
-- compiler cannot dict-pass per-where-helper anyway) are pinned, matching their
-- single enclosing-typed use.
methodConstrainedIds : Unit -> List Int
methodConstrainedIds _ =
  flatMap (s => monoUnboundIds (argStampMono s)) pendingArgStamps.value

argStampMono : (String, Ref Route, Ref (List Route), Mono, String) -> Mono
argStampMono (_, _, _, am, _) = am

monoUnboundIds : Mono -> List Int
monoUnboundIds t = match normalize t
  TVar cell => [tyvarId cell]
  TCon _ => []
  TApp a b => monoUnboundIds a ++ monoUnboundIds b
  TFun a _ b => monoUnboundIds a ++ monoUnboundIds b
  TEff _ => []

anyIn : List Int -> List Int -> Bool
anyIn xs ys = anyList (x => containsI x ys) xs

-- PLAN.md #11 (locked §0.2): monomorphism-for-Num defaulting.  Before a type [t]
-- is generalized at a let-binding boundary, ground every *ambiguous* tyvar carrying
-- a `Num` constraint to `Int`.  "Ambiguous" = the var is NOT reachable from an
-- ARGUMENT position of [t] (a caller can't fix it).  This stops a bare `n = 1` (or
-- an inner `let z = 2`) from generalizing to `Num a => a` / leaking an unbound
-- `Num a` to eval, while leaving a genuinely polymorphic var live: `sum`'s element
-- var in `t a -> a` is reachable from the argument `t a`, so it stays polymorphic
-- (`sum [1.0,…]` still works); `x : Float; x = 0`'s var is already concrete Float
-- (not a generalizable var), so it is untouched.  Mirrors lib/typecheck.ml's
-- default_ambiguous_num: a Num-constrained var (alone OR with another class) that is
-- ambiguous is grounded to Int — the literal's `Num`/`fromInt` representation IS
-- Int, so grounding keeps impl selection deterministic.
monoArgUnboundIds : Mono -> List Int
monoArgUnboundIds t = match normalize t
  TFun a _ b => monoUnboundIds a ++ monoArgUnboundIds b
  _ => []

-- the unbound var ids that any pending `Num` obligation in [obls] constrains (the
-- operand monos recorded by recordIfaceObligation / the literal infer arm)
numConstrainedIds : List (String, List String, Ty, Mono, Option Loc) -> List Int
numConstrainedIds obls = flatMap numObligIds obls

numObligIds : (String, List String, Ty, Mono, Option Loc) -> List Int
numObligIds (iface, _, _, occ, _)
  | iface == "Num" = monoUnboundIds occ
  | otherwise = []

defaultAmbiguousNum : List (String, List String, Ty, Mono, Option Loc) -> Mono -> Unit
defaultAmbiguousNum obls t =
  let argIds = monoArgUnboundIds t
  let inT = monoUnboundIds t
  let candidates = dedupI (numConstrainedIds obls)
  groundNumVars
    obls
    (filterList
      (id => containsI id inT && not (containsI id argIds))
      candidates)

-- group-level defaulting: ground every Num-constrained var NOT reachable from an
-- ARGUMENT position of ANY member's type.  [monos] = the group's member placeholder
-- monos; [obls] = ONLY this group's newly-added obligations (an earlier group's
-- already-generalized var must not be touched).  Unlike defaultAmbiguousNum this
-- does NOT require the var to appear in a member's type (a var consumed inside a
-- body surfaces in no type but must still ground — `let n = tag [1,2,3]`).  Mirrors
-- process_letrec_group's group_arg_ids over added_obligs/added_methods.
defaultGroupNum : List (String, List String, Ty, Mono, Option Loc) -> List Mono -> Unit
defaultGroupNum obls monos =
  let argIds = flatMap monoArgUnboundIds monos
  let candidates = dedupI (numConstrainedIds obls)
  groundNumVars obls (filterList (id => not (containsI id argIds)) candidates)

-- per-binding defaulting: run defaultAmbiguousNum on each member's placeholder mono
defaultEachMember : List (String, List String, Ty, Mono, Option Loc) -> List (String, Mono) -> Unit
defaultEachMember _ [] = ()
defaultEachMember obls ((_, m)::rest) =
  let _ = defaultAmbiguousNum obls m
  defaultEachMember obls rest

-- RETPOS soundness — ambiguous interface constraint (run≠build hole).
-- A method obligation recorded inside a binding whose discriminating tyvar is
-- UNBOUND, UNANCHORED, and appears NOWHERE in the binding's generalized type is
-- genuinely ambiguous (`make`'s result var in `f x = reveal (make (reveal x))`,
-- `f : Thing a => a -> Int`: `make`'s var is tied to neither `a` nor the result).
-- No annotation determines the instance and, with ≥2 impls, eval vs emit default
-- to DIFFERENT impls — a silent run≠build miscompile (RETPOS-DISPATCH-DESIGN.md).
-- We REJECT it by handing the genuine ambiguous DISPATCH mono to the existing
-- undetermined-obligation path (registering it as a call obligation), which
-- rejects (ambiguousImplMsg) under the SAME `Num` / active-dict / impl-count≥2
-- guards an undetermined call site already uses (so a sole-impl interface is never
-- over-rejected and `Num` stays on its literal-defaulting path).  Three filters
-- keep this from firing on legitimately-deferred constraints:
--   • member-type membership (defaultGroupNum's `monoUnboundIds`) — a var IN the
--     binding's type is determined by a caller/annotation;
--   • group LEVEL — a DEEPER var belongs to an inner let/where binding that already
--     generalized + checked it (its obligation merely leaks into our addedObls
--     window, e.g. `maximum`'s `where step` comparing at step's own element var);
--   • ANCHORED vars — a var that also appears inside a CONCRETE-HEADED dispatch mono
--     of this binding (`Set _a` from a `Set {…}` literal's FromEntries/Display) is
--     ground at emit by head-pinning, so it is sound-but-deferred, NOT ambiguous.
-- The obligation's record-site loc rides along (currentLoc is stale post-HM).
registerAmbiguousConstraints : List (String, List String, Ty, Mono, Option Loc) -> List Mono -> Unit
registerAmbiguousConstraints obls monos =
  -- groupLevel = the level THIS group generalizes at (we run post-exitLevel, so the
  -- outer currentLevel + 1).  anchoredIds = every unbound var that appears inside a
  -- concrete-headed dispatch mono across this group's obligations (head-pinnable).
  let anchoredIds = flatMap concreteHeadVarIds (flatMap oblDispatchMonos obls)
  registerAmbiguousGo obls (currentLevel.value + 1) (flatMap monoUnboundIds monos) anchoredIds

-- the dispatch monos this obligation discriminates on (empty for Num, whose
-- ambiguity is handled by literal defaulting).
oblDispatchMonos : (String, List String, Ty, Mono, Option Loc) -> List Mono
oblDispatchMonos (iface, typarams, mty, occ, _)
  | iface == "Num" = []
  -- F0: dispatch/ambiguity keys off the RECEIVER (dispatch) typaram only, NOT every
  -- interface typaram.  A return-only typaram (`v` in `Get c v where get1 : c -> v`)
  -- is determined by the impl AFTER the receiver picks it, so it must never be
  -- registered as an independent impl-selection obligation — else the still-unbound
  -- `v`, grounded later by groundMultiParamObligations, is re-checked as a single-mono
  -- obligation with no matching impl (`No impl of Get for Int`).  dispatchTyparams
  -- = [first typaram], the same receiver classification argDispatchOfMethod uses.
  | otherwise = dispatchMonosOf (dispatchTyparams typarams) mty occ

-- the unbound var ids carried by a dispatch mono WITH a concrete head (`Set _a` →
-- [_a]); a bare-var dispatch (`t0`) anchors nothing.
concreteHeadVarIds : Mono -> List Int
concreteHeadVarIds dm = match headTyconMono dm
  Some _ => monoUnboundIds dm
  None => []

registerAmbiguousGo : List (String, List String, Ty, Mono, Option Loc) -> Int -> List Int -> List Int -> Unit
registerAmbiguousGo [] _ _ _ = ()
registerAmbiguousGo ((iface, typarams, mty, occ, loc)::rest) groupLevel memberIds anchoredIds =
  let _ = registerOneAmbiguous iface typarams mty occ loc groupLevel memberIds anchoredIds
  registerAmbiguousGo rest groupLevel memberIds anchoredIds

-- For each of this obligation's DISPATCH monos (the interface-param positions, via
-- dispatchMonosOf — NOT the whole method type), register it as a call obligation
-- when it carries an escaped, unanchored this-group var.  Pushing the dispatch mono
-- (not the method type) is essential: checkUndeterminedObligation's guards
-- (`headTyconMono`, `activeDictVarOf`, `allConcreteHeads`) inspect a bare dispatch
-- mono and do NOT traverse `TFun`, so a concrete-headed dispatch and a forwarded-
-- dict element var are correctly NOT flagged, while a bare-var dispatch with ≥2
-- impls and no anchor (`Thing t0` from `make`) IS rejected.
registerOneAmbiguous : String -> List String -> Ty -> Mono -> Option Loc -> Int -> List Int -> List Int -> Unit
registerOneAmbiguous iface typarams mty occ loc groupLevel memberIds anchoredIds
  | iface == "Num" = ()
  -- F0: register call obligations for the RECEIVER (dispatch) typaram only — a
  -- return-only typaram is impl-determined, not an impl-selection key (see
  -- oblDispatchMonos).
  | otherwise = registerDispatchMonos iface (dispatchMonosOf (dispatchTyparams typarams) mty occ) loc groupLevel memberIds anchoredIds

registerDispatchMonos : String -> List Mono -> Option Loc -> Int -> List Int -> List Int -> Unit
registerDispatchMonos _ [] _ _ _ _ = ()
registerDispatchMonos iface (dm::rest) loc groupLevel memberIds anchoredIds =
  let ambig = filterList (p => snd p <= groupLevel && not (containsI (fst p) memberIds) && not (containsI (fst p) anchoredIds)) (monoUnboundVarLevels dm)
  let _ = if isEmptyL ambig then () else pushCallObl (iface, dm, loc)
  registerDispatchMonos iface rest loc groupLevel memberIds anchoredIds

-- the (id, level) of every UNBOUND tyvar in [t] (sibling of monoUnboundIds, but
-- carrying the level so registerOneAmbiguous can tell a this-group constraint var
-- from a deeper inner-generalized one that merely leaked into the obligation list).
monoUnboundVarLevels : Mono -> List (Int, Int)
monoUnboundVarLevels t = match normalize t
  TVar cell => [(tyvarId cell, tyvarLevel cell)]
  TCon _ => []
  TApp a b => monoUnboundVarLevels a ++ monoUnboundVarLevels b
  TFun a _ b => monoUnboundVarLevels a ++ monoUnboundVarLevels b
  TEff _ => []

-- ground each id to Int by unifying the live var carrying it (found among [obls]'
-- Num operand monos — refs alias post-unify, grounding any grounds all)
groundNumVars : List (String, List String, Ty, Mono, Option Loc) -> List Int -> Unit
groundNumVars _ [] = ()
groundNumVars obls (id::rest) =
  let _ = match liveNumVarGo id obls
    Some m => unify m (TCon "Int")
    None => ()
  groundNumVars obls rest

liveNumVarGo : Int -> List (String, List String, Ty, Mono, Option Loc) -> Option Mono
liveNumVarGo _ [] = None
liveNumVarGo id ((iface, _, _, occ, _)::rest)
  | iface == "Num" = match findTvarInMono occ id
    Some m => Some m
    None => liveNumVarGo id rest
  | otherwise = liveNumVarGo id rest

-- the first [n] entries of a list (the newly-prepended obligations of a group)
takeFirst : Int -> List a -> List a
takeFirst n _
  | n <= 0 = []
takeFirst _ [] = []
takeFirst n (x::xs) = x :: takeFirst (n - 1) xs

generalizeGroup : TcEnv -> List (LetBind, (String, Scheme)) -> TcEnv
generalizeGroup env [] = env
generalizeGroup env (((LetBind name clauses), (_, sch))::rest) =
  let constrained = methodConstrainedIds ()
  let mono = schemeMono sch
  let isVal = clausesAreValue clauses && not (anyIn (freeGenVars currentLevel.value mono) constrained)
  -- WS-2: α scope-seed — single-clause zero-param bindings only (mirror α's
  -- alphaCollectBinds rule); a multi-clause / parameterized binding is not a
  -- known prefix.
  let env1 = extendVar env name (genRestricted isVal mono)
  let env2 = match clauses
    [FunClause [] rhs] => seedAlphaLets env1 name rhs
    _ => env1
  generalizeGroup env2 rest

-- A where-clause binding is a value (generalizable) iff every clause has params
-- (it's a function) or its zero-arg RHS is non-expansive.  Mirrors the oracle
-- `ELetGroup` value test (lib/typecheck.ml:1715-1716).
clausesAreValue : List FunClause -> Bool
clausesAreValue clauses = allList clauseIsValue clauses

clauseIsValue : FunClause -> Bool
clauseIsValue (FunClause [] rhs) = isNonexpansive rhs
clauseIsValue (FunClause _ _) = True

-- infer a clause group (multi-clause function), unifying all clauses to one type
inferClauses : TcEnv -> List (List Pat, Expr) -> Mono
inferClauses env clauses =
  let v = freshVar ()
  let _ = unifyClauses env v clauses
  v

unifyClauses : TcEnv -> Mono -> List (List Pat, Expr) -> Unit
unifyClauses _ _ [] = ()
unifyClauses env v ((pats, body)::rest) =
  let _ = unify v (inferLam env pats body)
  unifyClauses env v rest

-- ── elaboration: resolve return-position method dispatch (RKey) ────────────
-- Rewrite each return-position method occurrence to EMethodAt (with a fresh route
-- ref), type-check (recording the sites), then stamp each site's route from its
-- now-resolved result type.  Returns the SAME tree (refs filled) for eval.
-- DRIVER-COLLAPSE Phase 5: the flat `elaborate` wrapper is DELETED; callers use
-- the 1-module `elaborateOne` (the typed/dict tree of the degenerate 1-module
-- multi path).  `elaborateDict` itself is RETAINED — the EMIT path
-- (core_ir_dict_pp_main / llvm_emit_*_main, argStamp mode) still uses it.

-- ── Phase 0 (DRIVER-COLLAPSE): 1-module wrapper over the multi-module path ──
-- elaborateOne runs the SINGLE flat program [prog] (the user's decls, the live
-- prelude ALREADY shadow-dropped by the caller — same `combined` the flat
-- elaborateDict callers build, minus the joint core) through elaborateModules as
-- the degenerate 1-module list [(rootId, prog)], returning the FLAT shape the flat
-- callers consume: core2 (dict-passed core) ++ the dict-passed module's decls.
--
-- The 1-module case automatically satisfies the flat path's invariants — one
-- resetState (one module ⇒ one checkModuleFullImpl), zero imports ⇒ the full
-- constraint set, and (for the EVAL path, emitArgStampPasses OFF) elaborateModules
-- runs the eval-dict layer unconditionally (ARGSTAMP-UNIFY Phase 4), so the
-- return-position constrained-fn dict layer matches the flat elaborateDict.
--
-- NOTE (Phase 0 is DISCOVERY): the dict-name set differs by construction —
-- elaborateModules computes its own via `moduleDictNames` (return-position subset:
-- `preludeReturnPosDictNames coreDecls allDecls ++ returnPosConstrainedSigNames …`)
-- whereas the flat callers pass an externally-built `dictNames`
-- (`preludeReturnPosDictNames livePrelude combined ++ constrainedSigNames userDecls`,
-- the FULL constrained-sig set).  This wrapper takes `coreDecls` SEPARATE (not
-- pre-flattened into prog), exactly as elaborateModules expects, and lets the
-- module path own the dict-set.  diff_flat_vs_onemodule.sh exists to CHARACTERIZE
-- where that difference (and the eval install order) actually changes OUTPUT.
export elaborateOne : List Decl -> List Decl -> (String, List Decl) -> List Decl
elaborateOne runtimeDecls coreDecls (rootId, prog) =
  let (coreD, modules) = elaborateModules runtimeDecls coreDecls [(rootId, prog)]
  coreD ++ flatMap snd modules

-- Dict-passing elaboration (the `=>`-constraint layer).  [dictNames] are the
-- *signatured* constrained functions to dict-pass (the user program's — the
-- prelude keeps arg-tag / RKey dispatch, which already type-checks the goldens).
-- [eligibleNames] are the user fn names that may additionally be PROMOTED when an
-- INFERRED (unsignatured) constraint is discovered (see registerInferredConstraints).
--
-- Two-pass / fixpoint orchestration (mirrors the reference's mark → typecheck →
-- re-mark → typecheck → dict_pass): a mark+typecheck pass discovers each eligible
-- unsignatured fn's inferred constraints (promotedRef); we grow the dict-passed
-- set and re-run until it stabilizes (one layer of a call chain promotes per
-- pass), then mark + typecheck + route + dict_pass the final set.  In the RKey
-- rewrite, each occurrence of a name in the final set becomes an EDictAt (routes
-- filled after inference) and its def gets matching leading dict params.
export elaborateDict : List Decl -> List String -> List String -> List Decl -> List Decl
elaborateDict runtimeDecls dictNames eligibleNames prog =
  let _ = setRef superDeclsRef prog
  let _ = setRef dictEligibleRef eligibleNames
  let _ = setRef dictEligibleSetRef (namesToSet eligibleNames omEmpty)
  let _ = setRef implInferEnabled True
  let allNames = discoverAll runtimeDecls prog dictNames eligibleNames
  let _ = setRef argDispatchIdxRef (argDispatchIndices prog)
  let argNames = map fst argDispatchIdxRef.value
  -- P0-18: [] — the confirmed definer-shadow-emit path is elaborateModules; this
  -- single-file scratch elaborate stays shadow-map-free (byte-identical discovery).
  let prog2 = prePassDictArg (returnPosMethodNames prog ++ methodConstraintNames prog) allNames argNames [] prog
  let _ = checkProgramSeeded (externSchemes runtimeDecls) prog2
  let _ = expandSupersTable prog2
  let implTable = buildImplTable prog2
  let keyTable = buildKeyTable prog2
  let _ = resolveSites implTable keyTable (returnPosMethodNames prog2) pendingSites.value
  let _ = resolveOpSites True implTable keyTable pendingBinopSites.value
  let _ = resolveOpSites False implTable keyTable pendingUnopSites.value
  let _ = resolveArithSites pendingArithSites.value
  let _ = realizeRecDictApps pendingRecDictApps.value
  let _ = resolveDictApps prog2 implTable pendingDictApps.value
  let _ = resolveMethodDicts implTable pendingMethodDicts.value
  let _ = resolveArgStamps implTable keyTable pendingArgStamps.value
  dictPass allNames prog2

-- With no eligible names (the RKey-only / typed path), there is nothing to
-- promote — skip discovery entirely so that path stays a single typecheck pass.
discoverAll : List Decl -> List Decl -> List String -> List String -> List String
discoverAll _ _ dictNames [] = dictNames
discoverAll runtimeDecls prog dictNames _ =
  discoverPromoted runtimeDecls prog dictNames

-- Grow the dict-passed set to a fixpoint.  Each pass marks occurrences of the
-- current set as EDictAt and typechecks; registerInferredConstraints populates
-- promotedRef (reset each pass by checkProgramSeeded) with eligible unsignatured
-- fns that picked up a constraint — including a CALLER that inherited one through
-- a now-marked constrained call.  Stop when no new name appears.
discoverPromoted : List Decl -> List Decl -> List String -> List String
discoverPromoted runtimeDecls prog current =
  let prog1 = prePassDict (returnPosMethodNames prog ++ methodConstraintNames prog) current prog
  let _ = checkProgramSeeded (externSchemes runtimeDecls) prog1
  discoverNext runtimeDecls prog current (dedup (current ++ promotedRef.value))

discoverNext : List Decl -> List Decl -> List String -> List String -> List String
discoverNext runtimeDecls prog current next
  | listLen next == listLen current = current
  | otherwise = discoverPromoted runtimeDecls prog next

-- ── Cause A: module-path promotion fixpoint ───────────────────────────────
-- The multi-module analogue of discoverPromoted/discoverAll.  elaborateModules
-- typechecks each module in its own frame (checkModuleFullImpl), but PROMOTION
-- (deciding which unsignatured fns carry an inferred constraint) needs to see the
-- whole graph at once so a caller in module B that uses a constrained fn from A is
-- discovered.  Mirror the oracle's joint mark→typecheck: flatten runtime ++ core ++
-- all modules into ONE program and run discoverPromoted's fixpoint on it.  The seed
-- is dictEligibleRef (already set to the user modules' fn names).  Returns the
-- promoted names and, as a side effect, seeds crossModuleFunConstraintsRef with the
-- joint-discovered constraint arities (count per promoted fn) so they survive the
-- per-module resetState and dictArityOf can read them at the final dictPass —
-- mirroring how each defining module's own pass re-registers REAL var-ids into
-- activeDictVars (the count must agree; the body routes carry the surviving ids).
-- argNames marks ARG-position method occurrences EMethodAt so inferMethodAt's
-- recordArgSiteFn surfaces an inferred arg-position constraint to inferredConstraintIds
-- (the Cause-A `f s = display s` shape, where the dispatch is the bare method itself).
discoverPromotedModules : List Decl -> List Decl -> List (String, List Decl) -> List String -> List String -> List String
discoverPromotedModules runtimeDecls coreDecls modules rpNames argNames =
  let joint = coreDecls ++ flatMap snd modules
  let dictSeed = moduleDictNames coreDecls joint modules
  let savedSticky = typeErrorsSticky.value
  let savedErrors = typeErrors.value
  -- Drop the prelude/core defs AND signatures shadowed by a same-named user-module
  -- fn before the SCRATCH joint typecheck.  The joint flatten is bare-name, so a
  -- core fn with a concrete signature (e.g. `isEven : Int -> Bool`) would otherwise
  -- PIN the user's same-named fn's inferred scheme to that concrete type — the
  -- user's genuinely-constrained `isEven x = x % 2 == 0` (inferred `Num a => …`)
  -- would NOT be discovered as promoted, so its define gets no leading dict param
  -- while its body still routes `$dict_isEven_0` (the real per-module pass, where the
  -- user fn shadows the prelude in its own scope, DOES infer the constraint) →
  -- `unbound identifier: $dict_isEven_0` on the run/loader path.  The real per-module
  -- pass already honours shadowing; mirror it here so discovery promotes the user fn.
  let discoveryJoint = dropShadowedCore (moduleUserFnNames modules) coreDecls ++ flatMap snd modules
  let grown = discoverPromotedJoint runtimeDecls discoveryJoint rpNames argNames dictSeed
  let promoted = filterList (n => not (contains n dictSeed)) grown
  let snapshot = promotedConstraints promoted funConstraintsRef.value
  let snapshotIfaces = promotedConstraintIfaces promoted funConstraintIfacesRef.value
  -- WS-1b: expand the cross-module snapshot's super slots too, so a cross-module
  -- constrained fn reached from another module under-fills exactly like clamp would.
  let expandedPair = expandSupersCross joint snapshot snapshotIfaces
  let snapshotE = fst expandedPair
  let snapshotIfacesE = snd expandedPair
  let _ = resetState ()
  let _ = setRef typeErrorsSticky savedSticky
  let _ = setRef typeErrors savedErrors
  let _ = setRef crossModuleFunConstraintsRef snapshotE
  let _ = setRef crossModuleFunConstraintIfacesRef snapshotIfacesE
  promoted
-- DRIVER-COLLAPSE Phase 2: discovery is a SCRATCH joint typecheck (see below); its
-- type-error side effects must NOT leak into the STICKY accumulator that gates the
-- build/run exit code.  The joint-flattened program can surface spurious errors
-- (cross-module names that resolve per-module but look ambiguous flattened) that
-- the REAL per-module pass (elabModulesGo) does not — so snapshot typeErrors +
-- typeErrorsSticky here and restore them after, leaving the gate to reflect only
-- the real per-module typecheck.  On the EMIT path discovery already ran, but
-- elaborateModules's caller (the emit driver) never reads hadTypeErrors, so this
-- was latent; the eval-path build/run gate (typecheckGate) DOES read it.

-- discoverPromotedJoint returns dictSeed GROWN by the newly-promoted user fns;
-- subtract the seed so [promoted] is ONLY the inferred-constraint user fns (the
-- prelude constrained fns in dictSeed are already handled by moduleDictNames +
-- constrainedSigArity — re-snapshotting THEIR joint-discovery arity into
-- crossModuleFunConstraintsRef would override each module's own sig-registered
-- arity and drop the prelude helpers' element-dict args → SIGSEGV).

-- Discovery is a SCRATCH typecheck purely to compute the promoted-name set; its
-- side effects on the shared inference refs (funConstraintsRef/activeDictVars/
-- pendingArgStamps/route refs left by the last checkProgramSeeded) must NOT leak
-- into the real per-module stamping that follows.  resetState wipes them; the
-- promoted arities survive in the snapshot, carried to the real pass via
-- crossModuleFunConstraintsRef.  dictEligibleRef + emitArgStampPasses are NOT touched
-- by resetState (set by the driver, constant).

-- Fixpoint body: prePass the joint program (return-position + constrained-fn names
-- → EMethodAt/EDictAt; arg-position method names → EMethodAt), typecheck it whole
-- (checkProgramSeeded resets promotedRef + funConstraintsRef each pass), grow the
-- set by the newly-promoted names, repeat until stable.  Uses prePassDictArg so
-- arg-position dispatch surfaces inferred constraints (recordArgSiteFn → methodSiteFns).
discoverPromotedJoint : List Decl -> List Decl -> List String -> List String -> List String -> List String
discoverPromotedJoint runtimeDecls joint rpNames argNames current =
  let prog1 = prePassDictArg (rpNames ++ methodConstraintNames joint) current argNames [] joint
  let _ = checkProgramSeeded (externSchemes runtimeDecls) prog1
  discoverNextJoint
    runtimeDecls
    joint
    rpNames
    argNames
    current
    (dedup (current ++ promotedRef.value))

discoverNextJoint : List Decl -> List Decl -> List String -> List String -> List String -> List String -> List String
discoverNextJoint runtimeDecls joint rpNames argNames current next
  | listLen next == listLen current = current
  | otherwise = discoverPromotedJoint runtimeDecls joint rpNames argNames next

-- the funConstraintsRef entries (name, ids) for the promoted user fns only —
-- snapshot of the joint discovery, carried across resetState by
-- crossModuleFunConstraintsRef so dictArityOf reads the right param count.
promotedConstraints : List String -> List (String, List Int) -> List (String, List Int)
promotedConstraints promoted entries =
  filterList (e => contains (fst e) promoted) entries

-- iface-list analog of promotedConstraints (parallel filter for funConstraintIfacesRef).
promotedConstraintIfaces : List String -> List (String, List String) -> List (String, List String)
promotedConstraintIfaces promoted entries =
  filterList (e => contains (fst e) promoted) entries

-- the USER modules' top-level fn names (NOT core/prelude) — the promotion-eligible
-- set on the build path.  Mirrors elaborateDict's eligibleNames = funNamesOf userDecls.
moduleUserFnNames : List (String, List Decl) -> List String
moduleUserFnNames modules =
  dedup (flatMap (p => map fst (funDefs (snd p))) modules)

-- Drop every core/prelude DEF and TYPE SIGNATURE whose name a user module
-- redefines, for the SCRATCH joint-discovery typecheck.  Unlike eval's
-- dropShadowed (DFunDef only), this ALSO drops the shadowed DTypeSig — the
-- signature is precisely what would pin the user fn's inferred scheme to the
-- prelude's concrete type and suppress its promotion.  Non-fn decls (impls,
-- interfaces, data) are kept (a user fn name can't shadow them).
dropShadowedCore : List String -> List Decl -> List Decl
dropShadowedCore _ [] = []
dropShadowedCore names ((DFunDef pub n pats body)::rest)
  | contains n names = dropShadowedCore names rest
  | otherwise = DFunDef pub n pats body :: dropShadowedCore names rest
dropShadowedCore names ((DTypeSig pub n ty)::rest)
  | contains n names = dropShadowedCore names rest
  | otherwise = DTypeSig pub n ty :: dropShadowedCore names rest
dropShadowedCore names (d::rest) = d :: dropShadowedCore names rest

-- the user program's top-level functions carrying a `=>` constraint in their
-- signature — the set elaborateDict dict-passes
export constrainedSigNames : List Decl -> List String
constrainedSigNames prog = flatMap constrainedSigName prog

constrainedSigName : Decl -> List String
constrainedSigName (DTypeSig _ n ty)
  | isConstrainedTy ty = [n]
  | otherwise = []
constrainedSigName _ = []

isConstrainedTy : Ty -> Bool
isConstrainedTy (TyConstrained _ _) = True
isConstrainedTy _ = False

-- The PRELUDE's own `=>`-constrained fns that must ALSO be dict-passed: those
-- whose body uses a return-position method (`when`/`unless` use `pure`), so
-- arg-tag dispatch can't resolve it at a constraint variable's type.  Every OTHER
-- constrained prelude fn (sum/any/elem/clamp/…) uses only arg-position methods —
-- arg-tag already resolves those, and the goldens type-check with them on RKey, so
-- they stay OUT.  [allDecls] supplies the interface set for returnPosMethodNames;
-- bodies come from [preludeDecls] (the shadow-dropped prelude).
export preludeReturnPosDictNames : List Decl -> List Decl -> List String
preludeReturnPosDictNames preludeDecls allDecls =
  let rpNames = returnPosMethodNames allDecls
  filterList
    (n => anyMember (declBodyVars n preludeDecls) rpNames)
    (constrainedSigNames preludeDecls)

-- D3b-2: the PRELUDE's `=>`-constrained fns that dispatch a method in ARGUMENT
-- position (the ~23 helpers: neq/elem/any/all/find/count/sum/product/maximum/
-- minimum/clamp/flatMap/flat/debugListItems/displayListItems/hashListItems/print/
-- println).  These stay OUT of the eval/golden dict set — arg-tag resolves them in
-- ceval (tagged values) and the goldens type-check with them on RKey — but the
-- NATIVE emit path MUST dict-pass them: arg-tag cannot dispatch on a PRIMITIVE
-- element (an `Int`/`String` immediate carries no cell tag).  The arg-position
-- analogue of preludeReturnPosDictNames: every constrained prelude fn that is NOT
-- already return-position.  Wired (alongside preludeReturnPosDictNames) into the
-- emit + dict_pp-oracle drivers ONLY (llvm_emit_typed_main / core_ir_dict_pp_main),
-- which no golden driver shares — so module/`=== TYPES ===`/eval goldens stay
-- byte-identical; the body sites route RDict $dict_<method>_<slot> through the same
-- activeDictVars layer registerConstraintRegs already builds for return-position.
export preludeArgPosDictNames : List Decl -> List Decl -> List String
preludeArgPosDictNames preludeDecls allDecls =
  let rpSet = preludeReturnPosDictNames preludeDecls allDecls
  filterList (n => not (contains n rpSet)) (constrainedSigNames preludeDecls)

-- the EVars referenced anywhere in [n]'s definition body (multi-clause: union)
declBodyVars : String -> List Decl -> List String
declBodyVars n decls = flatMap (declBodyVarsOf n) decls

declBodyVarsOf : String -> Decl -> List String
declBodyVarsOf n (DFunDef _ m _ body)
  | n == m = allEVars body
  | otherwise = []
declBodyVarsOf _ _ = []

-- methods whose interface type param appears ONLY in the result (no argument
-- mentions it) — pure/empty/minBound/maxBound/fromInt/… — are return-position
returnPosMethodNames : List Decl -> List String
returnPosMethodNames prog = flatMap returnPosOfDecl prog

returnPosOfDecl : Decl -> List String
returnPosOfDecl (DInterface { typarams, methods, ... }) =
  flatMap (returnPosMethod typarams) methods
returnPosOfDecl _ = []

returnPosMethod : List String -> IfaceMethod -> List String
returnPosMethod typarams (IfaceMethod mname mty _)
  | not (anyArgMentions (dispatchTyparams typarams) (methodArgs mty)) = [mname]
  | otherwise = []

-- argument types of a method (strip leading constraint/effect wrappers + arrows)
methodArgs : Ty -> List Ty
methodArgs (TyConstrained _ t) = methodArgs t
methodArgs (TyEffect _ _ t) = methodArgs t
methodArgs (TyFun a b) = a :: methodArgs b
methodArgs _ = []

anyArgMentions : List String -> List Ty -> Bool
anyArgMentions _ [] = False
anyArgMentions typarams (ty::rest) = argMentions typarams ty
  || anyArgMentions typarams rest

argMentions : List String -> Ty -> Bool
argMentions typarams ty = anyMember (tyVarNames ty) typarams

anyMember : List String -> List String -> Bool
anyMember [] _ = False
anyMember (x::xs) ys = contains x ys || anyMember xs ys

-- rewrite each return-position method occurrence to EMethodAt, and each
-- constrained-fn occurrence (a name in [dictNames]) to EDictAt — both carry a
-- fresh ref the typechecker fills.  The two name sets are disjoint (interface
-- methods vs top-level functions).
prePassDict : List String -> List String -> List Decl -> List Decl
prePassDict rpNames dictNames prog =
  mapProg (rewriteRPDict rpNames dictNames) prog

-- [rpNames] here is the union of return-position methods AND method-level-
-- constrained methods (foldMap): both must become EMethodAt so eval can narrow by
-- the t-route and/or fold on the method-level dicts.
rewriteRPDict : List String -> List String -> Expr -> Expr
rewriteRPDict rpNames dictNames (EVar n)
  | contains n rpNames = EMethodAt n (Ref RNone) (Ref []) (Ref [])
  | contains n dictNames = EDictAt n (Ref [])
  | otherwise = EVar n
rewriteRPDict _ _ e = e

-- D3a: like prePassDict but ALSO rewrite ARG-position method occurrences (names in
-- [argNames]) to EMethodAt, so inferMethodAt can stamp their route from the
-- discriminating-argument type.  [argNames] is empty unless emitArgStampPasses (the
-- emit path), so the golden/oracle paths get the same tree prePassDict produced.
-- The golden/oracle path (argNames == []) keeps the scope-BLIND mapProg rewrite,
-- byte-for-byte identical to prePassDict.  The emit path (argNames non-empty, set
-- only under emitArgStampPasses) instead uses the SCOPE-AWARE rewriteArgScoped below:
-- an arg-position interface-method name (in argNames) that is shadowed by a local
-- binder (a parameter, let, lambda arg, or match-pattern variable) stays a plain
-- EVar rather than becoming an EMethodAt.  This mirrors the reference typecheck's
-- Phase-95 `env.locals` guard (lib/typecheck.ml's EVar arm): the OCaml marker is
-- likewise scope-blind and the reference RECOVERS at inference by skipping the
-- scope-blind method table for locally-bound names.  Without it, a compiler
-- function whose parameter happens to share a method name (`arithOp lt rt`,
-- `composeOp gt ht`, `exprToPat … sub`) has that parameter mis-marked as a method
-- occurrence → arg-tag dispatch with no impl groups at emit time.  Gated on
-- argNames so the golden path is provably unchanged.  The rp/an/dn arms are ALL
-- scope-aware on this (emit + run `elaborateDict`) path: a local binder shadowing
-- a return-position method name (`let debug = 99` inside a fn body) keeps the
-- reference a plain EVar so inference resolves it to the local instead of
-- mis-stamping RKey<resultType> and dispatching to the prelude impl.  Mirrors
-- lib/typecheck.ml's `env.locals` guard, which skips the method_iface table for
-- any locally-bound name (the OCaml EVar-arm recovery).  Byte-identical for the
-- corpus (no corpus rp/arg/constrained name is shadowed by a local — the guard
-- only changes behaviour for a genuinely-shadowing local: an arg-method
-- `lt`/`gt`/`sub`, a constrained fn `elem`, or a return-position method `debug`).
-- The non-emit `mapProg` path (argNames == []) stays scope-blind.
-- [shadowMap] (P0-18) is the mangle definer-shadow map — non-empty only on the emit
-- path (argNames non-empty).  The scope-blind `mapProg` path (argNames == []) never
-- has mangled shadows, so it ignores it and stays byte-identical.
prePassDictArg : List String -> List String -> List String -> List (String, String) -> List Decl -> List Decl
prePassDictArg rpNames dictNames [] _ prog =
  mapProg (rewriteRPDictArg rpNames dictNames []) prog
prePassDictArg rpNames dictNames argNames shadowMap prog =
  map (prePassDeclScoped (ArgRw rpNames dictNames argNames shadowMap)) prog

rewriteRPDictArg : List String -> List String -> List String -> Expr -> Expr
rewriteRPDictArg rpNames dictNames argNames (EVar n)
  | contains n rpNames = EMethodAt n (Ref RNone) (Ref []) (Ref [])
  | contains n argNames = EMethodAt n (Ref RNone) (Ref []) (Ref [])
  | contains n dictNames = EDictAt n (Ref [])
  | otherwise = EVar n
rewriteRPDictArg _ _ _ e = e

-- ── scope-aware arg-position prepass (emit path; D3a shadow guard) ───────────
-- The three name sets carried through the scope-threaded rewrite (rp = return-
-- position methods, dn = constrained-fn dict names, an = arg-position methods).
-- rp = return-position methods, dn = constrained-fn dict names, an = arg-position
-- methods, sm = the P0-18 mangle definer-shadow map (mangledSymbol ↦ bareMethod).
data ArgRw =
  | ArgRw (List String) (List String) (List String) (List (String, String))

-- rewrite a decl body with its own parameters seeded into the bound set.  Mirrors
-- desugar's mapDecl coverage exactly (DFunDef / DInterface / DImpl / DProp /
-- DTest / DBench / DAttrib; everything else — incl. DLetGroup — left unchanged),
-- so with the emit path off this would degenerate to the same node set mapProg
-- visits.
prePassDeclScoped : ArgRw -> Decl -> Decl
prePassDeclScoped rw (DFunDef pub n ps e) =
  DFunDef pub n ps (rewriteArgScoped rw (patVarsListTc ps) e)
prePassDeclScoped rw (d@(DInterface { methods, ... })) =
  DInterface { d | methods = map (prePassIfaceMethodScoped rw) methods }
prePassDeclScoped rw (d@(DImpl { methods, ... })) =
  DImpl { d | methods = map (prePassImplMethodScoped rw) methods }
prePassDeclScoped rw (DProp pub name params body) =
  DProp pub name params (rewriteArgScoped rw (propParamNamesTc params) body)
prePassDeclScoped rw (DTest pub name body) =
  DTest pub name (rewriteArgScoped rw [] body)
prePassDeclScoped rw (DBench pub name body) =
  DBench pub name (rewriteArgScoped rw [] body)
prePassDeclScoped rw (DAttrib attrs d) = DAttrib attrs (prePassDeclScoped rw d)
-- Top-level `let rec … with …` (DLetGroup): mapDecl/the catch-all skip its bodies,
-- so a constrained-fn occurrence inside a group body would never be rewritten to
-- EDictAt/EMethodAt → its call site gets no dict route → the dict-passed callee is
-- under-applied at eval.  Rewrite each clause body with that clause's params scoped
-- in, exactly like the DFunDef arm.
prePassDeclScoped rw (DLetGroup pub binds) =
  DLetGroup pub (map (prePassLetBindScoped rw) binds)
prePassDeclScoped _ d = d

prePassLetBindScoped : ArgRw -> LetBind -> LetBind
prePassLetBindScoped rw (LetBind n clauses) =
  LetBind n (map (prePassFunClauseScoped rw) clauses)

prePassFunClauseScoped : ArgRw -> FunClause -> FunClause
prePassFunClauseScoped rw (FunClause ps e) =
  FunClause ps (rewriteArgScoped rw (patVarsListTc ps) e)

prePassIfaceMethodScoped : ArgRw -> IfaceMethod -> IfaceMethod
prePassIfaceMethodScoped _ (IfaceMethod n ty None) = IfaceMethod n ty None
prePassIfaceMethodScoped rw (IfaceMethod n ty (Some (MethodDefault ps e))) =
  IfaceMethod
    n
    ty
    (Some (MethodDefault ps (rewriteArgScoped rw (patVarsListTc ps) e)))

prePassImplMethodScoped : ArgRw -> ImplMethod -> ImplMethod
prePassImplMethodScoped rw (ImplMethod n ps e) =
  ImplMethod n ps (rewriteArgScoped rw (patVarsListTc ps) e)

propParamNamesTc : List PropParam -> List String
propParamNamesTc ps = map propParamName ps

propParamName : PropParam -> String
propParamName (PropParam n _) = n

-- the core scope-threaded rewrite.  `bound` is the set of names in scope as
-- locals at this node.  At an EVar: the rp arm is scope-blind (unchanged); the
-- arg-position (`an`) and constrained-fn (`dn`) arms fire only when the name is
-- NOT shadowed by a local.  Binders
-- (ELam/ELet/ELetGroup/EMatch arms/EBlock/EDo + the where/do/guard
-- binders) extend `bound`; every other node recurses into its children with the
-- same `bound`.
rewriteArgScoped : ArgRw -> List String -> Expr -> Expr
rewriteArgScoped (ArgRw rp dn an sm) bound (EVar n)
  -- P0-18: `n` is a MANGLED definer-shadow standalone (`<mid>__size`).  Mark it
  -- `EMethodAt` with the BARE dispatch name (so `implFor` finds the impl when the
  -- receiver has one) and seed the route's `RLocal <n>` fallback with the mangled
  -- symbol (so a no-impl receiver still reaches the standalone `@mdk_<mid>__size`).
  | not (contains n bound) && isSome (lookupAssoc n sm) =
    match lookupAssoc n sm
      Some bare => EMethodAt bare (Ref (RLocal n [])) (Ref []) (Ref [])
      None => EVar n
  | contains n rp && not (contains n bound) =
    EMethodAt n (Ref RNone) (Ref []) (Ref [])
  | contains n an && not (contains n bound) =
    EMethodAt n (Ref RNone) (Ref []) (Ref [])
  | contains n dn && not (contains n bound) = EDictAt n (Ref [])
  | otherwise = EVar n
-- binders
rewriteArgScoped rw bound (ELam ps body) =
  ELam ps (rewriteArgScoped rw (patVarsListTc ps ++ bound) body)
rewriteArgScoped rw bound (ELet m r p e1 e2) =
  let pv = patVarsTc p
  let b1 = if r then pv ++ bound else bound
  ELet m r p (rewriteArgScoped rw b1 e1) (rewriteArgScoped rw (pv ++ bound) e2)
rewriteArgScoped rw bound (ELetGroup binds e2) =
  let bnd = letBindNamesTc binds ++ bound
  ELetGroup (map (rewriteArgLetBind rw bnd) binds) (rewriteArgScoped rw bnd e2)
rewriteArgScoped rw bound (EMatch e0 arms) =
  EMatch (rewriteArgScoped rw bound e0) (map (rewriteArgArm rw bound) arms)
rewriteArgScoped rw bound (EBlock stmts) =
  EBlock (rewriteArgStmts rw bound stmts)
rewriteArgScoped rw bound (EDo stmts) = EDo (rewriteArgStmts rw bound stmts)
-- non-binder composites: recurse children with the same bound
rewriteArgScoped rw bound (ELoc l e) = ELoc l (rewriteArgScoped rw bound e)
rewriteArgScoped rw bound (EDoOrigin l e) =
  EDoOrigin l (rewriteArgScoped rw bound e)
rewriteArgScoped rw bound (EApp f x) =
  EApp (rewriteArgScoped rw bound f) (rewriteArgScoped rw bound x)
rewriteArgScoped rw bound (EIf c t e) =
  EIf
    (rewriteArgScoped rw bound c)
    (rewriteArgScoped rw bound t)
    (rewriteArgScoped rw bound e)
rewriteArgScoped rw bound (EBinOp op l r dr) =
  EBinOp op (rewriteArgScoped rw bound l) (rewriteArgScoped rw bound r) dr
rewriteArgScoped rw bound (EUnOp op x dr) =
  EUnOp op (rewriteArgScoped rw bound x) dr
rewriteArgScoped rw bound (EInfix op l r) =
  EInfix op (rewriteArgScoped rw bound l) (rewriteArgScoped rw bound r)
rewriteArgScoped rw bound (EFieldAccess e0 n r) =
  EFieldAccess (rewriteArgScoped rw bound e0) n r
rewriteArgScoped rw bound (ETuple es) =
  ETuple (map (rewriteArgScoped rw bound) es)
rewriteArgScoped rw bound (EListLit es) =
  EListLit (map (rewriteArgScoped rw bound) es)
rewriteArgScoped rw bound (EArrayLit es) =
  EArrayLit (map (rewriteArgScoped rw bound) es)
rewriteArgScoped rw bound (ERangeList lo hi i) =
  ERangeList (rewriteArgScoped rw bound lo) (rewriteArgScoped rw bound hi) i
rewriteArgScoped rw bound (ERangeArray lo hi i) =
  ERangeArray (rewriteArgScoped rw bound lo) (rewriteArgScoped rw bound hi) i
rewriteArgScoped rw bound (ESlice e0 lo hi i r) =
  ESlice
    (rewriteArgScoped rw bound e0)
    (rewriteArgScoped rw bound lo)
    (rewriteArgScoped rw bound hi)
    i
    r
rewriteArgScoped rw bound (EIndex e0 i r) =
  EIndex (rewriteArgScoped rw bound e0) (rewriteArgScoped rw bound i) r
rewriteArgScoped rw bound (EAnnot e0 t) =
  EAnnot (rewriteArgScoped rw bound e0) t
rewriteArgScoped rw bound (EHeadAnnot e0 t) =
  EHeadAnnot (rewriteArgScoped rw bound e0) t
rewriteArgScoped rw bound (ERecordCreate n fs) =
  ERecordCreate n (map (rewriteArgField rw bound) fs)
rewriteArgScoped rw bound (ERecordUpdate e0 fs r) =
  ERecordUpdate
    (rewriteArgScoped rw bound e0)
    (map (rewriteArgField rw bound) fs)
    r
rewriteArgScoped rw bound (EVariantUpdate c e0 fs) =
  EVariantUpdate
    c
    (rewriteArgScoped rw bound e0)
    (map (rewriteArgField rw bound) fs)
rewriteArgScoped rw bound (EStringInterp parts) =
  EStringInterp (map (rewriteArgInterp rw bound) parts)
rewriteArgScoped rw bound (EGuards arms) =
  EGuards (map (rewriteArgGuardArm rw bound) arms)
rewriteArgScoped rw bound (ESection (SecRight op e0)) =
  ESection (SecRight op (rewriteArgScoped rw bound e0))
rewriteArgScoped rw bound (ESection (SecLeft e0 op)) =
  ESection (SecLeft (rewriteArgScoped rw bound e0) op)
rewriteArgScoped rw bound (EMapLit n kvs) =
  EMapLit n (map (rewriteArgKv rw bound) kvs)
rewriteArgScoped rw bound (ESetLit n es) =
  ESetLit n (map (rewriteArgScoped rw bound) es)
rewriteArgScoped rw bound (EAsPat x sub) =
  EAsPat x (rewriteArgScoped rw bound sub)
-- leaves (ELit / EMethodRef / EDictApp / EVarAt / EMethodAt / EDictAt / SecBare)
rewriteArgScoped _ _ e = e

rewriteArgField : ArgRw -> List String -> FieldAssign -> FieldAssign
rewriteArgField rw bound (FieldAssign n e) =
  FieldAssign n (rewriteArgScoped rw bound e)

rewriteArgKv : ArgRw -> List String -> (Expr, Expr) -> (Expr, Expr)
rewriteArgKv rw bound (k, v) =
  (rewriteArgScoped rw bound k, rewriteArgScoped rw bound v)

rewriteArgInterp : ArgRw -> List String -> InterpPart -> InterpPart
rewriteArgInterp _ _ (InterpStr s) = InterpStr s
rewriteArgInterp rw bound (InterpExpr e) =
  InterpExpr (rewriteArgScoped rw bound e)

rewriteArgLetBind : ArgRw -> List String -> LetBind -> LetBind
rewriteArgLetBind rw bound (LetBind n clauses) =
  LetBind n (map (rewriteArgFunClause rw bound) clauses)

rewriteArgFunClause : ArgRw -> List String -> FunClause -> FunClause
rewriteArgFunClause rw bound (FunClause ps body) =
  FunClause ps (rewriteArgScoped rw (patVarsListTc ps ++ bound) body)

-- a match/function arm: the pattern binds for the guards + body; a `| p <- e`
-- guard binds for later guards + the body (threaded left-to-right).
rewriteArgArm : ArgRw -> List String -> Arm -> Arm
rewriteArgArm rw bound (Arm p gs body) =
  let b0 = patVarsTc p ++ bound
  let (gs2, bnd) = rewriteArgGuards rw b0 gs
  Arm p gs2 (rewriteArgScoped rw bnd body)

rewriteArgGuardArm : ArgRw -> List String -> GuardArm -> GuardArm
rewriteArgGuardArm rw bound (GuardArm gs body) =
  let (gs2, bnd) = rewriteArgGuards rw bound gs
  GuardArm gs2 (rewriteArgScoped rw bnd body)

rewriteArgGuards : ArgRw -> List String -> List Guard -> (List Guard, List String)
rewriteArgGuards _ bound [] = ([], bound)
rewriteArgGuards rw bound ((GBool e)::rest) =
  let e2 = rewriteArgScoped rw bound e
  let (rest2, bnd) = rewriteArgGuards rw bound rest
  (GBool e2 :: rest2, bnd)
rewriteArgGuards rw bound ((GBind p e)::rest) =
  let e2 = rewriteArgScoped rw bound e
  let (rest2, bnd) = rewriteArgGuards rw (patVarsTc p ++ bound) rest
  (GBind p e2 :: rest2, bnd)

-- do/block statements: a DoBind/DoLet pattern binds for SUBSEQUENT
-- statements (a recursive DoLet also for its own RHS).
rewriteArgStmts : ArgRw -> List String -> List DoStmt -> List DoStmt
rewriteArgStmts _ _ [] = []
rewriteArgStmts rw bound ((DoExpr e)::rest) =
  DoExpr (rewriteArgScoped rw bound e) :: rewriteArgStmts rw bound rest
rewriteArgStmts rw bound ((DoBind p e)::rest) =
  DoBind p (rewriteArgScoped rw bound e) ::
    rewriteArgStmts rw (patVarsTc p ++ bound) rest
rewriteArgStmts rw bound ((DoLet m r p e)::rest) =
  let b1 = if r then patVarsTc p ++ bound else bound
  DoLet m r p (rewriteArgScoped rw b1 e) :: rewriteArgStmts rw (patVarsTc p ++ bound) rest
rewriteArgStmts rw bound ((DoAssign x e)::rest) =
  DoAssign x (rewriteArgScoped rw bound e) :: rewriteArgStmts rw bound rest
rewriteArgStmts rw bound ((DoFieldAssign x fs e)::rest) =
  DoFieldAssign x fs (rewriteArgScoped rw bound e) ::
    rewriteArgStmts rw bound rest

letBindNamesTc : List LetBind -> List String
letBindNamesTc binds = map letBindNameTc binds

letBindNameTc : LetBind -> String
letBindNameTc (LetBind n _) = n

-- the variables a pattern binds (local copy; llvm_emit's patVars isn't importable
-- here, and this one also covers PRec field/pun binders).
patVarsTc : Pat -> List String
patVarsTc (PVar x) = [x]
patVarsTc (PCon _ args) = patVarsListTc args
patVarsTc (PCons h t) = patVarsTc h ++ patVarsTc t
patVarsTc (PTuple ps) = patVarsListTc ps
patVarsTc (PList ps) = patVarsListTc ps
patVarsTc (PAs x p) = x :: patVarsTc p
patVarsTc (PRec _ fields _) = flatMap recPatFieldVarsTc fields
patVarsTc _ = []

patVarsListTc : List Pat -> List String
patVarsListTc ps = flatMap patVarsTc ps

recPatFieldVarsTc : RecPatField -> List String
recPatFieldVarsTc (RecPatField label None) = [label]
recPatFieldVarsTc (RecPatField _ (Some p)) = patVarsTc p

-- interface methods carrying a method-level constraint (a `=>` over a tyvar that is
-- NOT the interface param, e.g. foldMap's `Monoid m`) — rewritten to EMethodAt
-- alongside the return-position methods so the method-level dict can be folded on.
-- Computed structurally (runs before checkProgramSeeded populates methodConstraintsRef).
methodConstraintNames : List Decl -> List String
methodConstraintNames prog = flatMap methodConstraintNamesOfDecl prog

methodConstraintNamesOfDecl : Decl -> List String
methodConstraintNamesOfDecl (DAttrib _ d) = methodConstraintNamesOfDecl d
methodConstraintNamesOfDecl (DInterface { typarams, methods, ... }) =
  flatMap (methodConstraintNameOf typarams) methods
methodConstraintNamesOfDecl _ = []

methodConstraintNameOf : List String -> IfaceMethod -> List String
methodConstraintNameOf typarams (IfaceMethod mname mty _)
  | hasMethodLevelConstraint typarams mty = [mname]
  | otherwise = []

-- does this method type carry a leading `=>` constraint whose tyvar is not an
-- interface param? (a method-LEVEL constraint, as opposed to one over the param)
hasMethodLevelConstraint : List String -> Ty -> Bool
hasMethodLevelConstraint typarams (TyConstrained cs t) = constraintsHaveMethodLevel typarams cs
  || hasMethodLevelConstraint typarams t
hasMethodLevelConstraint typarams (TyEffect _ _ t) =
  hasMethodLevelConstraint typarams t
hasMethodLevelConstraint _ _ = False

constraintsHaveMethodLevel : List String -> List Constraint -> Bool
constraintsHaveMethodLevel _ [] = False
constraintsHaveMethodLevel typarams (c::rest) = constraintIsMethodLevel typarams c
  || constraintsHaveMethodLevel typarams rest

-- a constraint is method-level iff it mentions at least one tyvar that is not an
-- interface param (so the dict is supplied per-call, not by the impl's dispatch)
constraintIsMethodLevel : List String -> Constraint -> Bool
constraintIsMethodLevel typarams c =
  isNonEmptyL (constraintNonParamVars typarams c)

constraintNonParamVars : List String -> Constraint -> List String
constraintNonParamVars typarams (Constraint _ args) =
  removeAllS typarams (flatMap tyVarNames args)

resolveSites : ImplBuckets -> KeyBuckets -> List String -> List (String, Ref Route, Ref (List Route), Mono, Mono, String) -> Unit
resolveSites _ _ _ [] = ()
resolveSites implTable keyTable rpNames ((name, tagRef, implRef, resultMono, fullMono, encl)::rest) =
  let _ = resolveSite implTable keyTable rpNames name tagRef implRef resultMono fullMono encl
  resolveSites implTable keyTable rpNames rest

-- a method occurrence's route: if its discriminating type is a constrained
-- function's constraint variable, read that function's dict param (RDict);
-- otherwise the concrete impl head tag (RKey); an unresolved polymorphic type
-- stays RNone (arg-tag fallback).  When the route resolves to a concrete head
-- that names a parametric impl WITH a `requires`, also fill the impl-dicts ref so
-- eval threads the element dict(s) into the impl body (Phase 83/84 single-level).
-- Phase 83/84 #5: stamp the route for one pending method site.  At a concrete
-- result type (ground RKey case) the element dict routes are computed recursively
-- by implDictRoutesFor.  At a polymorphic result type (RDict case) the route is
-- RDictFwd for return-position methods — eval will extract and forward the
-- enclosing VDict's nested requires at runtime.  Arg-position methods (display/==)
-- stay RDict; their VMulti dispatch is by arg-tag, not by the forwarded reqs.
-- TYPECHECK-AUDIT C7: the ground RKey case prefers the canonical impl KEY (via
-- keyForSite) over the bare head tycon, so two non-overlapping impls sharing a
-- head tycon (Pair Int Bool vs Pair Bool Int) route to distinct keys; eval's
-- narrowMethod then matches the right VTypedImpl by its key field.  No matching
-- key entry (args-free / unknown) → fall back to the head tag, behaviour unchanged.
-- C5 NOTE: standalone-shadow RLocal routing is NOT done here — a return-position
-- site keys off the RESULT mono (`isEmpty`'s `Bool`), which never names the receiver's
-- impl, so this gate would mis-route every shadow method.  RLocal is stamped by the
-- arg-position resolveRLocalSites (keyed on the RECEIVER mono) AFTER resolveSites.
resolveSite : ImplBuckets -> KeyBuckets -> List String -> String -> Ref Route -> Ref (List Route) -> Mono -> Mono -> String -> Unit
resolveSite implTable keyTable rpNames name tagRef implRef resultMono fullMono encl = match activeDictVarOfEncl resultMono encl
  Some dname => setRef tagRef (if contains name rpNames then RDictFwd dname else RDict dname)
  None => match headTyconMono resultMono
    Some tag =>
      let routeKey = fromOption tag (keyForSite keyTable name resultMono)
      let _ = setRef tagRef (RKey routeKey [])
      let paramMonos = fromOption [resultMono] (ifaceParamMonos name fullMono)
      setRef
        implRef
        (implDictRoutesForFull implTable name tag resultMono paramMonos)
    None => ()

-- Recover the FULL list of interface-type-parameter monos for a method occurrence,
-- ordered by the interface's typaram declaration.  Look up the method's interface
-- (methodIfaceParamsRef: iface, typarams, declared method Ty), match the declared Ty
-- against the occurrence's full mono to bind each typaram → its inferred mono, then
-- read them out in typaram order.  For `fromEntries : List e -> c` matched against the
-- occurrence `List Int -> Set _a`, this yields [Set _a, Int] (c then e) — the element
-- grounding (`e ↦ Int`) the result-only `resultMono` (= c = Set _a) had lost.  None
-- when the method has no registered interface (a plain `=>`-constrained fn) or the
-- declared/occurrence shapes do not match — resolveSite falls back to [resultMono].
ifaceParamMonos : String -> Mono -> Option (List Mono)
ifaceParamMonos name fullMono = match omLookup name methodIfaceParamsRef.value
  None => None
  Some (_, typarams, mty) =>
    map (subst => map (paramMonoOf subst) typarams) (matchTyMono mty fullMono)

paramMonoOf : List (String, Mono) -> String -> Mono
paramMonoOf subst tp = fromOption (TCon tp) (lookupAssoc tp subst)

-- C5: does some impl in [keyTable] define method [name] at head tycon [tag]?  The
-- static analogue of eval's narrowMethod finding a VTypedImpl tagged [tag] in the
-- method's VMulti — keyTable carries one entry per user+prelude impl with the methods
-- it defines and its head tycon.  Mirrors lib/typecheck.ml's impl_exists_for_head.
implExistsForHead : KeyBuckets -> String -> String -> Bool
implExistsForHead buckets name tag =
  implExistsForHeadGo (bucketOf tag buckets) name tag

implExistsForHeadGo : List KeyEntry -> String -> String -> Bool
implExistsForHeadGo [] _ _ = False
implExistsForHeadGo ((KeyEntry methods tag2 _ _)::rest) name tag
  | tag2 == tag && contains name methods = True
  | otherwise = implExistsForHeadGo rest name tag

-- C5: stamp RLocal on each recorded standalone-shadow arg-position site whose
-- receiver mono now grounds to a concrete head tycon with NO impl of the method.
-- The receiver HAS an impl (the genuine-method case, e.g. `toList (Some 7)`) → leave
-- the route untouched (RNone → eval arg-tag-dispatches to the real impl).  An
-- ungrounded receiver (still a tyvar) → leave it (polymorphic, deferred).  Mirrors
-- lib/typecheck.ml:1603-1640: RLocal only when impl_exists is false.
-- S-1: [prog]/[implTable] are here so the stamp can call routesOfMonosTop — a PURE
-- function of the (union-find-solved) constraint monos — and fill the standalone's own
-- dict routes IN PLACE.  Deliberately NOT routed through pendingDictApps: that list is
-- resolved by resolveDictApps, which runs AFTER this in elabModuleStamp, so the stamp
-- would read `[]`.  Resolving inside the stamp is ordering-immune.  An unconstrained
-- standalone has no monos ⇒ routesOfMonosTop returns [] immediately (it cannot even
-- reach its AmbiguousImpl arm) ⇒ `RLocal sym []` ⇒ byte-identical to the pre-S1 stamp.
resolveRLocalSites : List Decl -> ImplBuckets -> KeyBuckets -> List RLocalSite -> Unit
resolveRLocalSites _ _ _ [] = ()
resolveRLocalSites prog implTable keyTable ((RLocalSite name tagRef am sym forceLocal monos ifaces)::rest) =
  let _ = if forceLocal then
    setRef tagRef (RLocal sym (routesOfMonosTop prog implTable monos ifaces))
  else
    resolveRLocalSite prog implTable keyTable name tagRef am sym monos ifaces
  resolveRLocalSites prog implTable keyTable rest

-- C5: stamp RLocal on each recorded standalone-shadow arg-position site whose
-- receiver mono now grounds to a concrete head tycon with NO impl of the method.
-- The receiver HAS an impl (the genuine-method case, e.g. `toList (Some 7)`):
-- leave the route untouched — eval arg-tag-dispatches on RNone; emit already
-- stamped the correct RKey<receiverHead> via resolveArgStamps.
-- An ungrounded receiver (still a tyvar) → leave it.  Mirrors lib/typecheck.ml's
-- RLocal-vs-ordinary-dispatch split (the oracle keys the genuine case off the receiver).
resolveRLocalSite : List Decl -> ImplBuckets -> KeyBuckets -> String -> Ref Route -> Mono -> String -> List Mono -> List String -> Unit
resolveRLocalSite prog implTable keyTable name tagRef am sym monos ifaces = match headTyconMono am
  -- S2 (THE INVERSION): route by SHADOW KIND first, receiver second.
  --   * DEFINER shadow (the name is this module's own top-level fn) → the standalone,
  --     UNCONDITIONALLY.  The impl universe is not consulted; a grounded head with a live
  --     impl no longer steals the call.  (The APP path already forces this via the
  --     RLocalSite `forceLocal` flag; this arm is what carries the other recorders —
  --     notably the VALUE-position sites pushed by the generic recordRLocalSite, which is
  --     gated on standaloneValuesRef and that set holds definer AND importer shadows.)
  --   * IMPORTER shadow (Fork 1) → the OLD per-receiver rule, unchanged: a live impl at the
  --     receiver head dispatches, else the standalone.  An `import` is a SIBLING scope, not
  --     an inner one, so it does not shadow; inverting it too would break the everyday
  --     `import map` pattern (`isEmpty [1,2]` must still reach `Foldable.isEmpty`).
  -- am is the ACTUAL argument type (inferDefinerShadowApp records it), not the standalone's
  -- declared domain, so the importer arm's impl query is still meaningful.
  --
  -- ⚠️ isDefinerShadow — NOT a bare definerShadowNamesRef membership test.  That ref is
  -- populated for a multi-TYPARAM interface's method too, but EVERY typing entry point is
  -- gated on singleParamIfaceMethod and so leaves such an occurrence to ordinary dispatch
  -- (the open S-3 / row-26 bug).  Forcing RLocal here without the same gate would route a
  -- site whose TYPE came from the dispatch path — route and type disagreeing is exactly the
  -- P0-20 bug class.  Keep the two gates identical.
  Some tag => stampRLocalOrFallback
    (not (isDefinerShadow name) && implExistsForHead keyTable name tag)
    tagRef sym
    (routesOfMonosTop prog implTable monos ifaces)
  -- An UNGROUNDED definer-shadow receiver keeps the old default (RLocal → standalone);
  -- other (importer) ungrounded sites stay untouched (deferred/polymorphic).
  None => if contains name definerShadowNamesRef.value then
    setRef tagRef (RLocal sym (routesOfMonosTop prog implTable monos ifaces))
  else ()

-- C5: hasImpl ⇒ genuine method; route already correct (RNone for arg-tag eval,
-- or RKey stamped by resolveArgStamps on emit) — leave untouched.
-- no impl ⇒ standalone shadow ⇒ RLocal, carrying the standalone's own constraint
-- dicts (S-1; [] for an unconstrained standalone ⇒ the pre-S1 stamp exactly).
stampRLocalOrFallback : Bool -> Ref Route -> String -> List Route -> Unit
stampRLocalOrFallback True _ _ _ = ()
stampRLocalOrFallback False tagRef sym dicts = setRef tagRef (RLocal sym dicts)

-- if [m] normalizes to a registered constraint variable, the dict parameter name
-- a method at that type reads.  A return-position method at a HIGHER-KINDED
-- constraint var (`pure : a -> m a`, so the result mono is `m Unit` = TApp (TVar
-- m) Unit) carries the dict var in the application HEAD, not at top level — recurse
-- through TApp to find it.  (A concrete head, e.g. `Option Unit` after unification,
-- is a TCon and falls through to None → RKey, unchanged.)
activeDictVarOf : Mono -> Option String
activeDictVarOf m = match normalize m
  TVar cell => lookupAssocI (tyvarId cell) activeDictVars.value
  TApp a _ => activeDictVarOf a
  _ => None

-- activeDictVarOf, but PREFER the activeDictVars entry whose dict-param name belongs
-- to the enclosing method [encl] (`$dict_<encl>_<slot>`).  registerImplRequires
-- registers EVERY method of an impl under the SAME impl tyvar id (`impl Ord (List a)`
-- registers `a`'s id once per compare/lt/gt/min/max/… each to `$dict_<method>_<slot>`),
-- so the global first-match `activeDictVarOf` returns whichever method registered
-- LAST — inside `compare`'s body that wrongly yields `$dict_max_0` (out of compare's
-- scope → emitter "unbound dict witness").  Picking the [encl]-owned entry keeps each
-- method body's element-dict route bound to ITS OWN leading param.  encl == "" or no
-- match ⇒ fall back to the global lookup (genuine element dict from another impl).
activeDictVarForEncl : Mono -> String -> Option String
activeDictVarForEncl m encl
  | encl == "" = activeDictVarOf m
  | otherwise = match normalize m
    TVar cell => match firstDictForEncl (tyvarId cell) ("$dict_" ++ encl ++ "_") activeDictVars.value
      Some dname => Some dname
      None => activeDictVarOf m
    TApp a _ => activeDictVarForEncl a encl
    _ => None

firstDictForEncl : Int -> String -> List (Int, String) -> Option String
firstDictForEncl _ _ [] = None
firstDictForEncl id pfx ((eid, ename)::rest)
  | eid == id && startsWith pfx ename = Some ename
  | otherwise = firstDictForEncl id pfx rest

-- activeDictVarOf, but for a constraint var that is the ENCLOSING fn's OWN constraint
-- var, return [encl]'s in-scope dict param (the slot it sits at) rather than the
-- GLOBAL activeDictVars entry.  In a mutually-recursive group the constraint vars of
-- the siblings unify to one id; activeDictVars (global, uncleared) maps that id to
-- whichever sibling registered it LAST — so an arg-stamp inside `evenCat` would
-- forward `$dict_oddCat_0` (out of scope in evenCat's body).  Preferring encl's own
-- slot keeps the forwarded dict the one actually bound in the body.  Falls back to
-- the global lookup when the var is not one of encl's (a genuine element dict from a
-- different in-scope impl).
activeDictVarOfEncl : Mono -> String -> Option String
activeDictVarOfEncl m encl = match enclDictVarOf m encl
  Some dname => Some dname
  None => activeDictVarForEncl m encl

enclDictVarOf : Mono -> String -> Option String
enclDictVarOf m encl
  | encl == "" = None
  | otherwise = match normalize m
    TVar cell => map (dictParamName encl) (indexOfId (tyvarId cell) (fromOption [] (lookupAssocSL2 encl funConstraintsRef.value)))
    TApp a _ => enclDictVarOf a encl
    _ => None

-- Phase 151 / Gap G: stamp each comparison/equality OPERATOR site's EBinOp route
-- ref with the resolved Eq/Ord impl key (RKey) — but ONLY when the operand type
-- grounds to a NON-primitive head tycon.  Primitive (Int/Float/String/Bool/Char)
-- and ungroundable operands stay RNone → the structural-builtin EBinOp eval path
-- (so `eq a b = a == b` on Int never recurses).  Mirrors resolveSite's concrete
-- branch (head tycon → canonical key) minus the impl-dicts: the rewritten `eq`/`lt`
-- is arg-position, so it narrows by arg tag and needs no forwarded element dict.
binopPrimitiveHead : String -> Bool
binopPrimitiveHead h = contains h ["Int", "Float", "String", "Bool", "Char"]

-- Roadmap #18a: the heads a binop lowers to a BUILTIN for, and must therefore never
-- route to a typeclass method.  For the comparison operators that is exactly the
-- scalar primitives.  For `++` (→ Semigroup's `append`) it is those PLUS `List`:
-- `++` on a String/List is lowered structurally (eval's `appendVal`; the emitter's
-- `mdk_string_append`/`mdk_list_append`), and core.mdk's own builtin impls are
-- written in terms of the operator —
--     impl Semigroup (List a) where append xs ys = xs ++ ys
--     impl Semigroup String   where append s1 s2 = s1 ++ s2
-- — so routing a List/String `++` to `append` would make those bodies call
-- themselves unboundedly.  Every OTHER head still routes, which is precisely what
-- makes a user `impl Semigroup MyRope` reachable from `a ++ b`.
binopBuiltinHead : String -> String -> Bool
binopBuiltinHead "append" tag = binopPrimitiveHead tag || tag == "List"
binopBuiltinHead _ tag = binopPrimitiveHead tag

-- SHARED-FLOAT-RESIDUAL §3(C): after the module is inferred, zonk each recorded
-- arithmetic operand mono; when it grounds to concrete Float, stamp RScalar
-- "Float" on the node's route so lowering carries it into CBinPrim and the native
-- emitter picks the Float primitive (bypassing the type-lost structural
-- staticIsFloat).  Grounded-only, exactly like resolveBinopSite: a still-
-- polymorphic operand (headTyconMono None) is left untouched (RNone → dict path),
-- so polymorphic-Num arithmetic keeps routing through the runtime Num dict.  Only
-- Float is stamped (Int is the primitive default already; leaving Int operands
-- RNone avoids perturbing every integer binop's emitted IR).  Never overwrites a
-- route another pass already set (a comparison op has a different node/ref; an
-- arithmetic route starts RNone) — the guard is: stamp only if the site is still
-- RNone AND grounds to Float.
resolveArithSites : List (Ref Route, Mono) -> Unit
resolveArithSites [] = ()
resolveArithSites ((dref, m)::rest) =
  let _ = resolveArithSite dref m
  resolveArithSites rest

resolveArithSite : Ref Route -> Mono -> Unit
resolveArithSite dref m = match dref.value
  RNone => match headTyconMono m
    Some "Float" => setRef dref (RScalar "Float")
    _ => ()
  _ => ()

-- EBinOp and EUnOp share ONE dict-route resolution family
-- (resolveOpSites/resolveOpSite/stampOpRoute/opDictVarOf), selected by an `isBinop`
-- flag (Roadmap #18c collapsed the binop/unop mirror pair — unopMethodApp already
-- reused binopRouteSplit, proving the shapes unify).  The two paths differ in exactly
-- two flag-keyed places: the dict-var-of policy (opDictVarOf) and the RKey stamp
-- (stampOpRoute — its builtin-head guard and Ord-style innerDefaultMethod reduction).
resolveOpSites : Bool -> ImplBuckets -> KeyBuckets -> List (String, Ref Route, Mono, Bool, String) -> Unit
resolveOpSites _ _ _ [] = ()
resolveOpSites isBinop implTable keyTable ((method, tagRef, operandMono, inImpl, encl)::rest) =
  let _ = resolveOpSite isBinop implTable keyTable method tagRef operandMono inImpl encl
  resolveOpSites isBinop implTable keyTable rest

-- G4: an `==`/`<`/… INSIDE an impl body ([inImpl]) whose operand is the enclosing
-- impl's abstract `requires`-constrained tyvar routes RDict that impl's element dict
-- (`activeDictVarOf` maps the operand's surviving tyvar id → `$dict_<method>_<slot>`,
-- registered by registerImplRequires after body inference; this deferred batch sees
-- the populated table).  binopMethodApp then rewrites it to a dict-dispatched
-- `eq x y` and `usesImplDict` prepends the matching param.  Without this the abstract
-- operand never grounds to a head tycon → the route stayed RNone → the SHALLOW
-- structural builtin (`mdk_value_eq` / pointer-eq), silently mis-comparing any non-Int
-- element (List → False, nested Box → False) and crashing once the dicts were threaded.
-- The [inImpl] gate is REQUIRED for the GLOBAL activeDictVars route: activeDictVars
-- is global + uncleared, so a TOP-LEVEL comparison's operand tyvar id can collide
-- with a stale impl element-var entry → a spurious RDict (this flipped the repl's
-- String-keyed `:browse` sort).  But a legitimately-constrained TOP-LEVEL operator
-- (`f x y = x == y` under `Eq a =>`) must STILL forward the enclosing fn's own class
-- dict, exactly as the direct `eq x y` arg-stamp path does.  enclDictVarOf draws that
-- line PRECISELY: it consults `funConstraintsRef[encl]` (the enclosing fn's OWN
-- declared constraint slots, keyed by fn name) — NOT the global activeDictVars — so
-- it fires ONLY when the operand var is genuinely one of encl's constraint vars, and
-- can never pick up a stale cross-impl element-var id.  A concrete operand (no active
-- dict var / not a constraint var, grounds to Some tag) keeps the existing RKey path.
--
-- Roadmap #18a RESIDUAL — `++`/`append` does NOT take the IN-IMPL element-dict route.
-- `binopDictVarOf` sends `append` to `enclDictVarOf` even when inImpl, so an operand
-- that is an impl's abstract `requires` tyvar stays RNone (the structural builtin)
-- instead of routing the impl's threaded element dict.
--
-- WHY (measured, not assumed).  Taking that route for `append` regresses
-- `test/eval_typed_modules_fixtures/impl_requires_nonfunctor_sibling`:
--     impl Applicative (VT e) requires Semigroup e where
--       pure a = VS a
--       ap (VF e1) (VF e2) = VF (e1 ++ e2)
-- Routing `e1 ++ e2` to `$dict_ap_0` makes `usesImplDict "ap"` true for the FIRST
-- time, so `implDictPassMethods` PREPENDS an impl-`requires` dict param to `ap` —
-- which shifts `ap`'s arg-position dispatch index by one.  The VTypedImpl's recorded
-- discriminating indices are NOT re-offset to match, so the impl then tag-checks its
-- leading DICT argument instead of its receiver, rejects it, and every candidate
-- falls through → `no matching impl for dispatch`.  (Before #18a that
-- `requires Semigroup e` was effectively DEAD — nothing in the body consumed it —
-- which is why the latent hole never fired.)  Fixing it properly means re-offsetting
-- arg-dispatch indices when impl-dict params are prepended: Phase 83/84 territory,
-- across ast/typecheck/dict_pass/eval, and deliberately NOT attempted here.
--
-- What still works (all gated): a GROUND non-builtin operand (`Rope "a" ++ Rope "b"`)
-- routes RKey to the user impl — the whole point of #18a, and the fix for the `build`
-- SIGSEGV; a TOP-LEVEL declared `Semigroup a => a -> a` routes RDict through
-- `enclDictVarOf` (the enclosing fn's OWN declared constraint slot, a different and
-- already-sound dict source); and String/List stay on the structural builtin.
-- What does NOT: `++` on an impl's abstract `requires`-bound tyvar — it keeps the
-- pre-#18a builtin behaviour exactly (correct for List/String, which is every such
-- site in the tree today), so this is a residual, not a regression.
-- BINOP path (`isBinop`): `append` → enclDictVarOf even when inImpl (Roadmap #18a
-- residual, above); any other method → activeDictVarOf when inImpl, else enclDictVarOf.
-- UNOP path (not `isBinop`): ALWAYS enclDictVarOf.  Roadmap #18a/#45 landmine (same
-- shape as the `append` residual): routing `-x` through activeDictVarOf can make
-- usesImplDict true for a method for the FIRST time, prepending a dict param that
-- shifts the impl's arg-dispatch index without re-offsetting the VTypedImpl's
-- discriminating indices — dispatch then tag-checks the dict instead of the receiver.
-- So `-x` on an impl's own abstract `requires`-bound tyvar stays on the structural
-- builtin (RNone) via a top-level fn's own declared constraint slot, never
-- activeDictVarOf — a residual, not a regression (mirrors the `++` residual exactly).
opDictVarOf : Bool -> String -> Mono -> Bool -> String -> Option String
opDictVarOf True "append" m _ encl = enclDictVarOf m encl
opDictVarOf True _ m inImpl encl
  | inImpl = activeDictVarOf m
  | otherwise = enclDictVarOf m encl
opDictVarOf False _ m _ encl = enclDictVarOf m encl

resolveOpSite : Bool -> ImplBuckets -> KeyBuckets -> String -> Ref Route -> Mono -> Bool -> String -> Unit
resolveOpSite isBinop implTable keyTable method tagRef operandMono inImpl encl = match opDictVarOf isBinop method operandMono inImpl encl
  Some dname => setRef tagRef (RDict dname)
  None => match headTyconMono operandMono
    Some tag =>
      stampOpRoute isBinop implTable keyTable method tagRef operandMono tag
    None => ()

-- Native Gap C: a tuple (or other parametric-with-requires) Eq/Ord impl carries
-- element `requires` dicts (Eq a, Eq b) that the rewritten `eq`/`compare` method body
-- reads.  Stamp them into the RKey route's reqs so binopMethodApp can forward them
-- as the EMethodAt impl-dict routes — exactly as resolveArgStamp does for a direct
-- `eq`/`compare` call.  A concrete non-parametric impl (user `Eq MyType`) has no
-- requires → empty reqs → the plain direct call, behaviour unchanged.
--
-- PARAMETRIC DEFAULT CASE (now routed RKey, gap closed 2026-06-12): a comparison
-- OPERATOR (`<`/`>`/`<=`/`>=` → `lt`/`gt`/`lte`/`gte`) whose method is NOT itself
-- impl'd at this head (an Ord interface DEFAULT reducing to inner `compare`) AND the
-- head's Ord impl HAS `requires` (parametric, e.g. tuple / `List a` / `Box a`).  This
-- stamps the RKey route with the SAME element-dict reqs as the `==`/`eq` path, but
-- keyed on the INNER same-interface `compare` (the relational method has no own impl
-- at this head, so `argImplDictRoutesFor` keyed on it would find nothing).
-- binopMethodApp forwards them as the EMethodAt impl-dicts; emitDefaultRKey passes
-- them as leading words to `@mdk_default_<op>_<tag>`, whose emitDefaultDefine
-- eta-PREPENDS the matching dict params and threads them into the inner
-- `@mdk_impl_<tag>_compare(dict.., a, b)` call.  Previously this case BACKED OFF to
-- RNone, which the backend lowered as a raw pointer `icmp` (silently WRONG result) /
-- SIGSEGV on the by-name `lt` path.  Concrete Ord (no requires) keeps empty reqs →
-- the plain `@mdk_default_<op>_<tag>(a, b)` direct call, unchanged.
-- Flag-keyed differences between the two paths:
--   * builtin-head guard — BINOP: `binopBuiltinHead method tag` (append also treats
--     List as builtin); UNOP: `binopPrimitiveHead tag` (a ground Int/Float stays on
--     evalUnop's VInt/VFloat fast path, the unop analogue of the comparison guard).
--   * dictMethod — BINOP reduces an Ord-style interface DEFAULT to its inner
--     same-interface `compare` (innerDefaultMethod) when the head does not impl the
--     method directly; UNOP has no interface-level default to reduce through (every
--     `impl Num`, including Int/Float's own `negate a = 0 - a`, defines `negate`
--     directly), so dictMethod is just `method`.
stampOpRoute : Bool -> ImplBuckets -> KeyBuckets -> String -> Ref Route -> Mono -> String -> Unit
stampOpRoute isBinop implTable keyTable method tagRef operandMono tag =
  let isBuiltin = if isBinop then
    binopBuiltinHead method tag
  else
    binopPrimitiveHead tag
  if isBuiltin then ()
  else
    let key = fromOption tag (keyForSite keyTable method operandMono)
    let dictMethod = if isBinop then
      if implDefinesMethodAt implTable method tag then method else innerDefaultMethod method
    else
      method
    let reqs = argImplDictRoutesFor implTable dictMethod tag operandMono
    setRef tagRef (RKey key reqs)
-- Gap #21 (CLOSED): element reqs are now forwarded unconditionally on both eval and
-- emit paths.  The impl method `eq`/`compare` carries leading `$dict_*` params
-- (resolveArgStamps runs on both paths); emitter applies them; eval's methodAtNarrow
-- forwards dict reqs (like RDictFwd) truncated to the matched impl's reqCount.

-- The inner same-interface method an interface DEFAULT reduces to, supplying the
-- element `requires` dicts.  Ord's `lt`/`gt`/`lte`/`gte`/`min`/`max` defaults all
-- reduce to `compare`; any other relational/equality method has its own impl so the
-- `implDefinesMethodAt` guard keeps it on `method`, never reaching here.
innerDefaultMethod : String -> String
innerDefaultMethod m =
  if contains m ["lt", "gt", "lte", "gte", "min", "max"] then
    "compare"
  else
    m

implDefinesMethodAt : ImplBuckets -> String -> String -> Bool
implDefinesMethodAt buckets method tag =
  implDefinesMethodAtGo (bucketOf tag buckets) method tag

implDefinesMethodAtGo : List ImplEntry -> String -> String -> Bool
implDefinesMethodAtGo [] _ _ = False
implDefinesMethodAtGo ((ImplEntry tag2 methodNames _ _ _ _)::rest) method tag
  | tag2 == tag && contains method methodNames = True
  | otherwise = implDefinesMethodAtGo rest method tag

-- ── coherence check (TYPECHECK-AUDIT S3) ───────────────────────────────────
-- Mirror lib/typecheck.ml's check_coherence (Phase 68): reject incoherent USER
-- impl sets at declaration time.  Two impls of the SAME interface whose head
-- types can match the same concrete type (impls_overlap) are unresolvable unless
-- one strictly specializes the other (most-specific-wins).  Genuinely incoherent:
--   • two overlapping impls that are NOT a strict specialization → OverlappingImpls.
-- (Named impls + `@Name` selection + `default impl` were removed 2026-07-11; the
-- newtype-wrapper approach is the answer for a second instance.)
-- Prelude/seeded impls are excluded entirely (the driver passes USER decls only):
-- user impls are meant to override prelude impls (e.g. single-file `impl Ord Int`),
-- so they must not pair with a prelude `impl Ord Int`.  At most ONE error is
-- emitted (mirrors the oracle raising Type_error on the first conflict).

-- a user impl, reduced to what coherence needs: iface + head-arg monos (fresh
-- vars).
-- CohImpl iface head-tys ownerModuleId.  The 3rd field is the id of the module
-- that PHYSICALLY declares this impl ("" for the single-file / entry path, so its
-- goldens stay byte-identical — only the global cross-module check threads a real
-- module id and uses it to name BOTH modules in a conflict).
public export data CohImpl = CohImpl String (List Mono) String

cohImplsOf : Decl -> List CohImpl
cohImplsOf d = cohImplsOfMid "" d

-- module-tagged variant: stamp every harvested CohImpl with [mid].
cohImplsOfMid : String -> Decl -> List CohImpl
cohImplsOfMid mid (DAttrib _ d) = cohImplsOfMid mid d
cohImplsOfMid mid (DImpl { iface, tys, ... }) =
  [CohImpl iface (cohFreshTys tys) mid]
cohImplsOfMid _ _ = []

-- the impl's head args → monos under ONE shared fresh-var map (so a var reused
-- across args, e.g. `Conv a a`, is the SAME fresh tyvar — the oracle shares one
-- tbl across the whole impl head; distinct impls get distinct ids).
cohFreshTys : List Ty -> List Mono
cohFreshTys tys =
  let names = dedup (flatMap tyVarNames tys)
  let tvs = freshTvMap names
  map (fromAstType tvs) tys

-- impls_overlap: do two impl head-arg lists share a common instance?  Every
-- TVar (fresh per impl, so distinct ids) is a unification wildcard with a shared
-- subst — `(List Int)` vs `(List a)` overlap via a:=Int; `a a` vs `Int Bool`
-- does NOT (resolve binds a:=Int, then Int vs Bool fails), mirroring the oracle.
cohOverlap : List Mono -> List Mono -> Bool
cohOverlap xs ys
  | listLen xs == listLen ys = cohOverlapGo (Ref []) (zipL xs ys)
  | otherwise = False

cohOverlapGo : Ref (List (Int, Mono)) -> List (Mono, Mono) -> Bool
cohOverlapGo _ [] = True
cohOverlapGo subst ((a, b)::rest)
  | cohGo subst a b = cohOverlapGo subst rest
  | otherwise = False

-- resolve a mono through the wildcard subst (chasing bound vars)
cohResolve : Ref (List (Int, Mono)) -> Mono -> Mono
cohResolve subst m = match normalize m
  TVar cell => match lookupAssocI (tyvarId cell) subst.value
    Some m2 => cohResolve subst m2
    None => TVar cell
  other => other

cohGo : Ref (List (Int, Mono)) -> Mono -> Mono -> Bool
cohGo subst t1 t2 = cohGoR subst (cohResolve subst t1) (cohResolve subst t2)

cohGoR : Ref (List (Int, Mono)) -> Mono -> Mono -> Bool
cohGoR subst (TVar c1) (TVar c2)
  | tyvarId c1 == tyvarId c2 = True
  | otherwise = cohBind subst (tyvarId c1) (TVar c2)
cohGoR subst (TVar c1) t = cohBind subst (tyvarId c1) t
cohGoR subst t (TVar c2) = cohBind subst (tyvarId c2) t
cohGoR _ (TCon a) (TCon b) = a == b
cohGoR subst (TApp f1 a1) (TApp f2 a2) = cohGo subst f1 f2 && cohGo subst a1 a2
cohGoR subst (TFun a1 _ b1) (TFun a2 _ b2) = cohGo subst a1 a2
  && cohGo subst b1 b2
cohGoR _ (TEff _) (TEff _) = True
cohGoR _ _ _ = False

-- bind id := m in the wildcard subst and return True
cohBind : Ref (List (Int, Mono)) -> Int -> Mono -> Bool
cohBind subst id m =
  let _ = setRef subst ((id, m)::subst.value)
  True

-- subsumes ~general ~specific: is [specific] an instance of [general]?  Only the
-- general side's vars bind (consistently: a var bound twice must see structurally
-- equal types); the specific side's vars are rigid (match only the same id).
cohSubsumes : List Mono -> List Mono -> Bool
cohSubsumes general specific
  | listLen general == listLen specific =
    cohSubGo (Ref []) (zipL general specific)
  | otherwise = False

cohSubGo : Ref (List (Int, Mono)) -> List (Mono, Mono) -> Bool
cohSubGo _ [] = True
cohSubGo subst ((g, s)::rest)
  | cohSub subst g s = cohSubGo subst rest
  | otherwise = False

cohSub : Ref (List (Int, Mono)) -> Mono -> Mono -> Bool
cohSub subst g s = cohSubR subst (normalize g) (normalize s)

cohSubR : Ref (List (Int, Mono)) -> Mono -> Mono -> Bool
cohSubR subst (TVar c) s = match lookupAssocI (tyvarId c) subst.value
  Some prev => cohEqMono prev s
  None => cohBind subst (tyvarId c) s
cohSubR _ (TCon a) (TCon b) = a == b
cohSubR subst (TApp f1 a1) (TApp f2 a2) = cohSub subst f1 f2
  && cohSub subst a1 a2
cohSubR subst (TFun a1 _ b1) (TFun a2 _ b2) = cohSub subst a1 a2
  && cohSub subst b1 b2
cohSubR _ (TEff _) (TEff _) = True
cohSubR _ _ _ = False

-- rigid structural equality (the specific side's vars match only the same id)
cohEqMono : Mono -> Mono -> Bool
cohEqMono a b = cohEqR (normalize a) (normalize b)

cohEqR : Mono -> Mono -> Bool
cohEqR (TVar c1) (TVar c2) = tyvarId c1 == tyvarId c2
cohEqR (TCon a) (TCon b) = a == b
cohEqR (TApp f1 a1) (TApp f2 a2) = cohEqMono f1 f2 && cohEqMono a1 a2
cohEqR (TFun a1 _ b1) (TFun a2 _ b2) = cohEqMono a1 a2 && cohEqMono b1 b2
cohEqR (TEff _) (TEff _) = True
cohEqR _ _ = False

-- [a] strictly more specific than [b]: b subsumes a but not a subsumes b
cohStrictlyMoreSpecific : List Mono -> List Mono -> Bool
cohStrictlyMoreSpecific a b = cohSubsumes b a && not (cohSubsumes a b)

-- render two impl head-arg lists against ONE shared naming ctx (so a var shared
-- across both prints identically and distinct vars never collide) — mirrors the
-- oracle's pp_monos_pair.
cohPpPair : List Mono -> List Mono -> (String, String)
cohPpPair xs ys =
  let ctx = Ref []
  let cnt = Ref 0
  let s1 = joinWith " " (cohPpEach ctx cnt xs)
  let s2 = joinWith " " (cohPpEach ctx cnt ys)
  (s1, s2)

cohPpEach : Ref (List (Int, String)) -> Ref Int -> List Mono -> List String
cohPpEach _ _ [] = []
cohPpEach ctx cnt (m::ms) = ppGo ctx cnt 0 m :: cohPpEach ctx cnt ms

-- the coherence error string for one conflicting pair (OverlappingImpls).
cohOverlapMsg : String -> List Mono -> List Mono -> String
cohOverlapMsg iface xs ys = match cohPpPair xs ys
  (s1, s2) => "Overlapping impls of \{iface}: \{s1} and \{s2} can match the same type. Make them disjoint, or wrap one type in a newtype"

-- scan all ordered pairs; return the FIRST conflict message (mirrors the oracle
-- raising on the first incoherent pair).  None ⇒ coherent.
cohFirstConflict : List CohImpl -> Option String
cohFirstConflict [] = None
cohFirstConflict (e::rest) = match cohConflictWith e rest
  Some msg => Some msg
  None => cohFirstConflict rest

cohConflictWith : CohImpl -> List CohImpl -> Option String
cohConflictWith _ [] = None
cohConflictWith (e1@(CohImpl if1 xs mid1)) ((CohImpl if2 ys mid2)::rest)
  | if1 == if2 && cohOverlap xs ys = cohAnonConflict e1 xs ys mid1 mid2 rest
  | otherwise = cohConflictWith e1 rest

-- two overlapping impls: a strict specialization (most-specific-wins) is coherent
-- — it falls through to the rest of the scan.  Otherwise it is an unresolvable
-- overlap (mirrors the oracle's OverlappingImpls).  When the two impls come from
-- DIFFERENT modules (mid1 /= mid2, both non-empty), the message names BOTH owning
-- modules (the cross-module global-coherence case).
cohAnonConflict : CohImpl -> List Mono -> List Mono -> String -> String -> List CohImpl -> Option String
cohAnonConflict e1 xs ys mid1 mid2 rest
  | cohStrictlyMoreSpecific xs ys = cohConflictWith e1 rest
  | cohStrictlyMoreSpecific ys xs = cohConflictWith e1 rest
  | mid1 != "" && mid2 != "" && mid1 != mid2 =
    Some (cohCrossModuleMsg (cohImplIface e1) mid1 mid2)
  | otherwise = Some (cohOverlapMsg (cohImplIface e1) xs ys)

-- cross-module conflict wording: names the interface and BOTH owning modules.
cohCrossModuleMsg : String -> String -> String -> String
cohCrossModuleMsg iface mid1 mid2 =
  "Conflicting `impl \{iface}`. Defined in \{mid2} and \{mid1}"

cohImplIface : CohImpl -> String
cohImplIface (CohImpl i _ _) = i

-- run coherence over USER decls; push the first conflict (if any) into typeErrors.
-- The impls are scanned in REVERSE declaration order to mirror the oracle, whose
-- env.impls is built by prepending each entry (`entry :: !(env.impls)`) — so the
-- conflict message names the later-declared impl as the first head, byte-identical.
checkCoherence : List Decl -> Unit
checkCoherence userDecls = match cohFirstConflict (reverseL (cohCollectImpls userDecls))
  Some msg => pushTypeError "T-CONFLICTING-IMPL" msg
  None => ()

-- ── D1 WS-1a: superinterface-existence gate ────────────────────────────────
-- Mirror of lib/typecheck.ml's `check_superinterface_obligations`.  An
-- `impl C T` whose interface declares `interface C a requires D a` is unsound
-- unless a matching `impl D T` also exists.  This post-pass iterates the USER
-- impls (so a user impl that overrides a prelude impl isn't double-flagged) and,
-- for each, looks up its interface's supers in the FULL decl universe
-- ([allDecls], prelude included — the SUPER impl it needs may be a prelude impl).
-- It fires ONLY when the impl head's type args are all CONCRETE/ground (mirrors
-- the oracle's `is_concrete` gate); a parametric head like `impl Monoid (Bag a)`
-- (free tyvar) is deferred exactly as the oracle defers it.  Error wording is
-- byte-identical to the oracle's MissingSuperImpl message.
-- [userDecls] = the impls to check; [allDecls] = prelude + user, for both the
-- interface-supers lookup AND super-impl existence.
checkSuperImpls : List Decl -> List Decl -> Unit
checkSuperImpls userDecls allDecls =
  foreachUnit
    (pushTypeError "T-MISSING-SUPER-IMPL")
    (flatMap (superImplMsgsOf allDecls) userDecls)

foreachUnit : (a -> Unit) -> List a -> Unit
foreachUnit _ [] = ()
foreachUnit f (x::xs) =
  let _ = f x
  foreachUnit f xs

-- ── P0-17: impl-completeness check ─────────────────────────────────────────
-- Beta finding P0-17 (qa-beta-2026-07-07): an `impl Iface Ty…` that defines only
-- SOME of the interface's methods used to `check` clean, then PANIC at runtime
-- (`E-PANIC: unbound identifier: <method>`) when a missing method is dispatched —
-- a run≠check hole.  For each impl, verify every REQUIRED interface method (one
-- declared WITHOUT a default body) is defined by the impl body; each missing one
-- is a located `T-INCOMPLETE-IMPL` error, so check/run/build all reject instead of
-- deferring to a runtime panic.
--
-- Runs POST-desugar (from the typecheck cores), which is the ONLY stage where both
-- sets are cleanly visible with defaults distinguishable:
--   • desugar's mergeIfaceDefaults has coalesced each interface method's split
--     signature-entry (`lt : …`, default None) and body-entry (`lt x y = …`,
--     default Some) into ONE `IfaceMethod` carrying the merged Option MethodDefault.
--     PRE-merge the sig-only `None` entry would make every defaulted method (Ord's
--     lt/gt/…) look REQUIRED → hundreds of false positives across core/stdlib.
--   • desugar's fillImplDefaults has synthesized same-module default clauses INTO
--     the impl — which only ADDS to the defined set, never removes a required one,
--     so it cannot mask a genuinely-missing required method.
-- [lookupDecls] (prelude + accumulated modules + this module) resolves the
-- interface decl even when it is imported; [iterDecls] (this module's own decls)
-- are the impls to check.  Unknown interface (not in scope) → skip (a distinct
-- error is reported elsewhere), mirroring superImplMsgsOf.
checkImplCompleteness : List Decl -> List Decl -> Unit
checkImplCompleteness lookupDecls iterDecls =
  foreachUnit
    pushIncompleteImpl
    (flatMap (implCompletenessMsgsOf lookupDecls) iterDecls)

pushIncompleteImpl : (Option Loc, String) -> Unit
pushIncompleteImpl (loc, msg) = pushTypeErrorOnceAt "T-INCOMPLETE-IMPL" loc msg

-- the missing-required-method errors for one decl (a DImpl, possibly DAttrib-
-- wrapped); [] for a non-impl decl, an unknown interface, or a complete impl.
implCompletenessMsgsOf : List Decl -> Decl -> List (Option Loc, String)
implCompletenessMsgsOf lookupDecls (DAttrib _ d) =
  implCompletenessMsgsOf lookupDecls d
implCompletenessMsgsOf lookupDecls DImpl { iface, tys, methods, ... } =
  match ifaceRequiredMethods lookupDecls iface
    None => []   -- unknown interface (reported elsewhere) → skip
    Some required =>
      let defined = map implMethodName methods
      let loc = firstImplMethodLoc methods
      map
        (m => (loc, missingImplMethodMsg iface tys m))
        (filter (m => not (contains m defined)) required)
implCompletenessMsgsOf _ _ = []

implMethodName : ImplMethod -> String
implMethodName (ImplMethod n _ _) = n

-- a loc to attribute the error to: the first present impl-method body's span (the
-- impl head carries no Loc of its own).  None for a wholly-empty impl body.
firstImplMethodLoc : List ImplMethod -> Option Loc
firstImplMethodLoc [] = None
firstImplMethodLoc ((ImplMethod _ _ body)::_) = exprLoc body

-- the names of interface [target]'s REQUIRED methods (those whose merged
-- IfaceMethod carries NO default body); None if no such interface is in scope.
ifaceRequiredMethods : List Decl -> String -> Option (List String)
ifaceRequiredMethods [] _ = None
ifaceRequiredMethods ((DAttrib _ d)::rest) target = match ifaceRequiredMethods [d] target
  Some r => Some r
  None => ifaceRequiredMethods rest target
ifaceRequiredMethods ((DInterface { name, methods, ... })::rest) target
  | name == target = Some (requiredMethodNames methods)
  | otherwise = ifaceRequiredMethods rest target
ifaceRequiredMethods (_::rest) target = ifaceRequiredMethods rest target

requiredMethodNames : List IfaceMethod -> List String
requiredMethodNames [] = []
requiredMethodNames ((IfaceMethod n _ None)::rest) =
  n :: requiredMethodNames rest
requiredMethodNames ((IfaceMethod _ _ (Some _))::rest) =
  requiredMethodNames rest

missingImplMethodMsg : String -> List Ty -> String -> String
missingImplMethodMsg iface tys method = "'impl \{iface} \{joinWith " " (map ppTyAtom tys)}' is missing method '\{method}'. Every interface method without a default body must be implemented — define '\{method}' in the impl (or check for a typo in a method name)"

-- ── WS-5: phantom interface method detection ──────────────────────────────
-- A method whose declared type mentions NONE of the interface's type parameters
-- (neither in argument position nor in the result) cannot be dispatched: there
-- is no argument or return type to select an impl from.  Reject at check time
-- so the silent mis-dispatch at runtime is caught early.
--
-- Examples:
--   interface Phantom a where
--     name : String          -- PHANTOM: `a` appears nowhere in the type
--   interface Show a where
--     show : a -> String     -- OK: `a` appears in argument position
--   interface Pure f where
--     pure : a -> f a        -- OK: `f` appears in result position
--
-- The check uses the full method type (args AND result via tyVarNames), so
-- return-position methods like `pure : a -> f a` or `minBound : a` are NOT
-- flagged.  Multi-param interfaces: phantom iff ALL params absent.

checkPhantomMethods : List Decl -> Unit
checkPhantomMethods decls =
  foreachUnit
    (pushTypeError "T-PHANTOM-METHOD")
    (flatMap phantomMethodMsgs decls)

phantomMethodMsgs : Decl -> List String
phantomMethodMsgs (DAttrib _ d) = phantomMethodMsgs d
phantomMethodMsgs (DInterface { name, typarams, methods, ... }) =
  flatMap (phantomMethodMsg name typarams) methods
phantomMethodMsgs _ = []

phantomMethodMsg : String -> List String -> IfaceMethod -> List String
phantomMethodMsg ifaceName typarams (IfaceMethod mname mty _) =
  if isEmptyL typarams then
    []
  else if anyMember (tyVarNames mty) typarams then
    []
  else
    [
      "Method '\{mname}' in interface '\{ifaceName}' does not mention interface parameter(s) \{intercalateComma typarams}; cannot dispatch"
    ]

intercalateComma : List String -> String
intercalateComma [] = ""
intercalateComma [x] = "'" ++ x ++ "'"
intercalateComma (x::rest) = "'\{x}', \{intercalateComma rest}"

-- ── WS-4a: cyclic superinterface detection ────────────────────────────────
-- A cyclic `interface A requires B; interface B requires A` is ill-formed: no
-- impl can ever be constructed (each demands the other) and the transitive
-- evidence resolver would diverge.  DFS over the `requires` graph; if any node
-- is re-encountered on the current DFS stack, report the cycle.
-- Runs over ALL interfaces in scope (prelude + user) — a prelude cycle would
-- be equally ill-formed.  The `done` ref tracks fully-explored nodes to avoid
-- redundant traversal and re-reporting multi-root cycles.
checkInterfaceCycles : List Decl -> Unit
checkInterfaceCycles allDecls =
  let ifaceNames = collectIfaceNames allDecls
  let done = Ref []
  foreachUnit (checkOneIfaceCycle allDecls done) ifaceNames

checkOneIfaceCycle : List Decl -> Ref (List String) -> String -> Unit
checkOneIfaceCycle allDecls done ifaceName =
  if not (contains ifaceName done.value) then
    foreachUnit (pushTypeError "T-CYCLIC-SUPERINTERFACE") (ifaceDfsCycle allDecls done [ifaceName] ifaceName)
  else
    ()

collectIfaceNames : List Decl -> List String
collectIfaceNames [] = []
collectIfaceNames ((DInterface { name, ... })::rest) =
  name :: collectIfaceNames rest
collectIfaceNames ((DAttrib _ d)::rest) = collectIfaceNames (d::rest)
collectIfaceNames (_::rest) = collectIfaceNames rest

-- DFS from [current]; [path] is the stack of names visited so far (including
-- [current] as its last element, used to reconstruct the cycle message).
-- Marks [current] as done after all its supers are explored.
ifaceDfsCycle : List Decl -> Ref (List String) -> List String -> String -> List String
ifaceDfsCycle allDecls done path current = match ifaceSupersOf allDecls current
  None =>
    let _ = setRef done (current::done.value)
    []
  Some (_, supers) =>
    let msgs = ifaceDfsCycleSupers allDecls done path supers
    let _ = setRef done (current::done.value)
    msgs

ifaceDfsCycleSupers : List Decl -> Ref (List String) -> List String -> List Super -> List String
ifaceDfsCycleSupers _ _ _ [] = []
ifaceDfsCycleSupers allDecls done path ((Super superName _)::rest) =
  let msgs1 = ifaceDfsCycleOneSuper allDecls done path superName
  msgs1 ++ ifaceDfsCycleSupers allDecls done path rest

-- check one super edge: cycle if superName is on the DFS path; skip if done; else recurse.
ifaceDfsCycleOneSuper : List Decl -> Ref (List String) -> List String -> String -> List String
ifaceDfsCycleOneSuper allDecls done path superName =
  if contains superName path then
    [cyclicSuperIfaceMsg (path ++ [superName])]
  else if contains superName done.value then
    []
  else
    ifaceDfsCycle allDecls done (path ++ [superName]) superName

-- e.g. ["A", "B", "A"] → "cyclic superinterface: A requires B requires A"
cyclicSuperIfaceMsg : List String -> String
cyclicSuperIfaceMsg path = "Cyclic superinterface: "
  ++ joinWith " requires " path

-- the missing-superinterface error messages for one user decl (a DImpl, possibly
-- wrapped in DAttrib); [] for any non-impl decl or when every super impl exists.
superImplMsgsOf : List Decl -> Decl -> List String
superImplMsgsOf allDecls (DAttrib _ d) = superImplMsgsOf allDecls d
superImplMsgsOf allDecls DImpl { iface, tys, ... } =
  match ifaceSupersOf allDecls iface
    None => []   -- unknown interface (already reported elsewhere) → skip
    Some (typarams, supers) =>
      if listLen typarams == listLen tys && allList tyIsConcrete tys then
        flatMap (superMsgFor allDecls iface tys (zipL typarams tys)) supers
      else
        []   -- arity mismatch, or a non-concrete head (deferred, like the oracle)
superImplMsgsOf _ _ = []

-- check one `Super superName params` against the substitution: map each super
-- param name through [subst] to its concrete Ty; if every param mapped, all are
-- concrete, AND no matching `impl superName <concrete>` exists, emit the error.
superMsgFor : List Decl -> String -> List Ty -> List (String, Ty) -> Super -> List String
superMsgFor allDecls iface implTys subst (Super superName params) =
  let concrete = substParams params subst
  if listLen concrete == listLen params && allList tyIsConcrete concrete && not (superImplExists allDecls superName concrete) then
    [missingSuperImplMsg iface implTys superName concrete]
  else
    []

-- map each super-param NAME through [subst] to its Ty, dropping any unmapped (so a
-- short result vs [params] signals an incomplete substitution → caller skips).
substParams : List String -> List (String, Ty) -> List Ty
substParams [] _ = []
substParams (p::rest) subst = match lookupAssoc p subst
  Some t => t :: substParams rest subst
  None => substParams rest subst

-- byte-identical to lib/typecheck.ml's MissingSuperImpl rendering: both the impl
-- head and the super are printed with the same space-joined atom-position args.
missingSuperImplMsg : String -> List Ty -> String -> List Ty -> String
missingSuperImplMsg iface implTys superName superTys = "'impl \{iface} \{joinWith " " (map ppTyAtom implTys)}' requires a superinterface 'impl \{superName} \{joinWith " " (map ppTyAtom superTys)}', which is missing"

-- the (typarams, supers) of interface [target], scanning DInterface decls; None if
-- no such interface is in scope.
ifaceSupersOf : List Decl -> String -> Option (List String, List Super)
ifaceSupersOf [] _ = None
ifaceSupersOf ((DAttrib _ d)::rest) target = match ifaceSupersOf [d] target
  Some r => Some r
  None => ifaceSupersOf rest target
ifaceSupersOf ((DInterface { pub, def, name, typarams, supers, methods })::rest) target
  | name == target = Some (typarams, supers)
  | otherwise = ifaceSupersOf rest target
ifaceSupersOf (_::rest) target = ifaceSupersOf rest target

-- does any `impl superName <head>` with a head matching [concrete] exist? (head
-- may be parametric — a free tyvar in the impl head matches any concrete arg,
-- mirroring the oracle's mono_matches: pattern=impl head, concrete=super args.)
superImplExists : List Decl -> String -> List Ty -> Bool
superImplExists allDecls superName concrete =
  anyList (implMatchesSuper superName concrete) allDecls

implMatchesSuper : String -> List Ty -> Decl -> Bool
implMatchesSuper superName concrete (DAttrib _ d) =
  implMatchesSuper superName concrete d
implMatchesSuper superName concrete (DImpl { iface, tys, ... }) = iface == superName
  && listLen tys == listLen concrete
  && allList (p => tyMatchesAst (fst p) (snd p)) (zipL tys concrete)
implMatchesSuper _ _ _ = False

-- a Ty is concrete iff it contains no TyVar (mirror of the oracle's is_concrete,
-- which treats effect rows as transparent — TyEffect ignores its row).
tyIsConcrete : Ty -> Bool
tyIsConcrete (TyVar _) = False
tyIsConcrete (TyCon _ _) = True
tyIsConcrete (TyApp a b) = tyIsConcrete a && tyIsConcrete b
tyIsConcrete (TyFun a b) = tyIsConcrete a && tyIsConcrete b
tyIsConcrete (TyTuple ts) = allList tyIsConcrete ts
tyIsConcrete (TyEffect _ _ t) = tyIsConcrete t
tyIsConcrete (TyConstrained _ t) = tyIsConcrete t

-- one-directional structural match (pattern may carry free TyVar wildcards;
-- concrete is fully ground).  Mirror of lib/typecheck.ml's mono_matches.
tyMatchesAst : Ty -> Ty -> Bool
tyMatchesAst (TyVar _) _ = True
tyMatchesAst (TyCon a _) (TyCon b _) = a == b
tyMatchesAst (TyApp f1 a1) (TyApp f2 a2) = tyMatchesAst f1 f2
  && tyMatchesAst a1 a2
tyMatchesAst (TyFun a1 b1) (TyFun a2 b2) = tyMatchesAst a1 a2
  && tyMatchesAst b1 b2
tyMatchesAst (TyTuple ts1) (TyTuple ts2) = listLen ts1 == listLen ts2
  && allList (p => tyMatchesAst (fst p) (snd p)) (zipL ts1 ts2)
tyMatchesAst (TyEffect _ _ t1) t2 = tyMatchesAst t1 t2
tyMatchesAst t1 (TyEffect _ _ t2) = tyMatchesAst t1 t2
tyMatchesAst (TyConstrained _ t1) t2 = tyMatchesAst t1 t2
tyMatchesAst t1 (TyConstrained _ t2) = tyMatchesAst t1 t2
tyMatchesAst _ _ = False

-- effectful concatMap of cohImplsOf (astTypeFresh allocates fresh tyvars → <Mut>)
cohCollectImpls : List Decl -> List CohImpl
cohCollectImpls [] = []
cohCollectImpls (d::rest) = cohImplsOf d ++ cohCollectImpls rest

-- ── D3 / WS-2 part-2: GLOBAL (cross-module) coherence ──────────────────────
-- Per-module coherence (checkCoherence prog) accepts two DIFFERENT modules that
-- each define `impl C T` for the SAME instance — each module is locally coherent,
-- but jointly they are incoherent (silent dispatch ambiguity).  This pass scans
-- the joint impl set over ALL USER modules (prelude EXCLUDED — a user `impl Eq Int`
-- legitimately overrides the prelude one, so prelude impls must NOT be in the set).
-- Each CohImpl carries the id of the module that PHYSICALLY declares it; imports do
-- NOT copy impl decls, so the joint set has exactly one entry per definition and a
-- structural (iface, head-tys) overlap already distinguishes distinct definitions —
-- no occurrence-dedup needed.  A conflict between two distinct modules is reported
-- naming BOTH (cohCrossModuleMsg via cohAnonConflict's mid1/=mid2 branch).
cohCollectModuleImpls : List (String, List Decl) -> List CohImpl
cohCollectModuleImpls [] = []
cohCollectModuleImpls ((mid, prog)::rest) = flatMap (cohImplsOfMid mid) prog
  ++ cohCollectModuleImpls rest

-- the first cross-module coherence conflict (if any) as a bare message — drivers
-- that thread errs as a VALUE (checkModulesEntryFullGo) prepend this themselves,
-- rather than relying on the typeErrors ref (cleared per-module by resetState).
globalCoherenceConflict : List (String, List Decl) -> Option String
globalCoherenceConflict modules =
  cohFirstConflict (reverseL (cohCollectModuleImpls modules))

-- the USER decls a driver wants coherence-checked.  Set by single-file drivers
-- (check.mdk / typecheck_main.mdk / check_batch.mdk) to the desugared USER program
-- (NO prelude), so a user impl that overrides a prelude impl is not flagged.  []
-- (the golden/profile drivers and the no-runtime path) ⇒ checkToLines uses its own
-- prelude-free arg; checkToLinesWithRuntime runs no coherence (byte-identical).
coherenceUserDecls : Ref (List Decl)
coherenceUserDecls = Ref []

-- exported so the single-file front-end drivers set the user boundary before check
export setCoherenceUserDecls : List Decl -> Unit
setCoherenceUserDecls ds = setRef coherenceUserDecls ds

-- ── instance-`requires` impl-dict routing (Phase 83/84 single-level) ────────
-- One parametric impl that carries a `requires`: its head tag (the tycon eval
-- narrows by), the methods it defines (to disambiguate which impl a method site
-- picked), the head type pattern (matched against the call's concrete result mono
-- to recover the element type), and its requires constraints.
-- Fields: head tycon tag, defined method names, head type pattern, requires,
-- full impl type-args, and the INTERFACE this impl is for.  The iface field
-- disambiguates same-head impls: one type can carry several `requires`-bearing
-- impls at the same head tycon for DIFFERENT interfaces whose requires differ in
-- shape (e.g. `Applicative (VT e) requires Semigroup e` alongside
-- `Debug (VT e a) requires Debug e, Debug a`).  RKey element-dict routing must
-- pick the entry for the interface being dispatched, not merely the first by tag.
public export data ImplEntry =
  | ImplEntry String (List String) Ty (List Require) (List Ty) String

-- #148: the impl/key tables are keyed by head tycon TAG into a bucket of entries
-- kept in FORWARD declaration order (append; never re-sorted).  Every per-site
-- lookup filters `tag2 == tag` first, so it scans ONE bucket instead of the whole
-- impl universe — turning findImplEntry's O(impls) scan into O(bucket).  The
-- forward intra-bucket order is load-bearing: findImplEntry / implDictRoutesIn /
-- argImplDictRoutesForGo are FIRST-MATCH, so the earlier-declared of two coherent
-- overlapping requires-bearing siblings at the same head must still win.  (This is
-- NOT the coherence structure — cohFirstConflict scans a separate reverseL-ed list;
-- these buckets keep forward order and coherence is not routed through them.)
export type ImplBuckets = OrdMap (List ImplEntry)
export type KeyBuckets = OrdMap (List KeyEntry)

-- the entries at head tycon [tag] (empty when no impl heads there), in declaration
-- order.  Shared by both bucket flavours (List ImplEntry / List KeyEntry).
bucketOf : String -> OrdMap (List a) -> List a
bucketOf tag buckets = fromOption [] (omLookup tag buckets)

-- build the table from the program's impls-with-requires (others need no dicts),
-- bucketed by head tycon tag with each bucket in forward declaration order.
buildImplTable : List Decl -> ImplBuckets
buildImplTable prog = bucketImplEntries (flatMap implEntryOf prog) omEmpty

-- fold the flat, forward-ordered entry list into tag buckets, APPENDING so each
-- bucket preserves declaration order (first-match semantics).
bucketImplEntries : List ImplEntry -> ImplBuckets -> ImplBuckets
bucketImplEntries [] acc = acc
bucketImplEntries ((ImplEntry tag ms hty reqs itys ifn)::rest) acc =
  let e = ImplEntry tag ms hty reqs itys ifn
  bucketImplEntries rest (omInsert tag (bucketOf tag acc ++ [e]) acc)

implEntryOf : Decl -> List ImplEntry
implEntryOf (DAttrib _ d) = implEntryOf d
implEntryOf (DImpl { iface, tys, reqs, methods, ... }) = match reqs
  [] => []
  _ => implEntryFromTys iface tys reqs methods
implEntryOf _ = []

implEntryFromTys : String -> List Ty -> List Require -> List ImplMethod -> List ImplEntry
implEntryFromTys _ [] _ _ = []
implEntryFromTys iface (headTy::rest) reqs methods = match headTyconTy headTy
  Some tag => [
    ImplEntry tag (map implMethodNameTc methods) headTy reqs (headTy::rest) iface
  ]
  None => []

implMethodNameTc : ImplMethod -> String
implMethodNameTc (ImplMethod n _ _) = n

-- ── TYPECHECK-AUDIT C7: canonical-impl-key registry ────────────────────────
-- One entry per USER impl (regardless of `requires`): the methods it defines (to
-- match a method site), its head tycon (to detect a head-tag collision), its
-- head-arg type pattern (matched against the site's concrete result mono), and its
-- canonical impl key.  Mirrors lib/typecheck.ml's `matching_impls` + `entry.impl_key`.
-- The route normally keeps the bare head tycon (the established head-tag dispatch
-- the native Core-IR/LLVM backend keys symbols by); it is UPGRADED to the full
-- canonical key ONLY when two impls share that head tycon for the method (the C7
-- case, e.g. Pair Int Bool vs Pair Bool Int).  This keeps every single-impl-per-head
-- site — i.e. all existing code and the native backend — byte-identical, while
-- letting eval's narrowMethod pick the right VTypedImpl by its key field when the
-- heads genuinely collide.
public export data KeyEntry = KeyEntry (List String) String Ty String

buildKeyTable : List Decl -> KeyBuckets
buildKeyTable prog = bucketKeyEntries (flatMap keyEntryOf prog) omEmpty

-- fold the flat, forward-ordered entry list into tag buckets (declaration order).
bucketKeyEntries : List KeyEntry -> KeyBuckets -> KeyBuckets
bucketKeyEntries [] acc = acc
bucketKeyEntries ((KeyEntry ms tag hty key)::rest) acc =
  let e = KeyEntry ms tag hty key
  bucketKeyEntries rest (omInsert tag (bucketOf tag acc ++ [e]) acc)

keyEntryOf : Decl -> List KeyEntry
keyEntryOf (DAttrib _ d) = keyEntryOf d
keyEntryOf (DImpl { iface, tys, methods, ... }) = match tys
  headTy::_ => match headTyconTy headTy
    Some tag => [KeyEntry (map implMethodNameTc methods) tag headTy (implKeyTc iface tys)]
    None => []
  [] => []
keyEntryOf _ = []

-- the canonical impl key, byte-identical to eval.mdk's implKeyOf: `iface ++ "|" ++
-- <prec-2 args> ++ "|"` (the trailing empty name-component is retained so keys stay
-- byte-identical to the pre-removal format).
implKeyTc : String -> List Ty -> String
implKeyTc iface tys = "\{iface}|\{joinWith " " (map ppTyAtom tys)}|"

-- the canonical key to stamp for the impl of [name] matching the ground result
-- mono — but ONLY when another impl of the same method shares its head tycon (so
-- bare-head routing is ambiguous).  No collision (the common case) or no match →
-- None → the caller keeps the head tag, behaviour unchanged.
keyForSite : KeyBuckets -> String -> Mono -> Option String
keyForSite table name resultMono = match matchedEntry table name resultMono
  Some (KeyEntry _ tag _ key) =>
    if headCollides table name tag then
      Some key
    else
      None
  None => None

-- the entry whose method set contains [name] and whose head pattern matches the
-- concrete result mono (the impl the checker dispatches into at this site).  When
-- SEVERAL entries' head patterns match (overlapping instances, e.g. `Def (List a)`
-- and `Def (List Int)` both matching the ground result `List Int`), pick the
-- MOST-SPECIFIC one — the entry that is strictly more specific than (or equal to)
-- every other matching entry (WS-3/D4 return-position most-specific-wins).  No
-- unique most-specific (equal heads or incomparable partial overlap) → keep the
-- FIRST match, behaviour unchanged.  Mirrors lib/typecheck.ml's
-- `strictly_more_specific` selection at a call site.
matchedEntry : KeyBuckets -> String -> Mono -> Option KeyEntry
matchedEntry table name resultMono =
  pickMostSpecificEntry (matchingEntries table name resultMono)

-- all entries defining [name] whose head pattern matches [resultMono], in
-- declaration order.  #148: matchTyMono can only succeed when the entry's head
-- tycon equals [resultMono]'s spine head (a KeyEntry head is never a bare TyVar —
-- keyEntryOf only emits one when headTyconTy is Some), so scanning ONLY the bucket
-- at `monoHeadCon resultMono` collects exactly the same entries in the same order
-- as the old whole-table scan.  A headless mono (TVar/TFun) matched no entry then
-- and keys no bucket now → [].
matchingEntries : KeyBuckets -> String -> Mono -> List KeyEntry
matchingEntries buckets name resultMono = match monoHeadCon resultMono
  Some tag => matchingEntriesGo (bucketOf tag buckets) name resultMono
  None => []

matchingEntriesGo : List KeyEntry -> String -> Mono -> List KeyEntry
matchingEntriesGo [] _ _ = []
matchingEntriesGo ((KeyEntry methodNames tag headTy key)::rest) name resultMono
  | contains name methodNames = match matchTyMono headTy resultMono
    Some _ => KeyEntry methodNames tag headTy key :: matchingEntriesGo rest name resultMono
    None => matchingEntriesGo rest name resultMono
  | otherwise = matchingEntriesGo rest name resultMono

-- pick the entry strictly more specific than every OTHER matching entry; if no
-- such unique entry exists (≤1 match, equal heads, or incomparable overlap) keep
-- the head of the list (the pre-existing first-match behaviour).
pickMostSpecificEntry : List KeyEntry -> Option KeyEntry
pickMostSpecificEntry [] = None
pickMostSpecificEntry (e::rest) = match findMostSpecificEntry (e::rest) (e::rest)
  Some best => Some best
  None => Some e

findMostSpecificEntry : List KeyEntry -> List KeyEntry -> Option KeyEntry
findMostSpecificEntry [] _ = None
findMostSpecificEntry (c::cs) all
  | entryCoversAllOthers c all = Some c
  | otherwise = findMostSpecificEntry cs all

-- is [cand]'s head pattern more specific than (or structurally equal to) every
-- entry in [all]?  Equal-head entries are covered trivially; a genuinely more-
-- general entry is NOT covered, so [cand] is rejected for it.
entryCoversAllOthers : KeyEntry -> List KeyEntry -> Bool
entryCoversAllOthers cand all = allList (entryCovers cand) all

entryCovers : KeyEntry -> KeyEntry -> Bool
entryCovers (KeyEntry _ _ candTy _) (KeyEntry _ _ otherTy _) = tyHeadEq candTy otherTy
  || tyStrictlyMoreSpecific candTy otherTy

-- the two entries are the SAME head pattern (structurally equal up to var
-- renaming) — no ordering needed, the candidate trivially covers it.
tyHeadEq : Ty -> Ty -> Bool
tyHeadEq a b = tySubsumes a b && tySubsumes b a

-- [a] is STRICTLY more specific than [b]: [b] subsumes [a] but not vice versa.
tyStrictlyMoreSpecific : Ty -> Ty -> Bool
tyStrictlyMoreSpecific a b = tySubsumes b a && not (tySubsumes a b)

-- is [specific] an instance of [general]?  Only the GENERAL side's TyVars act as
-- wildcards (bound consistently — bound twice must see structurally equal types);
-- the SPECIFIC side's TyVars are rigid and match only the same name.  Mirrors
-- lib/typecheck.ml's `subsumes`.
tySubsumes : Ty -> Ty -> Bool
tySubsumes general specific = match tySubsumeGo general specific (Some [])
  Some _ => True
  None => False

tySubsumeGo : Ty -> Ty -> Option (List (String, Ty)) -> Option (List (String, Ty))
tySubsumeGo _ _ None = None
tySubsumeGo (TyVar gn) s (Some sub) = match lookupAssoc gn sub
  Some prev => if tyStructEq prev s then Some sub else None
  None => Some ((gn, s)::sub)
tySubsumeGo (TyCon a _) (TyCon b _) acc = if a == b then acc else None
tySubsumeGo (TyCon a _) _ acc = None
tySubsumeGo (TyApp f1 a1) (TyApp f2 a2) acc =
  tySubsumeGo a1 a2 (tySubsumeGo f1 f2 acc)
tySubsumeGo (TyApp f1 a1) _ acc = None
tySubsumeGo (TyFun a1 b1) (TyFun a2 b2) acc =
  tySubsumeGo b1 b2 (tySubsumeGo a1 a2 acc)
tySubsumeGo (TyFun a1 b1) _ acc = None
tySubsumeGo (TyTuple ts1) (TyTuple ts2) acc =
  if listLen ts1 == listLen ts2 then
    tySubsumeGoList ts1 ts2 acc
  else
    None
tySubsumeGo (TyTuple ts1) _ acc = None
tySubsumeGo (TyEffect _ _ t1) s acc = tySubsumeGo t1 (stripTyWrap s) acc
tySubsumeGo (TyConstrained _ t1) s acc = tySubsumeGo t1 (stripTyWrap s) acc

tySubsumeGoList : List Ty -> List Ty -> Option (List (String, Ty)) -> Option (List (String, Ty))
tySubsumeGoList [] [] acc = acc
tySubsumeGoList (t1::ts1) (t2::ts2) acc =
  tySubsumeGoList ts1 ts2 (tySubsumeGo t1 t2 acc)
tySubsumeGoList _ _ _ = None

stripTyWrap : Ty -> Ty
stripTyWrap (TyEffect _ _ t) = stripTyWrap t
stripTyWrap (TyConstrained _ t) = stripTyWrap t
stripTyWrap t = t

-- structural equality of two AST type patterns (rigid; TyVar names must match).
tyStructEq : Ty -> Ty -> Bool
tyStructEq (TyCon a _) (TyCon b _) = a == b
tyStructEq (TyVar a) (TyVar b) = a == b
tyStructEq (TyApp f1 a1) (TyApp f2 a2) = tyStructEq f1 f2 && tyStructEq a1 a2
tyStructEq (TyFun a1 b1) (TyFun a2 b2) = tyStructEq a1 a2 && tyStructEq b1 b2
tyStructEq (TyTuple ts1) (TyTuple ts2) = tyStructEqList ts1 ts2
tyStructEq (TyEffect _ _ t1) (TyEffect _ _ t2) = tyStructEq t1 t2
tyStructEq (TyConstrained _ t1) (TyConstrained _ t2) = tyStructEq t1 t2
tyStructEq _ _ = False

tyStructEqList : List Ty -> List Ty -> Bool
tyStructEqList [] [] = True
tyStructEqList (t1::ts1) (t2::ts2) = tyStructEq t1 t2 && tyStructEqList ts1 ts2
tyStructEqList _ _ = False

-- do two distinct impls of [name] share head tycon [tag]?  (≥2 entries that
-- define [name] at the same head tycon.)
headCollides : KeyBuckets -> String -> String -> Bool
headCollides table name tag = countHead table name tag > 1

countHead : KeyBuckets -> String -> String -> Int
countHead buckets name tag = countHeadGo (bucketOf tag buckets) name tag

countHeadGo : List KeyEntry -> String -> String -> Int
countHeadGo [] _ _ = 0
countHeadGo ((KeyEntry methodNames tag2 _ _)::rest) name tag
  | contains name methodNames && tag2 == tag = 1 + countHeadGo rest name tag
  | otherwise = countHeadGo rest name tag

-- the head type constructor of an (unelaborated) AST type
headTyconTy : Ty -> Option String
headTyconTy (TyCon n _) = Some n
headTyconTy (TyApp a _) = headTyconTy a
headTyconTy (TyTuple ts) = Some (tupleHeadTagTc (listLen ts))
headTyconTy _ = None

-- Multi-param-interface variant: [paramMonos] is the FULL list of the interface's
-- type-parameter monos at this occurrence (recovered by ifaceParamMonos), e.g. for
-- `Set { 3,1,2 } : Set _a` the `FromEntries c e` occurrence has c↦Set _a, e↦Int.
-- The single-param result-only path lost the element grounding (`e`): matching the
-- impl head `Set a` against the result `Set _a` only binds a↦_a (a free var), so the
-- `requires Ord a` route fell to RNone → a null Ord dict → SIGSEGV.  Matching the
-- impl's FULL `implTys` (`[Set a, a]`) against ALL the param monos recovers a↦Int from
-- the second param, exactly as the OCaml oracle's impl_head_subst keys off the full
-- concrete_args (the interface's param_vars), not just the result.
implDictRoutesForFull : ImplBuckets -> String -> String -> Mono -> List Mono -> List Route
implDictRoutesForFull implTable name tag resultMono paramMonos =
  implDictRoutesIn
    implTable
    (bucketOf tag implTable)
    name
    tag
    resultMono
    paramMonos

-- [fullTable] is the whole bucketed table (for the nested implReqRoutes recursion,
-- which re-buckets by the requires' own head); the scanned second arg is the [tag]
-- bucket only.
implDictRoutesIn : ImplBuckets -> List ImplEntry -> String -> String -> Mono -> List Mono -> List Route
implDictRoutesIn _ [] _ _ _ _ = []
implDictRoutesIn fullTable ((ImplEntry tag2 methodNames headTy reqs implTys _)::rest) name tag resultMono paramMonos
  | tag2 == tag && contains name methodNames = match headSubstWithParams headTy implTys resultMono paramMonos
    Some subst => implReqRoutes fullTable subst reqs
    None => implDictRoutesIn fullTable rest name tag resultMono paramMonos
  | otherwise = implDictRoutesIn fullTable rest name tag resultMono paramMonos

-- Build the impl head substitution.  Always match the impl HEAD (`Set a`) against
-- the result mono (the historical single-param behaviour, byte-identical when no
-- extra param info is supplied).  THEN, when the caller has the interface's FULL
-- param monos (`[Set _a, Int]` for a multi-param interface) and they line up with
-- the impl's full type-arg patterns (`[Set a, a]`), additionally match the trailing
-- patterns against the trailing param monos and merge — preferring a concrete head
-- (Int) over a free var (_a) on a key collision.  This recovers the element grounding
-- (`a ↦ Int`) the head-only match lost.  When the param monos don't line up (a plain
-- result-only call, or a shape mismatch) the head match alone stands.
headSubstWithParams : Ty -> List Ty -> Mono -> List Mono -> Option (List (String, Mono))
headSubstWithParams headTy implTys resultMono paramMonos = map
  (headSub => augmentWithParams headSub implTys paramMonos)
  (matchTyMono headTy resultMono)

-- When the impl's full type-arg patterns line up with the interface's full param
-- monos (a multi-param interface), fold the trailing element groundings into the
-- head subst (concrete-wins); otherwise return the head subst unchanged.
augmentWithParams : List (String, Mono) -> List Ty -> List Mono -> List (String, Mono)
augmentWithParams headSub implTys paramMonos
  | listLen implTys == listLen paramMonos && listLen paramMonos > 1 = match implHeadSubst implTys paramMonos
    Some full => mergeSubstPreferConcrete headSub full
    None => headSub
  | otherwise = headSub

-- Match the impl's full type-arg patterns [pats] (`[Set a, a]`) against the
-- interface's concrete param monos [concretes] (`[Set _a, Int]`), accumulating a
-- name→mono subst.  When the SAME impl var appears in several positions (here `a`
-- is both the head element and the standalone element param), prefer the binding
-- whose mono has a CONCRETE head tycon (Int) over a still-free var (_a) — that is
-- what recovers the element grounding the result-only match missed.  Mirrors the
-- oracle's impl_head_subst (Hashtbl.replace last-wins, with concrete winning here).
-- A length mismatch / structural failure → None (no match, try the next impl), so a
-- single-param interface ([resultMono] only) behaves exactly as the old matchTyMono.
implHeadSubst : List Ty -> List Mono -> Option (List (String, Mono))
implHeadSubst pats concretes
  | listLen pats != listLen concretes = None
  | otherwise = implHeadSubstGo pats concretes (Some [])

implHeadSubstGo : List Ty -> List Mono -> Option (List (String, Mono)) -> Option (List (String, Mono))
implHeadSubstGo [] [] acc = acc
implHeadSubstGo (p::ps) (c::cs) None = None
implHeadSubstGo (p::ps) (c::cs) (Some sofar) = match matchTyMono p c
  None => None
  Some s => implHeadSubstGo ps cs (Some (mergeSubstPreferConcrete sofar s))
implHeadSubstGo _ _ _ = None

-- Merge two name→mono substs; on a key collision keep whichever value has a
-- concrete head tycon (so the grounded element wins over a free result var).
mergeSubstPreferConcrete : List (String, Mono) -> List (String, Mono) -> List (String, Mono)
mergeSubstPreferConcrete acc [] = acc
mergeSubstPreferConcrete acc ((k, v)::rest) =
  mergeSubstPreferConcrete (mergeOne acc k v) rest

mergeOne : List (String, Mono) -> String -> Mono -> List (String, Mono)
mergeOne [] k v = [(k, v)]
mergeOne ((k2, v2)::rest) k v
  | k2 == k = (k2, preferConcrete v2 v)::rest
  | otherwise = (k2, v2) :: mergeOne rest k v

preferConcrete : Mono -> Mono -> Mono
preferConcrete a b = match headTyconMono a
  Some _ => a
  None => b

-- match an impl-head type PATTERN against a concrete mono, binding the impl's
-- type-variable names to monos (single-level: the pattern's args are bare vars).
matchTyMono : Ty -> Mono -> Option (List (String, Mono))
matchTyMono (TyVar n) m = Some [(n, m)]
matchTyMono (TyCon n _) m = match normalize m
  TCon n2 => if n == n2 then Some [] else None
  _ => None
matchTyMono (TyApp a b) m = match normalize m
  TApp ma mb => combineSubst (matchTyMono a ma) (matchTyMono b mb)
  _ => None
-- Native Gap C: a tuple impl head (`(a, b)`) matches a same-arity tuple mono,
-- recovering one element-var subst per position — so a tuple impl's per-element
-- `requires` (Eq a, Eq b, …) recover their element-dict routes, exactly as the
-- TyApp arm does for parametric ADTs.  Mismatched arity → None (distinct groups).
matchTyMono (TyTuple ts) m = match tupleSpine m
  Some ms => if listLen ts == listLen ms then matchTyMonoList ts ms else None
  _ => None
-- Function-type arm: recover typaram bindings from BOTH a method's argument and
-- result positions (used by ifaceParamMonos to ground a multi-param interface's
-- element param `e` from the argument `List e`).  Effects are ignored.  Wrapper
-- nodes (effect/constrained annotations on the declared Ty) are stripped first.
matchTyMono (TyFun a b) m = match normalize m
  TFun ma _ mb => combineSubst (matchTyMono a ma) (matchTyMono (stripEff b) mb)
  _ => None
matchTyMono (TyEffect _ _ t) m = matchTyMono t m
matchTyMono (TyConstrained _ t) m = matchTyMono t m
matchTyMono _ _ = None

-- zip-match element-type patterns against element monos, combining the substs.
matchTyMonoList : List Ty -> List Mono -> Option (List (String, Mono))
matchTyMonoList [] [] = Some []
matchTyMonoList (t::ts) (m::ms) =
  combineSubst (matchTyMono t m) (matchTyMonoList ts ms)
matchTyMonoList _ _ = None

combineSubst : Option (List (String, Mono)) -> Option (List (String, Mono)) -> Option (List (String, Mono))
combineSubst (Some xs) (Some ys) = Some (xs ++ ys)
combineSubst _ _ = None

-- one route per requires: substitute the recovered element subst into the
-- requires' dispatch arg, take its head tycon (the dict tag eval narrows by),
-- and recursively compute that impl's own requires routes (Phase 83/84 #5).
implReqRoutes : ImplBuckets -> List (String, Mono) -> List Require -> List Route
implReqRoutes _ _ [] = []
implReqRoutes implTable subst ((Require rIface rargs)::rest) =
  reqRoute implTable rIface subst rargs :: implReqRoutes implTable subst rest

-- depth-limited variants used by implRequiresRoutesRec (WS-4b).
implReqRoutesD : ImplBuckets -> List (String, Mono) -> List Require -> Int -> List Route
implReqRoutesD _ _ [] _ = []
implReqRoutesD implTable subst ((Require rIface rargs)::rest) depth =
  reqRouteD implTable rIface subst rargs depth ::
    implReqRoutesD implTable subst rest depth

reqRouteD : ImplBuckets -> String -> List (String, Mono) -> List Ty -> Int -> Route
reqRouteD _ _ _ [] _ = RNone
reqRouteD implTable iface subst (arg::_) depth =
  let m = fromAstType subst arg
  match headTyconMono m
    Some tag => RKey tag (implRequiresRoutesRecD implTable iface tag m depth)
    None => RNone

reqRoute : ImplBuckets -> String -> List (String, Mono) -> List Ty -> Route
reqRoute _ _ _ [] = RNone
reqRoute implTable iface subst (arg::_) =
  let m = fromAstType subst arg
  match headTyconMono m
    Some tag => RKey tag (implRequiresRoutesRec implTable iface tag m)
    None => RNone

-- Phase 83/84 #5: given the concrete mono [m] whose head tycon is [tag], find the
-- matching parametric impl in [implTable] and compute its requires routes
-- recursively — so RKey(tag, [RKey(subTag, [...])]) encodes the full element-dict
-- nesting.  Terminates because each step structurally shrinks the requirement type.
-- WS-4b: depth fuse (max 32 levels) guards against non-shrinking impl contexts
-- like `impl C (T a) requires C (T (T a))` that would otherwise diverge here at
-- route-resolution time.  Depth 32 is ample for valid programs (real nesting rarely
-- exceeds 3–4 levels); a pathological impl is ill-formed and checkInterfaceCycles
-- won't catch it (it's an impl-requires cycle, not a superinterface cycle), so the
-- fuse is the primary guard.  On limit-hit we return [] (no routes), which means
-- the nested element dict resolves to RNone → the emit path emits a null cell;
-- this is safe because the impl itself is ill-formed and will never produce a
-- valid concrete instantiation in a well-typed program.
implRequiresRoutesRec : ImplBuckets -> String -> String -> Mono -> List Route
implRequiresRoutesRec implTable iface tag m =
  implRequiresRoutesRecD implTable iface tag m 0

-- depth-limited core of implRequiresRoutesRec (WS-4b: max 32 levels).
implRequiresRoutesRecD : ImplBuckets -> String -> String -> Mono -> Int -> List Route
implRequiresRoutesRecD implTable iface tag m depth =
  if depth >= 32 then []
  else match findImplEntry implTable iface tag m
    Some (ImplEntry _ _ headTy reqs _ _) => match matchTyMono headTy m
      Some subst => implReqRoutesD implTable subst reqs (depth + 1)
      None => []
    None => []

-- find the ImplEntry in [implTable] for interface [iface] whose head tycon is
-- [tag] and whose head pattern matches the concrete mono [m].  A type may carry
-- SEVERAL `requires`-bearing impls at one head tycon for different interfaces
-- whose requires differ in shape (arity/parameters); keying on the tag alone
-- picked the first such impl and produced the WRONG element-dict routes (e.g.
-- `Applicative (VT e) requires Semigroup e` stealing dispatch from
-- `Debug (VT e a) requires Debug e, Debug a`).  So we filter by [iface] too.
-- [iface] == "" means "no interface known" (the method-level path) → fall back to
-- the historical first-by-tag behaviour.  The head-pattern match against [m] is
-- also required so a same-iface but wrong-arity head (e.g. `VT e` vs `VT e a`) is
-- skipped rather than matched-then-dropped.
findImplEntry : ImplBuckets -> String -> String -> Mono -> Option ImplEntry
findImplEntry buckets iface tag m =
  findImplEntryGo (bucketOf tag buckets) iface tag m

findImplEntryGo : List ImplEntry -> String -> String -> Mono -> Option ImplEntry
findImplEntryGo [] _ _ _ = None
findImplEntryGo ((ImplEntry tag2 ms hty reqs itys ifn)::rest) iface tag m
  | tag2 == tag && (iface == "" || ifn == iface) = match matchTyMono hty m
    Some _ => Some (ImplEntry tag2 ms hty reqs itys ifn)
    None => findImplEntryGo rest iface tag m
  | otherwise = findImplEntryGo rest iface tag m

-- fill each constrained-fn call site's routes: one route per constraint mono.  A
-- mono pinned to a concrete head → RKey; still a constraint variable (a nested
-- constrained call) → RDict; otherwise RNone.
resolveDictApps : List Decl -> ImplBuckets -> List (Ref (List Route), List Mono, List String) -> Unit
resolveDictApps _ _ [] = ()
resolveDictApps prog implTable ((routesRef, monos, ifaces)::rest) =
  let routes = routesOfMonosTop prog implTable monos ifaces
  let _ = setRef routesRef routes
  resolveDictApps prog implTable rest

-- TOP-LEVEL constraint routes (a constrained-fn CALL site, e.g. `roundtrip 10`).
-- Identical to routesOfMonos except for the UNDETERMINED case (the constraint var is
-- pinned by neither an argument nor the result): instead of the nested-recursion
-- RNone (which yields an empty dict → runtime `intToString: not an Int` / a null
-- build dict), look up how many impls of the slot's interface exist:
--   • exactly ONE  → stamp a concrete RKey to that impl's head tag (deterministic
--                    dispatch on both run and build);
--   • two or more  → genuinely ambiguous → pushTypeError AmbiguousImpl (DELIBERATELY
--                    diverges from the frozen oracle's silent first-wins);
--   • zero         → keep RNone (existing no-impl behaviour/error).
-- Kept SEPARATE from routesOfMonos/routeOfMono so the nested element-dict recursion
-- (argReqRoute → routeOfMono) is untouched — a blanket RNone→RKey there would corrupt
-- element-dict routing.
routesOfMonosTop : List Decl -> ImplBuckets -> List Mono -> List String -> List Route
routesOfMonosTop _ _ [] _ = []
routesOfMonosTop prog implTable (m::rest) [] =
  routeOfMonoTop prog implTable "" m :: routesOfMonosTop prog implTable rest []
routesOfMonosTop prog implTable (m::rest) (iface::ifacesRest) =
  routeOfMonoTop prog implTable iface m ::
    routesOfMonosTop prog implTable rest ifacesRest

routeOfMonoTop : List Decl -> ImplBuckets -> String -> Mono -> Route
routeOfMonoTop prog implTable iface m = match activeDictVarOf m
  Some dname => RDict dname
  None => match headTyconMono m
    Some tag => RKey tag (argImplRequiresRoutesRec implTable iface tag m)
    None => routeUndeterminedTop prog implTable iface

-- the undetermined-constraint resolution: count impls of [iface] in [prog].
routeUndeterminedTop : List Decl -> ImplBuckets -> String -> Route
routeUndeterminedTop prog implTable iface
  | iface == "" = RNone
  | otherwise = match implHeadTagsForIface prog iface
    [] => RNone
    [tag] => RKey tag (argImplRequiresRoutesRec implTable iface tag (TCon tag))
    _ => reportAmbiguousImpl iface

reportAmbiguousImpl : String -> Route
reportAmbiguousImpl iface =
  let _ = pushTypeError "T-AMBIGUOUS-INSTANCE" (ambiguousImplMsg iface)
  RNone

-- every impl head tycon for [iface] declared in [prog] (a single-arg interface has
-- one head ty per impl; we read its head tycon).  Dedups so a prelude impl imported
-- twice via multi-module loading doesn't read as ambiguous.
implHeadTagsForIface : List Decl -> String -> List String
implHeadTagsForIface prog iface =
  dedupStr (flatMap (implHeadTagForIface iface) prog)

implHeadTagForIface : String -> Decl -> List String
implHeadTagForIface want (DAttrib _ d) = implHeadTagForIface want d
implHeadTagForIface want (DImpl { iface, tys, ... })
  | iface == want = match tys
    headTy::_ => match headTyconTy headTy
      Some tag => [tag]
      None => []
    [] => []
  | otherwise = []
implHeadTagForIface _ _ = []

dedupStr : List String -> List String
dedupStr xs = dedupStrGo [] xs

dedupStrGo : List String -> List String -> List String
dedupStrGo _ [] = []
dedupStrGo seen (x::rest)
  | contains x seen = dedupStrGo seen rest
  | otherwise = x :: dedupStrGo (x::seen) rest

ambiguousImplMsg : String -> String
ambiguousImplMsg iface = "Ambiguous instance for `"
  ++ iface
  ++ "`. Cannot determine which impl; add a type annotation"

routesOfMonos : ImplBuckets -> List Mono -> List Route
routesOfMonos _ [] = []
routesOfMonos implTable (m::rest) =
  routeOfMono implTable m :: routesOfMonos implTable rest

routeOfMono : ImplBuckets -> Mono -> Route
routeOfMono implTable m = match activeDictVarOf m
  Some dname => RDict dname
  None => match headTyconMono m
    Some tag => RKey tag (argImplRequiresRoutesRec implTable "" tag m)
    None => RNone

-- encl-aware analogue of routeOfMono: when the element mono is one of the enclosing
-- method [encl]'s own constraint vars, route to [encl]'s `$dict_<encl>_<slot>` param
-- (activeDictVarForEncl) rather than the global last-registered name.  Recurses
-- encl-aware so nested element dicts (`List (k, v)` under a `requires Ord k, Ord v`)
-- forward [encl]'s params at every level.  encl == "" ⇒ identical to routeOfMono.
routeOfMonoEncl : ImplBuckets -> String -> String -> Mono -> Route
routeOfMonoEncl implTable iface encl m = match activeDictVarForEncl m encl
  Some dname => RDict dname
  None => match headTyconMono m
    Some tag =>
      RKey tag (argImplRequiresRoutesRecEncl implTable iface encl tag m)
    None => RNone

-- Native #54/#21 residual: the activeDictVar-AWARE analogue of
-- implRequiresRoutesRec, used ONLY by the arg-position routeOfMono recursion.
-- The return-position implRequiresRoutesRec recurses through reqRoute, which is
-- activeDictVar-BLIND (RNone for an abstract var) — correct for the golden return
-- path, but WRONG one level down on the arg path: e.g. a `Debug (Map k v)` impl
-- body's `debug (toList m)` arg-stamps `List (k, v)` → RKey "List" recursing into
-- the tuple `(k, v)` whose element vars `k`/`v` ARE the enclosing impl's
-- `requires Debug k, Debug v` dict params (registered in activeDictVars), so they
-- must route RDict $dict_debug_<slot>, NOT RNone.  Recursing via routeOfMono
-- (not reqRoute) keeps every nesting level activeDictVar-aware, so the emitted
-- element-dict cell carries the live impl dicts instead of a null (0) field — the
-- null field was the SIGSEGV (the inner per-element debug/eq/compare dispatched
-- through a 0 dict).  Kept SEPARATE from implRequiresRoutesRec so the golden
-- return-position routing stays byte-identical.
argImplRequiresRoutesRec : ImplBuckets -> String -> String -> Mono -> List Route
argImplRequiresRoutesRec implTable iface tag m =
  argImplRequiresRoutesRecEncl implTable iface "" tag m

argImplRequiresRoutesRecEncl : ImplBuckets -> String -> String -> String -> Mono -> List Route
argImplRequiresRoutesRecEncl implTable iface encl tag m = match findImplEntry implTable iface tag m
  Some (ImplEntry _ _ headTy reqs _ _) => match matchTyMono headTy m
    Some subst => argImplReqRoutes implTable encl subst reqs
    None => []
  None => []

-- ── D3b-1: arg-position element-dict routing ────────────────────────────────
-- The argument-position analogue of implDictRoutesFor.  Same impl-table match +
-- head-pattern unification against the discriminating-argument mono, but each
-- requires route is computed by routeOfMono (activeDictVar-aware): a recursive
-- element of the SAME parametric type (the impl's own element tyvar `a`, still a
-- registered constraint var) forwards the in-scope `$dict_<method>_<slot>` param
-- (RDict); a concrete element (`MyList Int`) materializes a static RKey.  Kept
-- SEPARATE from the return-position reqRoute/implDictRoutesFor chain so that
-- golden path's routing is untouched (this runs only for emit-path arg stamps).
argImplDictRoutesFor : ImplBuckets -> String -> String -> Mono -> List Route
argImplDictRoutesFor implTable name tag mono =
  argImplDictRoutesForEncl implTable "" name tag mono

-- encl-aware variant: thread the ENCLOSING method [encl] so the recursively-routed
-- element dicts forward [encl]'s own `$dict_<encl>_<slot>` params (not whichever
-- method registered the shared impl tyvar id LAST — see activeDictVarForEncl).  encl
-- == "" recovers the original global routing (binop path, single-method impls).
argImplDictRoutesForEncl : ImplBuckets -> String -> String -> String -> Mono -> List Route
argImplDictRoutesForEncl implTable encl name tag mono =
  argImplDictRoutesForGo implTable (bucketOf tag implTable) encl name tag mono

-- #21 (G4): element routes (argImplReqRoutes) must search the FULL impl table, not
-- the suffix from the matched outer entry.  The original recursion passed
-- `(matched :: rest)` — when the outer impl (e.g. user `Box`) sits LAST in the table
-- the element search saw only `[Box]` and could not find a DIFFERENT element impl
-- (List/Option/Wrap) that sits earlier → empty reqs → a flat 1-word dict cell → the
-- inner per-element dispatch read a missing field → SIGSEGV.  `Box (Box X)` worked by
-- accident (element tag == matched head, so it was the suffix head).  [full] keeps the
-- whole table for the nested routeOfMono recursion; [scan] walks to find the head.
argImplDictRoutesForGo : ImplBuckets -> List ImplEntry -> String -> String -> String -> Mono -> List Route
argImplDictRoutesForGo _ [] _ _ _ _ = []
argImplDictRoutesForGo full ((ImplEntry tag2 methodNames headTy reqs _ _)::rest) encl name tag mono
  | tag2 == tag && contains name methodNames = match matchTyMono headTy mono
    Some subst => argImplReqRoutes full encl subst reqs
    None => argImplDictRoutesForGo full rest encl name tag mono
  | otherwise = argImplDictRoutesForGo full rest encl name tag mono

argImplReqRoutes : ImplBuckets -> String -> List (String, Mono) -> List Require -> List Route
argImplReqRoutes _ _ _ [] = []
argImplReqRoutes implTable encl subst ((Require rIface rargs)::rest) =
  argReqRoute implTable rIface encl subst rargs ::
    argImplReqRoutes implTable encl subst rest

argReqRoute : ImplBuckets -> String -> String -> List (String, Mono) -> List Ty -> Route
argReqRoute _ _ _ _ [] = RNone
argReqRoute implTable iface encl subst (arg::_) =
  routeOfMonoEncl implTable iface encl (fromAstType subst arg)

-- Phase 69.x-e: fill each method occurrence's method-dicts ref — one route per
-- method-level constraint, from the instantiated constraint mono.  A concrete head
-- → RKey (eval supplies a literal VDict for the body's `empty`/… to read); a
-- constraint variable still (the caller is itself constrained) → RDict forwarding
-- the caller's dict.  Mirrors resolveDictApps; runs after inference.
resolveMethodDicts : ImplBuckets -> List (Ref (List Route), List Mono) -> Unit
resolveMethodDicts _ [] = ()
resolveMethodDicts implTable ((methodRef, monos)::rest) =
  let _ = setRef methodRef (routesOfMonos implTable monos)
  resolveMethodDicts implTable rest

-- ── recursive dict-app realization (self/mutual recursion) ──────────────────
-- A deferred recursive call records one route per the CALLEE's constraint slot
-- (matching the dict params dict_pass prepends to its def), each forwarding the
-- ENCLOSING fn's own dict param.  Run after inference, when funConstraintsRef is
-- fully populated.
realizeRecDictApps : List RecDictApp -> Unit
realizeRecDictApps [] = ()
realizeRecDictApps ((RecDictApp routesRef callee encl mono)::rest) =
  let ids = fromOption [] (lookupAssocSL2 callee funConstraintsRef.value)
  let routes = recRoutes encl mono ids
  let _ = setRef routesRef routes
  realizeRecDictApps rest

recRoutes : String -> Mono -> List Int -> List Route
recRoutes _ _ [] = []
recRoutes encl mono (id::rest) =
  recRoute encl mono id :: recRoutes encl mono rest

-- For one of the callee's constraint ids, recover the live occurrence type from
-- [mono] (the var the body unified it to).  Concrete head → RKey; still a
-- constraint variable that is one of [encl]'s own → forward [encl]'s dict param
-- (RDict, the slot it sits at); otherwise fall back to the global routing.
recRoute : String -> Mono -> Int -> Route
recRoute encl mono id = match findTvarInMono mono id
  None => RNone
  Some m => resolveRecMono encl m

resolveRecMono : String -> Mono -> Route
resolveRecMono encl m = match headTyconMono m
  Some tag => RKey tag []
  None => match enclSlot encl m
    Some slot => RDict (dictParamName encl slot)
    None => routeOfMono omEmpty m

-- the dict-param slot at which [m]'s tyvar sits among the enclosing fn's
-- constraint ids (its position in funConstraintsRef[encl] = the kept slot)
enclSlot : String -> Mono -> Option Int
enclSlot encl m = match normalize m
  TVar cell => indexOfId (tyvarId cell) (fromOption [] (lookupAssocSL2 encl funConstraintsRef.value))
  _ => None

indexOfId : Int -> List Int -> Option Int
indexOfId target ids = indexOfIdGo 0 target ids

indexOfIdGo : Int -> Int -> List Int -> Option Int
indexOfIdGo _ _ [] = None
indexOfIdGo i target (x::xs)
  | x == target = Some i
  | otherwise = indexOfIdGo (i + 1) target xs

-- the tyvar in [t] whose id is [id], if any (mirrors the reference's
-- find_tvar_in_mono): recovers the enclosing constraint var the body unified into
-- the recursive call's type
findTvarInMono : Mono -> Int -> Option Mono
findTvarInMono t id = findTvarN (normalize t) id

findTvarN : Mono -> Int -> Option Mono
findTvarN (TVar cell) id = if tyvarId cell == id then Some (TVar cell) else None
findTvarN (TCon _) _ = None
findTvarN (TApp a b) id = firstTvar a b id
findTvarN (TFun a _ b) id = firstTvar a b id
-- An effect row is reachable here as a KRow type-application argument
-- (`TApp con (TEff row)`); a value-level tyvar id is never inside an effect row
-- (its tail is an effvar, a separate namespace), so the answer is None.
findTvarN (TEff _) _ = None

firstTvar : Mono -> Mono -> Int -> Option Mono
firstTvar a b id = match findTvarInMono a id
  Some m => Some m
  None => findTvarInMono b id

-- ── dict_pass: prepend dict parameters to constrained function definitions ──
-- For each top-level def of a name in [dictNames], prepend one `$dict_<fn>_<slot>`
-- parameter per constraint (arity from funConstraintsRef, populated during
-- inference), matching the dicts EDictAt applies at call sites.  Multi-clause
-- functions are several DFunDef decls; each clause gets the same leading params.
dictPass : List String -> List Decl -> List Decl
dictPass names prog =
  map
    (dictPassDecl names (returnPosMethodNames prog))
    (mapProg rewriteBinopExpr prog)

-- Phase 151 / Gap G: rewrite each *stamped* comparison/equality EBinOp into its
-- Eq/Ord method application via EMethodAt (the same dispatch node `eq`/`lt` calls
-- become), so eval routes to the user/derived impl.  Only nodes resolveBinopSites
-- stamped (ground non-primitive operand) carry a non-RNone route; primitives /
-- arithmetic stay the literal EBinOp the eval builtin handles (no recursion).
-- Native Gap C: a parametric impl (tuple `Eq (a,b)`) has element `requires` dicts
-- the body reads; resolveBinopSite stamped them into the RKey route's reqs, which
-- binopMethodApp now forwards as the EMethodAt impl-dict routes (the 3rd ref).  A
-- non-parametric concrete impl stamps empty reqs → the plain direct call.
--   <→lt  >→gt  <=→lte  >=→gte  ==→eq  !=→not (eq a b)
rewriteBinopExpr : Expr -> Expr
rewriteBinopExpr (EBinOp op l r routeRef) = match routeRef.value
  RNone => EBinOp op l r routeRef
  -- SHARED-FLOAT-RESIDUAL §3(C): an RScalar route is NOT a typeclass dispatch — it
  -- is the scalar-type tag typecheck stamped on a monomorphic arithmetic binop
  -- (resolveArithSite, "Float").  The EBinOp's own route ref does NOT survive the
  -- dict-pass→lower boundary (only NODE values do — verified: an op-string change in
  -- this arm reaches lower but a setRef on routeRef does not), so we carry the scalar
  -- type in a NODE by wrapping the binop in `EAnnot … (TyCon tag)`.  Eval ignores the
  -- annotation (`eval (EAnnot e _) = eval e`) and evaluates the binop dynamically
  -- (Float-correct); lowering reads the annotation to stamp CBinPrim's scalar tag so
  -- the native emitter picks the Float primitive (bypassing the type-lost
  -- staticIsFloat).  This is the dispatch route READ-OUT the design names, relocated
  -- from the (lost) ref cell to a (surviving) node.
  RScalar tag => EAnnot (EBinOp op l r routeRef) (TyCon tag None)
  _ => binopMethodApp op l r routeRef
-- PLAN.md #11: re-tag a source integer literal to its inferred runtime rep, a 3-way
-- decision mirroring lib/dict_pass.ml's e7031e6 ENumLit arm.  setNumlitFloats already
-- decided: float cell `Some f` ⇒ concrete Float ⇒ `ELit (LFloat f)`; otherwise the
-- route cell [dref] distinguishes concrete-Int (RNone, cleared) from a surviving
-- polymorphic `Num a` (a non-RNone RDictFwd/RKey route, the soundness case) — the
-- latter dispatches through the runtime Num dict via `fromInt n` (the SAME dict the
-- enclosing `Num a => …` function threads), closing the hole where `inc x = x + 1`
-- instantiated at Float crashed `VFloat + VInt`.  The constructed EMethodAt carries
-- [dref]'s route on its tag ref; impl-dicts/method-dicts refs are empty (`Num` has no
-- element `requires`).  Done in the same mapProg walk that rewrites binops, so
-- eval/lower never see ENumLit and eval_arith / the emitter get matching tags.
rewriteBinopExpr (ENumLit n fref dref) = match fref.value
  Some f => ELit (LFloat f)
  None => match dref.value
    RNone => ELit (LInt n)
    route =>
      EApp (EMethodAt "fromInt" (Ref route) (Ref []) (Ref [])) (ELit (LInt n))
-- Roadmap #18c: rewrite each *stamped* EUnOp (`-` → `negate`) into its Num
-- method application via EMethodAt, exactly like the EBinOp arm above.  Only
-- nodes resolveUnopSites stamped (ground non-primitive operand) carry a
-- non-RNone route; Int/Float stay the literal EUnOp the eval builtin handles
-- structurally (no recursion — Int/Float's own `negate` bodies use the BINOP
-- `0 - a`, never unary minus).  `!` never routes (stays RNone unconditionally).
rewriteBinopExpr (EUnOp op e routeRef) = match routeRef.value
  RNone => EUnOp op e routeRef
  _ => unopMethodApp op e routeRef
rewriteBinopExpr e = e

-- split the stamped RKey route into a bare-tag route (reqs dropped) + the element
-- dict routes, so the dicts ride on the EMethodAt impl-dict ref (where emitMethod /
-- eval read leading dict words) rather than the route reqs (which the RKey call
-- path ignores).  A non-RKey / empty-reqs route forwards no dicts.
binopRouteSplit : Route -> (Route, List Route)
binopRouteSplit (RKey tag reqs) = (RKey tag [], reqs)
binopRouteSplit r = (r, [])

binopMethodApp : String -> Expr -> Expr -> Ref Route -> Expr
binopMethodApp op l r routeRef =
  let method = fromOption "eq" (binopMethod op)
  let split = binopRouteSplit routeRef.value
  let call = EApp (EApp (EMethodAt method (Ref (fst split)) (Ref (snd split)) (Ref [])) l) r
  if op == "!=" then EApp (EVar "not") call else call

-- The EUnOp analogue of binopMethodApp: one operand, no `!=`-style postfix
-- (unopMethod only ever routes `-`).  Reuses binopRouteSplit (a generic
-- Route-ripping helper — nothing about it is binop-specific).
unopMethodApp : String -> Expr -> Ref Route -> Expr
unopMethodApp op e routeRef =
  let method = fromOption "negate" (unopMethod op)
  let split = binopRouteSplit routeRef.value
  EApp (EMethodAt method (Ref (fst split)) (Ref (snd split)) (Ref [])) e

dictPassDecl : List String -> List String -> Decl -> Decl
dictPassDecl names _ (DFunDef pub n pats body)
  | contains n names = DFunDef pub n (dictParams n (dictArityOf n) ++ pats) body
  | otherwise = DFunDef pub n pats body
-- Top-level `let rec … with …` (DLetGroup): each binding is dict-passed exactly
-- like a DFunDef — a constrained member gets `dictParams n (dictArityOf n)`
-- prepended to every clause's params, so the dict-passed call sites (which DO get
-- rewritten) line up with the definition.  Mirror of lib/dict_pass.ml's DLetGroup
-- run_decl arm.  (Without this, a `Num a => a -> a` group member's call site
-- supplies a leading dict the body never binds → the dict lands in the first user
-- param → arithmetic over a dict value panics `unknown op`.)
dictPassDecl names _ (DLetGroup pub binds) =
  DLetGroup pub (map (dictPassLetBind names) binds)
-- Phase 83/84 single-level + D3b-1: a parametric impl with `requires` gets one
-- leading `$dict_<method>_<slot>` param on each method (return- OR argument-
-- position) whose body actually reads an impl dict (so a terminal body like
-- `eq Nil Nil = True` would take none — but see implDictPassMethods: the param is
-- added UNIFORMLY across all clauses of a method when ANY clause uses the dict, so
-- a multi-clause method keeps one arity).  The routes resolveSite/resolveArgStamp
-- filled on the call-site EMethodAt's impl-dicts ref line up with these params.
dictPassDecl _ _ (d@(DImpl { reqs, methods, ... })) =
  DImpl { d | methods = implDictPassMethods (listLen reqs) methods }
-- Phase 69.x-e: a method with method-level constraints (foldMap's `Monoid m`) gets
-- one leading `$dict_<method>_<slot>` param per constraint on its DEFAULT body, so a
-- caller can supply the dictionary the body's `empty`/… reads (routed RDict by
-- inferDefaultMethod).  Mirror of lib/dict_pass.ml's DInterface arm.
dictPassDecl _ _ (d@(DInterface { methods, ... })) =
  DInterface { d | methods = map ifaceDictPassMethod methods }
dictPassDecl names ret (DAttrib attrs d) =
  DAttrib attrs (dictPassDecl names ret d)
dictPassDecl _ _ d = d

-- DLetGroup binding dict-pass: prepend the member's dict params to every clause.
-- `dictArityOf n` is 0 for an unconstrained member (no change), matching the
-- oracle's `if k = 0 then (n, clauses)` guard.  Gated on `names` (the constrained
-- set) so an unconstrained member with a coincidental arity entry is untouched.
dictPassLetBind : List String -> LetBind -> LetBind
dictPassLetBind names (LetBind n clauses)
  | contains n names =
    LetBind n (map (prependDictClause n (dictArityOf n)) clauses)
  | otherwise = LetBind n clauses

prependDictClause : String -> Int -> FunClause -> FunClause
prependDictClause n k (FunClause pats body) =
  FunClause (dictParams n k ++ pats) body

ifaceDictPassMethod : IfaceMethod -> IfaceMethod
ifaceDictPassMethod (IfaceMethod n ty (Some (MethodDefault pats body))) =
  ifaceDictPassDefault n ty pats body (methodDictArityOf n)
ifaceDictPassMethod m = m

ifaceDictPassDefault : String -> Ty -> List Pat -> Expr -> Int -> IfaceMethod
ifaceDictPassDefault n ty pats body k
  | k > 0 =
    IfaceMethod n ty (Some (MethodDefault (dictParams n k ++ pats) body))
  | otherwise = IfaceMethod n ty (Some (MethodDefault pats body))

methodDictArityOf : String -> Int
methodDictArityOf n =
  listLen (fromOption [] (lookupAssocSL2 n methodConstraintsRef.value))

-- D3b-1: add the leading `$dict_<method>_<slot>` params UNIFORMLY across all
-- clauses of a method.  An impl method is many ImplMethod entries (one per
-- clause), so a per-clause `usesImplDict` test would give clauses different
-- arities (`eq Nil Nil = True` uses no dict; `eq (Cons …) (Cons …) = … eq x y …`
-- does) and break coalescing.  Compute the set of method NAMES any of whose
-- clauses reads the dict, then prepend the params to every clause of those names.
-- No rpNames gate: usesImplDict already requires an in-body RDict route to one of
-- these params, which on the non-emit path no arg-position site ever has (its
-- occurrences stay bare EVar), so return-position goldens are unaffected.
-- TYPECHECK-AUDIT S2: each method gets, in oracle slot order, its METHOD-LEVEL
-- dict params (`dictParams n k`, k = methodDictArityOf n — e.g. `build`'s `Num e`)
-- FOLLOWED BY the impl-`requires` element-dict params (at slots k..k+nReq-1, only
-- when the body reads one), then the original pats.  Direct mirror of
-- lib/dict_pass.ml:99-119 (`dict_pats n k @ impl_pats @ pats`) and the
-- `method_off + slot` impl-dict naming in lib/typecheck.ml:3682-3690.  Eval applies
-- method dicts unconditionally first (eval.mdk), so dropping the leading method-level
-- params (the old `match reqs []=>d` early-out) mis-bound the dict into the first
-- value parameter.
implDictPassMethods : Int -> List ImplMethod -> List ImplMethod
implDictPassMethods nReq methods =
  let users = dedup (flatMap (clauseImplDictUser nReq) methods)
  map (prependImplDictIfUser nReq users) methods

clauseImplDictUser : Int -> ImplMethod -> List String
clauseImplDictUser nReq (ImplMethod n _ body)
  | usesImplDict n nReq body = [n]
  | otherwise = []

-- params = method-level dicts (slots 0..k-1) ++ impl-`requires` dicts (slots
-- k..k+nReq-1, only when this method's body consumes one) ++ original pats.  Skip
-- entirely only when there are neither (k = 0 and no impl-dict use), matching the
-- oracle's `if k = 0 && not uses_impl_dict then (n, pats, body)`.
prependImplDictIfUser : Int -> List String -> ImplMethod -> ImplMethod
prependImplDictIfUser nReq users (ImplMethod n pats body) =
  let k = methodDictArityOf n
  let implPats = if contains n users then dictParamsFrom n k nReq else []
  if k == 0 && isEmptyL implPats then
    ImplMethod n pats body
  else
    ImplMethod n (dictParams n k ++ implPats ++ pats) body

-- does [body] reference an in-body return-position method already routed RDict to
-- one of THIS method's would-be impl-dict params? (the gate that distinguishes a
-- body that consumes the element dict from a terminal one that doesn't).  Impl-dict
-- slots are offset by the method's own method-level arity (S2), so probe at k..k+nReq-1.
usesImplDict : String -> Int -> Expr -> Bool
usesImplDict mname nReq body =
  anyMember (bodyRDictNames body) (implDictNames mname nReq)

implDictNames : String -> Int -> List String
implDictNames mname nReq =
  map (dictParamName mname) (rangeFromCount (methodDictArityOf mname) nReq)

-- [start, start+1, .. start+count-1]
rangeFromCount : Int -> Int -> List Int
rangeFromCount start count
  | count <= 0 = []
  | otherwise = start :: rangeFromCount (start + 1) (count - 1)

-- the dict-param names every EMethodAt in [e] routes RDict to (post-resolveSites)
-- plus every EDictAt route-LIST that forwards RDict/RDictFwd to an impl param
-- (a `=>`-constrained helper call that threads the impl dict through, e.g.
-- `debug xs = "[\{debugListItems xs}]"` where `debugListItems` is an EDictAt).
bodyRDictNames : Expr -> List String
bodyRDictNames e = flatMap siteRDictName (collectMethodSites e)
  ++ flatMap siteRDictNamesL (collectDictSites e)

siteRDictName : Ref Route -> List String
siteRDictName r = match r.value
  RDict d => [d]
  RDictFwd d => [d]
  _ => []

siteRDictNamesL : Ref (List Route) -> List String
siteRDictNamesL r = flatMap routeRDictName r.value

routeRDictName : Route -> List String
routeRDictName (RDict d) = [d]
routeRDictName (RDictFwd d) = [d]
-- Native #54/#21 residual: an element-dict RKey route can NEST an RDict forwarding
-- the enclosing impl's `requires` dict (e.g. `RKey "$tuple" [RDict $dict_debug_0,
-- RDict $dict_debug_1]` for `debug (toList m)` in a `Debug (Map k v)` body).  The
-- gate that decides whether to PREPEND those impl-dict params (usesImplDict) must
-- see the nested name, else the route references a param the clause never declares
-- → emitter panics "unbound dict witness".  Recurse into the nested reqs.
routeRDictName (RKey _ reqs) = flatMap routeRDictName reqs
routeRDictName _ = []

-- every EMethodAt route ref reachable in [e] (a pure structural walk; reading a
-- ref's `.value` is done later by siteRDictName, not here)
collectMethodSites : Expr -> List (Ref Route)
collectMethodSites (EMethodAt _ r _ _) = [r]
collectMethodSites (ELoc _ e) = collectMethodSites e
collectMethodSites (EDoOrigin _ e) = collectMethodSites e
collectMethodSites (EApp f x) = collectMethodSites f ++ collectMethodSites x
collectMethodSites (ELam _ b) = collectMethodSites b
collectMethodSites (ELet _ _ _ e1 e2) = collectMethodSites e1
  ++ collectMethodSites e2
collectMethodSites (ELetGroup binds body) = flatMap letBindSites binds
  ++ collectMethodSites body
collectMethodSites (EMatch e arms) = collectMethodSites e
  ++ flatMap armSites arms
collectMethodSites (EIf c t e) = collectMethodSites c
  ++ collectMethodSites t
  ++ collectMethodSites e
collectMethodSites (EBinOp _ l r _) = collectMethodSites l
  ++ collectMethodSites r
collectMethodSites (EUnOp _ e _) = collectMethodSites e
collectMethodSites (EInfix _ l r) = collectMethodSites l ++ collectMethodSites r
collectMethodSites (EFieldAccess e _ _) = collectMethodSites e
collectMethodSites (ETuple es) = flatMap collectMethodSites es
collectMethodSites (EListLit es) = flatMap collectMethodSites es
collectMethodSites (EArrayLit es) = flatMap collectMethodSites es
collectMethodSites (ERangeList a b _) = collectMethodSites a
  ++ collectMethodSites b
collectMethodSites (ERangeArray a b _) = collectMethodSites a
  ++ collectMethodSites b
collectMethodSites (ESlice e a b _ _) = collectMethodSites e
  ++ collectMethodSites a
  ++ collectMethodSites b
collectMethodSites (EIndex e i _) = collectMethodSites e ++ collectMethodSites i
collectMethodSites (EAnnot e _) = collectMethodSites e
collectMethodSites (EBlock stmts) = flatMap doStmtSites stmts
collectMethodSites (ERecordCreate _ fs) = flatMap fieldAssignSites fs
collectMethodSites (ERecordUpdate e fs _) = collectMethodSites e
  ++ flatMap fieldAssignSites fs
collectMethodSites (EVariantUpdate _ e fs) = collectMethodSites e
  ++ flatMap fieldAssignSites fs
collectMethodSites _ = []

letBindSites : LetBind -> List (Ref Route)
letBindSites (LetBind _ clauses) = flatMap funClauseSites clauses

funClauseSites : FunClause -> List (Ref Route)
funClauseSites (FunClause _ body) = collectMethodSites body

armSites : Arm -> List (Ref Route)
armSites (Arm _ guards body) = flatMap guardSites guards
  ++ collectMethodSites body

guardSites : Guard -> List (Ref Route)
guardSites (GBool e) = collectMethodSites e
guardSites (GBind _ e) = collectMethodSites e

doStmtSites : DoStmt -> List (Ref Route)
doStmtSites (DoExpr e) = collectMethodSites e
doStmtSites (DoLet _ _ _ e) = collectMethodSites e
doStmtSites (DoBind _ e) = collectMethodSites e
doStmtSites (DoAssign _ e) = collectMethodSites e
doStmtSites (DoFieldAssign _ _ e) = collectMethodSites e

fieldAssignSites : FieldAssign -> List (Ref Route)
fieldAssignSites (FieldAssign _ e) = collectMethodSites e

-- mirror of collectMethodSites's structural walk, but collecting EDictAt's
-- route-LIST refs (`Ref (List Route)`) instead of EMethodAt's single route ref.
collectDictSites : Expr -> List (Ref (List Route))
collectDictSites (EDictAt _ rs) = [rs]
-- D3b-1: an EMethodAt arg-position site carries its element-dict routes in the
-- impl-/method-dicts route LISTS (not tagRef).  A nested `requires` impl whose
-- body dispatches a method on its own element tyvar routes RDict $dict_<m>_<slot>
-- here — scan both so implDictPassMethods' usesImplDict gate sees it and prepends
-- the matching param.  [] on the golden path (resolveArgStamp never runs).
collectDictSites (EMethodAt _ _ implR methR) = [implR, methR]
collectDictSites (ELoc _ e) = collectDictSites e
collectDictSites (EDoOrigin _ e) = collectDictSites e
collectDictSites (EApp f x) = collectDictSites f ++ collectDictSites x
collectDictSites (ELam _ b) = collectDictSites b
collectDictSites (ELet _ _ _ e1 e2) = collectDictSites e1 ++ collectDictSites e2
collectDictSites (ELetGroup binds body) = flatMap letBindDictSites binds
  ++ collectDictSites body
collectDictSites (EMatch e arms) = collectDictSites e
  ++ flatMap armDictSites arms
collectDictSites (EIf c t e) = collectDictSites c
  ++ collectDictSites t
  ++ collectDictSites e
collectDictSites (EBinOp _ l r _) = collectDictSites l ++ collectDictSites r
collectDictSites (EUnOp _ e _) = collectDictSites e
collectDictSites (EInfix _ l r) = collectDictSites l ++ collectDictSites r
collectDictSites (EFieldAccess e _ _) = collectDictSites e
collectDictSites (ETuple es) = flatMap collectDictSites es
collectDictSites (EListLit es) = flatMap collectDictSites es
collectDictSites (EArrayLit es) = flatMap collectDictSites es
collectDictSites (ERangeList a b _) = collectDictSites a ++ collectDictSites b
collectDictSites (ERangeArray a b _) = collectDictSites a ++ collectDictSites b
collectDictSites (ESlice e a b _ _) = collectDictSites e
  ++ collectDictSites a
  ++ collectDictSites b
collectDictSites (EIndex e i _) = collectDictSites e ++ collectDictSites i
collectDictSites (EAnnot e _) = collectDictSites e
collectDictSites (EBlock stmts) = flatMap doStmtDictSites stmts
collectDictSites (ERecordCreate _ fs) = flatMap fieldAssignDictSites fs
collectDictSites (ERecordUpdate e fs _) = collectDictSites e
  ++ flatMap fieldAssignDictSites fs
collectDictSites (EVariantUpdate _ e fs) = collectDictSites e
  ++ flatMap fieldAssignDictSites fs
collectDictSites _ = []

letBindDictSites : LetBind -> List (Ref (List Route))
letBindDictSites (LetBind _ clauses) = flatMap funClauseDictSites clauses

funClauseDictSites : FunClause -> List (Ref (List Route))
funClauseDictSites (FunClause _ body) = collectDictSites body

armDictSites : Arm -> List (Ref (List Route))
armDictSites (Arm _ guards body) = flatMap guardDictSites guards
  ++ collectDictSites body

guardDictSites : Guard -> List (Ref (List Route))
guardDictSites (GBool e) = collectDictSites e
guardDictSites (GBind _ e) = collectDictSites e

doStmtDictSites : DoStmt -> List (Ref (List Route))
doStmtDictSites (DoExpr e) = collectDictSites e
doStmtDictSites (DoLet _ _ _ e) = collectDictSites e
doStmtDictSites (DoBind _ e) = collectDictSites e
doStmtDictSites (DoAssign _ e) = collectDictSites e
doStmtDictSites (DoFieldAssign _ _ e) = collectDictSites e

fieldAssignDictSites : FieldAssign -> List (Ref (List Route))
fieldAssignDictSites (FieldAssign _ e) = collectDictSites e

dictArityOf : String -> Int
dictArityOf n =
  listLen (fromOption [] (lookupAssocSL2 n funConstraintsRef.value))

dictParams : String -> Int -> List Pat
dictParams n k = dictParamsGo n 0 k

dictParamsGo : String -> Int -> Int -> List Pat
dictParamsGo n slot k
  | slot >= k = []
  | otherwise = PVar (dictParamName n slot) :: dictParamsGo n (slot + 1) k

-- [count] dict params for [n] starting at slot [start]: $dict_n_start ..
-- $dict_n_(start+count-1).  Used for impl-`requires` element-dict params, which
-- follow the method's own method-level params (S2 offset = methodDictArityOf).
dictParamsFrom : String -> Int -> Int -> List Pat
dictParamsFrom n start count
  | count <= 0 = []
  | otherwise =
    PVar (dictParamName n start) :: dictParamsFrom n (start + 1) (count - 1)

dictParamName : String -> Int -> String
dictParamName fn slot = "$dict_\{fn}_\{intToString slot}"

-- head type constructor, normalizing at each level (the head may be a TVar
-- linked to a concrete type after unification — normalize follows only the top
-- link, so recurse through normalize)
headTyconMono : Mono -> Option String
headTyconMono t = match normalize t
  TApp a _ => headTyconMono a
  TCon n => Some n
  _ => None

-- Native Gap C: the arity-distinguished tuple dispatch tag (`__tuple2__`, …),
-- byte-identical to eval.mdk's `tupleHeadTag`.  Stamped as the RKey route tag at a
-- tuple method site so each arity routes to its own impl group / lifted define.
tupleHeadTagTc : Int -> String
tupleHeadTagTc n = "__tuple" ++ intToString n ++ "__"

-- An n-tuple TYPE is a saturated left-spine TApp over the synthetic nullary
-- constructor `TCon (tupleHeadTagTc n)` — the constructor NAME string IS the
-- existing `__tupleN__` dispatch tag, so tag/eval parity is automatic and no
-- `Mono.TTuple` constructor is needed.  (Surface `Ty.TyTuple` is unchanged.)
tupleMono : List Mono -> Mono
tupleMono ts = tupleSpineOf (TCon (tupleHeadTagTc (listLen ts))) ts

tupleSpineOf : Mono -> List Mono -> Mono
tupleSpineOf acc [] = acc
tupleSpineOf acc (t::rest) = tupleSpineOf (TApp acc t) rest

-- collect a left-spine `TApp` into (head, args-in-application-order),
-- normalizing at each level so a linked head resolves.
spineParts : Mono -> (Mono, List Mono)
spineParts t = match normalize t
  TApp a b => match spineParts a
    (h, args) => (h, args ++ [b])
  other => (other, [])

-- recognise a fully-saturated tuple spine (arity >= 2 — `()`/Unit stays
-- `TCon "Unit"`, never a tuple); return its element monos in order.
export tupleSpine : Mono -> Option (List Mono)
tupleSpine t = match spineParts t
  (TCon n, args) =>
    if listLen args >= 2 && n == tupleHeadTagTc (listLen args) then
      Some args
    else
      None
  _ => None

-- arity a `__tupleN__` tag string names (else None) — bounded probe so a bare
-- or PARTIAL tuple ctor never leaks the raw `__tupleN__` tag into a message.
tupleTagArity : String -> Option Int
tupleTagArity n = tupleTagArityGo n 2

tupleTagArityGo : String -> Int -> Option Int
tupleTagArityGo n k
  | k > 32 = None
  | tupleHeadTagTc k == n = Some k
  | otherwise = tupleTagArityGo n (k + 1)

commaStr : Int -> String
commaStr n = if n <= 0 then "" else "," ++ commaStr (n - 1)

-- render a bare/partial tuple constructor as the surface-less `(,)`/`(,,)` head
-- (only reached when a tuple spine is UNSATURATED, e.g. an arity-mismatch
-- message); a saturated spine renders `(e1, …)` via ppApp before reaching here.
ppConName : String -> String
ppConName n = match tupleTagArity n
  Some k => "(" ++ commaStr (k - 1) ++ ")"
  None => n

-- Two monos genuinely CANNOT unify because a tuple spine meets a differing
-- concrete head/arity — used only to pick the readable full-type mismatch
-- message.  A TVar-headed other side returns False (it can still bind).
tupleUnifyClash : Mono -> Mono -> Bool
tupleUnifyClash a b = match (tupleSpine a, tupleSpine b)
  (Some xs, Some ys) => listLen xs != listLen ys
  (Some _, None) => monoSpineHeadIsCon b
  (None, Some _) => monoSpineHeadIsCon a
  (None, None) => False

-- DRIVER-COLLAPSE Phase 5: scheme extraction for repl/lsp `:type`/hover + the
-- `=== TYPES ===` golden (checkToLines), the surviving replacement for the
-- deleted flat `checkProgram`.  implInferEnabled OFF + the seeded path, which
-- keeps the checkLetRecDecls / LetRecNonFunction guard checkModuleFull skips.
-- Callers pass the 1-module decl list (preludeDecls ++ user buffer) and read
-- schemes by name; no eval, so this is the typecheck-only sibling of the
-- 1-module path.
export checkProgramSchemes : List Decl -> List Decl -> List (String, Scheme)
checkProgramSchemes coreProg userProg =
  let _ = setRef implInferEnabled False
  checkProgramSeededSplit [] coreProg userProg

-- Like checkProgramSchemes but ALSO seeds runtime.mdk's externs (putStrLn,
-- readLine, …) into scope, so a buffer using them type-checks instead of leaving
-- the bindings that consume them unconstrained.  Mirrors the OCaml reference's
-- `check_program`, which seeds `Runtime.entries` into the initial env — the LSP
-- hover/completion/inlay handlers run this so externs resolve and a `let input =
-- readLine ()` hovers as `String`, not a free `a`.
export checkProgramSchemesWithRuntime : List Decl -> List Decl -> List Decl -> List (String, Scheme)
checkProgramSchemesWithRuntime runtimeDecls coreProg userProg =
  let _ = setRef implInferEnabled False
  checkProgramSeededSplit (externSchemes runtimeDecls) coreProg userProg

-- [seed] are extern schemes from runtime.mdk: in scope for lookup (so core.mdk's
-- use of putStrLn/etc. resolves) but NOT part of the output (mirrors the
-- reference seeding Runtime.entries into initial_env, which aren't returned).
checkProgramSeeded : List (String, Scheme) -> List Decl -> List (String, Scheme)
checkProgramSeeded seed prog = checkProgramSeededSplit seed [] prog

-- Same pass, but told WHERE THE PRELUDE ENDS.  Every driver that flattens the prelude
-- into the program it checks (`desugar coreP ++ desugared`) hands the two halves in
-- separately instead of pre-concatenating them, which is the only thing the flat path
-- was missing to make SHADOW-SEMANTICS S1 (shadow-hood is PER-MODULE, per-name) hold:
-- with the boundary known, a user standalone that shadows an interface-method name is a
-- shadow inside the USER's decls and NOT inside the prelude's.  See flatShadowScopingRef
-- for the bug this closes.  [coreProg] = [] ⇒ prelude-free program ⇒ scoping is inert and
-- this is byte-for-byte the old checkProgramSeeded (that is the multi-module discovery,
-- elaborateDict, and probe-entry path).
checkProgramSeededSplit : List (String, Scheme) -> List Decl -> List Decl -> List (String, Scheme)
checkProgramSeededSplit seed coreProg userProg =
  let prog = coreProg ++ userProg
  let _ = resetState ()
  -- seed the interface decls for super-closure (the flat path skips elaborateDict/
  -- elabModuleStamp which set this elsewhere); read-only during inference, so the
  -- signature-constraint check's superclass closure works single-file too.
  let _ = setRef superDeclsRef prog
  let _ = populateEffectDomains prog
  let _ = checkEffectParams prog
  let _ = checkLetRecDecls prog
  let dataEnv = registerAllData initialEnv prog
  let _ = rejectCyclicAliases ()
  let globalS = ifaceMethodSchemes prog ++ externSchemes prog
  let _ = registerMethodIfaceParamsAll prog
  let env1 = extendVars (extendVars dataEnv seed) globalS
  let defs = funDefs prog
  let sigs = sigsOf prog
  -- FLAT-PATH SHADOW FIX (facet 1): record interface-method names so processSCC
  -- keeps a method-shadowing USER fn out of the env it threads forward (so a later
  -- prelude binding like `neq x y = not (eq x y)` resolves `eq` to the METHOD, not
  -- the user's `eq`).  See methodShadowNamesRef.  Empty on the multi-module path.
  let methodNames = map fst (ifaceMethodSchemes prog)
  let _ = setRef methodShadowNamesRef methodNames
  -- DEFINER-shadow set (facet 2): a USER top-level funDef reusing an interface-method
  -- name (a single-file program with its own `orElse`) resolves in-scope to the user's
  -- def, so recordImplObligation must NOT raise a spurious `No impl of <Iface> for <T>`
  -- at its occurrences.  Mirrors checkModuleFullImpl exactly: the METHOD universe is the
  -- whole flattened [prog] (core's interfaces are visible everywhere), but the STANDALONE
  -- side — and the local-binder exclusion — is scoped to the module that defines it
  -- ([userProg]), so this is the USER module's shadow set and nobody else's.
  let userShadows = buildDefinerShadows prog userProg
  let _ = setRef definerShadowNamesRef userShadows
  -- FLAT-PATH SHADOW SCOPING (S1): arm the per-group/per-body toggle, but ONLY when a
  -- prelude was actually prepended.  A prelude-free program has no other module to leak
  -- into, so the refs stay at their resetState values and every consumer behaves as before.
  let _ = setRef flatShadowScopingRef (declsNonEmpty coreProg)
  let _ = setRef flatUserShadowNamesRef userShadows
  let _ = setRef flatCoreFnNamesRef (namesToSet (map fst (funDefs coreProg)) omEmpty)
  -- P0-19: stash the standalone signatures + the impl key table so
  -- inferDefinerShadowApp can enforce a definer-shadow standalone's declared domain on
  -- a no-impl / ungrounded receiver (single-file check AND single-file run/build, which
  -- both flow through here).  shadowKeyTableRef distinguishes dispatch (impl exists →
  -- leave permissive) from standalone (no impl → enforce domain).
  let _ = setRef definerShadowSigsRef sigs
  let _ = setRef shadowKeyTableRef (buildKeyTable prog)
  let topSchemes = processTopGroups env1 sigs defs (groupNames defs omEmpty)
  -- FLAT-PATH SHADOW FIX (cont.): when a USER top-level fn shares a name with an
  -- interface method (e.g. user `eq : List Int -> List Int -> Bool` vs core's
  -- `Eq.eq`), the prelude's OWN prop/default/impl bodies still reference that name
  -- as the METHOD (core.mdk:1089 `prop … = … gt x y …`).  The multi-module path
  -- checks core in ISOLATION, so its bodies always see the method scheme; the
  -- single-file FLAT path flattens core+user and would let the user's scheme shadow
  -- the method here, unifying the user's applied param type against the prop's
  -- element → spurious "List Int vs Int".  The oracle avoids this by method-MARKING
  -- (the prop's `gt` becomes EMethodRef); we lack that arm, so for the prelude-body
  -- passes we drop any user scheme whose name is an interface method, leaving the
  -- method scheme (in env1/globalS) visible — the isolation the multi-module path gives.
  let preludeBodyEnv = extendVars env1 (dropSchemesNamed methodNames topSchemes)
  -- FLAT-PATH SHADOW SCOPING (S1): the prelude's OWN impl/default/prop/test bodies are
  -- inferred with the user's shadow set OFF — the isolation checkModuleFullImpl gets for
  -- free by checking core as its own module.  [coreProg] is [] on every prelude-free path,
  -- so these four calls are no-ops there and the user pair walks the whole program, exactly
  -- as the single pre-split call did (prog = coreProg ++ userProg preserves decl order too).
  let _ = scopeShadowsCore ()
  let _ = inferImplBodiesIfEnabledIn preludeBodyEnv prog coreProg
  let _ = inferDefaultBodiesIfEnabled preludeBodyEnv coreProg
  let _ = inferPropBodies preludeBodyEnv coreProg
  let _ = inferTestBodies preludeBodyEnv coreProg
  let _ = scopeShadowsUser ()
  let _ = inferImplBodiesIfEnabledIn preludeBodyEnv prog userProg
  let _ = inferDefaultBodiesIfEnabled preludeBodyEnv userProg
  let _ = inferPropBodies preludeBodyEnv userProg
  let _ = inferTestBodies preludeBodyEnv userProg
  let _ = groundMultiParamObligations prog pendingImplObligations.value
  let _ = checkImplCompleteness prog prog   -- P0-17: impl missing a required method
  let _ = checkImplObligations prog pendingImplObligations.value
  let _ = checkCallObligations prog pendingCallObligations.value
  let _ = setNumlitFloats ()   -- PLAN.md #11: stamp Float-typed int literals
  let _ = setRef localSchemesOut (mapLocalSchemes localBindRefs.value)
  let _ = setRef seedSchemesOut seed
  globalS ++ topSchemes
-- D2: check top-level `let rec` bindings for non-function members before
-- type-checking the DFunDef groups (mirrors oracle's LetRecNonFunction guard,
-- lib/typecheck.ml:2596-2602, which fires in process_letrec_group for
-- is_letrec=true groups — i.e. those coming from DLetGroup).

-- Phase 83/84 single-level: AFTER top-level inference (so the scheme output is
-- unchanged), and ONLY on the elaborate/dict path, infer each parametric impl's
-- return-position method bodies, registering the requires' element dict so the
-- inner ref routes RDict and the call site routes RKey + impl dicts.

-- Phase 69.x-e: likewise infer each interface DEFAULT body that carries a
-- method-level constraint (foldMap's default), registering the constraint var so
-- the in-body return-position ref (`empty`) routes RDict to `$dict_<method>_<slot>`.

-- Phase 4.55 (mirror lib/typecheck.ml:4254-4262): type-check each prop body with
-- its declared params in scope.  This is what RESOLVES the EDictAt/EMethodAt route
-- refs the prepass marked inside a prop body — without it the routes stay empty,
-- and on the dict-passed eval path (DRIVER-COLLAPSE Phase 2 promotes the file's own
-- `=>`-constrained fns) the prop body would call a now-dict-passed `wf`/`fromList`
-- with no dict argument → under-application → `force` a partial closure → not VBool
-- → every prop "fails" (set's `fromList []` reported ill-formed).  The compiler
-- typechecker previously skipped props entirely (funDefs ignores DProp), so this
-- gap was latent until Phase 2's promotion exposed it.

-- Shape A (gap #44): ground a container literal's free result-element var THROUGH
-- the impl's method type, BEFORE the resolve* passes read the cells.

-- Error-path B4: now every method occurrence's dispatch type is fully resolved;
-- reject any whose concrete head type has no matching impl (mirrors the oracle's
-- check_method_usages, lib/typecheck.ml:3845).

-- Phase 4.55: infer each prop body with its declared params in scope, so the
-- prepass-marked EDictAt/EMethodAt route refs inside resolve (mirror of
-- lib/typecheck.ml:4254-4262).  Runs unconditionally (props are eval-only; the
-- emit/golden paths have no props), like the OCaml `infer prop_body; unify t_bool`.
-- A prop body is eval-only and is NOT dict-passed for operator dispatch: like the
-- OCaml oracle (which evals raw prop bodies against the marked env), its comparison
-- operators must stay PRIMITIVE EBinOps the eval builtin handles structurally, not
-- get stamped and rewritten to eq/lt method apps (whose dict route would then be
-- applied to a non-dict-passed comparison, panic: applied non-function).  So
-- snapshot pendingBinopSites around prop inference and restore it after: the routes
-- the prop body NEEDS (EDictAt for the file's promoted constrained fns, via
-- pendingDictApps/pendingSites) are still collected; only the binop-rewrite sites
-- the prop body would otherwise contribute are dropped.
inferPropBodies : TcEnv -> List Decl -> Unit
inferPropBodies env prog =
  let savedBinop = pendingBinopSites.value
  let savedUnop = pendingUnopSites.value
  let savedArith = pendingArithSites.value
  let _ = inferPropBodiesGo env prog
  let _ = setRef pendingArithSites savedArith
  let _ = setRef pendingUnopSites savedUnop
  setRef pendingBinopSites savedBinop

inferPropBodiesGo : TcEnv -> List Decl -> Unit
inferPropBodiesGo _ [] = ()
inferPropBodiesGo env ((DProp _ _ params body)::rest) =
  let local = extendPropParams env params
  let _ = infer local body
  inferPropBodiesGo env rest
inferPropBodiesGo env (_::rest) = inferPropBodiesGo env rest

-- Phase 127 (restored 2026-07-11): typecheck each `test "…" = body` body,
-- requiring it to have type `Expectation` (a nullary TCon, so a plain nominal
-- unify).  Unlike props, test bodies ARE dict-passed (their `expectEqual`/… calls
-- come from `import test`), so this runs on the normal inference path with binop
-- stamping enabled (no snapshot/restore).  Without this, `test "x" = 1 + "str"`
-- and `test "x" = 42` slipped through `check` with zero diagnostics.
inferTestBodies : TcEnv -> List Decl -> Unit
inferTestBodies _ [] = ()
inferTestBodies env ((DTest _ _ body)::rest) =
  let _ = unify (infer env body) (TCon "Expectation")
  inferTestBodies env rest
inferTestBodies env (_::rest) = inferTestBodies env rest

-- bind each prop param `x : ty` as a monomorphic scheme in the env (fresh tyvars
-- for any free type variable in ty; props are normally concrete, e.g. `List Int`).
extendPropParams : TcEnv -> List PropParam -> TcEnv
extendPropParams env [] = env
extendPropParams env ((PropParam x ty)::rest) =
  let scheme = monoScheme (fromAstType (freshTvMap (dedup (tyVarNames ty))) ty)
  extendPropParams (extendVar env x scheme) rest

-- gate: impl-body inference runs only when the elaborate/dict path turned it on.
-- FLAT-PATH SHADOW SCOPING: the impl decls to WALK [decls] are given separately from the
-- [allProg] universe the return-position/method tables are built from — so the flat path
-- can walk core's impls (shadows off) and the user's impls (shadows on) in two bracketed
-- calls without perturbing either table.
inferImplBodiesIfEnabledIn : TcEnv -> List Decl -> List Decl -> Unit
inferImplBodiesIfEnabledIn env allProg decls
  | implInferEnabled.value =
    inferImplBodies env allProg (returnPosMethodNames allProg) decls
  | otherwise = ()

-- C8b: default-body type-checking runs UNCONDITIONALLY (mirrors the oracle's
-- register_interface default-body loop at lib/typecheck.ml:3122-3160 which checks
-- ALL default bodies regardless of whether they carry method-level constraints).
-- Previously gated on implInferEnabled — that blocked unconstrained defaults
-- (Ord.lt/gt/min/max, Foldable.length/isEmpty, Filterable.filter, …) from being
-- type-checked on the plain-check path, so bad unconstrained default bodies were
-- silently accepted.  The constrained branch still registers dict slots (needed
-- for the emit/dict path); the unconstrained branch only type-checks — safe on
-- the plain-check path (activeDictVars mutation is harmless; reset by resetState).
inferDefaultBodiesIfEnabled : TcEnv -> List Decl -> Unit
inferDefaultBodiesIfEnabled env prog = inferDefaultBodies env prog

-- drop every (name, scheme) whose name is in [names] (the flat-path prelude-body
-- shadow fix: remove user schemes that shadow an interface-method name so the
-- method scheme stays visible to the prelude's own bodies).
dropSchemesNamed : List String -> List (String, Scheme) -> List (String, Scheme)
dropSchemesNamed names schemes =
  filterList (s => not (contains (fst s) names)) schemes

inferDefaultBodies : TcEnv -> List Decl -> Unit
inferDefaultBodies _ [] = ()
inferDefaultBodies env (d::rest) =
  let _ = inferOneIfaceDefaults env d
  inferDefaultBodies env rest

inferOneIfaceDefaults : TcEnv -> Decl -> Unit
inferOneIfaceDefaults env (DAttrib _ d) = inferOneIfaceDefaults env d
-- Mirror lib/typecheck.ml:3116-3126: type each default body against the
-- interface's OWN method scheme (built from [typarams]+[methods]), NOT
-- `lookupVar env mname`.  On the flat single-file check path a user top-level
-- funDef can SHADOW a method name (e.g. map.mdk's `isEmpty : Map k v -> Bool`
-- shadowing Foldable's `isEmpty`); looking the name up in env would instantiate
-- that Map-typed shadow and infer the default `isEmpty t = match toList t`
-- against it, grounding `toList`'s container var to `Map` → a spurious
-- `No impl of Foldable for Map` obligation.  The interface scheme is shadow-free.
-- Also extend env with these schemes so PEER-method refs in a default body
-- resolve to the interface methods (oracle's env_with_methods), not user shadows.
inferOneIfaceDefaults env (DInterface { typarams, methods, ... }) =
  let ifaceSchemes = methodSchemesPure methods
  inferDefaultMethods (extendVars env ifaceSchemes) typarams methods
inferOneIfaceDefaults _ _ = ()

inferDefaultMethods : TcEnv -> List String -> List IfaceMethod -> Unit
inferDefaultMethods _ _ [] = ()
inferDefaultMethods env typarams (m::rest) =
  let _ = inferDefaultMethod env typarams m
  inferDefaultMethods env typarams rest

-- C8b: type-check ALL interface default bodies, unconditionally.
--
-- Constrained arm (non-empty ids): method has method-level constraints (e.g. foldMap : Monoid m =>):
--   Instantiate scheme, register constraint vars → dict param names (for dict-passing
--   emit path), infer body, unify.  Mirrors lib/typecheck.ml:3132-3142 + 3143-3150.
--   CRITICAL: the constraint slot ids AND the default-body instantiation MUST come
--   from the SAME sigToSchemeTvs build of THIS method's type.  Reading the ids from
--   methodConstraintsRef (filled by a SEPARATE ifaceMethodSchemes build with its own
--   fresh tyvar ids) and instantiating an unrelated methodSchemesPure scheme gave ids
--   that did not appear in the instantiation subst → registerOneMethodDict's
--   `lookupAssocI id subst` returned None → activeDictVars got no entry → the in-body
--   `empty`/`++` routed RNone → eval's `++` saw a non-monoid acc and panicked
--   ('++' requires Semigroup).  The oracle (lib/typecheck.ml:3067-3093 + 3126-3142)
--   uses ONE method_schemes build for both, which is mirrored here.
--
-- Unconstrained arm (empty ids): method has no method-level constraints (e.g. Ord.lt):
--   Instantiate scheme, infer body, unify — same but no dict registration.
--
-- Double-error guard: snapshot typeErrors length before body inference; skip the
-- outer unify if new errors were added (matches the oracle's single-error raise).
inferDefaultMethod : TcEnv -> List String -> IfaceMethod -> Unit
inferDefaultMethod env typarams (IfaceMethod mname mty (Some (MethodDefault pats body))) =
  let st = sigToSchemeTvs mty
  let ids = methodConstraintSlotIds typarams mty (snd st)
  let _ = setRef currentFn ""
  let inst = instantiateTracked (fst st)
  let _ = inferDefaultMethodBody mname env (fst inst) pats body
  -- register AFTER body inference, so each constraint var's id in [snd inst] is
  -- its SURVIVING (normalized) union-find root — the same id the in-body return-
  -- position `empty`/`++` site normalizes to (activeDictVarOf reads that root).
  -- Registering BEFORE inference recorded the pre-unification id; the in-body
  -- site could become the surviving root instead, so activeDictVarOf missed it →
  -- RNone → `'++' requires Semigroup`.  Mirrors registerImplRequires's ordering.
  registerMethodDictSlots mname 0 ids (snd inst)
inferDefaultMethod _ _ _ = ()

-- Infer a default method body against [expectedTy], suppressing the outer
-- unify if the body itself already pushed a type error (prevents duplicates
-- that would arise when the accumulating compiler differs from the oracle's
-- raise-on-first behaviour: oracle's TypeMismatch from inside `infer` never
-- reaches the outer `unify`, whereas compiler would report both).
--
-- C8b Gap 2: the outer unify runs with `currentMethodMismatch = Some mname` so a
-- leaf TypeMismatch reports the oracle's single specialized line
-- `Method '<mname>': expected type <e> but got <a>` rather than a bare
-- `Type mismatch`.  When that unify pushed a mismatch, the body's own added
-- impl obligations are TRUNCATED back to the pre-body snapshot — the oracle's
-- `fail (MethodTypeMismatch …)` RAISES, so its later check_method_usages never
-- sees the body's `Num <wrong-type>` usage (e.g. `(5 : Bool)` ⇒ `Num Bool`);
-- dropping them here mirrors that single-error outcome instead of cascading a
-- spurious `No impl of Num for Bool`.
inferDefaultMethodBody : String -> TcEnv -> Mono -> List Pat -> Expr -> Unit
inferDefaultMethodBody mname env expectedTy pats body =
  let oblSnapshot = pendingImplObligations.value
  let oblSnapshotN = pendingImplObligationsN.value
  let errsBefore = listLen typeErrors.value
  let actualTy = inferClauses env [(pats, body)]
  let errsAfter = listLen typeErrors.value
  if errsAfter != errsBefore then ()
  else
    let errsPreUnify = listLen typeErrors.value
    let _ = setRef currentMethodMismatch (Some mname)
    let _ = unify expectedTy actualTy
    let _ = setRef currentMethodMismatch None
    -- mismatch reported ⇒ restore the pre-body obligation list (drop the body's
    -- own added `Num <wrong-type>` cascade, prepended at the front)
    if listLen typeErrors.value != errsPreUnify then restorePendingObls oblSnapshot oblSnapshotN else ()

-- Restore the obligation list (and its length counter) to a snapshot.
restorePendingObls : List (String, List String, Ty, Mono, Option Loc) -> Int -> Unit
restorePendingObls obls n =
  let _ = setRef pendingImplObligations obls
  setRef pendingImplObligationsN n

-- ── Error-path B4: missing-impl dispatch-obligation check ──────────────────
-- Mirror lib/typecheck.ml's check_method_usages (the `No impl of … for …` reject,
-- :3845).  For each recorded interface-method occurrence, recover the types the
-- interface params resolved to at this site (dispatchMonosOf), and — ONLY when
-- they are all CONCRETE (a resolved head tycon, no remaining polymorphic var, so
-- a constrained-generic `Ord a =>` site whose receiver is still `a` is correctly
-- deferred to the caller) — verify the program declares a matching impl.  None →
-- `No impl of <iface> for <args>`.  An impl block (even one defaulting every
-- method to its interface default body) creates a head entry, so a default-method
-- call on a type WITH an impl is satisfied; a default-method call on a type with
-- NO impl is rejected — both matching the oracle.
checkImplObligations : List Decl -> List (String, List String, Ty, Mono, Option Loc) -> Unit
checkImplObligations prog obligations =
  checkImplObligationsGo (implDeclsWithReqs prog) (implHeadsOf prog) obligations

-- #11 soundness (native obligation hole): check each constrained-fn CALL site's
-- instantiated obligation.  When `f : C a => …` is applied (`g = f "hello"`),
-- inferDictAtFound recorded (iface, the instantiated constraint mono) here.  After
-- inference the mono is ground: a CONCRETE-head mono (`String`) with no matching impl
-- is an ERROR; a still-polymorphic head (`a`, the obligation propagated to a further-
-- out caller — `id x = x; y = id 5`) is DEFERRED.  Exactly the accept/reject decision
-- of checkOneImplObligation's tail, and the mirror of lib/typecheck.ml's
-- check_constraint_obligations (which checks fun_constraints instantiated at the call).
checkCallObligations : List Decl -> List (String, Mono, Option Loc) -> Unit
checkCallObligations prog obligations =
  checkCallObligationsGo
    (implDeclsWithReqs prog)
    (implHeadsOf prog)
    []
    obligations

-- [seen] dedups by (iface, concrete-head-tycon): the SAME unsatisfiable obligation can
-- be recorded by more than one path (a use marked both EVar and, on the emit path,
-- EDictAt) or by repeated call sites, but the oracle raises ONE error per missing impl.
checkCallObligationsGo : List (String, List Ty, List Require) -> List (String, List Ty) -> List String -> List (String, Mono, Option Loc) -> Unit
checkCallObligationsGo _ _ _ [] = ()
checkCallObligationsGo ireqs heads seen ((iface, occ, loc)::rest) =
  let key = "\{iface}|\{fromOption "" (headTyconMono occ)}"
  if contains key seen then checkCallObligationsGo ireqs heads seen rest
  else
    let _ = checkOneCallObligation ireqs heads iface occ loc
    checkCallObligationsGo ireqs heads (key::seen) rest

checkOneCallObligation : List (String, List Ty, List Require) -> List (String, List Ty) -> String -> Mono -> Option Loc -> Unit
checkOneCallObligation ireqs heads iface occ loc =
  let args = [normalize occ]
  if iface == "Num" && anyListM numUnimplementableHead args then
    pushNoImplError iface loc args
  -- A function-typed constraint obligation is fully ground yet has no impl — report
  -- `No impl of <iface> for <a -> b>` (not the emit path's misleading "Ambiguous").
  else if anyListM monoIsFunction args && not (implMatchesReceiver heads iface (normalize occ)) then
    pushNoImplError iface loc args
  else if not (allConcreteHeads args) then
    checkUndeterminedObligation heads iface occ loc
  else if implMatchesReceiver heads iface (normalize occ) then
    -- Recurse into a matched CONDITIONAL instance's `requires` (`impl Display (a, b)
    -- requires Display a, Display b`) so an unsatisfied element constraint surfaces
    -- (`main = (Red, 5)` → `No impl of Display for Color`) instead of the head-only
    -- match silently accepting (→ null element dict → SIGSEGV at runtime).
    checkNestedReqs ireqs heads iface args loc
  else
    pushNoImplError iface loc args

-- WS-1c: a constrained call whose constraint var stays UNDETERMINED (pinned by
-- neither arg nor result, `roundtrip 14` where `roundtrip : Sub a => Int -> Int`).
-- If the var is a FORWARDED enclosing-fn dict (activeDictVarOf Some), it's resolved
-- by dict-passing — fine.  Otherwise it is genuinely free, and the route must pick
-- an impl with no type to guide it: ONE impl of [iface] → sole-impl default (no
-- error; routeUndeterminedTop stamps it concretely); TWO or more → genuinely
-- ambiguous → AmbiguousImpl (the deliberate divergence from the oracle's silent
-- first-wins).  Skip "Num" (its literal defaulting handles ambiguity) and ifaces
-- with no user impls (zero → existing no-impl path).  This runs on BOTH the check
-- path (checkModuleFullImpl) and the emit/eval path, so `check` rejects too.
checkUndeterminedObligation : List (String, List Ty) -> String -> Mono -> Option Loc -> Unit
checkUndeterminedObligation heads iface occ loc
  | iface == "Num" = ()
  | isSome (activeDictVarOf occ) = ()
  | anyIn (monoUnboundIds occ) poisonedVars.value = ()  -- Chunk A: primary mismatch already explained this var
  | implCountForIface heads iface >= 2 =
    pushTypeErrorOnceAt "T-AMBIGUOUS-INSTANCE" loc (ambiguousImplMsg iface)
  | otherwise = ()

-- the number of DISTINCT-head impls of [iface] in [heads] (one (iface, tys) per
-- impl).  Dedups by head-tycon so a prelude impl imported twice doesn't inflate.
implCountForIface : List (String, List Ty) -> String -> Int
implCountForIface heads iface =
  listLen (dedupStr (implHeadTagsFromHeads heads iface))

implHeadTagsFromHeads : List (String, List Ty) -> String -> List String
implHeadTagsFromHeads [] _ = []
implHeadTagsFromHeads ((iface2, tys)::rest) iface
  | iface2 == iface = match tys
    headTy::_ => match headTyconTy headTy
      Some tag => tag :: implHeadTagsFromHeads rest iface
      None => implHeadTagsFromHeads rest iface
    [] => implHeadTagsFromHeads rest iface
  | otherwise = implHeadTagsFromHeads rest iface

-- PLAN.md #11: after HM + defaulting every source integer literal's type var is
-- ground (or a genuine `Num a` survivor).  Decide each literal's runtime rep
-- (3-way, mirror of lib/typecheck.ml's set_numlit_floats):
--   • ground Float ⇒ stamp the float cell + CLEAR the fromInt route (dref RNone) ⇒
--     dictPass emits `ELit (LFloat f)` (eval is value-tagged; eval_arith rejects
--     mixed int/float tags, so a Float literal must carry a real float).
--   • ground Int (incl. via ambiguous→Int defaulting) ⇒ clear both cells ⇒
--     `ELit (LInt n)`, no dict dispatch.
--   • NOT a primitive head (a still-polymorphic `Num a` — the soundness case, `1`
--     in `inc x = x + 1` — or an exotic user numeric type) ⇒ leave [dref]'s
--     resolveSites-stamped route in place ⇒ dictPass emits
--     `EApp (EMethodAt "fromInt" …) (ELit (LInt n))` so the literal dispatches
--     through the runtime Num dict (Int→identity, Float→intToFloat).  A dref left
--     RNone (route never filled, e.g. unreachable position) falls to Int below.
-- Reads numlitRefs (populated by inferNumLit during THIS run/module's inference).
setNumlitFloats : Unit -> Unit
setNumlitFloats _ = setNumlitFloatsGo numlitRefs.value

setNumlitFloatsGo : List (Mono, Ref (Option Float), Int, Ref Route) -> Unit
setNumlitFloatsGo [] = ()
setNumlitFloatsGo ((var, fref, n, dref)::rest) =
  let _ = match normalize var
    TCon "Float" =>
      let _ = setRef fref (Some (intToFloat n))
      setRef dref RNone
    TCon "Int" => setRef dref RNone
    _ => ()
  setNumlitFloatsGo rest

-- ── Multi-param-interface element grounding (Shape A / gap #44) ─────────────
-- A container LITERAL (`Set { 3,1,2 }` / `Map { 1 => "a" }`) desugars to a
-- return-position `fromEntries [..] :~ Set _a`.  The head-pin fixes the RESULT to
-- `Set _a`, and the list arg grounds the interface's ELEMENT param `e` (= Int),
-- but nothing ties the result's element var `_a` to `e` — HM does not propagate the
-- impl's `FromEntries (Set a) a` variable-sharing.  So `_a` stays free, and BOTH the
-- return-position `requires Ord a` route AND the enclosing `display`/`debug`'s
-- arg-position element dict drop their dictionaries (null dict → SIGSEGV on the build
-- path; eval recovers via runtime arg-tag fallback, which is why `medaka run` worked).
-- Fix: for each multi-param-interface method occurrence whose dispatch type heads a
-- UNIQUE impl, instantiate that impl's method type (interface typarams ↦ the impl's
-- own type args, freshened) and unify it with the occurrence mono.  This grounds `_a`
-- := Int THROUGH THE SHARED CELL, so every downstream site reading that cell (the
-- `display` arg-stamp) and the return-position route both see `Set Int`.  Runs after
-- inference, before the resolve* passes read the cells.  Single-param interfaces and
-- already-ground occurrences are no-ops.  Mirrors the intent of the oracle's
-- impl_head_subst keying off the FULL concrete_args (the interface's param_vars).
groundMultiParamObligations : List Decl -> List (String, List String, Ty, Mono, Option Loc) -> Unit
groundMultiParamObligations _ [] = ()
groundMultiParamObligations prog ((iface, typarams, mty, occ, _)::rest) =
  let _ = groundOneObligation prog iface typarams mty occ
  groundMultiParamObligations prog rest

groundOneObligation : List Decl -> String -> List String -> Ty -> Mono -> Unit
groundOneObligation prog iface typarams mty occ
  | listLen typarams <= 1 = ()
  | otherwise = match dispatchMonosOf typarams mty occ
    [] => ()
    dispMono::_ => match headTyconMono dispMono
      None => ()
      Some tag => match uniqueImplTysFor prog iface tag
        None => ()
        Some implTys =>
          let baseMap = zipL typarams implTys
          let implMethodTy = substTyVars baseMap mty
          let inst = fst (astTypeFreshTbl implMethodTy)
          unify occ inst
-- build impl method type: interface typaram ↦ impl ty, then freshen the
-- impl's own vars, then unify with the occurrence.

-- the type args of the UNIQUE impl of [iface] whose head tycon is [tag]; None when
-- absent or ambiguous (more than one), so an over-determined case is left untouched.
uniqueImplTysFor : List Decl -> String -> String -> Option (List Ty)
uniqueImplTysFor prog iface tag = match filterImplTysFor prog iface tag
  [tys] => Some tys
  _ => None

filterImplTysFor : List Decl -> String -> String -> List (List Ty)
filterImplTysFor prog iface tag = flatMap (implTysIfMatch iface tag) prog

implTysIfMatch : String -> String -> Decl -> List (List Ty)
implTysIfMatch iface tag (DAttrib _ d) = implTysIfMatch iface tag d
implTysIfMatch iface tag (DImpl { iface = ifn, tys, ... })
  | ifn == iface = match tys
    headTy::_ => match headTyconTy headTy
      Some t => if t == tag then [tys] else []
      None => []
    [] => []
  | otherwise = []
implTysIfMatch _ _ _ = []

-- substitute interface-typaram NAMES → impl type PATTERNS inside a declared Ty.
substTyVars : List (String, Ty) -> Ty -> Ty
substTyVars sub (TyVar n) = fromOption (TyVar n) (lookupAssoc n sub)
substTyVars _ (TyCon n _) = TyCon n None
substTyVars sub (TyApp a b) = TyApp (substTyVars sub a) (substTyVars sub b)
substTyVars sub (TyFun a b) = TyFun (substTyVars sub a) (substTyVars sub b)
substTyVars sub (TyTuple ts) = TyTuple (map (substTyVars sub) ts)
substTyVars sub (TyEffect es eff t) = TyEffect es eff (substTyVars sub t)
substTyVars sub (TyConstrained cs t) = TyConstrained cs (substTyVars sub t)

checkImplObligationsGo : List (String, List Ty, List Require) -> List (String, List Ty) -> List (String, List String, Ty, Mono, Option Loc) -> Unit
checkImplObligationsGo _ _ [] = ()
checkImplObligationsGo ireqs heads ((iface, typarams, mty, occ, loc)::rest) =
  let _ = checkOneImplObligation ireqs heads iface typarams mty occ loc
  checkImplObligationsGo ireqs heads rest

checkOneImplObligation : List (String, List Ty, List Require) -> List (String, List Ty) -> String -> List String -> Ty -> Mono -> Option Loc -> Unit
checkOneImplObligation ireqs heads iface typarams mty occ loc =
  let args = dispatchMonosOf typarams mty occ
  -- PLAN.md #11 soundness: under Num-polymorphic literals a literal's var can unify
  -- with a *function* type (`5 1` ⇒ the `5` var becomes `Int -> b`) or be forced
  -- into an abstract HKT position (`do x <- 42` ⇒ `Num (m a)` with an unbound head
  -- `m`).  Pre-#11 these failed at unification (the literal was concretely Int); now
  -- the obligation is non-concrete and would be deferred-then-DROPPED → a silent
  -- accept.  A function / unbound-headed application can never have a `Num` impl, so
  -- REJECT here even though inner vars are still free, restoring the structural error.
  -- Mirror of lib/typecheck.ml's check_method_usages Num guards.
  --
  -- No-prelude (`Num` unregistered): a numeric literal still records a Num obligation
  -- (inferNumLitBare) so value-level defaulting can ground it to Int, but the bare-HM
  -- oracle imposes NO `impl Num` constraint — so SKIP the reject here (there is no
  -- `impl Num Int` to match in the prelude-free program).  This keeps the no-prelude
  -- `typecheck_main`/tc_probe oracle parity: a grounded `Num Int` literal types Int
  -- without a spurious `No impl of Num for Int`.  The unimplementable-head reject
  -- (function/unbound `m`) stays even no-prelude — it is a structural unification
  -- error, not a missing-impl one.
  if iface == "Num" && anyListM numUnimplementableHead args then pushNoImplError iface loc args else if iface == "Eq" && anyListM eqUnimplementableHead args then pushNoImplError iface loc args else if iface == "Ord" && anyListM ordUnimplementableHead args then pushNoImplError iface loc args else if iface == "Num" && not (ifaceRegistered "Num") then () else if isEmptyL args then () else if anyListM monoIsFunction args && not (implMatches heads iface args) then pushNoImplError iface loc args else if not (allConcreteHeads args) then () else if implMatches heads iface args then checkNestedReqs ireqs heads iface args loc else reportNumOrNoImpl iface args loc

-- A function-typed dispatch mono is fully GROUND — its head is `->`, structurally
-- un-implementable for an ordinary interface (no `impl Display (a -> b)` exists).
-- So a function-typed obligation with no matching impl is a genuine `No impl of
-- <iface> for <a -> b>` (bug: `main = f` where `f : Int -> Int` used to fall
-- through to the emit path's route resolution and mis-report "Ambiguous instance"
-- — but a monomorphic function type is not ambiguous, it simply has no impl).
-- Reserved for the un-matched case so a real `impl Display (a -> b)` would satisfy.
monoIsFunction : Mono -> Bool
monoIsFunction m = match normalize m
  TFun _ _ _ => True
  _ => False

-- After the impl head for (iface, args) matched, a CONDITIONAL instance's
-- `requires` constraints must ALSO be satisfied (`impl Display (a, b) requires
-- Display a, Display b`).  Recover the impl's typaram bindings from the head match
-- and check each substituted requirement recursively — so `main = (Red, 5)` (Red
-- has no Display) surfaces `No impl of Display for Color` at the deepest failing
-- leaf, exactly like the bare `main = Red`, instead of the head-only match silently
-- accepting the unsatisfiable element constraint (→ null element dict → SIGSEGV).
-- A satisfied requirement (`Display Int`, `Display String`) recurses into ITS own
-- (empty) requires and accepts, so `(5, "hi")` / `[1,2,3]` still build.
checkNestedReqs : List (String, List Ty, List Require) -> List (String, List Ty) -> String -> List Mono -> Option Loc -> Unit
checkNestedReqs ireqs heads iface args loc =
  checkReqObligations ireqs heads loc (reqObligationsFor ireqs iface args)

-- Impl decls paired with their `requires` (implHeadsOf drops reqs; this keeps them).
implDeclsWithReqs : List Decl -> List (String, List Ty, List Require)
implDeclsWithReqs prog = flatMap implDeclWithReqs prog

implDeclWithReqs : Decl -> List (String, List Ty, List Require)
implDeclWithReqs (DAttrib _ d) = implDeclWithReqs d
implDeclWithReqs (DImpl { iface, tys, reqs, ... }) = [(iface, tys, reqs)]
implDeclWithReqs _ = []

-- The substituted requirement obligations of the impl of [iface] whose head
-- matches [args]: bind the impl's typaram vars from the head match, then apply that
-- binding to each `Require`'s type args.  No matching impl / no reqs → [].
-- PERF: takes the ALREADY-COMPUTED impl-reqs table, not `prog`.  It used to take
-- `prog` and call `implDeclsWithReqs` itself — a flatMap over every decl in the
-- program, re-run once per obligation.  With O(N) obligations over an O(N)-decl
-- program that was O(N²) time AND allocation, and it dominated the typecheck stage
-- on a large file.  The table is now hoisted to the checkImplObligations /
-- checkCallObligations entry points and threaded, exactly like `heads`.
reqObligationsFor : List (String, List Ty, List Require) -> String -> List Mono -> List (String, List Mono)
reqObligationsFor ireqs iface args = match findMatchingImplReqs ireqs iface args
  None => []
  Some (subst, reqs) => map (reqToObligation subst) reqs

reqToObligation : List (String, Mono) -> Require -> (String, List Mono)
reqToObligation subst (Require ifaceR tysR) =
  (ifaceR, map (reqTyToMono subst) tysR)

findMatchingImplReqs : List (String, List Ty, List Require) -> String -> List Mono -> Option (List (String, Mono), List Require)
findMatchingImplReqs [] _ _ = None
findMatchingImplReqs ((iface2, tys, reqs)::rest) iface args
  | iface2 == iface = match implHeadSubst tys args
    Some sub => Some (sub, reqs)
    None => findMatchingImplReqs rest iface args
  | otherwise = findMatchingImplReqs rest iface args

-- Convert a `Require`'s declared type arg to a mono under the head-match subst.
-- Impl-typaram vars (the common case, `Display a`) resolve to their bound mono; an
-- unbound name gets a fresh var (defers, never a spurious concrete head).
reqTyToMono : List (String, Mono) -> Ty -> Mono
reqTyToMono sub (TyVar n) = fromOption (freshVar ()) (lookupAssoc n sub)
reqTyToMono _ (TyCon n _) = TCon n
reqTyToMono sub (TyApp a b) = TApp (reqTyToMono sub a) (reqTyToMono sub b)
reqTyToMono sub (TyFun a b) =
  TFun (reqTyToMono sub a) (openRow ()) (reqTyToMono sub b)
reqTyToMono sub (TyTuple ts) =
  tupleSpineOf (TCon (tupleHeadTagTc (listLen ts))) (map (reqTyToMono sub) ts)
reqTyToMono sub (TyEffect _ _ t) = reqTyToMono sub t
reqTyToMono sub (TyConstrained _ t) = reqTyToMono sub t

-- Check each substituted requirement with the SAME accept/reject logic as a
-- top-level obligation, recursing into a satisfied conditional impl's own reqs.
checkReqObligations : List (String, List Ty, List Require) -> List (String, List Ty) -> Option Loc -> List (String, List Mono) -> Unit
checkReqObligations _ _ _ [] = ()
checkReqObligations ireqs heads loc ((ifaceR, monoArgs)::rest) =
  let _ = checkReqOne ireqs heads ifaceR monoArgs loc
  checkReqObligations ireqs heads loc rest

-- A function-typed requirement arg is fully GROUND yet structurally un-Ord/Eq/etc
-- (no `impl Ord (a -> b)` exists), so it must REJECT — but its head has no tycon,
-- so `allConcreteHeads` reads it as non-concrete.  Order the function-typed reject
-- BEFORE the concreteness defer (mirroring checkOneCallObligation): otherwise a
-- `requires Ord k` with k = (Int -> Int) — e.g. `Map { f => 1 }` selecting
-- `FromEntries (Map k v) (k, v) requires Ord k` — would DEFER into a silent accept,
-- and `check` would pass a program `run` rejects at runtime (P0-18).
checkReqOne : List (String, List Ty, List Require) -> List (String, List Ty) -> String -> List Mono -> Option Loc -> Unit
checkReqOne ireqs heads iface args loc
  | anyListM monoIsFunction args && not (implMatches heads iface args) =
    pushNoImplError iface loc args
  | not (allConcreteHeads args) = ()
  | implMatches heads iface args = checkNestedReqs ireqs heads iface args loc
  | otherwise = pushNoImplError iface loc args

-- a mono no `Ord` impl can ever match: a function type (`<` on functions).  Like
-- Eq (and unlike Num) an unbound spine head DEFERS — a downstream `Ord a =>`
-- constraint resolves it — so only functions are structurally un-Ord.
ordUnimplementableHead : Mono -> Bool
ordUnimplementableHead m = match normalize m
  TFun _ _ _ => True
  _ => False

-- a mono no `Eq` impl can ever match: a function type (`==` on functions).  Unlike
-- Num we do NOT reject an unbound spine head (`m a`) — for Eq that is a genuinely
-- polymorphic operand that a downstream `Eq a =>` constraint resolves, so it must
-- DEFER (allConcreteHeads), not reject.  Only functions are structurally un-Eq.
eqUnimplementableHead : Mono -> Bool
eqUnimplementableHead m = match normalize m
  TFun _ _ _ => True
  _ => False

-- a mono no `Num` impl can ever match: a function type, or an application whose
-- spine head is still an unbound tyvar (a literal forced into `m a` monad position)
numUnimplementableHead : Mono -> Bool
numUnimplementableHead m = match normalize m
  TFun _ _ _ => True
  TApp a b => unboundSpineHead (spineHeadMono (TApp a b))
  _ => False

-- True iff [m] normalizes to an unbound tyvar (the spine head of `m a`)
unboundSpineHead : Mono -> Bool
unboundSpineHead m = match normalize m
  TVar _ => True
  _ => False

spineHeadMono : Mono -> Mono
spineHeadMono t = match normalize t
  TApp f _ => spineHeadMono f
  other => other

noImplFoundMsg : String -> List Mono -> String
noImplFoundMsg iface args = "No impl of \{iface} for \{ppMonosShared args}"

-- Actionable-fix hint (F dimension) for a `No impl of <iface> for <ty>` reject:
-- only when [args] is a single user-declared data type (a `dataParamKindsRef`
-- hit) does "add deriving" / "write an impl" read as concrete, applicable
-- advice — a builtin (String/Int/Bool/…) can't take `deriving`, and a function
-- type is structurally un-implementable, so both stay hint-free (unchanged
-- message) rather than print misleading advice.
noImplHint : String -> List Mono -> Option String
noImplHint iface [arg] = match headTyconMono arg
  Some n =>
    map (_ => noImplAdvice iface n) (lookupAssoc n dataParamKindsRef.value)
  None => None
noImplHint _ _ = None

-- Roadmap #18a: only a DERIVABLE interface may be suggested via `deriving`.  A
-- `deriving <iface>` for anything outside that set is silently DROPPED by desugar's
-- `deriveImpls` (its `deriveForData`/`deriveForNewtype` return None), so the old
-- unconditional "add 'deriving X'" sent the user down a dead end for every other
-- interface — including the `Semigroup` reject `a ++ b` now raises, and the
-- pre-existing user-interface case (`No impl of Printable for Foo`).  For those the
-- only real fix is to write the impl, so that is all we advise.
noImplAdvice : String -> String -> String
noImplAdvice iface n
  | derivableIface iface = "add 'deriving \{iface}' to the '\{n}' type, or write an 'impl \{iface} \{n}'."
  | otherwise = "write an 'impl \{iface} \{n}'."

-- The interfaces desugar.mdk can actually synthesize an impl for (deriveForData /
-- deriveForNewtype).  `Generic` is data-only; the other four cover both.
derivableIface : String -> Bool
derivableIface iface =
  contains iface ["Eq", "Ord", "Debug", "Display", "Generic"]

-- Append the hint (when applicable) to the plain `noImplFoundMsg`, mirroring
-- the did-you-mean append convention (base message ++ " — " ++ hint).
noImplFoundMsgHinted : String -> List Mono -> (String, Option String)
noImplFoundMsgHinted iface args =
  let base = noImplFoundMsg iface args
  match noImplHint iface args
    Some hint => ("\{base}; \{hint}", Some hint)
    None => (base, None)

-- Push a `No impl of …` type error, appending + recording the actionable-fix
-- hint (via `pushTypeErrorHelpFixAt`) when one applies; otherwise behaves
-- exactly like the previous plain `pushTypeErrorOnceAt "T-NO-IMPL" …` call.
pushNoImplError : String -> Option Loc -> List Mono -> Unit
pushNoImplError iface loc args = match firstTupleCallHint args
  -- P0-16: the un-implementable type IS a tuple-call residual (e.g. `println
  -- (add(1, 2))` → `No impl of Display for ((Int, Int) -> (Int, Int))`) — append
  -- the "call with spaces, not parentheses" hint + machine fix.
  Some (help, fix) =>
    pushTypeErrorHelpFixAt "T-NO-IMPL" loc "\{noImplFoundMsg iface args} — \{help}" help fix
  None =>
    let (msg, mhint) = noImplFoundMsgHinted iface args
    match mhint
      Some hint => pushTypeErrorHelpFixAt "T-NO-IMPL" loc msg hint None
      None => pushTypeErrorOnceAt "T-NO-IMPL" loc msg

-- Chunk D (Num mis-framing reframe): at the final no-impl branch, a `Num`
-- obligation forced to a fully-ground concrete non-Num head (`args` already passed
-- allConcreteHeads + failed implMatches) is reframed to a structural type mismatch
-- WHEN it traces to a bare numeric LITERAL (`numlitReframeLoc`: recorded at this
-- loc, and NOT an arithmetic operand).  An operator-sourced `Num` failure
-- (`x + 1`, `1 + x`) keeps `No impl of Num for T` — the `+` is the real culprit.
reportNumOrNoImpl : String -> List Mono -> Option Loc -> Unit
reportNumOrNoImpl iface args loc
  | iface == "Num" && numlitReframeLoc loc =
    let hint = numlitMismatchHint loc args
    pushTypeErrorHelpFixAt
      "T-TYPE-MISMATCH"
      loc
      (numlitMismatchMsg loc args ++ hint)
      hint
      None
  | otherwise = pushNoImplError iface loc args

-- True iff [loc] is a literal-sourced Num obligation eligible for reframe: some
-- literal was recorded at [loc] and that loc was NOT operator-tainted.
numlitReframeLoc : Option Loc -> Bool
numlitReframeLoc (Some l) = anyList (p => locEq (snd p) l) numlitVarLocs.value
  && not (anyList (ol => locEq ol l) numlitOpLocs.value)
numlitReframeLoc None = False

-- site-specific reframe wording (if / list / cons) when the context is known, else
-- a bare literal-vs-type mismatch.  `Int` is the numeric default the literal takes.
numlitMismatchMsg : Option Loc -> List Mono -> String
numlitMismatchMsg loc args = match numlitCtxKind loc
  Some "if" =>
    "'if' branches have different types: Int vs \{ppMonosShared args}"
  Some "list" =>
    "List elements have different types: Int vs \{ppMonosShared args}"
  Some "cons" => "Cons (::) type mismatch: head is Int but the list holds \{ppMonosShared args}"
  _ => "Type mismatch: Int literal vs \{ppMonosShared args}"

-- F-dimension actionable-fix hint appended to `numlitMismatchMsg` (2026-07-04):
-- mirrors its per-context wording, reusing the SAME two type strings the
-- message already interpolates (never recomputed).  No hint for the
-- context-less fallback (`_`) — there's no branch/element/head to name.
numlitMismatchHint : Option Loc -> List Mono -> String
numlitMismatchHint loc args = match numlitCtxKind loc
  Some "if" => ". Both branches must have the same type; change the else branch to Int, or the then branch to \{ppMonosShared args}."
  Some "list" => ". All elements must have the same type; convert the \{ppMonosShared args} element, or make the list hold \{ppMonosShared args}."
  Some "cons" => ". The head's type must match the list's elements; change the head to \{ppMonosShared args}, or use a list of Int."
  _ => ""

numlitCtxKind : Option Loc -> Option String
numlitCtxKind (Some l) = lookupCtxKind l numlitCtxTags.value
numlitCtxKind None = None

lookupCtxKind : Loc -> List (Loc, String) -> Option String
lookupCtxKind _ [] = None
lookupCtxKind l ((l2, k)::rest) =
  if locEq l l2 then
    Some k
  else
    lookupCtxKind l rest

locEq : Loc -> Loc -> Bool
locEq (Loc f1 a1 b1 c1 d1) (Loc f2 a2 b2 c2 d2) = f1 == f2
  && a1 == a2
  && b1 == b2
  && c1 == c2
  && d1 == d2

-- the (iface, head-arg types) of every USER/prelude impl declared in [prog].
implHeadsOf : List Decl -> List (String, List Ty)
implHeadsOf prog = flatMap implHeadOf prog

implHeadOf : Decl -> List (String, List Ty)
implHeadOf (DAttrib _ d) = implHeadOf d
implHeadOf (DImpl { iface, tys, ... }) = [(iface, tys)]
implHeadOf _ = []

-- the dispatch (interface-param) monos at one occurrence: parallel-walk the
-- declared method type against the normalized occurrence mono; wherever the
-- declared type is a bare interface-param tyvar, read the corresponding sub-mono.
-- Returns one entry per interface param, in typaram order (deduplicated by name).
-- An empty result means the walk found no iface-param position (shadowed method /
-- shape mismatch) — the caller then skips, so a shadow never produces a false
-- reject.
dispatchMonosOf : List String -> Ty -> Mono -> List Mono
dispatchMonosOf typarams mty occ =
  let pairs = walkDispatch typarams (stripTyConstraints mty) occ
  collectByParam typarams pairs

-- strip leading `=>` constraints / effect rows so the walk aligns the method's
-- value type with the occurrence mono.
stripTyConstraints : Ty -> Ty
stripTyConstraints (TyConstrained _ t) = stripTyConstraints t
stripTyConstraints (TyEffect _ _ t) = stripTyConstraints t
stripTyConstraints t = t

-- parallel structural walk collecting (paramName, mono) wherever the declared
-- type is a bare iface-param tyvar.  Other positions recurse; a shape mismatch
-- (declared has structure the occurrence lacks) simply stops that branch.
walkDispatch : List String -> Ty -> Mono -> List (String, Mono)
walkDispatch typarams (TyVar n) m
  | contains n typarams = [(n, normalize m)]
  | otherwise = []
walkDispatch typarams (TyFun a b) m = match normalize m
  TFun ma _ mb => walkDispatch typarams (stripTyConstraints a) ma
    ++ walkDispatch typarams (stripTyConstraints b) mb
  _ => []
walkDispatch typarams (TyApp a b) m = match normalize m
  TApp ma mb => walkDispatch typarams a ma ++ walkDispatch typarams b mb
  _ => []
walkDispatch typarams (TyTuple ts) m = match tupleSpine m
  Some ms => flatMap (p => walkDispatch typarams (fst p) (snd p)) (zipL ts ms)
  _ => []
walkDispatch _ _ _ = []

-- one mono per interface param, in declaration order; if ANY param has no
-- recovered binding the whole obligation is abandoned (return [] → caller skips).
collectByParam : List String -> List (String, Mono) -> List Mono
collectByParam typarams pairs = match collectByParamGo typarams pairs
  None => []
  Some ms => ms

collectByParamGo : List String -> List (String, Mono) -> Option (List Mono)
collectByParamGo [] _ = Some []
collectByParamGo (p::rest) pairs = match lookupAssoc p pairs
  None => None
  Some m => map (m :: _) (collectByParamGo rest pairs)

-- every dispatch mono has a resolved concrete head tycon (no remaining bare
-- TVar at the head) — the oracle's is_concrete gate, restricted to the head (a
-- concrete head with free args, e.g. `Maybe a`, still uniquely picks the impl).
allConcreteHeads : List Mono -> Bool
allConcreteHeads [] = True
allConcreteHeads (m::rest) = isSome (headTyconMono m) && allConcreteHeads rest

-- does some impl of [iface] in [heads] match the concrete dispatch monos?  Each
-- head-arg type pattern is matched against the corresponding mono via matchTyMono
-- (a TyVar in the head is a wildcard; a parametric impl `impl Eq (List a)` thus
-- matches `List Int`).
implMatches : List (String, List Ty) -> String -> List Mono -> Bool
implMatches [] _ _ = False
implMatches ((iface2, tys)::rest) iface args
  | iface2 == iface && implHeadMatchesArgs tys args = True
  | otherwise = implMatches rest iface args

implHeadMatchesArgs : List Ty -> List Mono -> Bool
implHeadMatchesArgs tys args
  | listLen tys == listLen args = allHeadArgsMatch (zipL tys args)
  | otherwise = False

allHeadArgsMatch : List (Ty, Mono) -> Bool
allHeadArgsMatch [] = True
allHeadArgsMatch ((ty, m)::rest) = match matchTyMono ty m
  Some _ => allHeadArgsMatch rest
  None => False

-- Does some impl of [iface] have a RECEIVER (first head type) matching the single
-- dispatch mono [dm]?  The call-obligation path (checkOneCallObligation) only ever
-- carries the receiver dispatch mono — NOT every interface param — so it must match
-- against the impl head's receiver position alone.  For a single-param interface
-- (`Eq (List a)`) this is identical to implMatches (the head has one type); for a
-- MULTI-param interface (`Index (Array a) Int a`) a full-length implMatches would
-- length-mismatch [dm] (1) against the 3-type head and spuriously reject.  Soundness
-- is preserved because the full-arity checkImplObligations path (recordImplObligation)
-- still validates all interface params of the same occurrence.
implMatchesReceiver : List (String, List Ty) -> String -> Mono -> Bool
implMatchesReceiver [] _ _ = False
implMatchesReceiver ((iface2, tys)::rest) iface dm
  | iface2 == iface = match tys
    recv::_ => match matchTyMono recv dm
      Some _ => True
      None => implMatchesReceiver rest iface dm
    [] => implMatchesReceiver rest iface dm
  | otherwise = implMatchesReceiver rest iface dm

-- render the dispatch monos space-separated under ONE shared naming context
-- (mirrors lib/typecheck.ml's pp_monos), so distinct free vars don't all collapse
-- to "a".  Concrete heads (the only case that reaches an error) render as the
-- type name.
ppMonosShared : List Mono -> String
ppMonosShared ms =
  let ctx = Ref []
  let cnt = Ref 0
  joinWith " " (ppEachShared ctx cnt ms)

ppEachShared : Ref (List (Int, String)) -> Ref Int -> List Mono -> List String
ppEachShared _ _ [] = []
ppEachShared ctx cnt (m::rest) = ppGo ctx cnt 2 m :: ppEachShared ctx cnt rest

-- register, per slot, the default body's constraint var id → `$dict_<method>_<slot>`
-- in activeDictVars, so an in-body method ref unified to that var routes RDict.
-- Run AFTER body inference so the id is the SURVIVING (normalized) union-find root —
-- the same id the in-body site normalizes to (mirrors registerImplRequires).
registerMethodDictSlots : String -> Int -> List Int -> List (Int, Mono) -> Unit
registerMethodDictSlots _ _ [] _ = ()
registerMethodDictSlots mname slot (id::rest) subst =
  let _ = registerOneMethodDict mname slot id subst
  registerMethodDictSlots mname (slot + 1) rest subst

registerOneMethodDict : String -> Int -> Int -> List (Int, Mono) -> Unit
registerOneMethodDict mname slot id subst = match lookupAssocI id subst
  None => ()
  Some m => match normalize m
    TVar cell => setRef activeDictVars ((tyvarId cell, dictParamName mname slot)::activeDictVars.value)
    _ => ()

-- infer each impl-with-`requires`' return-position method bodies; the interface
-- declarations live in [allProg] (method types + typarams).
inferImplBodies : TcEnv -> List Decl -> List String -> List Decl -> Unit
inferImplBodies _ _ _ [] = ()
inferImplBodies env allProg rpNames (d::rest) =
  let _ = inferOneImpl env allProg rpNames d
  inferImplBodies env allProg rpNames rest

inferOneImpl : TcEnv -> List Decl -> List String -> Decl -> Unit
inferOneImpl env allProg rpNames (DAttrib _ d) =
  inferOneImpl env allProg rpNames d
inferOneImpl env allProg rpNames (DImpl { iface, tys, reqs, methods, ... }) = match reqs
  [] => inferPlainImpl env allProg iface tys methods
  _ => inferRequiresImpl env allProg rpNames iface tys reqs methods
inferOneImpl _ _ _ _ = ()

-- D3a: a NON-`requires` impl body, inferred only on the emit path (emitArgStampPasses)
-- so its ARG-position method occurrences (e.g. `display` of a String field inside a
-- `Display`/`Debug` impl — the 19 `display@String` sites) reach inferMethodAt and
-- get stamped.  Mirrors inferRequiresImpl's head-mono substitution but with no
-- requires to register (an unconstrained impl threads no element dict).  OFF, these
-- impl bodies stay un-inferred exactly as before, keeping every golden identical.
inferPlainImpl : TcEnv -> List Decl -> String -> List Ty -> List ImplMethod -> Unit
inferPlainImpl env allProg iface tys methods =
  let implTvMap = freshTvMap (dedup (flatMap tyVarNames tys))
  let headMonos = map (fromAstType implTvMap) tys
  inferImplMethods env allProg iface implTvMap headMonos methods

-- one impl `impl Iface (List a) requires Iface a where …`: build ONE tyvar map
-- shared between the head (`List a`) and the requires (`Iface a`) so the body's
-- inner method ref unifies its discriminating var to the head's `a`; infer each
-- method body against the method type instantiated at the head; THEN register the
-- requires' post-unification ids in activeDictVars keyed to `$dict_<method>_<slot>`.
inferRequiresImpl : TcEnv -> List Decl -> List String -> String -> List Ty -> List Require -> List ImplMethod -> Unit
inferRequiresImpl env allProg rpNames iface tys reqs methods =
  let implTvMap = freshTvMap (dedup (flatMap tyVarNames tys))
  let headMonos = map (fromAstType implTvMap) tys
  let _ = inferImplMethods env allProg iface implTvMap headMonos methods
  registerImplRequires implTvMap rpNames reqs methods

inferImplMethods : TcEnv -> List Decl -> String -> List (String, Mono) -> List Mono -> List ImplMethod -> Unit
inferImplMethods _ _ _ _ _ [] = ()
inferImplMethods env allProg iface implTvMap headMonos (m::rest) =
  let _ = inferImplMethod env allProg iface implTvMap headMonos m
  inferImplMethods env allProg iface implTvMap headMonos rest

inferImplMethod : TcEnv -> List Decl -> String -> List (String, Mono) -> List Mono -> ImplMethod -> Unit
inferImplMethod env allProg iface implTvMap headMonos (ImplMethod mname pats body) = match ifaceMethodTy allProg iface mname
  None => ()
  Some (ifaceParams, mty) =>
    -- currentFn = the method name (NOT "") so arg-/return-position sites in THIS
    -- body record `encl = mname`.  registerImplRequires keys every method of an impl
    -- under the SAME impl tyvar id (`impl Ord (List a)` registers `a` once per
    -- compare/lt/min/max/…), so the global first-match route resolution returns the
    -- LAST-registered method's `$dict_<m>_<slot>` for ALL bodies — corrupting e.g.
    -- compare's element dispatch to `$dict_max_0` (unbound in compare's scope).  With
    -- encl = mname, activeDictVarOfEncl/argImplDictRoutesForEncl prefer THIS method's
    -- own `$dict_<mname>_<slot>`.  Pre-specialization each Ord impl defined only
    -- compare so there was no collision; universal default specialization exposes it.
    let _ = setRef currentFn mname
    let _ = setRef currentImplBody True
    -- build the method type's tv map explicitly (instead of expectedMethodType,
    -- which hides it) so the impl method's OWN method-level constraint vars
    -- (`Thenable m => …`) can be registered into activeDictVars below.
    let baseMap = zipL ifaceParams headMonos
    let extraMap = freshTvMap (removeAllS ifaceParams (dedup (tyVarNames mty)))
    let expected = fromAstType (baseMap ++ extraMap) mty
    let actual = inferClauses env [(pats, body)]
    let _ = unify expected actual
    -- Eval-path method-dict threading (parity with inferDefaultMethod's
    -- registerMethodDictSlots): an impl method with its OWN method-level constraint
    -- (`wrap : Thenable m => … -> m (List b)`) whose body returns a constraint-var
    -- method (`pure []`) needs that inner site routed RDictFwd $dict_<mname>_<slot>
    -- — the leading method-dict param implDictPassMethods prepends — so eval narrows
    -- it by the dict supplied at the call site (resolveMethodDicts) instead of
    -- falling to arg-tag dispatch and panicking `no matching impl for dispatch`.
    -- The EMIT path already worked because the emitter restamps impl-body
    -- return-position methods to the dict param directly; the eval path relies on
    -- the route, so register the var → dict-param mapping here (AFTER body inference,
    -- so each var is its surviving union-find root, mirroring registerMethodDictSlots).
    let _ = registerImplMethodDicts mname ifaceParams mty extraMap
    let _ = setRef currentImplBody False
    setRef currentFn ""
-- G4: mark binop sites recorded while inferring this impl body so resolveBinopSite
-- routes their element dict (RDict) — and ONLY theirs, not top-level operators.

-- Register an impl method's OWN method-level constraints (`Thenable m => …`) into
-- activeDictVars, one slot per constraint, so a return-position method in the impl
-- body whose result type is the constraint var routes RDictFwd $dict_<mname>_<slot>.
-- [tvMap] maps the method type's non-interface-param tyvar names → the fresh vars
-- expected/the body unified against; normalize each to its surviving root before
-- registering.  Slot numbering matches methodConstraintSlotIds (same flatMap order),
-- so it lines up with implDictPassMethods' prepended params and the call-site
-- methodRoutes resolveMethodDicts fills.
registerImplMethodDicts : String -> List String -> Ty -> List (String, Mono) -> Unit
registerImplMethodDicts mname ifaceParams mty tvMap =
  registerImplMethodDictsGo
    mname
    0
    (methodLevelConstraintVarNames ifaceParams mty)
    tvMap

registerImplMethodDictsGo : String -> Int -> List String -> List (String, Mono) -> Unit
registerImplMethodDictsGo _ _ [] _ = ()
registerImplMethodDictsGo mname slot (vname::rest) tvMap =
  let _ = registerImplMethodDictOne mname slot vname tvMap
  registerImplMethodDictsGo mname (slot + 1) rest tvMap

registerImplMethodDictOne : String -> Int -> String -> List (String, Mono) -> Unit
registerImplMethodDictOne mname slot vname tvMap = match lookupAssoc vname tvMap
  None => ()
  Some m => match normalize m
    TVar cell => setRef activeDictVars ((tyvarId cell, dictParamName mname slot)::activeDictVars.value)
    _ => ()

-- the non-interface-param dispatch var name of each method-level constraint, in
-- declaration order — the name-returning mirror of methodConstraintSlotIds (which
-- returns the ids).  One name per constraint slot; a constraint over only interface
-- params contributes nothing (it dispatches via the impl, not a dict).
methodLevelConstraintVarNames : List String -> Ty -> List String
methodLevelConstraintVarNames typarams (TyConstrained cs t) = flatMap (constraintFirstNonParam typarams) cs
  ++ methodLevelConstraintVarNames typarams t
methodLevelConstraintVarNames typarams (TyEffect _ _ t) =
  methodLevelConstraintVarNames typarams t
methodLevelConstraintVarNames _ _ = []

constraintFirstNonParam : List String -> Constraint -> List String
constraintFirstNonParam typarams c = match constraintNonParamVars typarams c
  [] => []
  n::_ => [n]

removeAllS : List String -> List String -> List String
removeAllS _ [] = []
removeAllS drop (x::xs)
  | contains x drop = removeAllS drop xs
  | otherwise = x :: removeAllS drop xs

-- the (interface typarams, declared method type) of method [mname] in interface
-- [iface], searched across [allProg]'s interface decls
ifaceMethodTy : List Decl -> String -> String -> Option (List String, Ty)
ifaceMethodTy [] _ _ = None
ifaceMethodTy ((DAttrib _ d)::rest) iface mname = match ifaceMethodTy [d] iface mname
  Some r => Some r
  None => ifaceMethodTy rest iface mname
ifaceMethodTy ((DInterface { name, typarams, methods, ... })::rest) iface mname
  | name == iface = match methodTyOf mname methods
    Some ty => Some (typarams, ty)
    None => ifaceMethodTy rest iface mname
  | otherwise = ifaceMethodTy rest iface mname
ifaceMethodTy (_::rest) iface mname = ifaceMethodTy rest iface mname

methodTyOf : String -> List IfaceMethod -> Option Ty
methodTyOf _ [] = None
methodTyOf mname ((IfaceMethod n ty _)::rest)
  | n == mname = Some ty
  | otherwise = methodTyOf mname rest

-- AFTER body inference: for each method of the impl that dispatches the element
-- (return-position OR, on the emit path, argument-position), register the requires'
-- surviving (normalized) tyvar ids → its `$dict_<method>_<slot>` param, so the
-- inner ref's pendingSite/pendingArgStamp (also normalizing to that id) routes
-- RDict.  D3b-1: arg-position methods (`eq`/`compare`/`debug`/… on the element)
-- register only under emitArgStampPasses (argDispatchOf returns None otherwise), so
-- the non-emit return-position path is unchanged.  (The element tyvar is shared
-- across an impl's methods, so per-method dict names only disambiguate for
-- single-method interfaces — exactly the D3b-1 targets Eq/Ord/Debug/Display/Hashable.)
registerImplRequires : List (String, Mono) -> List String -> List Require -> List ImplMethod -> Unit
registerImplRequires _ _ _ [] = ()
registerImplRequires implTvMap rpNames reqs ((ImplMethod mname _ _)::rest)
  | registersElementDict mname rpNames =
    let _ = registerReqSlots mname implTvMap (methodDictArityOf mname) reqs
    registerImplRequires implTvMap rpNames reqs rest
  | otherwise = registerImplRequires implTvMap rpNames reqs rest

-- a method registers an element dict if it is return-position (rpNames) or — on
-- the emit path only — an arg-position dispatch method (argDispatchOf is Some).
registersElementDict : String -> List String -> Bool
registersElementDict mname rpNames = contains mname rpNames
  || isSome (argDispatchOf mname)

registerReqSlots : String -> List (String, Mono) -> Int -> List Require -> Unit
registerReqSlots _ _ _ [] = ()
registerReqSlots mname implTvMap slot ((Require _ rargs)::rest) =
  let ids = flatMap (a => monoTyvarIds (fromAstType implTvMap a)) rargs
  let _ = registerEachActive ids (dictParamName mname slot)
  registerReqSlots mname implTvMap (slot + 1) rest

registerEachActive : List Int -> String -> Unit
registerEachActive [] _ = ()
registerEachActive (id::rest) dname =
  let _ = setRef activeDictVars ((id, dname)::activeDictVars.value)
  registerEachActive rest dname

-- the tyvar ids in a (normalized) mono — single var for a bare constraint arg
monoTyvarIds : Mono -> List Int
monoTyvarIds m = match normalize m
  TVar cell => [tyvarId cell]
  TApp a b => monoTyvarIds a ++ monoTyvarIds b
  TFun a _ b => monoTyvarIds a ++ monoTyvarIds b
  _ => []

-- extern declarations become top-level schemes (like interface methods)
externSchemes : List Decl -> List (String, Scheme)
externSchemes [] = []
externSchemes ((DExtern _ n ty)::rest) =
  (n, sigToScheme ty) :: externSchemes rest
externSchemes (_::rest) = externSchemes rest

-- interface method schemes: each method's declared type, free tyvars (incl. the
-- interface param) quantified — the bare scheme the === TYPES === output shows
-- (the typeclass constraint itself is never rendered).  Impl bodies add no
-- top-level bindings, so DImpl needs no output here.
ifaceMethodSchemes : List Decl -> List (String, Scheme)
ifaceMethodSchemes [] = []
ifaceMethodSchemes (d::rest) = declIfaceMethods d ++ ifaceMethodSchemes rest

declIfaceMethods : Decl -> List (String, Scheme)
declIfaceMethods (DInterface { typarams, methods, ... }) =
  methodSchemes typarams methods
declIfaceMethods _ = []

-- Error-path B4: register each interface method → (iface, typarams, declared Ty)
-- so checkImplObligations can recover its dispatch (iface-param) types at a call
-- site.  Built from the SAME prog the impl lookup uses, so an interface absent
-- from prog (e.g. a prelude method in the no-prelude path) is never checked.
registerMethodIfaceParamsAll : List Decl -> Unit
registerMethodIfaceParamsAll [] = ()
registerMethodIfaceParamsAll (d::rest) =
  let _ = registerMethodIfaceParamsDecl d
  registerMethodIfaceParamsAll rest

registerMethodIfaceParamsDecl : Decl -> Unit
registerMethodIfaceParamsDecl (DAttrib _ d) = registerMethodIfaceParamsDecl d
registerMethodIfaceParamsDecl (DInterface { name, typarams, methods, ... }) =
  registerMethodIfaceParamsMethods name typarams methods
registerMethodIfaceParamsDecl _ = ()

registerMethodIfaceParamsMethods : String -> List String -> List IfaceMethod -> Unit
registerMethodIfaceParamsMethods _ _ [] = ()
registerMethodIfaceParamsMethods iface typarams ((IfaceMethod mname mty _)::rest) =
  let _ = setRef methodIfaceParamsRef (omInsert mname (iface, typarams, mty) methodIfaceParamsRef.value)
  let _ = setRef registeredIfacesRef (omInsert iface () registeredIfacesRef.value)
  registerMethodIfaceParamsMethods iface typarams rest

-- build each method's scheme AND register its method-level constraints (foldMap's
-- `Monoid m`) into methodConstraintsRef, keyed by the scheme's own quantified ids
-- (from the same tvs map), so a call-site instantiation can route the dict.
methodSchemes : List String -> List IfaceMethod -> List (String, Scheme)
methodSchemes _ [] = []
methodSchemes typarams ((IfaceMethod mname mty _)::rest) =
  let st = sigToSchemeTvs mty
  let _ = registerMethodConstraints typarams mname mty (snd st) (schemeIds (fst st))
  (mname, fst st) :: methodSchemes typarams rest

-- like methodSchemes but WITHOUT the registerMethodConstraints side effect — for
-- callers (inferOneIfaceDefaults) that only need the schemes to look up a method's
-- own type and must not double-register methodConstraintsRef entries (those are
-- registered once during ifaceMethodSchemes at env setup).
methodSchemesPure : List IfaceMethod -> List (String, Scheme)
methodSchemesPure [] = []
methodSchemesPure ((IfaceMethod mname mty _)::rest) =
  (mname, sigToScheme mty) :: methodSchemesPure rest

-- the method-level-constraint slot ids of [mname]: one id per `=>` constraint over
-- a non-interface-param tyvar, looked up in the scheme's tvs map.  Registered only
-- when non-empty (so methodConstraintsRef holds only genuinely-constrained methods).
registerMethodConstraints : List String -> String -> Ty -> List (String, Mono) -> List Int -> Unit
registerMethodConstraints typarams mname mty tvs fullIds =
  let ids = methodConstraintSlotIds typarams mty tvs
  if isEmptyL ids || hasAssocSL2 mname methodConstraintsRef.value then ()
  else
    let _ = setRef methodConstraintsRef ((mname, ids)::methodConstraintsRef.value)
    setRef
      methodConstraintPositionsRef
      ((mname, map (id => indexOfInt id fullIds) ids)::methodConstraintPositionsRef.value)

-- index of [x] in [xs] (0-based; -1 if absent — absent shouldn't happen, slot ids
-- are always quantified ids of the same scheme).
indexOfInt : Int -> List Int -> Int
indexOfInt x xs = indexOfIntGo x xs 0
indexOfIntGo : Int -> List Int -> Int -> Int
indexOfIntGo _ [] _ = 0 - 1
indexOfIntGo x (y::ys) i = if x == y then i else indexOfIntGo x ys (i + 1)
-- DRIVER-COLLAPSE Phase 2: skip when [mname] is ALREADY registered in THIS pass.
-- The ids must be the SAME quantified ids the call-site instantiation maps through
-- its subst (see methodConstraintsRef doc).  The module path's checkModuleFullImpl
-- can call ifaceMethodSchemes more than once per pass (env setup + impl/default body
-- inference re-resolving schemes), and a SECOND registration prepends DIFFERENT
-- freshly-instantiated ids → lookupAssocSL2 (first-match) returns the stale ids →
-- constraintMonosOf drops them → empty method-dict route (method_constraint_impl_offset:
-- methodN=0).  Keeping the FIRST (env-setup) registration — whose scheme is the one
-- lookupVar returns at call sites — restores the flat path's single-registration
-- invariant.  resetState clears methodConstraintsRef between modules, so this only
-- de-dups WITHIN a pass.

hasAssocSL2 : String -> List (String, List Int) -> Bool
hasAssocSL2 n xs = match lookupAssocSL2 n xs
  Some _ => True
  None => False

methodConstraintSlotIds : List String -> Ty -> List (String, Mono) -> List Int
methodConstraintSlotIds typarams (TyConstrained cs t) tvs = flatMap (constraintSlotId typarams tvs) cs
  ++ methodConstraintSlotIds typarams t tvs
methodConstraintSlotIds typarams (TyEffect _ _ t) tvs =
  methodConstraintSlotIds typarams t tvs
methodConstraintSlotIds _ _ _ = []

-- one slot per method-level constraint: the id of its first non-interface-param
-- tyvar (the dispatch var the supplied dict narrows by).  A constraint over only
-- interface params contributes no slot (it dispatches via the impl, not a dict).
constraintSlotId : List String -> List (String, Mono) -> Constraint -> List Int
constraintSlotId typarams tvs c = match constraintNonParamVars typarams c
  [] => []
  n::_ => match lookupAssoc n tvs
    Some m => [monoTyvarId m]
    None => []

sigsOf : List Decl -> List (String, Ty)
sigsOf [] = []
sigsOf ((DTypeSig _ n ty)::rest) = (n, ty) :: sigsOf rest
sigsOf (_::rest) = sigsOf rest

-- all free variable references in an expr (for the dependency graph); over-
-- approximate (includes bound vars), filtered to top-level group names by caller
allEVars : Expr -> List String
allEVars (EVar x) = [x]
allEVars (EMethodAt n _ _ _) = [n]
allEVars (EDictAt n _) = [n]
allEVars (ELit _) = []
allEVars (EApp f x) = allEVars f ++ allEVars x
allEVars (ELam _ b) = allEVars b
allEVars (ELet _ _ _ e1 e2) = allEVars e1 ++ allEVars e2
allEVars (ELetGroup binds body) = flatMap letBindEVars binds ++ allEVars body
allEVars (EMatch e arms) = allEVars e ++ flatMap armEVars arms
allEVars (EIf c t e) = allEVars c ++ allEVars t ++ allEVars e
allEVars (EBinOp _ l r _) = allEVars l ++ allEVars r
allEVars (EUnOp _ e _) = allEVars e
allEVars (EInfix op l r) = op :: allEVars l ++ allEVars r
allEVars (EFieldAccess e _ _) = allEVars e
allEVars (ETuple es) = flatMap allEVars es
allEVars (EListLit es) = flatMap allEVars es
allEVars (EArrayLit es) = flatMap allEVars es
allEVars (ERangeList a b _) = allEVars a ++ allEVars b
allEVars (ERangeArray a b _) = allEVars a ++ allEVars b
allEVars (ESlice e a b _ _) = allEVars e ++ allEVars a ++ allEVars b
allEVars (EIndex e i _) = allEVars e ++ allEVars i
allEVars (EAnnot e _) = allEVars e
allEVars (EBlock stmts) = flatMap doStmtEVars stmts
allEVars (ERecordCreate _ fs) = flatMap fieldAssignEVars fs
allEVars (ERecordUpdate e fs _) = allEVars e ++ flatMap fieldAssignEVars fs
allEVars (EVariantUpdate _ e fs) = allEVars e ++ flatMap fieldAssignEVars fs
allEVars (ELoc _ e) = allEVars e
allEVars (EDoOrigin _ e) = allEVars e
allEVars _ = []

letBindEVars : LetBind -> List String
letBindEVars (LetBind _ clauses) = flatMap funClauseEVars clauses

funClauseEVars : FunClause -> List String
funClauseEVars (FunClause _ body) = allEVars body

armEVars : Arm -> List String
armEVars (Arm _ guards body) = flatMap guardEVars guards ++ allEVars body

guardEVars : Guard -> List String
guardEVars (GBool e) = allEVars e
guardEVars (GBind _ e) = allEVars e

doStmtEVars : DoStmt -> List String
doStmtEVars (DoExpr e) = allEVars e
doStmtEVars (DoLet _ _ _ e) = allEVars e
doStmtEVars (DoBind _ e) = allEVars e
doStmtEVars (DoAssign _ e) = allEVars e
doStmtEVars (DoFieldAssign _ _ e) = allEVars e

fieldAssignEVars : FieldAssign -> List String
fieldAssignEVars (FieldAssign _ e) = allEVars e

-- builtin constructors available without the prelude (mirrors initial_env)
initialEnv : TcEnv
initialEnv =
  TcEnv
    omEmpty
    (omInsert
      "True"
      (monoScheme (TCon "Bool"))
      (omInsert "False" (monoScheme (TCon "Bool")) omEmpty))
    []

registerAllData : TcEnv -> List Decl -> TcEnv
registerAllData env [] = env
registerAllData env (d::rest) = registerAllData (registerData env d) rest

-- ── dependency-ordered, SCC-merged letrec processing ──────────────────────
-- The prelude has forward references and mutual recursion throughout, so groups
-- must be type-checked in dependency order (a callee generalized before its
-- callers instantiate it polymorphically) with mutually-recursive cycles merged
-- into one letrec group (generalized together).  Mirrors the reference's
-- order_groups_by_deps + process_letrec_group (Phase 136).

-- ── Tarjan strongly-connected components (O(V+E)) ─────────────────────────
-- Replaces the former all-pairs-reachability + mutual-reachability SCC + topo
-- sort, which was O(n^3) in a module's top-level binding count and dominated
-- the multi-module typecheck (check_modules).  Emits SCCs in dependency-first
-- order (a "sink" component — no outside dependencies — finishes and is emitted
-- first), exactly what processSCCs needs.  State is held in module-level refs,
-- reset at the start of each run (processTopGroups runs sequentially per module).

depGraphMap : List String -> OrdMap (List (List Pat, Expr)) -> OrdMap (List String)
depGraphMap names grouped =
  buildAdj names (namesToSet names omEmpty) grouped omEmpty

-- name-membership set, built ONCE, so `keepGroupNames` is O(log n)/ref instead of
-- O(names)/ref (the dep-graph build was O(names²·refs)). Output-order-preserving:
-- `keepGroupNames`'s `filterList` is unchanged, only its membership test is faster.
namesToSet : List String -> OrdMap Unit -> OrdMap Unit
namesToSet [] m = m
namesToSet (n::rest) m = namesToSet rest (omInsert n () m)

-- defs grouped by name ONCE (name -> its clauses, in defs order), so `depsOf`
-- does an O(log n) lookup instead of re-scanning all defs per name (was
-- O(names·defs)). Built by prepend (O(1)); `clausesOf` reverses on read to
-- restore defs order — so the per-name clause list is identical to the old
-- `clausesFor name defs`, keeping dep lists / SCC order / output byte-identical.
groupClauses : List (String, (List Pat, Expr)) -> OrdMap (List (List Pat, Expr))
groupClauses defs = groupClausesGo defs omEmpty
groupClausesGo : List (String, (List Pat, Expr)) -> OrdMap (List (List Pat, Expr)) -> OrdMap (List (List Pat, Expr))
groupClausesGo [] m = m
groupClausesGo ((n, c)::rest) m =
  groupClausesGo rest (omInsert n (c :: clausesAt n m) m)

clausesAt : String -> OrdMap (List (List Pat, Expr)) -> List (List Pat, Expr)
clausesAt n m = match omLookup n m
  Some xs => xs
  None => []

clausesOf : String -> OrdMap (List (List Pat, Expr)) -> List (List Pat, Expr)
clausesOf n m = revClauses (clausesAt n m) []

revClauses : List (List Pat, Expr) -> List (List Pat, Expr) -> List (List Pat, Expr)
revClauses [] acc = acc
revClauses (x::xs) acc = revClauses xs (x::acc)

buildAdj : List String -> OrdMap Unit -> OrdMap (List (List Pat, Expr)) -> OrdMap (List String) -> OrdMap (List String)
buildAdj [] _ _ m = m
buildAdj (n::rest) nameSet cbn m =
  buildAdj rest nameSet cbn (omInsert n (depsOf n nameSet cbn) m)

tjCounter : Ref Int
tjCounter = Ref 0
tjStack : Ref (List String)
tjStack = Ref []
tjIndex : Ref (OrdMap Int)
tjIndex = Ref omEmpty
tjLow : Ref (OrdMap Int)
tjLow = Ref omEmpty
tjOn : Ref (OrdMap Bool)
tjOn = Ref omEmpty
tjOut : Ref (List (List String))
tjOut = Ref []

tjLowOf : String -> Int
tjLowOf x = fromOption 0 (omLookup x tjLow.value)
tjOnStack : String -> Bool
tjOnStack x = fromOption False (omLookup x tjOn.value)

tarjanSCCs : List String -> OrdMap (List String) -> List (List String)
tarjanSCCs names adj =
  let _ = setRef tjCounter 0
  let _ = setRef tjStack []
  let _ = setRef tjIndex omEmpty
  let _ = setRef tjLow omEmpty
  let _ = setRef tjOn omEmpty
  let _ = setRef tjOut []
  let _ = tarjanAll names adj
  reverseL tjOut.value

tarjanAll : List String -> OrdMap (List String) -> Unit
tarjanAll [] _ = ()
tarjanAll (v::rest) adj =
  let _ = tjVisit v adj
  tarjanAll rest adj

tjVisit : String -> OrdMap (List String) -> Unit
tjVisit v adj = match omLookup v tjIndex.value
  Some _ => ()
  None => strongconnect v adj

strongconnect : String -> OrdMap (List String) -> Unit
strongconnect v adj =
  let idx = tjCounter.value
  let _ = setRef tjIndex (omInsert v idx tjIndex.value)
  let _ = setRef tjLow (omInsert v idx tjLow.value)
  let _ = setRef tjCounter (idx + 1)
  let _ = setRef tjStack (v::tjStack.value)
  let _ = setRef tjOn (omInsert v True tjOn.value)
  let _ = scEdges v (fromOption [] (omLookup v adj)) adj
  if tjLowOf v == idx then tjPop v [] else ()

scEdges : String -> List String -> OrdMap (List String) -> Unit
scEdges v [] adj = ()
scEdges v (w::ws) adj =
  let _ = scEdge v w adj
  scEdges v ws adj

scEdge : String -> String -> OrdMap (List String) -> Unit
scEdge v w adj = match omLookup w tjIndex.value
  None =>
    let _ = strongconnect w adj
    setRef tjLow (omInsert v (minI (tjLowOf v) (tjLowOf w)) tjLow.value)
  Some iw =>
    if tjOnStack w then
      setRef tjLow (omInsert v (minI (tjLowOf v) iw) tjLow.value)
    else
      ()

tjPop : String -> List String -> Unit
tjPop v acc = match tjStack.value
  [] => setRef tjOut (acc::tjOut.value)
  w::rest =>
    let _ = setRef tjStack rest
    let _ = setRef tjOn (omInsert w False tjOn.value)
    if w == v then setRef tjOut ((w::acc) :: tjOut.value) else tjPop v (w::acc)

-- sig-name presence set (which top-level names carry a type signature), set once
-- per module in `processTopGroups` so `memberPeelSource`/`memberSigIsFun` do an
-- O(log n) presence check instead of an O(sigs) `lookupAssoc` scan per SCC member
-- (was O(members·sigs) over the whole compiler). Module-level ref, matching the
-- `currentFn`/`curEffect` idiom; processing is sequential per module.
sigNameSetRef : Ref (OrdMap Unit)
sigNameSetRef = Ref omEmpty

sigNamesToSet : List (String, Ty) -> OrdMap Unit -> OrdMap Unit
sigNamesToSet [] m = m
sigNamesToSet ((n, _)::rest) m = sigNamesToSet rest (omInsert n () m)

-- PERF: name → declared signature, the same `sigs` assoc list as an index.  Three
-- sites (preunifySigsEx, checkEffectEscape, checkSigConstraintOne) did
-- `lookupAssoc m sigs` — an O(N) scan of EVERY top-level signature, run per member
-- of every group, so O(N²) over a large file.  Companion to `sigNameSetRef`, seeded
-- from the same `sigs` in processTopGroups.
--
-- Built from the REVERSED list: `omFromPairs` is last-write-wins, while the
-- `lookupAssoc` it replaces was first-match-wins, so reversing preserves which
-- signature a duplicated name resolves to.
sigTyMapRef : Ref (OrdMap Ty)
sigTyMapRef = Ref omEmpty

processTopGroups : TcEnv -> List (String, Ty) -> List (String, (List Pat, Expr)) -> List String -> List (String, Scheme)
processTopGroups env sigs defs names =
  let _ = setRef sigNameSetRef (sigNamesToSet sigs omEmpty)
  let _ = setRef sigTyMapRef (omFromPairs (reverseL sigs) omEmpty)
  let grouped = groupClauses defs
  let ordered = tarjanSCCs names (depGraphMap names grouped)
  processSCCs env sigs grouped ordered

-- per-name dependencies: the other top-level names a binding's bodies reference
-- (a conservative over-approximation via all free EVars is fine — only names
-- that are themselves groups matter).  Consumed by depGraphMap → Tarjan.
depsOf : String -> OrdMap Unit -> OrdMap (List (List Pat, Expr)) -> List String
depsOf name nameSet cbn =
  filterNonSelf
    name
    (keepGroupNames nameSet (dedup (groupRefs (clausesOf name cbn))))

groupRefs : List (List Pat, Expr) -> List String
groupRefs clauses = flatMap clauseRefs clauses

clauseRefs : (List Pat, Expr) -> List String
clauseRefs (_, body) = allEVars body

keepGroupNames : OrdMap Unit -> List String -> List String
keepGroupNames nameSet refs = filterList (r => omHasKey r nameSet) refs

filterNonSelf : String -> List String -> List String
filterNonSelf name xs = filterList (!= name) xs

-- process each SCC as a letrec group in topological order
processSCCs : TcEnv -> List (String, Ty) -> OrdMap (List (List Pat, Expr)) -> List (List String) -> List (String, Scheme)
processSCCs _ _ _ [] = []
processSCCs env sigs grouped (scc::rest) =
  let er = processSCC env sigs grouped scc
  snd er ++ processSCCs (fst er) sigs grouped rest

-- #23 support: synthesize impl-obligation-shaped Num entries from a group's
-- pendingCallObligations / pendingDictApps deltas.  The Num constraint of an
-- ambiguous var reaching a group ONLY through a constrained-callee instantiation
-- (`main = println (app2 (==))`) is recorded on those refs, never on
-- pendingImplObligations, so the group-level Num defaulting (defaultGroupNum /
-- groundNumVars, which both reads candidate ids AND finds the live var to ground
-- from impl-shaped entries) never saw it — leaving an ungrounded var whose Num dict
-- route resolves RNone → a NULL dict word → build-time SIGTRAP (run is correct).
-- Only field 0 (iface) and field 3 (the live operand mono) are read downstream;
-- the rest mirror inferNumLitBare's placeholder shape.
numCallObls : List (String, Mono, Option Loc) -> List (String, List String, Ty, Mono, Option Loc)
numCallObls [] = []
numCallObls ((iface, mono, loc)::rest)
  | iface == "Num" = ("Num", ["a"], TyVar "a", mono, loc) :: numCallObls rest
  | otherwise = numCallObls rest

numDictObls : List (Ref (List Route), List Mono, List String) -> List (String, List String, Ty, Mono, Option Loc)
numDictObls [] = []
numDictObls ((_, monos, ifaces)::rest) = flatMap (p => if fst p == "Num" then [("Num", ["a"], TyVar "a", snd p, currentLoc.value)] else []) (zipL ifaces monos)
  ++ numDictObls rest

-- #23 (two-hop forward): the impl-obligation-shaped entries for EVERY iface (not
-- just Num) a group's constrained-callee instantiations recorded on the call/dict
-- deltas.  Unlike numCallObls/numDictObls (which feed only Num-defaulting), these
-- feed registerSchemeObligations so a constraint FORWARDED from a constrained callee
-- (`useApp g = app2 g`, whose Num lives on the call/dict deltas, never on
-- pendingImplObligations) is recorded in schemeObligationsRef — so a caller of the
-- forwarder (`main = println (useApp (==))`) re-instantiates it (instantiateVarTracked),
-- surfacing the constraint on the caller's own delta where group Num-defaulting can
-- ground the shared ambiguous var.  Without this the forwarded var never grounds on
-- the check path and a downstream Eq/Ord obligation on it is falsely ambiguous.
allCallObls : List (String, Mono, Option Loc) -> List (String, List String, Ty, Mono, Option Loc)
allCallObls [] = []
allCallObls ((iface, mono, loc)::rest)
  | iface == "" = allCallObls rest
  | otherwise = (iface, ["a"], TyVar "a", mono, loc) :: allCallObls rest

allDictObls : List (Ref (List Route), List Mono, List String) -> List (String, List String, Ty, Mono, Option Loc)
allDictObls [] = []
allDictObls ((_, monos, ifaces)::rest) = flatMap (p => if fst p == "" then [] else [(fst p, ["a"], TyVar "a", snd p, currentLoc.value)]) (zipL ifaces monos)
  ++ allDictObls rest

-- FLAT-PATH SHADOW SCOPING (S1): a letrec group whose members are ALL prelude fns is a
-- CORE group — no user standalone is a shadow inside it.  Empty group ⇒ not core (it
-- cannot occur, and "user" is the conservative arm: it preserves the pre-fix behavior).
flatGroupIsCore : List String -> Bool
flatGroupIsCore [] = False
flatGroupIsCore members = allCoreFns members

allCoreFns : List String -> Bool
allCoreFns [] = True
allCoreFns (m::rest)
  | omHasKey m flatCoreFnNamesRef.value = allCoreFns rest
  | otherwise = False

-- FLAT-PATH SHADOW SCOPING (S1): point definerShadowNamesRef at the shadow set that is
-- actually IN SCOPE for the decls about to be inferred — [] inside the prelude, the
-- user's shadows inside the user's module.  Inert (and byte-identical) unless the flat
-- path prepended a prelude; see flatShadowScopingRef.
scopeShadowsForGroup : List String -> Unit
scopeShadowsForGroup members
  | not flatShadowScopingRef.value = ()
  | flatGroupIsCore members = setRef definerShadowNamesRef []
  | otherwise = setRef definerShadowNamesRef flatUserShadowNamesRef.value

scopeShadowsCore : Unit -> Unit
scopeShadowsCore _ =
  if flatShadowScopingRef.value then
    setRef definerShadowNamesRef []
  else
    ()

scopeShadowsUser : Unit -> Unit
scopeShadowsUser _ =
  if flatShadowScopingRef.value then
    setRef definerShadowNamesRef flatUserShadowNamesRef.value
  else
    ()

-- did the caller prepend a prelude?  (`listLen ds > 0` without walking the list.)
declsNonEmpty : List Decl -> Bool
declsNonEmpty [] = False
declsNonEmpty _ = True

processSCC : TcEnv -> List (String, Ty) -> OrdMap (List (List Pat, Expr)) -> List String -> (TcEnv, List (String, Scheme))
processSCC env sigs grouped members =
  let _ = scopeShadowsForGroup members
  let _ = enterLevel ()
  let oblN0 = pendingImplObligationsN.value
  let callN0 = pendingCallObligationsN.value
  let dictN0 = pendingDictAppsN.value
  let placeholders = map (m => (m, freshVar ())) members
  let env2 = extendVars env (map placeholderBinding placeholders)
  let (regs, sigTvMaps) = preunifySigsEx sigs placeholders
  -- P0-19 (constrained-receiver arm): publish THIS group's `=>`-constraint vars for
  -- the duration of body inference, so a definer-shadow method occurrence on one of
  -- them (`neq x y = not (eq x y)` under `neq : Eq a => …`) is seen as a DISPATCH and
  -- not monomorphised to the shadowing standalone's declared domain.
  let _ = setRef groupConstraintMonosRef (flatMap snd regs)
  let _ = inferMembers env2 sigs grouped placeholders
  let _ = setRef groupConstraintMonosRef []
  let _ = checkSigsTooGeneral sigTvMaps
  let _ = registerConstraintRegs regs
  let _ = exitLevel ()
  -- PLAN.md #11 (locked §0.2): GROUP-LEVEL + per-binding Num defaulting.  Ground
  -- every ambiguous Num-only var (one not reachable from an ARGUMENT position of
  -- ANY member's type) to Int before this group generalizes.  Covers both a var
  -- that surfaces in a member's type (`n = 1`) and one consumed entirely inside a
  -- body (`n = tag [1,2,3]`, element var in no member type).  An arg-reachable var
  -- (`sum`'s/`inc`'s element var) stays polymorphic.  Scoped to THIS group's newly
  -- added obligations (prepended at the front) so an earlier group's already-
  -- generalized var is never touched.  Mirrors lib/typecheck.ml's
  -- process_letrec_group group-level pass + per-binding default_ambiguous_num.
  let addedObls = takeFirst (pendingImplObligationsN.value - oblN0) pendingImplObligations.value
  -- #23: also ground an ambiguous Num var that reaches this group ONLY through a
  -- constrained-callee instantiation (its Num obligation lives on the call/dict deltas,
  -- not pendingImplObligations).  See numCallObls/numDictObls.  The synthetic entries
  -- feed ONLY the Num-defaulting search; addedObls alone still drives the
  -- ambiguous-constraint/scheme-obligation registration below.
  let extraNumObls =
        numCallObls (takeFirst (pendingCallObligationsN.value - callN0) pendingCallObligations.value)
        ++ numDictObls (takeFirst (pendingDictAppsN.value - dictN0) pendingDictApps.value)
  let defaultObls = addedObls ++ extraNumObls
  let _ = defaultGroupNum defaultObls (map snd placeholders)
  let _ = defaultEachMember defaultObls placeholders
  let _ = registerAmbiguousConstraints addedObls (map snd placeholders)   -- RETPOS soundness
  let schemes = sccSchemes sigs grouped (isLetrecGroup members) placeholders
  -- #23 two-hop forward: also record constraints FORWARDED from a constrained
  -- callee (living on the call/dict deltas, never in addedObls) into
  -- schemeObligationsRef, so a caller of this group re-instantiates them and its
  -- own group can ground the shared ambiguous var.  See allCallObls/allDictObls.
  let forwardedObls =
        allCallObls (takeFirst (pendingCallObligationsN.value - callN0) pendingCallObligations.value)
        ++ allDictObls (takeFirst (pendingDictAppsN.value - dictN0) pendingDictApps.value)
  let _ = registerSchemeObligations (addedObls ++ forwardedObls) schemes
  -- SIGNATURE CONSTRAINT SOUNDNESS: a signed member whose body induces an
  -- interface constraint on one of its own quantified vars that its declared `=>`
  -- context (superclass-closed) does NOT cover severs the constraint for callers
  -- → wrong-dictionary dispatch (a silent wrong answer).  Reject at the def-site.
  -- Runs on every path; the census over compiler+stdlib+sqlite was 0 new failures.
  let _ = checkSigConstraintCoverage regs sigs sigTvMaps addedObls schemes
  let _ = registerInferredConstraints sigs schemes
  -- FLAT-PATH SHADOW FIX (facet 1): thread forward only the NON-method-shadowing
  -- schemes, so a method name a user fn shadows keeps resolving to the METHOD
  -- (base env / globalS) for later prelude bindings.  The shadowing scheme is still
  -- RETURNED (second tuple slot) for the scheme dump + final env.
  (extendVars env (dropSchemesNamed methodShadowNamesRef.value schemes), schemes)

-- A multi-member SCC is a mutually-recursive group (always a function group, like
-- the oracle's DLetGroup); a singleton is a plain binding gated on its RHS.  Self-
-- recursive singletons have had their self-edge stripped (filterNonSelf) so they
-- arrive as size-1 SCCs — strict evaluation rules out a self-recursive zero-arg
-- value, so gating them on the RHS is sound and matches the oracle's DFunDef path.
isLetrecGroup : List String -> Bool
isLetrecGroup [] = False
isLetrecGroup [_] = False
isLetrecGroup _ = True

placeholderBinding : (String, Mono) -> (String, Scheme)
placeholderBinding (m, v) = (m, monoScheme v)

-- Extended Pass A: same as preunifySigs but also returns the tyvar maps (for
-- the signature-too-general check after body inference).  Returns a pair:
-- (constraintRegs, sigTvMaps) where sigTvMaps is [(name, sig_ast, tvs)] for
-- each signed member.
preunifySigsEx : List (String, Ty) -> List (String, Mono) -> (List (String, List (String, Mono)), List (String, Ty, List (String, Mono)))
preunifySigsEx _ [] = ([], [])
preunifySigsEx sigs ((m, v)::rest) =
  let (restRegs, restTvs) = preunifySigsEx sigs rest
  match omLookup m sigTyMapRef.value
    Some ty =>
      let inst = instantiateSigTracked ty
      let _ = unify v (fst inst)
      let regs = [(m, constraintVarIfaceMonos (sigConstraints ty) (snd inst))]
      (regs ++ restRegs, (m, ty, snd inst)::restTvs)
    None => (restRegs, restTvs)

-- like astTypeFresh but also returns the tyvar-name → fresh-var map
instantiateSigTracked : Ty -> (Mono, List (String, Mono))
instantiateSigTracked ty =
  let tvs = freshTvMap (removeAllS (rowArgNames ty) (tyVarNamesWithConstraints ty))
  let etbl = freshEffMap (dedup (effTailNames ty ++ rowArgNames ty))
  (fromAstTypeE etbl tvs ty, tvs)

-- the (iface, tyvarName) pairs of a signature's `=>` constraints (each constraint
-- argument that is a single type variable; multi-param/structured args skipped)
sigConstraints : Ty -> List (String, String)
sigConstraints (TyConstrained cs _) = flatMap constraintTyVars cs
sigConstraints _ = []

constraintTyVars : Constraint -> List (String, String)
constraintTyVars (Constraint iface tys) =
  map (n => (iface, n)) (tyVarArgNames tys)

tyVarArgNames : List Ty -> List String
tyVarArgNames [] = []
tyVarArgNames ((TyVar n)::rest) = n :: tyVarArgNames rest
tyVarArgNames (_::rest) = tyVarArgNames rest

-- like constraintVarMonos but KEEPS the iface name paired with each constraint var's
-- mono (slot order preserved), so registerMember can register call-obligation ifaces.
constraintVarIfaceMonos : List (String, String) -> List (String, Mono) -> List (String, Mono)
constraintVarIfaceMonos [] _ = []
constraintVarIfaceMonos ((iface, name)::rest) tvMap = match lookupAssoc name tvMap
  Some mono => (iface, mono) :: constraintVarIfaceMonos rest tvMap
  None => constraintVarIfaceMonos rest tvMap

-- After body inference, register each member's constraint variables by their
-- *surviving* (normalized) tyvar id: in activeDictVars (id → dict param name, for
-- in-body RDict routing) and per-fn in funConstraintsRef (for call-site dict
-- application).  Done per group so a callee's constraints are known before its
-- (later-group) callers infer.
registerConstraintRegs : List (String, List (String, Mono)) -> Unit
registerConstraintRegs [] = ()
registerConstraintRegs ((m, ifaceMonos)::rest) =
  let _ = registerMember m ifaceMonos
  registerConstraintRegs rest

-- register a member's constraints: ids into funConstraintsRef + activeDictVars (the
-- kept/abstract slots), and the SLOT-ALIGNED iface names into funConstraintIfacesRef.
-- registerMemberSlots keeps a slot only when its mono is still an abstract TVar (a
-- body-forced-concrete constraint takes no dict slot); the iface list is filtered the
-- same way so it stays parallel to the id list.
registerMember : String -> List (String, Mono) -> Unit
-- An UNCONSTRAINED member (empty constraint list) gets NO funConstraintsRef /
-- funConstraintIfacesRef entry.  These refs are keyed by BARE NAME and accumulate
-- across the per-module elaboration; an unconstrained top-level fn that shares a
-- name with a constrained one in another module (e.g. array.mdk's `find : (a ->
-- Bool) -> Array a -> Option a` vs core.mdk's `find : Foldable t => …`) would
-- otherwise register a `(find, [])` entry that, prepended later, wins the
-- first-match lookup over core's `(find, [foldableId])`.  inferDictAt then reads 0
-- constraint ids → 0 dict args at the call site → `unbound identifier:
-- $dict_find_0` at eval.  An unconstrained fn is never marked EDictAt, so it needs
-- no entry (mirrors registerInferredFor's empty-ids guard).
registerMember _ [] = ()
registerMember m ifaceMonos =
  let ids = registerMemberSlots m 0 (map snd ifaceMonos)
  let keptIfaces = keptConstraintIfaces ifaceMonos
  let _ = setRef funConstraintsRef ((m, ids)::funConstraintsRef.value)
  setRef funConstraintIfacesRef ((m, keptIfaces)::funConstraintIfacesRef.value)

-- the iface names of the constraints registerMemberSlots KEEPS (mono still a TVar),
-- in the same slot order — parallel to registerMember's id list.
keptConstraintIfaces : List (String, Mono) -> List String
keptConstraintIfaces [] = []
keptConstraintIfaces ((iface, mono)::rest) = match normalize mono
  TVar _ => iface :: keptConstraintIfaces rest
  _ => keptConstraintIfaces rest

-- [kept] is the next dict-param slot; a constraint variable forced concrete by the
-- body takes no dict and doesn't advance the slot (so param names stay 0..k-1,
-- matching dict_pass).
registerMemberSlots : String -> Int -> List Mono -> List Int
registerMemberSlots _ _ [] = []
registerMemberSlots m kept (mono::rest) = match normalize mono
  TVar cell =>
    let id = tyvarId cell
    let _ = setRef activeDictVars ((id, dictParamName m kept)::activeDictVars.value)
    id :: registerMemberSlots m (kept + 1) rest
  _ => registerMemberSlots m kept rest

-- Pass B: infer each member's clauses, unifying with its placeholder.
-- Phase 73 (bidirectional, signature-driven parameter typing): a member WITH a
-- signature peels its declared arrow types onto the clause parameter patterns
-- BEFORE inferring the body, so the body sees concrete parameter types (a
-- receiver-directed field access `f p = p.x` or a `String`-indexed `s.[0]`
-- resolves from the signature alone).  [peel] is Some(placeholder) for a signed
-- member, None otherwise; the placeholder already holds the sig instantiation
-- (preunifySigsEx unified it), and its shared tyvars accumulate unifications
-- across clauses exactly as the oracle's `sig_t` does.  Purely additive: the
-- per-clause `unify v arrow` below imposes the same equalities anyway.
inferMembers : TcEnv -> List (String, Ty) -> OrdMap (List (List Pat, Expr)) -> List (String, Mono) -> Unit
inferMembers _ _ _ [] = ()
inferMembers env sigs grouped ((m, v)::rest) =
  let _ = setRef currentFn m
  let peel = memberPeelSource sigs m v
  let effs = inferMemberClauses env peel v (clausesOf m grouped)
  let _ = setRef currentFn ""
  let _ = checkEffectEscape sigs m effs
  inferMembers env sigs grouped rest

-- the peel source for a member: Some placeholder if it has a signature (peel the
-- declared arrow domains onto the clause params), None otherwise
memberPeelSource : List (String, Ty) -> String -> Mono -> Option Mono
memberPeelSource sigs m v = map (_ => v) (omLookup m sigNameSetRef.value)

-- peel up to [n] arrow domains off [t], normalizing at each level.  A signature
-- with fewer arrows than the clause has params stops early and returns fewer
-- domains (the mismatch then surfaces at the per-clause `unify v arrow`).
peelArrows : Int -> Mono -> List Mono
peelArrows n t
  | n <= 0 = []
  | otherwise = match normalize t
    TFun a _ b => a :: peelArrows (n - 1) b
    _ => []

-- zip-unify the equal-length prefix of param types and peeled sig domains; a
-- shorter [qs] (partial sig) pushes nothing past its end
zipUnify : List Mono -> List Mono -> Unit
zipUnify (p::ps) (q::qs) =
  let _ = unify p q
  zipUnify ps qs
zipUnify _ _ = ()

-- infer each clause, unifying it to the member placeholder [v] and collecting the
-- concrete effect labels the bodies perform (Phase 79e binding-boundary check).
-- [peel] threads the Phase-73 sig peel source (Some placeholder when signed).
inferMemberClauses : TcEnv -> Option Mono -> Mono -> List (List Pat, Expr) -> List Atom
inferMemberClauses _ _ _ [] = []
inferMemberClauses env peel v (cl::rest) =
  let ce = inferClauseEff env peel cl
  let _ = unify v (fst ce)
  atomsUnion (snd ce) (inferMemberClauses env peel v rest)

-- infer one clause, returning its arrow type AND the concrete effect labels its
-- body performs (captured under a fresh open ambient, then the ambient restored —
-- building a closure performs nothing).  Mirrors inferLam but exposes the effect.
-- Phase 73: when [peel] is Some(sig source) and the clause has params, peel the
-- signature's arrow domains and zip-unify them onto the clause param types BEFORE
-- inferring the body (bidirectional checking mode).
inferClauseEff : TcEnv -> Option Mono -> (List Pat, Expr) -> (Mono, List Atom)
inferClauseEff env peel (pats, body) =
  -- Anchor currentLoc to THIS clause's body loc before inferring patterns:
  -- patterns carry no source Loc, so an over-applied-constructor / arity pattern
  -- error would otherwise be recorded at the STALE loc left by the previous
  -- clause's (or a previous function's) body inference — mis-blaming an innocent
  -- sibling clause.  See the twin note in inferLam.
  let _ = match exprLoc body
    Some l => setRef currentLoc (Some l)
    None => ()
  let pr = inferPats env pats
  let _ = peelOntoParams peel (fst pr) pats
  let saved = curEffect.value
  let _ = setRef curEffect (openRow ())
  let bodyTy = infer (extendVars env (snd pr)) body
  let bodyEff = curEffect.value
  let _ = setRef curEffect saved
  (arrowsWithLastEffect (fst pr) bodyEff bodyTy, effrowLabels bodyEff)

-- Phase 73 peel: for a signed clause with params, zip-unify the peeled sig
-- domains onto the inferred param types.  No-op for an unsigned member, a value
-- binding (no params), or a sig with no remaining arrows.
peelOntoParams : Option Mono -> List Mono -> List Pat -> Unit
peelOntoParams None _ _ = ()
peelOntoParams (Some _) _ [] = ()
peelOntoParams (Some src) patTypes pats =
  zipUnify patTypes (peelArrows (listLen pats) src)

-- a signatured binding's body must not perform a concrete effect its signature
-- doesn't declare; effect *variables* (polymorphic `<e>`) carry no labels and so
-- never escape (Phase 79e)
checkEffectEscape : List (String, Ty) -> String -> List Atom -> Unit
checkEffectEscape sigs m effs = match omLookup m sigTyMapRef.value
  None => ()
  Some ty => match atomsEscape effs (declaredEffects ty)
    [] => ()
    extras => pushTypeError "T-EFFECT-LEAK" (effectEscapeMsg m (declaredEffects ty) extras)

effectEscapeMsg : String -> List Atom -> List Atom -> String
effectEscapeMsg name declared extras = "Function '\{name}' declared with <\{renderAtoms declared}> but also performs <\{renderAtoms extras}>"

-- generalize each member's (sig-and-body-unified) placeholder.  A signature was
-- already unified into the placeholder by preunifySigs, so generalizing the
-- result respects it AND any further specialization the body forces (e.g.
-- sum : t a -> a with body `fold (+) 0` reports a Int -> Int, not the raw sig).
-- Value restriction (T1): generalize a member only if it is a *value* —
--   plainVal = isLetrec (multi-member SCC, always a function group) OR every
--              clause has params / a non-expansive zero-arg RHS;
--   sigIsFun = the member is signed AND its (post-unify) type is an arrow
--              (Phase 89 point-free relaxation: a signed arrow-typed point-free
--              binding like `maximum = fold step None` stays generalizable even
--              though its RHS is an application);
--   isVal    = plainVal || sigIsFun.
-- A non-function expansive unsigned binding (`r = Ref []`) is value-restricted and
-- stays monomorphic.  Mirrors oracle lib/typecheck.ml:2705-2710 + 2756.
sccSchemes : List (String, Ty) -> OrdMap (List (List Pat, Expr)) -> Bool -> List (String, Mono) -> List (String, Scheme)
sccSchemes _ _ _ [] = []
sccSchemes sigs grouped isLetrec ((m, v)::rest) =
  let plainVal = isLetrec || allList memberClauseIsValue (clausesOf m grouped)
  let sigIsFun = memberSigIsFun sigs m v
  let isVal = plainVal || sigIsFun
  (m, genRestricted isVal v) :: sccSchemes sigs grouped isLetrec rest

-- a top-level clause is a value if it has params (function) or a non-expansive RHS
memberClauseIsValue : (List Pat, Expr) -> Bool
memberClauseIsValue ([], rhs) = isNonexpansive rhs
memberClauseIsValue (_, _) = True

-- Phase 89: a signed binding whose (post-unify) type is an arrow is generalizable
memberSigIsFun : List (String, Ty) -> String -> Mono -> Bool
memberSigIsFun sigs m v = match omLookup m sigNameSetRef.value
  None => False
  Some _ => match normalize v
    TFun _ _ _ => True
    _ => False

-- ── signature-too-general check ──────────────────────────────────────────────
-- After body inference, the declared signature's type variables must map to
-- DISTINCT TVar refs.  If two declared tyvars (e.g. `a` and `b` in `a -> b`)
-- collapse to the SAME TVar after unification (body forces them equal), the
-- declared signature claims more polymorphism than the body allows.
-- We only reject the "two tvars become one" case (not concrete grounding), so
-- `sum = fold (+) 0` (which grounds one tyvar to Int) passes.
checkSigsTooGeneral : List (String, Ty, List (String, Mono)) -> Unit
checkSigsTooGeneral [] = ()
checkSigsTooGeneral ((m, ty, tvs)::rest) =
  let _ = checkSigTooGeneral m ty tvs
  checkSigsTooGeneral rest

checkSigTooGeneral : String -> Ty -> List (String, Mono) -> Unit
checkSigTooGeneral name ty tvs =
  let tvarIds = sigTvarIds (map snd tvs)
  if hasDupI tvarIds then
    pushTypeError "T-TYPE-TOO-GENERAL" (sigTooGeneralMsg name ty)
  else
    ()

-- collect the TVar ids of those entries in tvs that normalize to a TVar
-- (concrete-grounded entries are skipped — only same-TVar collapses are an error)
sigTvarIds : List Mono -> List Int
sigTvarIds [] = []
sigTvarIds (m::rest) = match normalize m
  TVar cell => tyvarId cell :: sigTvarIds rest
  _ => sigTvarIds rest

-- true if the list has any duplicate Int
hasDupI : List Int -> Bool
hasDupI [] = False
hasDupI (x::xs) = containsI x xs || hasDupI xs

sigTooGeneralMsg : String -> Ty -> String
sigTooGeneralMsg name ty = "Declared signature of '\{name}' is more general than its body. '\{ppTy ty}' claims type variables that are the same type after inference"

-- C3: mirrors lib/typecheck.ml's AnnotationTooGeneral message byte-for-byte.
annotTooGeneralMsg : Ty -> String
annotTooGeneralMsg ty = "Type annotation '"
  ++ ppTy ty
  ++ "' is more polymorphic than the expression. A type variable in the annotation is actually a specific type (or two annotation variables are the same type)"

-- pretty-print an AST type (mirrors lib/ast.ml's pp_ty byte-for-byte)
ppTy : Ty -> String
ppTy (TyCon n _) = n
ppTy (TyVar n) = n
ppTy (TyApp a b) = "\{ppTy a} \{ppTyAtom b}"
ppTy (TyFun a b) = "\{ppTyFunArg a} -> \{ppTy b}"
ppTy (TyTuple ts) = "(" ++ joinWith ", " (map ppTy ts) ++ ")"
ppTy (TyEffect effs tail t) =
  let labs = map ppEffAtomTy effs
  let inside = match tail
    None => joinWith ", " labs
    Some v => match effs
      [] => v
      _ => "\{joinWith ", " labs} | \{v}"
  "<\{inside}> \{ppTy t}"
ppTy (TyConstrained cs t) = "\{ppConstraints cs} => \{ppTy t}"

-- effect atom renderer for ppTy (mirrors OCaml pp_atom inside pp_ty_prec / TEff)
ppEffAtomTy : (String, Option String) -> String
ppEffAtomTy (l, None) = l
-- Intentional cross-file duplicate of the same helper in doc.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
ppEffAtomTy (l, Some s) = if s == "_" then l ++ " _" else "\{l} \{escStr s}"

-- single constraint: no outer parens; multiple: wrap in parens (mirrors OCaml)
ppConstraints : List Constraint -> String
ppConstraints [c] = ppConstraint c
ppConstraints cs = "(" ++ joinWith ", " (map ppConstraint cs) ++ ")"

-- argument of `->`: wrap TyFun (prec>=1) but not TyApp (prec<2)
ppTyFunArg : Ty -> String
ppTyFunArg (TyFun a b) = "(" ++ ppTy (TyFun a b) ++ ")"
ppTyFunArg t = ppTy t

-- argument of application: wrap TyFun (prec>=1) and TyApp (prec>=2)
ppTyAtom : Ty -> String
ppTyAtom (TyFun a b) = "(" ++ ppTy (TyFun a b) ++ ")"
ppTyAtom (TyApp a b) = "(" ++ ppTy (TyApp a b) ++ ")"
ppTyAtom t = ppTy t

ppConstraint : Constraint -> String
ppConstraint (Constraint iface []) = iface
ppConstraint (Constraint iface tys) =
  "\{iface} \{joinWith " " (map ppTyAtom tys)}"

-- ── inferred-constraint promotion (unsignatured `=>` — the two-pass layer) ──
-- After a group is generalized, an UNSIGNATURED eligible member that uses a
-- return-position method (methodSiteFns) — or calls a constrained fn (dictAppFns)
-- — at one of its OWN quantified tyvars carries an INFERRED constraint.  Register
-- it exactly as a signatured one (funConstraintsRef + activeDictVars, keyed by the
-- *surviving* normalized id) so its body's method routes RDict and dict_pass
-- prepends a dict param; and record it in promotedRef so elaborateDict marks its
-- occurrences EDictAt on the next pass.  Signatured members are skipped (their
-- constraints came from preunifySigs); prelude fns are skipped (not eligible).
registerInferredConstraints : List (String, Ty) -> List (String, Scheme) -> Unit
registerInferredConstraints _ [] = ()
registerInferredConstraints sigs ((m, sch)::rest) =
  let _ = maybeInferConstraint sigs m sch
  registerInferredConstraints sigs rest

maybeInferConstraint : List (String, Ty) -> String -> Scheme -> Unit
maybeInferConstraint sigs m sch
  | not (omHasKey m dictEligibleSetRef.value) = ()
  | omHasKey m sigNameSetRef.value = ()
  | otherwise = registerInferredFor m (inferredConstraintIds m (schemeIds sch))

-- #11 soundness (ALWAYS-ON): for each generalized member, record the deferred impl
-- obligations it quantifies over — an addedObls entry whose discriminating mono is a
-- TVar among the member's scheme ids becomes (iface, that id).  A signed member's
-- declared `=>` constraints come from its sig instead (registered via funConstraints);
-- but recording the inferred obligation list here too is harmless (a satisfiable
-- concrete instantiation passes; an unsatisfiable one SHOULD error).  Runs on every
-- path (NOT gated on dictEligibleSetRef), so the plain check path catches the hole.
registerSchemeObligations : List (String, List String, Ty, Mono, Option Loc) -> List (String, Scheme) -> Unit
registerSchemeObligations _ [] = ()
registerSchemeObligations addedObls ((m, sch)::rest) =
  let obs = schemeObligationsOf (schemeIds sch) addedObls
  let _ = if isEmptyL obs then
    ()
  else
    setRef schemeObligationsRef ((m, obs)::schemeObligationsRef.value)
  registerSchemeObligations addedObls rest

-- the (iface, var-id) pairs of the obligations whose discriminating mono is one of
-- this scheme's quantified ids (single-param interfaces only — the obligation's first
-- dispatch arg is the constraint var).  Deduped on (iface, id).
schemeObligationsOf : List Int -> List (String, List String, Ty, Mono, Option Loc) -> List (String, Int)
schemeObligationsOf _ [] = []
schemeObligationsOf boundIds ((iface, typarams, mty, occ, _)::rest) = schemeObligationOne boundIds iface typarams mty occ
  ++ schemeObligationsOf boundIds rest

-- a single obligation contributes (iface, id) iff its (single) dispatch mono is a
-- bound tyvar of the scheme.  Multi-param / non-var-headed dispatch is skipped (left
-- to the existing concrete-obligation checker); this targets the `Num a => a -> a`
-- single-param shape the hole exercises.
schemeObligationOne : List Int -> String -> List String -> Ty -> Mono -> List (String, Int)
schemeObligationOne boundIds iface typarams mty occ = match dispatchMonosOf typarams mty occ
  [d] => match normalize d
    TVar cell =>
      if containsI (tyvarId cell) boundIds then
        [(iface, tyvarId cell)]
      else
        []
    _ => []
  _ => []

schemeIds : Scheme -> List Int
schemeIds (Forall ids _ _) = ids

-- ── signature-constraint soundness check ─────────────────────────────────────
-- For each SIGNED member, the interface constraints its body INFERS on the
-- member's own quantified vars must be covered by the DECLARED `=>` context,
-- closed under the interface `requires` (superclass) graph.  An uncovered
-- inferred constraint ⇒ def-site type_error (the constraint analogue of
-- checkEffectEscape).  Single-param `C a` shape only (skips multi-param); the
-- inferred obligations are the UNION of the flat-path (schemeObligationsOf over
-- addedObls) and the marked-path (inferredConstraintIds + ifaceForInferredId)
-- sources — a return-position-method constraint lands only in the latter.
checkSigConstraintCoverage : List (String, List (String, Mono)) -> List (String, Ty) -> List (String, Ty, List (String, Mono)) -> List (String, List String, Ty, Mono, Option Loc) -> List (String, Scheme) -> Unit
checkSigConstraintCoverage _ _ _ _ [] = ()
checkSigConstraintCoverage regs sigs sigTvMaps addedObls ((m, sch)::rest) =
  let _ = checkSigConstraintOne regs sigs sigTvMaps addedObls m sch
  checkSigConstraintCoverage regs sigs sigTvMaps addedObls rest

checkSigConstraintOne : List (String, List (String, Mono)) -> List (String, Ty) -> List (String, Ty, List (String, Mono)) -> List (String, List String, Ty, Mono, Option Loc) -> String -> Scheme -> Unit
checkSigConstraintOne regs sigs sigTvMaps addedObls m sch = match omLookup m sigTyMapRef.value
  None => ()   -- unsigned member: its inferred constraints are promoted, not checked
  Some _ =>
    let declared = censusSuperClose superDeclsRef.value (declaredPairsFor m regs)
    let inferredA = schemeObligationsOf (schemeIds sch) addedObls
    let inferredB = inferredIfacePairs m (schemeIds sch)
    let inferred = dedupPairs (inferredA ++ inferredB)
    reportUncovered m sigTvMaps declared inferred

-- inferred (iface, id) pairs from the marked path: each inferred constraint var id
-- paired with its recovered iface (skip an id whose iface can't be recovered).
inferredIfacePairs : String -> List Int -> List (String, Int)
inferredIfacePairs m boundIds =
  flatMap (pairIface m) (inferredConstraintIds m boundIds)

pairIface : String -> Int -> List (String, Int)
pairIface m id = match ifaceForInferredId m id
  "" => []
  iface => [(iface, id)]

-- the declared (iface, id) constraint pairs of member m: each declared constraint
-- mono normalized to its surviving tyvar id (single-param shape; concrete-grounded
-- constraints — no tyvar — carry no dict slot and are skipped).
declaredPairsFor : String -> List (String, List (String, Mono)) -> List (String, Int)
declaredPairsFor m regs = match lookupAssoc m regs
  None => []
  Some ifaceMonos => flatMap declaredPairOne ifaceMonos

declaredPairOne : (String, Mono) -> List (String, Int)
declaredPairOne (iface, mono) = match normalize mono
  TVar cell => [(iface, tyvarId cell)]
  _ => []

-- UNGATED transitive super-closure over declared (iface, id) slots — mirrors
-- expandSupersPairs but WITHOUT the userIfaceNamesRef gate, so prelude super chains
-- (Applicative requires Mappable, Thenable requires Applicative, …) are included.
-- (The gated expandSupersPairs stays user-only because its slots drive dict arity;
-- this closure only feeds the read-only subset test, so gating is not needed here.)
censusSuperClose : List Decl -> List (String, Int) -> List (String, Int)
censusSuperClose allDecls declared =
  censusSuperCloseFix allDecls declared declared

censusSuperCloseFix : List Decl -> List (String, Int) -> List (String, Int) -> List (String, Int)
censusSuperCloseFix allDecls acc frontier =
  let next = dedupPairs (acc ++ flatMap (censusSuperSlotsOf allDecls) frontier)
  if listLen next == listLen acc then
    acc
  else
    censusSuperCloseFix allDecls next (dropPairs (listLen acc) next)

censusSuperSlotsOf : List Decl -> (String, Int) -> List (String, Int)
censusSuperSlotsOf allDecls (iface, id) = match ifaceSupersOf allDecls iface
  None => []
  Some (typarams, supers) =>
    let subst = zipL typarams (replicate (listLen typarams) id)
    flatMap (superSlotOf subst) supers

-- one type_error per inferred (iface, id) not covered by the declared-closed set.
reportUncovered : String -> List (String, Ty, List (String, Mono)) -> List (String, Int) -> List (String, Int) -> Unit
reportUncovered _ _ _ [] = ()
reportUncovered m sigTvMaps declared ((iface, id)::rest) =
  let _ = if containsPair (iface, id) declared then
    ()
  else
    pushTypeError "T-MISSING-CONSTRAINT" (missingConstraintMsg m iface (varNameForId sigTvMaps m id))
  reportUncovered m sigTvMaps declared rest

containsPair : (String, Int) -> List (String, Int) -> Bool
containsPair _ [] = False
containsPair (i, d) ((i2, d2)::rest) = i == i2 && d == d2
  || containsPair (i, d) rest

-- recover the sig-tyvar NAME for a constraint var id (for a readable message);
-- falls back to "a" if the id isn't found among the member's sig tyvars.
varNameForId : List (String, Ty, List (String, Mono)) -> String -> Int -> String
varNameForId sigTvMaps m id = match findSigTvMap m sigTvMaps
  None => "a"
  Some tvMap => match findTvName id tvMap
    None => "a"
    Some n => n

findSigTvMap : String -> List (String, Ty, List (String, Mono)) -> Option (List (String, Mono))
findSigTvMap _ [] = None
findSigTvMap m ((n, _, tvMap)::rest)
  | n == m = Some tvMap
  | otherwise = findSigTvMap m rest

findTvName : Int -> List (String, Mono) -> Option String
findTvName _ [] = None
findTvName id ((n, mono)::rest) = match normalize mono
  TVar cell => if tyvarId cell == id then Some n else findTvName id rest
  _ => findTvName id rest

missingConstraintMsg : String -> String -> String -> String
missingConstraintMsg name iface varName = "Could not deduce '\{iface} \{varName}' from the signature of '\{name}'. Its body requires it; add '\{iface} \{varName} =>' to the declared type"

-- the member's own quantified tyvar ids that a body method site / propagated
-- constrained-call sits at (deduped, slot order = discovery order)
inferredConstraintIds : String -> List Int -> List Int
inferredConstraintIds m boundIds =
  dedupI
    (flatMap (boundTvarId boundIds) (sitesFor m methodSiteFns.value) ++ flatMap (monosTvarIds boundIds) (sitesFor m dictAppFns.value))

monosTvarIds : List Int -> List Mono -> List Int
monosTvarIds boundIds monos = flatMap (boundTvarId boundIds) monos

-- [mono] normalizing to a tyvar this scheme generalized → that (constraint var)
-- id; a pinned-concrete or foreign var → none
boundTvarId : List Int -> Mono -> List Int
boundTvarId boundIds mono = match normalize mono
  TVar cell => if containsI (tyvarId cell) boundIds then [tyvarId cell] else []
  _ => []

registerInferredFor : String -> List Int -> Unit
registerInferredFor _ [] = ()
registerInferredFor m ids =
  let _ = setRef funConstraintsRef ((m, ids)::funConstraintsRef.value)
  let _ = setRef funConstraintIfacesRef ((m, map (ifaceForInferredId m) ids)::funConstraintIfacesRef.value)
  let _ = registerActiveDictVars m 0 ids
  setRef promotedRef (m::promotedRef.value)

-- #23: the iface name for an inferred constraint var.  `ifaceForConstraintId` only
-- recovers it from a pendingImplObligation whose `occ` is a BARE `TVar id`; a
-- constraint induced by a `fromInt`/method site records a COMPOUND occ (the whole
-- method type), so it returns "" — leaving the call site's dict route unkeyed
-- (`routeUndeterminedTop ""` → RNone → a NULL Num dict word → build SIGTRAP, while
-- `medaka run` is correct).  Two FALLBACKS recover the name when ifaceForConstraintId
-- returns "" (so existing non-"" routes stay byte-identical):
--   (1) `schemeObligationsRef` pairs each scheme var with its iface via
--       `dispatchMonosOf` (robust to compound occs); covers a fn whose own body has
--       the literal/method site (`app2 f = f 2 3`).
--   (2) a constraint FORWARDED from a constrained callee (`useApp g = app2 g`) never
--       lands in pendingImplObligations/schemeObligations — its iface lives in the
--       `pendingDictApps` entry the callee's inferDictAtFound recorded (slot-parallel
--       monos/ifaces).  Scan it for the var at a slot whose iface is now known.
-- Both run AFTER the callee's own constraints are registered (topological SCC order),
-- so the forwarded callee's ifaces are populated.
ifaceForInferredId : String -> Int -> String
ifaceForInferredId m id =
  let direct = ifaceForConstraintId id
  if direct != "" then direct
  else match lookupSchemeIface m id schemeObligationsRef.value
    Some s => s
    None => ifaceFromDictApps id pendingDictApps.value

lookupSchemeIface : String -> Int -> List (String, List (String, Int)) -> Option String
lookupSchemeIface _ _ [] = None
lookupSchemeIface m id ((m2, obs)::rest)
  | m == m2 = match lookupIfaceById id obs
    Some iface => Some iface
    None => lookupSchemeIface m id rest
  | otherwise = lookupSchemeIface m id rest

lookupIfaceById : Int -> List (String, Int) -> Option String
lookupIfaceById _ [] = None
lookupIfaceById id ((iface, oid)::rest)
  | id == oid = Some iface
  | otherwise = lookupIfaceById id rest

-- Scan pendingDictApps for [id] at a slot (bare-TVar mono) whose iface is non-empty.
ifaceFromDictApps : Int -> List (Ref (List Route), List Mono, List String) -> String
ifaceFromDictApps _ [] = ""
ifaceFromDictApps id ((_, monos, ifaces)::rest) = match ifaceAtMonoId id monos ifaces
  Some s => s
  None => ifaceFromDictApps id rest

ifaceAtMonoId : Int -> List Mono -> List String -> Option String
ifaceAtMonoId _ [] _ = None
ifaceAtMonoId _ _ [] = None
ifaceAtMonoId id (m::ms) (i::is) = match normalize m
  TVar cell =>
    if tyvarId cell == id && i != "" then
      Some i
    else
      ifaceAtMonoId id ms is
  _ => ifaceAtMonoId id ms is

-- recover the interface name of an INFERRED constraint var (unsignatured fn like
-- `f x = x + 1`): the var was recorded in a pendingImplObligation by the method
-- occurrence that induced the constraint (`+` → a `Num <thisvar>` entry).  Slot-
-- aligned with registerInferredFor's id list.  "" if unresolvable — recordCallObligations
-- still pairs it positionally, and checkOneCallObligation with an empty iface finds no
-- matching impl head ⇒ it only fires for a CONCRETE-head mono whose iface genuinely had
-- no impl, which for an inferred Num constraint is exactly the hole we close.  A still-
-- polymorphic head defers regardless of iface, so a blank iface never over-rejects.
ifaceForConstraintId : Int -> String
ifaceForConstraintId id = ifaceForConstraintIdGo id pendingImplObligations.value

ifaceForConstraintIdGo : Int -> List (String, List String, Ty, Mono, Option Loc) -> String
ifaceForConstraintIdGo _ [] = ""
ifaceForConstraintIdGo id ((iface, _, _, occ, _)::rest) = match normalize occ
  TVar cell =>
    if tyvarId cell == id then
      iface
    else
      ifaceForConstraintIdGo id rest
  _ => ifaceForConstraintIdGo id rest

registerActiveDictVars : String -> Int -> List Int -> Unit
registerActiveDictVars _ _ [] = ()
registerActiveDictVars m slot (id::rest) =
  let _ = setRef activeDictVars ((id, dictParamName m slot)::activeDictVars.value)
  registerActiveDictVars m (slot + 1) rest

-- Render accumulated type errors as `TYPE ERROR: <msg>` lines (in order of
-- occurrence — typeErrors accumulates newest-first, so reverse).
typeErrorLines : List String -> List String
typeErrorLines [] = []
typeErrorLines (e::rest) = "TYPE ERROR: " ++ e :: typeErrorLines rest

export checkToLines : List Decl -> String
checkToLines prog =
  let schemes = checkProgramSchemes [] prog
  let _ = checkCoherence prog
  let _ = checkInterfaceCycles prog
  let _ = checkPhantomMethods prog
  let _ = checkSuperImpls prog prog
  let errs = reverseL typeErrors.value
  match errs
    [] => joinNl (schemeLines schemes)
    _ => joinNl (typeErrorLines (map teErrMsg errs))
-- coherence over the WHOLE prog: this path (typecheck_main single-arg) is
-- prelude-free, so every impl is a user impl (mirrors check_program_no_prelude).

-- like checkToLines but seeds runtime.mdk's externs (for typechecking core.mdk,
-- which references putStrLn / etc. declared in runtime.mdk).  [coreProg] is the PRELUDE
-- the caller would otherwise have pre-concatenated onto [userProg]; keeping the two
-- apart is what lets the flat path scope shadow-hood per module (SHADOW-SEMANTICS S1 —
-- see flatShadowScopingRef).  Prelude-free callers pass [].
export checkToLinesWithRuntime : List Decl -> List Decl -> List Decl -> String
checkToLinesWithRuntime runtimeDecls coreProg userProg =
  let prog = coreProg ++ userProg
  let _ = setRef implInferEnabled False
  let _ = setRef matchWarnings []
  let _ = setRef matchOracle (buildOracle prog)
  let schemes = checkProgramSeededSplit (externSchemes runtimeDecls) coreProg userProg
  let _ = checkCoherence coherenceUserDecls.value
  let _ = checkInterfaceCycles prog
  let _ = checkPhantomMethods coherenceUserDecls.value
  let _ = checkSuperImpls coherenceUserDecls.value prog
  let errs = reverseL typeErrors.value
  let warns = reverseL matchWarnings.value
  match errs
    [] => joinNl (schemeLines schemes ++ warns)
    _ => joinNl (typeErrorLines (map teErrMsg errs))
-- B5: seed the exhaustiveness oracle and clear any stale match warnings so the
-- composed check.mdk path surfaces non-exhaustive-match warnings, mirroring the
-- OCaml oracle's `medaka check` output.

-- coherence over the USER decls the driver staged (NO prelude) — empty when the
-- driver staged nothing (golden/profile paths) ⇒ no check, byte-identical.

-- G1 (SOUNDNESS): does the runtime-seeded typecheck pass produce any TYPE ERROR?
-- Mirrors checkToLinesWithRuntime's side-effects EXACTLY (same seeding + coherence
-- over the same staged user decls) but returns a Bool keyed on the typeErrors
-- accumulator, ignoring the success-path scheme dump and the match WARNINGS (which
-- are not errors).  Used by check.mdk's checkHasErrors to gate the CLI exit code
-- WITHOUT altering runCheck's reported stdout.
export checkErrorsWithRuntime : List Decl -> List Decl -> List Decl -> Bool
checkErrorsWithRuntime runtimeDecls coreProg userProg =
  let prog = coreProg ++ userProg
  let _ = setRef implInferEnabled False
  let _ = setRef matchWarnings []
  let _ = setRef matchOracle (buildOracle prog)
  let _ = checkProgramSeededSplit (externSchemes runtimeDecls) coreProg userProg
  let _ = checkCoherence coherenceUserDecls.value
  let _ = checkInterfaceCycles prog
  let _ = checkPhantomMethods coherenceUserDecls.value
  let _ = checkSuperImpls coherenceUserDecls.value prog
  match typeErrors.value
    [] => False
    _ => True

-- ── type-aware non-exhaustive-match check (the `check_match` driver) ────────
-- Run the full typecheck pass over [prog] (runtime externs seeded, NO prelude —
-- mirrors the reference's check_program_no_prelude oracle) and return one
-- `Warning: non-exhaustive match …` line per `match` that isn't exhaustive.
-- The oracle is built from the program's own data decls + the syntactic builtins
-- (same set check_match's env-backed oracle has in the no-prelude path).  Diffs
-- against `dev/diagdump.exe --check-match` (the harness sorts).
export checkMatchToLines : List Decl -> List Decl -> String
checkMatchToLines runtimeDecls prog =
  let _ = setRef matchWarnings []
  let _ = setRef matchOracle (buildOracle prog)
  let _ = checkProgramSeeded (externSchemes runtimeDecls) prog
  joinNl (reverseL matchWarnings.value)

-- ── diagnostics entry point (compiler/diagnostics.mdk bridge) ────────────
-- Run the full typecheck pass (runtime-seeded) over [prog] and return the raw
-- error strings — each paired with its captured `Option Loc` (B.10.2b) — plus
-- the warning strings (each paired with its captured `Option Loc`, S4), so
-- diagnostics.mdk can wrap them in structured Diag values carrying the span.
export checkProgramDiags : List Decl -> List Decl -> List Decl -> (List (String, String, Option Loc), List (String, Option Loc))
checkProgramDiags runtimeDecls coreProg userProg =
  let prog = coreProg ++ userProg
  let _ = setRef implInferEnabled False
  let _ = setRef matchWarnings []
  let _ = setRef matchWarningLocs []
  let _ = setRef matchOracle (buildOracle prog)
  let _ = checkProgramSeededSplit (externSchemes runtimeDecls) coreProg userProg
  let _ = checkCoherence coherenceUserDecls.value
  let _ = checkInterfaceCycles prog
  let _ = checkPhantomMethods coherenceUserDecls.value
  let _ = checkSuperImpls coherenceUserDecls.value prog
  (
    reverseL typeErrors.value,
    zipL (reverseL matchWarnings.value) (reverseL matchWarningLocs.value),
  )

-- ── multi-module typecheck (bootstrap front-end) ───────────────────────────
-- Threads per-module exports in dependency order.  The prelude (core) is checked
-- ONCE and ALL its schemes + ctors seed every module (it's implicitly visible);
-- each compiler module then contributes only its PUBLIC value schemes — private
-- helpers stay module-local, so same-named helpers across modules never collide
-- (the per-module-frame property, without a frame) — plus its public ctors.
-- Returns each module's OWN value schemes, in load order.

-- typecheck one program with seeded value schemes + accumulated data decls.
-- Like checkProgramSeeded but ALSO re-registers prior modules' public data decls
-- (`accData ++ prog`) so imported constructors AND named-field-variant record
-- info (e.g. ast's DInterface) resolve.  Returns the module's own value schemes.
checkModuleFull : List (String, Scheme) -> List Decl -> List Decl -> List (String, Scheme)
checkModuleFull seedVars accData prog =
  checkModuleFullImpl "" seedVars accData [] prog

-- E5: like checkModuleFull but takes [implDecls] (core + every EARLIER module +
-- this module) as the impl-body inference universe.  Under implInferEnabled (the
-- emitArgStampPasses emit path ONLY) it ALSO infers THIS module's parametric impl
-- bodies — mirroring checkProgramSeeded's inferImplBodiesIfEnabled — so their
-- ARG-position ELEMENT dispatch (`eq`/`compare`/… on the impl head tyvar) reaches
-- inferMethodAt and lands in pendingArgStamps, which elabModuleStamp's
-- resolveArgStamps then stamps RDict (via the requires dict registered by
-- registerImplRequires).  [implDecls] gives ifaceMethodTy the interface decls
-- (core's Eq/Ord/…) AND lets a body dispatch against an earlier module's impl.
-- OFF (every golden module driver), this is exactly checkModuleFull pre-E5:
-- implInferEnabled is False → no inference, no extra stamping, byte-identical.
checkModuleFullImpl : String -> List (String, Scheme) -> List Decl -> List Decl -> List Decl -> List (String, Scheme)
checkModuleFullImpl mid seedVars accData implDecls prog =
  let _ = resetState ()
  let importerShadows = buildStandaloneShadows implDecls prog
  -- Scan the FULL visible universe (accData carries core's interfaces + earlier
  -- modules' PUBLIC ones, prog this module) for interface-method names, NOT just
  -- [implDecls] — the check path passes implDecls=[] (checkModuleFull), so a bare
  -- `allIfaceMethodNames implDecls` left this EMPTY there and a local funDef
  -- shadowing a prelude method (parser.mdk's own `orElse`, a plain
  -- `Parser a -> Parser a -> Parser a`) was NOT recognised as a definer shadow →
  -- recordImplObligation fired a spurious `No impl of Alternative for Parser`.
  let definerShadows = buildDefinerShadows (accData ++ implDecls ++ prog) prog
  let _ = setRef standaloneValuesRef (dedup (importerShadows ++ definerShadows))
  let _ = setRef definerShadowNamesRef definerShadows
  -- P0-19: stash this module's standalone signatures so inferDefinerShadowApp can
  -- enforce a definer-shadow standalone's declared domain on a no-impl / ungrounded
  -- receiver (shadowKeyTableRef, set just below, gates dispatch-vs-standalone).
  let _ = setRef definerShadowSigsRef (sigsOf prog)
  -- Bug C: stash each importer shadow's IMPORTED STANDALONE scheme (e.g. `toList` →
  -- `Map k v -> List (k, v)`) BEFORE env1 rebinds the name to the interface-method
  -- scheme, so inferAppExpr can recover the standalone result type for a no-impl
  -- receiver.  seedVars carries BOTH core's method scheme (`t a -> List a`) and map's
  -- standalone — pickStandaloneSchemes selects the one whose receiver (first arrow
  -- domain) has a CONCRETE head tycon (the standalone), never the polymorphic method
  -- scheme (which would unify `t a ~ Map String Int` → `a ↦ Int`, giving the wrong
  -- `List Int` result element type).
  let _ = setRef shadowStandaloneSchemesRef (pickStandaloneSchemes importerShadows seedVars)
  -- P0-18 (importer residual): include THIS module's own impls so inferShadowApp's
  -- `implExistsForHead` sees a LOCAL impl of the shadowed interface (the `impl
  -- Sizeable Box` lives in `prog`, not the imported [implDecls]).  Without it an
  -- importer shadow applied to a live-impl receiver (`size (Box 3)`) found no impl,
  -- fell through to the standalone (`Int -> Int`), and mis-typed `Box vs Int`.  Emit
  -- is unaffected (the importer path is unreachable there — standaloneValues empty).
  -- P0-19 d8 (S6): ALSO scan `accData` (prior modules' PUBLIC decls, incl. exported
  -- `DImpl`) so a DEFINER shadow whose interface + receiver impl are IMPORTED
  -- (`import prov.{Sizeable, Box(..)}`, local `size : Int -> Int`) dispatches to the
  -- imported impl for `size (Box 3)` and falls to the standalone for `size 3`.  The
  -- impl universe is GLOBAL (local ∪ imported ∪ prelude) — mirrors buildDefinerShadows
  -- / registerMethodIfaceParamsAll above, which already scan `accData ++ implDecls ++
  -- prog`.  Without this, batch-1's enforceStandaloneDomain saw no impl for `Box` and
  -- forced the standalone domain `Int` onto it → the row-14 `Int vs Box` reject.
  let _ = setRef shadowKeyTableRef (buildKeyTable (accData ++ implDecls ++ prog))
  let _ = setRef methodDispatchIdxRef (argDispatchIndices implDecls)
  let _ = setRef funConstraintsRef crossModuleFunConstraintsRef.value
  let _ = setRef funConstraintIfacesRef crossModuleFunConstraintIfacesRef.value
  -- IMPORT ALIASING: both tables above are keyed by the name AT THE CALL SITE, but an
  -- alias makes that name differ from the DEFINITION's.  Re-key each aliased origin's
  -- entry under the LOCAL name this module actually writes, or a constrained callee
  -- reached through an alias finds NO entry → zero dict routes → a silently
  -- under-applied partial closure (the Phase-134 failure mode: `check` green, `run`
  -- dies with "putStrLn: not a String").  Prepended so it wins the first-match.
  --
  -- Driven off the (definerMid, name) QUALIFIED tables, so only the ALIASED module's
  -- own entries are ever copied — a same-named constrained fn in some other module can
  -- never be picked up by mistake.
  let _ = setRef funConstraintsRef (aliasConstraintEntries prog crossModuleFunConstraintsQualRef.value
    ++ funConstraintsRef.value)
  let _ = setRef funConstraintIfacesRef (aliasConstraintEntries prog crossModuleFunConstraintIfacesQualRef.value
    ++ funConstraintIfacesRef.value)
  -- WS-2/D2: map THIS module's imported value names to their import-source module id,
  -- so inferDictAtFound can route a cross-module constrained callee's dict arity by
  -- module identity (the qual tables) rather than the collision-prone bare first-match.
  let _ = setRef currentImportDefinersRef (importDefinersOf prog)
  -- #11 soundness: register the interface method→iface-param map over the FULL
  -- visible universe (accData carries core's + earlier modules' PUBLIC interfaces,
  -- implDecls the emit-path impl universe, prog this module).  The check path passes
  -- implDecls=[] (checkModuleFull), so registering only [implDecls] left
  -- methodIfaceParamsRef EMPTY → `Num`/`fromInt` unregistered → a numeric literal's
  -- Num obligation (recordImplObligation) was silently dropped and the reject
  -- suppressed (ifaceRegistered False) → cross-module `g [1,2] 5` over-accepted.
  let _ = registerMethodIfaceParamsAll (accData ++ implDecls ++ prog)
  let dataEnv = registerAllData initialEnv (accData ++ prog)
  let _ = rejectCyclicAliases ()
  let globalS = ifaceMethodSchemes prog ++ externSchemes prog
  let shadowMethodSchemes = pickSchemes importerShadows (ifaceMethodSchemes implDecls)
  let _ = setRef methodConstraintsRef (methodConstraintsRef.value ++ crossModuleMethodConstraintsRef.value)
  let env1 = extendVars (extendVars (extendVars dataEnv seedVars) globalS) shadowMethodSchemes
  let defs = funDefs prog
  let sigs = sigsOf prog
  let topSchemes = processTopGroups env1 sigs defs (groupNames defs omEmpty)
  let _ = inferModuleImplBodiesIfEnabled (extendVars env1 topSchemes) implDecls prog
  let _ = inferDefaultBodiesIfEnabled (extendVars env1 topSchemes) prog
  let _ = inferPropBodies (extendVars env1 topSchemes) prog
  let _ = inferTestBodies (extendVars env1 topSchemes) prog
  -- WS-1b: append each constrained fn's transitive super slots to funConstraintsRef/
  -- funConstraintIfacesRef NOW (after this module's inference, before the cross-module
  -- + qualified mirrors snapshot it below) so every downstream reader — the qual ref
  -- seed, dictArityOf (define side), and elabModuleStamp's route resolution (call side)
  -- — sees identical expanded entries.  superDeclsRef carries the in-scope interfaces.
  let _ = expandSupersTable superDeclsRef.value
  let _ = setRef crossModuleFunConstraintsRef funConstraintsRef.value
  -- WS-2/D2: attribute THIS module's constrained-fn arities to mid in the qualified
  -- mirror.  Every fn DEFINED in [prog] that carries an entry in the (now this-module-
  -- accumulated) funConstraintsRef is owned by [mid]; record ((mid,name),ids) so the
  -- final scopeAritiesQual keeps only the in-scope module's arity (dissolves the
  -- bare-name cross-module collision).  PREPEND so the per-module-current entry wins
  -- the first-match if a name recurs across the graph.
  let _ = setRef crossModuleFunConstraintsQualRef
            (attributeModuleArities mid prog funConstraintsRef.value ++ crossModuleFunConstraintsQualRef.value)
  -- WS-2/D2: the slot-parallel ifaces analog of the qual arity snapshot above, keyed by
  -- the same (mid,name), so inferDictAtFound reads a cross-module callee's ids AND ifaces
  -- from one definer-aligned source.  funConstraintIfacesRef here is this module's
  -- super-EXPANDED ifaces (expandSupersTable ran above), matching the expanded ids.
  let _ = setRef crossModuleFunConstraintIfacesQualRef
            (attributeModuleArrIfaces mid prog funConstraintIfacesRef.value ++ crossModuleFunConstraintIfacesQualRef.value)
  let _ = setRef crossModuleFunConstraintIfacesRef funConstraintIfacesRef.value
  let _ = setRef crossModuleMethodConstraintsRef methodConstraintsRef.value
  -- WS-2/D2 (method analog of the qual snapshot above): attribute each method whose
  -- INTERFACE is declared in [prog] to [mid], so scopeMethodArities can keep only the
  -- in-scope module's arity for a bare method name shared across modules.  PREPEND so
  -- the per-module-current entry wins first-match.  The prog-filter is essential: an
  -- IMPORTING module's methodConstraintsRef carries the cross seed (line above), so
  -- without it the method would be re-attributed to every importer's mid → false twins.
  let _ = setRef crossModuleMethodConstraintsQualRef
            (attributeMethodModuleArities mid prog methodConstraintsRef.value ++ crossModuleMethodConstraintsQualRef.value)
  let _ = groundMultiParamObligations implDecls pendingImplObligations.value
  -- P0-17: reject an impl missing a required (non-defaulted) method.  UNGATED (runs
  -- on BOTH the check path AND the emit/eval path, unlike checkImplObligations
  -- below): a purely structural interface-method-set vs impl-method-set comparison,
  -- so run/build reject the impl cleanly here instead of deferring to a runtime
  -- `unbound identifier` panic.  Iterate THIS module's own decls; resolve the
  -- interface (possibly imported) in the full accumulated universe.
  let _ = checkImplCompleteness (accData ++ implDecls ++ prog) prog
  -- #11 soundness: on the TYPECHECK path (implInferEnabled OFF — `medaka check`,
  -- the diagnostics/golden drivers) validate each call site's instantiated impl
  -- obligations (incl. a numeric literal's `Num` obligation forced to a non-Num
  -- type) and stamp Float-typed literals, mirroring the single-file checkProgramSeeded
  -- and the oracle's typecheck_module finalize.  Without this the cross-module check
  -- path silently dropped a literal's `Num` obligation (`g [1,2] 5` forcing
  -- `5 : List (List Int)`).  Gated OFF on the EMIT path: elabModuleStamp runs its own
  -- setNumlitFloats AFTER arg-stamp resolution (calling it here would double-stamp),
  -- and checkImplObligations is a check-only diagnostic the emit driver doesn't want.
  let _ = if not implInferEnabled.value then
            let _ = checkImplObligations (accData ++ implDecls ++ prog) pendingImplObligations.value
            setNumlitFloats ()
          else ()
  let _ = checkCallObligations (accData ++ implDecls ++ prog) pendingCallObligations.value
  -- LSP hover: leave THIS module's locals + seed (runtime+core+imports) in the
  -- side-channels, mirroring checkProgramSeeded.  The entry module is checked
  -- LAST in the multi-module path, so the channels end holding ITS values, which
  -- is what project-aware hover reads (imported names live in seedVars).
  let _ = setRef localSchemesOut (mapLocalSchemes localBindRefs.value)
  let _ = setRef seedSchemesOut seedVars
  globalS ++ topSchemes
-- C5: compute this module's standalone-shadow set BEFORE inference, so the
-- inferMethodAt arg-position record can gate on it (resetState cleared it via
-- pendingRLocalSites, but standaloneValuesRef is set fresh here per module).
--
-- Two flavours of standalone-shadow, BOTH needing RLocal recording so a method
-- call on a no-impl receiver routes to the standalone instead of mis-dispatching:
--   • IMPORTER shadow (`importerShadows`): a name imported from a sibling that is
--     also an interface method (box importing map's `toList`).  Its scheme must be
--     REBOUND to the interface-method scheme (`shadowMethodSchemes`) so the call
--     site types polymorphically; RLocal then redirects the no-impl receiver back.
--   • DEFINER shadow (`definerShadows`): a name THIS module defines as a top-level
--     funDef that ALSO names an interface method (map-as-root's own `toList` /
--     `isEmpty`).  The MARK pass (`buildStandaloneShadowsGraph`) rewrites these to
--     `EMethodAt`, so without a matching RLocal record the route falls back to the
--     result-type `RKey` (e.g. `toList`'s `List` result), dispatching the method on
--     the WRONG impl (List's `toList = identity`) → `debug`/`display` recurse on the
--     unchanged receiver forever (Map Debug/Eq/Ord impl bodies call standalone
--     `toList`).  These must be RECORDED for RLocal but must NOT be rebound to the
--     method scheme — their local standalone scheme (`Map k v -> …`) is what the
--     impl body types against.

-- E6: re-install the cross-module constraint accumulator that resetState just
-- wiped, so this module's `=>`-constrained call sites into EARLIER modules resolve.
-- Post-ARGSTAMP-UNIFY (Phase 4): eval and emit both thread dicts, so this runs
-- UNCONDITIONALLY on both paths (was `emitArgStampPasses || evalDictLayerActive`, an
-- always-True tautology since evalDictLayerActive = not emitArgStampPasses).

-- resetState wiped methodIfaceParamsRef; re-register it from the FULL impl
-- universe [implDecls] (core/earlier modules ++ this prog) so resolveSite's
-- ifaceParamMonos can recover a multi-param interface's full param monos (the
-- element grounding `e` for `FromEntries c e`).  The flat checkProgramSeeded does
-- the same against its whole-program [prog].  Without it the module path leaves the
-- table empty → ifaceParamMonos returns None → a Set/Map-literal return-position
-- `fromEntries` route drops its `Ord` element dict → null dict → SIGSEGV.

-- C5: a standalone-shadow method name (box's `toList`/`isEmpty`) is bound in
-- seedVars to its imported MONOMORPHIC standalone scheme (`Box k v -> …`), which
-- would shadow the polymorphic interface-method scheme and mis-type a genuine
-- method call (`isEmpty [1,2,3]` unifying List with Box).  Re-bind those names to
-- the graph-wide METHOD scheme so the call site types against the method (oracle
-- behaviour); RLocal then redirects only the no-impl receiver back to the standalone
-- at eval.  Mirrors lib/typecheck.ml: the EApp method-head arm types against the
-- method scheme even when standalone_values holds the name.
-- DEFINER shadows are EXCLUDED here: the module's OWN funDef (map-root's `toList`)
-- must type against its local standalone scheme (`Map k v -> List (k, v)`), not the
-- imported method scheme — the impl bodies call it ON a Map.  Only IMPORTER shadows
-- (imported-from-sibling method names) get the method-scheme rebind.

-- E5: infer this module's parametric impl bodies (gated, emit path only), seeing
-- [implDecls] for interface method types + cross-module impl dispatch.  The sites
-- it records stay in pendingArgStamps/pendingSites for elabModuleStamp to resolve.

-- C8(b): also infer THIS module's interface DEFAULT bodies (gated identically to
-- the single-file path's inferDefaultBodiesIfEnabled) so a default body's type
-- error is caught on the module path too — mirrors checkProgramSeeded.

-- Phase 4.55 (mirror checkProgramSeeded + lib/typecheck.ml:4254-4262): infer this
-- module's prop bodies so their prepass-marked EDictAt/EMethodAt routes resolve.
-- The multi-module test path (runPropsMulti) evaluates the ELABORATED prop body
-- against the dict-passed env, so the body's calls into the file's own promoted
-- `=>`-constrained fns (set's `wellFormed`/`fromList`) need their dict-arg routes
-- filled here — otherwise the call under-applies the dict-passed callee → not VBool
-- → every prop "fails".  funDefs ignores DProp, so without this the module path
-- never typed props at all.

-- E6: fold THIS module's freshly-registered fn-constraints into the cross-module
-- accumulator so a LATER module's call site finds them after its own reset.
-- Post-ARGSTAMP-UNIFY (Phase 4): unconditional on both paths (was the always-True
-- `emitArgStampPasses || evalDictLayerActive`).

-- Shape A (gap #44): ground a container literal's free result-element var THROUGH
-- the unique impl's method type, so this module's pending sites/arg-stamps resolve
-- against the GROUNDED element (Set Int, not Set _a).  [implDecls] is the full impl
-- universe (core ++ earlier modules ++ prog), so the Set/Map impls are visible.

-- gate: per-module impl-body inference runs only on the emit path (implInferEnabled).
-- allProg = [implDecls] (interfaces + accumulated impls); rpNames computed over it.
inferModuleImplBodiesIfEnabled : TcEnv -> List Decl -> List Decl -> Unit
inferModuleImplBodiesIfEnabled env implDecls prog
  | implInferEnabled.value =
    inferImplBodies env implDecls (returnPosMethodNames implDecls) prog
  | otherwise = ()

-- public top-level value names (the pub flag may sit on the sig, def, or extern).
-- C8(a): a PUBLIC interface ALSO exports its method names so an importer can see
-- their schemes (mirrors lib/typecheck.ml's pub_iface_schemes — methods of an
-- `is_pub = true` interface are appended to the exported value schemes).
publicValNames : List Decl -> List String
publicValNames [] = []
publicValNames ((DAttrib _ d)::rest) = publicValNames [d] ++ publicValNames rest
publicValNames ((DFunDef True n _ _)::rest) = n :: publicValNames rest
publicValNames ((DTypeSig True n _)::rest) = n :: publicValNames rest
publicValNames ((DExtern True n _)::rest) = n :: publicValNames rest
publicValNames ((DInterface { pub = True, methods, ... })::rest) = ifaceMethodNames methods
  ++ publicValNames rest
publicValNames (_::rest) = publicValNames rest

ifaceMethodNames : List IfaceMethod -> List String
ifaceMethodNames [] = []
ifaceMethodNames ((IfaceMethod n _ _)::rest) = n :: ifaceMethodNames rest

-- C5: every interface method name declared anywhere in [decls] (unwrapping DAttrib).
allIfaceMethodNames : List Decl -> List String
allIfaceMethodNames [] = []
allIfaceMethodNames ((DAttrib _ d)::rest) = allIfaceMethodNames [d]
  ++ allIfaceMethodNames rest
allIfaceMethodNames ((DInterface { methods, ... })::rest) = ifaceMethodNames methods
  ++ allIfaceMethodNames rest
allIfaceMethodNames (_::rest) = allIfaceMethodNames rest

-- C5: the standalone-shadows-method set for THIS module.  A name qualifies when it
-- is (a) a top-level standalone funDef in the FULL graph [implDecls], (b) an interface
-- method name, and (c) NOT defined in the current module [prog] (a same-module def
-- shadows the method through ordinary scoping, taking the non-RLocal EVar path — only
-- the CROSS-module import is the RLocal case).  Mirrors lib/typecheck.ml's
-- standalone_values ∩ method_iface, minus env.locals.
buildStandaloneShadows : List Decl -> List Decl -> List String
buildStandaloneShadows implDecls prog =
  -- P0-18 (importer residual, check path): scan interface methods across BOTH the
  -- imported universe [implDecls] AND this module [prog] — the shadowed interface may
  -- be defined LOCALLY in the importing module (e.g. `import prov.{size}` where THIS
  -- module declares `interface Sizeable a where size : a -> Int`).  With only
  -- [implDecls] the local interface's `size` was invisible, so the imported standalone
  -- was not recognised as an importer shadow → recordImplObligation fired a spurious
  -- `No impl of Sizeable for Int` on a no-impl receiver (`size 3`) that `run`
  -- correctly resolved to the standalone.  EMIT path is unaffected: there the method
  -- names are bare but the imported funDefs are mangled (`<mid>__size`), so the
  -- intersection stays empty (the emit-side importer routing is recovered separately
  -- via the mark-seeded RLocal route in definerShadowArgHead).
  let methodNames = allIfaceMethodNames (implDecls ++ prog)
  let localNames = map fst (funDefs prog)
  let importedFns = map fst (funDefs implDecls)
  filter
    (n => contains n methodNames && contains n importedFns && not (contains n localNames))
    (dedup importedFns)

-- C5 (DEFINER shadow): the names THIS module declares as a top-level funDef that
-- ALSO name an interface method visible in [implDecls] (the imported prelude/core).
-- E.g. map-as-root defines `toList`/`isEmpty`, which shadow Foldable's methods.  The
-- MARK pass (`buildStandaloneShadowsGraph`) rewrites occurrences of these to
-- `EMethodAt`, so they MUST be in `standaloneValuesRef` for `recordRLocalSite` to
-- record an RLocal candidate — otherwise the route falls back to the method's
-- RESULT-type RKey (`toList`'s `List`) and the method dispatches on the WRONG impl.
-- Unlike importer shadows these keep their LOCAL standalone scheme (NOT rebound to the
-- method scheme), since the impl bodies apply them to the concrete receiver.
buildDefinerShadows : List Decl -> List Decl -> List String
buildDefinerShadows implDecls prog =
  -- A method name that is ALSO bound by a LOCAL pattern anywhere in the module (a
  -- clause/lambda param, a let/match binder) is NOT a definer shadow at that
  -- occurrence: lexical scope resolves it to the local.  Without this guard the
  -- definer-shadow application path (inferDefinerShadowVarApp / inferDefinerShadowApp)
  -- types `applyEq eq x y = eq x y` — where `eq` is a PARAMETER — against the TOP-LEVEL
  -- standalone `eq : Int -> Int -> Int`, ignoring the binder entirely.  Mirrors the
  -- MARK pass's identical exclusion (marker.mdk's shadowRenames `keepNotIn
  -- (localBoundNames prog)`), so check/run/build agree on which occurrences are shadows.
  let methodNames = allIfaceMethodNames implDecls
  let localNames = dedup (map fst (funDefs prog))
  let direct = filter (n => contains n methodNames) localNames
  -- P0-18: on the EMIT path this module's funDefs are MANGLED, so `direct` finds no
  -- shadow.  For each mangled funDef that the mangle map flags as an iface-method
  -- shadow, register the BARE method name — that is the name the mark pass stamped
  -- on the `EMethodAt`, which `definerShadowArgHead`/`resolveRLocalSite` key off.
  let bares = flatMap (n => match lookupAssoc n mangledShadowMapRef.value
    Some bare => [bare]
    None => []) localNames
  removeAllS (localBoundNames prog) (dedup (direct ++ bares))

-- C5: graph-wide standalone-shadow names — every top-level funDef name in [userDecls]
-- (the user modules, NOT core) that is also an interface method name anywhere in
-- [allDecls].  Used by the MARK pass to rewrite such occurrences to EMethodAt (so the
-- route ref exists for resolveRLocalSites to stamp).  Excludes core's own decls as the
-- funDef source so core's elaboration (no standalone shadows there) is untouched.
-- P0-18: recover, per (module, iface-method) pair, the mangled standalone symbol the
-- mangler produced for a definer-shadow funDef.  Forward-constructs `mangledName mid
-- method` (using the KNOWN mid — exact, not lossy prefix-stripping) and checks it
-- against the module's actual funDef names; a hit is a `(mangledSymbol ↦ bareMethod)`
-- entry.  On the un-mangled path no funDef matches → [] → every consumer unchanged.
computeMangledShadowMap : List Decl -> List (String, List Decl) -> List (String, String)
computeMangledShadowMap allDecls units =
  let methodNames = allIfaceMethodNames allDecls
  flatMap (unitMangledShadows methodNames) units

unitMangledShadows : List String -> (String, List Decl) -> List (String, String)
unitMangledShadows methodNames (mid, decls) =
  let fns = dedup (map fst (funDefs decls))
  flatMap
    (m => if contains (mangledName mid m) fns then [(mangledName mid m, m)] else [])
    methodNames

buildStandaloneShadowsGraph : List Decl -> List Decl -> List String
buildStandaloneShadowsGraph allDecls userDecls =
  let methodNames = allIfaceMethodNames allDecls
  let fns = dedup (map fst (funDefs userDecls))
  let direct = filter (n => contains n methodNames) fns
  -- P0-18: on the EMIT path the funDef names are MANGLED (`<mid>__toList`), so the
  -- `direct` name-intersection misses them; recover them via the mangle map so the
  -- prePass marks their (mangled) occurrences `EMethodAt`.  Empty on the un-mangled
  -- path (the map is empty there) → `direct` alone → byte-identical.
  let mangled = filter (n => isSome (lookupAssoc n mangledShadowMapRef.value)) fns
  dedup (direct ++ mangled)

-- `public export data` / `public export record` decls — re-registered in every
-- importing module so their constructors + field layout are in scope.
-- ALSO carries public DInterface (so the multi-module path can register the
-- interface's method→iface-param map for #11 obligation checking — a numeric
-- literal's `fromInt`/`Num` obligation, recorded via recordImplObligation, needs
-- `Num`'s entry in methodIfaceParamsRef), AND public DImpl (so checkImplObligations'
-- implHeadsOf sees core's `impl Num Int` etc. — without it a legitimately Int-typed
-- literal's Num obligation finds no matching impl head and is spuriously rejected).
-- registerAllData and buildOracle read only DData, so the extra DInterface/
-- DImpl entries are inert for them.
publicDataDecls : List Decl -> List Decl
publicDataDecls [] = []
publicDataDecls ((DData VisPublic n ps vs ds)::rest) =
  DData VisPublic n ps vs ds :: publicDataDecls rest
publicDataDecls ((d@(DInterface { pub = True, ... }))::rest) =
  d :: publicDataDecls rest
publicDataDecls ((d@(DImpl { pub = True, ... }))::rest) =
  d :: publicDataDecls rest
publicDataDecls ((d@(DTypeAlias True _ _ _))::rest) = d :: publicDataDecls rest
publicDataDecls (_::rest) = publicDataDecls rest

-- WS-1a fix: every impl in scope, EXPORT OR NOT.  Instances are GLOBAL (coherence
-- + dispatch leak across module boundaries regardless of `export`), so the
-- superinterface existence query (checkSuperImpls/superImplExists) must see an
-- imported module's `impl Semigroup T` even when it isn't `export`-marked — else
-- `impl Monoid T` in an importer is falsely rejected for a "missing" super impl.
pickSchemes : List String -> List (String, Scheme) -> List (String, Scheme)
pickSchemes [] _ = []
pickSchemes (n::ns) table = match lookupAssoc n table
  Some s => (n, s) :: pickSchemes ns table
  None => pickSchemes ns table

-- Bug C: for each importer-shadow name, pick from [table] the scheme that is the
-- imported STANDALONE — the one whose receiver (first arrow domain) heads in a
-- CONCRETE type constructor (`Map k v`), NOT the polymorphic interface-method scheme
-- (`t a`) that shares the same name in the seed.  A name with no concrete-domain
-- entry contributes nothing (its only binding is the method scheme; the ordinary
-- dispatch path handles it).
pickStandaloneSchemes : List String -> List (String, Scheme) -> List (String, Scheme)
pickStandaloneSchemes [] _ = []
pickStandaloneSchemes (n::ns) table = match concreteDomainScheme n table
  Some s => (n, s) :: pickStandaloneSchemes ns table
  None => pickStandaloneSchemes ns table

-- the FIRST scheme bound to [n] in [table] whose first arrow domain has a concrete
-- (TCon-headed) receiver — i.e. the standalone rather than the `t a` method scheme.
concreteDomainScheme : String -> List (String, Scheme) -> Option Scheme
concreteDomainScheme _ [] = None
concreteDomainScheme n ((n2, s)::rest) =
  if n == n2 && schemeHasConcreteDomain s then
    Some s
  else
    concreteDomainScheme n rest

-- True iff the scheme's type is `dom -> _` and [dom]'s spine head is a TCon (a
-- concrete receiver), distinguishing the standalone `Map k v -> …` from the method
-- `t a -> …` whose domain head is a quantified tyvar.
schemeHasConcreteDomain : Scheme -> Bool
schemeHasConcreteDomain (Forall _ _ t) = match normalize t
  TFun dom _ _ => monoSpineHeadIsCon dom
  _ => False

monoSpineHeadIsCon : Mono -> Bool
monoSpineHeadIsCon m = match normalize m
  TApp a _ => monoSpineHeadIsCon a
  TCon _ => True
  _ => False

-- ── IMPORT-SCOPED per-module seeding (mirrors lib/typecheck.ml:4513-4543) ────
-- The multi-module drivers must NOT flat-seed the cumulative UNION of every
-- dependency's public schemes into each module's env: omInsert is last-write-wins,
-- so a later-loaded dependency's same-named binding (e.g. `string.reverse :
-- String -> String`) silently overwrites an earlier one (`list.reverse :
-- List a -> List a`) — mis-typing a module that explicitly `import list.{reverse}`.
-- Instead each module's seed is built from ONLY the names its own `DUse` decls
-- import, looked up in the SPECIFIC dependency they name.  The implicit prelude
-- (runtime + core) is always fully in scope and is threaded separately as baseSeed.

-- the bare member names a single `import` form names from its dependency —
-- mirrors lib/typecheck.ml's imported_names match (BEFORE mangle-key resolution):
--   UseGroup (_, ms) → the member names         (import dep.{a, b, c})
--   UseWild _        → ALL of the dep's schemes  (import dep.*)
--   UseName ns       → [last ns] if dotted (import a.b.name), else [] (bare name)
--   UseAlias _       → [] (alias only — no auto-imported value names)
-- `None` ⇒ wildcard (every scheme); `Some names` ⇒ exactly those member names.
-- (ORIGIN, LOCAL) per imported member.  They differ only under a member alias
-- (`import m.{a as b}`): the SCHEME is looked up under the origin `a` in the
-- dependency, and bound into this module's env under the local `b`.
importedBindings : UsePath -> Option (List (String, String))
importedBindings (UseGroup _ ms) = Some (map memberBinding ms)
importedBindings (UseWild _) = None
importedBindings (UseName ns)
  | listLen ns > 1 = Some [selfBinding (lastComponent ns)]
  | otherwise = Some []
-- A module alias enumerates the dependency's schemes, so it cannot be expressed as a
-- fixed member list — importFormSchemes handles it directly.
importedBindings (UseAlias _ _) = Some []

memberBinding : UseMember -> (String, String)
memberBinding m = (useMemberOrigin m, useMemberLocal m)

selfBinding : String -> (String, String)
selfBinding n = (n, n)

-- resolve one imported bare member name to its actual key in a dependency's public
-- schemes.  The golden path keys schemes by the bare name; the EMIT path runs after
-- universal mangling (backend.private_mangle), which rewrites a definition `member`
-- to `<dep>__member` but leaves the importer's `DUse` member name BARE — so the key
-- is the SUFFIX-matching scheme `…__member` (uniquely identified within THIS dep's
-- own schemes; distinct members never share an `__<name>` suffix).  Try the bare
-- key first (golden), then the `__<name>` suffix (mangled emit path).
memberSuffix : String -> String
memberSuffix n = "__" ++ n

-- local suffix test (string.endsWith is not imported here): `s` ends with `suf`.
endsWithStr : String -> String -> Bool
endsWithStr suf s =
  let ls = stringLength s
  let lsuf = stringLength suf
  lsuf <= ls && stringSlice (ls - lsuf) ls s == suf

-- Look the member up by its ORIGIN name, bind it under its LOCAL name.  Without an
-- alias the two coincide and this is the historical behaviour.
--
-- On the MANGLED emit path the bare origin is absent (the dep's keys are `<dep>__name`)
-- AND the reference in this module's body has itself been mangled to `<dep>__name` by
-- backend/private_mangle — so the suffix-matched entries are passed through under their
-- MANGLED keys, which is exactly the key the mangled reference will look up.  (A member
-- alias is erased by the same mangling, so it needs no rebinding there.)
resolveMemberSchemes : (String, String) -> List (String, Scheme) -> List (String, Scheme)
resolveMemberSchemes (origin, local) depSchemes = match lookupAssoc origin depSchemes
  Some s => [(local, s)]
  None => filter (kv => endsWithStr (memberSuffix origin) (fst kv)) depSchemes

-- `import m as A` binds EVERY value m exports under `A.name` — so it enumerates the
-- dependency's schemes rather than a fixed member list.
--
-- Same golden/mangled split as above, made exact by testing the dep's own mangle prefix
-- (`<sanitized mid>__`) instead of guessing: on the emit path the reference is already
-- `<mid>__name`, so the key must stay mangled; on the golden path the reference is the
-- flat `A.name` that desugar produced, so bind it under that.
aliasSchemes : String -> String -> List (String, Scheme) -> List (String, Scheme)
aliasSchemes mid alias depSchemes = map (aliasSchemeEntry mid alias) depSchemes

aliasSchemeEntry : String -> String -> (String, Scheme) -> (String, Scheme)
aliasSchemeEntry mid alias (k, s) =
  if isMangledFor mid k then
    (k, s)
  else
    (qualifiedLocal alias k, s)

-- does `k` carry the `<sanitized mid>__` prefix the mangler would have given it?
isMangledFor : String -> String -> Bool
isMangledFor mid k =
  let pre = mangledName mid ""
  let lp = stringLength pre
  lp <= stringLength k && stringSlice 0 lp k == pre

-- the (key, scheme) pairs a single `import` form brings into scope, resolving each
-- member to its (possibly mangled) key in the dependency's schemes.
importFormSchemes : String -> UsePath -> List (String, Scheme) -> List (String, Scheme)
importFormSchemes mid (UseAlias _ alias) depSchemes =
  aliasSchemes mid alias depSchemes
importFormSchemes _ path depSchemes = match importedBindings path
  None => depSchemes
  Some bindings => flatMap (b => resolveMemberSchemes b depSchemes) bindings

-- ── import aliasing: re-key the dict-arity / dict-iface tables ───────────────────
-- Both tables (funConstraintsRef, funConstraintIfacesRef) are keyed by the name a CALL
-- SITE writes.  An alias makes that name differ from the definition's, so without this
-- an aliased constrained callee gets zero dict routes and under-applies.  Generic over
-- the payload so the arity table (List Int) and the iface table (List String) share it.
--
-- [qual] is the (definerMid, name)-keyed table, which is what makes this PRECISE: an
-- entry is copied only when its DEFINER is the very module the alias names.
aliasConstraintEntries : List Decl -> List ((String, String), List a) -> List (String, List a)
aliasConstraintEntries [] _ = []
aliasConstraintEntries ((DAttrib _ d)::rest) qual = aliasConstraintEntries [d] qual
  ++ aliasConstraintEntries rest qual
aliasConstraintEntries ((DUse _ path _)::rest) qual = aliasEntriesFor (usePathModuleId path) path qual
  ++ aliasConstraintEntries rest qual
aliasConstraintEntries (_::rest) qual = aliasConstraintEntries rest qual

aliasEntriesFor : String -> UsePath -> List ((String, String), List a) -> List (String, List a)
-- `import m as A` → every constrained fn m defines is callable as `A.<name>`.
aliasEntriesFor mid (UseAlias _ a) qual = flatMap (moduleAliasEntry mid a) qual
-- `import m.{x as y}` → `y` carries `x`'s dict arity.
aliasEntriesFor mid (UseGroup _ ms) qual =
  flatMap (memberAliasEntry mid qual) ms
aliasEntriesFor _ _ _ = []

-- ── import aliasing of an interface/impl METHOD ─────────────────────────────────
-- A method is GLOBAL-BY-NAME.  Impl coalescing, dispatch routing, the emitter's method
-- tables and the METHOD-side dict-arity tables are every one of them keyed by the
-- method's own name, and there is exactly ONE cell per name — a method is deliberately
-- NOT a per-module binding (eval.mdk's globalCells / coalesceImpls).  So an alias of a
-- method is not a new binding at all: it is a second SPELLING of the same method.
--
-- Resolve it back to the origin name here, once, right after resolve has validated the
-- alias and before ANY marking / route-stamping / dict-arity machinery runs.  Every
-- downstream stage — marker, typecheck route stamping, private_mangle, the emitter, both
-- eval drivers — then sees an ordinary method reference and needs no alias awareness.
--
-- That is also precisely why the METHOD-side dict-arity tables (methodConstraintsRef /
-- crossModuleMethodConstraintsQualRef / scopeMethodArities) need no alias re-keying the
-- way funConstraintsRef did: by the time they are built, no aliased method name survives.
-- The standalone `=>`-constrained functions are the opposite case — they ARE per-module
-- bindings that keep their local name, which is why they needed the re-keying.
--
-- Caveat, shared with the marker's own shadowRename: the rewrite is scope-blind, so a
-- LOCAL binder whose name equals an alias local would also be rewritten.  An alias local
-- is chosen by the importing file, so this is a self-inflicted collision.
-- The rewrite has TWO halves, and they must agree: rewriting only the references would
-- leave them bound to nothing.
--   (a) every reference to an aliased method  → the origin method name
--   (b) the module's own `DUse` decls          → import that method under its ORIGIN name
-- With (b) in place, the import seed (typecheck), the import frame (eval) and the
-- rename map (private_mangle) all bind the origin name by their ORDINARY un-aliased
-- paths — none of them needs to learn anything about aliases.
renameAliasedMethods : List Decl -> List (String, List Decl) -> List (String, List Decl)
renameAliasedMethods coreDecls modules =
  let coreEntry = ("core", declMethodNames coreDecls)
  let methodsPerMid = coreEntry :: methodsPerMidGo [coreEntry] modules
  map (renameAliasedMethodsIn methodsPerMid) modules

-- A module's method set is what it DECLARES *plus what it RE-EXPORTS*, folded in
-- dependency-first (loader) order so a re-export resolves against its source's
-- already-computed set (and a >1-hop chain still resolves).
--
-- The `++ reexportedMethodNames` half closes a run≠build divergence that predates
-- core re-exports and is NOT core-specific: with a module's set limited to its own
-- `declMethodNames`, a module that re-exports a method did not list it, so at an
-- importer's `import reExporter.{method as alias}` neither half of the rewrite fired
-- — the alias was not dropped from the DUse (b) and references were not renamed to the
-- origin (a).  `run` still worked (eval's import frame binds the alias to the origin's
-- cell), but a method is global-by-name with no per-module symbol, so EMIT had nothing
-- to bind `alias` to and died with `unbound variable '<alias>'`.  Observed on a pure
-- user-module chain (b defines `area`; c re-exports it; main imports `area as surface`
-- → run prints 16, build fails), and on `import list.{filter as f}` once
-- `export import core.{filter}` began re-exporting at all.
methodsPerMidGo : List (String, List String) -> List (String, List Decl) -> List (String, List String)
methodsPerMidGo _ [] = []
methodsPerMidGo acc ((mid, decls)::rest) =
  let entry = (mid, dedup (declMethodNames decls ++ reexportedMethodNames acc decls))
  entry :: methodsPerMidGo (entry::acc) rest

-- method names a module re-exports via `export import src.{…}` (`DUse True`), taken
-- from `acc` — the dependency's already-folded method set.
reexportedMethodNames : List (String, List String) -> List Decl -> List String
reexportedMethodNames acc decls = flatMap (reexportedMethodsOf acc) decls

reexportedMethodsOf : List (String, List String) -> Decl -> List String
reexportedMethodsOf acc (DAttrib _ d) = reexportedMethodsOf acc d
reexportedMethodsOf acc (DUse True path _) = match lookupAssoc (usePathModuleId path) acc
  None => []
  Some srcMethods => match importedBindings path
    -- `export import src.*` re-exports every one of src's methods
    None => srcMethods
    Some bs => filterList (n => contains n srcMethods) (map fst bs)
reexportedMethodsOf _ _ = []

renameAliasedMethodsIn : List (String, List String) -> (String, List Decl) -> (String, List Decl)
renameAliasedMethodsIn methodsPerMid (mid, prog) = match aliasMethodRenames methodsPerMid prog
  [] => (mid, prog)
  renames =>
    let prog2 = flatMap (deAliasMethodImports methodsPerMid) prog
    (mid, mapProg (renameMethodVar renames) prog2)

-- (b): make each import bind the METHODS it names under their ORIGIN name.
--   `import m.{area as computeArea}` → `import m.{area}`  (the alias is dropped: a method
--                                      is global-by-name, so the rename already points
--                                      every reference at `area`)
--   `import m as A`                  → keep it (its non-method values are still `A.f`)
--                                      and ADD `import m.{…m's methods…}`, which is what
--                                      `A.area` was rewritten to refer to.
deAliasMethodImports : List (String, List String) -> Decl -> List Decl
deAliasMethodImports mm (DAttrib attrs d) =
  map (DAttrib attrs) (deAliasMethodImports mm d)
deAliasMethodImports mm (d@(DUse pub path loc)) = match lookupAssoc (usePathModuleId path) mm
  None => [d]
  Some methods => match path
    UseGroup quals ms =>
      [DUse pub (UseGroup quals (map (deAliasMethodMember methods) ms)) loc]
    UseAlias quals _ => match methodMembersOf methods loc
      [] => [d]
      mems => [d, DUse pub (UseGroup quals mems) loc]
    _ => [d]
deAliasMethodImports _ d = [d]

deAliasMethodMember : List String -> UseMember -> UseMember
deAliasMethodMember methods (m@(UseMember n allCtors loc _))
  | contains n methods = UseMember n allCtors loc None
  | otherwise = m

methodMembersOf : List String -> Loc -> List UseMember
methodMembersOf methods loc = map (n => UseMember n False loc None) methods

renameMethodVar : List (String, String) -> Expr -> Expr
renameMethodVar renames (e@(EVar x)) = match lookupAssoc x renames
  Some origin => EVar origin
  None => e
renameMethodVar _ e = e

-- (localName, originMethodName) for every import in [prog] whose ORIGIN is a method of
-- the module it comes from.  Only an alias yields an entry — an un-aliased import already
-- carries the origin name, which is why this gap stayed invisible for so long.
aliasMethodRenames : List (String, List String) -> List Decl -> List (String, String)
aliasMethodRenames methodsPerMid prog =
  flatMap (aliasMethodRenamesOf methodsPerMid) prog

aliasMethodRenamesOf : List (String, List String) -> Decl -> List (String, String)
aliasMethodRenamesOf mm (DAttrib _ d) = aliasMethodRenamesOf mm d
aliasMethodRenamesOf mm (DUse _ path _) = match lookupAssoc (usePathModuleId path) mm
  None => []
  Some methods => aliasMethodRenamesOfPath methods path
aliasMethodRenamesOf _ _ = []

aliasMethodRenamesOfPath : List String -> UsePath -> List (String, String)
-- `import m as A` → `A.area` is method `area`
aliasMethodRenamesOfPath methods (UseAlias _ a) =
  map (n => (qualifiedLocal a n, n)) methods
-- `import m.{area as computeArea}` → `computeArea` is method `area`
aliasMethodRenamesOfPath methods (UseGroup _ ms) =
  flatMap (memberMethodRename methods) ms
aliasMethodRenamesOfPath _ _ = []

memberMethodRename : List String -> UseMember -> List (String, String)
memberMethodRename methods m = match useMemberAlias m
  Some local =>
    let origin = useMemberOrigin m
    if contains origin methods then [(local, origin)] else []
  None => []

-- every interface/impl method name a decl list declares (interface methods with or
-- without a default, plus impl method names).
declMethodNames : List Decl -> List String
declMethodNames decls = dedup (flatMap declMethodNamesOf decls)

declMethodNamesOf : Decl -> List String
declMethodNamesOf (DAttrib _ d) = declMethodNamesOf d
declMethodNamesOf (DInterface { methods, ... }) = ifaceMethodNames methods
declMethodNamesOf (DImpl { methods, ... }) = map implMethodName methods
declMethodNamesOf _ = []

-- IMPORT ALIASING: the LOCAL names, across every module, under which a CONSTRAINED
-- function is reachable through an alias.  These must join dictNames or the aliased
-- call site is never marked as a dict application (see the call site of this fn).
--
-- [bare] is the un-aliased dictNames; [unitDecls] is (mid, decls) for core + every
-- module, used to ask which fns a given module actually DEFINES — so `import m as A`
-- contributes `A.<n>` only for m's own constrained fns, never for a same-named
-- constrained fn belonging to some other module.
aliasDictNames : List String -> List (String, List Decl) -> List (String, List Decl) -> List String
aliasDictNames bare unitDecls modules =
  flatMap (u => aliasDictNamesOfUnit bare unitDecls (snd u)) modules

aliasDictNamesOfUnit : List String -> List (String, List Decl) -> List Decl -> List String
aliasDictNamesOfUnit bare unitDecls decls =
  flatMap (aliasDictNamesOfDecl bare unitDecls) decls

aliasDictNamesOfDecl : List String -> List (String, List Decl) -> Decl -> List String
aliasDictNamesOfDecl bare unitDecls (DAttrib _ d) =
  aliasDictNamesOfDecl bare unitDecls d
aliasDictNamesOfDecl bare unitDecls (DUse _ path _) =
  aliasDictNamesOfPath bare unitDecls (usePathModuleId path) path
aliasDictNamesOfDecl _ _ _ = []

aliasDictNamesOfPath : List String -> List (String, List Decl) -> String -> UsePath -> List String
aliasDictNamesOfPath bare unitDecls mid (UseAlias _ a) = match lookupAssoc mid unitDecls
  Some ds =>
    map (qualifiedLocal a) (filter (n => contains n bare) (declTopFnNames ds))
  None => []
aliasDictNamesOfPath bare _ _ (UseGroup _ ms) = flatMap (memberDictName bare) ms
aliasDictNamesOfPath _ _ _ _ = []

memberDictName : List String -> UseMember -> List String
memberDictName bare m = match useMemberAlias m
  Some local => if contains (useMemberOrigin m) bare then [local] else []
  None => []

moduleAliasEntry : String -> String -> ((String, String), List a) -> List (String, List a)
moduleAliasEntry mid a ((defMid, n), ids)
  | defMid == mid = [(qualifiedLocal a n, ids)]
  | otherwise = []

memberAliasEntry : String -> List ((String, String), List a) -> UseMember -> List (String, List a)
memberAliasEntry mid qual m = match useMemberAlias m
  None => []
  Some local =>
    let origin = useMemberOrigin m
    map
      (e => (local, snd e))
      (filter (e => fst (fst e) == mid && snd (fst e) == origin) qual)

-- build THIS module's import-scoped seed: walk its DUse decls, and for each one
-- pick the imported names out of the named dependency's public schemes (held in
-- depEnv, keyed by the dotted module id that usePathModuleId yields == the loader's
-- mid).  `core` DUse decls are skipped — core is always seeded via baseSeed.
importSeed : List Decl -> List (String, List (String, Scheme)) -> List (String, Scheme)
importSeed [] _ = []
importSeed ((DAttrib _ d)::rest) depEnv = importSeed [d] depEnv
  ++ importSeed rest depEnv
importSeed ((DUse _ path _)::rest) depEnv =
  let depId = usePathModuleId path
  match lookupAssoc depId depEnv
    None => importSeed rest depEnv
    Some depSchemes => importFormSchemes depId path depSchemes
      ++ importSeed rest depEnv
importSeed (_::rest) depEnv = importSeed rest depEnv

-- WS-2/D2: THIS module's imported value name → import-source module id, from its DUse
-- decls.  Mirrors importSeed's walk but records (localName, depId) for EXPLICIT imports
-- only (importedBindings = Some bindings); a wildcard `import mod.*` (None) is skipped —
-- it can't enumerate names here, so those names fall back to the bare arity table at the
-- call site.  `core` is skipped (core fns route via the prelude dict machinery, never the
-- cross-module qual tables).  depId == usePathModuleId == the loader mid == the qual
-- tables' definer key for a DIRECT import; a re-exported fn's depId is the intermediate
-- (≠ definer), so its qual lookup misses and it too falls back to bare (correct).
--
-- Keyed by the LOCAL name, because that is the name the CALL SITE writes: under a member
-- alias (`import m.{a as b}`) the call site says `b`, so `b` is what must map to m.
--
-- A whole-module alias (`import m as A`) contributes nothing, for the same reason a
-- wildcard doesn't: its locals are one-per-export and this walk has no depEnv to
-- enumerate them.  Those call sites take the same documented bare-table fallback as
-- every wildcard import does today.  The dict ARGS themselves are unaffected — they are
-- stamped from the callee's SCHEME, which importSeed binds under the alias local — so
-- this costs only the cross-module arity DISAMBIGUATION, and only when two modules
-- export same-named constrained fns of differing dict arity.
importDefinersOf : List Decl -> List (String, String)
importDefinersOf [] = []
importDefinersOf ((DAttrib _ d)::rest) = importDefinersOf [d]
  ++ importDefinersOf rest
importDefinersOf ((DUse _ path _)::rest) =
  let depId = usePathModuleId path
  if depId == "core" then importDefinersOf rest
  else match importedBindings path
    None => importDefinersOf rest
    Some bindings => map (b => (snd b, depId)) bindings ++ importDefinersOf rest
importDefinersOf (_::rest) = importDefinersOf rest

-- the (key, scheme) pairs a module RE-EXPORTS via `export import` (`DUse True`).
-- Mirrors resolve's re-export set (resolve.pubUsePaths filters the same `DUse True`)
-- into the typecheck seed: walk the export-flagged DUse decls and, for each, pick the
-- re-exported member names out of the SOURCE dependency's public schemes already in
-- depEnv — the exact member resolution importSeed uses (importFormSchemes /
-- resolveMemberSchemes), so it works on both golden and mangled emit paths.  Schemes
-- come from depEnv by IDENTITY (the definer's original schemes, never re-generalized),
-- which preserves the original-definer constraint ids (D2 diamond-safety).  ONLY
-- `DUse True` is threaded, so a plain `import` never leaks the importer's names
-- downstream.  Transitivity is automatic: pubV accumulates these and is carried
-- forward as depEnv, so a second `export import` hop re-resolves against the enriched
-- pubV.  Methods need no special case — the source module's pubV already holds the
-- method scheme (publicValNames includes DInterface method names).
--
-- `core` is the one source that is NOT in depEnv: it is the implicit prelude, so its
-- schemes go into `baseSeed`, not into the per-module dep chain.  It is therefore
-- passed separately as `coreV` — without it, `lookupAssoc "core" depEnv` missed and
-- `export import core.{filter}` re-exported nothing (in silence, and forever).
-- `coreV` is consulted ONLY here, on `DUse True`: `importSeed` keeps taking the plain
-- depEnv, so a plain `import core.{…}` still seeds nothing (its names are already in
-- baseSeed — seeding them twice would only add duplicate assoc entries).
reexportSeed : List (String, Scheme) -> List Decl -> List (String, List (String, Scheme)) -> List (String, Scheme)
reexportSeed _ [] _ = []
reexportSeed coreV ((DAttrib _ d)::rest) depEnv = reexportSeed coreV [d] depEnv
  ++ reexportSeed coreV rest depEnv
reexportSeed coreV ((DUse True path _)::rest) depEnv =
  let depId = usePathModuleId path
  let src = if depId == "core" then Some coreV else lookupAssoc depId depEnv
  match src
    None => reexportSeed coreV rest depEnv
    Some depSchemes => importFormSchemes depId path depSchemes
      ++ reexportSeed coreV rest depEnv
reexportSeed coreV (_::rest) depEnv = reexportSeed coreV rest depEnv

checkModulesGo : List (String, Scheme) -> List (String, Scheme) -> List (String, List (String, Scheme)) -> List Decl -> List (String, List Decl) -> List (String, List (String, Scheme))
checkModulesGo _ _ _ _ [] = []
checkModulesGo baseSeed coreV depEnv accData ((mid, prog)::rest) =
  let seed = baseSeed ++ importSeed prog depEnv
  let schemes = checkModuleFull seed accData prog
  let pubV = pickSchemes (publicValNames prog) schemes ++ reexportSeed coreV prog depEnv
  (mid, schemes) :: checkModulesGo baseSeed coreV ((mid, pubV)::depEnv) (accData ++ publicDataDecls prog) rest

-- check every module in dependency order against a shared prelude + runtime.
-- modules = (moduleId, desugared program) in dependency-first order.
export checkModules : List Decl -> List Decl -> List (String, List Decl) -> List (String, List (String, Scheme))
checkModules runtimeDecls coreDecls modules =
  let _ = resetCrossModuleState ()
  let runtimeSeed = externSchemes runtimeDecls
  let _ = seedAbstractRecordTypes coreDecls modules
  let coreSchemes = checkModuleFull runtimeSeed [] coreDecls
  checkModulesGo
    (runtimeSeed ++ coreSchemes)
    coreSchemes
    []
    (publicDataDecls coreDecls)
    modules

-- ── per-module ISOLATED diagnostics (the analyzeProject typecheck stage) ────
-- Like checkModuleFull but ALSO harvests THIS module's type diagnostics: it
-- mirrors checkProgramDiags's side-effects (matchOracle/matchWarnings seeded,
-- coherence over the module's OWN decls) while keeping the module ISOLATED — only
-- PUBLIC schemes/data of earlier modules are seeded (via seedVars/accData), so a
-- private same-named helper in another module never collides (the bug the old
-- flat prefix-concat diagnostics path had).  checkModuleFull calls resetState (),
-- which clears typeErrors at module start, so the post-call typeErrors snapshot is
-- exactly THIS module's contribution; matchWarnings is cleared here explicitly
-- (resetState does NOT clear it).  Returns (own value schemes, errs, warns) so the
-- driver can thread accV/accData exactly as checkModulesGo does.
export checkModuleFullDiags : List (String, Scheme) -> List Decl -> List Decl -> List Decl -> (List (String, Scheme), List (String, String, Option Loc), List (String, Option Loc))
checkModuleFullDiags seedVars accData accAll prog =
  let _ = setRef implInferEnabled False
  let _ = setRef matchWarnings []
  let _ = setRef matchWarningLocs []
  -- P0-9: THIS module's own decls (`prog`) come FIRST so its constructors win
  -- the oracle's first-wins bare-name tables.  Another loaded module (in accData)
  -- can define a same-named ctor at a different arity (`map`'s arity-5 `Bin` vs
  -- `set`'s arity-4 `Bin`); with accData first, the type-aware `check_match` reads
  -- the WRONG arity/type for this module's own `Bin` in a match and false-warns
  -- W-NONEXHAUSTIVE.  buildOracle is duplicate-tolerant, and accData still
  -- supplies prelude Option/Result ctors (this module never redefines them).
  let _ = setRef matchOracle (buildOracle (prog ++ accData))
  -- Bug C: pass the cumulative full impl universe (core + earlier modules) as
  -- implDecls (was checkModuleFull, i.e. implDecls=[]) so buildStandaloneShadows sees
  -- an imported standalone funDef that shadows an interface method (`map`'s `toList`
  -- vs Foldable's): without it the importer-shadow set is EMPTY on the CHECK path and
  -- `toList m` routes to method dispatch → spurious `No impl of Foldable for Map`.
  -- implInferEnabled stays False, so this does NOT trigger impl-body inference — it
  -- only feeds the shadow/dispatch-index/key tables, matching the eval path's
  -- elabModuleStamp (which passes accAll ++ prog too).
  let schemes = checkModuleFullImpl "" seedVars accData accAll prog
  let _ = checkCoherence prog
  let _ = checkInterfaceCycles (accAll ++ accData ++ prog)
  let _ = checkPhantomMethods prog
  let _ = checkSuperImpls prog (accAll ++ accData ++ prog)
  (
    schemes,
    reverseL typeErrors.value,
    zipL (reverseL matchWarnings.value) (reverseL matchWarningLocs.value),
  )
-- Seed the ctor oracle over ALL data decls in scope (prelude + every imported
-- module via accData, plus this module's own prog), NOT just `prog`.  The
-- single-file path (checkProgramDiags:5826) sees a flat prelude+user dump, so
-- its `buildOracle prog` already includes Option/Result; the multi-module path
-- keeps modules separate, so prelude ADTs live in accData.  Seeding with only
-- `prog` left the oracle missing Some/None|Ok/Err → exhaustive matches on
-- Option/Result false-warned "non-exhaustive".  buildOracle reads only DData
-- and is duplicate-tolerant, so accData ++ prog is safe.

-- checkModuleFull → checkModuleFullImpl runs resetState () first (clears
-- typeErrors + currentLevel), so the snapshot below is this module's own errors.

-- coherence over THIS module's own decls (mirrors checkProgramDiags's
-- checkCoherence coherenceUserDecls.value, which moduleTypeDiags set to the
-- module decls).  Pushes any conflict into typeErrors AFTER the resetState above.

-- multi-module diagnostics driver: threads the runtime+core seed and per-module
-- PUBLIC accumulators exactly as checkModulesGo, but at each module harvests its
-- ISOLATED diagnostics via checkModuleFullDiags.  Returns one
-- (mid, (errs, warns)) per module in load order.  Core is checked ONCE (its
-- diagnostics are not surfaced — it is the trusted prelude, as in checkModules).
-- IMPORT-SCOPED seed (baseSeed ++ importSeed prog depEnv), exactly like
-- checkModulesGo — NOT a flat union of every earlier module's publics, which let
-- a same-named function from a non-imported module win by load order (e.g.
-- string.reverse shadowing the list.reverse a module imports → spurious errors).
checkModulesDiagsGo : List (String, Scheme) -> List (String, Scheme) -> List (String, List (String, Scheme)) -> List Decl -> List Decl -> List (String, List Decl) -> List (String, (List (String, String, Option Loc), List (String, Option Loc)))
checkModulesDiagsGo _ _ _ _ _ [] = []
checkModulesDiagsGo baseSeed coreV depEnv accData accAll ((mid, prog)::rest) =
  let (schemes, errs, warns) = checkModuleFullDiags (baseSeed ++ importSeed prog depEnv) accData accAll prog
  let pubV = pickSchemes (publicValNames prog) schemes ++ reexportSeed coreV prog depEnv
  (mid, (errs, warns)) :: checkModulesDiagsGo baseSeed coreV ((mid, pubV)::depEnv) (accData ++ publicDataDecls prog) (accAll ++ prog) rest

export checkModulesDiags : List Decl -> List Decl -> List (String, List Decl) -> List (String, (List (String, String, Option Loc), List (String, Option Loc)))
checkModulesDiags runtimeDecls coreDecls modules =
  let _ = resetCrossModuleState ()
  let runtimeSeed = externSchemes runtimeDecls
  let _ = seedAbstractRecordTypes coreDecls modules
  let coreSchemes = checkModuleFull runtimeSeed [] coreDecls
  let perMod = checkModulesDiagsGo (runtimeSeed ++ coreSchemes) coreSchemes [] (publicDataDecls coreDecls) coreDecls modules
  -- D3 / WS-2 part-2: attach any cross-module coherence conflict to the ENTRY
  -- module's diagnostics (last in dependency-first order), so LSP/analyzeProject
  -- surfaces it too.  User modules only (prelude excluded).
  match globalCoherenceConflict modules
    Some msg => attachEntryDiag ("T-CONFLICTING-IMPL", msg, None) perMod
    None => perMod

-- prepend an error to the LAST module's (errs, warns) in a per-module diag list.
attachEntryDiag : (String, String, Option Loc) -> List (String, (List (String, String, Option Loc), List (String, Option Loc))) -> List (String, (List (String, String, Option Loc), List (String, Option Loc)))
attachEntryDiag _ [] = []
attachEntryDiag e [(mid, (errs, warns))] = [(mid, (e::errs, warns))]
attachEntryDiag e (m::rest) = m :: attachEntryDiag e rest

-- the entry module is last in dependency-first order
export entryOwnSchemes : List (String, List (String, Scheme)) -> List (String, Scheme)
entryOwnSchemes [] = []
entryOwnSchemes [(_, ss)] = ss
entryOwnSchemes (_::rest) = entryOwnSchemes rest

-- ── multi-module `check` CLI report (DRIVER-COLLAPSE Phase 4, OPTION A) ─────
-- The unified `medaka check` path for IMPORT-BEARING files: the caller loads the
-- entry + its transitive imports (loadProgram), then this typechecks the whole
-- graph in dependency order (checkModuleFullDiags per module: per-module-frame,
-- prelude seeded once) and harvests the ENTRY module's OWN (schemes, errs, warns).
-- Imports are RESOLVED (their public schemes seed the entry), so a valid cross-
-- module reference no longer falls through to `UnknownModule` — the known "native
-- check is single-file" limitation, fixed.  The entry is last in dependency-first
-- order.  No-import (1-module) files still route through runCheck (full prelude+
-- user dump, byte-identical); this path is reached ONLY when the load returned
-- more than one module.
checkModulesEntryFull : List Decl -> List Decl -> List (String, List Decl) -> (List (String, Scheme), List (String, String, Option Loc), List (String, Option Loc))
checkModulesEntryFull runtimeDecls coreDecls modules =
  let _ = resetCrossModuleState ()
  let runtimeSeed = externSchemes runtimeDecls
  let _ = seedAbstractRecordTypes coreDecls modules
  let coreSchemes = checkModuleFull runtimeSeed [] coreDecls
  let (schemes, errs, warns) = checkModulesEntryFullGo (runtimeSeed ++ coreSchemes) coreSchemes [] (publicDataDecls coreDecls) coreDecls modules
  -- D3 / WS-2 part-2: cross-module coherence over the USER modules only (prelude
  -- excluded — it is checked separately and a user impl may override a prelude one).
  -- Prepend any conflict (dependency-first, ahead of the entry's own errors).
  match globalCoherenceConflict modules
    Some msg => (schemes, ("T-CONFLICTING-IMPL", msg, None) :: errs, warns)
    None => (schemes, errs, warns)

-- thread the public accumulators exactly as checkModulesGo.  The returned
-- triple keeps the ENTRY (last) module's SCHEMES and WARNINGS (those belong to the
-- entry's report), but ACCUMULATES type errors from EVERY module: a type error in
-- an IMPORTED module is still a hard error of `check`ing the entry graph and must
-- surface (otherwise it silently reaches codegen — the G1-class soundness hole).
-- Earlier-module errors are prepended (dependency-first) to the entry's own.
--
-- Each module's VALUE seed is IMPORT-SCOPED (`baseSeed ++ importSeed prog depEnv`,
-- exactly like checkModulesGo), NOT the flat union of every earlier module's public
-- schemes.  A flat union let a same-named function from a non-imported module win by
-- load order — e.g. `string.reverse : String -> String` shadowing the `list.reverse`
-- a module actually imported, producing spurious `String vs List a` errors (json.mdk).
-- baseSeed (runtime + core) is always in scope; depEnv keys earlier modules' public
-- schemes by module id for importSeed to pick from.  accData stays a flat union
-- (data/type collisions aren't the issue here; mirrors checkModulesGo).
checkModulesEntryFullGo : List (String, Scheme) -> List (String, Scheme) -> List (String, List (String, Scheme)) -> List Decl -> List Decl -> List (String, List Decl) -> (List (String, Scheme), List (String, String, Option Loc), List (String, Option Loc))
checkModulesEntryFullGo _ _ _ _ _ [] = ([], [], [])
checkModulesEntryFullGo baseSeed _ depEnv accData accAll [(_, prog)] =
  checkModuleFullDiags (baseSeed ++ importSeed prog depEnv) accData accAll prog
checkModulesEntryFullGo baseSeed coreV depEnv accData accAll ((mid, prog)::rest) =
  let (schemes, errs, _) = checkModuleFullDiags (baseSeed ++ importSeed prog depEnv) accData accAll prog
  let pubV = pickSchemes (publicValNames prog) schemes ++ reexportSeed coreV prog depEnv
  let (eSchemes, eErrs, eWarns) = checkModulesEntryFullGo baseSeed coreV ((mid, pubV)::depEnv) (accData ++ publicDataDecls prog) (accAll ++ prog) rest
  (eSchemes, errs ++ eErrs, eWarns)

-- render the entry report: type errors win (each `TYPE ERROR: …`), else the
-- entry's `name : scheme` lines followed by its non-exhaustive-match warnings.
-- The harness sorts, so scheme/warn relative order is not load-bearing.  Mirrors
-- runCheck's single-file shape, but over the entry module of a resolved graph.
export checkModulesEntryReport : List Decl -> List Decl -> List (String, List Decl) -> String
checkModulesEntryReport runtimeDecls coreDecls modules =
  let (schemes, errs, warns) = checkModulesEntryFull runtimeDecls coreDecls modules
  match errs
    [] => joinNl (schemeLines schemes ++ map fst warns)
    _ => joinNl (typeErrorLines (map teErrMsg errs))

-- exit-code predicate analog of checkHasErrors: any type error in ANY module of
-- the resolved graph (entry or imported — see checkModulesEntryFullGo).
export checkModulesEntryHasErrors : List Decl -> List Decl -> List (String, List Decl) -> Bool
checkModulesEntryHasErrors runtimeDecls coreDecls modules =
  let (_, errs, _) = checkModulesEntryFull runtimeDecls coreDecls modules
  match errs
    [] => False
    _ => True

-- run the multi-module front-end and render the ENTRY module's own bindings as
-- `name : scheme` per line (the harness sorts) — diffs vs dev/tc_module_probe.
export checkModulesEntryLines : List Decl -> List Decl -> List (String, List Decl) -> String
checkModulesEntryLines runtimeDecls coreDecls modules =
  joinNl (schemeLines (entryOwnSchemes (checkModules
    runtimeDecls
    coreDecls
    modules)))

-- Emit EVERY module's bindings in one pass, each section preceded by a
-- `## MODULE <mid>` marker line.  A single full-closure run can then cover many
-- modules at once (the batch harness splits on the marker and diffs each
-- section vs its per-module oracle).  Scheme of a module depends only on its
-- dependency-closure (which precedes it in topo order), so a module's section
-- is identical whether checked alone or inside a larger union closure.
export checkModulesAllLines : List Decl -> List Decl -> List (String, List Decl) -> String
checkModulesAllLines runtimeDecls coreDecls modules =
  joinNl (allModuleLines (checkModules runtimeDecls coreDecls modules))

allModuleLines : List (String, List (String, Scheme)) -> List String
allModuleLines [] = []
allModuleLines ((mid, ss)::rest) =
  "## MODULE " ++ mid :: schemeLines ss ++ allModuleLines rest

-- ── TYPED multi-module elaboration (bootstrap eval front-end) ──────────────
-- The multi-module analog of `elaborate`: the composition of `checkModules`
-- (per-module-frame typecheck, dependency-first) and the EMethodAt route-
-- stamping `elaborate` does single-module.  prePasses the prelude + every module
-- (rewriting return-position method occurrences to EMethodAt over the WHOLE
-- program's RP method set), typechecks each module in dependency order (seeded
-- like checkModules), and STAMPS each module's route refs from its now-resolved
-- result types.  Returns the SAME trees (refs filled) so evalModules can route
-- return-position dispatch (`pure`/`andThen` — the Parser monad) by RKey instead
-- of the untyped arg-tag fallback.  RKey-only (dictNames = []): the bootstrap
-- source uses no `=>`-constrained user polymorphism, so no EDictAt / dict params
-- and no pendingDictApps / pendingRecDictApps to resolve.
export elaborateModules : List Decl -> List Decl -> List (String, List Decl) -> (List Decl, List (String, List Decl))
-- E4: under emitArgStampPasses (the LLVM emit drivers ONLY) apply D3b's ARG-position
-- dict-passing per module, mirroring elaborateDict.
--
-- implInferEnabled is now ON unconditionally (was `emitArgStampPasses.value`): the EVAL
-- path needs impl-body inference too, so a standalone-shadow method call INSIDE an
-- impl body (map's `Debug`/`Eq`/`Ord`/`Display (Map k v)` bodies all call standalone
-- `toList m`) RECORDS its RLocal site (recordRLocalSite → pendingRLocalSites) for
-- resolveRLocalSites to stamp.  Without it the impl-body `toList` route stayed at its
-- default RNone → eval arg-tag-dispatched a Map through the no-matching-tag `keepOrAll`
-- fallback to Foldable List's `toList = identity` → returned the Map unchanged →
-- `debug`/`display` recursed forever (SIGBUS on `medaka test stdlib/map.mdk`).  The
-- TYPECHECK golden probes use checkModulesEntryLines/checkModulesDiags (NOT
-- elaborateModules), so their goldens are unaffected; the emit-path diff gates run
-- with emitArgStampPasses True, where impl inference was already ON — also unchanged.
elaborateModules runtimeDecls coreDecls modulesIn =
  let _ = setRef implInferEnabled True
  -- IMPORT ALIASING of an interface/impl METHOD — resolve it back to the origin name
  -- before ANY of the marking / stamping / dict-arity machinery below runs.  See
  -- renameAliasedMethods: a method is global-by-name, so an alias of one is a second
  -- SPELLING, not a second binding.
  let modules = renameAliasedMethods coreDecls modulesIn
  let _ = setRef mainSchemeRef None
  let _ = resetCrossModuleState ()
  let allDecls = coreDecls ++ flatMap snd modules
  -- P0-18: recover the definer-shadow map from the (already-mangled on the emit path)
  -- decls BEFORE marking/typecheck reads it.  Empty on the un-mangled path.  Set once
  -- here; per-module resetState (in checkModuleFullImpl) does NOT clear it.
  let _ = setRef mangledShadowMapRef (computeMangledShadowMap allDecls (("core", coreDecls)::modules))
  let _ = setRef superDeclsRef allDecls  -- WS-1b: interfaces in scope for the discovery scratch typecheck
  let _ = setRef userIfaceNamesRef (collectIfaceNames (flatMap snd modules))  -- WS-1b: gate super-expansion to user interfaces
  let rpNames = returnPosMethodNames allDecls
  let _ = setRef argDispatchIdxRef (argDispatchIndices allDecls)
  let argNames = map fst argDispatchIdxRef.value
  let _ = setRef dictEligibleRef (moduleUserFnNames modules)
  let _ = setRef dictEligibleSetRef (namesToSet (moduleUserFnNames modules) omEmpty)
  let promoted = discoverPromotedModules runtimeDecls coreDecls modules rpNames argNames
  let bareDictNames = dedup (moduleDictNames coreDecls allDecls modules ++ promoted)
  -- IMPORT ALIASING: prePassDict* marks a call site `EVar n` as a dict application only
  -- when `n` is in dictNames — a set of DEFINITION names.  An aliased call site writes
  -- the LOCAL name, so unless the alias locals are added here the call is never marked,
  -- receives no dict arguments, and silently UNDER-APPLIES: `check` stays green and
  -- `run` dies downstream with a type-confused value (the Phase-134 shape).
  let dictNames = dedup (bareDictNames
    ++ aliasDictNames bareDictNames (("core", coreDecls)::modules) modules)
  let markRpNames = dedup (rpNames ++ methodConstraintNames allDecls ++ buildStandaloneShadowsGraph allDecls (flatMap snd modules))
  let core2 = prePassDictArg markRpNames dictNames argNames mangledShadowMapRef.value coreDecls
  let modules2 = map (prePassModulePairArg markRpNames dictNames argNames mangledShadowMapRef.value) modules
  let runtimeSeed = externSchemes runtimeDecls
  let coreSchemes = elabModuleStamp "" runtimeSeed [] core2 core2
  let _ = elabModulesGo (runtimeSeed ++ coreSchemes) coreSchemes [] (publicDataDecls core2) core2 modules2
  dictPassModulesIfEnabled dictNames core2 modules2
-- arg-position interface-method names whose route resolveArgStamps may stamp
-- (empty when OFF → prePassDictArg degenerates to prePassDict, goldens unchanged)

-- DRIVER-COLLAPSE Phase 2 (global): seed the promotion-eligible set with the USER
-- modules' top-level fn names (NOT core/prelude — those keep arg-tag / RKey
-- dispatch, which type-checks the goldens).  Previously gated on emitArgStampPasses
-- (build path only); now ALSO seeded on the eval path (emitArgStampPasses OFF) so
-- elaborateModules promotes INFERRED-constraint user fns exactly as flat
-- elaborateDict does (discoverAll runs discoverPromoted whenever eligibleNames is
-- non-empty, independent of emitArgStampPasses).  The TYPECHECK golden module drivers
-- (checkModulesEntryLines/checkModulesDiags) never reach elaborateModules, so their
-- goldens are unaffected; the eval goldens are captured from the OCaml oracle's
-- run, which dict-passes prelude+modules unconditionally — so promotion-on-eval
-- matches them.  Mirrors elaborateDict's dictEligibleRef seed.

-- Cause A / Phase 2: run a JOINT-flattened promotion fixpoint over runtime ++ core
-- ++ all modules (mirror discoverPromoted) so an unsignatured fn whose body
-- dispatches a method in ARG position (`f s = println s` → inferred `Display a => …`)
-- OR uses a return-position method (`doubleEmpty x = append (append x empty) empty`
-- → inferred `Monoid a => …`) is discovered + registered in
-- promotedRef/funConstraintsRef/activeDictVars.  The promoted names then join the
-- dict-name set so their call sites are marked EDictAt (caller supplies the dict
-- ARGUMENT) and their defs get the leading dict PARAM.  Now runs on BOTH paths
-- (eval too): with argNames=[] on eval it surfaces only RETURN-position inferred
-- constraints (no arg-position dict-passing), matching flat elaborateDict's eval
-- behaviour (emitArgStampPasses OFF ⇒ argNames=[] there too).

-- E6: dict-name set for the `=>`-constrained-function layer, mirroring the
-- single-file emit driver's assembly (llvm_emit_typed_main.runEmit): prelude
-- return- AND arg-position `=>`-constrained fns (clamp/debugListItems/…) plus the
-- modules' own constrained signatures.  [] when OFF (emitArgStampPasses gates every
-- consumer), so the golden module drivers compute nothing extra → byte-identical.
-- Used to MARK constrained-fn call sites EDictAt in the prePass (so the caller
-- supplies the dict ARGUMENT) AND to add the leading dict PARAM in the final
-- dictPass (so the callee body's witness binds).  BOTH halves are required: marking
-- alone under-defines the param; param alone under-applies the call (ABI mismatch).
-- Cause A: promoted (inferred-constraint) user fns join the set.

-- ARGSTAMP-UNIFY Phase 4: the eval-dict layer is now PERMANENTLY active on both
-- paths (flag retired).  Flat elaborateDict runs its resolve chain + dictPass
-- UNCONDITIONALLY; the 1-module / multi-module eval path matches, so method-level
-- constraints (`build : Num e =>`) and parametric-impl `requires` (`impl Default
-- (List a) requires Default a`) — which leave dictNames EMPTY (no top-level
-- constrained FUNCTION) but still need resolveMethodDicts / the DImpl dict-pass —
-- get serviced.  The dictPass/resolve passes are no-ops when nothing was marked, so
-- this leaves the golden eval trees byte-identical where there is nothing to
-- dict-pass.
-- C5: ALSO mark cross-module standalone-shadow method occurrences (box's
-- `toList`/`isEmpty`) as EMethodAt, so they carry a route ref for elabModuleStamp's
-- resolveRLocalSites to stamp RLocal.  Without this they stay EVar (arg-position,
-- emitArgStampPasses OFF on the eval path) → no route ref → arg-tag panic on a no-impl
-- receiver.  Only added to the MARK set (not rpNames proper, which discoverPromoted
-- etc. consume) so other passes are unchanged.
-- DRIVER-COLLAPSE Phase 2: ALSO include methodConstraintNames (methods with their OWN
-- method-level `=>` constraint, e.g. `build : Num e => e -> t`), mirroring flat
-- elaborateDict's prePass mark set (`returnPosMethodNames prog ++ methodConstraintNames
-- prog`).  Without it the method-constraint occurrence stays unmarked → its impl
-- clause's leading method-dict param is dropped/mis-bound → `non-exhaustive match`
-- (method_constraint_impl_offset).

-- impl table accumulates across modules (dependency order): a module's
-- arg-position dispatch can thread an EARLIER module's / core's parametric
-- `requires` element dict.  core2 seeds it.

-- E5: on the emit path (emitArgStampPasses), dict-pass each module's now-stamped
-- trees, mirroring elaborateDict's final `dictPass`.  A parametric `requires`
-- impl whose body element-dispatch E5 routed RDict needs its leading
-- `$dict_<m>_<slot>` PARAM (dictPassDecl's DImpl arm) so the emitter can bind the
-- witness the route references; the call site's impl-dict route (filled by
-- resolveArgStamp) supplies the matching ARGUMENT.  E6: dictNames now carries the
-- prelude/module `=>`-constrained fns (clamp/debugListItems/displayListItems/…),
-- so dictPassDecl's DFunDef arm ALSO prepends their `$dict_<fn>_<slot>` params —
-- closing the "unbound dict witness" residual.  OFF (oracle eval_typed_modules +
-- every golden module driver), dictPass is skipped → core2/modules2 returned
-- verbatim, byte-identical with the pre-E5 trees.

-- E5/E6: gated final dict-pass of the stamped module trees (emit path only).
-- [dictNames] is the prelude + module `=>`-constrained fn set; [] when OFF.
-- E6: each module's typecheck calls resetState, which clears funConstraintsRef,
-- so by this final pass only the LAST module's constraint arities survive — a
-- core-level constrained fn like `clamp` would get `dictArityOf` = 0 and NO leading
-- param.  Re-seed funConstraintsRef from every constrained signature (core +
-- modules) so dictPassDecl's DFunDef arm prepends the right number of
-- `$dict_<fn>_<slot>` params.  Only the COUNT is read here (the body's EDictAt/RDict
-- routes were already stamped, with real ids, during each module's own pass), so a
-- placeholder id list of the correct length is sufficient.  Prepended → wins the
-- lookupAssocSL2 first-match over any stale last-module entry.  Gated by the
-- emitArgStampPasses guard below (golden drivers never reach it).
-- Step 4 (Phase-134 fix): per-module importer-scoped arity, mirroring the oracle
-- eval.ml:2104-2164 collect_arities-per-scope.  The pre-fix JOINT
-- seedDictAritiesFromSigs keyed arity by BARE NAME, so a constrained fn in module A
-- forced spurious leading dict params onto an unconstrained same-named fn in module
-- B (whose call sites then under-applied → silent partial closure).  Core
-- (≈ the oracle's prelude) is imported by every module, so it keeps the FULL joint
-- scope.  Each module's scope = its own decls ∪ the decls of its transitive
-- importers ∪ core (the importer part covers a PUBLIC constrained fn referenced only
-- by its importers; mangleUnits already de-collided PRIVATES).  promotedC = the
-- joint-discovered promoted-fn arities (unsignatured, so constrainedSigArity misses
-- them) carried across resetState in crossModuleFunConstraintsRef.
dictPassModulesIfEnabled : List String -> List Decl -> List (String, List Decl) -> (List Decl, List (String, List Decl))
dictPassModulesIfEnabled dictNames core2 modules2 =
  let allModDecls = flatMap snd modules2
  let promotedQ = crossModuleFunConstraintsQualRef.value
  let allMods = namesToSet (map fst modules2) omEmpty
  let _ = setRef funConstraintsRef (scopeArities promotedQ allMods (core2 ++ allModDecls))
  let _ = setRef methodConstraintsRef (scopeMethodArities crossModuleMethodConstraintsQualRef.value allMods)
  let core2' = dictPass dictNames core2
  let modules2' = dictPassModulesScoped dictNames promotedQ core2 modules2 modules2
  (core2', modules2')
-- Post-ARGSTAMP-UNIFY (Phase 4): ALWAYS run on BOTH paths.  Emit (emitArgStampPasses):
-- the DImpl arm prepends parametric impl-body element-dict params even when no
-- top-level `=>`-constrained FUNCTION is in [dictNames] (e.g. the empty-prelude
-- nested_dict_dispatch fixture: a parametric `Cmp (Box a) requires Cmp a` with no
-- constrained fn).  Eval: same — a parametric-impl `requires` whose DImpl body needs
-- its leading element-dict param (nested_instance_dicts: `impl Default (List a)
-- requires Default a`) gets dict-passed even with no top-level constrained FUNCTION.
-- Mirrors flat elaborateDict's unconditional final dictPass.  No-op when nothing was
-- marked → byte-identical golden trees.  scopeArities sizes each define's leading
-- dict params to its surviving-constraint count.  (Was the always-True
-- `emitArgStampPasses || evalDictLayerActive` clause guard.)

-- per-module: set funConstraintsRef to the module's importer-scoped arities, then
-- dict-pass that module.  [allModules] is the full set (for the transitive-importer
-- walk); [modules2] is the remaining suffix to process.  core2 is always in scope.
dictPassModulesScoped : List String -> List ((String, String), List Int) -> List Decl -> List (String, List Decl) -> List (String, List Decl) -> List (String, List Decl)
dictPassModulesScoped _ _ _ _ [] = []
dictPassModulesScoped dictNames promotedQ core2 allModules ((mid, prog)::rest) =
  let importerDecls = transitiveImporterDecls mid allModules
  let scope = core2 ++ prog ++ importerDecls
  let scopeMods = namesToSet (mid :: transitiveImporterIds mid allModules) omEmpty
  -- IMPORT ALIASING: scopeArities keys arity by the DEFINITION's name, but an aliased
  -- call site in THIS module writes the LOCAL name.  Re-key this module's own aliases
  -- (from its DUse decls) onto the origin's arity, else the aliased call under-applies
  -- its dicts.  This is the RUN/eval path's counterpart to the same fix in
  -- checkModuleFullImpl — the EMIT path never needs it, because private_mangle has
  -- already rewritten `A.name` to the origin's real symbol before this point.
  let _ = setRef funConstraintsRef (aliasConstraintEntries prog promotedQ
    ++ scopeArities promotedQ scopeMods scope)
  let _ = setRef methodConstraintsRef (scopeMethodArities crossModuleMethodConstraintsQualRef.value scopeMods)
  (mid, dictPass dictNames prog) :: dictPassModulesScoped dictNames promotedQ core2 allModules rest

-- the arity table for a scope: every `=>`-constrained signature in [scope]
-- (constrainedSigArity) PLUS the joint-discovered promoted-fn arities whose fn is
-- DEFINED in [scope] (so a promoted fn out of scope doesn't leak a param count in).
-- #55: the signature count (`constrainedSigArity`) is the SYNTACTIC `=>`-constraint
-- count; the INFERRED count in [promotedC] (crossModuleFunConstraintsRef, the
-- surviving generalized constraint vars from each body's inference) is what every
-- CALL site computes (constraintMonosOf over the call's instantiated scheme).  These
-- diverge for a point-free fn whose body MONOMORPHIZES a constraint var — e.g.
-- `sum = fold (+) 0`: the `0` literal is typed `Int` (litType), pinning `Num a`'s `a`
-- to `Int`, so `a` is NOT generalized → the scheme keeps only `Foldable t` (1
-- constraint) while the signature still lists 2.  If the define were sized off the
-- 2-count sig it would take 2 leading dict params while call sites pass 1 (dict +
-- container) → the container arg lands in an unpassed register → garbage deref /
-- SIGSEGV at -O2.  So for a fn WITH an inferred entry, the inferred arity WINS (drop
-- its sig entry); the sig count is the fallback for fns the body-inference path never
-- registered (unreached/never-called constrained fns).  `elem` is unaffected: both
-- its `Eq a` and `Foldable t` vars survive (no literal pins them) → inferred == sig == 2.
-- WS-2/D2: [promotedQ] is the module-attributed inferred arities
-- (crossModuleFunConstraintsQualRef); [scopeMods] is the set of module ids in this
-- dict-pass scope (this module ∪ its transitive importers ∪ "" for core, which is in
-- every scope).  An inferred entry survives when its fn NAME is in scope (as before).
-- For the SUBSET of names that collide (same bare name from ≥2 modules), prefer the
-- entry whose OWNING module is in scope — that disambiguation is the WS-2/D2 fix.
-- A non-colliding name, or a colliding name with NO in-scope-module entry, keeps the
-- old bare behavior (every same-name entry retained; first-match downstream).  This
-- is intentionally minimal: it changes arity ONLY for the cross-module bare-name
-- collision, so non-colliding programs (every golden) are byte-identical.
-- Reduces the qualified entries to the bare (name,ids) form downstream readers expect.
scopeArities : List ((String, String), List Int) -> OrdMap Unit -> List Decl -> List (String, List Int)
scopeArities promotedQ scopeMods scope =
  let scopeNames = namesToSet (declTopFnNames scope) omEmpty
  let nameInScope = filterList (e => omHasKey (snd (fst e)) scopeNames) promotedQ
  -- names that have at least one in-scope-module entry → drop their out-of-scope-module twins
  let resolvedNames = namesToSet (map (e => snd (fst e)) (filterList (e => modInScope (fst (fst e)) scopeMods) nameInScope)) omEmpty
  let inferredQ = filterList (e => modInScope (fst (fst e)) scopeMods || not (omHasKey (snd (fst e)) resolvedNames)) nameInScope
  let inferred = map (e => (snd (fst e), snd e)) inferredQ
  let inferredNames = namesToSet (map fst inferred) omEmpty
  let sigEntries = filterList (e => not (omHasKey (fst e) inferredNames)) (flatMap constrainedSigArity scope)
  inferred ++ sigEntries

-- WS-2/D2 method analog of scopeArities, WITHOUT the sig-fallback: every method-level
-- constraint is registered during its interface module's typecheck
-- (registerMethodConstraints over ifaceMethodSchemes), so there is no
-- unsignatured-promoted residual to seed from signatures.  No method-name scope filter
-- either: keep every entry whose bare method name does NOT collide across modules (so a
-- method whose impl lives in a different module than its interface is never dropped),
-- and for the SUBSET of names that DO collide, prefer the entry whose owning (interface)
-- module is in [scopeMods] — the bare-name disambiguation.  Non-colliding programs keep
-- every entry → the per-scope methodConstraintsRef is identical to the bare accumulated
-- table → byte-identical method dict-pass (every existing fixture, and the fixpoint).
scopeMethodArities : List ((String, String), List Int) -> OrdMap Unit -> List (String, List Int)
scopeMethodArities promotedMQ scopeMods =
  let resolvedNames = namesToSet (map (e => snd (fst e)) (filterList (e => modInScope (fst (fst e)) scopeMods) promotedMQ)) omEmpty
  let kept = filterList (e => modInScope (fst (fst e)) scopeMods || not (omHasKey (snd (fst e)) resolvedNames)) promotedMQ
  map (e => (snd (fst e), snd e)) kept

-- core (mid "") is in every scope; otherwise membership in the scope-module set.
modInScope : String -> OrdMap Unit -> Bool
modInScope mid scopeMods = mid == "" || omHasKey mid scopeMods

-- attribute each fn DEFINED in [prog] that carries a funConstraintsRef entry to [mid].
attributeModuleArities : String -> List Decl -> List (String, List Int) -> List ((String, String), List Int)
attributeModuleArities mid prog entries =
  let progNames = namesToSet (declTopFnNames prog) omEmpty
  map
    (e => ((mid, fst e), snd e))
    (filterList (e => omHasKey (fst e) progNames) entries)

-- WS-2/D2: ifaces analog of attributeModuleArities — attribute each fn DEFINED in [prog]
-- that carries a funConstraintIfacesRef entry to [mid], slot-parallel to the arity qual
-- snapshot, so inferDictAtFound reads a callee's ids + ifaces from one (mid,name) source.
attributeModuleArrIfaces : String -> List Decl -> List (String, List String) -> List ((String, String), List String)
attributeModuleArrIfaces mid prog entries =
  let progNames = namesToSet (declTopFnNames prog) omEmpty
  map
    (e => ((mid, fst e), snd e))
    (filterList (e => omHasKey (fst e) progNames) entries)

-- WS-2/D2 method analog: attribute each method whose INTERFACE is declared in [prog]
-- (carrying a methodConstraintsRef entry) to [mid].  Keyed by the interface's module —
-- the arity is a property of the method signature, registered during that module's
-- ifaceMethodSchemes pass.
attributeMethodModuleArities : String -> List Decl -> List (String, List Int) -> List ((String, String), List Int)
attributeMethodModuleArities mid prog entries =
  let progMethods = namesToSet (allIfaceMethodNames prog) omEmpty
  map
    (e => ((mid, fst e), snd e))
    (filterList (e => omHasKey (fst e) progMethods) entries)
-- membership-only sets (built once) instead of O(N) contains scans per entry:
-- scopeNames (~all top-level fn names) was scanned per promotedC entry → O(N²).

declTopFnNames : List Decl -> List String
declTopFnNames decls = map fst (funDefs decls)

-- the decls of every module that transitively imports [mid] (excluding [mid]),
-- so a public constrained/promoted fn defined in [mid] but referenced only by an
-- importer is in scope when [mid] is dict-passed.
transitiveImporterDecls : String -> List (String, List Decl) -> List Decl
transitiveImporterDecls mid modules = flatMap
  (p => if fst p != mid && transitivelyImports (fst p) mid modules then snd p else [])
  modules

-- the module IDS that transitively import [mid] (excluding [mid]) — the id-level
-- analog of transitiveImporterDecls, for the scopeArities owning-module set.
transitiveImporterIds : String -> List (String, List Decl) -> List String
transitiveImporterIds mid modules = flatMap
  (p => if fst p != mid && transitivelyImports (fst p) mid modules then [fst p] else [])
  modules

-- does module [a] transitively import module [target]?
transitivelyImports : String -> String -> List (String, List Decl) -> Bool
transitivelyImports a target modules = depReaches [] a target modules

depReaches : List String -> String -> String -> List (String, List Decl) -> Bool
depReaches seen a target modules
  | contains a seen = False
  | otherwise =
    let deps = directImports a modules
    contains target deps || anyDepReaches (a::seen) deps target modules

anyDepReaches : List String -> List String -> String -> List (String, List Decl) -> Bool
anyDepReaches _ [] _ _ = False
anyDepReaches seen (d::rest) target modules = depReaches seen d target modules
  || anyDepReaches seen rest target modules

-- the module ids module [mid] imports directly (from its DUse decls), mirroring the
-- oracle's path→module-id mapping (last component of a dotted UseName, else the path).
directImports : String -> List (String, List Decl) -> List String
directImports mid modules = match lookupAssoc mid modules
  Some prog => flatMap useModuleId prog
  None => []

useModuleId : Decl -> List String
useModuleId (DUse _ path _) = [usePathModuleId path]
useModuleId _ = []

usePathModuleId : UsePath -> String
usePathModuleId (UseName ns)
  | listLen ns > 1 = joinDot (initList ns)
  | otherwise = lastComponent ns
usePathModuleId (UseGroup ns _) = joinDot ns
usePathModuleId (UseWild ns) = joinDot ns
usePathModuleId (UseAlias ns _) = joinDot ns

lastComponent : List String -> String
lastComponent [] = ""
lastComponent [x] = x
lastComponent (_::rest) = lastComponent rest

-- E6: the `=>`-constrained-function dict-name set for the module emit path,
-- mirroring the single-file driver (llvm_emit_typed_main.runEmit): prelude return-
-- AND arg-position constrained fns (clamp/debugListItems/displayListItems/…) plus
-- every module's own constrained signatures.  Both eval and emit paths return the
-- same set; guarded so prePass/dictPass both see the SAME set.
moduleDictNames : List Decl -> List Decl -> List (String, List Decl) -> List String
moduleDictNames coreDecls allDecls modules = preludeReturnPosDictNames coreDecls allDecls
  ++ preludeArgPosDictNames coreDecls allDecls
  ++ constrainedSigNames (flatMap snd modules)
-- EVAL path: even with arg-position stamping OFF, the constrained prelude/module
-- fns MUST be dict-passed.  DRIVER-COLLAPSE Phase 2: the MODULE part now uses the
-- FULL constrainedSigNames (every `=>`-constrained module signature), mirroring flat
-- elaborateDict's caller (constrainedSigNames userDecls) — NOT the return-position
-- subset.  Rationale: dictPass adds a leading dict PARAM to every fn whose
-- constrained signature is in scopeArities (all constrained sigs), so the prePass
-- MARK set must match or a fn like `quad : Monoid a => a -> a` (body calls another
-- constrained fn, NOT a return-position method directly) gets the PARAM but its call
-- sites are unmarked → `unbound identifier: $dict_quad_0`.  The PRELUDE part stays
-- return-position-only (preludeReturnPosDictNames): arg-position prelude helpers
-- (neq/elem/clamp) keep arg-tag dispatch in ceval and sweeping them in re-triggers
-- the prop-shrinker `neq`-hang.  User modules have no such hazard (flat already
-- dict-passes their full constrained set).  #55 background: their bodies route a
-- return-position method (`fromInt`/`pure`) RDictFwd `$dict_<fn>_<slot>` during the
-- per-module typecheck (registerConstraintRegs ungated); with no leading dict PARAM
-- the witness is unbound.  The OCaml oracle's eval_modules dict-passes
-- prelude+modules unconditionally; this mirrors that.
-- ARGSTAMP-UNIFY Phase 1 (F10 dict-set convergence): the eval branch now ALSO
-- includes preludeArgPosDictNames, matching the emit branch's dict-name set.
-- First convergence step toward flipping eval to full dict-threading.  By itself
-- OUTPUT-invariant: an arg-position prelude fn that is ALSO arg-tag-dispatchable
-- gets a redundant (not wrong) dict pass.  NOTE the historical neq-hang risk
-- (prop-shrinker oscillation when neq/elem/any/… were swept into the eval dict
-- set); guarded by the `medaka test stdlib/core.mdk` canary.

constrainedSigArity : Decl -> List (String, List Int)
constrainedSigArity (DTypeSig _ n ty)
  | isConstrainedTy ty = [(n, zerosL (listLen (sigConstraints ty)))]
  | otherwise = []
constrainedSigArity _ = []

zerosL : Int -> List Int
zerosL k
  | k <= 0 = []
  | otherwise = 0 :: zerosL (k - 1)

prePassModulePair : List String -> (String, List Decl) -> (String, List Decl)
prePassModulePair rpNames (mid, prog) = (mid, prePassDict rpNames [] prog)

-- E4/E6: prePass a module rewriting ARG-position method occurrences to EMethodAt
-- (argNames) AND `=>`-constrained-fn occurrences to EDictAt (dictNames); both
-- non-empty only under emitArgStampPasses.  Degenerates to prePassModulePair when both
-- are [] (prePassDictArg with empty argNames/dictNames == prePassDict).
prePassModulePairArg : List String -> List String -> List String -> List (String, String) -> (String, List Decl) -> (String, List Decl)
prePassModulePairArg rpNames dictNames argNames shadowMap (mid, prog) =
  (mid, prePassDictArg rpNames dictNames argNames shadowMap prog)

-- The mark sub-phase of elaborateModules (RKey-only): compute rpNames over the
-- full module graph and prePassDict each module.  Exported so profiling drivers
-- can bracket the mark phase vs the typecheck phase separately.
export markModules : List Decl -> List (String, List Decl) -> (List Decl, List (String, List Decl))
markModules coreDecls modules =
  let rpNames = returnPosMethodNames (coreDecls ++ flatMap snd modules)
  let core2 = prePassDict rpNames [] coreDecls
  let modules2 = map (prePassModulePair rpNames) modules
  (core2, modules2)

-- typecheck one module (seeded like checkModuleFull) AND immediately stamp the
-- EMethodAt route refs it just recorded.  checkModuleFull's resetState clears
-- pendingSites before inference, so on return pendingSites holds exactly THIS
-- module's sites; the tyvar cells are still bound (the next module's resetState
-- hasn't run yet), so resolveSites reads each site's resolved result type.
-- E4: under emitArgStampPasses, ALSO stamp this module's ARG-position sites
-- (pendingArgStamps, likewise this-module-only after resetState) from their now-
-- resolved discriminating-argument monos — the multi-module analogue of
-- elaborateDict's resolveArgStamps.  [implDecls] is core + every EARLIER module +
-- this module, so a cross-module parametric `requires` element dict resolves; a
-- still-unresolvable case stays RNone (arg-tag fallback).  activeDictVars (the
-- constraint-var → dict-param map registerConstraintRegs built in checkModuleFull)
-- is also still bound, so a tyvar receiver routes RDict.
elabModuleStamp : String -> List (String, Scheme) -> List Decl -> List Decl -> List Decl -> List (String, Scheme)
elabModuleStamp mid seedVars accData implDecls prog =
  let _ = setRef superDeclsRef implDecls  -- WS-1b: interfaces in scope for super expansion
  let schemes = checkModuleFullImpl mid seedVars accData implDecls prog
  let _ = setNumlitFloats ()  -- PLAN.md #11: stamp Float-typed int literals (per module, before dictPass)
  let stampImplTable = buildImplTable implDecls
  -- #150 level-1: hoist the impl KEY table (was rebuilt from `implDecls` at each of
  -- the five resolve* sites below).  buildKeyTable is a pure function of implDecls,
  -- so one build feeds all five byte-identically — one O(cumulative decls) pass per
  -- module instead of five.
  let stampKeyTable = buildKeyTable implDecls
  let _ = resolveSites stampImplTable stampKeyTable (returnPosMethodNames implDecls) pendingSites.value
  let _ = resolveOpSites True stampImplTable stampKeyTable pendingBinopSites.value
  let _ = resolveOpSites False stampImplTable stampKeyTable pendingUnopSites.value
  let _ = resolveArithSites pendingArithSites.value
  let _ = resolveArgStamps stampImplTable stampKeyTable pendingArgStamps.value
  let _ = resolveRLocalSites implDecls stampImplTable stampKeyTable pendingRLocalSites.value
  let _ = realizeRecDictApps pendingRecDictApps.value
  let _ = resolveDictApps implDecls stampImplTable pendingDictApps.value
  let _ = resolveMethodDicts stampImplTable pendingMethodDicts.value
  schemes
-- DRIVER-COLLAPSE Phase 2: pass the return-position method names (was `[]`) so
-- resolveSite's RDict-case routes a RETURN-position method site RDictFwd (forward the
-- enclosing dict's nested reqs) rather than RDict (arg-position).  Flat elaborateDict
-- passes `returnPosMethodNames prog2`; the empty list mis-stamped a parametric-impl
-- body's inner return-position method (`impl Default (List a) requires Default a where
-- def = [def]` — the inner `def` must be RDictFwd:$dict_def_0, not RDict) → eval
-- `no matching impl for dispatch` (nested_instance_dicts).  `implDecls` is this
-- module's full impl universe (core/earlier-modules ++ prog), the analogue of flat's
-- whole-program `prog2`.

-- Phase 151 / Gap G: stamp this module's comparison-operator binop sites.
-- UNGATED (mirrors flat elaborateDict, which calls resolveBinopSites
-- unconditionally) so the EVAL path also dispatches `==`/`<`/… to user/derived
-- Eq/Ord impls (adt_deriving_ord / record_deriving_ord).  No-op when
-- pendingBinopSites is empty (no comparison-operator site) → golden type-only
-- path leaves them RNone → dictPass-skipped → byte-identical.  Gap #21: on the
-- EVAL path stampBinopRoute now stamps `RKey key []` (element reqs gated on
-- emitArgStampPasses), which only narrows the method VMulti and applies ZERO dicts,
-- so even a RECURSIVE user Eq impl (json's `impl Eq Json`) dispatches inner
-- operands by arg-tag without over-applying — no suppression needed.

-- C5: LAST among the route-stampers (after resolveSites AND resolveArgStamps) so the
-- receiver-grounded RLocal/RNone overrides whatever those stamped on the SAME ref —
-- resolveSites mis-stamps RKey<resultType> (eval path) and resolveArgStamps stamps
-- RKey<receiverHead> (emit path), both wrong for a standalone-shadow site.

-- E6: fill THIS module's `=>`-constrained-fn EDictAt routes (the call sites
-- prePassDictArg marked) so the emitter supplies the matching dict ARGUMENT —
-- realizeRecDictApps for self/mutually-recursive calls, resolveDictApps for the
-- normal ones.  ARGSTAMP-UNIFY Phase 4: unconditional on BOTH paths — the eval path
-- also marks the RETURN-position constrained fns (sum/product/when/unless) EDictAt
-- via moduleDictNames, so their call-site routes must resolve here too.  No-op when
-- nothing was marked (pendingDictApps/pendingRecDictApps empty → golden drivers
-- byte-identical).  (Was the always-True `emitArgStampPasses || evalDictLayerActive`.)

-- G7: fill each foldMap-style method occurrence's methRoutes from the monos its
-- `Monoid m` constraint resolved to AT THE CALL SITE (List vs String), so
-- emitDefaultRKey threads the right per-call dict word into the shared default body.
-- Independent of the body-side dict routing (the emitter restamps the body's
-- cross-interface `empty` to its `$dict_<method>_<slot>` param directly).
-- ARGSTAMP-UNIFY Phase 4: run unconditionally on BOTH paths (was the always-True
-- `emitArgStampPasses || evalDictLayerActive`), mirroring flat elaborateDict (which
-- calls resolveMethodDicts unconditionally) — a method with its OWN method-level
-- constraint (`build : Num e => e -> t`) needs its method-dict route filled so its
-- impl clause binds the leading dict param instead of mis-binding it into the first
-- value param (method_constraint_impl_offset: was `non-exhaustive match`).  No-op
-- when pendingMethodDicts is empty → golden drivers byte-identical.

elabModulesGo : List (String, Scheme) -> List (String, Scheme) -> List (String, List (String, Scheme)) -> List Decl -> List Decl -> List (String, List Decl) -> Unit
elabModulesGo _ _ _ _ _ [] = ()
-- IMPORT-SCOPED seed (see importSeed / checkModulesGo): only the names THIS
-- module's DUse decls import; accAll stays the cumulative impl-body universe.
elabModulesGo baseSeed coreV depEnv accData accAll ((mid, prog)::rest) =
  let seed = baseSeed ++ importSeed prog depEnv
  let schemes = elabModuleStamp mid seed accData (accAll ++ prog) prog
  let _ = match lookupAssoc "main" schemes
    Some s => setRef mainSchemeRef (Some s)
    None => ()
  let pubV = pickSchemes (publicValNames prog) schemes ++ reexportSeed coreV prog depEnv
  elabModulesGo
    baseSeed
    coreV
    ((mid, pubV)::depEnv)
    (accData ++ publicDataDecls prog)
    (accAll ++ prog)
    rest

schemeLines : List (String, Scheme) -> List String
schemeLines [] = []
schemeLines ((n, s)::rest) = "\{n} : \{ppSchemeNamed n s}" :: schemeLines rest
