}
import backend.trmc_analysis.{
  SelfRef(..),
  trmcEligible,
  isCtorTail,
  isSelfSatApp,
  consTailArgs,
  ctorTailName,
  ctorTailLeadFields,
  ctorTailSelfIdx,
}
import backend.private_mangle.{hashName}
import backend.emit_support.{
  eagerVars,
  methodIfaceTableRef,
  methodArityOf,
  methodIfaceOf,
}
import backend.wasm_preamble.{
  preambleHeadLines,
  closTypeLines,
  closApplyLines,
  ioByteImportLines,
  strTypeLines,
  ioRuntimeLines,
  ioStrRuntimeLines,
  stderrByteImportLines,
  stderrRuntimeLines,
  strLeafRuntimeLines,
  strConcatRuntimeLines,
  appendRuntimeLines,
  valueEqRuntimeLines,
