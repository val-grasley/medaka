-- ── static value kind (scalar-mode only; for the auto-print routing) ─────────
data WTy = WInt | WBool | WUnit | WStr | WRef | WChar | WFloat

-- ── program info threaded through the ref-mode emitter ───────────────────────
-- ctorArs: ctor name → arity.  ctorTypes: ctor name → owning type name.
-- typeNames: distinct user type names in declaration order (for per-type ids).
-- useRef: whether this program uses any ADT (→ the §8.6 (ref eq) rep).
-- fnNames / valNames: top-level functions / value-globals (as in W2).
-- fnArs: top-level fn name → param count (its arity, for closure wrappers + the
--   over/under-application decision at a known-fn application site).
-- useClos: whether this program uses closures / higher-order application / a
--   multi-clause-or-pattern-param fn (→ the §4 closure ABI + universal apply, and
--   forces ref-mode since a closure captures heterogeneous values).
-- impls (W5): the lowered typeclass impl/default entries (CProgram's 4th field).
--   Threaded so the CMethod/CDict dispatch arms can resolve candidate impls
--   (RDict runtime switch needs the full candidate set; RKey the single match).
data Prog =
  | Prog (List (String, Int)) (List (String, String)) (List String) Bool (List String) (List String) (List (String, Int)) Bool (List CImplEntry)

progFnNames : Prog -> List String
progFnNames (Prog _ _ _ _ fns _ _ _ _) = fns

progValNames : Prog -> List String
progValNames (Prog _ _ _ _ _ vals _ _ _) = vals

progFnArs : Prog -> List (String, Int)
progFnArs (Prog _ _ _ _ _ _ ars _ _) = ars

progUseClos : Prog -> Bool
progUseClos (Prog _ _ _ _ _ _ _ uc _) = uc

-- W5: the lowered typeclass impl entries (CProgram's 4th field).
progImpls : Prog -> List CImplEntry
progImpls (Prog _ _ _ _ _ _ _ _ impls) = impls

-- ── method → DECLARED interface arity table (W9b — port of llvm_emit's) ───────
-- The REAL prelude carries POINT-FREE impls whose source clause arity is LESS than
-- the method's declared user arity: `length = fold g 0` (clause arity 0, method
-- arity 1), `toList = identity` (0 vs 1), `foldMap f = fold …` (1 vs 2), `filter p
-- = filterMap …` (1 vs 2).  Such an impl's `@mdk_impl_<tag>_<method>` function is
-- emitted at the SHORT clause arity, but DISPATCHED at the full method arity (the
-- call site passes every declared arg) → the impl fn has fewer params than the call
-- supplies → invalid WAT ("expected (ref eq) but nothing on stack").  Eta-expanding
-- the impl body to the method's FULL declared arity (gatherImplGroup) makes the
-- define and the call sites agree.
--
-- This table maps a BARE method name to its DECLARED interface arity (the true USER
-- arity, SEPARATE from the forwarded `requires`/method-level dict params the dict-
-- pass prepends).  Keyed by bare method name (interface method names are distinct in
-- the prelude).  A max-clause-arity heuristic is WRONG: a `Debug (List a) requires
-- Debug a` impl's leading requires-dict inflates the apparent arity, so the separation
-- via methodArityOf + implReqCount is load-bearing.  Installed from the modules entry
-- (installMethodIface) before emitProgram; an empty table (the prelude-free W2/W5
-- entries never install it) ⇒ methodArityOf returns 0 ⇒ eta-expansion is a no-op ⇒
-- byte-identical to the pre-W9b behaviour.
-- The table Ref + the `methodArityOf`/`methodIfaceOf` readers live in
-- `backend.emit_support` (shared with the LLVM emitter); `installMethodIface`
-- stays here as the WasmGC-side install entry point the emit drivers import.
export installMethodIface : List (String, (String, Int)) -> <Mut> Unit
installMethodIface t = setRef methodIfaceTableRef t

-- C4 (SHARED-FLOAT-RESIDUAL-DESIGN §6): hint from the driver: True when typecheck
-- resolved main's inferred return type to Float (e.g. via a polymorphic HOF like
-- `fold` whose result specialises to Float with no explicit annotation).  When set,
-- `emitRefMain` overrides the structural `refMainKind` (which defaults to WInt on
-- type-erased returns) and emits the WFloat auto-print path.  Set by the emit driver
-- after elaborateModules via installMainIsFloatHint; False in prelude-free entries.
mainIsFloatHintRef : Ref Bool
mainIsFloatHintRef = Ref False

export installMainIsFloatHint : Bool -> <Mut> Unit
installMainIsFloatHint b = setRef mainIsFloatHintRef b

-- ── decl → DECLARED return type-head name table (W9b — for Unit-main detection) ─
-- `declSigTypeNames` maps a top-level binding name to (param-type-heads, return-type-
-- head).  A value main `main = println (10 + 5)` whose head function `println` is
-- declared `Display a => a -> <IO> Unit` must NOT auto-print its Unit result (the
-- "Unit main no auto-print" contract — the trailing `0` bug); a structural-only
-- `refMainKind` can't see through the `println` wrapper to the Unit, so it routes the
-- result to the Int printer.  Installed from the modules entry (installDeclRetTypes);
-- empty (prelude-free entries) ⇒ declRetTypeOf returns "" ⇒ unchanged.
declRetTypesRef : Ref (List (String, (List String, String)))
declRetTypesRef = Ref []

export installDeclRetTypes : List (String, (List String, String)) -> <Mut> Unit
installDeclRetTypes t = setRef declRetTypesRef t

-- the declared return type-head name of a top-level binding ("" = unknown).
declRetTypeOf : String -> <Mut> String
declRetTypeOf name = match lookupAssoc name declRetTypesRef.value
  Some (_, ret) => ret
  None => ""

-- W-SQLITE-4: the declared param type-head names of a top-level fn ([] = unknown).
declParamTypesOf : String -> <Mut> List String
declParamTypesOf name = match lookupAssoc name declRetTypesRef.value
  Some (ps, _) => ps
  None => []

-- W-SQLITE-4 (float-return registry): does this fn's DECLARED signature return a
-- Float?  Consulted by `cexprIsFloat`'s CApp arm so Float arithmetic at a call to a
-- user fn returning Float (`acc + cellNumF c`, `cellNumF : Cell -> Float`) is
-- recognized even with no co-located Float literal — the analog of the native
-- emitter's `declRetLTy`.  Additive: an unknown/Int-returning fn stays the Int path.
fnReturnsFloat : String -> Bool
fnReturnsFloat name = match lookupAssoc name declRetTypesRef.value
  Some (_, ret) => ret == "Float"
  None => False

-- the declared arity (param count) of a top-level function, or -1 if not a fn.
progFnArity : Prog -> String -> Int
progFnArity prog n = match lookupAssoc n (progFnArs prog)
  Some a => a
  None => -1

-- W9: canonicalize a referenced fn name against the defined-fn set, mirroring DCE's
-- canonRef + the LLVM emitter's canonFnName.  `mangleUnits` renames prelude defs to
-- `core__<name>` AND rewrites uses present at mangle time — but the desugar/elaborate
-- passes SYNTHESIZE bare prelude references afterwards (notably string-interp `\{e}`
-- → `debug`/`debugStringLit`/`displayListItems`, and `!=` → `not`).  Such a bare ref
-- does not match its `core__`-mangled def by string equality, so resolve it: if the
-- bare name isn't a defined fn but its `core__` form is, use the mangled name.
canonFn : Prog -> String -> String
canonFn prog n =
  if contains n (progFnNames prog) then
    n
  else if contains ("core__" ++ n) (progFnNames prog) then
    "core__" ++ n
  else
    n

-- ── program entry ────────────────────────────────────────────────────────────
-- W4 module-level state for lambda lifting.  `lamIdRef` is the fresh-id counter for
-- lifted-lambda names (`$mdk_lamN`); `liftedFnsRef` accumulates the lifted top-level
-- function definitions emitted by `emitClosure`, drained at the end of the module
-- (peer to the LLVM emitter's defs list).  `funcRefsRef` accumulates the names that
-- must be `(elem declare func …)`'d so `ref.func` validates.  Reset per program.
lamIdRef : Ref Int
lamIdRef = Ref 0

liftedFnsRef : Ref (List (List String))
liftedFnsRef = Ref []

-- Names of lifted defines whose body is fully determined by the name (the eta-wrap
-- ctor `$mdk_wctor_<C>` and extern `$mdk_ext_<name>` closures) — used to dedup so a
-- ctor/extern referenced point-free at MORE THAN ONE site emits its lifted (func …)
-- ONCE.  `noteFuncRef` already deduped the matching `(elem declare)`, but `addLifted`
-- did not dedup the define, so a second use-site duplicated the func → "duplicate func
-- identifier" at wasm-tools assembly (`$mdk_lamN` names are unique, so they still route
-- through the plain `addLifted`).  Reset per program alongside `liftedFnsRef`.
liftedNamesRef : Ref (List String)
liftedNamesRef = Ref []

funcRefsRef : Ref (List String)
funcRefsRef = Ref []

-- ── W6 string state ──────────────────────────────────────────────────────────
-- `useStrRef` records whether the program uses any String/Char literal, the
-- byte-level IO externs (putStr/putStrLn/…), or a String-returning extern
-- (intToString/charToStr/stringConcat/…) — any of which forces the §3.3 `$str`
-- aggregate + the byte-write runtime into the module (and ref-mode, since a String
-- is a boxed (ref eq) value).  `strSegsRef` accumulates the passive data segments
-- for string literals (one `(data $strseg_N "…")` per distinct literal, init'd via
-- `array.new_data`, the §11-preferred non-const-array scheme).  Both reset per
-- program in `emitProgram`.
useStrRef : Ref Bool
useStrRef = Ref False

-- each entry: (segment index, the byte list of that literal).  Drained at module end.
strSegsRef : Ref (List (Int, List Int))
strSegsRef = Ref []

strSegIdRef : Ref Int
strSegIdRef = Ref 0

curBindRef : Ref String
curBindRef = Ref "?"

-- ── gap census (mirrors llvm_emit's gapRecordEnabled/gapLog/curGapBind) ───────
-- The WasmGC emitter normally `panic`s at the first node it can't lower (`gap`).
-- In CENSUS mode the gap helpers instead RECORD the reason and return a
-- type-appropriate placeholder so emission CONTINUES, surfacing EVERY gap over the
-- whole compiler graph in one run (the LLVM-self-hosting playbook).  Default
-- (record OFF) is behaviourally identical to today — every gap still `panic`s the
-- same message, so the existing gates stay green.
gapRecordEnabledW : Ref Bool
gapRecordEnabledW = Ref False

gapLogW : Ref (List String)
gapLogW = Ref []

curGapBindW : Ref String
curGapBindW = Ref "?"

export enableGapRecordW : Unit -> <Mut> Unit
enableGapRecordW _ = setRef gapRecordEnabledW True

export resetGapsW : Unit -> <Mut> Unit
resetGapsW _ =
  let _ = setRef gapLogW []
  setRef curGapBindW "?"

-- the recorded gap events, in first-recorded order ("<binding>\t<reason>").
export gapEventsW : Unit -> <Mut> List String
gapEventsW _ = reverseL gapLogW.value

export setGapBindW : String -> <Mut> Unit
setGapBindW name = setRef curGapBindW name

noteGapW : String -> <Mut> Unit
noteGapW reason =
  setRef gapLogW ("\{curGapBindW.value}\t\{reason}"::gapLogW.value)

-- typed gap-tolerant variants, one per return shape the `gap` call sites need.
-- Each records (census mode) or panics (default), returning a placeholder.
gapL : String -> <Mut> List String
gapL reason =
  if gapRecordEnabledW.value then
    let _ = noteGapW reason in []
  else
    gap reason

gapLTy : String -> <Mut> (List String, WTy)
gapLTy reason =
  if gapRecordEnabledW.value then
    let _ = noteGapW reason in ([], WInt)
  else
    gap reason

gapS : String -> <Mut> String
gapS reason =
  if gapRecordEnabledW.value then
    let _ = noteGapW reason in "0"
  else
    gap reason

gapSInt : String -> <Mut> (String, Int)
gapSInt reason =
  if gapRecordEnabledW.value then
    let _ = noteGapW reason in ("0", 0)
  else
    gap reason

gapOptE : String -> <Mut> Option CExpr
gapOptE reason =
  if gapRecordEnabledW.value then
    let _ = noteGapW reason in None
  else
    gap reason

gapL2 : String -> <Mut> (List String, List String)
gapL2 reason =
  if gapRecordEnabledW.value then
    let _ = noteGapW reason in ([], [])
  else
    gap reason

gapL3 : String -> <Mut> (List String, List String, List String)
gapL3 reason =
  if gapRecordEnabledW.value then
    let _ = noteGapW reason in ([], [], [])
  else
    gap reason

-- ── W7 collection state ──────────────────────────────────────────────────────
-- Which collection reps the program actually uses (gates their type-section decls,
-- peer to `useStrRef`).  `useListRef`: any CList/CRangeList or a HCons/HNil match
-- head → the cons-cell `$C_Cons` + root `$T_List` (Nil is an i31).  `useArrayRef`:
-- any CArray/CRangeArray/CIndex/CSlice → the `$arr` (array (mut (ref eq))) type.
-- `useRefBoxRef`: any Ref/setRef/.value → the `$refbox` 1-field mutable struct.
-- `tupleAritiesRef`: the distinct tuple arities present (CTuple / HTuple) → one
-- per-arity struct `$C_TupN`.  Records reuse the EXISTING per-ctor struct ($C_<ctor>,
-- already declared by the W3 ctor type section since a named-field ctor is in the
-- ctor table) — they need no new type, only the field-order table below.
useListRef : Ref Bool
useListRef = Ref False

useArrayRef : Ref Bool
useArrayRef = Ref False

useRefBoxRef : Ref Bool
useRefBoxRef = Ref False

-- ── W8 extern-use state ──────────────────────────────────────────────────────
-- Which W8 LEAF/RNG runtime groups the program reaches (gates their preamble
-- emission, peer to useStrRef).  useStrLeafRef: any pure-WAT string leaf op
-- (++/charToStr/stringConcat/stringSlice/toUpper/toLower) → the strLeafRuntime.
-- useRngRef: any RNG extern → the SplitMix64 state global + runtime.  useHashRef:
-- any per-type hasher → the hash runtime.  useEPutRef: ePutStr/ePutStrLn → the
-- stderr import + runtime.
useStrLeafRef : Ref Bool
useStrLeafRef = Ref False

useRngRef : Ref Bool
useRngRef = Ref False

useHashRef : Ref Bool
useHashRef = Ref False

useEPutRef : Ref Bool
useEPutRef = Ref False

-- B5 (RUNTIME-TRAP-UNIFY §3 (5)): a coded runtime-trap helper streamed bytes to
-- stderr via the mdk_write_err_byte host import → force that import.  SET DURING
-- EMIT by wasmTrapInstrs (not the pre-scan): a trap can appear at a decision-tree
-- CTFail / clause-chain fallthrough whose reachability the pre-scan can't cheaply
-- decide, so emit{Ref,Scalar}Program reads this AFTER the body-emit bindings (Medaka
-- `let` is strict, so the import binding, computed after `fns`/`initLines`, sees it).
useTrapImport : Ref Bool
useTrapImport = Ref False

-- B5: the program contains a concrete-Int `/`/`%` → declare the i64 divisor-guard
-- scratch local ($__divr<depth> in ref mode, $__sdivr in scalar mode).  Set by the
-- pre-scan (noteW8Binop) so the local decl is present before the div-site emit.
useDivGuardRef : Ref Bool
useDivGuardRef = Ref False

-- W8b: the program uses Float (a Float literal, a Float extern, or a Float arith op).
-- Forces ref-mode (a Float is a boxed (ref eq) $float struct) + gates the Float runtime
-- (floatRuntimeLines + the floatToString host import).  useFloatHashRef / useFloatRngRef
-- gate the hashFloat / randomFloat runtimes (which need the shared mix64 / next_u64).
useFloatRef : Ref Bool
useFloatRef = Ref False

useFloatHashRef : Ref Bool
useFloatHashRef = Ref False

useFloatRngRef : Ref Bool
useFloatRngRef = Ref False

-- layer-6: stringToFloat is a host-seam extern (like floatToString).  It takes a $str,
-- pushes its bytes via the IO path channel (mdk_path_reset/mdk_path_push), and calls
-- the new mdk_str_to_float host import to parse the f64 JS-side.  Forces floatRef
-- (result is a boxed $float), strRef (input is a $str), and ioRef (uses path channel).
useFloatStrRef : Ref Bool
useFloatStrRef = Ref False

-- W8b: the program uses stringIndexOf / stringCompare (the strSearchRuntime).
useStrSearchRef : Ref Bool
useStrSearchRef = Ref False

-- layer-9: the program does a ref-mode `==`/`!=`/ordering binop in a string-using
-- program → route through the runtime-shape-dispatched $mdk_value_eq / $mdk_value_cmp
-- (Core IR is type-erased, so a String `==` cannot be told from an Int `==` statically;
-- the old i31-only lowering trapped `illegal cast` on a String operand).  When set we
-- also force useStrSearchRef so $mdk_str_compare (the byte comparator) is in scope.
useValueCmpRef : Ref Bool
useValueCmpRef = Ref False

-- A0/A1 (poly-`Num`-on-Float): the program routes an arithmetic binop through the
-- runtime value-tag-dispatched $mdk_value_add/sub/mul/div/mod helpers (a polymorphic
-- `Num a` operand — see numPolyLocalsRef).  Gates valueArithRuntimeLines.
useValueArithRef : Ref Bool
useValueArithRef = Ref False

-- A1 (poly-`Num`-on-Float): the pattern-var names bound at the CURRENT function's
-- POLYMORPHIC `Num`/`Ord` param positions — a param whose declared type head is a type
-- VARIABLE (lowercase-initial) used arithmetically, OR (no declared sig) any param used
-- arithmetically.  The wasm peer of native's `isNumPolyParam`/LTNum seed.  A binop with
-- such an operand routes to the runtime value-dispatch helper instead of the trapping
-- inline int primitive; the static Int/Float fast paths (declared `Int`/`Float`, literals,
-- structural Float) are unchanged.  Seeded (and reset to []) per fn in emitRefFnBind.
numPolyLocalsRef : Ref (List String)
numPolyLocalsRef = Ref []

-- W11b: the program uses stringToChars / stringFromChars (the UTF-8 codec runtime
-- $mdk_str_to_chars / $mdk_chars_to_str, which decode/encode between a $str and an
-- $arr of i31 Char codepoints).  Needs $str + $arr + the strLeaf char encoder.
useStrCodecRef : Ref Bool
useStrCodecRef = Ref False

-- W11b: the program uses charFromCode (the $mdk_char_from_code range-check runtime).
useCharFromCodeRef : Ref Bool
useCharFromCodeRef = Ref False

-- W11b: the program uses charIsAlpha/charIsSpace/… or charToUpper/charToLower.
useCharClassRef : Ref Bool
useCharClassRef = Ref False

-- W12: the program uses any IO host-surface extern (readFile / fileExists / args /
-- getEnv / exit).  Gates the IO host imports + the byte-channel marshaling runtime.
-- All of these touch a $str (path/result), so they also force useStrRef.
useIORef : Ref Bool
useIORef = Ref False

-- W12: the program uses `args` specifically — gates ioArgsRuntimeLines, which builds a
-- Cons list ($C_Cons) and so needs the list types (useListRef is co-forced).
useArgsRef : Ref Bool
useArgsRef = Ref False

-- stage-D: the program uses readFileBytes / writeFileBytes (byte-clean file I/O).
-- Gates the write host imports (fileBytesHostImportLines) + the two runtime bodies
-- (fileBytesRuntimeLines).  Co-forces useIORef ($mdk_push_path / $mdk_io_result_to_str),
-- useArrayRef ($arr rep), and useStrRef (the Err $str + the path $str).
useFileBytesRef : Ref Bool
useFileBytesRef = Ref False

-- W8b: the names KNOWN to hold a Float in the CURRENT function/impl body — set while
-- emitting an `impl Num Float` (etc.) method, whose params are Float but appear as bare
-- CVars the structural detector can't otherwise see.  `cexprIsFloat` consults this so
-- `add a b = a + b` lowers to f64 ops.  Reset to [] before every non-Float-impl body.
floatLocalsRef : Ref (List String)
floatLocalsRef = Ref []

-- W-SQLITE-4 stage 2: ctor name → field INDICES declared as Float (from
-- ctorFieldTypeNames; installed by installCtorFloatFields from each wasm entry).
-- Drives cexprIsFloat's CFieldAccess arm and ctor-payload Float binder seeding.
-- Empty at startup (programs with no data decls stay unaffected).
ctorFloatFieldsRef : Ref (List (String, List Int))
ctorFloatFieldsRef = Ref []

export installCtorFloatFields : List (String, List String) -> <Mut> Unit
installCtorFloatFields entries =
  setRef ctorFloatFieldsRef (map ctorToFloatIdxs entries)

-- convert one ctorFieldTypeNames entry to (ctorName, [floatFieldIndex, …]).
ctorToFloatIdxs : (String, List String) -> (String, List Int)
ctorToFloatIdxs (ctor, typeNames) = (ctor, floatFieldIndices typeNames 0)

-- collect the 0-based indices of "Float" fields from a type-head list.
floatFieldIndices : List String -> Int -> List Int
floatFieldIndices [] _ = []
floatFieldIndices ("Float"::rest) i = i :: floatFieldIndices rest (i + 1)
floatFieldIndices (_::rest) i = floatFieldIndices rest (i + 1)

-- true iff the ctor's field at the given 0-based index has declared type Float.
isFloatCtorField : String -> Int -> Bool
isFloatCtorField ctor idx = match lookupAssoc ctor ctorFloatFieldsRef.value
  Some idxs => containsInt idx idxs
  None => False

-- the distinct tuple arities used anywhere in the program (construction or match).
tupleAritiesRef : Ref (List Int)
tupleAritiesRef = Ref []

noteTupleArity : Int -> <Mut> Unit
noteTupleArity n =
  if containsInt n tupleAritiesRef.value then
    ()
  else
    setRef tupleAritiesRef (n::tupleAritiesRef.value)

containsInt : Int -> List Int -> Bool
containsInt _ [] = False
containsInt x (y::ys) = x == y || containsInt x ys

-- ctor name → field labels in DECLARED order, for every named-field record/variant
-- the program constructs (scanned from CRecord nodes, peer to llvm_emit.collectRecords).
-- Drives CFieldAccess's struct index + CRecordUpdate/CVariantUpdate's unchanged-field
-- copy.  Set once per program in emitProgram.
recFieldsRef : Ref (List (String, List String))
recFieldsRef = Ref []

-- intern a literal's bytes as a fresh passive data segment; returns its index.
freshStrSeg : List Int -> <Mut> Int
freshStrSeg bytes =
  let i = strSegIdRef.value
  let _ = setRef strSegIdRef (i + 1)
  let _ = setRef strSegsRef ((i, bytes)::strSegsRef.value)
  i

freshLamId : Unit -> <Mut> Int
freshLamId _ =
  let n = lamIdRef.value
  let _ = setRef lamIdRef (n + 1)
  n

addLifted : List String -> <Mut> Unit
addLifted def = setRef liftedFnsRef (def::liftedFnsRef.value)

-- addLifted, but keyed by a unique define name (see `liftedNamesRef`): a second call
-- with an already-seen name is a no-op, so a point-free ctor/extern used at N sites
-- lifts its (func …) exactly once.
addLiftedNamed : String -> List String -> <Mut> Unit
addLiftedNamed name def =
  if contains name liftedNamesRef.value then ()
  else
    let _ = setRef liftedNamesRef (name::liftedNamesRef.value)
    addLifted def

noteFuncRef : String -> <Mut> Unit
noteFuncRef nm =
  if contains nm funcRefsRef.value then
    ()
  else
    setRef funcRefsRef (nm::funcRefsRef.value)

export emitProgram : CProgram -> <Mut> String
emitProgram (CProgram groups ctorArs ctorTypes impls) =
  let _ = setRef lamIdRef 0
  let _ = setRef liftedFnsRef []
  let _ = setRef liftedNamesRef []
  let _ = setRef emittedDefaultsWRef []
  let _ = setRef defaultDefsWRef []
  let _ = setRef funcRefsRef []
  let _ = setRef useStrRef (programUsesStr groups)
  let _ = setRef strSegsRef []
  let _ = setRef strSegIdRef 0
  -- W7: scan the program for collection usage (gates type-section decls + forces
  -- ref-mode — every collection is a boxed (ref eq) value).
  let _ = setRef useListRef False
  let _ = setRef useArrayRef False
  let _ = setRef useRefBoxRef False
  let _ = setRef useStrLeafRef False
  let _ = setRef useRngRef False
  let _ = setRef useHashRef False
  let _ = setRef useEPutRef False
  let _ = setRef useTrapImport False
  let _ = setRef useDivGuardRef False
  let _ = setRef useFloatRef False
  let _ = setRef useFloatHashRef False
  let _ = setRef useFloatRngRef False
  let _ = setRef useFloatStrRef False
  let _ = setRef useStrSearchRef False
  let _ = setRef useValueCmpRef False
  let _ = setRef useValueArithRef False
  let _ = setRef numPolyLocalsRef []
  let _ = setRef useStrCodecRef False
  let _ = setRef useCharFromCodeRef False
  let _ = setRef useCharClassRef False
  let _ = setRef useIORef False
  let _ = setRef useArgsRef False
  let _ = setRef useFileBytesRef False
  let _ = setRef tupleAritiesRef []
  let _ = setRef recFieldsRef (collectRecFields groups)
  let _ = scanProgW7 groups
  let _ = scanImplsW7 impls
  -- W8b: any Float program needs the $str rep — a Float value-main auto-prints through
  -- floatToString (a $str), and $mdk_float_to_str builds a $str.  Force useStrRef so the
  -- $str type + the $str print runtime emit.
  let _ = if useFloatRef.value then setRef useStrRef True else ()
  let fnNames = collectFnNames groups
  let valNames = collectValNames groups
  let fnArs = collectFnArities groups
  let _ = setRef fnsUsedAsValuesRef (scanFnValueUses fnNames fnArs ctorArs groups ++ scanImplValueUses fnNames fnArs ctorArs impls)
  let useClos = programUsesClosures groups ctorArs
  -- closures force the uniform (ref eq) rep (a closure captures heterogeneous
  -- values); so does ANY dispatch — an impl method / method occurrence threads
  -- (ref eq) impl args + i31 dict witnesses, the W5 §8.6 uniform rep.  Strings
  -- (W6) also force ref-mode: a String is a boxed (ref eq) $str struct.  W8 RNG /
  -- hash externs produce/consume (ref eq) i31 values, so they force ref-mode too.
  let useRef = useClos || programUsesAdt groups ctorArs || isNonEmptyList impls || useStrRef.value
    || useListRef.value || useArrayRef.value || useRefBoxRef.value || isNonEmptyList tupleAritiesRef.value
    || useRngRef.value || useHashRef.value || useFloatRef.value || useStrSearchRef.value
    || useCharClassRef.value || useIORef.value
  let typeNames = distinctTypeNames ctorTypes
  let prog = Prog ctorArs ctorTypes typeNames useRef fnNames valNames fnArs useClos impls
  if useRef then emitRefProgram prog groups
  else emitScalarProgram fnNames valNames groups

-- ── gap census driver ────────────────────────────────────────────────────────
-- The WasmGC peer of llvm_emit's emitProgramGaps: emit EVERY binding (fns +
-- impls + top-level values) in record mode and return the recorded gap events,
-- WITHOUT requiring a `main`.  Mirrors emitProgram's Prog/state setup (the same
-- W7 scans + Prog build), but forces the ref path (the whole compiler graph is
-- ADT/string/closure-heavy, so ref-mode is the representative path) and never
-- calls the main-requiring emitRefMain.  Each binding is wrapped with setGapBindW
-- so a recorded gap is attributed to its source binding.
export emitProgramGaps : CProgram -> <Mut> List String
emitProgramGaps (CProgram groups ctorArs ctorTypes impls) =
  let _ = setRef lamIdRef 0
  let _ = setRef liftedFnsRef []
  let _ = setRef liftedNamesRef []
  let _ = setRef emittedDefaultsWRef []
  let _ = setRef defaultDefsWRef []
  let _ = setRef funcRefsRef []
  let _ = setRef useStrRef (programUsesStr groups)
  let _ = setRef strSegsRef []
  let _ = setRef strSegIdRef 0
  let _ = setRef useListRef False
  let _ = setRef useArrayRef False
  let _ = setRef useRefBoxRef False
  let _ = setRef useStrLeafRef False
  let _ = setRef useRngRef False
  let _ = setRef useHashRef False
  let _ = setRef useEPutRef False
  let _ = setRef useTrapImport False
  let _ = setRef useDivGuardRef False
  let _ = setRef useFloatRef False
  let _ = setRef useFloatHashRef False
  let _ = setRef useFloatRngRef False
  let _ = setRef useFloatStrRef False
  let _ = setRef useStrSearchRef False
  let _ = setRef useValueCmpRef False
  let _ = setRef useValueArithRef False
  let _ = setRef numPolyLocalsRef []
  let _ = setRef useStrCodecRef False
  let _ = setRef useCharFromCodeRef False
  let _ = setRef useCharClassRef False
  let _ = setRef useIORef False
  let _ = setRef useArgsRef False
  let _ = setRef useFileBytesRef False
  let _ = setRef tupleAritiesRef []
  let _ = setRef recFieldsRef (collectRecFields groups)
  let _ = scanProgW7 groups
  let _ = scanImplsW7 impls
  let _ = if useFloatRef.value then setRef useStrRef True else ()
  let fnNames = collectFnNames groups
  let valNames = collectValNames groups
  let fnArs = collectFnArities groups
  let _ = setRef fnsUsedAsValuesRef (scanFnValueUses fnNames fnArs ctorArs groups ++ scanImplValueUses fnNames fnArs ctorArs impls)
  let useClos = programUsesClosures groups ctorArs
  -- force the ref path: the census measures the full (ref eq) emitter surface.
  let typeNames = distinctTypeNames ctorTypes
  let prog = Prog ctorArs ctorTypes typeNames True fnNames valNames fnArs useClos impls
  let _ = resetGapsW ()
  let _ = enableGapRecordW ()
  let _ = emitFnsGapsW prog (userFnBinds groups)
  let _ = emitImplsGapsW prog (implGroups impls)
  let _ = emitValsGapsW prog (filterList isValBind groups)
  gapEventsW ()

emitFnsGapsW : Prog -> List CBind -> <Mut> Unit
emitFnsGapsW _ [] = ()
emitFnsGapsW prog ((CBind name cs)::rest) =
  let _ = setGapBindW ("fn " ++ name)
  let _ = emitRefFnBind prog (CBind name cs)
  emitFnsGapsW prog rest

emitImplsGapsW : Prog -> List ImplG -> <Mut> Unit
emitImplsGapsW _ [] = ()
emitImplsGapsW prog ((ImplG method tag arity clauses)::rest) =
  let _ = setGapBindW "impl \{method}@\{tag}"
  let _ = emitImplGroup prog (ImplG method tag arity clauses)
  emitImplsGapsW prog rest

emitValsGapsW : Prog -> List CBind -> <Mut> Unit
emitValsGapsW _ [] = ()
emitValsGapsW prog (b::rest) =
  let _ = setGapBindW ("val " ++ bindName b)
  let _ = emitRefValInit prog b
  emitValsGapsW prog rest

isEmptyList : List a -> Bool
isEmptyList [] = True
isEmptyList _ = False

isNonEmptyList : List a -> Bool
isNonEmptyList xs = not (isEmptyList xs)

-- a top-level fn's arity = its (first clause's) param count.  Multi-clause fns share
-- one arity (all clauses agree); use the first clause.
collectFnArities : List CBind -> List (String, Int)
collectFnArities groups = map bindArity (userFnBinds groups)

bindArity : CBind -> (String, Int)
bindArity (CBind n ((CClause pats _)::_)) = (n, listLen pats)
bindArity (CBind n []) = (n, 0)

-- a program uses CLOSURES if any body contains a CLam, any application head is a
-- non-ctor / non-top-level-fn variable or a non-variable (an indirect/HOF call),
-- any top-level fn is multi-clause or has a non-PVar param (clause-dispatch
-- coalescing, W4), OR any top-level fn is referenced as a VALUE (passed/returned —
-- needs a closure wrapper).  Detected structurally over the whole program.
programUsesClosures : List CBind -> List (String, Int) -> Bool
programUsesClosures groups ctorArs =
  let fnNames = collectFnNames groups
  let fnArs = collectFnArities groups
  anyBind (bindUsesClosures fnNames fnArs ctorArs) groups

anyBind : (CBind -> Bool) -> List CBind -> Bool
anyBind _ [] = False
anyBind p (b::rest) = if p b then True else anyBind p rest

-- ── W6: does the program use strings? ────────────────────────────────────────
-- True if any body contains a String/Char literal, or applies a String/IO extern
-- (intToString/putStrLn/stringConcat/…).  Any of these forces the §3.3 $str rep +
-- the byte-write runtime + ref-mode.  Detected structurally over every clause body.
isStrExternW : String -> Bool
isStrExternW name = contains name [
  "intToString", "charToStr", "stringConcat", "stringLength",
  "putStr", "putStrLn", "ePutStr", "ePutStrLn", "flushStdout",
  "stringSlice", "stringToUpper", "stringToLower", "hashString",
  -- W8b: floatToString returns a $str; stringIndexOf/stringCompare read $str (and
  -- return Option Int / Ordering, built inline).  All force the $str rep.
  "floatToString", "stringIndexOf", "stringCompare",
  -- W11b: stringToChars/stringFromChars are the UTF-8 codec ($str <-> Array Char);
  -- charFromCode : Int -> Option Char is range-check + i31 rebox.  Routed here so they
  -- reach emitStrExternRef (all touch $str / Char codepoints).
  "stringToChars", "stringFromChars", "charFromCode",
  -- W11b: the UTF-8 byte codec ($str <-> Array Int) — raw backing bytes 0..255.
  "stringToUtf8Bytes", "stringFromUtf8Bytes",
  -- W9: the Debug-quoting externs render a String/Char as a quoted+escaped literal
  -- ("hi" / 'a').  Both produce a fresh $str via the $mdk_dbg_quote runtime (which
  -- reuses $mdk_cp_count + $mdk_char_to_str, both in strLeafRuntimeLines).
  "debugStringLit", "debugCharLit",
  -- layer-6: stringToFloat : String -> Option Float.  Reads the $str, pushes bytes
  -- via the IO path channel, calls mdk_str_to_float (JS Number()) -> f64 -> $float.
  "stringToFloat"]

-- ── W8: RNG + hash LEAF externs (no `$str` dependency on their own) ──────────
-- These force ref-mode (they produce/consume (ref eq) i31 values) but, unlike the
-- string externs, do NOT pull in the `$str` rep (hashString is the exception and is
-- listed under isStrExternW since it reads a $str).  Detected so emitProgram can
-- force `useRef` and gate the RNG / hash preamble.
isLeafExternW : String -> Bool
isLeafExternW name = contains name [
  "randomInt", "randomBool", "randomChar", "setSeed",
  "hashInt", "hashChar", "hashBool",
  -- W11: charCode : Char -> Int — a Char is an i31 codepoint; charCode = cast+unbox+rebox.
  "charCode",
  -- W11b: char classification and case-mapping (ASCII-only, byte-identical to medaka_rt.c).
  "charIsAlpha", "charIsSpace", "charIsUpper", "charIsLower", "charIsPunct",
  "charToUpper", "charToLower",
  -- W8b Float leaf externs (produce/consume a boxed $float (ref eq)).
  "intToFloat", "floatToInt", "hashFloat", "randomFloat",
  -- W12 IO host-surface externs.  readFile/getEnv build a $str-bearing Result/Option,
  -- fileExists a Bool, args a List String, exit a trap — all routed through
  -- emitLeafExternRef into the byte-channel host-import runtime.  ($str is forced by
  -- noteW8Extern, not by listing them under isStrExternW.)
  "readFile", "fileExists", "args", "getEnv", "exit",
  -- canonicalizePath : String -> String — realpath(3) natively; the browser wasm vfs
  -- has no realpath, so it lowers to IDENTITY (matches the extern's "input unchanged on
  -- failure" contract).  Reachable in the wasm playground because the loader's
  -- canonicalModId calls it; a single-file (dep-less) buffer never actually exercises
  -- the cross-package branch, so identity is exact for the playground.
  "canonicalizePath",
  -- stage-D: byte-clean file I/O.  readFileBytes builds a Result String (Array Int)
  -- (an $arr of i31 bytes); writeFileBytes streams an Array Int OUT + fs.writeFileSync.
  -- Both route through emitLeafExternRef into the fileBytesRuntime host seam.
  "readFileBytes", "writeFileBytes",
  -- W10: `panic : String -> a` lowers to a `unreachable` trap (stack-polymorphic,
  -- validates as any result type — matches the native @mdk_panic abort).  The message
  -- arg is emitted-then-dropped; printing it to stderr is a nice-to-have not done here.
  "panic",
  -- stage-A: bitwise / shift externs (Int -> Int -> Int).  Pure i64 ops over the
  -- box/unbox seam; no $str/$arr/$float dependencies.
  "bitAnd", "shiftLeft", "shiftRight"]

-- Net externs (NET-DESIGN.md §6): native-only.  Raw BSD sockets have no WasmGC
-- equivalent, so `medaka build --target wasm` must REJECT a net-importing program
-- with a clear message rather than fall through to emitIndirectApp (which would only
-- report a generic "unbound variable").  This single-set guard is wired into both
-- application dispatch ladders (emitAppRef, emitTailAppRef).
isNetExternW : String -> Bool
-- Intentional cross-file duplicate of the same helper in llvm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
isNetExternW name = contains
  name
  [
    "netResolve",
    "netTcpConnect",
    "netTcpListen",
    "netListenPort",
    "netTcpAccept",
    "netSend",
    "netRecv",
    "netShutdown",
    "netClose",
    "netSetTimeout",
  ]

-- W9: arity of a str/leaf extern (the param count its emit* arm consumes).  Used to
-- build an eta closure when the extern is referenced as a VALUE (point-free / passed
-- as an argument), mirroring the LLVM emitter's emitExternEtaClosure.
externArityW : String -> Int
externArityW name =
  if contains name ["flushStdout", "randomBool"] then 0
  else if contains name ["intToString", "charToStr", "stringLength", "putStr",
    "putStrLn", "ePutStr", "ePutStrLn", "stringToUpper", "stringToLower", "hashString",
    "stringConcat", "setSeed", "randomChar", "hashInt", "hashChar", "hashBool",
    -- W11: charCode : Char -> Int (1-arg leaf); W11b: char classification + case-mapping (1-arg).
    "charCode",
    "charIsAlpha", "charIsSpace", "charIsUpper", "charIsLower", "charIsPunct",
    "charToUpper", "charToLower",
    -- W8b: floatToString/intToFloat/floatToInt/hashFloat are 1-arg; randomFloat takes
    -- a Unit arg (like randomChar — emitted + dropped).
    "floatToString", "intToFloat", "floatToInt", "hashFloat", "randomFloat",
    -- W10: panic msg (1); arrayLength/arrayFromList/arrayCopy (1).
    "panic", "arrayLength", "arrayFromList", "arrayCopy",
    -- stage-B: floatToBytes64 : Float -> Array Int (1-arg).
    "floatToBytes64",
    -- W11b: stringToChars/stringFromChars/charFromCode are each 1-arg.
    "stringToChars", "stringFromChars", "charFromCode",
    -- W11b: the UTF-8 byte codec externs are each 1-arg.
    "stringToUtf8Bytes", "stringFromUtf8Bytes",
    -- W12: readFile/fileExists/getEnv/exit take 1 arg; args takes a Unit arg
    -- (emitted + dropped, like randomFloat).
    "readFile", "fileExists", "getEnv", "exit", "args",
    -- stage-D: readFileBytes : String -> Result String (Array Int) (1-arg).
    "readFileBytes",
    -- layer-6: stringToFloat : String -> Option Float (1-arg).
    "stringToFloat"] then 1
  else if contains name ["randomInt", "stringIndexOf", "stringCompare",
    -- W10: arrayGetUnsafe (idx, arr); arrayMake (size, init); arrayMakeWith (size, f).
    "arrayGetUnsafe", "arrayMake", "arrayMakeWith",
    -- stage-A: 2-arg bitwise (Int->Int->Int) and arrayFill (val->arr->Unit).
    "bitAnd", "shiftLeft", "shiftRight", "arrayFill",
    -- stage-B: bytesToFloat64 : Array Int -> Int -> Float (2-arg).
    "bytesToFloat64",
    -- stage-D: writeFileBytes : String -> Array Int -> Result String Unit (2-arg).
    "writeFileBytes"] then 2
  else if contains name ["stringSlice", "arraySetUnsafe"] then 3
  -- stage-A: arrayBlit src srcOff dst dstOff len (5 args).
  else if name == "arrayBlit" then 5
  else 1

isWasmEtaExtern : String -> Bool
isWasmEtaExtern name = isStrExternW name
  || isLeafExternW name
  || isArrayExternW name

-- ── W10: Array intrinsic externs (RUNTIME-DESIGN array kernel) ────────────────
-- The seven array primitives from stdlib/runtime.mdk that lower to the `$arr =
-- (array (mut (ref eq)))` WasmGC array (array.len/get/set/new/copy + the apply seam
-- for arrayMakeWith's per-index closure call).  Detected so emitProgram forces the
-- $arr rep (via noteW8Extern) and the dispatch routes here.  NOTE the per-extern arg
-- orders (some take the index/size FIRST) — see stdlib/runtime.mdk:92-104.
isArrayExternW : String -> Bool
isArrayExternW name = contains name [
  "arrayLength", "arrayGetUnsafe", "arrayMake", "arrayMakeWith",
  "arrayCopy", "arraySetUnsafe", "arrayFromList",
  -- stage-A: arrayBlit (offset copy) and arrayFill (bulk fill).
  "arrayBlit", "arrayFill",
  -- stage-B: float-reinterpret externs build/read the $arr rep (8-byte big-endian
  -- IEEE-754 (de)serialization).  floatToBytes64 : Float -> Array Int (produces $arr);
  -- bytesToFloat64 : Array Int -> Int -> Float (reads $arr).
  "floatToBytes64", "bytesToFloat64"]

-- ── W8b: the ONE residual deferred extern ────────────────────────────────────
-- All other Float externs (floatToString / intToFloat / floatToInt / hashFloat /
-- randomFloat) are PORTED in W8b (real WAT + the floatToString host seam).  The lone
-- holdout is `stringToFloat` — a faithful port means reimplementing `strtod` (decimal/
-- exponent/hex float parsing + the Option result), which would balloon this slice; per
-- the W8b plan it STOPs-and-defers.  It reaches a real prelude only through Foldable/
-- json's `toFloat`, which W8b fixtures avoid.  Stub to a trap so the program still
-- emits; a program that actually parses a Float traps loudly (diverges from the LLVM
-- oracle, which has strtod).
isDeferredFloatExternW : String -> Bool
isDeferredFloatExternW _ = False

-- W9: a DEFERRED Float extern (boxing + %.12g dtoa is W8b) lowers to a `unreachable`
-- TRAP STUB rather than aborting the whole build.  The real prelude's `impl Debug/
-- Display/Hash/Num Float` reference these, and DCE retains every impl WHOLE, so the
-- refs are unconditionally reachable in EVERY real-prelude program even when no Float
-- is ever displayed.  Stubbing (instead of `gap`) lets the Int/Bool/String/List
-- programs emit and run; a program that ACTUALLY evaluates a Float-extern call traps
-- loudly (and diverges from the LLVM oracle, which has full Float) — so W9 fixtures
-- avoid Float, and the W8b Float port remains the precise remaining-MVP item.
-- `unreachable` is stack-polymorphic, so it validates as any `(result (ref eq))`.
floatExternStub : String -> List String
floatExternStub _ = ["unreachable"]

-- W9: the QUOTING debug externs `debugStringLit`/`debugCharLit` (used by `impl Debug
-- String`/`impl Debug Char` to render `"hi"`/`'a'` with quotes+escapes).  These now
-- have a real WasmGC runtime ($mdk_dbg_quote / $mdk_debug_string_lit / _char_lit in
-- strLeafRuntimeLines) and are routed through isStrExternW → emitStrExternRef, so the
-- unimplemented set is now empty.  (Kept as a hook for any future trap-stubbed str
-- extern; `floatExternStub` remains the trap path.)
isUnimplStrExternW : String -> Bool
isUnimplStrExternW _ = False

programUsesStr : List CBind -> Bool
programUsesStr groups = anyBind bindUsesStr groups

bindUsesStr : CBind -> Bool
bindUsesStr (CBind _ clauses) =
  anyList (c => exprUsesStr (clauseBodyOf c)) clauses

exprUsesStr : CExpr -> Bool
exprUsesStr (CLit (LString _)) = True
exprUsesStr (CLit (LChar _)) = True
exprUsesStr (CLit _) = False
exprUsesStr (CVar x _) = isStrExternW x
exprUsesStr (CApp f a) =
  let (hd, args) = flattenApp (CApp f a) []
  headUsesStr hd || anyList exprUsesStr args
exprUsesStr (CLam _ b) = exprUsesStr b
exprUsesStr (CBinPrim _ l r _) = exprUsesStr l || exprUsesStr r
exprUsesStr (CUnOp _ x) = exprUsesStr x
exprUsesStr (CIf c t f) = exprUsesStr c || exprUsesStr t || exprUsesStr f
exprUsesStr (CLet _ _ a b) = exprUsesStr a || exprUsesStr b
exprUsesStr (CBlock stmts) = anyList stmtUsesStr stmts
exprUsesStr (CDecision scrut arms _) = exprUsesStr scrut
  || anyList (a => exprUsesStr (armBody a)) arms
exprUsesStr (CMatch scrut arms) = exprUsesStr scrut
  || anyList (a => exprUsesStr (armBody a)) arms
exprUsesStr _ = False

stmtUsesStr : CStmt -> Bool
stmtUsesStr (CSExpr e) = exprUsesStr e
stmtUsesStr (CSLet _ _ e) = exprUsesStr e
stmtUsesStr _ = False

headUsesStr : CExpr -> Bool
headUsesStr (CVar fn _) = isStrExternW fn
headUsesStr h = exprUsesStr h

-- ── W7: scan the program for collection usage (sets the type-section gating refs) ──
-- Sets useListRef/useArrayRef/useRefBoxRef and records every tuple arity seen, from
-- BOTH constructions (CList/CTuple/CArray/CRangeArray/CIndex/CSlice/CRangeList, Ref/
-- setRef) AND match heads (HCons/HNil → list, HTuple n → tuple).  Mirrors how
-- programUsesStr scans, but mutates the refs as it walks (peer to noteTupleArity).
scanProgW7 : List CBind -> <Mut> Unit
scanProgW7 groups = forEachU (b => scanBindW7 b) groups

-- W9: scan impl method bodies + interface defaults for collection/extern use too
-- (e.g. `eq (x::xs) (y::ys)` forces lists; `display n = intToString n` forces $str).
scanImplsW7 : List CImplEntry -> <Mut> Unit
scanImplsW7 impls = forEachU scanImplEntryW7 impls

scanImplEntryW7 : CImplEntry -> <Mut> Unit
scanImplEntryW7 (CImplEntry _ _ body) = match body
  CImplTagged _ _ _ _ pats b => let _ = forEachU scanPatW7 pats in scanExprW7 b
  CImplDefault pats b => let _ = forEachU scanPatW7 pats in scanExprW7 b

forEachU : (a -> <Mut> Unit) -> List a -> <Mut> Unit
forEachU _ [] = ()
forEachU f (x::xs) = let _ = f x in forEachU f xs

scanBindW7 : CBind -> <Mut> Unit
scanBindW7 (CBind _ clauses) = forEachU scanClauseW7 clauses

-- W9: scan BOTH a clause's param patterns (a list/tuple clause head forces the
-- collection type sections even when the body has no collection literal — e.g.
-- core.mdk's debugListItems `(y::rest)` heads) AND its body.
scanClauseW7 : CClause -> <Mut> Unit
scanClauseW7 (CClause pats body) =
  let _ = forEachU scanPatW7 pats
  scanExprW7 body

scanExprW7 : CExpr -> <Mut> Unit
scanExprW7 (CList es) = let _ = setRef useListRef True in forEachU scanExprW7 es
scanExprW7 (CRangeList lo hi _) =
  let _ = setRef useListRef True in let _ = scanExprW7 lo in scanExprW7 hi
scanExprW7 (CTuple es) =
  let _ = noteTupleArity (listLen es) in forEachU scanExprW7 es
scanExprW7 (CArray es) =
  let _ = setRef useArrayRef True in forEachU scanExprW7 es
scanExprW7 (CRangeArray lo hi _) =
  let _ = setRef useArrayRef True in let _ = scanExprW7 lo in scanExprW7 hi
scanExprW7 (CIndex a i) =
  let _ = setRef useArrayRef True in let _ = scanExprW7 a in scanExprW7 i
scanExprW7 (CSlice a lo hi _) = let _ = setRef useArrayRef True in let _ = scanExprW7 a in let _ = scanExprW7 lo in scanExprW7 hi
scanExprW7 (CRecord _ fields) = forEachU (f => scanExprW7 (cFieldExpr f)) fields
scanExprW7 (CFieldAccess ex _ _) = scanExprW7 ex
scanExprW7 (CRecordUpdate base fields) =
  let _ = scanExprW7 base in forEachU (f => scanExprW7 (cFieldExpr f)) fields
scanExprW7 (CVariantUpdate _ base fields) =
  let _ = scanExprW7 base in forEachU (f => scanExprW7 (cFieldExpr f)) fields
scanExprW7 (CApp f a) =
  let (hd, args) = flattenApp (CApp f a) []
  let _ = scanW7Head hd
  forEachU scanExprW7 args
scanExprW7 (CVar x _) =
  if x == "Ref" then
    setRef useRefBoxRef True
  else
    noteW8Extern x
-- W8b: a Float literal forces the Float rep + runtime.  (Bare `pi`/`e` are NOT keyed
-- here — scanExprW7 doesn't track binders, so a LOCAL named `e`/`pi`, e.g. `Err e`,
-- would false-positive; useFloatRef is instead forced by a Float literal, a Float
-- extern, OR a Float-kinded main, post-scan in emitProgram.)
scanExprW7 (CLit (LFloat _)) = setRef useFloatRef True
scanExprW7 (CLam _ b) = scanExprW7 b
scanExprW7 (CBinPrim op l r _) =
  let _ = noteW8Binop op in let _ = scanExprW7 l in scanExprW7 r
scanExprW7 (CUnOp _ x) = scanExprW7 x
scanExprW7 (CIf c t f) =
  let _ = scanExprW7 c in let _ = scanExprW7 t in scanExprW7 f
scanExprW7 (CLet _ pat a b) =
  let _ = scanPatW7 pat in let _ = scanExprW7 a in scanExprW7 b
scanExprW7 (CBlock stmts) = forEachU scanStmtW7 stmts
scanExprW7 (CDecision scrut arms tree) = let _ = scanExprW7 scrut in let _ = forEachU (a => scanArmW7 a) arms in scanTreeW7 tree
scanExprW7 (CMatch scrut arms) =
  let _ = scanExprW7 scrut in forEachU (a => scanArmW7 a) arms
-- W9: descend a CLetGroup so its lifted members' bodies (and their externs /
-- collection use, e.g. arbitraryList's `go` using `randomInt` + `::`) gate the
-- runtime/type sections.
scanExprW7 (CLetGroup binds b) =
  let _ = forEachU (bd => scanBindW7 bd) binds in scanExprW7 b
scanExprW7 _ = ()

scanW7Head : CExpr -> <Mut> Unit
scanW7Head (CVar "Ref" _) = setRef useRefBoxRef True
scanW7Head (CVar "setRef" _) = setRef useRefBoxRef True
scanW7Head (CVar f _) = noteW8Extern f
scanW7Head h = scanExprW7 h

-- ── W8: note which W8 LEAF/RNG/hash runtime groups an extern occurrence reaches ──
-- Sets useStrLeafRef (the pure-WAT string ops needing strLeafRuntime), useRngRef,
-- useHashRef, useEPutRef as appropriate.  Piggybacks on the W7 walk.
noteW8Extern : String -> <Mut> Unit
noteW8Extern name =
  let _ = if contains name ["charToStr", "stringConcat", "stringSlice", "stringToUpper", "stringToLower"]
          then setRef useStrLeafRef True else ()
  let _ = if isLeafExternW name && contains name ["randomInt", "randomBool", "randomChar", "setSeed"]
          then setRef useRngRef True else ()
  -- a Char main from randomChar is auto-printed by encoding the codepoint to a $str
  -- ($mdk_char_to_str → $mdk_print_strln), so randomChar needs the $str rep + the
  -- char-encode strLeaf runtime.
  let _ = if name == "randomChar" then let _ = setRef useStrRef True in setRef useStrLeafRef True else ()
  let _ = if contains name ["hashInt", "hashChar", "hashBool", "hashString"]
          then setRef useHashRef True else ()
  -- W8b: Float externs force the Float runtime (+ ref-mode + $str for floatToString).
  let _ = if contains name ["floatToString", "intToFloat", "floatToInt", "hashFloat", "randomFloat"]
          then setRef useFloatRef True else ()
  -- floatToString needs the $str rep to build its result string.
  let _ = if name == "floatToString" then setRef useStrRef True else ()
  -- layer-6: stringToFloat : String -> Option Float.  Pushes bytes via the IO path
  -- channel then calls mdk_str_to_float (JS Number()).  Forces floatStr, float, str,
  -- and IO (for mdk_path_reset/mdk_path_push).  The $C_Some ctor is in ref-type-section
  -- which is always present when useStrRef/useFloatRef forces ref-mode.
  let _ = if name == "stringToFloat"
          then let _ = setRef useFloatStrRef True in let _ = setRef useFloatRef True in let _ = setRef useStrRef True in setRef useIORef True
          else ()
  -- hashFloat needs the shared mix64 (hashRuntime); randomFloat needs next_u64 (rngRuntime).
  let _ = if name == "hashFloat" then let _ = setRef useFloatHashRef True in setRef useHashRef True else ()
  let _ = if name == "randomFloat" then let _ = setRef useFloatRngRef True in setRef useRngRef True else ()
  -- W8b: stringIndexOf/stringCompare use the strSearch runtime + cp_count (strLeaf) + $str.
  let _ = if contains name ["stringIndexOf", "stringCompare"]
          then let _ = setRef useStrSearchRef True in let _ = setRef useStrRef True in setRef useStrLeafRef True else ()
  -- W11b: stringToChars/stringFromChars are the UTF-8 codec between a $str and an $arr
  -- of i31 Char codepoints.  Force the $str rep, the $arr rep, the strLeaf char encoder
  -- ($mdk_char_to_str, reused by stringFromChars), and the codec runtime itself.
  let _ = if contains name ["stringToChars", "stringFromChars"]
          then let _ = setRef useStrCodecRef True in let _ = setRef useStrRef True in let _ = setRef useArrayRef True in setRef useStrLeafRef True else ()
  -- W11b: the UTF-8 byte codec ($str <-> Array Int).  Force the codec runtime (carries
  -- $mdk_str_to_utf8_bytes / $mdk_utf8_bytes_to_str), the $str rep, and the $arr rep.
  let _ = if contains name ["stringToUtf8Bytes", "stringFromUtf8Bytes"]
          then let _ = setRef useStrCodecRef True in let _ = setRef useStrRef True in setRef useArrayRef True else ()
  -- W9: debugStringLit/debugCharLit quote+escape into a fresh $str via $mdk_dbg_quote,
  -- which reuses $mdk_cp_count + $mdk_char_to_str (both in strLeafRuntimeLines).  Force
  -- the $str rep + the strLeaf runtime.  (No $arr needed.)
  let _ = if contains name ["debugStringLit", "debugCharLit"]
          then let _ = setRef useStrRef True in setRef useStrLeafRef True else ()
  -- W11b: charFromCode : Int -> Option Char — range-check runtime, no $str/$arr needed.
  let _ = if name == "charFromCode" then setRef useCharFromCodeRef True else ()
  -- W11b: char classification + case-mapping externs — pure WAT helpers, no $str/$arr.
  let _ = if contains name ["charIsAlpha", "charIsSpace", "charIsUpper", "charIsLower",
                             "charIsPunct", "charToUpper", "charToLower"]
          then setRef useCharClassRef True else ()
  -- W10: panic's message arg is a $str → force the $str rep.  B5: the coded-trap
  -- lowering streams that message through $mdk_eprint_str (gated on useEPutRef) after a
  -- fixed "runtime error [E-PANIC]: " prefix, so force useEPutRef too.
  let _ = if name == "panic" then let _ = setRef useStrRef True in setRef useEPutRef True else ()
  -- W10: the array intrinsic externs all build/read the $arr rep (and arrayFromList
  -- consumes a cons list).  Force useArrayRef; arrayFromList also forces useListRef.
  let _ = if contains name ["arrayLength", "arrayGetUnsafe", "arrayMake", "arrayMakeWith",
            "arrayCopy", "arraySetUnsafe", "arrayFromList",
            -- stage-A: arrayBlit/arrayFill also operate on $arr.
            "arrayBlit", "arrayFill",
            -- stage-B: float-reinterpret externs build/read $arr.
            "floatToBytes64", "bytesToFloat64"] then setRef useArrayRef True else ()
  -- stage-B: float-reinterpret externs consume/produce a boxed $float — force the
  -- Float rep + runtime ($float is unconditionally declared, but useFloatRef gates the
  -- float runtime helpers a printed/used Float result may reach).
  let _ = if contains name ["floatToBytes64", "bytesToFloat64"] then setRef useFloatRef True else ()
  let _ = if name == "arrayFromList" then setRef useListRef True else ()
  -- W12: the IO host-surface externs.  readFile/fileExists/getEnv/args all build a $str
  -- (path/result), so force the $str rep; args additionally builds a Cons list (force
  -- useListRef).  `exit` needs no $str (it lowers to mdk_exit + unreachable) but still
  -- forces ref-mode via the useRef predicate (useIORef).
  let _ = if contains name ["readFile", "fileExists", "getEnv", "args"]
          then setRef useStrRef True else ()
  let _ = if name == "args" then setRef useListRef True else ()
  let _ = if name == "args" then setRef useArgsRef True else ()
  let _ = if contains name ["readFile", "fileExists", "args", "getEnv", "exit"]
          then setRef useIORef True else ()
  -- stage-D: byte-clean file I/O.  Force the IO host channel ($mdk_push_path etc via
  -- useIORef), the $arr rep (useArrayRef), the $str rep (path/Err message), and the
  -- fileBytes runtime + write host imports (useFileBytesRef).
  let _ = if contains name ["readFileBytes", "writeFileBytes"]
          then let _ = setRef useIORef True in let _ = setRef useArrayRef True in let _ = setRef useStrRef True in setRef useFileBytesRef True
          else ()
  if contains name ["ePutStr", "ePutStrLn"] then setRef useEPutRef True else ()
-- `++` is runtime-dispatched ($mdk_append): needs the $str leaf concat ($mdk_str_append)
-- AND the W7 cons list types ($C_Cons/$T_List) for the list-append branch.
noteW8Binop : String -> <Mut> Unit
noteW8Binop "++" =
  let _ = setRef useStrLeafRef True
  let _ = setRef useStrRef True
  setRef useListRef True
noteW8Binop "::" = setRef useListRef True
-- B5: a concrete-Int `/`/`%` needs the divisor-guard scratch local (declared per fn
-- via w7LocalsAtDepth / the scalar fn+init decls).  Float `/` never traps on zero.
noteW8Binop "/" = setRef useDivGuardRef True
noteW8Binop "%" = setRef useDivGuardRef True
noteW8Binop _ = ()

scanArmW7 : CArm -> <Mut> Unit
scanArmW7 (CArm pat guards body) =
  let _ = scanPatW7 pat
  let _ = forEachU scanGuardW7 guards
  scanExprW7 body

scanGuardW7 : CGuard -> <Mut> Unit
scanGuardW7 (CGBool g) = scanExprW7 g
scanGuardW7 (CGBind p e) = let _ = scanPatW7 p in scanExprW7 e

scanStmtW7 : CStmt -> <Mut> Unit
scanStmtW7 (CSExpr e) = scanExprW7 e
scanStmtW7 (CSLet _ pat e) = let _ = scanPatW7 pat in scanExprW7 e
scanStmtW7 (CSLetElse pat e els) =
  let _ = scanPatW7 pat in let _ = scanExprW7 e in scanExprW7 els
scanStmtW7 (CSAssign _ e) = scanExprW7 e

-- a pattern's collection heads: a cons/nil/list pattern → list; a tuple pattern → its arity.
scanPatW7 : Pat -> <Mut> Unit
scanPatW7 (PCons h t) =
  let _ = setRef useListRef True in let _ = scanPatW7 h in scanPatW7 t
scanPatW7 (PList ps) = let _ = setRef useListRef True in forEachU scanPatW7 ps
scanPatW7 (PTuple ps) =
  let _ = noteTupleArity (listLen ps) in forEachU scanPatW7 ps
scanPatW7 (PCon _ args) = forEachU scanPatW7 args
scanPatW7 (PAs _ p) = scanPatW7 p
scanPatW7 _ = ()

-- a decision tree's match heads (the lowered shape of list/tuple patterns).
scanTreeW7 : CTree -> <Mut> Unit
scanTreeW7 CTFail = ()
scanTreeW7 (CTLeaf _) = ()
scanTreeW7 (CTGuard _ fail) = scanTreeW7 fail
scanTreeW7 (CTDrop sub) = scanTreeW7 sub
scanTreeW7 (CTSwitch branches dft) =
  let _ = forEachU scanBranchW7 branches in scanTreeW7 dft

scanBranchW7 : CTBranch -> <Mut> Unit
scanBranchW7 (CTBranch h sub) = let _ = scanHeadW7 h in scanTreeW7 sub

scanHeadW7 : CHead -> <Mut> Unit
scanHeadW7 HCons = setRef useListRef True
scanHeadW7 HNil = setRef useListRef True
scanHeadW7 (HTuple n) = noteTupleArity n
scanHeadW7 _ = ()

cFieldExpr : CField -> CExpr
cFieldExpr (CField _ e) = e

cFieldName : CField -> String
cFieldName (CField k _) = k

-- ── W7: record field-order table (ctor → declared field labels) ──────────────
-- A named-field record/variant ctor IS a user ctor (in the W3 ctor table); we only
-- need its field ORDER to compute a CFieldAccess struct index + a record-update's
-- unchanged-field copy.  Recover it from CRecord nodes (which carry fields in
-- declared order — lowering preserves it), peer to llvm_emit.collectRecords.
collectRecFields : List CBind -> List (String, List String)
collectRecFields groups = dedupRecEntries (flatMap collectRecFieldsBind groups)

collectRecFieldsBind : CBind -> List (String, List String)
collectRecFieldsBind (CBind _ clauses) =
  flatMap (c => scanRecFields (clauseBodyOf c)) clauses

scanRecFields : CExpr -> List (String, List String)
scanRecFields (CRecord name fields) =
  (name, map cFieldName fields) ::
    flatMap (f => scanRecFields (cFieldExpr f)) fields
scanRecFields (CFieldAccess ex _ _) = scanRecFields ex
scanRecFields (CRecordUpdate base fields) = scanRecFields base
  ++ flatMap (f => scanRecFields (cFieldExpr f)) fields
scanRecFields (CVariantUpdate _ base fields) = scanRecFields base
  ++ flatMap (f => scanRecFields (cFieldExpr f)) fields
scanRecFields (CTuple es) = flatMap scanRecFields es
scanRecFields (CList es) = flatMap scanRecFields es
scanRecFields (CArray es) = flatMap scanRecFields es
scanRecFields (CApp f a) = scanRecFields f ++ scanRecFields a
scanRecFields (CLam _ b) = scanRecFields b
scanRecFields (CBinPrim _ l r _) = scanRecFields l ++ scanRecFields r
scanRecFields (CUnOp _ x) = scanRecFields x
scanRecFields (CIf c t f) = scanRecFields c
  ++ scanRecFields t
  ++ scanRecFields f
scanRecFields (CLet _ _ a b) = scanRecFields a ++ scanRecFields b
scanRecFields (CBlock stmts) = flatMap scanRecFieldsStmt stmts
scanRecFields (CDecision scrut arms _) = scanRecFields scrut
  ++ flatMap (a => scanRecFields (armBody a)) arms
scanRecFields (CMatch scrut arms) = scanRecFields scrut
  ++ flatMap (a => scanRecFields (armBody a)) arms
scanRecFields (CRangeList lo hi _) = scanRecFields lo ++ scanRecFields hi
scanRecFields (CRangeArray lo hi _) = scanRecFields lo ++ scanRecFields hi
scanRecFields (CIndex a i) = scanRecFields a ++ scanRecFields i
scanRecFields (CSlice a lo hi _) = scanRecFields a
  ++ scanRecFields lo
  ++ scanRecFields hi
scanRecFields _ = []

scanRecFieldsStmt : CStmt -> List (String, List String)
scanRecFieldsStmt (CSExpr e) = scanRecFields e
scanRecFieldsStmt (CSLet _ _ e) = scanRecFields e
scanRecFieldsStmt _ = []

-- dedup by ctor name (first entry wins; all entries for one ctor agree).
dedupRecEntries : List (String, List String) -> List (String, List String)
dedupRecEntries [] = []
dedupRecEntries ((n, fs)::rest) =
  if isSome (lookupAssoc n rest) then
    (n, fs) :: dedupRecEntries (filterList (e => not (eqStr (recEntryName e) n)) rest)
  else
    (n, fs) :: dedupRecEntries rest

recEntryName : (String, List String) -> String
recEntryName (n, _) = n

bindUsesClosures : List String -> List (String, Int) -> List (String, Int) -> CBind -> Bool
bindUsesClosures fnNames fnArs ctorArs (CBind _ clauses) = multiOrPatternClauses clauses
  || anyList (clauseUsesClosures fnNames fnArs ctorArs) clauses

-- a fn binding needs clause-dispatch coalescing (W4) if it has >1 clause or any
-- non-PVar/PWild parameter (an inner-match on the args).
multiOrPatternClauses : List CClause -> Bool
multiOrPatternClauses [] = False
multiOrPatternClauses [CClause pats _] =
  anyList (p => not (isPlainParam p)) pats
multiOrPatternClauses _ = True

isPlainParam : Pat -> Bool
isPlainParam (PVar _) = True
isPlainParam PWild = True
isPlainParam _ = False

-- the set of top-level fn names that appear as VALUES (bare ref in a non-call
-- position, or partially / over applied) anywhere in the program — these need a
-- closure wrapper so they can flow through `(ref eq)` slots / be applied indirectly.
scanFnValueUses : List String -> List (String, Int) -> List (String, Int) -> List CBind -> List String
scanFnValueUses fnNames fnArs ctorArs groups =
  dedupKeep (flatMap (scanBindValueUses fnNames fnArs ctorArs) groups)

-- W9: the impl method bodies + interface defaults also use top-level fns as values
-- (e.g. `toList = identity` in `impl Foldable List`), so their fn-value uses must seed
-- the closure-wrapper set too — else `$mdk_w_<f>` is referenced but never emitted.
scanImplValueUses : List String -> List (String, Int) -> List (String, Int) -> List CImplEntry -> List String
scanImplValueUses fnNames fnArs ctorArs impls = dedupKeep (flatMap
  (e => scanImplEntryValueUses fnNames fnArs ctorArs e)
  impls)

scanImplEntryValueUses : List String -> List (String, Int) -> List (String, Int) -> CImplEntry -> List String
scanImplEntryValueUses fnNames fnArs ctorArs (CImplEntry _ _ body) = match body
  CImplTagged _ _ _ _ _ b => scanExprValueUses fnNames fnArs ctorArs b
  CImplDefault _ b => scanExprValueUses fnNames fnArs ctorArs b

scanBindValueUses : List String -> List (String, Int) -> List (String, Int) -> CBind -> List String
scanBindValueUses fnNames fnArs ctorArs (CBind _ clauses) = flatMap
  (c => scanExprValueUses fnNames fnArs ctorArs (clauseBodyOf c))
  clauses

clauseBodyOf : CClause -> CExpr
clauseBodyOf (CClause _ body) = body

scanExprValueUses : List String -> List (String, Int) -> List (String, Int) -> CExpr -> List String
scanExprValueUses fnNames fnArs ctorArs (CVar x _) =
  if contains x fnNames then
    [x]
  else if contains ("core__" ++ x) fnNames then
    ["core__" ++ x]
  else
    []
scanExprValueUses fnNames fnArs ctorArs (CApp f a) =
  let (hd, args) = flattenApp (CApp f a) []
  let here = match hd
    CVar fn0 _ =>
      let fn = if contains fn0 fnNames then
        fn0
      else if contains ("core__" ++ fn0) fnNames then
        "core__" ++ fn0
      else
        fn0
      if contains fn fnNames then
        if arityOf fnArs fn == listLen args then [] else [fn]
      else
        []
    _ => scanExprValueUses fnNames fnArs ctorArs hd
  here ++ flatMap (scanExprValueUses fnNames fnArs ctorArs) args
scanExprValueUses fnNames fnArs ctorArs (CLam _ b) =
  scanExprValueUses fnNames fnArs ctorArs b
scanExprValueUses fnNames fnArs ctorArs (CBinPrim _ l r _) = scanExprValueUses fnNames fnArs ctorArs l
  ++ scanExprValueUses fnNames fnArs ctorArs r
scanExprValueUses fnNames fnArs ctorArs (CUnOp _ x) =
  scanExprValueUses fnNames fnArs ctorArs x
scanExprValueUses fnNames fnArs ctorArs (CIf c t f) = scanExprValueUses fnNames fnArs ctorArs c
  ++ scanExprValueUses fnNames fnArs ctorArs t
  ++ scanExprValueUses fnNames fnArs ctorArs f
scanExprValueUses fnNames fnArs ctorArs (CLet _ _ a b) = scanExprValueUses fnNames fnArs ctorArs a
  ++ scanExprValueUses fnNames fnArs ctorArs b
scanExprValueUses fnNames fnArs ctorArs (CBlock stmts) =
  flatMap (s => scanStmtValueUses fnNames fnArs ctorArs s) stmts
scanExprValueUses fnNames fnArs ctorArs (CDecision scrut arms _) = scanExprValueUses fnNames fnArs ctorArs scrut
  ++ flatMap (a => scanArmValueUses fnNames fnArs ctorArs a) arms
scanExprValueUses fnNames fnArs ctorArs (CMatch scrut arms) = scanExprValueUses fnNames fnArs ctorArs scrut
  ++ flatMap (a => scanArmValueUses fnNames fnArs ctorArs a) arms
scanExprValueUses fnNames fnArs ctorArs (CLetGroup binds b) = flatMap (bd => scanBindValueUses fnNames fnArs ctorArs bd) binds
  ++ scanExprValueUses fnNames fnArs ctorArs b
-- Composite arms emitVarRef descends into at emit time — each can hold a fn-VALUE
-- use (`map (mapIfaceMethod f) ms` lives in a CRecordUpdate; `map (substField s) fs`
-- in a CTuple; `flatMap dataArity prog` in a CRecord field).  Missing these here
-- under-counted fnsUsedAsValuesRef → the closure wrapper `$mdk_w_<f>` was referenced
-- (ref.func emitted) but never DEFINED → "unknown func" at assemble.
scanExprValueUses fnNames fnArs ctorArs (CTuple xs) =
  flatMap (scanExprValueUses fnNames fnArs ctorArs) xs
scanExprValueUses fnNames fnArs ctorArs (CList xs) =
  flatMap (scanExprValueUses fnNames fnArs ctorArs) xs
scanExprValueUses fnNames fnArs ctorArs (CArray xs) =
  flatMap (scanExprValueUses fnNames fnArs ctorArs) xs
scanExprValueUses fnNames fnArs ctorArs (CRecord _ fs) =
  flatMap (fd => scanExprValueUses fnNames fnArs ctorArs (cFieldExpr fd)) fs
scanExprValueUses fnNames fnArs ctorArs (CFieldAccess r _ _) =
  scanExprValueUses fnNames fnArs ctorArs r
scanExprValueUses fnNames fnArs ctorArs (CRecordUpdate r fs) = scanExprValueUses fnNames fnArs ctorArs r
  ++ flatMap (fd => scanExprValueUses fnNames fnArs ctorArs (cFieldExpr fd)) fs
scanExprValueUses fnNames fnArs ctorArs (CVariantUpdate _ r fs) = scanExprValueUses fnNames fnArs ctorArs r
  ++ flatMap (fd => scanExprValueUses fnNames fnArs ctorArs (cFieldExpr fd)) fs
scanExprValueUses fnNames fnArs ctorArs (CRangeList lo hi _) = scanExprValueUses fnNames fnArs ctorArs lo
  ++ scanExprValueUses fnNames fnArs ctorArs hi
scanExprValueUses fnNames fnArs ctorArs (CRangeArray lo hi _) = scanExprValueUses fnNames fnArs ctorArs lo
  ++ scanExprValueUses fnNames fnArs ctorArs hi
scanExprValueUses fnNames fnArs ctorArs _ = []

-- scan an arm's guards (refutable `Pat <- e` / boolean `if e`) AND its body — a
-- guard scrutinee can carry a fn-value use just like the body.
scanArmValueUses : List String -> List (String, Int) -> List (String, Int) -> CArm -> List String
scanArmValueUses fnNames fnArs ctorArs (CArm _ guards body) = flatMap (g => scanGuardValueUses fnNames fnArs ctorArs g) guards
  ++ scanExprValueUses fnNames fnArs ctorArs body

scanGuardValueUses : List String -> List (String, Int) -> List (String, Int) -> CGuard -> List String
scanGuardValueUses fnNames fnArs ctorArs (CGBool e) =
  scanExprValueUses fnNames fnArs ctorArs e
scanGuardValueUses fnNames fnArs ctorArs (CGBind _ e) =
  scanExprValueUses fnNames fnArs ctorArs e

scanStmtValueUses : List String -> List (String, Int) -> List (String, Int) -> CStmt -> List String
scanStmtValueUses fnNames fnArs ctorArs (CSExpr e) =
  scanExprValueUses fnNames fnArs ctorArs e
scanStmtValueUses fnNames fnArs ctorArs (CSLet _ _ e) =
  scanExprValueUses fnNames fnArs ctorArs e
scanStmtValueUses fnNames fnArs ctorArs (CSLetElse _ e f) = scanExprValueUses fnNames fnArs ctorArs e
  ++ scanExprValueUses fnNames fnArs ctorArs f
scanStmtValueUses _ _ _ _ = []

clauseUsesClosures : List String -> List (String, Int) -> List (String, Int) -> CClause -> Bool
clauseUsesClosures fnNames fnArs ctorArs (CClause pats body) =
  exprUsesClosures fnNames fnArs ctorArs (flatMap patVars pats) body

-- a CLam anywhere; an application whose head is not a saturated known-fn/ctor call;
-- a bare CVar referencing a top-level fn in NON-call (value) position.
-- `locals` = the in-scope LOCALLY-BOUND names (clause params, let/lambda binders).
-- A CVar matching a local SHADOWS any same-named top-level fn / ctor, so applying it
-- is an INDIRECT (closure) call — the analysis MUST agree with emitAppRef/emitAppTail's
-- `contains f0 env`-first guard, else a shadowing-local call (`applyEq eq x y = eq x y`
-- with a top-level `eq` in scope) is mis-judged "saturated direct call, no closure" and
-- the closure types are never emitted though emit uses them (parse/validate failure).
exprUsesClosures : List String -> List (String, Int) -> List (String, Int) -> List String -> CExpr -> Bool
exprUsesClosures fnNames fnArs ctorArs locals (CLam _ _) = True
exprUsesClosures fnNames fnArs ctorArs locals (CApp f a) =
  appUsesClosures fnNames fnArs ctorArs locals (CApp f a)
exprUsesClosures fnNames fnArs ctorArs locals (CVar x _) = not (contains x locals)
  && contains x fnNames
exprUsesClosures fnNames fnArs ctorArs locals (CLit _) = False
exprUsesClosures fnNames fnArs ctorArs locals (CBinPrim _ l r _) = exprUsesClosures fnNames fnArs ctorArs locals l
  || exprUsesClosures fnNames fnArs ctorArs locals r
exprUsesClosures fnNames fnArs ctorArs locals (CUnOp _ x) =
  exprUsesClosures fnNames fnArs ctorArs locals x
exprUsesClosures fnNames fnArs ctorArs locals (CIf c t f) = exprUsesClosures fnNames fnArs ctorArs locals c
  || exprUsesClosures fnNames fnArs ctorArs locals t
  || exprUsesClosures fnNames fnArs ctorArs locals f
exprUsesClosures fnNames fnArs ctorArs locals (CLet _ pat a b) = exprUsesClosures fnNames fnArs ctorArs locals a
  || exprUsesClosures fnNames fnArs ctorArs (patVars pat ++ locals) b
exprUsesClosures fnNames fnArs ctorArs locals (CBlock stmts) =
  blockUsesClosures fnNames fnArs ctorArs locals stmts
exprUsesClosures fnNames fnArs ctorArs locals (CDecision scrut arms _) = exprUsesClosures fnNames fnArs ctorArs locals scrut
  || anyList (a => exprUsesClosures fnNames fnArs ctorArs locals (armBody a)) arms
exprUsesClosures fnNames fnArs ctorArs locals (CMatch scrut arms) = exprUsesClosures fnNames fnArs ctorArs locals scrut
  || anyList (a => exprUsesClosures fnNames fnArs ctorArs locals (armBody a)) arms
exprUsesClosures fnNames fnArs ctorArs locals _ = False

-- thread let-bound names through a block so a later statement's shadowing local is seen.
blockUsesClosures : List String -> List (String, Int) -> List (String, Int) -> List String -> List CStmt -> Bool
blockUsesClosures _ _ _ _ [] = False
blockUsesClosures fnNames fnArs ctorArs locals ((CSLet _ pat e)::rest) = exprUsesClosures fnNames fnArs ctorArs locals e
  || blockUsesClosures fnNames fnArs ctorArs (patVars pat ++ locals) rest
blockUsesClosures fnNames fnArs ctorArs locals ((CSExpr e)::rest) = exprUsesClosures fnNames fnArs ctorArs locals e
  || blockUsesClosures fnNames fnArs ctorArs locals rest
blockUsesClosures fnNames fnArs ctorArs locals (_::rest) =
  blockUsesClosures fnNames fnArs ctorArs locals rest

-- an application uses closures unless it is a saturated direct call to a known
-- top-level fn (exact arity) or a ctor application.  Over/under application of a
-- known fn, or a non-variable / non-fn / non-ctor head, is a closure use.  The args
-- are also scanned (a saturated call passing a lambda is still a closure use).
appUsesClosures : List String -> List (String, Int) -> List (String, Int) -> List String -> CExpr -> Bool
appUsesClosures fnNames fnArs ctorArs locals app =
  let (hd, args) = flattenApp app []
  let argsClos = anyList (exprUsesClosures fnNames fnArs ctorArs locals) args
  match hd
    CVar f _ =>
      if contains f locals then True   -- a shadowing local/param head → indirect (closure) call
      else if contains f fnNames then
        arityOf fnArs f != listLen args || argsClos
      else if isSome (lookupAssoc f ctorArs) || isReservedCtor f then argsClos
      else True   -- a local/param/let-bound head → an indirect (closure) call
    _ => True

-- a fn's recorded arity, or -1 if absent (a fn whose arity table entry is missing
-- can't be saturated by exact count, so it's treated as non-saturated).
arityOf : List (String, Int) -> String -> Int
arityOf ars f = match lookupAssoc f ars
  Some n => n
  None => -1

-- a program uses ADTs if it has any user constructor (the ctor table is non-empty
-- once a `data` decl exists) OR any `CDecision` in any body.  The reserved
-- Option/Result/Ordering ctors only enter the table when actually used, and a
-- bare scalar program (the W2 corpus) has an empty ctor table + no CDecision.
programUsesAdt : List CBind -> List (String, Int) -> Bool
programUsesAdt groups ctorArs = listLen ctorArs != 0
  || anyBindHasDecision groups

anyBindHasDecision : List CBind -> Bool
anyBindHasDecision [] = False
anyBindHasDecision ((CBind _ clauses)::rest) =
  if anyClauseHasDecision clauses then
    True
  else
    anyBindHasDecision rest

anyClauseHasDecision : List CClause -> Bool
anyClauseHasDecision [] = False
anyClauseHasDecision ((CClause _ body)::rest) =
  if exprHasDecision body then
    True
  else
    anyClauseHasDecision rest

exprHasDecision : CExpr -> Bool
exprHasDecision (CDecision _ _ _) = True
exprHasDecision (CMatch _ _) = True
exprHasDecision (CIf c t f) = exprHasDecision c
  || exprHasDecision t
  || exprHasDecision f
exprHasDecision (CLet _ _ a b) = exprHasDecision a || exprHasDecision b
exprHasDecision (CBinPrim _ a b _) = exprHasDecision a || exprHasDecision b
exprHasDecision (CUnOp _ a) = exprHasDecision a
exprHasDecision (CApp f a) = exprHasDecision f || exprHasDecision a
exprHasDecision (CBlock stmts) = anyList stmtHasDecision stmts
exprHasDecision _ = False

stmtHasDecision : CStmt -> Bool
stmtHasDecision (CSExpr e) = exprHasDecision e
stmtHasDecision (CSLet _ _ e) = exprHasDecision e
stmtHasDecision _ = False

anyList : (a -> Bool) -> List a -> Bool
anyList _ [] = False
anyList p (x::xs) = if p x then True else anyList p xs

-- ════════════════════════════════════════════════════════════════════════════
-- SCALAR MODE (W2, raw i32) — byte-identical to the W2 emitter.
-- ════════════════════════════════════════════════════════════════════════════

emitScalarProgram : List String -> List String -> List CBind -> <Mut> String
emitScalarProgram fnNames valNames groups =
  -- the scalar type section (W2 shape) with the byte-write IO import (W6 collapse)
  -- replacing the old mdk_write_int/mdk_write_bool scaffold imports.
  let header = preambleHeadLines
    ++ [
      "  ;; ── §3 type section (one rec group) — scalar subset uses raw i32 ──",
      "  (rec",
      "    (type $boxint (sub (struct (field i64))))",
      "    (type $float (sub (struct (field f64))))",
      "  )"]
    ++ ioByteImportLines
  let globals = map oneGlobalI32 valNames
  let fns = flatMap (emitScalarFnBind fnNames valNames) (userFnBinds groups)
  let initLines = emitScalarInit fnNames valNames groups
  -- B5: the stderr byte-write import for a coded div/mod trap.  Computed AFTER the
  -- body-emit bindings above (Medaka `let` is strict) so useTrapImport — set during
  -- emit by wasmTrapBytes — is visible.  wasm-tools text assembles fields into
  -- sections regardless of order, so a late `(import …)` field is fine.
  let trapImport = if useTrapImport.value then stderrByteImportLines else []
  joinNl (header ++ trapImport ++ globals ++ fns ++ ioRuntimeLines ++ initLines ++ [")"])

oneGlobalI32 : String -> String
oneGlobalI32 n = "  (global $" ++ gname n ++ " (mut i64) (i64.const 0))"

emitScalarInit : List String -> List String -> List CBind -> <Mut> List String
emitScalarInit fnNames valNames groups =
  let valBinds = topoSortValBinds (filterList isValBind groups)
  let valInit = flatMap (emitScalarValInit fnNames valNames) valBinds
  let mainLines = emitScalarMain fnNames valNames groups
  let valLocals = flatMap collectBindLocals valBinds
  let mainLocals = match findMain groups
    Some body => collectExprLocals body
    None => []
  let locals = dedupKeep (valLocals ++ mainLocals)
  let localDecls = map (l => "  " ++ localDeclI32 l) locals
  -- B5: scalar divisor-guard scratch (a `/`/`%` in a value-binding or `main` body).
  let dv = if useDivGuardRef.value then ["    (local $__sdivr i64)"] else []
  ["  (func $__init"]
    ++ dv
    ++ localDecls
    ++ valInit
    ++ mainLines
    ++ ["  )", "  (start $__init)"]

emitScalarValInit : List String -> List String -> CBind -> <Mut> List String
emitScalarValInit fnNames valNames (CBind name [CClause [] body]) =
  let (instrs, _) = emitScalarExpr fnNames valNames [] body
  indent instrs ++ ["    global.set $" ++ gname name]
emitScalarValInit _ _ _ = gapL "value binding must be a nullary clause"

emitScalarMain : List String -> List String -> List CBind -> <Mut> List String
emitScalarMain fnNames valNames groups = match findMain groups
  Some body =>
    let (instrs, ty) = emitScalarExpr fnNames valNames [] body
    indent instrs ++ printFor ty
  None => gapL "no `main` binding"

printFor : WTy -> <Mut> List String
-- layer-17 §2.1: scalar values are uniformly i64 now.  Int prints directly; Bool is
-- an i64 0/1, so wrap to i32 for $mdk_print_bool.
printFor WInt = ["    call $mdk_print_int"]
printFor WBool = ["    i32.wrap_i64", "    call $mdk_print_bool"]
printFor WUnit = gapL "scalar-mode: Unit main has no scalar value to print"
printFor WStr =
  gapL
    "scalar-mode main produced a String — internal mode mismatch (strings force ref-mode)"
printFor WChar =
  gapL
    "scalar-mode main produced a Char — internal mode mismatch (Char main forces ref-mode)"
printFor WRef =
  gapL "scalar-mode main produced a (ref eq) — internal mode mismatch"

emitScalarFnBind : List String -> List String -> CBind -> <Mut> List String
emitScalarFnBind fnNames valNames (CBind name [CClause pats body]) =
  let params = map patName pats
  let localsInBody = collectExprLocals body
  let extraLocals = filterList (notIn params) (dedupKeep localsInBody)
  let env = params
  let instrs = emitScalarTail fnNames valNames env body
  let sig = "  (func $\{gname name}\{joinWith "" (map paramDeclI32 params)} (result i64)"
  let localDecls = map localDeclI32 extraLocals
  -- B5: scalar divisor-guard scratch for a concrete-Int `/`/`%` in this fn body.
  let dv = if useDivGuardRef.value then ["(local $__sdivr i64)"] else []
  [sig] ++ map ("  " ++ _) (dv ++ localDecls) ++ indent instrs ++ ["  )"]
emitScalarFnBind _ _ (CBind name _) =
  gap
    ("scalar-mode top-level function '" ++ name ++ "' is multi-clause or pattern-matching (decision-tree match needs ADT mode)")

-- scalar (i32) TAIL-position emitter (§4.2 TCO for the monomorphic-Int fast path).
-- Descends into if-branches; a saturated direct call to a known top-level fn at the
-- tail → `return_call` (guaranteed constant-stack); any other tail leaf → its value +
-- `return`.  This is what lets a deep scalar tail-recursion (the 5M `loop`) run in
-- bounded stack.  Non-recursive / shallow fns are unaffected (still correct).
emitScalarTail : List String -> List String -> List String -> CExpr -> <Mut> List String
emitScalarTail fnNames valNames env (CIf c t f) =
  let (ci, _) = emitScalarExpr fnNames valNames env c
  let ti = emitScalarTail fnNames valNames env t
  let fi = emitScalarTail fnNames valNames env f
  ci
    ++ ["i64.const 0", "i64.ne", "if (result i64)"]
    ++ indent ti
    ++ ["else"]
    ++ indent fi
    ++ ["end", "unreachable"]
emitScalarTail fnNames valNames env (CLet False (PVar x) e1 e2) =
  let (i1, _) = emitScalarExpr fnNames valNames env e1
  i1
    ++ ["local.set $" ++ gname x]
    ++ emitScalarTail fnNames valNames (x::env) e2
emitScalarTail fnNames valNames env (CLet False PWild e1 e2) =
  let (i1, _) = emitScalarExpr fnNames valNames env e1
  i1 ++ ["drop"] ++ emitScalarTail fnNames valNames env e2
emitScalarTail fnNames valNames env (CApp f a) =
  emitScalarAppTail fnNames valNames env (CApp f a)
emitScalarTail fnNames valNames env other =
  let (i, _) = emitScalarExpr fnNames valNames env other
  i ++ ["return"]

emitScalarAppTail : List String -> List String -> List String -> CExpr -> <Mut> List String
emitScalarAppTail fnNames valNames env app =
  let (hd, args) = flattenApp app []
  match hd
    CVar f _ => if contains f fnNames then
      let argInstrs = flatMap (a => fst (emitScalarExpr fnNames valNames env a)) args
      argInstrs ++ ["return_call $" ++ gname f]
    else
      let (i, _) = emitScalarExpr fnNames valNames env app
      i ++ ["return"]
    _ =>
      let (i, _) = emitScalarExpr fnNames valNames env app
      i ++ ["return"]

paramDeclI32 : String -> String
paramDeclI32 p = " (param $" ++ gname p ++ " i64)"

localDeclI32 : String -> String
localDeclI32 l = "(local $" ++ gname l ++ " i64)"

emitScalarExpr : List String -> List String -> List String -> CExpr -> <Mut> (List String, WTy)
emitScalarExpr fnNames valNames env (CLit l) = emitLitI32 l
emitScalarExpr fnNames valNames env (CVar x _) =
  emitVarI32 fnNames valNames env x
emitScalarExpr fnNames valNames env (CBinPrim op l r _) =
  emitBinI32 fnNames valNames env op l r
emitScalarExpr fnNames valNames env (CUnOp op x) =
  emitUnI32 fnNames valNames env op x
emitScalarExpr fnNames valNames env (CIf c t f) =
  emitIfI32 fnNames valNames env c t f
emitScalarExpr fnNames valNames env (CLet recF pat e1 e2) =
  emitLetI32 fnNames valNames env recF pat e1 e2
emitScalarExpr fnNames valNames env (CBlock stmts) =
  emitBlockI32 fnNames valNames env stmts
emitScalarExpr fnNames valNames env (CApp f a) =
  emitAppI32 fnNames valNames env (CApp f a)
emitScalarExpr fnNames valNames env other =
  gapLTy ("scalar-mode: unsupported Core IR node " ++ ctag other)

emitLitI32 : Lit -> <Mut> (List String, WTy)
-- layer-17 §2.1: scalar mode is now uniformly i64 (Int/Bool/Unit all i64 0/1/value)
-- so >2^30 Int arithmetic computes in i64 and never truncates.
emitLitI32 (LInt n) = (["i64.const " ++ intToString n], WInt)
emitLitI32 (LBool b) = ([if b then "i64.const 1" else "i64.const 0"], WBool)
emitLitI32 LUnit = (["i64.const 0"], WUnit)
emitLitI32 (LFloat _) =
  gapLTy
    "Float literal (boxed (struct f64)) is deferred — no scalar Float fixture"
emitLitI32 (LString _) = gapLTy "String literal (the (array i8) rep) is W6"
emitLitI32 (LChar _) = gapLTy "Char literal is W6 (string/unicode slice)"

emitVarI32 : List String -> List String -> List String -> String -> <Mut> (List String, WTy)
emitVarI32 fnNames valNames env x =
  if contains x env then
    (["local.get $" ++ gname x], WInt)
  else if contains x valNames then
    (["global.get $" ++ gname x], WInt)
  else if contains x fnNames then
    (["call $" ++ gname x], WInt)
  else
    gapLTy ("scalar-mode: unbound variable '" ++ x ++ "'")

emitBinI32 : List String -> List String -> List String -> String -> CExpr -> CExpr -> <Mut> (List String, WTy)
emitBinI32 fnNames valNames env op l r =
  let (li, _) = emitScalarExpr fnNames valNames env l
  let (ri, _) = emitScalarExpr fnNames valNames env r
  -- layer-17 §2.1: i64 arithmetic.  A comparison yields wasm i32 0/1, so extend it
  -- back to the uniform i64 value rep.
  if isCmpOp op then (li ++ ri ++ [wasmBinOp64 op, "i64.extend_i32_u"], binOpTy op)
  -- B5: scalar-mode concrete-Int `/`/`%` get the same coded divisor-zero guard as
  -- ref mode (single function-scope $__sdivr i64 scratch; reuse across nested divs is
  -- safe — each store-then-immediately-use completes before the next).
  else if (op == "/" || op == "%") then
    (li ++ ri ++ emitDivZeroGuard op "$__sdivr" ++ [wasmBinOp64 op], binOpTy op)
  else (li ++ ri ++ [wasmBinOp64 op], binOpTy op)

emitUnI32 : List String -> List String -> List String -> String -> CExpr -> <Mut> (List String, WTy)
emitUnI32 fnNames valNames env "-" x =
  let (xi, _) = emitScalarExpr fnNames valNames env x
  (["i64.const 0"] ++ xi ++ ["i64.sub"], WInt)
emitUnI32 fnNames valNames env "!" x =
  let (xi, _) = emitScalarExpr fnNames valNames env x
  -- i64 Bool -> negate: i64.eqz yields i32, extend back to i64.
  (xi ++ ["i64.eqz", "i64.extend_i32_u"], WBool)
emitUnI32 _ _ _ op _ =
  gapLTy ("scalar-mode: unsupported unary op '" ++ op ++ "'")

emitIfI32 : List String -> List String -> List String -> CExpr -> CExpr -> CExpr -> <Mut> (List String, WTy)
emitIfI32 fnNames valNames env c t f =
  let (ci, _) = emitScalarExpr fnNames valNames env c
  let (ti, tty) = emitScalarExpr fnNames valNames env t
  let (fi, _) = emitScalarExpr fnNames valNames env f
  -- the condition is an i64 Bool; wasm `if` consumes i32, so test against zero.
  (ci ++ ["i64.const 0", "i64.ne", "if (result i64)"] ++ indent ti ++ ["else"] ++ indent fi ++ ["end"], tty)

emitLetI32 : List String -> List String -> List String -> Bool -> Pat -> CExpr -> CExpr -> <Mut> (List String, WTy)
emitLetI32 fnNames valNames env False (PVar x) e1 e2 =
  let (i1, _) = emitScalarExpr fnNames valNames env e1
  let (i2, ty2) = emitScalarExpr fnNames valNames (x::env) e2
  (i1 ++ ["local.set $" ++ gname x] ++ i2, ty2)
emitLetI32 fnNames valNames env False PWild e1 e2 =
  let (i1, _) = emitScalarExpr fnNames valNames env e1
  let (i2, ty2) = emitScalarExpr fnNames valNames env e2
  (i1 ++ ["drop"] ++ i2, ty2)
emitLetI32 _ _ _ _ _ _ _ =
  gap "scalar-mode: only non-recursive `let x = e` / `let _ = e`"

emitBlockI32 : List String -> List String -> List String -> List CStmt -> <Mut> (List String, WTy)
emitBlockI32 fnNames valNames env [CSExpr ex] =
  emitScalarExpr fnNames valNames env ex
emitBlockI32 fnNames valNames env ((CSExpr ex)::rest) =
  let (i1, _) = emitScalarExpr fnNames valNames env ex
  let (i2, ty) = emitBlockI32 fnNames valNames env rest
  (i1 ++ ["drop"] ++ i2, ty)
emitBlockI32 fnNames valNames env ((CSLet _ (PVar x) ex)::rest) =
  let (i1, _) = emitScalarExpr fnNames valNames env ex
  let (i2, ty) = emitBlockI32 fnNames valNames (x::env) rest
  (i1 ++ ["local.set $" ++ gname x] ++ i2, ty)
emitBlockI32 fnNames valNames env ((CSLet _ PWild ex)::rest) =
  let (i1, _) = emitScalarExpr fnNames valNames env ex
  let (i2, ty) = emitBlockI32 fnNames valNames env rest
  (i1 ++ ["drop"] ++ i2, ty)
-- W11: a `let mut x` reassignment `x = e` in scalar mode — `x` is already an i32
-- local (the originating `let mut`'s PVar is declared by collectExprLocals); just
-- recompute and re-set it.  (Scalar mode is i32-only, so the value is an i32.)
emitBlockI32 fnNames valNames env ((CSAssign x ex)::rest) =
  let (i1, _) = emitScalarExpr fnNames valNames env ex
  let (i2, ty) = emitBlockI32 fnNames valNames env rest
  (i1 ++ ["local.set $" ++ gname x] ++ i2, ty)
emitBlockI32 _ _ _ [] = gapLTy "scalar-mode: empty block"
emitBlockI32 _ _ _ _ = gapLTy "scalar-mode: unsupported block statement"

emitAppI32 : List String -> List String -> List String -> CExpr -> <Mut> (List String, WTy)
emitAppI32 fnNames valNames env app =
  let (hd, args) = flattenApp app []
  match hd
    CVar f _ => if contains f fnNames then
      let argInstrs = flatMap (a => fst (emitScalarExpr fnNames valNames env a)) args
      (argInstrs ++ ["call $" ++ gname f], WInt)
    else gapLTy ("scalar-mode: application of non-top-level head '" ++ f ++ "' (closures/HOFs are W4)")
    _ => gapLTy "scalar-mode: application of a non-variable head (closures/HOFs are W4)"

-- ════════════════════════════════════════════════════════════════════════════
-- REF MODE (W3, uniform (ref eq) + i31/structs) — the ADT path.
-- ════════════════════════════════════════════════════════════════════════════

emitRefProgram : Prog -> List CBind -> <Mut> String
emitRefProgram prog groups =
  let header = preambleHeadLines
  let typeSection = emitTypeSection prog
  -- W8: ePutStr/ePutStrLn (useEPutRef) and B5 coded traps (useTrapImport) both need the
  -- stderr byte-write import; it is emitted ONCE, LATE (see `trapImport` below), because
  -- useTrapImport is set during body emit.
  let imports = ioByteImportLines
    -- W8b: floatToString is a host import (the %.12g formatter lives JS-side).
    ++ (if useFloatRef.value then floatFmtImportLines else [])
    -- layer-6: stringToFloat is a host import (mdk_str_to_float uses JS Number()).
    ++ (if useFloatStrRef.value then floatStrImportLines else [])
    -- W12: the IO host surface (readFile/fileExists/args/getEnv/exit) host imports.
    ++ (if useIORef.value then ioHostImportLines else [])
    -- stage-D: writeFileBytes's write host imports (reset/push/commit).
    ++ (if useFileBytesRef.value then fileBytesHostImportLines else [])
  let valNames = progValNames prog
  -- Stage-2/3 (b′) WASMGC-TRMC: detect dispatch-graph TMC groups (the lexer's `scan`
  -- token spine, the offside-rule `layout` family, `intersperse`) BEFORE emitting fns,
  -- so emitRefFnBind can route a group member to the dest-passing reset-wrapper +
  -- inner-loop emit.  ALL binds are passed (not just fn binds): the external-entry
  -- root-selection check must see references from value-bind bodies too.
  let dispGroups = detectDispatchGroups prog groups
  let _ = setRef wDispGroupsRef dispGroups
  -- W8: the SplitMix64 seed lives in a mutable i64 global (emitted before the value globals).
  let rngGlobal = if useRngRef.value then rngStateGlobalLines else []
  let dispGlobals = flatMap wDispGlobalLines dispGroups
  let globals = rngGlobal ++ dispGlobals ++ map oneGlobalRef valNames
  -- emit user fns FIRST (this is what accumulates lifted lambdas into liftedFnsRef).
  let fns = flatMap (emitRefFnBind prog) (userFnBinds groups)
  -- W5: the typeclass impl functions ($mdk_impl_<tag>_<method>), emitted as ordinary
  -- (ref eq) functions the RKey direct call / RDict if-chain dispatch into.
  let implFns = emitImplFns prog
  let initLines = emitRefInit prog groups
  -- layer-15: the synthesized interface-default defines ($mdk_default_<method>_<tag>),
  -- accumulated during fns/implFns/INIT body emission — a `filter` call may live in a
  -- value binding / `main` (emitRefInit), so this drain must follow initLines too.
  -- Each default's inner lambda already drained into liftedFnsRef, so this precedes
  -- the `lifted` concat.  Drained UNCONDITIONALLY (a default define is a plain fn).
  let defaultDefs = flatMap (x => x) (reverseL defaultDefsWRef.value)
  -- now drain the lifted-lambda defs + the closure-apply runtime + elem-declare.
  let lifted = if progUseClos prog then flatMap (x => x) (reverseL liftedFnsRef.value) else []
  let applyRt = if progUseClos prog then closApplyLines else []
  let elemDecl = if progUseClos prog then [emitElemDeclare ()] else []
  -- W6: the byte-write IO runtime (int/bool printers always; the $str-dependent
  -- string runtime only when strings are used) + the string-literal passive data
  -- segments (drained from strSegsRef, in segment-index order).
  let ioRt = ioRuntimeLines ++ (if useStrRef.value then ioStrRuntimeLines else [])
  -- W8: the pure-WAT string LEAF ops, stderr runtime, RNG, and hashers — each gated
  -- by its use ref.  strConcat needs the W7 cons list types ($C_Cons), so it is gated
  -- on useListRef too (a stringConcat always uses a list, so useListRef is set).
  let strLeafRt = if useStrLeafRef.value then strLeafRuntimeLines else []
  let strConcatRt = if useStrLeafRef.value && useListRef.value then strConcatRuntimeLines else []
  -- W13: `++` is runtime-dispatched ($mdk_append); needs $str (str leaf) + $C_Cons (list).
  let appendRt = if useStrLeafRef.value && useListRef.value then appendRuntimeLines else []
  -- layer-9: $mdk_value_eq / $mdk_value_cmp (runtime-shape-dispatched comparison).
  -- Needs $str (forced via useStrRef when this is set) + $mdk_str_compare (forced via
  -- useStrSearchRef in emitValueCmpRef).
  let valueCmpRt = if useValueCmpRef.value then valueEqRuntimeLines else []
  -- A0: runtime value-tag-dispatched arithmetic helpers ($mdk_value_add/…), emitted only
  -- when a poly-`Num` operand is routed to them (A1).  Reference $float/$boxint (always
  -- declared) + $mdk_unbox_int/$mdk_box_int (always in ioRuntimeLines).
  let valueArithRt = if useValueArithRef.value then valueArithRuntimeLines else []
  let stderrRt = if useEPutRef.value then stderrRuntimeLines else []
  let rngRt = if useRngRef.value then rngRuntimeLines else []
  let hashRt = if useHashRef.value then hashRuntimeLines else []
  let hashStrRt = if useHashRef.value && useStrRef.value then hashStringRuntimeLines else []
  -- W8b: the Float runtime (intToFloat/floatToInt/floatToString) + the hashFloat /
  -- randomFloat helpers (gated separately since they need mix64 / next_u64) + the
  -- string index-of / compare runtime.
  let floatRt = if useFloatRef.value then floatRuntimeLines else []
  let hashFloatRt = if useFloatHashRef.value then hashFloatRuntimeLines else []
  let randomFloatRt = if useFloatRngRef.value then randomFloatRuntimeLines else []
  -- layer-6: stringToFloat runtime ($mdk_string_to_float).  Needs ioHostRt for the
  -- path channel ($mdk_path_reset/$mdk_path_push), but emitted AFTER ioHostRt since
  -- those functions are defined there (wasm forward refs are fine, but order is clear).
  let floatStrRt = if useFloatStrRef.value then floatStrRuntimeLines else []
  let strSearchRt = if useStrSearchRef.value then strSearchRuntimeLines else []
  -- W11b: the UTF-8 codec ($mdk_str_to_chars / $mdk_chars_to_str) + charFromCode's
  -- range-check runtime ($mdk_char_from_code).  The codec needs the $str rep ($u8arr)
  -- and the $arr rep (both forced via noteW8Extern).  charFromCode alone needs neither
  -- the codec nor strLeaf, so its runtime fn is gated independently.
  let strCodecRt = if useStrCodecRef.value then strCodecRuntimeLines else []
  let charFromCodeRt = if useCharFromCodeRef.value then charFromCodeRuntimeLines else []
  -- W11b: char classification + case-mapping helpers (ASCII-only pure WAT).
  let charClassRt = if useCharClassRef.value then charClassRuntimeLines else []
  -- W12: the IO host-surface marshaling runtime (byte-channel + the five extern bodies).
  -- The `args` body lives in a separate block (it builds a $C_Cons list, needing the
  -- list types) gated on useArgsRef.
  let ioHostRt = if useIORef.value then ioHostRuntimeLines else []
  let ioArgsRt = if useArgsRef.value then ioArgsRuntimeLines else []
  -- stage-D: the byte-clean file I/O bodies ($mdk_read_file_bytes_io / _write_).  Needs
  -- ioHostRt in scope ($mdk_push_path / $mdk_io_result_to_str) + the $arr rep.
  let fileBytesRt = if useFileBytesRef.value then fileBytesRuntimeLines else []
  let dataSegs = emitDataSegs ()
  -- B5: the stderr byte-write import — for ePutStr (useEPutRef) OR a coded runtime trap
  -- (useTrapImport, set during the body emit above).  Emitted ONCE.  This binding is
  -- forced after all body-emit bindings (strict `let`), so useTrapImport is visible;
  -- `dataSegs` above already relies on that same after-body ordering (strSegsRef).
  let trapImport = if useEPutRef.value || useTrapImport.value then stderrByteImportLines else []
  joinNl (header ++ typeSection ++ imports ++ trapImport ++ elemDecl ++ globals
            ++ fns ++ implFns ++ defaultDefs ++ lifted ++ applyRt ++ ioRt ++ strLeafRt ++ strConcatRt ++ appendRt ++ valueCmpRt ++ valueArithRt
            ++ stderrRt ++ rngRt ++ hashRt ++ hashStrRt
            ++ floatRt ++ hashFloatRt ++ randomFloatRt ++ strSearchRt
            ++ strCodecRt ++ charFromCodeRt ++ charClassRt ++ ioHostRt ++ ioArgsRt ++ fileBytesRt ++ floatStrRt
            ++ dataSegs ++ initLines ++ [")"])

-- the passive data segments for string literals — one `(data $strseg_N "…")` per
-- distinct literal, emitted in segment-index order.  `array.new_data` reads from
-- these (the §11-preferred non-const-array init scheme; no active memory needed).
emitDataSegs : Unit -> <Mut> List String
emitDataSegs _ =
  let segs = sortSegsByIdx (reverseL strSegsRef.value)
  map oneDataSeg segs

oneDataSeg : (Int, List Int) -> String
oneDataSeg (i, bytes) =
  "  (data $strseg_\{intToString i} \"\{escWatBytes bytes}\")"

-- sort (idx, bytes) entries by ascending idx (insertion sort; segment counts are tiny).
sortSegsByIdx : List (Int, List Int) -> List (Int, List Int)
sortSegsByIdx [] = []
sortSegsByIdx (x::xs) = insertSeg x (sortSegsByIdx xs)

insertSeg : (Int, List Int) -> List (Int, List Int) -> List (Int, List Int)
insertSeg x [] = [x]
insertSeg (i, b) ((j, c)::rest) =
  if i <= j then
    (i, b) :: (j, c)::rest
  else
    (j, c) :: insertSeg (i, b) rest

-- the `(elem declare func …)` line listing every fn `ref.func`'d (lifted lambdas,
-- the PAP code, and any top-level fn used as a value) — required so `ref.func`
-- validates.  Drained from `funcRefsRef` after all bodies are emitted.
emitElemDeclare : Unit -> <Mut> String
emitElemDeclare _ =
  let names = "$mdk_pap" :: reverseL funcRefsRef.value
  "  (elem declare func " ++ joinWith " " names ++ ")"

oneGlobalRef : String -> String
oneGlobalRef n = "  (global $"
  ++ gname n
  ++ " (mut (ref null eq)) (ref.null eq))"

-- ── §3.4 type section: one rec group with the universal root + per-type roots
-- + per payload-ctor structs.  Each payload struct has an explicit i32 tag field
-- (field 0 — defends against structural-subtyping collapse) then one (ref eq) per
-- payload field.  Nullary ctors need no struct (they are i31 immediates).  The
-- reserved Option/Result/Ordering types are appended (their structs only matter
-- for the payload ctors Some/Ok/Err).
emitTypeSection : Prog -> List String
emitTypeSection prog =
  let userTypes = userTypesWithCtors prog
  let userStructs = flatMap (emitTypeStructs prog) userTypes
  let reservedStructs = emitReservedStructs prog
  let closTypes = if progUseClos prog then closTypeLines else []
  let strTypes = if useStrRef.value then strTypeLines else []
  let w7Types = emitW7Types ()
  ["  ;; ── §3 type section (rec group) — §3.4 ADT structs + §8.6 (ref eq)/i31 ──",
   "  (rec",
   "    ;; layer-17 §2.1: boxed Int outside ±2^30 (the $mdk_box_int/$mdk_unbox_int seam).",
   "    (type $boxint (sub (struct (field i64))))",
   "    ;; boxed Float (§3.3) — declared, unused until a Float fixture needs it.",
   "    (type $float (sub (struct (field f64))))",
   -- W5 nested requires-dict cell (mirrors llvm_emit's `[ i64 head_tag | i64 reqdict_0 | … ]`).
   -- A one-level dict stays an i31 (just the tag); a NESTED dict (`RKey k [reqs]`) is a
   -- $dictcell: field 0 = i32 hashName(head-tag), field 1 = a $dictarr of the recursively-
   -- built nested req witnesses.  Consumption (readDictParam / loadReqDicts) type-tests the
   -- witness: i31 ⇒ tag = i31.get_s, no reqs; $dictcell ⇒ tag = struct.get 0, reqs = array.
   "    (type $dictarr (array (mut (ref eq))))",
   "    (type $dictcell (sub (struct (field i32) (field (ref $dictarr)))))"]
    ++ strTypes
    ++ closTypes
    ++ userStructs
    ++ reservedStructs
    ++ w7Types
    ++ ["  )"]

-- ── W7 collection types (§3.3) ───────────────────────────────────────────────
-- Conditionally emitted by usage (peer to strTypes):
--   List: root $T_List (i32 tag) + cons struct $C_Cons (tag, head, tail); Nil is an
--     i31 immediate (ordinal 1) so it needs no struct.  Matches the §3.3 + LLVM rep.
--   Tuple n: per-arity $T_Tup<n> root + $C_Tup<n> struct (tag + n (ref eq) fields).
--     A tuple is single-shape, but it reuses the W3 ctor machinery (discrimReadOf
--     reads the struct's field-0 tag = ordinal 0), so it carries a leading i32 tag.
--   Array: $arr = (array (mut (ref eq))) — array.len carries the length (§3.3).
--   Ref:   $refbox = a 1-field MUTABLE struct (setRef overwrites the field).
emitW7Types : Unit -> List String
emitW7Types _ =
  let listT = if useListRef.value then
        ["    (type $T_List (sub (struct (field i32))))",
         -- §3/Stage-0: cons TAIL field (index 2) is `mut` so TRMC destination-passing can
         -- `struct.set` a freshly-built child into the parent cell.  Head (index 1) stays
         -- immutable.  `mut` only PERMITS mutation — output is unchanged (nothing writes it yet).
         "    (type $C_Cons (sub $T_List (struct (field i32) (field (ref eq)) (field (mut (ref eq))))))"]
      else []
  let tupTs = flatMap tupleTypeDecl (reverseL tupleAritiesRef.value)
  let arrT = if useArrayRef.value then ["    (type $arr (array (mut (ref eq))))"] else []
  let refT = if useRefBoxRef.value then ["    (type $refbox (sub (struct (field (mut (ref eq))))))"] else []
  listT ++ tupTs ++ arrT ++ refT

tupleTypeDecl : Int -> List String
tupleTypeDecl n =
  let fields = joinWith "" (replicate n " (field (ref eq))")
  let root = typeRootName (syntheticCtorType (tupleCtorName n))
  let cs = ctorStructName (tupleCtorName n)
  [
    "    (type $" ++ root ++ " (sub (struct (field i32))))",
    "    (type $\{cs} (sub $\{root} (struct (field i32)\{fields})))",
  ]

-- distinct user type names (declaration order) that actually own ctors, paired
-- with their ctor list.  Reserved types are handled separately so they are never
-- double-declared.
userTypesWithCtors : Prog -> List String
userTypesWithCtors (Prog _ ctorTypes typeNames _ _ _ _ _ _) =
  filterList (t => not (isReservedType t)) typeNames

-- per-type: a root struct (just the i32 tag) + one struct per PAYLOAD ctor (tag +
-- fields), each declared `(sub $root …)`.  Nullary ctors get no struct.
emitTypeStructs : Prog -> String -> List String
emitTypeStructs prog ty =
  let ctors = ctorsOfType prog ty
  let root = "    (type $" ++ typeRootName ty ++ " (sub (struct (field i32))))"
  let payloadStructs = flatMap (emitCtorStruct prog ty) ctors
  [root] ++ payloadStructs

emitCtorStruct : Prog -> String -> String -> List String
emitCtorStruct prog ty ctor =
  let arity = ctorArity prog ctor
  if arity == 0 then []
  else
    -- §3/Stage-0: ctor payload fields are `mut` so a TRMC-destination recursive field
    -- can be `struct.set` after the parent cell is built.  Field types are uniform
    -- `(ref eq)` here (no per-field type), so all payload fields are made `mut`; this is
    -- output-neutral (`mut` only PERMITS mutation — nothing writes them yet), following
    -- the `$refbox`/`$arr` precedent.
    let fields = joinWith "" (replicate arity " (field (mut (ref eq)))")
    ["    (type $\{ctorStructName ctor} (sub $\{typeRootName ty} (struct (field i32)\{fields})))"]

-- reserved Option/Result/Ordering: declare each type's root + payload structs.
-- Emitted UNCONDITIONALLY in ref-mode (they are small; unused struct types are
-- valid WasmGC).  Detecting exact usage would need to scan the whole program for
-- reserved-ctor occurrences (constructions AND match heads) — the ctor table only
-- lists USER ctors — so always-declare is the simple correct choice for this slice.
emitReservedStructs : Prog -> List String
emitReservedStructs prog = reservedTypeStructs prog "Option" ["Some", "None"]
  ++ reservedTypeStructs prog "Result" ["Ok", "Err"]
  ++ reservedTypeStructs prog "Ordering" ["Lt", "Eq", "Gt"]

reservedTypeStructs : Prog -> String -> List String -> List String
reservedTypeStructs prog ty ctors =
  let root = "    (type $" ++ typeRootName ty ++ " (sub (struct (field i32))))"
  let payloadStructs = flatMap (emitReservedCtorStruct ty) ctors
  [root] ++ payloadStructs

-- reserved-ctor arities are fixed: Some/Ok/Err carry 1 payload field; None/Lt/Eq/Gt
-- are nullary.
emitReservedCtorStruct : String -> String -> List String
emitReservedCtorStruct ty ctor =
  if reservedCtorArity ctor == 0 then []
  else
    let fields = joinWith "" (replicate (reservedCtorArity ctor) " (field (ref eq))")
    [
      "    (type $\{ctorStructName ctor} (sub $\{typeRootName ty} (struct (field i32)\{fields})))"
    ]

-- ── ref-mode globals init + main ─────────────────────────────────────────────

-- Value globals (nullary top-level bindings) are eagerly initialized in `$__init`
-- in the order `valBinds` arrives.  But a value binding may REFERENCE another value
-- global (`topA = wrap topB`), and a forward reference reads that other global's
-- slot before its `global.set` runs → it is still `ref.null eq` → a `ref.as_non_null`
-- in the consumer traps "dereferencing a null pointer" at instantiate.  The parser
-- combinator ladder (`parsePipe = chainl1 parseCompose …`) is exactly this shape, a
-- chain of forward-referencing nullary value globals.  Topologically sort the value
-- binds so every global is initialized AFTER the value globals it reads EAGERLY.
--
-- CRUCIAL: the dependency edge is only an EAGER reference — a name NOT inside a
-- lambda/closure body.  A `CLam`/`do`-closure captures a global BY REFERENCE and
-- reads it only when later CALLED (at parse time, long after every global is set), so
-- a reference appearing solely inside a closure is NOT an init-order dependency.
-- Counting it would forge FALSE cycles between mutually-recursive combinators (the
-- whole parser ladder: `parseAtom` reaches `parseExpr` reaches `parseAtom`, but only
-- THROUGH their `do`-closures), and the cycle fallback would then emit them in source
-- order, leaving an eager forward ref null again — which is exactly why a naive
-- free-vars sort (descending lambdas) did NOT fix `parse ""`.  This mirrors the LLVM
-- backend's `eagerVars`/`orderedValBinds` (slice E1b), the proven solution.
-- A genuine EAGER value cycle (mutual recursion through nullary globals with no
-- intervening closure — none arise in practice) keeps source order via the back-edge
-- guard, the pre-existing behaviour.
topoSortValBinds : List CBind -> <Mut> List CBind
-- Intentional cross-file duplicate of the same helper in llvm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
topoSortValBinds binds =
  let names = map bindName binds
  let (_, ordered) = topoValGo binds names binds [] []
  ordered

-- DFS post-order: visit each binding's value-global EAGER deps first, appending the
-- binding after them.  `visiting` guards cycles (a back-edge is skipped).
topoValGo : List CBind -> List String -> List CBind -> List String -> List CBind -> <Mut> (List String, List CBind)
topoValGo _ _ [] done acc = (done, acc)
-- Intentional cross-file duplicate of the same helper in llvm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
topoValGo all names (b::rest) done acc =
  let (done2, acc2) = topoValVisit all names b done acc []
  topoValGo all names rest done2 acc2

topoValVisit : List CBind -> List String -> CBind -> List String -> List CBind -> List String -> <Mut> (List String, List CBind)
topoValVisit all names b done acc visiting
  | contains (bindName b) done = (done, acc)
  | contains (bindName b) visiting = (done, acc)
  | otherwise =
    let deps = filterList (n => contains n names) (dedupKeep (bindEagerVars b))
    let (done2, acc2) = topoValVisitDeps all names deps done acc (bindName b :: visiting)
    (bindName b :: done2, acc2 ++ [b])

topoValVisitDeps : List CBind -> List String -> List String -> List String -> List CBind -> List String -> <Mut> (List String, List CBind)
topoValVisitDeps _ _ [] done acc _ = (done, acc)
topoValVisitDeps all names (d::rest) done acc visiting = match findBindByName d all
  Some db =>
    let (done2, acc2) = topoValVisit all names db done acc visiting
    topoValVisitDeps all names rest done2 acc2 visiting
  None => topoValVisitDeps all names rest done acc visiting

findBindByName : String -> List CBind -> Option CBind
findBindByName _ [] = None
findBindByName name (b::rest) =
  if bindName b == name then
    Some b
  else
    findBindByName name rest

-- the EAGER free vars of a value binding's nullary rhs (does NOT descend lambdas).
bindEagerVars : CBind -> <Mut> List String
bindEagerVars (CBind _ [CClause [] body]) = eagerVars [] body
bindEagerVars _ = []

-- `eagerVars` (eager free-var / strictness analysis) lives in
-- `backend.emit_support`, shared verbatim with the LLVM emitter.  `bindEagerVars`
-- above threads it into this backend's value-init topo sort.

emitRefInit : Prog -> List CBind -> <Mut> List String
emitRefInit prog groups =
  let valBinds = topoSortValBinds (filterList isValBind groups)
  let valInit = flatMap (emitRefValInit prog) valBinds
  let mainLines = emitRefMain prog groups
  let valLocals = flatMap collectBindLocals valBinds
  let mainBodies = match findMain groups
    Some body => [body]
    None => []
  let mainLocals = flatMap collectExprLocals mainBodies
  let valBodies = flatMap bindBodies valBinds
  -- scratch ($__rf<d>) locals sized to the deepest match nesting across all $__init
  -- bodies (val inits + main).
  let maxDepth = foldMaxDepth (valBodies ++ mainBodies)
  let scratch = scratchLocals maxDepth
  let locals = dedupKeep (valLocals ++ mainLocals) ++ scratch
  let localDecls = map (l => "  " ++ localDeclRef l) locals
  let w7Decls = map ("  " ++ _) (w7LocalDecls maxDepth)
  ["  (func $__init"]
    ++ localDecls
    ++ w7Decls
    ++ valInit
    ++ mainLines
    ++ ["  )", "  (start $__init)"]

bindBodies : CBind -> List CExpr
bindBodies (CBind _ clauses) = flatMap clauseBody clauses

clauseBody : CClause -> List CExpr
clauseBody (CClause _ body) = [body]

foldMaxDepth : List CExpr -> Int
foldMaxDepth [] = 0
foldMaxDepth (e::rest) = maxI (maxRefDepth e) (foldMaxDepth rest)

emitRefValInit : Prog -> CBind -> <Mut> List String
emitRefValInit prog (CBind name [CClause [] body]) =
  let instrs = emitRefExpr prog [] 0 body
  indent instrs ++ ["    global.set $" ++ gname name]
emitRefValInit _ _ = gapL "value binding must be a nullary clause"

-- main: compute the body (a (ref eq)), then unbox to i32 and route to the print
-- import by the body's STATIC kind (Int vs Bool — the only printable scalar mains
-- in this slice).  In ref-mode an Int/Bool result is an i31 immediate, so unbox via
-- `i31.get_s` / `i31.get_u`.
emitRefMain : Prog -> List CBind -> <Mut> List String
emitRefMain prog groups = match findMain groups
  Some body =>
    let instrs = emitRefExpr prog [] 0 body
    -- C4: if the typecheck Float hint is set, override the structural refMainKind
    -- (which defaults to WInt on type-erased polymorphic-HOF returns) so bare Float
    -- value mains (e.g. `main = fold (acc x => acc + x) 0.0 [1.0, 2.0, 3.0]`)
    -- auto-print via the Float formatter instead of reinterpreting bits as an Int.
    let k = if mainBodyIsUnit prog body then WUnit
            else if mainIsFloatHintRef.value then WFloat
            else refMainKind prog body
    -- a Unit main (a `putStrLn …` etc.) has already produced its IO effect; drop its
    -- i31-0 result and auto-print NOTHING (the "Unit main no auto-print" contract).
    match k
      WUnit => indent instrs ++ ["    drop"]
      _ => indent instrs ++ refPrintFor k
  None => gapL "no `main` binding"

-- W9b: a value main whose head function DECLARES a Unit return (`println : … -> <IO>
-- Unit`, `print`, any user/prelude Unit-returning wrapper) is a Unit main and must
-- NOT auto-print its result — the structural `refMainKind` can't see through the
-- wrapper, so it would route the Unit result to the Int printer (a trailing `0`).
-- Reads the installed declared-return-type table; empty ⇒ "" ⇒ False (unchanged).
mainBodyIsUnit : Prog -> CExpr -> <Mut> Bool
mainBodyIsUnit prog (CApp f _) = match appHead f
  CVar fn _ => declRetTypeOf fn == "Unit"
  -- `println`/`print` are `Display a =>` constrained → the dict-pass rewrites the
  -- head to a CDict (or CMethod) carrying the routes; recover the bare name.
  CDict fn _ => declRetTypeOf fn == "Unit"
  CMethod fn _ _ _ => declRetTypeOf fn == "Unit"
  _ => False
mainBodyIsUnit prog (CVar fn _) = declRetTypeOf fn == "Unit"
mainBodyIsUnit prog (CDict fn _) = declRetTypeOf fn == "Unit"
mainBodyIsUnit prog (CMethod fn _ _ _) = declRetTypeOf fn == "Unit"
mainBodyIsUnit prog (CLet _ _ _ b) = mainBodyIsUnit prog b
-- the native branch-(2) equivalent: an UNANNOTATED `main = match … { … }` whose
-- Unit-ness is only knowable from its inferred body type (e.g. check_main's
-- `match args () { [r,c,f] => withFiles … ; _ => ePutStrLn … }`).  Type-erased here,
-- so reason structurally: a match/decision body is Unit iff EVERY tail leaf is Unit
-- (an IO-extern returning Unit, a fn whose declared ret is Unit, or another all-Unit
-- match).  Conservative — a single non-Unit leaf ⇒ False, so a value main is never
-- suppressed.  Block/Let tails recurse to their final expr.
mainBodyIsUnit prog (CDecision _ arms _) = allArmsUnit prog arms
mainBodyIsUnit prog (CMatch _ arms) = allArmsUnit prog arms
mainBodyIsUnit prog (CBlock stmts) = blockTailIsUnit prog stmts
mainBodyIsUnit prog _ = False

-- True iff every match/decision arm body is itself a Unit main body.  Empty ⇒ False
-- (no leaves to prove Unit ⇒ don't suppress).
allArmsUnit : Prog -> List CArm -> <Mut> Bool
allArmsUnit _ [] = False
allArmsUnit prog arms = allArmsUnitGo prog arms

allArmsUnitGo : Prog -> List CArm -> <Mut> Bool
allArmsUnitGo _ [] = True
allArmsUnitGo prog ((CArm _ _ body)::rest) =
  if mainBodyIsUnit prog body then
    allArmsUnitGo prog rest
  else
    False

blockTailIsUnit : Prog -> List CStmt -> <Mut> Bool
blockTailIsUnit _ [] = False
blockTailIsUnit prog [CSExpr e] = mainBodyIsUnit prog e
blockTailIsUnit prog (_::rest) = blockTailIsUnit prog rest

-- the printable static kind of a ref-mode main body: an Int (decimal) or a Bool
-- (true/false).  Determined structurally — arithmetic/Int-lit → Int; a comparison
-- / Bool-lit / `!` → Bool.  A match's kind is its first arm's body kind.
isWBool : WTy -> Bool
isWBool WBool = True
isWBool _ = False

-- a CIf main's kind: WBool if either branch is conclusively Bool, else the then kind.
ifKind : Prog -> CExpr -> CExpr -> WTy
ifKind prog t f =
  if isWBool (refMainKind prog t) then
    WBool
  else if isWBool (refMainKind prog f) then
    WBool
  else
    refMainKind prog t

refMainKind : Prog -> CExpr -> WTy
refMainKind prog (CLit (LInt _)) = WInt
refMainKind prog (CLit (LBool _)) = WBool
refMainKind prog (CLit (LString _)) = WStr
refMainKind prog (CLit (LChar _)) = WChar
-- W8b: a Float literal main auto-prints via %.12g (floatToString).
refMainKind prog (CLit (LFloat _)) = WFloat
-- the Bool constructors as values (a dispatched main `… else False`); also lets a
-- CIf whose arms are dispatch calls recover Bool-ness from a literal-Bool branch.
refMainKind prog (CVar "True" _) = WBool
refMainKind prog (CVar "False" _) = WBool
-- W8b: pi/e are Float values.
refMainKind prog (CVar "pi" _) = WFloat
refMainKind prog (CVar "e" _) = WFloat
-- W8b: a Float arith binop (recovered structurally) auto-prints as a Float; otherwise
-- the op's kind (arith→Int, compare→Bool, ++→Str).
refMainKind prog (CBinPrim op l r _) =
  if isArithOp op && (cexprIsFloat prog [] l || cexprIsFloat prog [] r) then
    WFloat
  else
    binOpTy op
refMainKind prog (CUnOp "!" _) = WBool
refMainKind prog (CUnOp "-" x) = if cexprIsFloat prog [] x then WFloat else WInt
refMainKind prog (CUnOp _ _) = WInt
-- a CIf main: prefer whichever branch is conclusively Bool (a comparison / Bool
-- ctor / `!`), else fall back to the then branch.  A W5 dispatch fixture often has
-- `if <Bool-cond> then <method-call : Bool> else False` — the else pins it Bool.
refMainKind prog (CIf _ t f) = ifKind prog t f
refMainKind prog (CLet _ _ _ b) = refMainKind prog b
refMainKind prog (CBlock stmts) = refMainKindBlock prog stmts
refMainKind prog (CDecision _ arms _) = refMainKindArms prog arms
refMainKind prog (CMatch _ arms) = refMainKindArms prog arms
-- a String-returning extern applied to its args (intToString/charToStr/stringConcat).
refMainKind prog (CApp f a) = match appHead f
  CVar fn _ =>
    if isStrReturningExtern fn then WStr
    else if contains fn ["randomBool", "charIsAlpha", "charIsSpace", "charIsUpper",
                         "charIsLower", "charIsPunct"] then WBool
    else if contains fn ["randomChar", "charToUpper", "charToLower"] then WChar
    -- W8b: a Float-returning extern main (intToFloat/randomFloat) auto-prints as Float.
    else if contains fn ["intToFloat", "randomFloat"] then WFloat
    -- W-SQLITE-4: a call to a user fn whose declared sig returns Float (`main = f 2.5`).
    else if fnReturnsFloat fn then WFloat
    else if isUnitExtern fn then WUnit
    -- composite-autoprint parity: a bare `main = myeq a b` calls a dispatched
    -- interface method whose Bool result is type-erased at this CApp (→ WInt →
    -- prints the raw i31 "1").  Native's `println`/`display` wrap renders the Bool
    -- ctor as `True`/`False`, so recover Bool-ness structurally from the method's
    -- lowered impl bodies (all conclusively Bool ⇒ WBool → $mdk_print_bool).
    else if methodReturnsBoolW prog fn then WBool
    else refMainKind prog (appHead f)
  -- a resolved dispatch head (`main = myeq a b` lowers to CApp (CMethod/CDict …) …):
  -- same composite-autoprint Bool recovery as the CVar method case above.
  CMethod fn _ _ _ => if methodReturnsBoolW prog fn then WBool else WInt
  CDict fn _ => if methodReturnsBoolW prog fn then WBool else WInt
  h => refMainKind prog h
-- W-SQLITE-4: a nullary Float-typed binding used as a value main (`main = h`, `h : Float`).
refMainKind prog (CVar x _) = if fnReturnsFloat x then WFloat else WInt
refMainKind prog other = WInt

-- True iff EVERY lowered impl clause of dispatched method `fn` conclusively renders
-- Bool (its body's structural refMainKind is WBool).  Used to recover Bool-ness for a
-- type-erased `main = <method> a b` value-main so its auto-print matches native's
-- `println`/`display` (`True`/`False`).  Conservative: no impls (not a method) or any
-- non-Bool clause ⇒ False, so the caller keeps the existing WInt fallback.
methodReturnsBoolW : Prog -> String -> Bool
methodReturnsBoolW prog fn = match implBodiesForW fn (progImpls prog)
  [] => False
  bodies => allWBoolW prog bodies

implBodiesForW : String -> List CImplEntry -> List CExpr
implBodiesForW _ [] = []
implBodiesForW fn ((CImplEntry name _ body)::rest) =
  if name == fn then
    implBodyExprW body :: implBodiesForW fn rest
  else
    implBodiesForW fn rest

implBodyExprW : CImplBody -> CExpr
implBodyExprW (CImplTagged _ _ _ _ _ e) = e
implBodyExprW (CImplDefault _ e) = e

allWBoolW : Prog -> List CExpr -> Bool
allWBoolW _ [] = True
allWBoolW prog (e::rest) = isWBool (refMainKind prog e) && allWBoolW prog rest

-- the String-RESULT externs (drive value-main String auto-print).  `stringLength`
-- returns Int, so it is NOT here.
isStrReturningExtern : String -> Bool
isStrReturningExtern name = contains name [
  "intToString", "charToStr", "stringConcat",
  "stringSlice", "stringToUpper", "stringToLower",
  -- W8b: floatToString returns a String.
  "floatToString",
  -- W11b: stringFromChars : Array Char -> String.
  "stringFromChars",
  -- W11b: stringFromUtf8Bytes : Array Int -> String.
  "stringFromUtf8Bytes"]

-- the Unit-RESULT IO externs: a `main = putStrLn …` produces Unit and must NOT be
-- auto-printed (the "Unit main no auto-print" contract — the native oracle prints
-- nothing for a Unit main; the IO side effect IS the output).
isUnitExtern : String -> Bool
-- Intentional cross-file duplicate of the same helper in llvm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
isUnitExtern name =
  contains name ["putStr", "putStrLn", "ePutStr", "ePutStrLn", "flushStdout"]

refMainKindBlock : Prog -> List CStmt -> WTy
refMainKindBlock _ [] = WInt
refMainKindBlock prog [CSExpr e] = refMainKind prog e
refMainKindBlock prog (_::rest) = refMainKindBlock prog rest

refMainKindArms : Prog -> List CArm -> WTy
refMainKindArms _ [] = WInt
refMainKindArms prog ((CArm _ _ body)::_) = refMainKind prog body

appHead : CExpr -> CExpr
appHead (CApp f _) = appHead f
appHead e = e

refPrintFor : WTy -> <Mut> List String
refPrintFor WInt = ["    call $mdk_unbox_int", "    call $mdk_print_int"]
refPrintFor WBool =
  ["    ref.cast (ref i31)", "    i31.get_u", "    call $mdk_print_bool"]
refPrintFor WStr = ["    ref.cast (ref $str)", "    call $mdk_print_strln"]
-- a Char main: an i31 codepoint → encode to a $str via $mdk_char_to_str → print + '\n'
-- (matches the oracle's pp_value, which renders a Char as its glyph).  Forces the
-- $str rep + the char-encode strLeaf runtime (see noteW8MainChar).
refPrintFor WChar = [
  "    ref.cast (ref i31)",
  "    i31.get_u",
  "    call $mdk_char_to_str",
  "    call $mdk_print_strln",
]
-- W8b: a Float main → unbox the $float → %.12g format ($mdk_float_to_str builds a $str)
-- → print + '\n' (matches the oracle's mdk_print_float, the same %.12g + .0 rule).
refPrintFor WFloat = [
  "    ref.cast (ref $float)",
  "    struct.get $float 0",
  "    call $mdk_float_to_str",
  "    call $mdk_print_strln",
]
refPrintFor WUnit = gapL "ref-mode: Unit main has no value to print"
refPrintFor WRef =
  gapL
    "ref-mode main produced a non-scalar value — printing ADTs is W6b (Debug)"

-- ── ref-mode top-level function defs ─────────────────────────────────────────
-- Every param/local/result is `(ref eq)`.  Three shapes:
--   * single clause, all-PVar params → the fast path: bind params, TAIL-emit the
--     body (self-recursion + general tail calls become return_call/return_call_ref).
--   * single clause with a non-PVar (literal/ctor) param, OR multiple clauses →
--     coalesce into a synthetic-parameter dispatch: each clause becomes a guarded
--     block testing its non-PVar params, binding its PVar params, then tail-emitting
--     its body; clauses fall through in order (W4 clause-dispatch coalescing,
--     peer to llvm_emit's emitClauseTree).
-- After the body, if `name` is used anywhere as a VALUE (passed/returned/partially
-- applied), also emit a closure wrapper `$name__clos` (a $clos with arity = param
-- count, code = a thunk that unpacks the args array + calls $name).
emitRefFnBind : Prog -> CBind -> <Mut> List String
emitRefFnBind prog (CBind name clauses0) =
  let _ = setRef curBindRef name
  -- W9b: a single-clause point-free constrained fn (`elem a = fold g False`) whose
  -- body is an under-applied CMethod gets eta-saturated to the method's full arity
  -- so the emitted dispatch call pushes every operand (else a validate underflow).
  let clauses = map etaSaturateFnClause clauses0
  -- W-SQLITE-4: seed (and reset) floatLocalsRef with this fn's declared Float
  -- params before emitting its body, so type-erased Float arith on a param lowers
  -- to f64 ops (mirrors emitImplGroup's `impl … Float` seeding, generalized).
  let _ = setRef floatLocalsRef (floatParamNames name clauses)
  -- A1 (poly-`Num`-on-Float): seed the polymorphic-`Num`/`Ord` param names so this fn's
  -- bare-CVar arithmetic on a type-var param routes to the runtime value-dispatch helper
  -- (mirrors floatLocalsRef, and native's LTNum seed).  [] resets for monomorphic fns.
  let _ = setRef numPolyLocalsRef (numPolyParamNames name clauses)
  let arity = clauseArityOf clauses
  let params = synthParams arity
  -- Stage-2/3 (b′): a member of a detected dispatch-TMC group emits via the dest-passing
  -- reset-wrapper (root) / inner-loop or redirected-leaf member path.  The group takes
  -- PRECEDENCE over Stage-1: a group root like the lexer's `layout` is Stage-1-eligible
  -- for its SELF-cons arm, but only the group transform linearizes the cross-member
  -- edges (`layout ↔ flushCloseGo ↔ …`) — and a Stage-1-emitted member inside a group
  -- would return its own locally-built spine instead of closing the group's shared dest
  -- globals (a miscompile).  Detection keeps a Stage-1-claimable SINGLETON out of any
  -- group (wDispValidate v5), so plain self-TMC fns still take the Stage-1 loop below.
  match wDispGroupOf wDispGroupsRef.value name
    Some grp =>
      let gd = if wDispIsRoot grp name then emitWDispRoot prog grp arity clauses
        else emitWDispMemberFn prog grp name name arity clauses
      gd ++ (if needsClosWrapper prog name then emitFnClosWrapper prog name arity else [])
    None =>
      -- Stage 1 (WASMGC-TRMC-DESIGN §7): a top-level NON-DICT self-recursive define whose
      -- clauses are `trmcEligible` for the self-only cons/ctor-tail shape (a) is emitted as
      -- a destination-passing LOOP (emitWasmTrmcBind) instead of the stack-growing recursive
      -- call (emitRefTail's generic ctor arm evaluates the self-call as a struct.new ARG, so
      -- the frame stays live → deep lists overflow).  Ineligible fns fall to the normal path.
      match wasmTrmcTry prog name arity clauses
        Some tmcDef => tmcDef ++ (if needsClosWrapper prog name then emitFnClosWrapper prog name arity else [])
        None =>
          let bodyLines = emitClausesRef prog name params arity clauses
          let allLocals = clauseLocals clauses
          let extraLocals = filterList (notIn params) (dedupKeep allLocals)
          let scratch = scratchLocals (clausesMaxDepth clauses)
          let sig = "  (func $\{gname name}\{joinWith "" (map paramDeclRef params)} (result (ref eq))"
          let localDecls = map localDeclRef (extraLocals ++ scratch)
          let w7Decls = w7LocalDecls (clausesMaxDepth clauses)
          let fnDef = [sig] ++ map ("  " ++ _) (localDecls ++ w7Decls) ++ indent bodyLines ++ ["  )"]
          let wrapper = if needsClosWrapper prog name then emitFnClosWrapper prog name arity else []
          fnDef ++ wrapper

-- a fn's arity (all clauses agree).
clauseArityOf : List CClause -> Int
clauseArityOf ((CClause pats _)::_) = listLen pats
clauseArityOf [] = 0

-- synthetic positional parameter names `$__wparg0 $__wparg1 …` (used for multi-clause
-- dispatch and as the uniform fn ABI param names).  The `__wparg` prefix is RESERVED:
-- a source pattern variable in a clause head (e.g. `unifyN (TFun a1 r1 b1) (TFun a2 r2
-- b2)` binds `a1`) must NOT collide with a sibling positional param's wasm local, or
-- its `local.set` clobbers a not-yet-read argument and a later field extract `ref.cast`
-- traps `illegal cast` (layer-11 bug: the second `TFun`'s value was destroyed by the
-- first clause head binding a var literally named `a1` into `$a1`).  Earlier these were
-- `$a0/$a1/…`, which a user var named `a1` aliased directly.  `gname` escapes any user
-- identifier spelled `__wparg<digits>` (mirrors the `self`/`args` reserved-name escape),
-- so the positional params are provably distinct from every clause-bound source var.
synthParams : Int -> List String
synthParams n = map (i => "__wparg" ++ intToString i) (rangeList 0 n)

-- emit the clause chain.  Single all-PVar clause: rename its params to the synthetic
-- positions (so the body env binds them) and tail-emit.  Otherwise: a fallthrough
-- chain of guarded blocks.
emitClausesRef : Prog -> String -> List String -> Int -> List CClause -> <Mut> List String
emitClausesRef prog name params arity clauses =
  emitClausesRefEnv prog [] name params arity clauses

-- W9: env-seeded clause emission — `baseEnv` names (a CLetGroup's sibling closures +
-- captured outer vars, bound as locals before the body) are in scope in every clause
-- body in addition to the clause's own param bindings.  The non-letgroup path passes
-- baseEnv=[] (emitClausesRef).
emitClausesRefEnv : Prog -> List String -> String -> List String -> Int -> List CClause -> <Mut> List String
-- the single-clause fast path skips the clause BLOCK (plain params need no test).
-- But a guard chain in the body desugars to `__fallthrough__`, which needs a block
-- to `br` to — so when the body contains one, fall back to the chain path (its
-- block wrapper + trailing `unreachable` give the fall-through a target).
emitClausesRefEnv prog baseEnv name params arity (clauses@[CClause pats body]) =
  if allPlainParams pats && not (exprHasFallthrough body) then
    let aliases = bindParamAliases pats params
    let env = map patName pats ++ baseEnv
    aliases ++ emitRefTail prog env arity body
  else emitClauseChainRefEnv prog baseEnv name params arity clauses
emitClausesRefEnv prog baseEnv name params arity clauses =
  emitClauseChainRefEnv prog baseEnv name params arity clauses

-- does this expression contain a `__fallthrough__` occurrence (bare CVar or the
-- desugared `__fallthrough__ ()` CApp)?  A single-clause body with one needs a clause
-- block to branch to; without one the fast path (no block) is safe.  Only descends
-- the constructs a guard chain produces (CIf / CDecision arms / CLet / CBlock); a
-- `__fallthrough__` never appears under a CLam (closures own their own clause scope).
exprHasFallthrough : CExpr -> Bool
exprHasFallthrough (CVar x _) = x == "__fallthrough__"
exprHasFallthrough (CApp f a) = exprHasFallthrough f || exprHasFallthrough a
exprHasFallthrough (CIf c t f) = exprHasFallthrough c
  || exprHasFallthrough t
  || exprHasFallthrough f
exprHasFallthrough (CLet _ _ e1 e2) = exprHasFallthrough e1
  || exprHasFallthrough e2
exprHasFallthrough (CLetGroup _ body) = exprHasFallthrough body
exprHasFallthrough (CBlock stmts) = anyList stmtHasFallthrough stmts
exprHasFallthrough (CDecision scrut arms _) = exprHasFallthrough scrut
  || anyList (a => exprHasFallthrough (armBody a)) arms
exprHasFallthrough _ = False

stmtHasFallthrough : CStmt -> Bool
stmtHasFallthrough (CSExpr e) = exprHasFallthrough e
stmtHasFallthrough (CSLet _ _ e) = exprHasFallthrough e
-- a refutable `let pat = e else els`: a `__fallthrough__` can hide in either the
-- scrutinee or the else alternative (both are ordinary exprs), so descend both.
stmtHasFallthrough (CSLetElse _ e els) = exprHasFallthrough e
  || exprHasFallthrough els
stmtHasFallthrough (CSAssign _ e) = exprHasFallthrough e

-- when the single clause's params are plain PVars, alias each to the synthetic
-- positional wasm param ($a<i>): `local.get $a<i>; local.set $<srcname>`.  (The
-- source names are declared as locals via clauseLocals.)
bindParamAliases : List Pat -> List String -> <Mut> List String
bindParamAliases pats params = flatMap aliasOne (zipPats pats params)

aliasOne : (Pat, String) -> <Mut> List String
aliasOne (PVar x, a) = ["local.get $" ++ gname a, "local.set $" ++ gname x]
aliasOne (PWild, _) = []
aliasOne _ = gapL "ref-mode: non-plain param in fast-path alias"

zipPats : List Pat -> List String -> List (Pat, String)
zipPats (p::ps) (a::bs) = (p, a) :: zipPats ps bs
zipPats _ _ = []

allPlainParams : List Pat -> Bool
allPlainParams pats = not (anyList (p => not (isPlainParam p)) pats)

-- the fallthrough clause chain.  Each clause: a block `$cl<i>` that tests its
-- non-PVar params (literal/ctor) against the synthetic positions, binds its PVar
-- params, and on full match TAIL-emits its body; a failed test `br $cl<i>` falls
-- through to the next clause.  The last clause's failure is `unreachable` (a
-- well-typed exhaustive fn won't reach it).
emitClauseChainRefEnv : Prog -> List String -> String -> List String -> Int -> List CClause -> <Mut> List String
emitClauseChainRefEnv prog baseEnv name params arity clauses =
  emitClauseChainGo prog baseEnv name params arity clauses 0

emitClauseChainGo : Prog -> List String -> String -> List String -> Int -> List CClause -> Int -> <Mut> List String
-- B5: the last clause fell through (non-exhaustive function) → coded trap.
emitClauseChainGo _ _ _ _ _ [] _ =
  wasmTrap "E-NONEXHAUSTIVE-MATCH" "non-exhaustive match"
emitClauseChainGo prog baseEnv name params arity ((CClause pats body)::rest) i =
  let clLabel = "$cl_\{name}_\{intToString i}"
  let (tests, binds, env) = clausePatCodeEnv prog baseEnv pats params clLabel
  -- A guard chain inside this clause's body desugars to `__fallthrough__` (the
  -- "no arm matched, try the next clause" sentinel).  We REWRITE each such occurrence
  -- in the body to a label-carrying sentinel `__ft__<clLabel>` BEFORE emitting, so the
  -- emitter lowers it to `br <clLabel>` as a PURE function of the var name.  (A mutable
  -- "current label" ref does NOT work here: this emitter builds the instruction list
  -- lazily and forces the strings at final assembly, long after any setRef/restore —
  -- so the read would see a stale/default label.  Encoding the target in the node is
  -- timing-independent.)  `br <clLabel>` exits this clause's block, landing on the next
  -- clause (or the chain's trailing `unreachable` for the last clause).
  let body2 = labelFallthrough body clLabel
  ["block " ++ clLabel]
    ++ indent (tests ++ binds ++ emitRefTail prog env arity body2)
    ++ ["end"]
    ++ emitClauseChainGo prog baseEnv name params arity rest (i + 1)

-- the prefix marking a fall-through sentinel CVar that carries its target block label:
-- `__ft__$cl_foo_0` → `br $cl_foo_0`.  Produced by labelFallthrough, consumed by
-- emitVarRef / emitAppRef / emitAppTail / emitRefTail.
ftPrefix : String
ftPrefix = "__ft__"

-- rewrite every `__fallthrough__` occurrence in a clause body to the label-carrying
-- sentinel `__ft__<label>`, so it lowers to `br <label>`.  Descends only the
-- constructs a guard chain produces (CIf / CLet / CBlock / CApp / CDecision arms);
-- does NOT enter a CLam (a closure owns its own clause scope and never contains a bare
-- fall-through for THIS clause).
labelFallthrough : CExpr -> String -> CExpr
labelFallthrough (e@(CVar x r)) label =
  if x == "__fallthrough__" then
    CVar (ftPrefix ++ label) r
  else
    e
labelFallthrough (CApp f a) label =
  CApp (labelFallthrough f label) (labelFallthrough a label)
labelFallthrough (CIf c t f) label =
  CIf
    (labelFallthrough c label)
    (labelFallthrough t label)
    (labelFallthrough f label)
labelFallthrough (CLet rf p e1 e2) label =
  CLet rf p (labelFallthrough e1 label) (labelFallthrough e2 label)
labelFallthrough (CLetGroup binds b) label =
  CLetGroup binds (labelFallthrough b label)
labelFallthrough (CBlock stmts) label =
  CBlock (map (s => labelFallthroughStmt s label) stmts)
labelFallthrough (CDecision scrut arms tree) label = CDecision
  (labelFallthrough scrut label)
  (map (a => labelFallthroughArm a label) arms)
  tree
labelFallthrough e label = e

labelFallthroughStmt : CStmt -> String -> CStmt
labelFallthroughStmt (CSExpr e) label = CSExpr (labelFallthrough e label)
labelFallthroughStmt (CSLet rf p e) label =
  CSLet rf p (labelFallthrough e label)

labelFallthroughArm : CArm -> String -> CArm
labelFallthroughArm (CArm p gs b) label = CArm
  p
  (map (g => labelFallthroughGuard g label) gs)
  (labelFallthrough b label)

labelFallthroughGuard : CGuard -> String -> CGuard
labelFallthroughGuard (CGBool e) label = CGBool (labelFallthrough e label)
labelFallthroughGuard (CGBind p e) label = CGBind p (labelFallthrough e label)

-- generate (tests, binds, env) for a clause's parameter patterns against the
-- synthetic positional params.  A `br clLabel` on a failed test falls to the next
-- clause.  PLit param → compare the i31 against the constant.  PCon param → test
-- the discriminant + bind fields.  PVar → bind to a local.  PWild → nothing.
clausePatCodeEnv : Prog -> List String -> List Pat -> List String -> String -> <Mut> (List String, List String, List String)
clausePatCodeEnv prog baseEnv pats params clLabel =
  clausePatGo prog (zipPats pats params) clLabel [] [] baseEnv

clausePatGo : Prog -> List (Pat, String) -> String -> List String -> List String -> List String -> <Mut> (List String, List String, List String)
clausePatGo _ [] _ tAcc bAcc env = (tAcc, bAcc, env)
clausePatGo prog ((pat, a)::rest) clLabel tAcc bAcc env =
  let occ = ["local.get $" ++ gname a]
  let (t, b, env2) = patTestBind prog pat occ clLabel env
  clausePatGo prog rest clLabel (tAcc ++ t) (bAcc ++ b) env2

-- (tests, binds, env') for matching `pat` against the value snippet `occ`.
patTestBind : Prog -> Pat -> List String -> String -> List String -> <Mut> (List String, List String, List String)
patTestBind prog PWild occ clLabel env = ([], [], env)
patTestBind prog (PVar x) occ clLabel env =
  ([], occ ++ ["local.set $" ++ gname x], x::env)
patTestBind prog (PLit (LInt n)) occ clLabel env = (
  occ ++ [
    "ref.cast (ref i31)",
    "i31.get_s",
    "i32.const " ++ intToString n,
    "i32.ne",
    "br_if " ++ clLabel,
  ],
  [],
  env,
)
patTestBind prog (PLit (LBool b)) occ clLabel env = (
  occ ++ [
    "ref.cast (ref i31)",
    "i31.get_u",
    "i32.const " ++ (if b then "1" else "0"),
    "i32.ne",
    "br_if " ++ clLabel,
  ],
  [],
  env,
)
-- W9: a `()` (Unit) clause head — Unit is the i31 0 immediate, irrefutable here
-- (the type guarantees the value is Unit), so no test and no binding.
patTestBind prog (PLit LUnit) occ clLabel env = ([], [], env)
-- W9: a Char-literal clause head — a Char is an i31 codepoint immediate (same rep
-- as emitLitRef (LChar)); compare the i31 against the codepoint constant.
patTestBind prog (PLit (LChar c)) occ clLabel env = (
  occ ++ [
    "ref.cast (ref i31)",
    "i31.get_u",
    "i32.const " ++ intToString (charCode (arrayGetUnsafe 0 (stringToChars c))),
    "i32.ne",
    "br_if " ++ clLabel,
  ],
  [],
  env,
)
patTestBind prog (PLit (LString s)) occ clLabel env =
  let cmpSuffix = [
    "call $mdk_str_compare",
    "ref.cast (ref i31)",
    "i31.get_u",
    "i32.const 1",
    "i32.ne",
    "br_if " ++ clLabel,
  ]
  let _ = setRef useStrSearchRef True
  let _ = setRef useStrLeafRef True
  let _ = setRef useStrRef True
  (
    occ ++ ["ref.cast (ref $str)"] ++ emitLitRef (LString s) ++ cmpSuffix,
    [],
    env,
  )
-- W10: a constructor clause head — test the discriminant, then descend into each
-- field with patTestBind (NOT bindConFields).  A nested field pattern can itself be
-- refutable (e.g. `Variant cname (ConNamed fs)` — the inner `ConNamed` discriminates
-- against a sibling `ConPos` of the same payload type), so the field must emit its own
-- discriminant test, else its struct cast runs unconditionally and traps `illegal
-- cast` on the sibling shape.  bindConFields only binds (no tests), so it is unsound
-- for refutable nested ctors — mirror PCons/PTuple/PList, which recurse via patTestBind.
patTestBind prog (PCon c args) occ clLabel env =
  let ctest = discrimReadOf occ (ctorTypeName prog c) ++ [
    "i32.const " ++ intToString (ctorOrdinal prog c),
    "i32.ne",
    "br_if " ++ clLabel,
  ]
  let (ft, fb, env2) = patTestBindCon prog c args occ clLabel env 0
  (ctest ++ ft, fb, env2)
patTestBind prog (PAs x p) occ clLabel env =
  let setX = occ ++ ["local.set $" ++ gname x]
  let (t, b, env2) = patTestBind prog p occ clLabel (x::env)
  (t, setX ++ b, env2)
-- W9: a refutable cons-cell clause head `(h :: t)` — the focus must be a Cons
-- (ordinal 0; Nil is ordinal 1), else fall to the next clause.  Then test+bind
-- the head (field 1) and tail (field 2) recursively (nested patterns may also be
-- refutable, e.g. `[x] = (x :: [])`).
patTestBind prog (PCons h t) occ clLabel env =
  let consTest = discrimReadOf occ "List" ++ ["i32.const 0", "i32.ne", "br_if " ++ clLabel]
  let hSnip = occ ++ ["ref.cast (ref $C_Cons)", "struct.get $C_Cons 1"]
  let tSnip = occ ++ ["ref.cast (ref $C_Cons)", "struct.get $C_Cons 2"]
  let (ht, hb, env2) = patTestBind prog h hSnip clLabel env
  let (tt, tb, env3) = patTestBind prog t tSnip clLabel env2
  (consTest ++ ht ++ tt, hb ++ tb, env3)
-- W9: a refutable fixed-length list clause head `[p0, p1, …]` — descend the Cons
-- spine: each element's cell must be a Cons (else fall through), then the final
-- tail must be Nil (ordinal 1).
patTestBind prog (PList ps) occ clLabel env =
  patTestBindList prog ps occ clLabel env
-- W9: a tuple clause head `(p0, p1, …)` — a tuple is single-shape (irrefutable),
-- so no test; bind each field (field i+1 of $C_Tup<n>) and recurse for nested
-- refutable subpatterns.
patTestBind prog (PTuple ps) occ clLabel env =
  patTestBindTuple prog (tupleCtorName (listLen ps)) ps occ clLabel env 0
patTestBind prog other occ clLabel env =
  gapL3 ("ref-mode: unsupported clause parameter pattern " ++ ptag other)

-- (tests, binds, env') for a refutable fixed-length list clause head against `occ`.
-- Each element requires its cell be a Cons; the spine end requires Nil.
patTestBindList : Prog -> List Pat -> List String -> String -> List String -> <Mut> (List String, List String, List String)
patTestBindList _ [] occ clLabel env = (
  discrimReadOf occ "List" ++ ["i32.const 1", "i32.ne", "br_if " ++ clLabel],
  [],
  env,
)
patTestBindList prog (p::ps) occ clLabel env =
  let consTest = discrimReadOf occ "List" ++ ["i32.const 0", "i32.ne", "br_if " ++ clLabel]
  let hSnip = occ ++ ["ref.cast (ref $C_Cons)", "struct.get $C_Cons 1"]
  let tSnip = occ ++ ["ref.cast (ref $C_Cons)", "struct.get $C_Cons 2"]
  let (ht, hb, env2) = patTestBind prog p hSnip clLabel env
  let (tt, tb, env3) = patTestBindList prog ps tSnip clLabel env2
  (consTest ++ ht ++ tt, hb ++ tb, env3)

-- (tests, binds, env') for a tuple clause head: each field i+1 of $C_Tup<n> (after
-- the i32 tag), recursing into the sub-pattern (which may itself be refutable).
patTestBindTuple : Prog -> String -> List Pat -> List String -> String -> List String -> Int -> <Mut> (List String, List String, List String)
patTestBindTuple _ _ [] _ _ env _ = ([], [], env)
patTestBindTuple prog tc (p::rest) occ clLabel env i =
  let fieldSnip = occ ++ [
    "ref.cast (ref $" ++ ctorStructName tc ++ ")",
    "struct.get $\{ctorStructName tc} \{intToString (i + 1)}",
  ]
  let (ft, fb, env2) = patTestBind prog p fieldSnip clLabel env
  let (rt, rb, env3) = patTestBindTuple prog tc rest occ clLabel env2 (i + 1)
  (ft ++ rt, fb ++ rb, env3)

-- (tests, binds, env') for a constructor clause head's fields: field i+1 of the ctor's
-- struct (after the i32 tag), recursing into each sub-pattern with patTestBind so a
-- refutable nested ctor (`ConNamed fs`) emits its own discriminant test+bind.
patTestBindCon : Prog -> String -> List Pat -> List String -> String -> List String -> Int -> <Mut> (List String, List String, List String)
patTestBindCon _ _ [] _ _ env _ = ([], [], env)
patTestBindCon prog c (p::rest) occ clLabel env i =
  let fieldSnip = occ ++ [
    "ref.cast (ref $" ++ ctorStructName c ++ ")",
    "struct.get $\{ctorStructName c} \{intToString (i + 1)}",
  ]
  let (ft, fb, env2) = patTestBind prog p fieldSnip clLabel env
  let (rt, rb, env3) = patTestBindCon prog c rest occ clLabel env2 (i + 1)
  (ft ++ rt, fb ++ rb, env3)

-- all locals a clause group needs: every clause's param-bound vars + body locals.
clauseLocals : List CClause -> List String
clauseLocals clauses = flatMap oneClauseLocals clauses

oneClauseLocals : CClause -> List String
oneClauseLocals (CClause pats body) = flatMap patVars pats
  ++ collectExprLocals body

clausesMaxDepth : List CClause -> Int
clausesMaxDepth clauses = foldMaxDepth (flatMap clauseBody clauses)

-- whether a top-level fn must get a closure wrapper: it is referenced as a VALUE
-- anywhere in the program (bare CVar in non-call position, or partially applied).
-- Conservative + cheap: scan if the name occurs in any value position.  We compute
-- this lazily per fn (the program is small); the fnNeedsValue scan is in `Prog`-free
-- form so it can run here.  For this slice we wrap EVERY top-level fn lazily only
-- when noted via noteFuncRef during emission — but a value-ref to a fn that's never
-- emitted-as-value wouldn't note it.  So instead: wrap a fn iff its name appears as
-- a value-ref somewhere (detected by the same exprUsesClosures value-position rule).
needsClosWrapper : Prog -> String -> Bool
needsClosWrapper prog name = contains name fnsUsedAsValuesRef.value

-- a module-level set of top-level fn names used as values, populated during body
-- emission (emitVarRef / emitAppRef note a fn-as-value here).  Because fns are
-- emitted before the wrapper-decision, and emitRefProgram forces all bodies first,
-- this set is complete by the time wrappers are appended… EXCEPT a fn defined after
-- its value-use is still emitted in order.  To be safe we PRE-SCAN the program for
-- fn-value uses up front in emitProgram and seed this set.
fnsUsedAsValuesRef : Ref (List String)
fnsUsedAsValuesRef = Ref []

-- the closure wrapper for a top-level fn: `$mdk_w_<name>` is a $codety that unpacks
-- the args array and calls $name; `$name__clos` is built by `mkFnClos` at each value
-- ref.  Here we emit only the wrapper CODE function; the $clos struct is built inline
-- at the value-reference site (emitVarRef) so partial application threads its arity.
emitFnClosWrapper : Prog -> String -> Int -> <Mut> List String
emitFnClosWrapper prog name arity =
  let _ = noteFuncRef ("$mdk_w_" ++ name)
  let argLoads = flatMap (i => [
    "local.get $args",
    "i32.const " ++ intToString i,
    "array.get $argarr",
    "ref.as_non_null",
  ]) (rangeList 0 arity)
  [
      "  (func $mdk_w_" ++ name ++ " (type $codety) (param $self (ref eq)) (param $args (ref $argarr)) (result (ref eq))"
    ]
    ++ indent (argLoads ++ ["call $" ++ gname name])
    ++ ["  )"]

paramDeclRef : String -> String
paramDeclRef p = " (param $" ++ gname p ++ " (ref eq))"

localDeclRef : String -> <Mut> String
localDeclRef l = "(local $" ++ gname l ++ " (ref eq))"

-- ── §W5 typeclass dispatch (dict-passing) ────────────────────────────────────
-- Parallels the LLVM emitter (emitMethod/emitDictApp/dictWordsOf + emitImpls).
-- STAGE2-DESIGN §2.4c policy: dispatch is RUNTIME DICT-PASSING.  The Core IR
-- carries the resolved Routes as DATA on CMethod/CDict; this section reads them.
--
-- DICT-WITNESS REPRESENTATION (the WasmGC analogue of the LLVM i64 "dict word").
-- Every value here is a (ref eq).  A dict witness is an i31 immediate carrying
-- `hashName(impl-head-tag)` — the SAME djb2 hash the LLVM emitter stores at field
-- 0 of its dict cell.  Threading it as a (ref eq) i31 rides the uniform W4 ABI for
-- free: a constrained fn's leading `$dict_*` params are ordinary (ref eq) params,
-- and at a dispatch site the witness is unboxed (`i31.get_s`) back to the i32 tag
-- word.  For minimal Eq/Ord/Num at Int/Bool/ADT the per-instance `requires` dicts
-- are empty, so a one-level witness is just `i32.const <hashName tag>; ref.i31`
-- (no heap cell needed — the LLVM emitter's nested-cell layout is W5-out-of-scope).
--
--   RKey tag   → a STATIC direct call to $mdk_impl_<tag>_<method> (llvm_emit line
--                2846: an RKey is a compile-time direct call).
--   RDict d    → the in-scope dict param $d carries hashName(tag); unbox it and
--   RDictFwd d   if-chain over the method's candidate impls (i32.eq against each
--                impl's hashName(routeKey)) → call the matching impl.  Sparse hash
--                keys ⇒ an if-chain, NOT a br_table (which is for dense ctor tags).
--   RNone      → arg-tag fallback (gap this slice; no minimal fixture needs it).

-- the method occurrence (return-/arg-position), applied to `args`.  `implRoutes`
-- (per-instance requires) + `methRoutes` (method-level constraints) are the leading
-- dict witnesses, prepended to the args (in methRoutes++implRoutes order, matching
-- llvm_emit's dictWordsOf (methRoutes ++ implRoutes)).
emitMethodRef : Prog -> List String -> Int -> String -> Route -> List Route -> List Route -> List CExpr -> <Mut> List String
emitMethodRef prog env d name (RKey tag _) implRoutes methRoutes args =
  let dictWords = flatMap (routeWitness prog env d) (methRoutes ++ implRoutes)
  let argInstrs = flatMap (a => emitRefExpr prog env d a) args
  -- layer-15 (defaulted-method emission, peer to llvm_emit's emitMethod RKey arm,
  -- line ~2925): `RKey tag` selects a STATIC impl.  When the type provides a
  -- CONCRETE impl of [name] at [tag] (`implForW`), call `$mdk_impl_<tag>_<name>`
  -- directly (the original path).  But an INTERFACE DEFAULT method the type did NOT
  -- override (`filter` on `Filterable List`, which only impls `filterMap`) has NO
  -- tagged impl define — calling `$mdk_impl_List_filter` references a never-emitted
  -- symbol.  Mirror llvm_emit's `None => emitDefaultRKey`: synthesize a per-(method,
  -- tag) `$mdk_default_<name>_<tag>` define ONCE from the interface default body
  -- (inner same-iface calls restamped to this tag's concrete impl) and call THAT.
  match implForW prog name tag
    Some _ => dictWords ++ argInstrs ++ ["call $" ++ implFnSym tag name]
    None => emitDefaultRKeyRef prog dictWords argInstrs name tag
emitMethodRef prog env d name (RDict dpar) implRoutes methRoutes args =
  emitMethodDispatchRef prog env d name dpar args
emitMethodRef prog env d name (RDictFwd dpar) implRoutes methRoutes args =
  emitMethodDispatchRef prog env d name dpar args
emitMethodRef prog env d name RNone implRoutes methRoutes args =
  gapL ("wasm W5: RNone arg-tag dispatch for '" ++ name ++ "' is out of slice")

-- RDict/RDictFwd: the dict param `$dpar` is an i31 carrying hashName(tag).  Unbox
-- it, then if-chain over the method's candidate impls comparing the loaded tag
-- against each impl's hashName(routeKey); on a match call $mdk_impl_<symTag>_<m>.
-- The chain runs inside a result block; each arm `br`s out with its value.
emitMethodDispatchRef : Prog -> List String -> Int -> String -> String -> List CExpr -> <Mut> List String
emitMethodDispatchRef prog env d name dpar args =
  let impls = methodImpls prog name
  let argInstrs = flatMap (a => emitRefExpr prog env d a) args
  -- the dict tag is read repeatedly; stash it in the scratch local for this depth.
  let tagRead = readDictParam prog env dpar
  let blk = "$disp_\{name}_\{intToString d}"
  let chain = emitDispatchChain prog name impls blk tagRead dpar argInstrs (listLen args)
  ["block " ++ blk ++ " (result (ref eq))"]
    ++ indent chain
    ++ ["unreachable", "end"]

-- one comparison + call per candidate impl group.  loaded tag (i32) == dictTag
-- routeKey?  if so: load this impl's nested requires-dicts from the dict param's
-- $dictcell (W5 — was a placeholder zero) ++ the args, call the impl, `br` out of the
-- result block carrying its (ref eq).  The `if` carries NO result type — the matched
-- branch exits via `br $blk` (which supplies the block's value), the else branch falls
-- through to the next comparison; after the whole chain an `unreachable` (a well-typed
-- dict always names a candidate) satisfies the block's (ref eq) fallthrough requirement.
emitDispatchChain : Prog -> String -> List (String, String) -> String -> List String -> String -> List String -> Int -> <Mut> List String
emitDispatchChain _ _ [] _ _ _ _ _ = []
emitDispatchChain prog name ((tag, key)::rest) blk tagRead dpar argInstrs nArgs =
  -- W5: a `requires`-bearing impl (e.g. `Debug (a,b) requires Debug a, Debug b`) compiles
  -- to a fn whose leading params are the forwarded `requires` dicts BEFORE the method args.
  -- The dispatch site holds the dict param ($dpar): when this impl is constrained, the dict
  -- reaching this arm is a $dictcell whose field-1 $dictarr carries those nested req dicts in
  -- order (built by routeWitness).  Load field 0..reqDicts-1 and prepend them as the impl fn's
  -- leading dict args, mirroring llvm_emit's loadReqDicts (fields 1..n of the boxed cell).
  let reqDicts = implReqDictCount prog name tag nArgs
  let reqLoads = flatMap (loadReqDict dpar) (rangeList 0 reqDicts)
  tagRead
    ++ ["i32.const " ++ intToString (dictTag key), "i32.eq", "if"]
    ++ indent (reqLoads ++ argInstrs ++ ["call $" ++ implFnSym tag name, "br " ++ blk])
    ++ ["else"]
    ++ indent (emitDispatchChain prog name rest blk tagRead dpar argInstrs nArgs)
    ++ ["end"]

-- load nested req dict `i` from the dict param $dpar's $dictcell (field 1 = $dictarr).
-- Only reached for a constrained impl arm, where the in-scope dict IS a $dictcell.
-- load nested req dict `i` for a matched impl arm.  The witness ($dpar) is EITHER a
-- one-level i31 (no nested reqs — the typed-entry case where the iface table is absent
-- so the req COUNT is over-counted, or any concrete-element dict) OR a $dictcell (a real
-- nested dict carrying its element witnesses in field-1's $dictarr).  Runtime-test the
-- shape: i31 ⇒ a placeholder i31(0) (mirrors the pre-W5 stub — harmless, the impl never
-- recurses into a real element dict in that case); $dictcell ⇒ load field-1 array[i] (the
-- genuine nested element witness).  Both arms leave one (ref eq) → the arg count is static.
loadReqDict : String -> Int -> <Mut> List String
loadReqDict dpar i = ["local.get $" ++ gname dpar, "ref.test (ref i31)", "if (result (ref eq))"]
  ++ indent ["i32.const 0", "ref.i31"]
  ++ ["else"]
  ++ indent [
    "local.get $" ++ gname dpar,
    "ref.cast (ref $dictcell)",
    "struct.get $dictcell 1",
    "i32.const " ++ intToString i,
    "array.get $dictarr",
    "ref.as_non_null",
  ]
  ++ ["end"]

-- leading `requires`-dict count for a method's impl at `tag`: the impl's SOURCE
-- clause pattern count (the dict-pass injects leading $dict_* params, BEFORE the
-- user args) minus the method's DECLARED user arity (methodArityOf).  This is the
-- llvm_emit `implReqCount` separation (listLen implPats - methodArityOf), NOT the
-- pre-W9b `arity - userArgs` heuristic: a point-free impl (`length`, raw pats 0,
-- method arity 1) now yields 0 (no requires) rather than a spurious count, and a
-- genuinely-constrained impl yields exactly its requires-dict count regardless of
-- how many args the call site supplies.  >= 0; 0 for the unconstrained impls.
implReqDictCount : Prog -> String -> String -> Int -> <Mut> Int
implReqDictCount prog method tag _userArgs =
  let raw = implArityFor prog method tag
  let ua = methodArityOf method
  if raw > ua then raw - ua else 0

implArityFor : Prog -> String -> String -> Int
implArityFor prog method tag =
  implGroupArity (flatMap (implClauseFor method tag) (progImpls prog))

-- read a dict PARAM's HEAD TAG (an i32) into the stack.  The witness is EITHER an i31
-- (a one-level `RKey k []` dict — tag = i31.get_s) OR a $dictcell (a nested `RKey k [reqs]`
-- dict — tag = struct.get 0).  Type-test once and read the tag from the matching shape;
-- both arms leave one i32 on the stack.  The param is a leading $dict_* local, always in env.
readDictParam : Prog -> List String -> String -> <Mut> List String
readDictParam _ env dpar =
  if contains dpar env then
    ["local.get $" ++ gname dpar, "ref.test (ref i31)", "if (result i32)"] ++ indent ["local.get $" ++ gname dpar, "ref.cast (ref i31)", "i31.get_s"] ++ ["else"] ++ indent ["local.get $" ++ gname dpar, "ref.cast (ref $dictcell)", "struct.get $dictcell 0"] ++ ["end"]
  else
    gapL ("wasm W5: dict param '" ++ dpar ++ "' not in scope")

-- materialize a Route as its leading dict witness instruction(s): a concrete RKey →
-- the i31 of hashName(tag); a forwarded RDict/RDictFwd → re-push the in-scope dict
-- param.  Nested `requires` (RKey with non-empty reqs) are out of the minimal slice.
routeWitness : Prog -> List String -> Int -> Route -> <Mut> List String
routeWitness _ _ _ (RKey tag []) =
  ["i32.const " ++ intToString (dictTag tag), "ref.i31"]
-- W5 (nested requires-dict): build a $dictcell — push the tag, recursively build each
-- nested req witness onto the stack, pack them into a $dictarr (array.new_fixed), then
-- struct.new $dictcell.  Mirrors llvm_emit's emitDictCell (header + recursively-built
-- req fields); the recursion is dictWordsOf == flatMap routeWitness over reqs.
routeWitness prog env d (RKey tag reqs) =
  let reqWitnesses = flatMap (routeWitness prog env d) reqs
  ["i32.const " ++ intToString (dictTag tag)]
    ++ reqWitnesses
    ++ [
      "array.new_fixed $dictarr " ++ intToString (listLen reqs),
      "struct.new $dictcell",
    ]
routeWitness _ env _ (RDict dpar) =
  if contains dpar env then
    ["local.get $" ++ gname dpar]
  else
    gapL ("wasm W5: forwarded dict '" ++ dpar ++ "' not in scope")
routeWitness _ env _ (RDictFwd dpar) =
  if contains dpar env then
    ["local.get $" ++ gname dpar]
  else
    gapL ("wasm W5: forwarded dict '" ++ dpar ++ "' not in scope")
routeWitness _ _ _ RNone = gapL "wasm W5: RNone route as a dict witness"

-- a constrained-function occurrence applied to `args`: prepend the materialized
-- dict witnesses (one per `=>` constraint, in route order) to the args, then call
-- the lifted $name (whose leading params are the $dict_* the dict-pass injected).
emitDictRef : Prog -> List String -> Int -> String -> List Route -> List CExpr -> <Mut> List String
emitDictRef prog env d name routes args =
  if contains name (progFnNames prog) then
    let dictWords = flatMap (routeWitness prog env d) routes
    let argInstrs = flatMap (a => emitRefExpr prog env d a) args
    dictWords ++ argInstrs ++ ["call $" ++ gname name]
  else gapL ("wasm W5: CDict over unknown function '" ++ name ++ "'")

-- ── EMITTER-GAPS E23 (wasm peer): CMethod / CDict in VALUE position ───────────
-- A typeclass METHOD (`map negate xs`, `filter isEv xs`) or a `=>`-constrained NAMED
-- function (`filter myParity xs`) passed UNAPPLIED to a higher-order combinator lowers
-- to a bare CMethod/CDict in OPERAND position.  The emitRefExpr arms previously routed
-- these to emitMethodRef/emitDictRef with `[]` args → a TRUNCATED saturated dispatch
-- (`call $mdk_impl_*` / `call $fn`) carrying ONLY the dict words, no value args and no
-- closure capture → wasm stack underflow at validate (`not enough arguments on the
-- stack for call`).  (This is the wasm peer of the LLVM emitDictValue/emitMethodValue
-- fix — EMITTER-GAPS E23; distinct from #18/E18, the shadowed-local case that stays a
-- plain EVar.)
--
-- FIX: ETA-EXPAND the occurrence to a synthetic lambda `\a0..a(k-1) -> head a0..a(k-1)`
-- and lower it through emitClosure — the universal W4 closure path.  emitClosure (a)
-- captures the route's forwarded dict params (freeVarsExpr surfaces RDict/RDictFwd via
-- freeVarsRoute) into the closure $env, and (b) re-emits the SATURATED dispatch in the
-- lifted body via the CALL-position emitMethodRef/emitDictRef (correct: dicts ++ args ++
-- call).  The result is a `$clos` struct (code_ptr, arity, $env captures) with the exact
-- ABI W4 HOFs expect — the working lambda path IS the reference.

-- CMethod value: arity k = the method's declared USER arity; a nullary method (k <= 0)
-- is a plain value — keep the immediate saturated dispatch.
emitMethodValueRef : Prog -> List String -> Int -> String -> Route -> List Route -> List Route -> <Mut> List String
emitMethodValueRef prog env d name route implRoutes methRoutes =
  let arity = methodValArity prog name
  if arity <= 0 then emitMethodRef prog env d name route implRoutes methRoutes []
  else
    let names = etaValNames arity
    let ps = map (n => PVar n) names
    let body = applyArgsC (CMethod name route implRoutes methRoutes) (map (n => CVar n AGlobal) names)
    emitClosure prog env d ps body

-- the method's USER arity for an eta-value closure.  Prefer the installed iface table
-- (methodArityOf, the modules path); when absent (the prelude-free W5/typed path never
-- installs it → methodArityOf 0) fall back to the method's impl clause arity (these
-- prelude-free fixtures define simple `requires`-free impls, so the clause arity IS the
-- user arity — no leading requires-dict params to subtract).
methodValArity : Prog -> String -> <Mut> Int
methodValArity prog name =
  let viaTable = methodArityOf name
  if viaTable > 0 then viaTable
  else match methodImpls prog name
    (tag, _)::_ => implArityFor prog name tag
    _ => 0

-- CDict value: value arity v = define arity (progFnArity, which the dict-pass already
-- widened with the leading dict params) − route count.  A nullary value arity (the
-- constrained fn takes no value args) degenerates to the saturated dict call.
emitDictValueRef : Prog -> List String -> Int -> String -> List Route -> <Mut> List String
emitDictValueRef prog env d name routes =
  if contains name (progFnNames prog) then
    let valArity = progFnArity prog name - listLen routes
    if valArity <= 0 then emitDictRef prog env d name routes []
    else
      let names = etaValNames valArity
      let ps = map (n => PVar n) names
      let body = applyArgsC (CDict name routes) (map (n => CVar n AGlobal) names)
      emitClosure prog env d ps body
  else gapL ("wasm E23: CDict value over unknown function '" ++ name ++ "'")

-- fresh eta param names `$hov0..$hov(n-1)` (the `$`-prefixed convention etaFreshPatsW
-- uses); each lambda owns its own param scope so fixed names never collide.
etaValNames : Int -> List String
etaValNames n = map (i => "$hov" ++ intToString i) (rangeList 0 n)

-- left-fold a head expression over a list of value args into a saturated CApp spine.
applyArgsC : CExpr -> List CExpr -> CExpr
applyArgsC hd [] = hd
applyArgsC hd (a::rest) = applyArgsC (CApp hd a) rest

-- the impl-function symbol: $mdk_impl_<tag>_<method>.  For the minimal slice every
-- (method, head-tag) pair has a SOLE impl, so the bare head tag is the symbol tag
-- (no C7 same-head-tycon collision; that canonical-key path is out of scope).
implFnSym : String -> String -> String
implFnSym tag method = "mdk_impl_\{gname tag}_\{gname method}"

-- ── §W5 impl-function emission ───────────────────────────────────────────────
-- Coalesce the CImplEntry list (one entry per clause) by (method, symTag) into
-- per-impl clause groups, then emit each as a wasm function $mdk_impl_<tag>_<m>
-- via the SAME clause machinery top-level fns use (emitClausesRef).  Multi-clause
-- impls (`eq Red Red = …; eq _ _ = …`) coalesce into a fall-through chain.
emitImplFns : Prog -> <Mut> List String
emitImplFns prog = flatMap (emitImplGroup prog) (implGroups (progImpls prog))

-- (method, tag, arity, clauses) per distinct impl key, in first-seen order.
data ImplG = ImplG String String Int (List CClause)

implGroups : List CImplEntry -> <Mut> List ImplG
implGroups entries = mapGatherGroups entries (distinctImplKeys entries)

-- map gatherImplGroup (a <Mut> fn — it reads the iface-arity table) over the keys.
mapGatherGroups : List CImplEntry -> List (String, String) -> <Mut> List ImplG
mapGatherGroups _ [] = []
mapGatherGroups entries (k::rest) =
  let g = gatherImplGroup entries k
  g :: mapGatherGroups entries rest

-- the (method, tag) keys present, first-seen order.
distinctImplKeys : List CImplEntry -> List (String, String)
distinctImplKeys entries = dedupPairs (flatMap implKeyOf entries) []

implKeyOf : CImplEntry -> List (String, String)
implKeyOf (CImplEntry m _ (CImplTagged tag _ _ _ _ _)) = [(m, tag)]
implKeyOf _ = []

-- dedup a (method, tag) key list, first-seen order (dedupKeep is String-only).
dedupPairs : List (String, String) -> List (String, String) -> List (String, String)
dedupPairs [] acc = reverseL acc
dedupPairs (p::rest) acc =
  if containsPair p acc then
    dedupPairs rest acc
  else
    dedupPairs rest (p::acc)

containsPair : (String, String) -> List (String, String) -> Bool
containsPair _ [] = False
containsPair (a, b) ((c, dd)::rest) =
  if a == c && b == dd then
    True
  else
    containsPair (a, b) rest

gatherImplGroup : List CImplEntry -> (String, String) -> <Mut> ImplG
gatherImplGroup entries (m, tag) =
  let clauses = flatMap (implClauseFor m tag) entries
  -- W9b: eta-expand a POINT-FREE / under-applied impl (`length = fold g 0`, clause
  -- arity 0) to the method's full DECLARED arity (methodArityOf), so the lifted
  -- $mdk_impl_<tag>_<method> takes every call-site arg.  maxI keeps a multi-clause
  -- or already-full-arity impl unchanged (etaExpandClause is a no-op when have >=
  -- arity).  An empty iface table ⇒ methodArityOf 0 ⇒ no-op (W2/W5 entries).
  --
  -- #24: methodArityOf counts only the source VALUE params, but a point-free impl
  -- that carries a leading `requires`-dict (`foldMap f = fold (step f) empty`, which
  -- `requires Monoid m`) has clause pats `[$dict_Monoid, f]` — so the FULL define
  -- arity is the method's user arity PLUS the leading dict count, not just one or the
  -- other.  Mirrors llvm_emit's gatherGroup (`methodArityOf method + nDicts`): without
  -- the `+ nDicts`, max(implGroupArity 2, methodArityOf 2) = 2 leaves the container arg
  -- dropped → the lifted fn returns an under-applied `fold step empty` PAP → wasm
  -- validate fails at `$mdk_impl_List_foldMap` (expected (ref eq) but nothing on stack).
  -- nDicts = 0 for a dict-free impl (`length`/`toList`) ⇒ identical to the old maxI.
  let nDicts = wLeadingDictPats (firstImplClausePats clauses)
  let arity = maxI (implGroupArity clauses) (methodArityOf m + nDicts)
  let clauses2 = map (etaExpandClause arity) clauses
  ImplG m tag arity clauses2

-- count of leading `$dict_…` param patterns the dict-pass prepends ahead of the
-- source value params (mirror of llvm_emit's leadingDictPats; uses wIsDictParamName).
wLeadingDictPats : List Pat -> Int
wLeadingDictPats ((PVar x)::rest) =
  if wIsDictParamName x then
    1 + wLeadingDictPats rest
  else
    0
wLeadingDictPats _ = 0

-- the first clause's patterns (for counting leading dict params); [] when no clause.
firstImplClausePats : List CClause -> List Pat
firstImplClausePats ((CClause pats _)::_) = pats
firstImplClausePats [] = []

-- eta-expand one impl clause's (pats, body) to `arity` (no-op when already there).
-- The added trailing params are fresh `$etaN` PVars, and the body is APPLIED to each
-- — so `length = fold g 0` (arity 0) becomes `length $eta0 = (fold g 0) $eta0`.  The
-- $etaN are bound to the synthetic positional params in emitClausesRef (they reach
-- env) and declared as locals by clauseLocals (patVars collects them).  Mirror of
-- llvm_emit's etaExpand / etaExpandClause.
etaExpandClause : Int -> CClause -> CClause
etaExpandClause arity (CClause pats body) =
  let (pats2, body2) = etaExpandTo pats body arity (listLen pats)
  CClause pats2 body2

etaExpandTo : List Pat -> CExpr -> Int -> Int -> (List Pat, CExpr)
etaExpandTo pats body arity have
  | have >= arity = (pats, body)
  | otherwise =
    let nm = "$eta" ++ intToString have
    etaExpandTo
      (pats ++ [PVar nm])
      (CApp body (CVar nm AGlobal))
      arity
      (have + 1)

-- W9b — eta-SATURATE a POINT-FREE / under-applied PLAIN top-level constrained fn
-- whose body is an under-applied interface-method (CMethod) occurrence.  Peer to
-- llvm_emit's etaSaturateMethodBody (the plain-fn analog of the impl-clause
-- gatherImplGroup eta-expansion).  `elem a = fold (acc x => …) False` dict-passes
-- to a clause `[$dict_Foldable, $dict_Eq, a]` whose body is the CMethod `fold`
-- (declared arity 3) applied to only TWO args (the lambda + `False`) — the
-- container `t a` argument is the RESIDUAL the method's full arity supplies.  The
-- emitted call then pushes 2 args at a `mdk_impl_*_fold` that takes 3 → stack
-- underflow at validate.  Append `deficit` fresh value params and APPLY them to
-- the body (threading through any where/let tail), so the dispatch call is
-- SATURATED.  No-op (deficit 0) for a saturated body, a bare value, or any fn
-- whose body tail is not an under-applied CMethod.  Mirrors the LLVM method-spine
-- deficit; the #12 CLam-compose case (sig-arity deficit) is not yet a wasm fixture
-- so we key only on the method-spine signal (the load-bearing one for the prelude).
etaSaturateFnClause : CClause -> <Mut> CClause
etaSaturateFnClause (CClause pats body) =
  let deficit = methodBodyDeficitW body
  if deficit <= 0 then CClause pats body
  else
    let (pats2, body2) = applyEtaTailW pats body deficit (listLen pats)
    CClause pats2 body2

-- the count of still-unapplied VALUE args of an under-applied CMethod body tail
-- (0 = saturated / not a method head).  Transparent through CLet/CLetGroup tail
-- wrappers (a method spine can be the let-body tail).  Mirror of llvm_emit's
-- methodBodyDeficit.
methodBodyDeficitW : CExpr -> <Mut> Int
methodBodyDeficitW (CLet _ _ _ b) = methodBodyDeficitW b
methodBodyDeficitW (CLetGroup _ b) = methodBodyDeficitW b
methodBodyDeficitW (CMethod name _ _ _) = methodArityOf name
methodBodyDeficitW app =
  let (hd, args) = flattenApp app []
  match hd
    CMethod name _ _ _ => maxI 0 (methodArityOf name - listLen args)
    _ => 0

-- append `n` fresh eta params (numbered after `start`) and APPLY them to the body
-- at its tail position, threading through where/let wrappers so let bindings stay
-- in scope for the saturated tail application.  Mirror of llvm_emit's
-- applyEtaArgsTail / etaFreshPats.
applyEtaTailW : List Pat -> CExpr -> Int -> Int -> (List Pat, CExpr)
applyEtaTailW pats body n start =
  let fresh = etaFreshPatsW n start
  (pats ++ fresh, applyEtaArgsTailW body fresh)

etaFreshPatsW : Int -> Int -> List Pat
etaFreshPatsW 0 _ = []
etaFreshPatsW n start =
  PVar ("$eta" ++ intToString start) :: etaFreshPatsW (n - 1) (start + 1)

applyEtaArgsTailW : CExpr -> List Pat -> CExpr
applyEtaArgsTailW (CLet r p rhs b) fresh =
  CLet r p rhs (applyEtaArgsTailW b fresh)
applyEtaArgsTailW (CLetGroup bs b) fresh =
  CLetGroup bs (applyEtaArgsTailW b fresh)
applyEtaArgsTailW body fresh = applyEtaArgsW body fresh

applyEtaArgsW : CExpr -> List Pat -> CExpr
applyEtaArgsW body [] = body
applyEtaArgsW body ((PVar x)::rest) =
  applyEtaArgsW (CApp body (CVar x AGlobal)) rest
applyEtaArgsW body (_::rest) = applyEtaArgsW body rest

implClauseFor : String -> String -> CImplEntry -> List CClause
implClauseFor m tag (CImplEntry n _ (CImplTagged t _ _ _ pats body)) =
  if n == m && t == tag then
    [CClause pats body]
  else
    []
implClauseFor _ _ _ = []

implGroupArity : List CClause -> Int
implGroupArity ((CClause pats _)::_) = listLen pats
implGroupArity [] = 0

emitImplGroup : Prog -> ImplG -> <Mut> List String
emitImplGroup prog (ImplG method tag arity clauses) =
  let fnName = implFnSym tag method
  let params = synthParams arity
  -- Phase 2 B-dispatch (TRMC-DESIGN §"Phase 2"): a DISPATCHED self-recursive cons/ctor-tail
  -- impl (the `List map`: self-call is a `CMethod method (RKey tag)`) is emitted as a
  -- destination-passing loop — the WasmGC peer of llvm_emit's trmcImplTry.  Eligibility +
  -- the safety-critical `mentionsSelfMethod` disqualification are in wTrmcImplTry; an
  -- ineligible impl (non-tail self, dict-passed, no cons-tail) returns None → ordinary body.
  match wTrmcImplTry prog method tag arity clauses
    Some tmcDef => tmcDef
    None =>
      -- W8b: an `impl … Float` method's params are Float — record their (pattern-var) names
      -- so the body's bare-CVar arithmetic lowers to f64.  `signum`/`abs`/`negate`/`add`/…
      -- all take Float args.  Reset for every other impl (Int/String/etc. stay i31).
      let _ = setRef floatLocalsRef (if tag == "Float" then flatMap clausePatVars clauses else [])
      -- A1: impl-method params are concrete-typed (the impl tag), never poly-`Num`; reset.
      let _ = setRef numPolyLocalsRef []
      -- layer-18: arm the plain-tail impl-method return_call context for THIS impl, so a
      -- saturated tail-position self-call (`fold f (f z x) xs` → `CMethod "fold" (RKey
      -- "List")`) lowers to `return_call $mdk_impl_List_fold` (constant stack) rather than a
      -- recursive `call`.  Disarmed immediately after (default defines + everything else
      -- must NOT see it).
      let savedImplSelf = implSelfCtxRef.value
      let _ = setRef implSelfCtxRef (ImplSelfOn method tag arity)
      let bodyLines = emitClausesImpl prog fnName params arity clauses
      let _ = setRef implSelfCtxRef savedImplSelf
      let _ = setRef floatLocalsRef []
      let allLocals = clauseLocals clauses
      let extraLocals = filterList (notIn params) (dedupKeep allLocals)
      let scratch = scratchLocals (clausesMaxDepth clauses)
      let sig = "  (func $\{fnName}\{joinWith "" (map paramDeclRef params)} (result (ref eq))"
      let localDecls = map localDeclRef (extraLocals ++ scratch)
      let w7Decls = w7LocalDecls (clausesMaxDepth clauses)
      [sig] ++ map ("  " ++ _) (localDecls ++ w7Decls) ++ indent bodyLines ++ ["  )"]

clausePatVars : CClause -> List String
clausePatVars (CClause pats _) = flatMap patVars pats

-- W-SQLITE-4 (float-param registry): the pattern-var names bound at a fn's
-- Float-typed parameter positions (from the installed `declSigTypeNames` table),
-- unioned across clauses.  `emitRefFnBind` seeds `floatLocalsRef` with these before
-- emitting the body, so `f (x : Float) = x + x` sees `x` as Float without a
-- co-located literal — generalizing the `impl … Float` seeding at emitImplGroup to
-- any sig'd top-level fn.  Empty (no sig / no Float param) resets floatLocalsRef,
-- preserving the reset-before-body discipline.
floatParamNames : String -> List CClause -> <Mut> List String
floatParamNames name clauses = match declParamTypesOf name
  [] => []
  ptys => dedupKeep (flatMap (floatClausePatVars ptys) clauses)

floatClausePatVars : List String -> CClause -> List String
floatClausePatVars ptys (CClause pats _) = floatPatsAt ptys pats

floatPatsAt : List String -> List Pat -> List String
floatPatsAt (ty::tys) ((PVar x)::ps) = (if ty == "Float" then [x] else [])
  ++ floatPatsAt tys ps
floatPatsAt (_::tys) (_::ps) = floatPatsAt tys ps
floatPatsAt _ _ = []

-- A1 (poly-`Num`-on-Float): the pattern-var names bound at this fn's POLYMORPHIC
-- `Num`/`Ord` param positions — the wasm peer of native's `isNumPolyParam`.  Two cases,
-- matching native's `isNumPolyParam` (dsig Some → type-var head; dsig None → True):
--   • declared sig present (declParamTypesOf non-empty): a param whose declared type
--     head is a type VARIABLE (lowercase-initial, `Num a => a -> a`) and used arithmetically.
--   • no declared sig: any param USED arithmetically (`sq x = x*x`) — the operand's type
--     is only known at runtime, so it must dispatch (native seeds LTNum identically).
-- A param declared with a concrete scalar (`: Int`/`: Float`) stays on the static fast
-- path.  Unioned across clauses.  `paramUsedInArith` keeps `id x = x` off the list.
numPolyParamNames : String -> List CClause -> <Mut> List String
numPolyParamNames name clauses = match declParamTypesOf name
  [] => dedupKeep (flatMap noSigNumPolyPatVars clauses)
  ptys => dedupKeep (flatMap (numPolyClausePatVars ptys) clauses)

-- declared-sig case: collect PVar params whose declared type head is a type var and
-- which are used arithmetically in the clause body.
numPolyClausePatVars : List String -> CClause -> List String
numPolyClausePatVars ptys (CClause pats body) = numPolyPatsAt ptys pats body

numPolyPatsAt : List String -> List Pat -> CExpr -> List String
numPolyPatsAt (ty::tys) ((PVar x)::ps) body = (if isTypeVarName ty && paramUsedInNumBinop x body then [x] else [])
  ++ numPolyPatsAt tys ps body
numPolyPatsAt (_::tys) (_::ps) body = numPolyPatsAt tys ps body
numPolyPatsAt _ _ _ = []

-- no-declared-sig case: every PVar param used in an arithmetic OR comparison binop is
-- poly-`Num`/`Ord` (its type is resolved only at runtime, so the op must dispatch).
noSigNumPolyPatVars : CClause -> List String
noSigNumPolyPatVars (CClause pats body) = flatMap
  (p => match p
    PVar x => if paramUsedInNumBinop x body then [x] else []
    _ => [])
  pats

-- A1 (design row 6): a lambda's PVar params used in a num/cmp binop — the lambda has no
-- declared sig, so like the no-sig fn case its arith-used params are polymorphic `Num`.
lamPolyParamNames : List Pat -> CExpr -> List String
lamPolyParamNames pats body = flatMap
  (p => match p
    PVar x => if paramUsedInNumBinop x body then [x] else []
    _ => [])
  pats

-- a type-variable head name is lowercase-initial (`a`, `elem`); a concrete type
-- (`Int`, `Float`, a user type) is uppercase-initial (peer of native's isTypeVarName).
isTypeVarName : String -> Bool
isTypeVarName n =
  if stringLength n == 0 then
    False
  else
    let f = stringSlice 0 1 n in "a" <= f && f <= "z"

isVarNamed : String -> CExpr -> Bool
isVarNamed p (CVar x _) = p == x
isVarNamed _ _ = False

-- True when param `p` appears as a direct operand of an arithmetic OR comparison binop
-- anywhere in `body` (peer of native's paramUsedInArith, extended to `Ord` compares so
-- the poly-`Ord`-on-Float sibling `myMax a b = if a > b …` is seeded).  Structural walk.
paramUsedInNumBinop : String -> CExpr -> Bool
paramUsedInNumBinop p (CBinPrim op l r _) =
  if (isArithOp op || isCmpOp op) && (isVarNamed p l || isVarNamed p r) then
    True
  else
    paramUsedInNumBinop p l || paramUsedInNumBinop p r
paramUsedInNumBinop p (CUnOp _ x) = paramUsedInNumBinop p x
paramUsedInNumBinop p (CIf c t f) = paramUsedInNumBinop p c
  || paramUsedInNumBinop p t
  || paramUsedInNumBinop p f
paramUsedInNumBinop p (CLet _ _ e1 e2) = paramUsedInNumBinop p e1
  || paramUsedInNumBinop p e2
paramUsedInNumBinop p (CLetGroup _ b) = paramUsedInNumBinop p b
paramUsedInNumBinop p (CBlock stmts) = anyNumStmt p stmts
paramUsedInNumBinop p (CApp f a) = paramUsedInNumBinop p f
  || paramUsedInNumBinop p a
-- match bodies: a param used arithmetically inside an arm (`sumOne acc xs = match xs {…
-- y::rest => acc + y}`) must be seeded, so walk the scrutinee + every arm body.
paramUsedInNumBinop p (CMatch scrut arms) = paramUsedInNumBinop p scrut
  || anyNumArm p arms
paramUsedInNumBinop p (CDecision scrut arms _) = paramUsedInNumBinop p scrut
  || anyNumArm p arms
paramUsedInNumBinop _ _ = False

anyNumArm : String -> List CArm -> Bool
anyNumArm _ [] = False
anyNumArm p ((CArm _ _ body)::rest) = paramUsedInNumBinop p body
  || anyNumArm p rest

anyNumStmt : String -> List CStmt -> Bool
anyNumStmt _ [] = False
anyNumStmt p ((CSExpr e)::rest) = paramUsedInNumBinop p e || anyNumStmt p rest
anyNumStmt p ((CSLet _ _ e)::rest) = paramUsedInNumBinop p e
  || anyNumStmt p rest
anyNumStmt p (_::rest) = anyNumStmt p rest

-- impl bodies use the SAME clause emission as top-level fns; the synthetic fn
-- "name" (used only for the internal clause-block labels) is the impl symbol.
emitClausesImpl : Prog -> String -> List String -> Int -> List CClause -> <Mut> List String
emitClausesImpl prog fnName params arity clauses =
  emitClausesRef prog fnName params arity clauses

-- the candidate impls for a method: (symTag, routeKey) per group.  routeKey is the
-- key the RDict witness hashes (the canonical impl key); for the minimal slice the
-- bare head tag IS the key (sole impl per head), so symTag == routeKey == tag.
methodImpls : Prog -> String -> <Mut> List (String, String)
methodImpls prog method =
  dedupPairs (flatMap (methodImplKey method) (progImpls prog)) []

methodImplKey : String -> CImplEntry -> <Mut> List (String, String)
methodImplKey method (CImplEntry n _ (CImplTagged tag _ _ _ _ _)) =
  if n == method then
    [(tag, tag)]
  else
    []
methodImplKey _ _ = []

-- ── layer-15: defaulted-method emission (peer to llvm_emit's E19 default subsystem) ──
-- A `Filterable List` provides `filterMap` as a CONCRETE impl but inherits `filter`
-- as an INTERFACE DEFAULT (`filter p = filterMap (x => if p x then Some x else None)`).
-- A `filter` call resolves to `RKey "List"` with no tagged impl define, so a naive
-- `call $mdk_impl_List_filter` references a never-emitted symbol (the WAT-assemble
-- hole layer-15 closes).  Mirror llvm_emit's emitDefaultRKey/ensureDefaultEmitted/
-- emitDefaultDefine: when no concrete impl exists at [tag] but the interface has a
-- default body, synthesize `$mdk_default_<method>_<tag>` ONCE from that default body
-- (its inner same-interface method calls restamped to THIS tag's concrete impl, so a
-- partially-applied inner `filterMap` lowers to a direct `$mdk_impl_List_filterMap`
-- call) and emit a `call $mdk_default_<method>_<tag>` instead.

-- the CONCRETE tagged impl entry for (method, tag), if one exists (mirror of
-- llvm_emit's implFor/findByTag).  None ⇒ the type did not override the method.
implForW : Prog -> String -> String -> Option CImplEntry
implForW prog method tag = findByTagW method tag (progImpls prog)

findByTagW : String -> String -> List CImplEntry -> Option CImplEntry
findByTagW _ _ [] = None
findByTagW method tag ((CImplEntry n s (CImplTagged t k iface ps pats body))::rest)
  | n == method && (t == tag || k == tag) =
    Some (CImplEntry n s (CImplTagged t k iface ps pats body))
  | otherwise = findByTagW method tag rest
findByTagW method tag (_::rest) = findByTagW method tag rest

-- the interface DEFAULT entry (CImplDefault) for a method (mirror of defaultFor/
-- findDefault).  None ⇒ no default body ⇒ a genuine missing-impl error.
defaultForW : Prog -> String -> Option CImplEntry
defaultForW prog method = findDefaultW method (progImpls prog)

findDefaultW : String -> List CImplEntry -> Option CImplEntry
findDefaultW _ [] = None
findDefaultW method ((CImplEntry n s (CImplDefault pats body))::rest)
  | n == method = Some (CImplEntry n s (CImplDefault pats body))
  | otherwise = findDefaultW method rest
findDefaultW method (_::rest) = findDefaultW method rest

-- `$mdk_default_<method>_<tag>` (mirror of llvm_emit's defaultFnName, gname-mangled
-- for wasm symbols).
defaultFnNameW : String -> String -> String
defaultFnNameW tag method = "mdk_default_\{gname method}_\{gname tag}"

-- the RKey-arm fallback: `defaultFor` finds a default ⇒ synthesize the per-(method,
-- tag) define once and emit a direct call to it (forwarding the same dict words +
-- args the concrete impl call would have taken).  No default ⇒ gap (the same
-- missing-impl error llvm_emit's `None => gapE` reports).
emitDefaultRKeyRef : Prog -> List String -> List String -> String -> String -> <Mut> List String
emitDefaultRKeyRef prog dictWords argInstrs name tag = match defaultForW prog name
  Some entry =>
    let fname = defaultFnNameW tag name
    let _ = ensureDefaultEmittedW prog fname tag name entry
    dictWords ++ argInstrs ++ ["call $" ++ fname]
  None => gapL "wasm layer-15: no impl of method '\{name}' for type '\{tag}'"

-- a module-level set of already-synthesized default symbols (dedup like
-- llvm_emit's emittedDefaultsRef) + the accumulated define line-blocks, drained
-- UNCONDITIONALLY in emitProgram (a default define is a plain fn, not closure-gated).
emittedDefaultsWRef : Ref (List String)
emittedDefaultsWRef = Ref []

defaultDefsWRef : Ref (List (List String))
defaultDefsWRef = Ref []

defaultAlreadyEmittedW : String -> <Mut> Bool
defaultAlreadyEmittedW name = contains name emittedDefaultsWRef.value

markDefaultEmittedW : String -> <Mut> Unit
markDefaultEmittedW name =
  setRef emittedDefaultsWRef (name::emittedDefaultsWRef.value)

addDefaultDefW : List String -> <Mut> Unit
addDefaultDefW def = setRef defaultDefsWRef (def::defaultDefsWRef.value)

ensureDefaultEmittedW : Prog -> String -> String -> String -> CImplEntry -> <Mut> Unit
ensureDefaultEmittedW prog fname tag method entry =
  if defaultAlreadyEmittedW fname then ()
  else
    let _ = markDefaultEmittedW fname
    addDefaultDefW (emitDefaultDefineW prog fname tag method entry)

-- synthesize `$mdk_default_<method>_<tag>` from the interface default body.  Mirror
-- of llvm_emit's emitDefaultDefine: eta-expand the (point-free) default body to the
-- method's full declared arity, restamp inner SAME-interface method calls to a
-- concrete `RKey tag` (so the inner `filterMap` is a direct impl call, not an
-- un-dispatchable arg-tag site), then emit it with the SAME clause machinery an impl
-- group uses.  The define arity counts the dict-pass's leading `$dict_<method>` params
-- (the method-level `=>` constraint dicts, e.g. foldMap's `Monoid m`) ON TOP of the
-- method's user arity (#24-peer, below) — a constrained point-free default would
-- otherwise drop the container arg.  Cross-interface method-level dicts (the Monoid
-- `empty` in foldMap's default) and the inner same-interface call are already routed
-- by the dict-pass (RDict `$dict_<method>`) / restampIfaceDictsW respectively, so no
-- emitter-side restampCrossIface is needed here (unlike llvm_emit, which re-derives it).
-- Interface-level `requires` element dicts (the llvm reqDict path) are still deferred —
-- no current interface pairs a `requires`-bearing head with a constrained default.
emitDefaultDefineW : Prog -> String -> String -> String -> CImplEntry -> <Mut> List String
emitDefaultDefineW prog fname tag method entry =
  let pats0 = implDefaultPats entry
  let body0 = implDefaultBody entry
  -- #24-peer (default path): the dict-pass PREPENDS one `$dict_<method>_<slot>` param per
  -- method-level `=>` constraint (foldMap's `Monoid m`) to the default's pats, so the full
  -- arity is that leading-dict count PLUS the method's user arity.  `methodArityOf` counts
  -- only the interface's user args (f + container); without the `+ nDicts` term,
  -- max(listLen pats0 = 2, methodArityOf = 2) = 2 leaves the container arg unbound — the
  -- body stays the under-applied `fold step empty` PAP and the lifted $mdk_default_<m>_<tag>
  -- drops the container, failing wasm validate ("expected (ref eq) but nothing on stack").
  -- Mirrors gatherImplGroup's `methodArityOf m + nDicts` (the #24 concrete-impl fix); the
  -- cross-interface `empty` and the inner same-interface `fold` are already routed by the
  -- dict-pass / restampIfaceDictsW (an unconstrained default ⇒ nDicts = 0 ⇒ byte-identical).
  let nDicts = wLeadingDictPats pats0
  let arity = maxI (listLen pats0) (methodArityOf method + nDicts)
  let (pats1, body1) = etaExpandTo pats0 body0 arity (listLen pats0)
  let body = restampIfaceDictsW methodIfaceTableRef.value (methodIfaceOf method) tag body1
  emitDefaultDefnGroup prog fname tag method arity [CClause pats1 body]

implDefaultPats : CImplEntry -> List Pat
implDefaultPats (CImplEntry _ _ (CImplDefault pats _)) = pats
implDefaultPats _ = []

implDefaultBody : CImplEntry -> CExpr
implDefaultBody (CImplEntry _ _ (CImplDefault _ body)) = body
implDefaultBody _ = CLit LUnit

-- emit the synthesized default define `$fname` with the same body/locals machinery
-- emitImplGroup uses for `$mdk_impl_*`, but under the default symbol name.  (We can't
-- reuse emitImplGroup directly — it hardcodes implFnSym for the symbol; this is the
-- emitImplGroup body inlined with `fname` substituted.  No TRMC/Float-impl path: a
-- default body is not a self-recursive ctor-tail impl, and its params are the
-- interface's, not Float.)
emitDefaultDefnGroup : Prog -> String -> String -> String -> Int -> List CClause -> <Mut> List String
emitDefaultDefnGroup prog fname tag method arity clauses =
  let params = synthParams arity
  let bodyLines = emitClausesImpl prog fname params arity clauses
  let allLocals = clauseLocals clauses
  let extraLocals = filterList (notIn params) (dedupKeep allLocals)
  let scratch = scratchLocals (clausesMaxDepth clauses)
  let sig = "  (func $\{fname}\{joinWith "" (map paramDeclRef params)} (result (ref eq))"
  let localDecls = map localDeclRef (extraLocals ++ scratch)
  let w7Decls = w7LocalDecls (clausesMaxDepth clauses)
  [sig]
    ++ map ("  " ++ _) (localDecls ++ w7Decls)
    ++ indent bodyLines
    ++ ["  )"]

-- restamp every inner SAME-interface method occurrence in the default body to a
-- concrete `RKey tag` (peer of llvm_emit's restampIfaceDicts, non-parametric path:
-- empty element-dict routes, no cross-interface threading).  A bare `CVar m` or an
-- already-marked `CMethod m RNone` whose interface == [iface] becomes
-- `CMethod m (RKey tag []) [] []` ⇒ the wasm RKey arm calls `$mdk_impl_<tag>_<m>`
-- directly.  Walks the whole CExpr tree (the arms mirror restampIfaceDicts).
restampIfaceDictsW : List (String, (String, Int)) -> String -> String -> CExpr -> CExpr
restampIfaceDictsW tbl iface tag (CVar m ad)
  | iface != "" && ifaceOfInW tbl m == iface = CMethod m (RKey tag []) [] []
  | otherwise = CVar m ad
restampIfaceDictsW tbl iface tag (CMethod m RNone irs mrs)
  | iface != "" && ifaceOfInW tbl m == iface = CMethod m (RKey tag []) irs mrs
  | otherwise = CMethod m RNone irs mrs
restampIfaceDictsW tbl iface tag (CApp f a) =
  CApp (restampIfaceDictsW tbl iface tag f) (restampIfaceDictsW tbl iface tag a)
restampIfaceDictsW tbl iface tag (CLam ps b) =
  CLam ps (restampIfaceDictsW tbl iface tag b)
restampIfaceDictsW tbl iface tag (CLet r p rhs b) =
  CLet
    r
    p
    (restampIfaceDictsW tbl iface tag rhs)
    (restampIfaceDictsW tbl iface tag b)
restampIfaceDictsW tbl iface tag (CLetGroup bs b) =
  CLetGroup
    (map (restampBindW tbl iface tag) bs)
    (restampIfaceDictsW tbl iface tag b)
restampIfaceDictsW tbl iface tag (CMatch s arms) =
  CMatch
    (restampIfaceDictsW tbl iface tag s)
    (map (restampArmW tbl iface tag) arms)
restampIfaceDictsW tbl iface tag (CDecision s arms tr) =
  CDecision
    (restampIfaceDictsW tbl iface tag s)
    (map (restampArmW tbl iface tag) arms)
    tr
restampIfaceDictsW tbl iface tag (CIf c t el) =
  CIf
    (restampIfaceDictsW tbl iface tag c)
    (restampIfaceDictsW tbl iface tag t)
    (restampIfaceDictsW tbl iface tag el)
restampIfaceDictsW tbl iface tag (CTuple xs) =
  CTuple (map (restampIfaceDictsW tbl iface tag) xs)
restampIfaceDictsW tbl iface tag (CList xs) =
  CList (map (restampIfaceDictsW tbl iface tag) xs)
restampIfaceDictsW tbl iface tag (CFieldAccess a f n) =
  CFieldAccess (restampIfaceDictsW tbl iface tag a) f n
restampIfaceDictsW tbl iface tag (CIndex a b) =
  CIndex
    (restampIfaceDictsW tbl iface tag a)
    (restampIfaceDictsW tbl iface tag b)
restampIfaceDictsW _ _ _ other = other

restampBindW : List (String, (String, Int)) -> String -> String -> CBind -> CBind
restampBindW tbl iface tag (CBind n cl) =
  CBind n (map (restampClauseW tbl iface tag) cl)

restampClauseW : List (String, (String, Int)) -> String -> String -> CClause -> CClause
restampClauseW tbl iface tag (CClause ps b) =
  CClause ps (restampIfaceDictsW tbl iface tag b)

restampArmW : List (String, (String, Int)) -> String -> String -> CArm -> CArm
restampArmW tbl iface tag (CArm p g b) =
  CArm
    p
    (map (restampGuardW tbl iface tag) g)
    (restampIfaceDictsW tbl iface tag b)

restampGuardW : List (String, (String, Int)) -> String -> String -> CGuard -> CGuard
restampGuardW tbl iface tag (CGBool e) =
  CGBool (restampIfaceDictsW tbl iface tag e)
restampGuardW tbl iface tag (CGBind p e) =
  CGBind p (restampIfaceDictsW tbl iface tag e)

-- the interface a method name belongs to ("" = not an interface method); peer of
-- llvm_emit's ifaceOfIn.
ifaceOfInW : List (String, (String, Int)) -> String -> String
-- Intentional cross-file duplicate of the same helper in llvm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
ifaceOfInW tbl m = match lookupAssoc m tbl
  Some (iface, _) => iface
  None => ""

-- `hashName` (djb2, seed 5381) lives in `backend.private_mangle`, shared verbatim
-- with the LLVM emitter so the dict-witness tag matches across backends + the
-- route-key dispatch agrees.

-- the i31-safe dict-witness tag: hashName masked into the low 30 bits (positive
-- range of an i31).  The full djb2 hash is an i64 in the LLVM backend (an i64 dict
-- word); a WasmGC dict witness rides an i31 immediate (31 bits), so the raw hash
-- (e.g. hashName "Color" = 210671116836, a 38-bit value) overflows `i32.const`.
-- Masking to 30 bits keeps it a positive i32/i31 that `i31.get_s` reads back
-- unchanged, and — being applied identically at witness CREATION (routeWitness) and
-- at the dispatch COMPARISON (emitDispatchChain) — preserves the equality test.
-- (No bitwise primitive in the compiler subset; `% 2^30` is the mask.  Collisions
-- across 30-bit-equal tag names are astronomically unlikely for the small impl-tag
-- alphabet; the LLVM 64-bit scheme has the same theoretical collision shape.)
dictTag : String -> <Mut> Int
dictTag s = posMod (hashName s) 1073741824

-- a non-negative remainder (Medaka `%` can be negative for a negative dividend; the
-- djb2 i64 accumulator can wrap negative).
posMod : Int -> Int -> Int
posMod n m = (n % m + m) % m

-- ── ref-mode expression emitter — every result is a (ref eq) on the stack ────
-- `d` is the current match/switch nesting DEPTH: a CDecision/CTSwitch stashes a
-- value into the scratch local `$__rf<d>` and recurses at d+1, so simultaneously-
-- live stash locals never collide.  The function header declares `$__rf0..` up to
-- the body's max depth (`maxRefDepth`).  No mutable counter needed → re-derivable.

emitRefExpr : Prog -> List String -> Int -> CExpr -> <Mut> List String
emitRefExpr prog env d (CLit l) = emitLitRef l
emitRefExpr prog env d (CVar x _) = emitVarRef prog env d x
emitRefExpr prog env d (CBinPrim op l r tag) = emitBinRef prog env d op l r tag
emitRefExpr prog env d (CUnOp op x) = emitUnRef prog env d op x
emitRefExpr prog env d (CIf c t f) = emitIfRef prog env d c t f
emitRefExpr prog env d (CLet recF pat e1 e2) =
  emitLetRef prog env d recF pat e1 e2
emitRefExpr prog env d (CLetGroup binds body) =
  emitLetGroupRef prog env d binds body
emitRefExpr prog env d (CBlock stmts) = emitBlockRef prog env d stmts
emitRefExpr prog env d (CApp f a) = emitAppRef prog env d (CApp f a)
emitRefExpr prog env d (CDecision scrut arms tree) =
  emitDecisionRef prog env d scrut arms tree
emitRefExpr prog env d (CLam pats body) = emitClosure prog env d pats body
emitRefExpr prog env d (CMethod name route implRoutes methRoutes) =
  emitMethodValueRef prog env d name route implRoutes methRoutes
emitRefExpr prog env d (CDict name routes) =
  emitDictValueRef prog env d name routes
emitRefExpr prog env d (CTuple es) = emitTupleRef prog env d es
emitRefExpr prog env d (CList es) = emitListRef prog env d es
emitRefExpr prog env d (CRangeList lo hi incl) =
  emitRangeListRef prog env d lo hi incl
emitRefExpr prog env d (CArray es) = emitArrayCreateRef prog env d es
emitRefExpr prog env d (CRangeArray lo hi incl) =
  emitRangeArrayRef prog env d lo hi incl
emitRefExpr prog env d (CIndex a i) = emitIndexRef prog env d a i
emitRefExpr prog env d (CSlice a lo hi incl) =
  emitSliceRef prog env d a lo hi incl
emitRefExpr prog env d (CRecord name fields) =
  emitRecordRef prog env d name fields
emitRefExpr prog env d (CFieldAccess ex label _) =
  emitFieldAccessRef prog env d ex label
emitRefExpr prog env d (CRecordUpdate base fields) =
  emitRecordUpdateRef prog env d base fields
emitRefExpr prog env d (CVariantUpdate con base fields) =
  emitVariantUpdateRef prog env d con base fields
emitRefExpr prog env d other =
  gapL
    "ref-mode: unsupported Core IR node \{ctag other} [in \{curBindRef.value}]"

-- a scalar literal → an i31 immediate.  Int: ref.i31 of the value.  Bool: 1/0.
-- Unit: i31 0 (a placeholder immediate; Unit is never inspected in this slice).
emitLitRef : Lit -> <Mut> List String
emitLitRef (LInt n) =
  -- layer-17 §2.1: in-range Ints stay i31 immediates (byte-identical to before);
  -- literals outside ±2^30 box into $boxint via the i64 seam so they don't truncate.
  if n >= (0 - 1073741824) && n < 1073741824 then ["i32.const " ++ intToString n, "ref.i31"]
  else ["i64.const " ++ intToString n, "call $mdk_box_int"]
emitLitRef (LBool b) = [if b then "i32.const 1" else "i32.const 0", "ref.i31"]
emitLitRef LUnit = ["i32.const 0", "ref.i31"]
-- W8b: a Float literal in ref-mode boxes the double into a `(struct $float (f64))`.
-- The f64.const text is `floatToString f` — the SAME `%.12g` rendering the LLVM oracle
-- bakes into its IR const, so clang and wasm-tools parse the identical double (verified
-- byte-identical via i64.reinterpret_f64).  `$float` is always in the rec group.  Emitted
-- as TWO FLAT instructions (not the folded `struct.new $float (f64.const …)`) so it
-- composes with the surrounding flat instruction stream (a folded form mid-stream breaks
-- wasm-tools' stack tracking).
emitLitRef (LFloat f) = ["f64.const " ++ floatToString f, "struct.new $float"]
-- W6: a String literal is a §3.3 `$str` boxed value.  Its UTF-8 bytes go in a
-- passive data segment (the §11-preferred non-const-array init), read at run time by
-- `array.new_data`; the cached cp_count is computed at emit time (UTF-8 codepoint
-- count == source Char count).  Stack: push cp_count (i32), build the byte array via
-- array.new_data, then struct.new $str.
emitLitRef (LString s) =
  let bytes = strBytesW s
  let cpc = stringLength s
  let n = listLen bytes
  let seg = freshStrSeg bytes
  [
    "i32.const " ++ intToString cpc,
    "i32.const 0",
    "i32.const " ++ intToString n,
    "array.new_data $u8arr $strseg_" ++ intToString seg,
    "struct.new $str",
  ]
-- W6: a Char literal is its Unicode codepoint as an i31 immediate (matching the
-- native rep: a Char is a tagged codepoint, not a boxed string).  `LChar` carries a
-- one-char String, so take the codepoint of its sole char (peer to llvm_emit).
emitLitRef (LChar c) = [
  "i32.const " ++ intToString (charCode (arrayGetUnsafe 0 (stringToChars c))),
  "ref.i31",
]

-- ── W6 UTF-8 codec (compiler-local; mirrors llvm_emit.strBytes/utf8Bytes — the
-- no-stdlib rule forbids importing `string`, so the codec is duplicated here). ──
-- the raw UTF-8 bytes of a string, in order.
strBytesW : String -> List Int
strBytesW s = strBytesGoW (stringToChars s) 0

strBytesGoW : Array Char -> Int -> List Int
strBytesGoW cs i =
  if i >= arrayLength cs then
    []
  else
    utf8BytesW (charCode (arrayGetUnsafe i cs)) ++ strBytesGoW cs (i + 1)

-- encode one Unicode codepoint to its UTF-8 bytes (0..255).  Bit fields are disjoint,
-- so `or` is `+` and the masks are `% 64`; no bitwise primitive needed.
utf8BytesW : Int -> List Int
utf8BytesW cp =
  if cp < 128 then
    [cp]
  else if cp < 2048 then
    [192 + cp / 64, 128 + cp % 64]
  else if cp < 65536 then
    [224 + cp / 4096, 128 + (cp / 64) % 64, 128 + cp % 64]
  else
    [
      240 + cp / 262144,
      128 + (cp / 4096) % 64,
      128 + (cp / 64) % 64,
      128 + cp % 64,
    ]

-- escape a byte list for a WAT data-string `"…"`: every byte as `\HH` (lowercase
-- hex per wasm-tools convention; uppercase also parses, lowercase keeps the emitted
-- text stable vs a `wasm-tools print` round-trip).
escWatBytes : List Int -> String
escWatBytes [] = ""
escWatBytes (b::rest) = "\\\{hex2W b}\{escWatBytes rest}"

hex2W : Int -> String
hex2W b = hexDigitW (b / 16) ++ hexDigitW (b % 16)

hexDigitW : Int -> String
hexDigitW d =
  if d < 10 then
    intToString d
  else if d == 10 then
    "a"
  else if d == 11 then
    "b"
  else if d == 12 then
    "c"
  else if d == 13 then
    "d"
  else if d == 14 then
    "e"
  else
    "f"

-- a variable: local/global → get (already (ref eq)); a nullary ctor → its i31 tag;
-- a top-level fn used as a VALUE → build its closure wrapper struct (code =
-- $mdk_w_<f>, arity = its param count, env = []) so it can flow through a (ref eq)
-- slot / be applied indirectly.
-- a fall-through sentinel var → its lowering.  `__ft__<label>` (produced by
-- labelFallthrough in a clause body) → `br <label>`, exiting the clause block to fall
-- through to the next clause.  The bare `__fallthrough__` (NOT rewritten — appears only
-- outside a clause block, e.g. a value-binding body or a context the typechecker proved
-- exhaustive) → a trap stub `unreachable` (the WasmGC peer of llvm_emit's `call void
-- @mdk_oob()`, EMITTER-GAPS.md E3).  PURE functions of the name — no mutable "current
-- label" ref, which this lazily-assembled emitter cannot thread reliably (the strings
-- are forced at final assembly, long after any setRef).
isFtSentinel : String -> Bool
isFtSentinel x = x == "__fallthrough__" || startsWithStr x ftPrefix

ftSentinelInstrs : String -> List String
ftSentinelInstrs x =
  if startsWithStr x ftPrefix then
    ["br " ++ dropPrefix x ftPrefix]
  else
    ["unreachable"]

emitFtSentinel : String -> Option (List String)
emitFtSentinel x = if isFtSentinel x then Some (ftSentinelInstrs x) else None

-- prefix test / drop (compiler-local; no-stdlib).
startsWithStr : String -> String -> Bool
startsWithStr s p = stringLength s >= stringLength p
  && stringSlice 0 (stringLength p) s == p

dropPrefix : String -> String -> String
dropPrefix s p = stringSlice (stringLength p) (stringLength s) s

-- a variable: local/global → get (already (ref eq)); a nullary ctor → its i31 tag;
emitVarRef : Prog -> List String -> Int -> String -> <Mut> List String
emitVarRef prog env d x = match emitFtSentinel x
  Some instrs => instrs
  None => emitVarRefPlain prog env d x

emitVarRefPlain : Prog -> List String -> Int -> String -> <Mut> List String
emitVarRefPlain prog env d x =
  if contains x env then ["local.get $" ++ gname x]
  else if contains x (progValNames prog) then ["global.get $" ++ gname x, "ref.as_non_null"]
  -- the Bool constructors used as VALUES (e.g. an `eq` impl body `… = True`) are
  -- i31 immediates 1/0 — the same rep as `emitLitRef (LBool _)`, so `if` reads them
  -- via `i31.get_u` uniformly.  (Surface `True`/`False` literals desugar to CLit;
  -- these reach the emitter only as bare ctor occurrences, e.g. from impl bodies.)
  else if x == "True" then ["i32.const 1", "ref.i31"]
  else if x == "False" then ["i32.const 0", "ref.i31"]
  else if x == "otherwise" then ["i32.const 1", "ref.i31"]
  -- W9: builtin Char bounds fit in an i31 → emit directly (codepoints 1 / 0x21FFFF).
  else if x == "charMinBound" then ["i32.const 1", "ref.i31"]
  else if x == "charMaxBound" then ["i32.const 2228223", "ref.i31"]
  -- W9: builtin Int/Float bounds (intMinBound/intMaxBound = 64-bit, overflow i31; pi/e
  -- = Float) are W8b-shaped — they appear only in always-retained Bounded/Num impl
  -- bodies (DCE can't prune them), executed only by a program that actually uses them,
  -- which W9 fixtures avoid.  Trap-stub so the program emits.
  -- W8b: the Float math constants pi/e are boxed (struct $float) — the SAME decimal
  -- text the LLVM oracle boxes (3.141592653589793 / 2.718281828459045).  intMin/MaxBound
  -- are 64-bit Ints that overflow i31 and are W8b-shaped; they trap-stub still.
  else if x == "pi" then ["f64.const 3.141592653589793", "struct.new $float"]
  else if x == "e" then ["f64.const 2.718281828459045", "struct.new $float"]
  else if contains x ["intMinBound", "intMaxBound"] then ["unreachable"]
  else if isCtor prog x then
    if ctorArity prog x == 0 then emitCtorConstruct prog env d x []
    else emitCtorEtaClosure prog x
  else if isDeferredFloatExternW x then floatExternStub x
  else if isUnimplStrExternW x then floatExternStub x
  else if contains x (progFnNames prog) then
    let _ = noteFuncRef ("$mdk_w_" ++ x)
    ["ref.func $mdk_w_" ++ x, "i32.const " ++ intToString (progFnArity prog x),
     "array.new_fixed $argarr 0", "struct.new $clos"]
  -- W9: a bare prelude reference synthesized post-mangle (string-interp / `!=`) →
  -- resolve to its `core__`-mangled def and emit the closure wrapper for it.
  else if canonFn prog x != x then emitVarRef prog env d (canonFn prog x)
  -- W9: a str/leaf extern referenced as a VALUE (point-free / passed as an arg) —
  -- build an eta closure wrapping a lifted `$mdk_ext_<name>` that calls the extern
  -- (peer of the LLVM emitExternEtaClosure).  env = [] (externs capture nothing).
  else if isWasmEtaExtern x then emitExternEtaClosure prog x
  else gapL "ref-mode: unbound variable '\{x}' [in \{curBindRef.value}]"

-- W9: lift `$mdk_ext_<name>` (a $codety) that unpacks its $args into synthetic CVar
-- locals and emits the extern call, then build the closure struct at the use site.
emitExternEtaClosure : Prog -> String -> <Mut> List String
emitExternEtaClosure prog name =
  let arity = externArityW name
  let lamName = "$mdk_ext_" ++ name
  let _ = noteFuncRef lamName
  let _ = addLiftedNamed lamName (emitExternEtaDefine prog lamName name arity)
  [
    "ref.func " ++ lamName,
    "i32.const " ++ intToString arity,
    "array.new_fixed $argarr 0",
    "struct.new $clos",
  ]

-- The depth-0 `$__aex*`/`$__raarr*` array-intrinsic scratch locals (a flat copy of the
-- useArrayRef block in w7LocalsAtDepth at depth 0) that an ARRAY-extern eta (func …)
-- must declare to host emitArrayExternRef's loop counter / size / result $arr / list
-- cursor / closure-init-value cells / i64 reinterpret accumulator.
arrayEtaScratchLocals : List String
arrayEtaScratchLocals = [
  "(local $__aexi0 i32)",
  "(local $__aexn0 i32)",
  "(local $__aexarr0 (ref null $arr))",
  "(local $__aexlst0 (ref eq))",
  "(local $__aexf0 (ref eq))",
  "(local $__aexv0 (ref eq))",
  "(local $__aexbits0 i64)",
  "(local $__raarr0 (ref null $arr))",
]

emitExternEtaDefine : Prog -> String -> String -> Int -> <Mut> List String
emitExternEtaDefine prog lamName name arity =
  let params = synthParams arity
  let argPrologue = flatMap (argLoadAt) (zipIdx params 0)
  let argVars = map (p => CVar p AGlobal) params
  -- An ARRAY extern referenced point-free (e.g. `arrayFromList` passed to the byteparser
  -- parse path) must route to emitArrayExternRef — mirroring the DIRECT-call arm at
  -- emitRefApp (isArrayExternW f → emitArrayExternRef).  Without this it fell to
  -- emitLeafExternRef → "unsupported leaf extern".  The array externs use the depth-0
  -- `$__aex*`/`$__raarr*` scratch locals (loop counter, size, result $arr, list cursor,
  -- closure/init/value cells, i64 reinterpret accumulator), which the synthesized eta
  -- (func …) must declare itself (its localLines otherwise only cover the param locals).
  let call = if isStrExternW name then emitStrExternRef prog params 0 name argVars
             else if isArrayExternW name then emitArrayExternRef prog params 0 name argVars
             else emitLeafExternRef prog params 0 name argVars
  let arrayScratch = if isArrayExternW name then arrayEtaScratchLocals else []
  let localLines = map (l => localDeclRef l) params ++ arrayScratch
  ["  (func " ++ lamName ++ " (type $codety) (param $self (ref eq)) (param $args (ref $argarr)) (result (ref eq))"]
    ++ map ("  " ++ _) localLines
    ++ indent (argPrologue ++ call ++ ["return"])
    ++ ["  )"]

-- W9b: a bare/partial ADT constructor of arity > 0 used as a VALUE (`map PVar xs`)
-- — eta-wrap it into a captureless closure whose lifted code function `$mdk_wctor_
-- <Ctor>` unpacks the argarr and allocates the ctor cell.  Peer to llvm_emit's
-- emitCtorEtaClosure: an arity-0 ctor stays the immediate i31 (emitCtorConstruct
-- … []), but an arity-N ctor in value position is a FUNCTION and must be a closure,
-- not a malformed partial struct.new (the pre-W9b bug: emitCtorConstruct unpacked 0
-- args at an N-field struct → stray operands underflow at validate).
emitCtorEtaClosure : Prog -> String -> <Mut> List String
emitCtorEtaClosure prog ctor =
  let arity = ctorArity prog ctor
  let lamName = "$mdk_wctor_" ++ gname ctor
  let _ = noteFuncRef lamName
  let _ = addLiftedNamed lamName (emitCtorEtaDefine prog lamName ctor arity)
  [
    "ref.func " ++ lamName,
    "i32.const " ++ intToString arity,
    "array.new_fixed $argarr 0",
    "struct.new $clos",
  ]

emitCtorEtaDefine : Prog -> String -> String -> Int -> <Mut> List String
emitCtorEtaDefine prog lamName ctor arity =
  let params = synthParams arity
  let argPrologue = flatMap argLoadAt (zipIdx params 0)
  let argVars = map (p => CVar p AGlobal) params
  let body = emitCtorConstruct prog params 0 ctor argVars
  let localLines = map (l => localDeclRef l) params
  [
      "  (func " ++ lamName ++ " (type $codety) (param $self (ref eq)) (param $args (ref $argarr)) (result (ref eq))"
    ]
    ++ map ("  " ++ _) localLines
    ++ indent (argPrologue ++ body ++ ["return"])
    ++ ["  )"]

-- arithmetic / comparison: unbox both operands from i31 to i32, do the i32 op, then
-- re-box (arithmetic → i31 int; comparison → i31 0/1 bool).
emitBinRef : Prog -> List String -> Int -> String -> CExpr -> CExpr -> String -> <Mut> List String
-- W13: `++` is runtime-dispatched (Core IR is type-erased, so we can't tell a
-- String `++` from a List `++` statically).  Both operands stay (ref eq) and
-- $mdk_append inspects the left operand's shape ($str → string concat; i31/$C_Cons
-- → list append), mirroring the LLVM backend's @mdk_append.
emitBinRef prog env d "++" l r _ = emitRefExpr prog env d l
  ++ emitRefExpr prog env d r
  ++ ["call $mdk_append"]
-- W9: `::` is cons — build a $C_Cons cell {tag=0, head=l, tail=r} (same rep the W7
-- list-literal / Cons match machinery uses).  Reached from prelude fns that cons in
-- expression position (e.g. `gen () :: acc` in arbitraryList's where-go).
emitBinRef prog env d "::" l r _ = ["i32.const 0"]
  ++ emitRefExpr prog env d l
  ++ emitRefExpr prog env d r
  ++ ["struct.new $C_Cons"]
-- W8b: Float arithmetic / comparison.  Core IR is type-erased (CBinPrim carries no
-- LTy), so Float-ness is recovered STRUCTURALLY from the operands (a Float lit, pi/e,
-- a Float-returning extern, or a nested Float binop).  SHARED-FLOAT-RESIDUAL §6 C3:
-- the typecheck-stamped scalar-type tag (CBinPrim's 4th field, "Float" when the
-- operands ground to concrete Float) provides a direct route — additive over the
-- structural check, so an absent/non-Float tag falls back to today's path.
emitBinRef prog env d op l r tag =
  if isArithOrCmp op && (tag == "Float" || cexprIsFloat prog env l || cexprIsFloat prog env r) then
    emitFloatBinRef prog env d op l r
  -- layer-9: a ref-mode comparison (`==`/`!=`/`<`/`>`/`<=`/`>=`) in a string-using
  -- program could have String OR Int operands (Core IR is type-erased), so the old
  -- i31-only lowering trapped `illegal cast` on a String operand (e.g. parser
  -- `coalesceStep`'s `n == name`).  Route through the runtime-shape-dispatched
  -- $mdk_value_eq / $mdk_value_cmp ($str → byte compare; immediate → identity/i31).
  -- Pure-int programs (no $str rep) keep the i31 fast path below.
  -- A1 (poly-`Ord`-on-Float sibling): a comparison whose operand is a polymorphic
  -- `Num`/`Ord` param must dispatch on the operand's runtime shape (a boxed $float would
  -- otherwise trap in the int fallback's $mdk_unbox_int ref.cast).  Two routes:
  --   • string-using program (useStrRef, set by the pre-scan → $str declared): the
  --     $str-capable $mdk_value_cmp / $mdk_value_eq, now with $float arms (A2), handle
  --     String, Int AND Float — one path for a poly operand that could be any of them.
  --   • string-free program: the num-only $mdk_value_cmp_num / $mdk_value_eq_num (A0),
  --     which need only $float/$boxint (always declared) — no $str, so no type-section
  --     dependency on the pre-scan's useStrRef (which body emission cannot retroactively set).
  else if isCmpOp op && useStrRef.value then
    let _ = setRef useValueCmpRef True
    let _ = setRef useStrSearchRef True
    let _ = setRef useStrLeafRef True
    emitValueCmpRef prog env d op l r
  else if isCmpOp op && isPolyNumBinop l r then
    let _ = setRef useValueArithRef True
    emitValueCmpNumRef prog env d op l r
  -- A1 (poly-`Num`-on-Float): arithmetic whose operand is a polymorphic `Num` param
  -- routes through the runtime value-tag-dispatched $mdk_value_add/… helper (A0) instead
  -- of the trapping inline int primitive.  The static Int/Float fast paths are unchanged.
  else if isArithOp op && isPolyNumBinop l r then
    let _ = setRef useValueArithRef True
    emitRefExpr prog env d l ++ emitRefExpr prog env d r ++ ["call $mdk_value_" ++ valueArithName op]
  else
    -- layer-17 §2.1: Int arithmetic/comparison computes in i64 over the box/unbox
    -- seam ($mdk_unbox_int / $mdk_box_int), so values outside ±2^30 no longer
    -- truncate.  Arithmetic re-boxes the i64 result; comparisons yield an i31 Bool.
    let li = emitRefExpr prog env d l ++ ["call $mdk_unbox_int"]
    let ri = emitRefExpr prog env d r ++ ["call $mdk_unbox_int"]
    -- B5: concrete-Int `/`/`%` get a divisor-zero guard emitting the coded trap line
    -- (peer of the native emitIntDivZeroChecked) before the raw i64.div_s/rem_s.
    if (op == "/" || op == "%") then
      li ++ ri ++ emitDivZeroGuard op ("$__divr" ++ intToString d) ++ [wasmBinOp64 op, "call $mdk_box_int"]
    else if isCmpOp op then li ++ ri ++ [wasmBinOp64 op, "ref.i31"]
    else li ++ ri ++ [wasmBinOp64 op, "call $mdk_box_int"]

-- A1: a binop with a POLYMORPHIC `Num`/`Ord` operand — a bare CVar bound to a param
-- seeded into numPolyLocalsRef.  Only such operands route to the runtime value-dispatch
-- helpers; literals / computed sub-expressions / concrete-scalar params stay on the fast path.
isPolyNumBinop : CExpr -> CExpr -> <Mut> Bool
isPolyNumBinop l r = isPolyNumOperand l || isPolyNumOperand r

isPolyNumOperand : CExpr -> <Mut> Bool
isPolyNumOperand (CVar x _) = contains x numPolyLocalsRef.value
isPolyNumOperand _ = False

-- A0: arithmetic op → the $mdk_value_<name> helper suffix.
valueArithName : String -> String
valueArithName "+" = "add"
valueArithName "-" = "sub"
valueArithName "*" = "mul"
valueArithName "/" = "div"
valueArithName "%" = "mod"
valueArithName op = panic ("wasm A0: not a value-arith op '" ++ op ++ "'")

-- ── B5: coded runtime-trap helpers (RUNTIME-TRAP-UNIFY-DESIGN §3 (5), §7 forks 1-2) ──
-- The WasmGC peer of the native traps: emit the same coded stderr line the interpreter
-- and medaka_rt.c produce — `runtime error [E-CODE]: <message>\n` — then `unreachable`.
-- The bytes are streamed to stderr via the mdk_write_err_byte host import, FULLY
-- UNROLLED (one i32.const/call pair per byte): no $str value, no data segment, no
-- ref-mode dependency, so the SAME helper works in scalar AND ref mode and only the
-- import (not the $str runtime) is forced.  `unreachable` is stack-polymorphic, so the
-- sequence validates as any result type (mirroring the bare `unreachable` it replaces).
-- Sets useTrapImport so emit{Ref,Scalar}Program declares the host import.
trapByteInstr : Int -> List String
trapByteInstr b = ["i32.const " ++ intToString b, "call $mdk_write_err_byte"]

wasmTrapBytes : String -> <Mut> List String
wasmTrapBytes text =
  let _ = setRef useTrapImport True
  flatMap trapByteInstr (strBytesW text)

-- a full coded trap with a compile-time-fixed message (div/mod/OOB/non-exhaustive).
wasmTrap : String -> String -> <Mut> List String
wasmTrap code msg = wasmTrapBytes "runtime error [\{code}]: \{msg}\n"
  ++ ["unreachable"]

-- B5: guard a concrete-Int div/mod divisor.  Stack in `[dividend:i64, divisor:i64]`;
-- stashes the divisor in `dloc`, traps with the coded [E-DIV-ZERO]/[E-MOD-ZERO] line if
-- it is zero, then restores `[dividend, divisor]` for the following i64.div_s/rem_s.
-- (The `if` has empty block type; the dividend rests untouched beneath it, and the
-- then-branch ends in `unreachable` so the branch is stack-polymorphic.)
emitDivZeroGuard : String -> String -> <Mut> List String
emitDivZeroGuard op dloc =
  let code = if op == "/" then "E-DIV-ZERO" else "E-MOD-ZERO"
  let msg = if op == "/" then "division by zero" else "modulo by zero"
  ["local.set " ++ dloc, "local.get " ++ dloc, "i64.eqz", "if"]
    ++ indent (wasmTrap code msg)
    ++ ["end", "local.get " ++ dloc]

-- layer-9: emit a runtime-shape-dispatched comparison.  `==`/`!=` go through
-- $mdk_value_eq (-> i31 Bool); ordering ops call $mdk_value_cmp (-> plain i32 -1/0/1)
-- then i32-compare the result against 0 for the requested op, re-boxing the Bool i31.
emitValueCmpRef : Prog -> List String -> Int -> String -> CExpr -> CExpr -> <Mut> List String
emitValueCmpRef prog env d op l r =
  let lv = emitRefExpr prog env d l
  let rv = emitRefExpr prog env d r
  if op == "==" then lv ++ rv ++ ["call $mdk_value_eq"]
  else if op == "!=" then
    lv ++ rv ++ ["call $mdk_value_eq", "ref.cast (ref i31)", "i31.get_u", "i32.eqz", "ref.i31"]
  else
    -- ordering: $mdk_value_cmp -> i32 -1/0/1, then compare against 0.
    lv ++ rv ++ ["call $mdk_value_cmp", "i32.const 0", wasmBinOp op, "ref.i31"]

-- A1 (poly-`Ord`-on-Float, string-free program): the num-only peer of emitValueCmpRef.
-- `==`/`!=` go through $mdk_value_eq_num (-> i31 Bool); ordering through $mdk_value_cmp_num
-- (-> i32 -1/0/1).  Both dispatch $float vs int (i31/$boxint) ONLY — no $str — so they
-- need no pre-scan-set type; gated by useValueArithRef alongside the arith helpers.
emitValueCmpNumRef : Prog -> List String -> Int -> String -> CExpr -> CExpr -> <Mut> List String
emitValueCmpNumRef prog env d op l r =
  let lv = emitRefExpr prog env d l
  let rv = emitRefExpr prog env d r
  if op == "==" then
    lv ++ rv ++ ["call $mdk_value_eq_num"]
  else if op == "!=" then
    lv ++ rv ++ [
      "call $mdk_value_eq_num",
      "ref.cast (ref i31)",
      "i31.get_u",
      "i32.eqz",
      "ref.i31",
    ]
  else
    lv ++ rv ++ ["call $mdk_value_cmp_num", "i32.const 0", wasmBinOp op, "ref.i31"]

-- W8b: emit a Float binop.  Arith (+,-,*,/) → unbox both, f64 op, rebox.  `%` has no
-- f64 instruction, so it calls $mdk_float_rem (a - b*trunc(a/b) == fmod == LLVM frem).
-- Comparison (==,!=,<,>,<=,>=) → unbox both, f64 compare → i31 Bool.
emitFloatBinRef : Prog -> List String -> Int -> String -> CExpr -> CExpr -> <Mut> List String
emitFloatBinRef prog env d op l r =
  let lf = emitRefExpr prog env d l ++ ["ref.cast (ref $float)", "struct.get $float 0"]
  let rf = emitRefExpr prog env d r ++ ["ref.cast (ref $float)", "struct.get $float 0"]
  if isCmpOp op then
    lf ++ rf ++ [wasmFloatCmp op, "ref.i31"]
  else if op == "%" then
    lf ++ rf ++ ["call $mdk_float_rem", "struct.new $float"]
  else
    lf ++ rf ++ [wasmFloatArith op, "struct.new $float"]

isArithOrCmp : String -> Bool
isArithOrCmp op =
  contains op ["+", "-", "*", "/", "%", "==", "!=", "<", ">", "<=", ">="]

isCmpOp : String -> Bool
isCmpOp op = contains op ["==", "!=", "<", ">", "<=", ">="]

wasmFloatArith : String -> String
wasmFloatArith "+" = "f64.add"
wasmFloatArith "-" = "f64.sub"
wasmFloatArith "*" = "f64.mul"
wasmFloatArith "/" = "f64.div"
wasmFloatArith op = panic ("wasm W8b: not a Float arith op '" ++ op ++ "'")

wasmFloatCmp : String -> String
wasmFloatCmp "==" = "f64.eq"
wasmFloatCmp "!=" = "f64.ne"
wasmFloatCmp "<" = "f64.lt"
wasmFloatCmp ">" = "f64.gt"
wasmFloatCmp "<=" = "f64.le"
wasmFloatCmp ">=" = "f64.ge"
wasmFloatCmp op = panic ("wasm W8b: not a Float compare op '" ++ op ++ "'")

-- W8b: STRUCTURAL Float detection (Core IR is type-erased).  An expression is Float if
-- it is a Float literal, the pi/e constants (NOT shadowed by a local of that name —
-- `env` carries the bound locals; `Err e => 0 - e`'s `e` is the LOCAL, not Euler's),
-- a Float-returning extern application (intToFloat / randomFloat), a Float arith binop,
-- a unary `-` on a Float, or a let/block/if whose result is Float.  Conservative:
-- anything else → not Float (Int path).  Sufficient for the W8b fixtures.
cexprIsFloat : Prog -> List String -> CExpr -> Bool
cexprIsFloat prog env (CLit (LFloat _)) = True
cexprIsFloat prog env (CVar "pi" _) = not (contains "pi" env)
cexprIsFloat prog env (CVar "e" _) = not (contains "e" env)
-- W8b: a name known to be Float in the current body (an `impl Num Float` param).
cexprIsFloat prog env (CVar x _) = contains x floatLocalsRef.value
-- C3: also True when the binop itself carries an "Float" scalar-tag (e.g. a nested
-- Float binop whose operands are type-lost but the typecheck stamped the node).
cexprIsFloat prog env (CBinPrim op l r tag) = isArithOp op
  && (tag == "Float" || cexprIsFloat prog env l || cexprIsFloat prog env r)
cexprIsFloat prog env (CUnOp "-" x) = cexprIsFloat prog env x
cexprIsFloat prog env (CLet _ (PVar x) _ b) = cexprIsFloat prog (x::env) b
cexprIsFloat prog env (CLet _ _ _ b) = cexprIsFloat prog env b
cexprIsFloat prog env (CBlock stmts) = cexprIsFloatBlock prog env stmts
cexprIsFloat prog env (CIf _ t f) = cexprIsFloat prog env t
  || cexprIsFloat prog env f
-- W-SQLITE-4: a call to a Float-returning extern OR a user fn whose declared
-- signature returns Float (`cellNumF : Cell -> Float`) — additive over the two
-- externs, so a co-located literal is no longer required to detect Float arith.
cexprIsFloat prog env (CApp f a) = match appHead (CApp f a)
  CVar fn _ => not (contains fn env)
    && (contains fn ["intToFloat", "randomFloat"] || fnReturnsFloat fn)
  _ => False
-- W-SQLITE-4 stage 2: a record field access whose field is declared Float.
-- Look up the record ctor that owns `label` (via recFieldsRef) and check if
-- that field's 0-based index is in ctorFloatFieldsRef.
cexprIsFloat prog env (CFieldAccess _ label _) = match findRecByField recFieldsRef.value label
  Some (ctor, labels) =>
    isFloatCtorField ctor (orZeroIdx (indexOfL label labels))
  None => False
cexprIsFloat prog env _ = False

isArithOp : String -> Bool
-- Intentional cross-file duplicate of the same helper in typecheck.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
isArithOp op = contains op ["+", "-", "*", "/", "%"]

-- W-SQLITE-4 stage 2: collect the PVar names that bind Float ctor-payload fields in
-- a PCon pattern.  For `PCon c [PVar x, …]`, for each field index i where ctor c is
-- declared Float (via ctorFloatFieldsRef), collect x if the i-th sub-pattern is a
-- PVar.  Used by emitLeafRef/emitGuardArmRef to seed floatLocalsRef for the arm body.
ctorPatFloatBinders : Pat -> List String
ctorPatFloatBinders (PCon c args) = match lookupAssoc c ctorFloatFieldsRef.value
  Some floatIdxs => ctorPatFloatBindersGo c floatIdxs args 0
  None => []
ctorPatFloatBinders _ = []

ctorPatFloatBindersGo : String -> List Int -> List Pat -> Int -> List String
ctorPatFloatBindersGo _ _ [] _ = []
ctorPatFloatBindersGo c floatIdxs ((PVar x)::rest) i = (if containsInt i floatIdxs then [x] else [])
  ++ ctorPatFloatBindersGo c floatIdxs rest (i + 1)
ctorPatFloatBindersGo c floatIdxs (_::rest) i =
  ctorPatFloatBindersGo c floatIdxs rest (i + 1)

cexprIsFloatBlock : Prog -> List String -> List CStmt -> Bool
cexprIsFloatBlock _ _ [] = False
cexprIsFloatBlock prog env [CSExpr e] = cexprIsFloat prog env e
cexprIsFloatBlock prog env ((CSLet _ (PVar x) _)::rest) =
  cexprIsFloatBlock prog (x::env) rest
cexprIsFloatBlock prog env (_::rest) = cexprIsFloatBlock prog env rest

emitUnRef : Prog -> List String -> Int -> String -> CExpr -> <Mut> List String
emitUnRef prog env d "-" x =
  -- W8b: unary `-` on a Float negates the f64 (f64.neg), reboxing; else integer negate.
  if cexprIsFloat prog env x then
    emitRefExpr prog env d x ++ ["ref.cast (ref $float)", "struct.get $float 0", "f64.neg", "struct.new $float"]
  else
    -- layer-17 §2.1: integer negate over the i64 box/unbox seam.
    let xi = emitRefExpr prog env d x ++ ["call $mdk_unbox_int"]
    ["i64.const 0"] ++ xi ++ ["i64.sub", "call $mdk_box_int"]
emitUnRef prog env d "!" x =
  let xi = emitRefExpr prog env d x ++ ["ref.cast (ref i31)", "i31.get_u"]
  xi ++ ["i32.eqz", "ref.i31"]
emitUnRef _ _ _ op _ = gapL ("ref-mode: unsupported unary op '" ++ op ++ "'")

-- if/else: cond is an i31 Bool — unbox to i32 for the wasm `if`; both branches push
-- a (ref eq).
emitIfRef : Prog -> List String -> Int -> CExpr -> CExpr -> CExpr -> <Mut> List String
emitIfRef prog env d c t f =
  let ci = emitRefExpr prog env d c ++ ["ref.cast (ref i31)", "i31.get_u"]
  let ti = emitRefExpr prog env d t
  let fi = emitRefExpr prog env d f
  ci
    ++ ["if (result (ref eq))"]
    ++ indent ti
    ++ ["else"]
    ++ indent fi
    ++ ["end"]

-- ── W11: irrefutable destructuring let / refutable let-else / assignment ──────
-- An irrefutable `let <pat> = e` (PTuple / single-ctor PCon / PRecord / PCons /
-- PList — all single-shape here, the type proves the shape): emit the RHS once,
-- stash it into the scratch local `$__rf<de>` (de = one slot above whatever the
-- RHS uses, so it never collides), then bind each sub-pattern by field extraction
-- (reusing bindPatRef, the same machinery match-arm leaves use).  Returns the
-- stash+bind instructions and the env extended with the bound vars.
emitDestructureLet : Prog -> List String -> Int -> Pat -> CExpr -> <Mut> (List String, List String)
emitDestructureLet prog env d pat e1 =
  let de = maxIndexAt e1 d + 1
  let sv = scratchLocal de
  let rhs = emitRefExpr prog env d e1 ++ ["local.set $" ++ sv]
  let (binds, env2) = bindPatRef prog env pat ["local.get $" ++ sv]
  (rhs ++ binds, env2)

-- a refutable `let <pat> = e else <els>`: emit e, stash, test the pattern; on a
-- mismatch run `els` (which diverges / returns a value of the same block type);
-- on a match bind the sub-vars and continue with `rest` (the block continuation,
-- passed as the already-emitted instructions producing the block's result value).
emitLetElse : Prog -> List String -> Int -> Pat -> CExpr -> CExpr -> (List String -> <Mut> List String) -> <Mut> List String
emitLetElse prog env d pat e1 els kont =
  let de = maxIndexAt e1 d + 1
  let sv = scratchLocal de
  let okL = "$le_ok" ++ intToString de
  let failL = "$le_fail" ++ intToString de
  let (tests, binds, env2) = patTestBind prog pat ["local.get $" ++ sv] failL env
  let elsI = emitRefExpr prog env d els
  let cont = kont env2
  ["block " ++ okL ++ " (result (ref eq))"]
    ++ indent (["block " ++ failL] ++ indent (emitRefExpr prog env d e1 ++ ["local.set $" ++ sv] ++ tests ++ binds ++ cont ++ ["br " ++ okL]) ++ ["end"] ++ elsI)
    ++ ["end"]

-- tail-position `let <pat> = e else <els>`: both the continuation and the else are
-- in tail position (they return / return_call), so no result block / br is needed —
-- the fail block falls through to the tail `els` and the match path's continuation
-- returns directly from within the block.
emitLetElseTail : Prog -> List String -> Int -> Pat -> CExpr -> CExpr -> (List String -> <Mut> List String) -> <Mut> List String
emitLetElseTail prog env arity pat e1 els kont =
  let de = maxIndexAt e1 0 + 1
  let sv = scratchLocal de
  let failL = "$le_failt" ++ intToString de
  let (tests, binds, env2) = patTestBind prog pat ["local.get $" ++ sv] failL env
  let elsI = emitRefTail prog env arity els
  let cont = kont env2
  ["block " ++ failL]
    ++ indent (emitRefExpr prog env 0 e1 ++ ["local.set $" ++ sv] ++ tests ++ binds ++ cont)
    ++ ["end"]
    ++ elsI

emitLetRef : Prog -> List String -> Int -> Bool -> Pat -> CExpr -> CExpr -> <Mut> List String
emitLetRef prog env d False (PVar x) e1 e2 =
  let i1 = emitRefExpr prog env d e1
  let i2 = emitRefExpr prog (x::env) d e2
  i1 ++ ["local.set $" ++ gname x] ++ i2
emitLetRef prog env d False PWild e1 e2 =
  let i1 = emitRefExpr prog env d e1
  let i2 = emitRefExpr prog env d e2
  i1 ++ ["drop"] ++ i2
emitLetRef prog env d False pat e1 e2 =
  let (binds, env2) = emitDestructureLet prog env d pat e1
  binds ++ emitRefExpr prog env2 d e2
emitLetRef _ _ _ _ _ _ _ = gapL "ref-mode: recursive `let` binding"

emitBlockRef : Prog -> List String -> Int -> List CStmt -> <Mut> List String
emitBlockRef prog env d [CSExpr ex] = emitRefExpr prog env d ex
emitBlockRef prog env d ((CSExpr ex)::rest) = emitRefExpr prog env d ex
  ++ ["drop"]
  ++ emitBlockRef prog env d rest
emitBlockRef prog env d ((CSLet _ (PVar x) ex)::rest) = emitRefExpr prog env d ex
  ++ ["local.set $" ++ gname x]
  ++ emitBlockRef prog (x::env) d rest
emitBlockRef prog env d ((CSLet _ PWild ex)::rest) = emitRefExpr prog env d ex
  ++ ["drop"]
  ++ emitBlockRef prog env d rest
emitBlockRef prog env d ((CSLet _ pat ex)::rest) =
  let (binds, env2) = emitDestructureLet prog env d pat ex
  binds ++ emitBlockRef prog env2 d rest
emitBlockRef prog env d ((CSLetElse pat ex els)::rest) =
  emitLetElse prog env d pat ex els (env2 => emitBlockRef prog env2 d rest)
emitBlockRef prog env d ((CSAssign x ex)::rest) = emitRefExpr prog env d ex
  ++ ["local.set $" ++ gname x]
  ++ emitBlockRef prog env d rest
emitBlockRef _ _ _ [] = gapL "ref-mode: empty block"
emitBlockRef _ _ _ _ = gapL "ref-mode: unsupported block statement"

-- application: a saturated top-level-fn call, or a saturated CONSTRUCTOR application
-- (the W3 ADT construction path).
-- application (non-tail position).  A saturated direct call to a known top-level fn
-- → `call`.  A ctor application → struct.new.  Anything else (a partial / over
-- application of a known fn; an indirect call whose head is a closure value: a local
-- param, a let-bound closure, a returned closure, an immediately-applied lambda) →
-- build an args array + `call $mdk_apply` (the universal arity-dispatched apply).
emitAppRef : Prog -> List String -> Int -> CExpr -> <Mut> List String
emitAppRef prog env d app =
  let (hd, args) = flattenApp app []
  match hd
    CVar f0 _ =>
      let f = canonFn prog f0
      -- the desugared `__fallthrough__ ()` / `__ft__<label> ()` form: ignore the (unit)
      -- arg, lower the sentinel (br to the clause label, or trap stub).  The bare-CVar
      -- form is handled by emitVarRef; this catches the applied form guard chains make.
      if isFtSentinel f0 then ftSentinelInstrs f0
      -- E24 (wasm peer): a LOCALLY-BOUND name (param / let-binding) SHADOWS any same-named
      -- ctor / known top-level fn / extern: it is a runtime closure VALUE, so applying it
      -- is an INDIRECT call, never a direct `call $fn` / ctor.new.  Without this, a HOF
      -- param named like an interface method (`pickEq eq x y = eq x y`, or `cmp`/`compare`/
      -- `map`) that ALSO collides with a top-level fn name fell to the `progFnNames` arm →
      -- a direct `call $<toplevel>` over the WRONG callee (silent miscompile: the top-level
      -- fn ran instead of the param), while `medaka run` and the LLVM build were always
      -- correct.  Mirrors emitVarRefPlain's `contains x env`-first priority for the bare
      -- VALUE reference, and the LLVM emitApp E24 `isLocal`-first guard.
      else if contains f0 env then emitIndirectApp prog env d hd args
      else if isCtor prog f then emitCtorConstruct prog env d f args
      else if f == "Ref" then emitRefBoxNew prog env d args
      else if f == "setRef" then emitRefBoxSet prog env d args
      else if isNetExternW f then gapL ("wasm: net extern '" ++ f ++ "' is native-only — the `net` module cannot target wasm (raw BSD sockets have no WasmGC equivalent). Build for a native target instead.")
      else if isStrExternW f then emitStrExternRef prog env d f args
      else if isLeafExternW f then emitLeafExternRef prog env d f args
      else if isArrayExternW f then emitArrayExternRef prog env d f args
      else if isDeferredFloatExternW f then floatExternStub f
      else if isUnimplStrExternW f then floatExternStub f
      else if contains f (progFnNames prog) && listLen args == progFnArity prog f then
        let argInstrs = flatMap (a => emitRefExpr prog env d a) args
        argInstrs ++ ["call $" ++ gname f]
      else
        emitIndirectApp prog env d hd args
    -- W5: a method occurrence applied to its args (the common return-/arg-position
    -- dispatch shape — a CMethod head under a CApp).  Dispatch on the route.
    CMethod name route implRoutes methRoutes =>
      emitMethodRef prog env d name route implRoutes methRoutes args
    -- W5: a constrained-function occurrence applied to its real args.  The dict
    -- witnesses (from `routes`) are PREPENDED to the args at the call.
    CDict name routes => emitDictRef prog env d name routes args
    _ => emitIndirectApp prog env d hd args

-- ── W6 string / IO externs ───────────────────────────────────────────────────
-- `intToString` : i31 Int → unbox → i64 → $mdk_int_to_str → (ref $str) (an (ref eq)).
-- `stringLength` : (ref $str) → cached cp_count (O(1), §5 INTRINSIC) → i31 Int.
-- `putStr`/`putStrLn` : (ref $str) → byte-write (no/with trailing '\n'); Unit (i31 0).
-- `flushStdout` : no-op (byte writes are unbuffered through the host import); Unit.
-- `charToStr`/`stringConcat` are W6b (charToStr needs a codepoint→$str runtime;
-- stringConcat takes a `List String`, which needs W7 list support).
emitStrExternRef : Prog -> List String -> Int -> String -> List CExpr -> <Mut> List String
emitStrExternRef prog env d "intToString" [a] = emitRefExpr prog env d a
  ++ ["call $mdk_unbox_int", "call $mdk_int_to_str"]
emitStrExternRef prog env d "intToString" _ =
  gapL "wasm W6: intToString takes exactly one argument"
emitStrExternRef prog env d "stringLength" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)", "struct.get $str $cp_count", "ref.i31"]
emitStrExternRef prog env d "stringLength" _ =
  gapL "wasm W6: stringLength takes exactly one argument"
emitStrExternRef prog env d "putStr" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)", "call $mdk_print_str", "i32.const 0", "ref.i31"]
emitStrExternRef prog env d "putStr" _ =
  gapL "wasm W6: putStr takes exactly one argument"
emitStrExternRef prog env d "putStrLn" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)", "call $mdk_print_strln", "i32.const 0", "ref.i31"]
emitStrExternRef prog env d "putStrLn" _ =
  gapL "wasm W6: putStrLn takes exactly one argument"
emitStrExternRef prog env d "ePutStr" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)", "call $mdk_eprint_str", "i32.const 0", "ref.i31"]
emitStrExternRef prog env d "ePutStr" _ =
  gapL "wasm W8: ePutStr takes exactly one argument"
emitStrExternRef prog env d "ePutStrLn" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)", "call $mdk_eprint_strln", "i32.const 0", "ref.i31"]
emitStrExternRef prog env d "ePutStrLn" _ =
  gapL "wasm W8: ePutStrLn takes exactly one argument"
emitStrExternRef _ _ _ "flushStdout" _ = ["i32.const 0", "ref.i31"]
-- charToStr : a Char is an i31 codepoint (ref eq) → unbox to i32 → $mdk_char_to_str.
emitStrExternRef prog env d "charToStr" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_char_to_str"]
emitStrExternRef prog env d "charToStr" _ =
  gapL "wasm W8: charToStr takes exactly one argument"
-- stringConcat : a List String (ref eq) → walk the W7 cons list → fresh $str.
emitStrExternRef prog env d "stringConcat" [a] = emitRefExpr prog env d a
  ++ ["call $mdk_str_concat"]
emitStrExternRef prog env d "stringConcat" _ =
  gapL "wasm W8: stringConcat takes exactly one argument"
-- stringSlice lo hi s : lo/hi are i31 Int codepoint indices, s a $str.
emitStrExternRef prog env d "stringSlice" [lo, hi, s] = emitRefExpr prog env d lo
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ emitRefExpr prog env d hi
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ emitRefExpr prog env d s
  ++ ["ref.cast (ref $str)", "call $mdk_str_slice"]
emitStrExternRef prog env d "stringSlice" _ =
  gapL "wasm W8: stringSlice takes exactly three arguments"
emitStrExternRef prog env d "stringToUpper" [s] = emitRefExpr prog env d s
  ++ ["ref.cast (ref $str)", "call $mdk_str_upper"]
emitStrExternRef prog env d "stringToUpper" _ =
  gapL "wasm W8: stringToUpper takes exactly one argument"
emitStrExternRef prog env d "stringToLower" [s] = emitRefExpr prog env d s
  ++ ["ref.cast (ref $str)", "call $mdk_str_lower"]
emitStrExternRef prog env d "stringToLower" _ =
  gapL "wasm W8: stringToLower takes exactly one argument"
-- hashString : a $str → FNV-1a i32 in [0,2^30) → i31 Int.
emitStrExternRef prog env d "hashString" [s] = emitRefExpr prog env d s
  ++ ["ref.cast (ref $str)", "call $mdk_hash_string", "ref.i31"]
emitStrExternRef prog env d "hashString" _ =
  gapL "wasm W8: hashString takes exactly one argument"
-- W8b: floatToString : a boxed $float → unbox → $mdk_float_to_str → (ref $str).
emitStrExternRef prog env d "floatToString" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $float)", "struct.get $float 0", "call $mdk_float_to_str"]
emitStrExternRef prog env d "floatToString" _ =
  gapL "wasm W8b: floatToString takes exactly one argument"
-- W8b: stringIndexOf needle hay : two $str → Option Int (ref eq).  The runtime fn
-- builds the Some/None result directly (Some idx / None), so no inline ctor here.
emitStrExternRef prog env d "stringIndexOf" [needle, hay] = emitRefExpr prog env d needle
  ++ ["ref.cast (ref $str)"]
  ++ emitRefExpr prog env d hay
  ++ ["ref.cast (ref $str)", "call $mdk_str_index_of"]
emitStrExternRef prog env d "stringIndexOf" _ =
  gapL "wasm W8b: stringIndexOf takes exactly two arguments"
-- W8b: stringCompare a b : two $str → Ordering (ref eq).  The runtime fn returns the
-- Lt/Eq/Gt i31 immediate directly.
emitStrExternRef prog env d "stringCompare" [a, b] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)"]
  ++ emitRefExpr prog env d b
  ++ ["ref.cast (ref $str)", "call $mdk_str_compare"]
emitStrExternRef prog env d "stringCompare" _ =
  gapL "wasm W8b: stringCompare takes exactly two arguments"
-- W11b: stringToChars : String -> Array Char.  Decode the $str's UTF-8 bytes into a
-- fresh $arr of `cp_count` i31 Char codepoints.  The runtime fn builds the $arr.
emitStrExternRef prog env d "stringToChars" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)", "call $mdk_str_to_chars"]
emitStrExternRef prog env d "stringToChars" _ =
  gapL "wasm W11b: stringToChars takes exactly one argument"
-- W11b: stringFromChars : Array Char -> String.  Encode an $arr of i31 Char codepoints
-- into a fresh $str (UTF-8); cp_count = array.len.  The runtime fn builds the $str.
emitStrExternRef prog env d "stringFromChars" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $arr)", "call $mdk_chars_to_str"]
emitStrExternRef prog env d "stringFromChars" _ =
  gapL "wasm W11b: stringFromChars takes exactly one argument"
-- W11b: stringToUtf8Bytes : String -> Array Int.  Copy the $str's $u8arr backing into
-- a fresh $arr of i31 Int bytes (0..255).  stringFromUtf8Bytes : Array Int -> String —
-- blit the low 8 bits of each i31 back into a $u8arr + struct.new $str.
emitStrExternRef prog env d "stringToUtf8Bytes" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)", "call $mdk_str_to_utf8_bytes"]
emitStrExternRef prog env d "stringToUtf8Bytes" _ =
  gapL "wasm W11b: stringToUtf8Bytes takes exactly one argument"
emitStrExternRef prog env d "stringFromUtf8Bytes" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $arr)", "call $mdk_utf8_bytes_to_str"]
emitStrExternRef prog env d "stringFromUtf8Bytes" _ =
  gapL "wasm W11b: stringFromUtf8Bytes takes exactly one argument"
-- W11b: charFromCode : Int -> Option Char.  Range-check the i31 Int (valid = 0..0x10FFFF
-- EXCLUDING surrogates 0xD800..0xDFFF, byte-identical to medaka_rt.c mdk_char_from_code)
-- → Some <char i31> (struct.new $C_Some, ordinal 0) / None (i31 ordinal 1).  Inlined
-- (peer to the runtime-built stringIndexOf Option, but small enough to emit directly).
emitStrExternRef prog env d "charFromCode" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_s", "call $mdk_char_from_code"]
emitStrExternRef prog env d "charFromCode" _ =
  gapL "wasm W11b: charFromCode takes exactly one argument"
-- W9: debugStringLit s : $str -> $str (quote+escape with double-quotes).
emitStrExternRef prog env d "debugStringLit" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)", "call $mdk_debug_string_lit"]
emitStrExternRef prog env d "debugStringLit" _ =
  gapL "wasm W9: debugStringLit takes exactly one argument"
-- W9: debugCharLit c : Char (i31) -> $str (quote+escape with single-quotes).
emitStrExternRef prog env d "debugCharLit" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_debug_char_lit"]
emitStrExternRef prog env d "debugCharLit" _ =
  gapL "wasm W9: debugCharLit takes exactly one argument"
-- layer-6: stringToFloat : String -> Option Float.
-- Push the $str's bytes via the path channel, call mdk_str_to_float -> f64, return
-- Option Float (Some(boxed $float) | None) via the WAT runtime $mdk_string_to_float.
emitStrExternRef prog env d "stringToFloat" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $str)", "call $mdk_string_to_float"]
emitStrExternRef prog env d "stringToFloat" _ =
  gapL "wasm layer-6: stringToFloat takes exactly one argument"
emitStrExternRef _ _ _ name _ =
  gapL ("wasm W6: unsupported string extern '" ++ name ++ "'")

-- ── W8 RNG + hash LEAF externs (RUNTIME-DESIGN §5 RNG / §5 hash) ─────────────
-- RNG: randomInt lo hi (i31 Int args → $mdk_random_int → i31 Int, INCLUSIVE);
-- randomBool/randomChar take a Unit arg (emitted + dropped) → i31 Bool/Char;
-- setSeed unboxes its i31 Int to i64 into the seed global.  Hash: hashInt/hashChar
-- ── Ref / setRef / .value — $refbox mutable-cell externs ───────────────────
-- `Ref x`     : allocate a fresh 1-field mutable $refbox, storing x as (ref eq).
-- `setRef r v` : overwrite field 0 of r's $refbox; result is Unit (i31 0).
-- `.value`    : struct.get the mutable field 0; handled in emitFieldAccessRef.
emitRefBoxNew : Prog -> List String -> Int -> List CExpr -> <Mut> List String
emitRefBoxNew prog env d [x] = emitRefExpr prog env d x
  ++ ["struct.new $refbox"]
emitRefBoxNew prog env d _ = gapL "wasm Ref: Ref takes exactly one argument"

-- `setRef r v` : struct.set $refbox 0 ; returns Unit.
-- WAT stack order for struct.set is [structref, value] (ref on top first).
emitRefBoxSet : Prog -> List String -> Int -> List CExpr -> <Mut> List String
emitRefBoxSet prog env d [r, v] = emitRefExpr prog env d r
  ++ ["ref.cast (ref $refbox)"]
  ++ emitRefExpr prog env d v
  ++ ["struct.set $refbox 0", "i32.const 0", "ref.i31"]
emitRefBoxSet prog env d _ = gapL "wasm Ref: setRef takes exactly two arguments"

-- untag the i31 value to i32 (the runtime sign-extends to i64, matching the native
-- signed `tagged>>1`); hashBool passes the 0/1 i31.  All hash results fit i31
-- (masked to 2^30-1, non-negative).  randomFloat / hashFloat are DEFERRED (W8b —
-- they need Float boxing + the %.12g float formatter; see the gap arms).
emitLeafExternRef : Prog -> List String -> Int -> String -> List CExpr -> <Mut> List String
emitLeafExternRef prog env d "randomInt" [lo, hi] = emitRefExpr prog env d lo
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ emitRefExpr prog env d hi
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ ["call $mdk_random_int", "ref.i31"]
emitLeafExternRef prog env d "randomInt" _ =
  gapL "wasm W8: randomInt takes exactly two arguments"
emitLeafExternRef prog env d "randomBool" [u] = emitRefExpr prog env d u
  ++ ["drop", "call $mdk_random_bool", "ref.i31"]
emitLeafExternRef prog env d "randomBool" _ =
  gapL "wasm W8: randomBool takes exactly one (Unit) argument"
emitLeafExternRef prog env d "randomChar" [u] = emitRefExpr prog env d u
  ++ ["drop", "call $mdk_random_char", "ref.i31"]
emitLeafExternRef prog env d "randomChar" _ =
  gapL "wasm W8: randomChar takes exactly one (Unit) argument"
emitLeafExternRef prog env d "setSeed" [n] = emitRefExpr prog env d n
  ++ [
    "ref.cast (ref i31)",
    "i31.get_s",
    "i64.extend_i32_s",
    "global.set $mdk_rng_state",
    "i32.const 0",
    "ref.i31",
  ]
emitLeafExternRef prog env d "setSeed" _ =
  gapL "wasm W8: setSeed takes exactly one argument"
emitLeafExternRef prog env d "hashInt" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_s", "call $mdk_hash_int", "ref.i31"]
emitLeafExternRef prog env d "hashInt" _ =
  gapL "wasm W8: hashInt takes exactly one argument"
emitLeafExternRef prog env d "hashChar" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_hash_int", "ref.i31"]
emitLeafExternRef prog env d "hashChar" _ =
  gapL "wasm W8: hashChar takes exactly one argument"
emitLeafExternRef prog env d "hashBool" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_hash_bool", "ref.i31"]
emitLeafExternRef prog env d "hashBool" _ =
  gapL "wasm W8: hashBool takes exactly one argument"
-- W11: charCode : Char -> Int — a Char is an i31 codepoint immediate.  Cast to i31,
-- read the unsigned payload (the codepoint), wrap back as an i31 Int.  The unbox +
-- rebox is identity on the bits (both Char and Int are i31 codepoint / integer), but
-- the cast ensures Wasm's type-safe path through (ref eq).
emitLeafExternRef prog env d "charCode" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "ref.i31"]
emitLeafExternRef prog env d "charCode" _ =
  gapL "wasm W11: charCode takes exactly one argument"
-- W11b: char classification predicates (ASCII-only, byte-identical to medaka_rt.c).
-- Char is i31 codepoint; unbox with i31.get_u, call WAT helper, result is i32 0/1 → ref.i31.
-- charIsAlpha c → (c>='a'&&c<='z')||(c>='A'&&c<='Z')
emitLeafExternRef prog env d "charIsAlpha" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_char_is_alpha", "ref.i31"]
emitLeafExternRef prog env d "charIsAlpha" _ =
  gapL "wasm W11b: charIsAlpha takes exactly one argument"
-- charIsSpace c → c==32 || (c>=9 && c<=13)
emitLeafExternRef prog env d "charIsSpace" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_char_is_space", "ref.i31"]
emitLeafExternRef prog env d "charIsSpace" _ =
  gapL "wasm W11b: charIsSpace takes exactly one argument"
-- charIsUpper c → c>='A'&&c<='Z'
emitLeafExternRef prog env d "charIsUpper" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_char_is_upper", "ref.i31"]
emitLeafExternRef prog env d "charIsUpper" _ =
  gapL "wasm W11b: charIsUpper takes exactly one argument"
-- charIsLower c → c>='a'&&c<='z'
emitLeafExternRef prog env d "charIsLower" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_char_is_lower", "ref.i31"]
emitLeafExternRef prog env d "charIsLower" _ =
  gapL "wasm W11b: charIsLower takes exactly one argument"
-- charIsPunct: exact set from medaka_rt.c switch — Unicode Pc/Pd/Pe/Pf/Pi/Po/Ps for ASCII.
emitLeafExternRef prog env d "charIsPunct" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_char_is_punct", "ref.i31"]
emitLeafExternRef prog env d "charIsPunct" _ =
  gapL "wasm W11b: charIsPunct takes exactly one argument"
-- charToUpper c → if c>='a'&&c<='z' then c-32 else c  (result = Char i31 codepoint)
emitLeafExternRef prog env d "charToUpper" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_char_to_upper", "ref.i31"]
emitLeafExternRef prog env d "charToUpper" _ =
  gapL "wasm W11b: charToUpper takes exactly one argument"
-- charToLower c → if c>='A'&&c<='Z' then c+32 else c  (result = Char i31 codepoint)
emitLeafExternRef prog env d "charToLower" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_u", "call $mdk_char_to_lower", "ref.i31"]
emitLeafExternRef prog env d "charToLower" _ =
  gapL "wasm W11b: charToLower takes exactly one argument"
-- W8b Float leaf externs.  intToFloat : i31 Int → $mdk_int_to_float → boxed $float.
-- floatToInt : $float → $mdk_float_to_int → i31 Int.  hashFloat : $float → masked i32 →
-- i31.  randomFloat : Unit arg dropped → $mdk_random_float → boxed $float.
emitLeafExternRef prog env d "intToFloat" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref i31)", "i31.get_s", "call $mdk_int_to_float"]
emitLeafExternRef prog env d "intToFloat" _ =
  gapL "wasm W8b: intToFloat takes exactly one argument"
emitLeafExternRef prog env d "floatToInt" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $float)", "call $mdk_float_to_int", "ref.i31"]
emitLeafExternRef prog env d "floatToInt" _ =
  gapL "wasm W8b: floatToInt takes exactly one argument"
emitLeafExternRef prog env d "hashFloat" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $float)", "call $mdk_hash_float", "ref.i31"]
emitLeafExternRef prog env d "hashFloat" _ =
  gapL "wasm W8b: hashFloat takes exactly one argument"
emitLeafExternRef prog env d "randomFloat" [u] = emitRefExpr prog env d u
  ++ ["drop", "call $mdk_random_float"]
emitLeafExternRef prog env d "randomFloat" _ =
  gapL "wasm W8b: randomFloat takes exactly one (Unit) argument"
-- W12 IO host-surface externs.  readFile/fileExists/getEnv take a $str path/name;
-- args takes a Unit (dropped); exit takes an i31 Int.  Each routes through the
-- byte-channel host-import runtime (ioHostRuntimeLines).  readFile returns a Result
-- (ref eq), fileExists a Bool i31, getEnv an Option (ref eq), args a List (ref eq),
-- exit traps (mdk_exit + unreachable, stack-polymorphic like panic).
emitLeafExternRef prog env d "readFile" [p] = emitRefExpr prog env d p
  ++ ["ref.cast (ref $str)", "call $mdk_read_file_io"]
emitLeafExternRef prog env d "readFile" _ =
  gapL "wasm W12: readFile takes exactly one argument"
-- canonicalizePath : String -> String — IDENTITY on the wasm host (no realpath in a
-- browser vfs).  Emit the $str argument and leave it on the stack as the result.
emitLeafExternRef prog env d "canonicalizePath" [p] = emitRefExpr prog env d p
emitLeafExternRef prog env d "canonicalizePath" _ =
  gapL "wasm: canonicalizePath takes exactly one argument"
emitLeafExternRef prog env d "fileExists" [p] = emitRefExpr prog env d p
  ++ ["ref.cast (ref $str)", "call $mdk_file_exists_io"]
emitLeafExternRef prog env d "fileExists" _ =
  gapL "wasm W12: fileExists takes exactly one argument"
emitLeafExternRef prog env d "getEnv" [n] = emitRefExpr prog env d n
  ++ ["ref.cast (ref $str)", "call $mdk_get_env_io"]
emitLeafExternRef prog env d "getEnv" _ =
  gapL "wasm W12: getEnv takes exactly one argument"
emitLeafExternRef prog env d "args" [u] = emitRefExpr prog env d u
  ++ ["drop", "call $mdk_args_io"]
emitLeafExternRef prog env d "args" args =
  gapL "wasm W12: args takes exactly one (Unit) argument"
emitLeafExternRef prog env d "exit" [code] = emitRefExpr prog env d code
  ++ ["ref.cast (ref i31)", "i31.get_s", "call $mdk_exit", "unreachable"]
emitLeafExternRef prog env d "exit" _ =
  gapL "wasm W12: exit takes exactly one argument"
-- stage-D: byte-clean file I/O.  readFileBytes returns a Result String (Array Int);
-- writeFileBytes takes (path, Array Int) and returns Result String Unit.  Both route
-- into the fileBytes host seam ($mdk_read_file_bytes_io / $mdk_write_file_bytes_io).
emitLeafExternRef prog env d "readFileBytes" [p] = emitRefExpr prog env d p
  ++ ["ref.cast (ref $str)", "call $mdk_read_file_bytes_io"]
emitLeafExternRef prog env d "readFileBytes" _ =
  gapL "wasm stage-D: readFileBytes takes exactly one argument"
emitLeafExternRef prog env d "writeFileBytes" [p, arr] = emitRefExpr prog env d p
  ++ ["ref.cast (ref $str)"]
  ++ emitRefExpr prog env d arr
  ++ ["ref.cast (ref $arr)", "call $mdk_write_file_bytes_io"]
emitLeafExternRef prog env d "writeFileBytes" _ =
  gapL "wasm stage-D: writeFileBytes takes exactly two arguments"
-- W10/B5: `panic msg` → stream the coded line `runtime error [E-PANIC]: <msg>\n` to
-- stderr, then `unreachable` (peer of native @mdk_panic / the interp's runtimePanic).
-- The fixed prefix is unrolled to byte-writes; the user message (a $str (ref eq), any
-- expression) is streamed through $mdk_eprint_str (forced via useEPutRef in noteW8Extern
-- for `panic`), then a trailing newline byte.  `unreachable` is stack-polymorphic, so it
-- validates as any result type.
emitLeafExternRef prog env d "panic" [msg] = wasmTrapBytes "runtime error [E-PANIC]: "
  ++ emitRefExpr prog env d msg
  ++ ["ref.cast (ref $str)", "call $mdk_eprint_str"]
  ++ trapByteInstr 10
  ++ ["unreachable"]
emitLeafExternRef prog env d "panic" _ =
  gapL "wasm W10: panic takes exactly one argument"
-- stage-A: bitwise / shift externs (Int -> Int -> Int).  Args are (ref eq) boxed Ints;
-- unbox both to i64 via $mdk_unbox_int, apply the i64 op, rebox via $mdk_box_int.
-- shiftRight uses i64.shr_u (LOGICAL) — shiftRight is defined as logical in runtime/medaka_rt.c
-- (">> on the untagged non-negative 63-bit value == OCaml lsr").
emitLeafExternRef prog env d "bitAnd" [a, b] = emitRefExpr prog env d a
  ++ ["call $mdk_unbox_int"]
  ++ emitRefExpr prog env d b
  ++ ["call $mdk_unbox_int"]
  ++ ["i64.and", "call $mdk_box_int"]
emitLeafExternRef prog env d "bitAnd" _ =
  gapL "wasm stage-A: bitAnd takes exactly two arguments"
emitLeafExternRef prog env d "shiftLeft" [a, b] = emitRefExpr prog env d a
  ++ ["call $mdk_unbox_int"]
  ++ emitRefExpr prog env d b
  ++ ["call $mdk_unbox_int"]
  ++ ["i64.shl", "call $mdk_box_int"]
emitLeafExternRef prog env d "shiftLeft" _ =
  gapL "wasm stage-A: shiftLeft takes exactly two arguments"
emitLeafExternRef prog env d "shiftRight" [a, b] = emitRefExpr prog env d a
  ++ ["call $mdk_unbox_int"]
  ++ emitRefExpr prog env d b
  ++ ["call $mdk_unbox_int"]
  ++ ["i64.shr_u", "call $mdk_box_int"]
emitLeafExternRef prog env d "shiftRight" _ =
  gapL "wasm stage-A: shiftRight takes exactly two arguments"
emitLeafExternRef _ _ _ name _ =
  gapL ("wasm W8: unsupported leaf extern '" ++ name ++ "'")

-- ── W10: Array intrinsic externs ─────────────────────────────────────────────
-- All work over `$arr = (array (mut (ref eq)))`.  Index/size args are i31 Ints
-- (unboxed to i32); element args are (ref eq).  NOTE the arg orders (runtime.mdk):
--   arrayLength    arr               → array.len → i31
--   arrayGetUnsafe idx arr           → (idx FIRST) cast arr, array.get
--   arrayMake      size init         → array.new $arr (init, size)
--   arrayMakeWith  size f            → alloc size, loop i: array.set (f applied to i)
--   arrayCopy      arr               → array.new (len) + array.copy
--   arraySetUnsafe idx val arr       → array.set; result Unit (i31 0)
--   arrayFromList  list              → alloc (length list), loop-fill from cons cells
emitArrayExternRef : Prog -> List String -> Int -> String -> List CExpr -> <Mut> List String
emitArrayExternRef prog env d "arrayLength" [a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $arr)", "array.len", "ref.i31"]
emitArrayExternRef prog env d "arrayLength" _ =
  gapL "wasm W10: arrayLength takes exactly one argument"
-- idx is the FIRST arg, the array the SECOND.  Cast arr, unbox idx, array.get.
emitArrayExternRef prog env d "arrayGetUnsafe" [i, a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $arr)"]
  ++ emitRefExpr prog env d i
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ ["array.get $arr", "ref.as_non_null"]
emitArrayExternRef prog env d "arrayGetUnsafe" _ =
  gapL "wasm W10: arrayGetUnsafe takes exactly two arguments"
-- size FIRST, init SECOND.  array.new takes (init, size) from the stack.
emitArrayExternRef prog env d "arrayMake" [n, init] = emitRefExpr prog env d init
  ++ emitRefExpr prog env d n
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ ["array.new $arr"]
emitArrayExternRef prog env d "arrayMake" _ =
  gapL "wasm W10: arrayMake takes exactly two arguments"
emitArrayExternRef prog env d "arrayCopy" [a] =
  let sfx = intToString d
  let srcL = "$__aexarr" ++ sfx
  let dstL = "$__raarr" ++ sfx
  let nL = "$__aexn" ++ sfx
  emitRefExpr prog env d a
    ++ ["ref.cast (ref $arr)", "local.set " ++ srcL]
    ++ ["local.get " ++ srcL, "ref.as_non_null", "array.len", "local.set " ++ nL]
    ++ [
      "i32.const 0",
      "ref.i31",
      "local.get " ++ nL,
      "array.new $arr",
      "local.set " ++ dstL,
    ]
    ++ [
      "local.get " ++ dstL,
      "ref.as_non_null",
      "i32.const 0",
      "local.get " ++ srcL,
      "ref.as_non_null",
      "i32.const 0",
      "local.get " ++ nL,
      "array.copy $arr $arr",
    ]
    ++ ["local.get " ++ dstL, "ref.as_non_null"]
emitArrayExternRef prog env d "arrayCopy" _ =
  gapL "wasm W10: arrayCopy takes exactly one argument"
-- idx, val, arr.  array.set takes (arrayref, index, value); result Unit (i31 0).
emitArrayExternRef prog env d "arraySetUnsafe" [i, v, a] = emitRefExpr prog env d a
  ++ ["ref.cast (ref $arr)"]
  ++ emitRefExpr prog env d i
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ emitRefExpr prog env d v
  ++ ["array.set $arr", "i32.const 0", "ref.i31"]
emitArrayExternRef prog env d "arraySetUnsafe" _ =
  gapL "wasm W10: arraySetUnsafe takes exactly three arguments"
-- size FIRST, f SECOND.  Alloc size slots (init 0), then loop i=0..n-1:
-- array.set arr i (apply f [i]).  f is applied via the universal $mdk_apply.
emitArrayExternRef prog env d "arrayMakeWith" [n, f] =
    let sfx = intToString d
    let arrL = "$__aexarr" ++ sfx
    let iL = "$__aexi" ++ sfx
    let nL = "$__aexn" ++ sfx
    let fL = "$__aexf" ++ sfx
    emitRefExpr prog env d n ++ ["ref.cast (ref i31)", "i31.get_s", "local.set " ++ nL]
      ++ emitRefExpr prog env d f ++ ["local.set " ++ fL]
      ++ ["i32.const 0", "ref.i31", "local.get " ++ nL, "array.new $arr", "local.set " ++ arrL]
      ++ ["i32.const 0", "local.set " ++ iL]
      ++ ["block $aexd" ++ sfx, "loop $aexl" ++ sfx]
      ++ ["local.get " ++ iL, "local.get " ++ nL, "i32.ge_s", "br_if $aexd" ++ sfx]
      ++ ["local.get " ++ arrL, "ref.as_non_null", "local.get " ++ iL]
      -- value = f applied to (i31 i): build a 1-element $argarr, call $mdk_apply
      ++ ["local.get " ++ fL, "local.get " ++ iL, "ref.i31", "array.new_fixed $argarr 1", "call $mdk_apply"]
      ++ ["array.set $arr"]
      ++ ["local.get " ++ iL, "i32.const 1", "i32.add", "local.set " ++ iL]
      ++ ["br $aexl" ++ sfx, "end", "end"]
      ++ ["local.get " ++ arrL, "ref.as_non_null"]
emitArrayExternRef prog env d "arrayMakeWith" _ =
  gapL "wasm W10: arrayMakeWith takes exactly two arguments"
-- count the list (a $C_Cons chain ending in an i31 Nil), alloc that many slots,
-- walk the chain again filling cells in order.  Two-pass over a $C_Cons cursor.
emitArrayExternRef prog env d "arrayFromList" [lst] =
    let sfx = intToString d
    let arrL = "$__aexarr" ++ sfx
    let iL = "$__aexi" ++ sfx
    let nL = "$__aexn" ++ sfx
    let curL = "$__aexlst" ++ sfx
    -- pass 1: length.  cursor = lst; while not i31: n++, cursor = tail.
    emitRefExpr prog env d lst ++ ["local.set " ++ curL]
      ++ ["i32.const 0", "local.set " ++ nL]
      ++ ["block $aexcd" ++ sfx, "loop $aexcl" ++ sfx]
      ++ ["local.get " ++ curL, "ref.test (ref i31)", "br_if $aexcd" ++ sfx]
      ++ ["local.get " ++ nL, "i32.const 1", "i32.add", "local.set " ++ nL]
      ++ ["local.get " ++ curL, "ref.cast (ref $C_Cons)", "struct.get $C_Cons 2", "local.set " ++ curL]
      ++ ["br $aexcl" ++ sfx, "end", "end"]
    -- alloc n slots
      ++ ["i32.const 0", "ref.i31", "local.get " ++ nL, "array.new $arr", "local.set " ++ arrL]
    -- pass 2: fill.  cursor = lst; i = 0; while not i31: set arr[i]=head, i++, cursor=tail.
      ++ emitRefExpr prog env d lst ++ ["local.set " ++ curL]
      ++ ["i32.const 0", "local.set " ++ iL]
      ++ ["block $aexfd" ++ sfx, "loop $aexfl" ++ sfx]
      ++ ["local.get " ++ curL, "ref.test (ref i31)", "br_if $aexfd" ++ sfx]
      ++ ["local.get " ++ arrL, "ref.as_non_null", "local.get " ++ iL]
      ++ ["local.get " ++ curL, "ref.cast (ref $C_Cons)", "struct.get $C_Cons 1"]
      ++ ["array.set $arr"]
      ++ ["local.get " ++ iL, "i32.const 1", "i32.add", "local.set " ++ iL]
      ++ ["local.get " ++ curL, "ref.cast (ref $C_Cons)", "struct.get $C_Cons 2", "local.set " ++ curL]
      ++ ["br $aexfl" ++ sfx, "end", "end"]
      ++ ["local.get " ++ arrL, "ref.as_non_null"]
emitArrayExternRef prog env d "arrayFromList" _ =
  gapL "wasm W10: arrayFromList takes exactly one argument"
-- stage-A: arrayBlit src srcOff dst dstOff len — copies `len` elements from src[srcOff..]
-- into dst[dstOff..] using `array.copy $arr $arr`.  Arg order from runtime.mdk: src, srcOff,
-- dst, dstOff, len.  Wasm array.copy takes: [dst, dstOff, src, srcOff, len] (all i32).
-- Int args (offsets/len) are i31 small ints; unbox with i31.get_s to i32.  Result = Unit.
emitArrayExternRef prog env d "arrayBlit" [src, srcOff, dst, dstOff, len] = emitRefExpr prog env d dst
  ++ ["ref.cast (ref $arr)"]
  ++ emitRefExpr prog env d dstOff
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ emitRefExpr prog env d src
  ++ ["ref.cast (ref $arr)"]
  ++ emitRefExpr prog env d srcOff
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ emitRefExpr prog env d len
  ++ ["ref.cast (ref i31)", "i31.get_s"]
  ++ ["array.copy $arr $arr", "i32.const 0", "ref.i31"]
emitArrayExternRef prog env d "arrayBlit" _ =
  gapL "wasm stage-A: arrayBlit takes exactly five arguments"
-- stage-A: arrayFill val arr — sets every element of arr to val via a loop.
-- Reuses the $__aex* locals declared by w7LocalsAtDepth when useArrayRef.
emitArrayExternRef prog env d "arrayFill" [val, arr] =
  let sfx = intToString d
  let arrL = "$__aexarr" ++ sfx
  let iL = "$__aexi" ++ sfx
  let nL = "$__aexn" ++ sfx
  let vL = "$__aexv" ++ sfx
  emitRefExpr prog env d arr
    ++ ["ref.cast (ref $arr)", "local.set " ++ arrL]
    ++ ["local.get " ++ arrL, "ref.as_non_null", "array.len", "local.set " ++ nL]
    ++ emitRefExpr prog env d val
    ++ ["local.set " ++ vL]
    ++ ["i32.const 0", "local.set " ++ iL]
    ++ ["block $afld" ++ sfx, "loop $afll" ++ sfx]
    ++ ["local.get " ++ iL, "local.get " ++ nL, "i32.ge_s", "br_if $afld" ++ sfx]
    ++ [
      "local.get " ++ arrL,
      "ref.as_non_null",
      "local.get " ++ iL,
      "local.get " ++ vL,
    ]
    ++ ["array.set $arr"]
    ++ ["local.get " ++ iL, "i32.const 1", "i32.add", "local.set " ++ iL]
    ++ ["br $afll" ++ sfx, "end", "end"]
    ++ ["i32.const 0", "ref.i31"]
emitArrayExternRef prog env d "arrayFill" _ =
  gapL "wasm stage-A: arrayFill takes exactly two arguments"
-- stage-B: floatToBytes64 : Float -> Array Int — reinterpret the boxed $float's f64 to
-- an i64 via i64.reinterpret_f64, then extract 8 bytes BIG-ENDIAN (byte 0 = bits>>56,
-- byte 7 = bits&0xFF) into a fresh 8-element $arr, each byte a boxed Int.  Matches
-- runtime/medaka_rt.c:mdk_float_to_bytes64 exactly (cell[i+1] = byte at (bits>>(8*(7-i)))&0xFF).
emitArrayExternRef prog env d "floatToBytes64" [f] =
    let sfx = intToString d
    let arrL = "$__aexarr" ++ sfx
    let bitsL = "$__aexbits" ++ sfx
    emitRefExpr prog env d f ++ ["ref.cast (ref $float)", "struct.get $float 0", "i64.reinterpret_f64", "local.set " ++ bitsL]
      -- alloc 8 slots (placeholder element, overwritten below)
      ++ ["i32.const 0", "ref.i31", "i32.const 8", "array.new $arr", "local.set " ++ arrL]
      ++ flatMap (i => f2bByteSet arrL bitsL i) [0, 1, 2, 3, 4, 5, 6, 7]
      ++ ["local.get " ++ arrL, "ref.as_non_null"]
emitArrayExternRef prog env d "floatToBytes64" _ =
  gapL "wasm stage-B: floatToBytes64 takes exactly one argument"
-- stage-B: bytesToFloat64 : Array Int -> Int -> Float — read 8 bytes BIG-ENDIAN from the
-- $arr starting at index `off`, assemble an i64 (byte at off+0 → bits 56..63), then
-- f64.reinterpret_i64 + box into a $float.  Matches runtime/medaka_rt.c:mdk_bytes_to_float64.
emitArrayExternRef prog env d "bytesToFloat64" [arr, off] =
  let sfx = intToString d
  let arrL = "$__aexarr" ++ sfx
  let offL = "$__aexi" ++ sfx
  let bitsL = "$__aexbits" ++ sfx
  emitRefExpr prog env d arr
    ++ ["ref.cast (ref $arr)", "local.set " ++ arrL]
    ++ emitRefExpr prog env d off
    ++ ["ref.cast (ref i31)", "i31.get_s", "local.set " ++ offL]
    ++ ["i64.const 0", "local.set " ++ bitsL]
    ++ flatMap (i => b2fByteRead arrL offL bitsL i) [0, 1, 2, 3, 4, 5, 6, 7]
    ++ ["local.get " ++ bitsL, "f64.reinterpret_i64", "struct.new $float"]
emitArrayExternRef prog env d "bytesToFloat64" _ =
  gapL "wasm stage-B: bytesToFloat64 takes exactly two arguments"
emitArrayExternRef _ _ _ name _ =
  gapL ("wasm W10: unsupported array extern '" ++ name ++ "'")

-- stage-B helpers: set arr[i] = boxed byte ((bits >> (8*(7-i))) & 0xFF); big-endian.
f2bByteSet : String -> String -> Int -> List String
f2bByteSet arrL bitsL i = [
  "local.get " ++ arrL,
  "ref.as_non_null",
  "i32.const " ++ intToString i,
  "local.get " ++ bitsL,
  "i64.const " ++ intToString (8 * (7 - i)),
  "i64.shr_u",
  "i64.const 255",
  "i64.and",
  "call $mdk_box_int",
  "array.set $arr",
]
-- read arr[off+i] (a boxed Int 0..255), shift to its big-endian position, OR into bits.
b2fByteRead : String -> String -> String -> Int -> List String
b2fByteRead arrL offL bitsL i = [
  "local.get " ++ arrL,
  "ref.as_non_null",
  "local.get " ++ offL,
  "i32.const " ++ intToString i,
  "i32.add",
  "array.get $arr",
  "ref.as_non_null",
  "call $mdk_unbox_int",
  "i64.const 255",
  "i64.and",
  "i64.const " ++ intToString (8 * (7 - i)),
  "i64.shl",
  "local.get " ++ bitsL,
  "i64.or",
  "local.set " ++ bitsL,
]

-- an indirect application: emit the head (a (ref eq) closure value), pack the args
-- into an $argarr, and `call $mdk_apply` — which dispatches on the closure's arity
-- (exact / under→PAP / over→saturate+reapply).  This makes over/under/exact uniform
-- and reads arity from the value (never a name-keyed table), per WASMGC-DESIGN §11.
emitIndirectApp : Prog -> List String -> Int -> CExpr -> List CExpr -> <Mut> List String
emitIndirectApp prog env d hd args =
  let hi = emitRefExpr prog env d hd
  let arr = emitArgsArray prog env d args
  hi ++ arr ++ ["call $mdk_apply"]

-- build an $argarr holding the emitted args, in order.  `array.new_fixed` takes the
-- element values from the stack — so emit all args (each leaves a (ref eq)) then one
-- array.new_fixed of the right length.  Zero args → an empty array.
emitArgsArray : Prog -> List String -> Int -> List CExpr -> <Mut> List String
emitArgsArray prog env d args =
  let n = listLen args
  let argInstrs = flatMap (a => emitRefExpr prog env d a) args
  argInstrs ++ ["array.new_fixed $argarr " ++ intToString n]

-- ── §4.2 tail-position emission (guaranteed TCO) ─────────────────────────────
-- ════════════════════════════════════════════════════════════════════════════
-- Stage-1 WasmGC self-recursive TMC (destination-passing loop) — WASMGC-TRMC-DESIGN §7
-- ════════════════════════════════════════════════════════════════════════════
-- When a top-level non-dict self-recursive define is `trmcEligible` for the self-only
-- cons/ctor-tail shape (a), we emit the body as a LOOP that conses into a mutable
-- destination cell instead of issuing the stack-growing recursive call.  The
-- destination-passing context (the self-ref, arity, the param locals, the loop/exit
-- labels, the uniform cell struct name + recursive-field index) is carried in a
-- module-level ref so the existing tail-descent (emitRefTail / emitDecisionTail) can
-- redirect its cons/ctor/base leaves without threading a new argument through every arm.
-- The ENGINE never sees a recursive `call`/`return_call` to the self fn inside the loop
-- (the decisive "TMC fired" property): a cons/ctor leaf builds a cell, struct.sets it
-- into the parent's recursive slot, advances the dest, recomputes the self-call args
-- into the loop's param locals, and `br`s to the loop header.
-- WTrmcOn self arity pslots ctorName selfFieldIdx loopLbl exitLbl
data WTrmcCtx =
  | WTrmcOff
  | WTrmcOn SelfRef Int (List String) String Int String String

wTrmcCtxRef : Ref WTrmcCtx
wTrmcCtxRef = Ref WTrmcOff

-- layer-18: the PLAIN-tail impl-method `return_call` context.  Set to `Some (method,
-- tag, arity)` ONLY while emitting an ordinary (non-TMC, non-default) impl body in
-- `emitImplGroup`; off everywhere else (top-level fns, default defines, dispatch
-- chains).  Consulted by `emitAppTail`'s CMethod arm: a SATURATED tail-position
-- self-call `CMethod method (RKey tag) …` matching THIS (method, tag) is rewritten
-- from `call $mdk_impl_<tag>_<method>` to `return_call $mdk_impl_<tag>_<method>` — the
-- impl-method analog of the top-level plain-tail return_call (so `fold`/`length`/`ap`/
-- any accumulator-recursive impl method runs in constant wasm stack).  The TMC cons-tail
-- case is handled separately by wTrmcImplTry (it never reaches this path); a NON-tail
-- self-call never reaches emitAppTail (it goes through emitRefExpr), so it stays a plain
-- `call` — the safety net.
data ImplSelfCtx = ImplSelfOff | ImplSelfOn String String Int

implSelfCtxRef : Ref ImplSelfCtx
implSelfCtxRef = Ref ImplSelfOff

-- the loop-local names used by the destination-passing emit.  `$__tmc_head` holds the
-- first cell (the result returned at exit); `$__tmc_dest` holds the cell whose recursive
-- slot the NEXT leaf must fill; `$__tmc_first` is 1 until the first cell is built.
-- `$__tmc_t<k>` are arg-recompute temps (one per param) so an arg may read an old param
-- before any slot is overwritten.
wTrmcHeadL : String
wTrmcHeadL = "$__tmc_head"
wTrmcDestL : String
wTrmcDestL = "$__tmc_dest"
wTrmcFirstL : String
wTrmcFirstL = "$__tmc_first"
wTrmcTempL : Int -> String
wTrmcTempL k = "$__tmc_t" ++ intToString k

-- Emit `body` in TAIL position of the enclosing function.  Descends into the tails
-- of if/let/block/decision so the syntactic tail call is found wherever it sits.
-- A tail call emits `return_call` (saturated direct call to a known top-level fn) or
-- `return_call $mdk_apply` (indirect / non-saturated — the universal apply itself
-- tail-dispatches via return_call_ref).  These are guaranteed constant-stack by the
-- engine (Wasm 3.0 / Node 24).  A NON-call tail leaf emits its value then `return`.
-- Calls to host imports are NOT reachable as tail calls here (IO is W6), so the
-- "never tail a host import" rule is vacuously satisfied this slice.
-- `arity` = the enclosing fn's param count (unused today; kept for symmetry with
-- the LLVM self-call walk).
emitRefTail : Prog -> List String -> Int -> CExpr -> <Mut> List String
emitRefTail prog env arity e = match wTrmcCtxRef.value
  WTrmcOn self sarity pslots cellStruct selfIdx loopLbl exitLbl =>
    -- TMC active: descend the structural tail wrappers (if/let/block/decision) with the
    -- context STILL LIVE so their inner leaves re-enter here; redirect every LEAF
    -- (cons/ctor-tail, plain self-call, or base) to the destination-passing emit.
    if isWTrmcWrapper e then emitRefTailWrap prog env arity e
    else emitWasmTrmcLeaf prog env self sarity pslots cellStruct selfIdx loopLbl exitLbl e
  WTrmcOff => match wDispCtxRef.value
    WDispOn root loopLbl rootArity members =>
      -- Stage-2/3 (b′) active: descend the structural tail wrappers with the dispatch
      -- context LIVE; redirect SPINE cons leaves + base leaves to the dest globals.
      if isWTrmcWrapper e then emitRefTailWrap prog env arity e
      else emitWDispLeaf prog env root loopLbl rootArity members e
    WDispOff => emitRefTailWrap prog env arity e

-- a (b′) tail leaf: a peeled spine cons `<h1> :: … :: <member> <sat>` → dest-link each
-- cell + return_call the target (the root's inner loop for the root, the member fn
-- itself otherwise — only the root carries a reset wrapper); a saturated tail-call to
-- a group member → ordinary return_call (the dest threads through untouched); any
-- other leaf (base, e.g. `[]`) → close the dest + return $g_tmc_head.
emitWDispLeaf : Prog -> List String -> String -> String -> Int -> List String -> CExpr -> <Mut> List String
emitWDispLeaf prog env root loopLbl rootArity members (e@(CBinPrim "::" _ _ _)) =
  match wDispSpineParts prog (f => contains f members) e
    Some (heads, f, args) =>
      emitWDispSpineCons prog env root (if f == root then loopLbl else f) heads args
    None =>
      -- a cons that does not bottom in a saturated group call (the spine terminator
      -- can be a cons onto a non-spine value): group validation guaranteed it is
      -- member-free, so it is a BASE value — close the dest + return the head global.
      emitWDispBase prog env root e
emitWDispLeaf prog env root loopLbl rootArity members other =
  if wDispIsSatRootCall prog root rootArity other then
    -- a bare saturated tail-call to root: emit the args + return_call the inner loop
    -- (skip the reset wrapper, which would re-zero the in-flight dest).
    match flattenApp other []
      (_, args) => flatMap (a => emitRefExpr prog env 0 a) args ++ ["return_call $" ++ gname loopLbl]
  else
    match flattenApp other []
      ((CVar f0 _), args) =>
        let f = canonFn prog f0
        if isFtSentinel f0 then ftSentinelInstrs f0
        else emitWDispTailOrBase prog env root members f other
      _ => emitWDispBase prog env root other

-- a non-cons, non-root-bare leaf: a SATURATED tail-call to another group member →
-- ordinary return_call (dest untouched; the member's own redirected leaves will close
-- it); anything else → a base value — dest-close.  (An unsaturated or non-member call
-- here cannot thread the dest, so it must terminate the spine as a value.)
emitWDispTailOrBase : Prog -> List String -> String -> List String -> String -> CExpr -> <Mut> List String
emitWDispTailOrBase prog env root members f e = match flattenApp e []
  (_, args) =>
    if contains f members && listLen args == progFnArity prog f then
      emitAppTail prog env 0 e
    else
      emitWDispBase prog env root e

-- the ordinary tail descent (TMC-inactive, or the wrapper arms while TMC is active).
emitRefTailWrap : Prog -> List String -> Int -> CExpr -> <Mut> List String
emitRefTailWrap prog env arity (CIf c t f) =
  let ci = emitRefExpr prog env 0 c ++ ["ref.cast (ref i31)", "i31.get_u"]
  let ti = emitRefTail prog env arity t
  let fi = emitRefTail prog env arity f
  ci ++ ["if"] ++ indent ti ++ ["else"] ++ indent fi ++ ["end", "unreachable"]
emitRefTailWrap prog env arity (CLet False (PVar x) e1 e2) = emitRefExpr prog env 0 e1
  ++ ["local.set $" ++ gname x]
  ++ emitRefTail prog (x::env) arity e2
emitRefTailWrap prog env arity (CLet False PWild e1 e2) = emitRefExpr prog env 0 e1
  ++ ["drop"]
  ++ emitRefTail prog env arity e2
emitRefTailWrap prog env arity (CBlock stmts) =
  emitBlockTail prog env arity stmts
emitRefTailWrap prog env arity (CDecision scrut arms tree) =
  emitDecisionTail prog env arity scrut arms tree
emitRefTailWrap prog env arity (CApp f a) =
  emitAppTail prog env arity (CApp f a)
-- a bare fall-through sentinel in tail position lowers to its sentinel instrs (a `br`
-- to the clause label, or a trap) — NOT value+return (the generic CVar arm would
-- append a dead `return` after an unconditional branch, leaving the stack ill-typed).
emitRefTailWrap prog env arity (e@(CVar x _)) =
  if isFtSentinel x then
    ftSentinelInstrs x
  else
    emitRefExpr prog env 0 e ++ ["return"]
emitRefTailWrap prog env arity other = emitRefExpr prog env 0 other
  ++ ["return"]

-- a structural tail WRAPPER (if/let/block/decision) whose tail descends to leaves —
-- vs a LEAF (cons/ctor/self-call/base) that TMC redirects.  Mirrors emitRefTailWrap's
-- own wrapper arms so the TMC guard descends exactly what the ordinary path descends.
isWTrmcWrapper : CExpr -> Bool
isWTrmcWrapper (CIf _ _ _) = True
isWTrmcWrapper (CLet False (PVar _) _ _) = True
isWTrmcWrapper (CLet False PWild _ _) = True
isWTrmcWrapper (CBlock _) = True
isWTrmcWrapper (CDecision _ _ _) = True
isWTrmcWrapper _ = False

-- a TMC tail leaf: an eligible cons/ctor-tail conses into the destination + loops; a
-- bare saturated plain self-call recomputes its args + loops (iterate-on-shorter-list);
-- any other leaf is the BASE — store it into the current destination + exit.
emitWasmTrmcLeaf : Prog -> List String -> SelfRef -> Int -> List String -> String -> Int -> String -> String -> CExpr -> <Mut> List String
emitWasmTrmcLeaf prog env self arity pslots cellStruct selfIdx loopLbl exitLbl e = if isCtorTail (c => isCtor prog c) (c => ctorArity prog c) self arity e then emitWasmTrmcCtor prog env self arity pslots cellStruct selfIdx loopLbl (ctorTailLeadFields e) (consTailArgs e) else if isSelfSatApp self arity e then emitWasmTrmcTailCall prog env pslots loopLbl e else emitWasmTrmcBase prog env exitLbl e

-- cons/ctor leaf: build the cell with its NON-recursive (leading) fields + a placeholder
-- in the recursive slot, link it into the parent's recursive slot (or seed $__tmc_head on
-- the first cell), advance the destination to this cell, recompute the self-call args into
-- the loop's param locals, and br to the loop header.  NO recursive call is emitted.
--   • first cell  → $__tmc_head := cell ; $__tmc_first := 0
--   • later cells → struct.set <cellStruct> $__tmc_dest <selfIdx+1> cell
--   • always      → $__tmc_dest := cell
-- The recursive slot is `(mut (ref eq))` (Stage 0), seeded here with a safe i31 nil
-- placeholder (never dereferenced — it is overwritten by the next iteration's struct.set,
-- or stays as the cell's tail which the BASE leaf fills before exit).
emitWasmTrmcCtor : Prog -> List String -> SelfRef -> Int -> List String -> String -> Int -> String -> List CExpr -> List CExpr -> <Mut> List String
emitWasmTrmcCtor prog env self arity pslots ctorName selfIdx loopLbl leadFields args =
  let cellStruct = ctorStructName ctorName
  let tag = ["i32.const " ++ intToString (ctorOrdinal prog ctorName)]
  let leadInstrs = flatMap (a => emitRefExpr prog env 0 a) leadFields
  -- placeholder for the recursive slot (overwritten next iter / by the base leaf).
  let placeholder = ["i32.const 1", "ref.i31"]
  let buildCell = tag ++ leadInstrs ++ placeholder ++ ["struct.new $" ++ cellStruct]
  -- stash new cell in temp 0; link into prev dest (or seed head); advance dest := new.
  let stashNew = buildCell ++ ["local.set " ++ wTrmcTempL 0]
  let linkSet = ["local.get " ++ wTrmcDestL, "ref.cast (ref $" ++ cellStruct ++ ")", "local.get " ++ wTrmcTempL 0, "ref.as_non_null", "struct.set $\{cellStruct} \{intToString (selfIdx + 1)}"]
  let linkSeed = ["local.get " ++ wTrmcTempL 0, "local.set " ++ wTrmcHeadL, "i32.const 0", "local.set " ++ wTrmcFirstL]
  let linkInstrs = ["local.get " ++ wTrmcFirstL, "if"] ++ indent linkSeed ++ ["else"] ++ indent linkSet ++ ["end"]
  let advance = ["local.get " ++ wTrmcTempL 0, "local.set " ++ wTrmcDestL]
  -- recompute the self-call args into temps (an arg may read an old param), then store
  -- into the param slots, then loop.  Args occupy temps 1..arity (temp 0 = the cell).
  let argTemps = wTrmcEmitArgsToTemps prog env args 1
  let storeSlots = wTrmcStoreSlots pslots args 1
  stashNew ++ linkInstrs ++ advance ++ argTemps ++ storeSlots ++ ["br " ++ loopLbl]

-- plain saturated self-call leaf (no cell): recompute args into temps + store into the
-- param slots + br.  Leaves the destination UNCHANGED (the next iter fills the same slot).
emitWasmTrmcTailCall : Prog -> List String -> List String -> String -> CExpr -> <Mut> List String
emitWasmTrmcTailCall prog env pslots loopLbl e =
  let (_, args) = flattenApp e []
  let argTemps = wTrmcEmitArgsToTemps prog env args 0
  let storeSlots = wTrmcStoreSlots pslots args 0
  argTemps ++ storeSlots ++ ["br " ++ loopLbl]

-- base/other leaf: a value with NO self-call.  Store it into the current destination's
-- recursive slot (or directly into $__tmc_head if no cell was ever built), then br to exit
-- where the function returns $__tmc_head.  Uses $__tmc_first to choose.
emitWasmTrmcBase : Prog -> List String -> String -> CExpr -> <Mut> List String
emitWasmTrmcBase prog env exitLbl e =
  let valInstrs = emitRefExpr prog env 0 e
  -- if no cell was built, the whole result IS this value → head := value.
  -- else store it into the current dest's recursive slot.  We need the dest's struct type;
  -- it is the active cellStruct, threaded via the ctx — but emitWasmTrmcBase doesn't carry
  -- it.  Fetch from the ctx.
  match wTrmcCtxRef.value
    WTrmcOn _ _ _ ctorName selfIdx _ _ =>
      let cellStruct = ctorStructName ctorName
      let storeBranch = ["local.get " ++ wTrmcDestL, "ref.cast (ref $" ++ cellStruct ++ ")"] ++ valInstrs ++ ["struct.set $\{cellStruct} \{intToString (selfIdx + 1)}"]
      let seedBranch = valInstrs ++ ["local.set " ++ wTrmcHeadL]
      ["local.get " ++ wTrmcFirstL, "if"] ++ indent seedBranch ++ ["else"] ++ indent storeBranch ++ ["end", "br " ++ exitLbl]
    WTrmcOff => valInstrs ++ ["return"]

-- recompute each self-call arg into its temp local ($__tmc_t<base+k>), left-to-right.
wTrmcEmitArgsToTemps : Prog -> List String -> List CExpr -> Int -> <Mut> List String
wTrmcEmitArgsToTemps prog env args base = wTrmcArgsGo prog env args base 0

wTrmcArgsGo : Prog -> List String -> List CExpr -> Int -> Int -> <Mut> List String
wTrmcArgsGo _ _ [] _ _ = []
wTrmcArgsGo prog env (a::rest) base k = emitRefExpr prog env 0 a
  ++ ["local.set " ++ wTrmcTempL (base + k)]
  ++ wTrmcArgsGo prog env rest base (k + 1)

-- store each recomputed temp into the matching param slot ($a<i>), left-to-right.
wTrmcStoreSlots : List String -> List CExpr -> Int -> List String
wTrmcStoreSlots pslots args base = wTrmcStoreGo pslots args base 0

wTrmcStoreGo : List String -> List CExpr -> Int -> Int -> List String
wTrmcStoreGo [] _ _ _ = []
wTrmcStoreGo _ [] _ _ = []
wTrmcStoreGo (p::ps) (_::as_) base k = [
    "local.get " ++ wTrmcTempL (base + k),
    "ref.as_non_null",
    "local.set $" ++ gname p,
  ]
  ++ wTrmcStoreGo ps as_ base (k + 1)

-- ── the Stage-1 driver: decide eligibility + emit the destination-passing loop ──
-- Returns `Some fnDef` when `name`/`clauses` is a top-level non-dict self-recursive
-- define that is `trmcEligible` for the self-only cons/ctor-tail shape (a) AND every
-- cons/ctor-tail leaf builds the SAME ctor (so the single typed dest local + casts are
-- sound).  Otherwise `None` → the caller falls back to the ordinary (stack-growing)
-- codegen (no regression).
wasmTrmcTry : Prog -> String -> Int -> List CClause -> <Mut> Option (List String)
wasmTrmcTry prog name arity clauses =
  let self = SelfByVar name
  let pairs = map clauseToPair clauses
  -- Stage-1b: a multi-clause fn whose params carry list/ctor PATTERNS (the
  -- `stripComments` {cons-tail + plain-tail-drop + base} shape) is NOW admitted —
  -- emitWasmTrmcFn routes it through the clause-dispatch chain (emitClauseChainGo)
  -- with the TMC context live, so each clause's tail leaf is TMC-aware (cons-into-dest,
  -- plain-tail-drop+loop, base+exit) instead of the stack-growing recursive call the
  -- ordinary emitClausesRef path emits.  All-PVar single/multi-clause stays the fast
  -- direct-body path.  (Mirrors llvm_emit's trmcTryFn forceSingle=False / emitClauseTree
  -- reuse.)
  if arity > 0
     && wTrmcNonDict clauses
     && trmcEligible (c => isCtor prog c) (c => ctorArity prog c) self arity pairs then
    map (emitWasmTrmcFn prog name arity clauses) (wTrmcUniformCtor prog self arity pairs)
  else None

clauseToPair : CClause -> (List Pat, CExpr)
clauseToPair (CClause pats body) = (pats, body)

-- Phase 2 B-dispatch (mirror of llvm_emit.trmcImplTry): a DISPATCHED self-recursive
-- cons/ctor-tail IMPL method (the `List` Functor `map`: `map f (x::xs) = f x :: map f xs`,
-- recursing via a `CMethod method (RKey tag)` node) is emitted as an O(1)-stack
-- destination-passing loop, just like a top-level builder.  Without this the ordinary
-- impl-body emit lowers the self-call as a `call $mdk_impl_<tag>_<method>` inside the
-- cons args (the frame stays live → deep lists overflow V8's stack).
--
-- The self-ref is `SelfByMethod method tag` (the self-call head is `CMethod method
-- (RKey tag)`, NOT a `CVar`).  SAFETY-CRITICAL: `freeVars (CMethod …)` is BLIND to the
-- method NAME — the analysis (`trmcEligible`/`isCtorTail`/`selfFree`) routes the
-- `SelfByMethod` disqualification through `mentionsSelfMethod`, so a body that
-- self-recurses via `CMethod` in a NON-tail position is rejected (stays ordinary) rather
-- than wrongly transformed (dropped recursion → silent miscompile).
--
-- Scope = F2(a): NON-dict, NON-eta impls.  Returns Some def when eligible (the whole
-- `(func …)` define via emitWasmTrmcCore with the impl symbol + SelfByMethod), else None
-- so emitImplGroup falls back to the ordinary emitClausesImpl body.
wTrmcImplTry : Prog -> String -> String -> Int -> List CClause -> <Mut> Option (List String)
wTrmcImplTry prog method tag arity clauses =
  let self = SelfByMethod method tag
  let pairs = map clauseToPair clauses
  if arity > 0 && wTrmcNonDict clauses && trmcEligible (c => isCtor prog c) (c => ctorArity prog c) self arity pairs then
    map (emitWasmTrmcCore prog (implFnSym tag method) self (implFnSym tag method) arity clauses) (wTrmcUniformCtor prog self arity pairs)
  else
    None  -- a non-dict define: no clause has a leading `$dict_…`/`$dict…` param (dict-passed
-- methods / lifted lambdas are out of scope for Stage 1).
wTrmcNonDict : List CClause -> Bool
wTrmcNonDict clauses = not (anyList clauseHasLeadingDict clauses)

clauseHasLeadingDict : CClause -> Bool
clauseHasLeadingDict (CClause ((PVar x)::_) _) = wIsDictParamName x
clauseHasLeadingDict _ = False

wIsDictParamName : String -> Bool
wIsDictParamName x = startsWithStr x "$dict"

-- the single ctor name every cons/ctor-tail leaf in the body builds, if uniform; None if
-- the bodies build no ctor-tail or DISAGREE (mixed ctors would need a per-leaf-typed dest;
-- out of scope — fall back).  Cons-tail leaves report ctor "Cons" (struct $C_Cons).
wTrmcUniformCtor : Prog -> SelfRef -> Int -> List (List Pat, CExpr) -> <Mut> Option String
wTrmcUniformCtor prog self arity pairs =
  let names = dedupKeep (flatMap (pr => wTrmcCtorNamesOf prog self arity (snd pr)) pairs)
  match names
    [n] => Some n
    _ => None

snd : (a, b) -> b
snd (_, b) = b

-- collect the ctor NAMES of every cons/ctor-tail leaf reachable through the tail
-- wrappers (if/let/block/decision).  Mirrors trmcBodyHasCons's descent.
wTrmcCtorNamesOf : Prog -> SelfRef -> Int -> CExpr -> <Mut> List String
wTrmcCtorNamesOf prog self arity (CIf _ t f) = wTrmcCtorNamesOf prog self arity t
  ++ wTrmcCtorNamesOf prog self arity f
wTrmcCtorNamesOf prog self arity (CLet _ _ _ b) =
  wTrmcCtorNamesOf prog self arity b
wTrmcCtorNamesOf prog self arity (CBlock stmts) = match lastStmtExpr stmts
  Some ex => wTrmcCtorNamesOf prog self arity ex
  None => []
wTrmcCtorNamesOf prog self arity (CDecision _ arms _) =
  flatMap (a => wTrmcCtorNamesOf prog self arity (armBody a)) arms
wTrmcCtorNamesOf prog self arity ex =
  if isCtorTail (c => isCtor prog c) (c => ctorArity prog c) self arity ex then
    [ctorTailName ex]
  else
    []

lastStmtExpr : List CStmt -> Option CExpr
lastStmtExpr [] = None
lastStmtExpr [CSExpr ex] = Some ex
lastStmtExpr (_::rest) = lastStmtExpr rest

-- emit the eligible function as a destination-passing loop.  Scaffold:
--   (func $name (param $a0 …) (result (ref eq))
--     <tmc locals> <clause locals> <scratch> <w7 locals>
--     i32.const 1  local.set $__tmc_first
--     block $tmcexit  loop $tmcloop  <body via emitRefTail under WTrmcOn>  end  end
--     local.get $__tmc_head)
-- Every cons/ctor leaf `br $tmcloop` (no recursive call); the base leaf `br $tmcexit`.
emitWasmTrmcFn : Prog -> String -> Int -> List CClause -> String -> <Mut> List String
emitWasmTrmcFn prog name arity clauses ctorName =
  -- top-level define: the func symbol is `gname name`, the self-ref is `SelfByVar name`,
  -- and `name` doubles as the clause-block label root.
  emitWasmTrmcCore prog (gname name) (SelfByVar name) name arity clauses ctorName

-- the shared destination-passing-loop emitter for BOTH the top-level path (SelfByVar) and
-- the Phase-2 B-dispatch impl path (SelfByMethod).  `funcSym` is the rendered func symbol
-- (no leading `$`; `gname name` for a top-level fn, `implFnSym tag method` for an impl);
-- `self` is the SelfRef the TMC analysis + leaf-emit thread (CVar vs CMethod recognition);
-- `lblRoot` is the clause-block label root (unique per emitted define).
emitWasmTrmcCore : Prog -> String -> SelfRef -> String -> Int -> List CClause -> String -> <Mut> List String
emitWasmTrmcCore prog funcSym self lblRoot arity clauses ctorName =
  let params = synthParams arity
  -- the recursive self-call field index — scan EVERY clause body (the cons/ctor-tail
  -- leaf may live in a LATER clause: `stripComments`'s base `[]` is clause 1, the
  -- cons-tail is clause 3), not just the first.
  let selfIdx = wTrmcSelfIdxClauses prog self arity clauses
  let pslots = map gname params
  let loopLbl = "$tmcloop"
  let exitLbl = "$tmcexit"
  let saved = wTrmcCtxRef.value
  let _ = setRef wTrmcCtxRef (WTrmcOn self arity pslots ctorName selfIdx loopLbl exitLbl)
  -- Single all-PVar clause (no fallthrough): the fast path — alias params to the
  -- synthetic positions and TMC-emit the body directly.  Otherwise (multi-clause OR
  -- a clause carries a list/ctor pattern, e.g. `stripComments`/the `map` impl): route
  -- through the clause-dispatch chain (emitClauseChainGo) with the TMC context LIVE, so
  -- each clause's tail leaf is TMC-aware (cons-into-dest / plain-tail-drop+loop / base+exit).
  let bodyLines = match clauses
    [(CClause ps b)] =>
      if allPlainParams ps && not (exprHasFallthrough b) then
        bindParamAliases ps params ++ emitRefTail prog (map patName ps) arity b
      else emitClauseChainGo prog [] lblRoot params arity clauses 0
    _ => emitClauseChainGo prog [] lblRoot params arity clauses 0
  let _ = setRef wTrmcCtxRef saved
  let loopShell = ["i32.const 1", "local.set " ++ wTrmcFirstL]
      ++ ["block " ++ exitLbl, "loop " ++ loopLbl]
      ++ indent bodyLines
      ++ ["end", "end"]
      ++ ["local.get " ++ wTrmcHeadL, "ref.as_non_null"]
  -- locals: the tmc bookkeeping + temps (t0..t_arity), then the ordinary clause/scratch.
  let tmcLocals = ["(local " ++ wTrmcHeadL ++ " (ref null eq))", "(local " ++ wTrmcDestL ++ " (ref null eq))", "(local " ++ wTrmcFirstL ++ " i32)"]
    ++ map (k => "(local " ++ wTrmcTempL k ++ " (ref null eq))") (rangeList 0 (arity + 1))
  let allLocals = clauseLocals clauses
  let extraLocals = filterList (notIn params) (dedupKeep allLocals)
  let scratch = scratchLocals (clausesMaxDepth clauses)
  let localDecls = map localDeclRef (extraLocals ++ scratch)
  let w7Decls = w7LocalDecls (clausesMaxDepth clauses)
  let sig = "  (func $\{funcSym}\{joinWith "" (map paramDeclRef params)} (result (ref eq))"
  [sig] ++ map ("  " ++ _) (tmcLocals ++ localDecls ++ w7Decls) ++ indent loopShell ++ ["  )"]

-- the recursive self-call field index, scanning EVERY clause's body for the first
-- cons/ctor-tail leaf (the leaf may live in a clause after a base clause).  Defaults
-- to 1 (Cons tail field) when no clause has a ctor-tail (a pure plain-tail fn).
wTrmcSelfIdxClauses : Prog -> SelfRef -> Int -> List CClause -> <Mut> Int
wTrmcSelfIdxClauses _ _ _ [] = 1
wTrmcSelfIdxClauses prog self arity ((CClause _ body)::rest) = match wTrmcFirstCtorTail prog self arity body
  Some ex => ctorTailSelfIdx ex
  None => wTrmcSelfIdxClauses prog self arity rest

wTrmcFirstCtorTail : Prog -> SelfRef -> Int -> CExpr -> <Mut> Option CExpr
wTrmcFirstCtorTail prog self arity (CIf _ t f) = match wTrmcFirstCtorTail prog self arity t
  Some ex => Some ex
  None => wTrmcFirstCtorTail prog self arity f
wTrmcFirstCtorTail prog self arity (CLet _ _ _ b) =
  wTrmcFirstCtorTail prog self arity b
wTrmcFirstCtorTail prog self arity (CBlock stmts) = match lastStmtExpr stmts
  Some ex => wTrmcFirstCtorTail prog self arity ex
  None => None
wTrmcFirstCtorTail prog self arity (CDecision _ arms _) =
  wTrmcFirstCtorTailArms prog self arity arms
wTrmcFirstCtorTail prog self arity ex =
  if isCtorTail (c => isCtor prog c) (c => ctorArity prog c) self arity ex then
    Some ex
  else
    None

wTrmcFirstCtorTailArms : Prog -> SelfRef -> Int -> List CArm -> <Mut> Option CExpr
wTrmcFirstCtorTailArms _ _ _ [] = None
wTrmcFirstCtorTailArms prog self arity (a::rest) = match wTrmcFirstCtorTail prog self arity (armBody a)
  Some ex => Some ex
  None => wTrmcFirstCtorTailArms prog self arity rest

-- ════════════════════════════════════════════════════════════════════════════
-- Stage-2/3 WasmGC DISPATCH-GRAPH TMC (shape (b′)) — WASMGC-TRMC-DESIGN §7/§11,
-- BROWSER-STACK-DIAGNOSIS §7 (Stage-3 generalization: pattern-matched roots,
-- member-targeted multi-cell spine conses, external-entry root selection)
-- ════════════════════════════════════════════════════════════════════════════
-- The lexer overflows because each per-token LEAF (`scanLower`/`emit`/…) does
-- `tok :: scan …`: the cons-target is the single dispatcher `scan`, NOT the leaf
-- itself, so the LLVM/Stage-1 self-recursive analysis (`isSelfSatApp self`) never
-- fires across the dispatch boundary.  The cons `scan …` is emitted as a struct.new
-- ARG → the leaf frame stays live to EOF → V8 stack overflow.
--
-- Fix (emitter-only, reuses Stage-1's cons-cell + dest mechanism): identify a "TMC
-- group" = a set of functions tail-connected under an EXTERNAL-ENTRY root `R`
-- (`scan`, the layout family's `layout`), where every tail leaf is either
--   (1) a base case (no call to a group member), or
--   (2) a SPINE cons — a peeled chain of 1..N member-free heads bottoming in a
--       saturated call to ANY group member (the overflow site), or
--   (3) a saturated tail-call to another group member (a dispatcher OR a
--       non-spine self-accumulator like the string-interp `acc++` loops).
-- We then emit `R` as a RESET wrapper that zeroes three module-level dest globals
-- ($g_tmc_head / $g_tmc_dest / $g_tmc_first) and `return_call`s an inner `R__loop`,
-- and we emit every group member with its SPINE cons leaves rewritten to: build each
-- `Cons` cell with a placeholder tail, link it into $g_tmc_dest (or seed $g_tmc_head
-- on the first cell), advance the dest, then `return_call` the bottom callee (`$R__loop`
-- when it is the root — never the reset wrapper — else the member fn itself; a REAL
-- tail call — the leaf frame dies; no struct.new holds the recursion).  A member's
-- base leaf closes the dest with its real value and returns $g_tmc_head.  Dispatcher /
-- self-accumulator tails (case 3) are emitted UNCHANGED (they already `return_call`,
-- and they never touch the dest globals, which thread through transparently).
--
-- This needs NO param-slot recompute loop (unlike Stage-1): the engine's `return_call`
-- IS the loop.  Soundness rests on: the group is entered only as a top-level call (no
-- nesting of one scan inside another), so the shared globals carry exactly one in-flight
-- spine; the reset wrapper re-zeroes them per outer call.

-- the active dispatch-group context during a group member's body emit.  `WDispOn root
-- loopLbl rootArity members` ⇒ redirect SPINE cons leaves (a peeled cons chain
-- bottoming in a saturated call to a group member) to the dest-passing emit +
-- `return_call` (the root's inner loop for the root, the member fn itself otherwise),
-- and base leaves to the dest-close.  WDispOff ⇒ ordinary emit.
data WDispCtx = WDispOff | WDispOn String String Int (List String)

wDispCtxRef : Ref WDispCtx
wDispCtxRef = Ref WDispOff

-- the detected (b′) groups for this program (root name + member names), computed once
-- in emitRefProgram and consulted by emitRefFnBind.  Empty when no group qualifies.
data WDispGroup = WDispGroup String (List String)

wDispGroupsRef : Ref (List WDispGroup)
wDispGroupsRef = Ref []

-- PER-GROUP dest globals (Stage-3): each group root gets its own head/dest/first
-- triple, so one group's spine build cannot clobber another's — a member's helper
-- (mid-spine, non-tail) may freely call ANOTHER group's root (e.g. a lexer helper
-- reaching `join` → `intersperse`): that root resets and threads ITS OWN globals
-- and returns a closed spine, leaving the in-flight group's dest untouched.  Only
-- SAME-group re-entry is unsafe, and wDispValidate v3 rejects exactly that.
wDispHeadL : String -> String
wDispHeadL root = "$g_tmc_head_" ++ gname root
wDispDestL : String -> String
wDispDestL root = "$g_tmc_dest_" ++ gname root
wDispFirstL : String -> String
wDispFirstL root = "$g_tmc_first_" ++ gname root

-- the inner-loop fn name for a group root `R`: `<R>__disploop`.
wDispLoopName : String -> String
wDispLoopName root = root ++ "__disploop"

-- one group's three dest globals (mutable; reset per outer entry by the wrapper).
wDispGlobalLines : WDispGroup -> List String
wDispGlobalLines grp =
  let root = wDispRootOf grp
  [
    "  (global " ++ wDispHeadL root ++ " (mut (ref null eq)) (ref.null eq))",
    "  (global " ++ wDispDestL root ++ " (mut (ref null eq)) (ref.null eq))",
    "  (global " ++ wDispFirstL root ++ " (mut i32) (i32.const 1))",
  ]

-- ── group detection ──────────────────────────────────────────────────────────
-- Try to grow a (b′) group rooted at each candidate root `R`.  Stage-3 generalizes
-- the Stage-2 single-target analysis to a DISPATCH GRAPH (the lexer's offside-rule
-- `layout` family + `string.intersperse` — BROWSER-STACK-DIAGNOSIS §7):
--   • the root MAY pattern-match its params (`layout ((RNewline …)::rest) …`) — the
--     all-PVar gate was a Stage-1 br-loop constraint; the (b′) member emit routes
--     through the ordinary clause-chain dispatcher, which handles ctor patterns;
--   • a spine cons may target ANY group member, not just the root (`applyNlTop`'s
--     `(TNewline,_) :: popDedents …`), and may build SEVERAL cells before the
--     recursive call (`popDedents`'s `(TDedent,_)::(TNewline,_):: popDedents …`);
--   • the family may be STRONGLY CONNECTED, so root selection is by EXTERNAL
--     ENTRY: a fn may root a group only if NO other member is referenced from
--     anywhere outside the group — then the root's reset wrapper is provably the
--     sole way in.  (Any other root choice would let control enter a member with
--     stale dest globals: a silent miscompile, not a detectable gate failure.)
-- The group is the transitive closure of fns tail-reachable from R whose EVERY
-- tail leaf is (1) a base, (2) a spine cons bottoming in a saturated call to a
-- group fn, or (3) a saturated tail-call to a group fn.  A grown group must then
-- pass wDispValidate (v2–v7 below) before it is accepted; any failure ⇒ no
-- transform, no regression.  Greedy in bind order; every check is deterministic.
detectDispatchGroups : Prog -> List CBind -> <Mut> List WDispGroup
detectDispatchGroups prog allBinds =
  let binds = userFnBinds allBinds
  let fnNames = map bindName binds
  -- pass 0: global tables.  `consTargets` = the bottom callee of every peeled
  -- tail spine cons (root-candidacy pre-gate: only a fn somebody conses onto can
  -- anchor a spine; a family whose external entry is never itself a cons target
  -- is out of scope — documented residual).  `headsMap` = per-bind referenced
  -- heads over ALL binds (fn + value); `implHeads` = the same over impl bodies.
  let consTargets = dedupKeep (flatMap (b => wDispBindConsTargets prog fnNames b) binds)
  let headsMap = map (b => (bindName b, dedupKeep (wDispBindHeads prog b))) allBinds
  let implHeads = dedupKeep (flatMap (e => wDispImplEntryHeads prog e) (progImpls prog))
  wDispDetectGo prog binds fnNames headsMap implHeads consTargets binds []

-- greedy accept in bind order (deterministic; groups are disjoint by v7).
wDispDetectGo : Prog -> List CBind -> List String -> List (String, List String) -> List String -> List String -> List CBind -> List WDispGroup -> <Mut> List WDispGroup
wDispDetectGo _ _ _ _ _ _ [] accepted = reverseL accepted
wDispDetectGo prog binds fnNames headsMap implHeads consTargets (b::rest) accepted = match wDispTryRoot prog binds fnNames headsMap implHeads consTargets accepted b
  Some grp => wDispDetectGo prog binds fnNames headsMap implHeads consTargets rest (grp::accepted)
  None => wDispDetectGo prog binds fnNames headsMap implHeads consTargets rest accepted

-- the bind's group if it roots a valid one, else None.
wDispTryRoot : Prog -> List CBind -> List String -> List (String, List String) -> List String -> List String -> List WDispGroup -> CBind -> <Mut> Option WDispGroup
wDispTryRoot prog binds fnNames headsMap implHeads consTargets accepted (CBind root clauses) =
  let arity = clauseArityOf clauses
  let claimed = flatMap wDispMembersOf accepted
  if arity > 0 && wTrmcNonDict clauses && contains root consTargets && not (contains root claimed) then match wDispGrow prog binds fnNames root [root] [root]
    Some members => wDispValidate prog binds headsMap implHeads claimed root arity clauses members
    None => None
  else None

-- the post-growth soundness checks.  Some ⇒ accept; None ⇒ no transform.
--   v2 the group builds a Cons spine somewhere;
--   v3 member bodies reference group fns ONLY on the sanctioned tail edges (the
--      bare tail callee / the spine-cons bottom callee) — every OTHER referenced
--      head, expanded TRANSITIVELY through top-level helpers, must stay outside
--      the group (a mid-spine re-entry corrupts the shared dest globals);
--   v4 external entry: no bind or impl body outside the group references a
--      member other than the root;
--   v5 a Stage-1-claimable singleton stays with Stage-1 (its local-dest loop
--      needs no reset wrapper or globals at all);
--   v7 groups are disjoint (a claimed member is never re-grouped).
-- (No cross-group check is needed: each group threads its OWN global triple, so
-- a helper reaching ANOTHER group's root mid-spine builds that group's spine in
-- that group's globals and returns it closed — this group's dest is untouched.)
wDispValidate : Prog -> List CBind -> List (String, List String) -> List String -> List String -> String -> Int -> List CClause -> List String -> <Mut> Option WDispGroup
wDispValidate prog binds headsMap implHeads claimed root arity clauses members =
  if anyList (m => contains m claimed) members then None
  else if not (wDispGroupHasSpineCons prog binds members) then None
  else if members == [root] && wDispStage1Claims prog root arity clauses then None
  else
    let allNames = map fst headsMap
    let nt = filterList (h => contains h allNames) (dedupKeep (flatMap (m => wDispMemberNonTailHeads prog binds members m) members))
    let closure = wDispBfs headsMap nt []
    -- an oversize helper closure ⇒ same-group isolation not cheaply provable ⇒ reject.
    if listLen closure > 256 then None
    else if anyList (h => contains h members) closure then None
    else
      let inner = filterList (!= root) members
      if anyList (p => wDispEntryRefs members inner p) headsMap then None
      else if anyList (h => contains h inner) implHeads then None
      else Some (WDispGroup root members)

-- does a bind OUTSIDE the group reference a non-root member?
wDispEntryRefs : List String -> List String -> (String, List String) -> Bool
wDispEntryRefs members inner (name, heads) =
  if contains name members then
    False
  else
    anyList (h => contains h inner) heads

-- transitive closure of `work` over the top-level referenced-heads graph, capped
-- (the caller treats a past-cap closure as un-provable and rejects the group).
wDispBfs : List (String, List String) -> List String -> List String -> List String
wDispBfs _ [] visited = visited
wDispBfs headsMap (h::rest) visited =
  if contains h visited || listLen visited > 256 then wDispBfs headsMap rest visited
  else
    let nexts = match lookupAssoc h headsMap
      Some hs => hs
      None => []
    wDispBfs headsMap (nexts ++ rest) (h::visited)

-- would Stage-1 (wasmTrmcTry) already claim this fn as a self-TMC loop?
wDispStage1Claims : Prog -> String -> Int -> List CClause -> <Mut> Bool
wDispStage1Claims prog name arity clauses =
  let self = SelfByVar name
  let pairs = map clauseToPair clauses
  arity > 0
    && wTrmcNonDict clauses
    && trmcEligible (c => isCtor prog c) (c => ctorArity prog c) self arity pairs
    && isSome (wTrmcUniformCtor prog self arity pairs)

-- peel a chain of conses `h1 :: h2 :: … :: bottom` → (heads, bottom).
wDispPeelCons : CExpr -> (List CExpr, CExpr)
wDispPeelCons (CBinPrim "::" h t _) =
  let (hs, b) = wDispPeelCons t
  (h::hs, b)
wDispPeelCons e = ([], e)

-- a spine-cons leaf `<h1> :: … :: f <saturated>` where `ok f` holds: Some (peeled
-- heads, bottom callee, its args); None if the leaf is not that shape.  This ONE
-- classifier is shared by detection, validation, and the leaf emit, so the three
-- agree exactly on what is (and is not) a spine cons.
wDispSpineParts : Prog -> (String -> Bool) -> CExpr -> Option (List CExpr, String, List CExpr)
wDispSpineParts prog ok e = match wDispPeelCons e
  ([], _) => None
  (heads, bottom) => match flattenApp bottom []
    (CVar f0 _, args) =>
      let f = canonFn prog f0
      if ok f && contains f (progFnNames prog) && listLen args == progFnArity prog f then
        Some (heads, f, args)
      else
        None
    _ => None

-- pass 0: the bottom-target names of every peeled tail-position spine cons.
wDispBindConsTargets : Prog -> List String -> CBind -> List String
wDispBindConsTargets prog fnNames (CBind _ clauses) =
  flatMap (c => wDispExprConsTargets prog fnNames (clauseBodyOf c)) clauses

wDispExprConsTargets : Prog -> List String -> CExpr -> List String
wDispExprConsTargets prog fnNames (CIf _ t f) = wDispExprConsTargets prog fnNames t
  ++ wDispExprConsTargets prog fnNames f
wDispExprConsTargets prog fnNames (CLet _ _ _ b) =
  wDispExprConsTargets prog fnNames b
wDispExprConsTargets prog fnNames (CBlock stmts) = match lastStmtExpr stmts
  Some ex => wDispExprConsTargets prog fnNames ex
  None => []
wDispExprConsTargets prog fnNames (CDecision _ arms _) =
  flatMap (a => wDispExprConsTargets prog fnNames (armBody a)) arms
wDispExprConsTargets prog fnNames other = match wDispSpineParts prog (f => contains f fnNames) other
  Some (_, f, _) => [f]
  None => []

-- a saturated direct call to `root` (canonicalized): flattenApp head is `CVar f`, canonFn
-- f == root, arg count == arity.
wDispIsSatRootCall : Prog -> String -> Int -> CExpr -> Bool
wDispIsSatRootCall prog root arity e = match flattenApp e []
  (CVar f _, args) => canonFn prog f == root && listLen args == arity
  _ => False

-- does `e` mention `root` as a call head anywhere (used to keep cons HEADS root-free so
-- the cell's lead fields don't themselves re-enter the spine)?
wDispCallsRoot : Prog -> String -> CExpr -> Bool
wDispCallsRoot prog root e = contains root (allCallHeads prog e)

allCallHeads : Prog -> CExpr -> List String
allCallHeads prog (CVar f _) = [canonFn prog f]
allCallHeads prog (CApp f a) = allCallHeads prog f ++ allCallHeads prog a
allCallHeads prog (CLam _ b) = allCallHeads prog b
allCallHeads prog (CLet _ _ e1 e2) = allCallHeads prog e1
  ++ allCallHeads prog e2
allCallHeads prog (CLetGroup binds b) = flatMap (bd => wDispBindHeads prog bd) binds
  ++ allCallHeads prog b
allCallHeads prog (CBlock stmts) = flatMap (allCallHeadsStmt prog) stmts
allCallHeads prog (CIf c t f) = allCallHeads prog c
  ++ allCallHeads prog t
  ++ allCallHeads prog f
allCallHeads prog (CBinPrim _ l r _) = allCallHeads prog l
  ++ allCallHeads prog r
allCallHeads prog (CUnOp _ x) = allCallHeads prog x
allCallHeads prog (CMatch s arms) = allCallHeads prog s
  ++ flatMap (allArmHeads prog) arms
allCallHeads prog (CDecision s arms _) = allCallHeads prog s
  ++ flatMap (allArmHeads prog) arms
allCallHeads prog (CTuple es) = flatMap (allCallHeads prog) es
allCallHeads prog (CList es) = flatMap (allCallHeads prog) es
allCallHeads prog (CArray es) = flatMap (allCallHeads prog) es
allCallHeads prog (CRecord _ fs) =
  flatMap (f => allCallHeads prog (cfieldExpr f)) fs
allCallHeads prog (CFieldAccess x _ _) = allCallHeads prog x
allCallHeads prog (CRecordUpdate base fs) = allCallHeads prog base
  ++ flatMap (f => allCallHeads prog (cfieldExpr f)) fs
allCallHeads prog (CVariantUpdate _ base fs) = allCallHeads prog base
  ++ flatMap (f => allCallHeads prog (cfieldExpr f)) fs
allCallHeads prog (CRangeList lo hi _) = allCallHeads prog lo
  ++ allCallHeads prog hi
allCallHeads prog (CRangeArray lo hi _) = allCallHeads prog lo
  ++ allCallHeads prog hi
allCallHeads prog (CIndex a i) = allCallHeads prog a ++ allCallHeads prog i
allCallHeads prog (CSlice a lo hi _) = allCallHeads prog a
  ++ allCallHeads prog lo
  ++ allCallHeads prog hi
allCallHeads prog (CStringIndex a i) = allCallHeads prog a
  ++ allCallHeads prog i
allCallHeads prog (CStringSlice a lo hi _) = allCallHeads prog a
  ++ allCallHeads prog lo
  ++ allCallHeads prog hi
allCallHeads prog (CListIndex a i) = allCallHeads prog a ++ allCallHeads prog i
allCallHeads prog (CListSlice a lo hi _) = allCallHeads prog a
  ++ allCallHeads prog lo
  ++ allCallHeads prog hi
allCallHeads prog _ = []

-- an arm's heads, INCLUDING its guard expressions (a guard runs before the arm
-- body is selected — a group-fn reference there is just as live as one in the body).
allArmHeads : Prog -> CArm -> List String
allArmHeads prog (CArm _ guards body) = flatMap (wDispGuardHeads prog) guards
  ++ allCallHeads prog body

wDispGuardHeads : Prog -> CGuard -> List String
wDispGuardHeads prog (CGBool c) = allCallHeads prog c
wDispGuardHeads prog (CGBind _ e) = allCallHeads prog e

-- every head referenced anywhere in a bind's clause bodies (pass-0 table for the
-- external-entry + helper-closure checks).
wDispBindHeads : Prog -> CBind -> List String
wDispBindHeads prog (CBind _ clauses) =
  flatMap (c => allCallHeads prog (clauseBodyOf c)) clauses

-- every head referenced from a lowered impl/default body (impl bodies are outside
-- the CBind list but can still call into a group).
wDispImplEntryHeads : Prog -> CImplEntry -> List String
wDispImplEntryHeads prog (CImplEntry _ _ (CImplTagged _ _ _ _ _ body)) =
  allCallHeads prog body
wDispImplEntryHeads prog (CImplEntry _ _ (CImplDefault _ body)) =
  allCallHeads prog body

allCallHeadsStmt : Prog -> CStmt -> List String
allCallHeadsStmt prog (CSExpr e) = allCallHeads prog e
allCallHeadsStmt prog (CSLet _ _ e) = allCallHeads prog e
allCallHeadsStmt prog (CSAssign _ e) = allCallHeads prog e
allCallHeadsStmt prog (CSLetElse _ e els) = allCallHeads prog e
  ++ allCallHeads prog els
allCallHeadsStmt _ _ = []

cfieldExpr : CField -> CExpr
cfieldExpr (CField _ e) = e

-- grow the group: `worklist` = members yet to scan, `acc` = accepted members.  For each
-- member, every tail leaf must be (1) base, (2) a peeled spine cons bottoming in a
-- saturated group-fn call, or (3) a saturated tail-call to a group fn (NEW group members
-- are added to the worklist).  Any other tail leaf shape ⇒ reject (None).  `fuel` via
-- the worklist (finite # fns).
wDispGrow : Prog -> List CBind -> List String -> String -> List String -> List String -> Option (List String)
wDispGrow _ _ _ _ [] acc = Some acc
wDispGrow prog binds fnNames root (m::rest) acc =
  match findBind binds m
    None => None
    Some (CBind _ clauses) =>
      -- a non-root member must be non-dict (we emit it via the normal clause machinery
      -- with redirected leaves).  Unlike Stage-1's br-loop, the (b′) emit uses return_call
      -- (the engine threads args), so a member MAY have literal- or ctor-pattern clauses
      -- (singleOp dispatch on a Char, `layout` dispatch on the RawTok head) — the
      -- clause-chain emit handles them and the context redirect reaches each arm's leaves.
      if not (wTrmcNonDict clauses) then None
      else match wDispMemberTailsOk prog fnNames root acc clauses
        None => None
        Some newMembers =>
          let toAdd = dedupKeep (filterList (n => not (contains n acc)) newMembers)
          wDispGrow prog binds fnNames root (rest ++ toAdd) (acc ++ toAdd)

findBind : List CBind -> String -> Option CBind
findBind [] _ = None
findBind ((CBind n cs)::rest) m =
  if n == m then
    Some (CBind n cs)
  else
    findBind rest m

-- check every clause's every tail leaf; collect the NEW group fns referenced by case-(2)
-- cons bottoms and case-(3) tail-calls.  Returns None if any leaf is an unsupported shape.
wDispMemberTailsOk : Prog -> List String -> String -> List String -> List CClause -> Option (List String)
wDispMemberTailsOk prog fnNames root acc clauses =
  wDispClausesGo prog fnNames root acc clauses []

wDispClausesGo : Prog -> List String -> String -> List String -> List CClause -> List String -> Option (List String)
wDispClausesGo _ _ _ _ [] found = Some found
wDispClausesGo prog fnNames root acc ((CClause _ body)::rest) found = match wDispLeavesOk prog fnNames root acc body found
  None => None
  Some found2 => wDispClausesGo prog fnNames root acc rest found2

-- descend the tail wrappers; check each leaf; accumulate referenced new group fns.
-- (Block-prefix statements, let-RHSs, guards, and scrutinees are validated by
-- wDispValidate's v3 non-tail-heads walk against the FINAL member set.)
wDispLeavesOk : Prog -> List String -> String -> List String -> CExpr -> List String -> Option (List String)
wDispLeavesOk prog fnNames root acc (CIf _ t f) found = match wDispLeavesOk prog fnNames root acc t found
  None => None
  Some f2 => wDispLeavesOk prog fnNames root acc f f2
wDispLeavesOk prog fnNames root acc (CLet False (PVar _) _ b) found =
  wDispLeavesOk prog fnNames root acc b found
wDispLeavesOk prog fnNames root acc (CLet False PWild _ b) found =
  wDispLeavesOk prog fnNames root acc b found
wDispLeavesOk prog fnNames root acc (CBlock stmts) found = match lastStmtExpr stmts
  Some ex => wDispLeavesOk prog fnNames root acc ex found
  None => None
wDispLeavesOk prog fnNames root acc (CDecision _ arms _) found =
  wDispArmsOk prog fnNames root acc arms found
wDispLeavesOk prog fnNames root acc other found =
  wDispLeafOk prog fnNames root acc other found

wDispArmsOk : Prog -> List String -> String -> List String -> List CArm -> List String -> Option (List String)
wDispArmsOk _ _ _ _ [] found = Some found
wDispArmsOk prog fnNames root acc ((CArm _ guards body)::rest) found =
  -- only ordinary bool guards (the same restriction the tail emit honors); a refutable
  -- guard binder would complicate the leaf rewrite — reject the group.
  if not (allBoolGuards guards) then None
  else match wDispLeavesOk prog fnNames root acc body found
    None => None
    Some f2 => wDispArmsOk prog fnNames root acc rest f2

-- classify a single LEAF.  peeled spine cons bottoming in a saturated user-fn call
-- ⇒ ok + the bottom fn joins the group.  bare saturated tail-call to a user fn ⇒ ok
-- + it joins.  base (no reference to root) ⇒ ok.  Anything else ⇒ None.
wDispLeafOk : Prog -> List String -> String -> List String -> CExpr -> List String -> Option (List String)
wDispLeafOk prog fnNames root acc e found =
  match wDispSpineParts prog (f => contains f fnNames) e
    Some (heads, f, _) =>
      -- the heads become the cells' lead fields; one that re-enters the root would
      -- run a nested spine build mid-leaf — poison the group.  (Non-root member
      -- references in heads are caught by wDispValidate v3.)
      if anyList (h => wDispCallsRoot prog root h) heads then None
      else Some (f :: found)
    None => match flattenApp e []
      ((CVar f0 _), args) =>
        let f = canonFn prog f0
        if contains f fnNames && contains f (progFnNames prog) && listLen args == progFnArity prog f then
          -- saturated tail-call to a user fn (the root included): pull it into the
          -- group (case 3).  Its own tails are validated when the worklist reaches it.
          Some (f :: found)
        else if wDispLeafIsBase prog root e then Some found
        else None
      _ => if wDispLeafIsBase prog root e then Some found else None

-- a BASE leaf: a value with NO call to `root` and no tail-call into a group fn — e.g. `[]`,
-- a literal, a non-recursive value.  (Root-free here; wDispValidate v3 re-checks every
-- base against the FULL member set.)
wDispLeafIsBase : Prog -> String -> CExpr -> Bool
wDispLeafIsBase prog root e = not (wDispCallsRoot prog root e)

-- the group built a Cons spine somewhere (sanity: the dest globals carry $C_Cons cells).
wDispGroupHasSpineCons : Prog -> List CBind -> List String -> Bool
wDispGroupHasSpineCons prog binds members =
  anyList (m => wDispMemberHasSpineCons prog binds members m) members

wDispMemberHasSpineCons : Prog -> List CBind -> List String -> String -> Bool
wDispMemberHasSpineCons prog binds members m = match findBind binds m
  Some (CBind _ cs) => anyList (c => isNonEmptyList (wDispExprConsTargets prog members (clauseBodyOf c))) cs
  None => False

-- v3 walk: every fn-name head in a member body that is NOT on a sanctioned tail edge
-- (the bare tail callee / the spine-cons bottom callee).  Mirrors wDispLeavesOk's
-- structural descent EXACTLY, so detection, validation, and emit classify each leaf
-- identically.  Collected: if-conds, let-RHSs, block prefixes, scrutinees, guards,
-- cons heads, sanctioned-call args, and whole base exprs.
wDispMemberNonTailHeads : Prog -> List CBind -> List String -> String -> List String
wDispMemberNonTailHeads prog binds members m = match findBind binds m
  Some (CBind _ clauses) =>
    flatMap (c => wDispNonTailHeads prog members (clauseBodyOf c)) clauses
  None => []

wDispNonTailHeads : Prog -> List String -> CExpr -> List String
wDispNonTailHeads prog members (CIf c t f) = allCallHeads prog c
  ++ wDispNonTailHeads prog members t
  ++ wDispNonTailHeads prog members f
wDispNonTailHeads prog members (CLet False (PVar _) rhs b) = allCallHeads prog rhs
  ++ wDispNonTailHeads prog members b
wDispNonTailHeads prog members (CLet False PWild rhs b) = allCallHeads prog rhs
  ++ wDispNonTailHeads prog members b
wDispNonTailHeads prog members (CBlock stmts) =
  wDispStmtNonTailHeads prog members stmts
wDispNonTailHeads prog members (CDecision scrut arms _) = allCallHeads prog scrut
  ++ flatMap (a => wDispArmNonTailHeads prog members a) arms
wDispNonTailHeads prog members leaf = match wDispSpineParts prog (f => contains f members) leaf
  Some (heads, _, args) => flatMap (allCallHeads prog) heads
    ++ flatMap (allCallHeads prog) args
  None => match flattenApp leaf []
    (CVar f0 _, args) =>
      let f = canonFn prog f0
      if contains f members && listLen args == progFnArity prog f then
        flatMap (allCallHeads prog) args
      else
        allCallHeads prog leaf
    _ => allCallHeads prog leaf

wDispArmNonTailHeads : Prog -> List String -> CArm -> List String
wDispArmNonTailHeads prog members (CArm _ guards body) = flatMap (wDispGuardHeads prog) guards
  ++ wDispNonTailHeads prog members body

wDispStmtNonTailHeads : Prog -> List String -> List CStmt -> List String
wDispStmtNonTailHeads prog members [CSExpr ex] =
  wDispNonTailHeads prog members ex
wDispStmtNonTailHeads prog members (s::rest) = allCallHeadsStmt prog s
  ++ wDispStmtNonTailHeads prog members rest
wDispStmtNonTailHeads _ _ [] = []

-- ── group-member emit ────────────────────────────────────────────────────────
-- look up which group (if any) a fn name belongs to, and whether it is the ROOT.
wDispGroupOf : List WDispGroup -> String -> Option WDispGroup
wDispGroupOf [] _ = None
wDispGroupOf ((WDispGroup root members)::rest) name =
  if contains name members then
    Some (WDispGroup root members)
  else
    wDispGroupOf rest name

wDispIsRoot : WDispGroup -> String -> Bool
wDispIsRoot (WDispGroup root _) name = root == name

wDispRootOf : WDispGroup -> String
wDispRootOf (WDispGroup root _) = root

wDispMembersOf : WDispGroup -> List String
wDispMembersOf (WDispGroup _ members) = members

-- emit a group ROOT: the reset wrapper `$root` (zero the dest globals, return_call the
-- inner loop) + the inner `$root__disploop` (the real body, leaves redirected).
emitWDispRoot : Prog -> WDispGroup -> Int -> List CClause -> <Mut> List String
emitWDispRoot prog grp arity clauses =
  let name = wDispRootOf grp
  let params = synthParams arity
  let loopName = wDispLoopName name
  let resetWrapper = wDispResetWrapper name loopName params arity
  let inner = emitWDispMemberFn prog grp loopName name arity clauses
  resetWrapper ++ inner

-- the reset wrapper: (func $root (param …) (result (ref eq))
--   i32.const 1  global.set $g_tmc_first
--   ref.null eq  global.set $g_tmc_head
--   ref.null eq  global.set $g_tmc_dest
--   local.get $a0 … return_call $root__disploop)
wDispResetWrapper : String -> String -> List String -> Int -> List String
wDispResetWrapper name loopName params arity =
  let sig = "  (func $\{gname name}\{joinWith "" (map paramDeclRef params)} (result (ref eq))"
  let reset = [
    "i32.const 1",
    "global.set " ++ wDispFirstL name,
    "ref.null eq",
    "global.set " ++ wDispHeadL name,
    "ref.null eq",
    "global.set " ++ wDispDestL name,
  ]
  let forward = flatMap (p => ["local.get $" ++ gname p]) params ++ ["return_call $" ++ gname loopName]
  [sig] ++ indent (reset ++ forward) ++ ["  )"]

-- emit a non-root group MEMBER (or the root's inner loop): the ordinary clause machinery,
-- but with the dispatch context LIVE so spine cons leaves + the root's base redirect.
-- `emitName` is the wasm fn name to emit under (the inner loop for the root; the fn's own
-- name for a non-root member).
emitWDispMemberFn : Prog -> WDispGroup -> String -> String -> Int -> List CClause -> <Mut> List String
emitWDispMemberFn prog grp emitName origName arity clauses =
  let root = wDispRootOf grp
  let params = synthParams arity
  let loopName = wDispLoopName root
  -- the dispatch context carries the ROOT's arity (for the bare-root-call redirect
  -- check), NOT this member's arity — a member like scanAt is arity-6 but the bare
  -- call it makes to `scan` is arity-5.  It also carries the MEMBER SET so spine
  -- cons leaves targeting a non-root member return_call that member directly.
  let rootArity = progFnArity prog root
  let saved = wDispCtxRef.value
  let _ = setRef wDispCtxRef (WDispOn root loopName rootArity (wDispMembersOf grp))
  let bodyLines = emitClausesRef prog origName params arity clauses
  let _ = setRef wDispCtxRef saved
  let allLocals = clauseLocals clauses
  let extraLocals = filterList (notIn params) (dedupKeep allLocals)
  let scratch = scratchLocals (clausesMaxDepth clauses)
  let sig = "  (func $\{gname emitName}\{joinWith "" (map paramDeclRef params)} (result (ref eq))"
  -- the member needs the tmc temp local ($__tmc_t0 = the fresh cell stash).
  let tmcLocal = ["(local " ++ wTrmcTempL 0 ++ " (ref null eq))"]
  let localDecls = map localDeclRef (extraLocals ++ scratch)
  let w7Decls = w7LocalDecls (clausesMaxDepth clauses)
  [sig] ++ map ("  " ++ _) (tmcLocal ++ localDecls ++ w7Decls) ++ indent bodyLines ++ ["  )"]

-- the spine-cons leaf rewrite (case 2), generalized to N cells + any group-member
-- target: build each peeled cell in source order (lead field + placeholder tail),
-- link it into $g_tmc_dest (or seed $g_tmc_head on the very first cell), advance the
-- dest — the second-and-later cells naturally chain through the just-advanced dest —
-- then emit the bottom call's ARGS + `return_call` the target (`$root__disploop` for
-- the root, the member fn itself otherwise).  NO struct.new holds the recursion →
-- the leaf frame dies.
emitWDispSpineCons : Prog -> List String -> String -> String -> List CExpr -> List CExpr -> <Mut> List String
emitWDispSpineCons prog env root target heads args = flatMap (h => emitWDispCell prog env root h) heads
  ++ flatMap (a => emitRefExpr prog env 0 a) args
  ++ ["return_call $" ++ gname target]

-- one Cons cell of a spine-cons leaf: build, link, advance.
emitWDispCell : Prog -> List String -> String -> CExpr -> <Mut> List String
emitWDispCell prog env root head =
  let cellStruct = "C_Cons"
  let tag = ["i32.const " ++ intToString (ctorOrdinal prog "Cons")]
  let headInstrs = emitRefExpr prog env 0 head
  let placeholder = ["i32.const 1", "ref.i31"]
  let buildCell = tag ++ headInstrs ++ placeholder ++ ["struct.new $" ++ cellStruct]
  let stashNew = buildCell ++ ["local.set " ++ wTrmcTempL 0]
  -- link: first cell → head:=cell, first:=0 ; else struct.set dest.tail := cell.
  let linkSeed = ["local.get " ++ wTrmcTempL 0, "global.set " ++ wDispHeadL root,
                  "i32.const 0", "global.set " ++ wDispFirstL root]
  let linkSet = ["global.get " ++ wDispDestL root, "ref.cast (ref $" ++ cellStruct ++ ")",
                 "local.get " ++ wTrmcTempL 0, "ref.as_non_null",
                 "struct.set $" ++ cellStruct ++ " 2"]
  let linkInstrs = ["global.get " ++ wDispFirstL root, "if"] ++ indent linkSeed ++ ["else"] ++ indent linkSet ++ ["end"]
  let advance = ["local.get " ++ wTrmcTempL 0, "global.set " ++ wDispDestL root]
  stashNew ++ linkInstrs ++ advance

-- the root's BASE leaf (case 1): close the dest with the real value of the base (the
-- spine's terminator, e.g. `[]` = Nil), then return $g_tmc_head.  If no cell was ever
-- built ($g_tmc_first still 1) the whole result IS the base value.
emitWDispBase : Prog -> List String -> String -> CExpr -> <Mut> List String
emitWDispBase prog env root e =
  let valInstrs = emitRefExpr prog env 0 e
  let cellStruct = "C_Cons"
  let storeBranch = ["global.get " ++ wDispDestL root, "ref.cast (ref $" ++ cellStruct ++ ")"] ++ valInstrs ++ ["struct.set $" ++ cellStruct ++ " 2"]
  let seedBranch = valInstrs ++ ["global.set " ++ wDispHeadL root]
  ["global.get " ++ wDispFirstL root, "if"]
    ++ indent seedBranch
    ++ ["else"]
    ++ indent storeBranch
    ++ ["end"]
    ++ ["global.get " ++ wDispHeadL root, "ref.as_non_null", "return"]

-- layer-18: the plain-tail impl-method return_call rewrite (helper for emitAppTail's
-- CMethod arm).  Some instrs ⇒ this tail CMethod application is a saturated self-call to
-- the impl `(method, tag)` we are currently emitting, lowered to `return_call
-- $mdk_impl_<tag>_<method>` (the args + forwarded dict words, exactly as the ordinary RKey
-- `call` arm builds them, but tail).  None ⇒ not a self-call (or no impl-self context) ⇒
-- the caller keeps the ordinary `call … ; return`.  Gated on BOTH the impl-self context
-- AND `isSelfSatApp (SelfByMethod …)`: a different-method/tag, unsaturated, or non-self
-- call fails the gate and stays ordinary; a non-tail self-call never reaches here.
implSelfReturnCall : Prog -> List String -> String -> Route -> List Route -> List Route -> CExpr -> List CExpr -> <Mut> Option (List String)
implSelfReturnCall prog env name route methRoutes implRoutes app args = match implSelfCtxRef.value
  ImplSelfOff => None
  ImplSelfOn method tag arity => if name == method && isSelfSatApp (SelfByMethod method tag) arity app then match route
    RKey rtag _ => match implForW prog name rtag
      Some _ =>
        let dictWords = flatMap (routeWitness prog env 0) (methRoutes ++ implRoutes)
        let argInstrs = flatMap (a => emitRefExpr prog env 0 a) args
        Some
          (dictWords ++ argInstrs ++ ["return_call $" ++ implFnSym rtag name])
      None => None
    _ => None
  else None

-- a tail application: saturated direct known-fn → return_call; ctor → value+return;
-- everything else → indirect via return_call $mdk_apply.
emitAppTail : Prog -> List String -> Int -> CExpr -> <Mut> List String
emitAppTail prog env arity app =
  let (hd, args) = flattenApp app []
  match hd
    CVar f0 _ =>
      let f = canonFn prog f0
      -- tail-position `__fallthrough__ ()` / `__ft__<label> ()`: lower the sentinel
      -- (a `br`, NOT a `return` — control leaves the clause, not the function).
      if isFtSentinel f0 then ftSentinelInstrs f0
      -- E24 (wasm peer): a LOCALLY-BOUND name shadows any same-named ctor / known top-level
      -- fn / extern — applying it is an INDIRECT tail call (`return_call $mdk_apply`), never a
      -- direct `return_call $<toplevel>`.  Same guard as emitAppRef's CVar arm; without it a
      -- method-named HOF param colliding with a top-level fn (`pickEq eq x y = eq x y`) tail-
      -- called the WRONG callee.  Mirrors emitVarRefPlain's `contains x env`-first priority.
      else if contains f0 env then
        let hi = emitRefExpr prog env 0 hd
        let arr = emitArgsArray prog env 0 args
        hi ++ arr ++ ["return_call $mdk_apply"]
      else if isCtor prog f then emitRefExpr prog env 0 app ++ ["return"]
      else if isNetExternW f then gapL ("wasm: net extern '" ++ f ++ "' is native-only — the `net` module cannot target wasm (raw BSD sockets have no WasmGC equivalent). Build for a native target instead.")
      else if f == "Ref" || f == "setRef" || isStrExternW f || isLeafExternW f || isArrayExternW f || isDeferredFloatExternW f || isUnimplStrExternW f then
        emitAppRef prog env 0 app ++ ["return"]
      else if contains f (progFnNames prog) && listLen args == progFnArity prog f then
        flatMap (a => emitRefExpr prog env 0 a) args ++ ["return_call $" ++ gname f]
      else
        let hi = emitRefExpr prog env 0 hd
        let arr = emitArgsArray prog env 0 args
        hi ++ arr ++ ["return_call $mdk_apply"]
    -- W5: a dispatched method/constrained-fn in tail position.  Compute the
    -- dispatch result via the value emitter (an RKey direct call, an RDict
    -- if-chain, or a CDict dict-prepended call) and `return` it.  (return_call
    -- specialization of the RKey direct call is deferred; the dispatch fixtures
    -- here are not deep-recursive through a method, so a plain return is sound.)
    CMethod name route implRoutes methRoutes =>
      -- layer-18: a PLAIN-tail impl-method self-call.  When we are emitting impl
      -- `(method, tag)`'s ordinary body and THIS tail application is a saturated self-call
      -- to exactly that `CMethod method (RKey tag)` (`isSelfSatApp (SelfByMethod …)`), emit
      -- the recomputed args + `return_call $mdk_impl_<tag>_<method>` (a real tail call, zero
      -- stack growth) instead of `call … ; return`.  This is the impl-method analog of the
      -- top-level plain-tail return_call.  SAFETY NET: gated on the saturated-self-call
      -- detection AND on being in tail position (only emitAppTail reaches here); a NON-tail
      -- self-call goes through emitRefExpr/emitMethodRef and stays a plain `call`.  A
      -- self-call to a DIFFERENT method/tag, or an unsaturated one, fails the gate and stays
      -- ordinary.  (A cons-tail impl is already diverted to wTrmcImplTry's TMC loop and never
      -- reaches this path.)
      match implSelfReturnCall prog env name route methRoutes implRoutes app args
        Some retInstrs => retInstrs
        None => emitMethodRef prog env 0 name route implRoutes methRoutes args ++ ["return"]
    CDict name routes => emitDictRef prog env 0 name routes args ++ ["return"]
    _ =>
      let hi = emitRefExpr prog env 0 hd
      let arr = emitArgsArray prog env 0 args
      hi ++ arr ++ ["return_call $mdk_apply"]

-- a block in tail position: the last CSExpr is the tail; everything before is a
-- statement (effect/let).  (W4 blocks in tail position only appear via desugared
-- sequencing; the last expr is the result.)
emitBlockTail : Prog -> List String -> Int -> List CStmt -> <Mut> List String
emitBlockTail prog env arity [CSExpr ex] = emitRefTail prog env arity ex
emitBlockTail prog env arity ((CSExpr ex)::rest) = emitRefExpr prog env 0 ex
  ++ ["drop"]
  ++ emitBlockTail prog env arity rest
emitBlockTail prog env arity ((CSLet _ (PVar x) ex)::rest) = emitRefExpr prog env 0 ex
  ++ ["local.set $" ++ gname x]
  ++ emitBlockTail prog (x::env) arity rest
emitBlockTail prog env arity ((CSLet _ PWild ex)::rest) = emitRefExpr prog env 0 ex
  ++ ["drop"]
  ++ emitBlockTail prog env arity rest
emitBlockTail prog env arity ((CSLet _ pat ex)::rest) =
  let (binds, env2) = emitDestructureLet prog env 0 pat ex
  binds ++ emitBlockTail prog env2 arity rest
emitBlockTail prog env arity ((CSLetElse pat ex els)::rest) = emitLetElseTail
  prog
  env
  arity
  pat
  ex
  els
  (env2 => emitBlockTail prog env2 arity rest)
emitBlockTail prog env arity ((CSAssign x ex)::rest) = emitRefExpr prog env 0 ex
  ++ ["local.set $" ++ gname x]
  ++ emitBlockTail prog env arity rest
emitBlockTail _ _ _ [] = gapL "ref-mode: empty block in tail position"
emitBlockTail _ _ _ _ =
  gapL "ref-mode: unsupported block statement in tail position"

-- a CDecision in tail position: each arm body is itself in tail position.  Reuse the
-- W3 decision machinery but route arm bodies through emitRefTail (so a tail call in
-- a match arm is a return_call).  The decision's result block is no longer needed —
-- each arm either return_calls or value+returns, so the function returns directly
-- from within the tower.  We emit the scrutinee stash + the tree with TAIL arm
-- emission.  `decLabel` is unused for tail arms (they `return`/`return_call`), but
-- the tree walker still threads it; we pass a dead label that is never branched to.
emitDecisionTail : Prog -> List String -> Int -> CExpr -> List CArm -> CTree -> <Mut> List String
emitDecisionTail prog env arity scrut arms tree =
  let st = emitRefExpr prog env 0 scrut
  let scrutL = scratchLocal 0
  let occ0 = ["local.get $" ++ scrutL]
  st
    ++ ["local.set $" ++ scrutL]
    ++ emitTreeTail prog env arity 1 occ0 [occ0] arms tree

-- the decision tree, with arm LEAVES emitted in tail position.  Structurally mirrors
-- emitTreeRef but: leaves → emitRefTail (return_call / value+return), and switches do
-- NOT need a result block (each path returns).  Reuses the same br_table tower shape
-- with the slot bodies tail-emitting their arms.
emitTreeTail : Prog -> List String -> Int -> Int -> List String -> List (List String) -> List CArm -> CTree -> <Mut> List String
emitTreeTail prog env arity d root occs arms CTFail =
  wasmTrap "E-NONEXHAUSTIVE-MATCH" "non-exhaustive match"
emitTreeTail prog env arity d root occs arms (CTLeaf i) =
  emitLeafTail prog env arity root arms i
emitTreeTail prog env arity d root occs arms (CTGuard i fail) =
  emitGuardArmTail prog env arity d root occs arms i fail
emitTreeTail prog env arity d root occs arms (CTDrop sub) =
  emitTreeTail prog env arity d root (tailList occs) arms sub
emitTreeTail prog env arity d root occs arms (CTSwitch branches dft) =
  emitSwitchTail prog env arity d root occs arms branches dft

-- W-SQLITE-4 stage 2: same ctor-payload Float binder seeding as emitLeafRef,
-- but for arm bodies in TAIL POSITION (emitRefTail path).
emitLeafTail : Prog -> List String -> Int -> List String -> List CArm -> Int -> <Mut> List String
emitLeafTail prog env arity root arms i = match nthArm arms i
  Some (CArm pat _ body) =>
    let (binds, env2) = bindPatRef prog env pat root
    let floatBinders = ctorPatFloatBinders pat
    let savedFloat = floatLocalsRef.value
    let _ = setRef floatLocalsRef (floatBinders ++ savedFloat)
    let bodyCode = emitRefTail prog env2 arity body
    let _ = setRef floatLocalsRef savedFloat
    binds ++ bodyCode
  None => gapL "ref-mode: tail decision arm index out of range"

-- W-SQLITE-4 stage 2: same ctor-payload Float binder seeding as emitGuardArmRef,
-- for guarded arms in tail position.
emitGuardArmTail : Prog -> List String -> Int -> Int -> List String -> List (List String) -> List CArm -> Int -> CTree -> <Mut> List String
emitGuardArmTail prog env arity d root occs arms i fail = match nthArm arms i
  Some (CArm pat guards body) => if allBoolGuards guards then
    let (binds, env2) = bindPatRef prog env pat root
    let floatBinders = ctorPatFloatBinders pat
    let savedFloat = floatLocalsRef.value
    let _ = setRef floatLocalsRef (floatBinders ++ savedFloat)
    let gLabel = "$gt" ++ intToString d
    let armCode = ["block " ++ gLabel] ++ indent (binds ++ flatMap (emitGuardTest prog env2 0 gLabel) guards ++ emitRefTail prog env2 arity body) ++ ["end"]
    let _ = setRef floatLocalsRef savedFloat
    armCode ++ emitTreeTail prog env arity d root occs arms fail
  else gapL "ref-mode: refutable pattern guard (`p <- e`) in a tail match arm — not yet lowered"
  None => gapL "ref-mode: tail guarded arm index out of range"

emitSwitchTail : Prog -> List String -> Int -> Int -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> <Mut> List String
emitSwitchTail prog env arity d root [] arms branches dft =
  emitTreeTail prog env arity d root [] arms dft
emitSwitchTail prog env arity d root (foc::rest) arms [] dft =
  emitTreeTail prog env arity d root rest arms dft
emitSwitchTail prog env arity d root (foc::rest) arms (branches@((CTBranch (HLit _) _)::_)) dft = emitLitSwitchTail prog env arity d root foc rest arms branches dft
emitSwitchTail prog env arity d root (foc::rest) arms ((CTBranch HUnit sub)::_) dft = emitTreeTail prog env arity d root rest arms sub
emitSwitchTail prog env arity d root (foc::rest) arms (branches@((CTBranch h _)::_)) dft = match conHeadInfo h
  Some _ => emitConSwitchTail prog env arity d root foc rest arms branches dft
  None => gapL "ref-mode: unsupported tail switch head"

-- constructor switch (tail): stash focus, br_table on the discriminant; each slot
-- tail-emits its arm (which return_calls / returns), so we need no result block.
emitConSwitchTail : Prog -> List String -> Int -> Int -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> <Mut> List String
emitConSwitchTail prog env arity d root foc rest arms branches dft =
  let ty = switchTypeName prog branches
  let nOrd = typeCtorCount prog ty
  let sv = scratchLocal d
  let svRead = ["local.get $" ++ sv]
  foc
    ++ ["local.set $" ++ sv]
    ++ emitBrTableTowerTail prog env arity (d + 1) root svRead rest arms branches dft ty d nOrd

-- the br_table tower in tail position: no `$swd` result block — each ordinal slot's
-- body tail-emits its arm (return_call / return), and the default subtree follows the
-- innermost `end`.  The table targets `$sw<sd>_k` slots; the default slot is the last
-- `end`'s fall-through into the default subtree.
emitBrTableTowerTail : Prog -> List String -> Int -> Int -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> String -> Int -> Int -> <Mut> List String
emitBrTableTowerTail prog env arity d root svRead rest arms branches dft ty sd nOrd =
  let sfx = intToString sd
  let labels = map (k => "$swt\{sfx}_\{intToString k}") (rangeList 0 nOrd)
  let dftLabel = "$swdt" ++ sfx
  let tableInstr = "br_table \{joinWith " " labels} \{dftLabel}"
  let opens = ["block " ++ dftLabel] ++ map (k => "block $swt\{sfx}_\{intToString k}") (rangeList 0 nOrd)
  let pick = discrimReadOf svRead ty ++ [tableInstr]
  opens
    ++ pick
    ++ towerBodiesTail prog env arity d root svRead rest arms branches dft ty sd (nOrd - 1)

towerBodiesTail : Prog -> List String -> Int -> Int -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> String -> Int -> Int -> <Mut> List String
towerBodiesTail prog env arity d root svRead rest arms branches dft ty sd k =
  if k < 0 then
    ["end"] ++ emitTreeTail prog env arity d root rest arms dft
  else
    ["end"] ++ emitOrdinalSlotTail prog env arity d root svRead rest arms branches ty sd k ++ towerBodiesTail prog env arity d root svRead rest arms branches dft ty sd (k - 1)

emitOrdinalSlotTail : Prog -> List String -> Int -> Int -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> String -> Int -> Int -> <Mut> List String
emitOrdinalSlotTail prog env arity d root svRead rest arms branches ty sd k = match branchForOrdinal prog branches ty k
  Some (CTBranch h sub) =>
    let (c, a) = conHeadInfoUnsafe h
    let fieldOccs = map (i => svRead ++ [
      "ref.cast (ref $" ++ ctorStructName c ++ ")",
      "struct.get $\{ctorStructName c} \{intToString (i + 1)}",
    ]) (rangeList 0 a)
    emitTreeTail prog env arity d root (fieldOccs ++ rest) arms sub
  None => ["br $swdt" ++ intToString sd]

emitLitSwitchTail : Prog -> List String -> Int -> Int -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> <Mut> List String
emitLitSwitchTail prog env arity d root foc rest arms [] dft =
  emitTreeTail prog env arity d root rest arms dft
emitLitSwitchTail prog env arity d root foc rest arms ((CTBranch (HLit (LInt k)) sub)::more) dft = foc ++ ["ref.cast (ref i31)", "i31.get_s", "i32.const " ++ intToString k, "i32.eq"] ++ ["if"] ++ indent (emitTreeTail prog env arity d root rest arms sub) ++ ["else"] ++ indent (emitLitSwitchTail prog env arity d root foc rest arms more dft) ++ ["end", "unreachable"]
-- W6: Char-literal switch head — a Char is an i31 codepoint immediate (cf.
-- `PLit (LChar)`); compare the i31 against the codepoint constant.
emitLitSwitchTail prog env arity d root foc rest arms ((CTBranch (HLit (LChar c)) sub)::more) dft = foc ++ ["ref.cast (ref i31)", "i31.get_u", "i32.const " ++ intToString (charCode (arrayGetUnsafe 0 (stringToChars c))), "i32.eq"] ++ ["if"] ++ indent (emitTreeTail prog env arity d root rest arms sub) ++ ["else"] ++ indent (emitLitSwitchTail prog env arity d root foc rest arms more dft) ++ ["end", "unreachable"]
-- W6: String-literal switch head — compare the focus $str against each literal via
-- `$mdk_str_compare` (returns the i31 1 on equal), reusing the `PLit (LString)` logic.
emitLitSwitchTail prog env arity d root foc rest arms ((CTBranch (HLit (LString s)) sub)::more) dft =
  let _ = setRef useStrSearchRef True
  let _ = setRef useStrLeafRef True
  let _ = setRef useStrRef True
  foc
    ++ ["ref.cast (ref $str)"]
    ++ emitLitRef (LString s)
    ++ [
      "call $mdk_str_compare",
      "ref.cast (ref i31)",
      "i31.get_u",
      "i32.const 1",
      "i32.eq",
    ]
    ++ ["if"]
    ++ indent (emitTreeTail prog env arity d root rest arms sub)
    ++ ["else"]
    ++ indent (emitLitSwitchTail prog env arity d root foc rest arms more dft)
    ++ ["end", "unreachable"]
emitLitSwitchTail _ _ _ _ _ _ _ _ _ _ =
  gapL "ref-mode: non-Int literal tail switch head"

-- ── §4 closure (CLam) lowering — lambda-lift + arity-in-struct ───────────────
-- A CLam is lambda-lifted to a top-level $codety function `$mdk_lamN`.  Its FREE
-- variables (names referenced in the body, minus the lambda's own params, that are
-- live in the enclosing env) are CAPTURED into the closure's $env array, in a fixed
-- order.  The lifted function reads its captures from `self`'s $env (cast to $clos)
-- and its params from the $args array.  At the USE site we build the $clos struct:
-- code = `ref.func $mdk_lamN`, arity = the lambda's param count, env = the captured
-- values emitted from the current env.  Arity lives IN THE STRUCT (§11) so apply
-- never consults a name-keyed table.
emitClosure : Prog -> List String -> Int -> List Pat -> CExpr -> <Mut> List String
emitClosure prog env d pats body =
  let n = freshLamId ()
  let lamName = "$mdk_lam" ++ intToString n
  -- W2/cat2: a param may be a destructuring pattern (tuple/ctor); its BOUND vars
  -- (patVars) — not a single synthetic name — are what the body's free-var set
  -- subtracts, so the captures are computed over the real bound names.
  let boundVars = flatMap patVars pats
  let captured = filterList (c => contains c env) (dedupKeep (freeVarsExpr boundVars body))
  let _ = noteFuncRef lamName
  let _ = addLifted (emitLamDefine prog lamName pats captured body)
  -- build the closure struct at the use site: ref.func, arity, env array of captures.
  let capInstrs = flatMap (c => ["local.get $" ++ gname c]) captured
  ["ref.func " ++ lamName, "i32.const " ++ intToString (listLen pats)]
    ++ capInstrs ++ ["array.new_fixed $argarr " ++ intToString (listLen captured), "struct.new $clos"]

-- the lifted lambda body.  Prologue: bind each captured var from self's $env (cast
-- self to $clos, get $env, array.get i, non-null) into its local; bind each param
-- from the $args array.  Then TAIL-emit the body.
emitLamDefine : Prog -> String -> List Pat -> List String -> CExpr -> <Mut> List String
emitLamDefine prog lamName pats captured body =
  let arity = listLen pats
  -- each param i: load $args[i] into a synthetic local `$__lp<i>`, then bind its
  -- (possibly-destructuring) pattern against that local via bindPatRef (the same
  -- field-extraction machinery match-arm leaves / destructuring-lets use).
  let synthPs = map (i => "__lp" ++ intToString i) (rangeList 0 arity)
  let capPrologue = flatMap (capLoadAt) (zipIdx captured 0)
  let argLoads = flatMap (argLoadAt) (zipIdx synthPs 0)
  let (paramBinds, bodyEnv0) = bindParamPats prog (captured ++ synthPs) (zipPatsP pats synthPs)
  let bodyEnv = bodyEnv0
  let patBoundVars = flatMap patVars pats
  let bodyLocals = filterList (notIn (synthPs ++ captured ++ patBoundVars)) (dedupKeep (collectExprLocals body))
  let scratch = scratchLocals (maxRefDepth body)
  let localLines = ["(local $__self_clos (ref $clos))"]
    ++ map (l => localDeclRef l) (synthPs ++ captured ++ patBoundVars ++ bodyLocals ++ scratch)
    ++ w7LocalDecls (maxRefDepth body)
  let setup = ["local.get $self", "ref.cast (ref $clos)", "local.set $__self_clos"]
  -- A lifted lambda is an INDEPENDENT function: it must NOT inherit the enclosing
  -- fn's TMC loop context (wTrmcCtxRef) nor a dispatch-group context (wDispCtxRef).
  -- emitLamDefine can run while one of those is LIVE (a cons-tail clause body whose
  -- lead-field / recomputed-arg builds a closure is emitted under a live wTrmcCtxRef),
  -- and without clearing it the lambda body's tail leaves would emit `$__tmc_*` /
  -- `$tmcloop` references that this lambda never declares as locals → invalid wasm.
  let savedTrmc = wTrmcCtxRef.value
  let savedDisp = wDispCtxRef.value
  let _ = setRef wTrmcCtxRef WTrmcOff
  let _ = setRef wDispCtxRef WDispOff
  -- A1 (poly-`Num`-on-Float, design row 6): a lambda's own params carry no declared
  -- sig, so its arith-used params are polymorphic `Num` (the arith-section accumulator
  -- `a x => a + x` in `fold`).  Seed them (unioned with the enclosing poly set, whose
  -- captured vars may also be poly) so the lambda body routes to the value helpers.
  let savedNumPoly = numPolyLocalsRef.value
  let _ = setRef numPolyLocalsRef (dedupKeep (lamPolyParamNames pats body ++ savedNumPoly))
  let bodyLines = emitRefTail prog bodyEnv arity body
  let _ = setRef numPolyLocalsRef savedNumPoly
  let _ = setRef wTrmcCtxRef savedTrmc
  let _ = setRef wDispCtxRef savedDisp
  ["  (func " ++ lamName ++ " (type $codety) (param $self (ref eq)) (param $args (ref $argarr)) (result (ref eq))"]
    ++ map ("  " ++ _) localLines
    ++ indent (setup ++ capPrologue ++ argLoads ++ paramBinds ++ bodyLines)
    ++ ["  )"]

-- bind a list of (pattern, synthetic-local-name) lambda params: for each, run
-- bindPatRef against `local.get $<synth>` (the pattern is irrefutable — the type
-- proves the shape, like a destructuring let).  Threads the env left-to-right.
bindParamPats : Prog -> List String -> List (Pat, String) -> <Mut> (List String, List String)
bindParamPats _ env [] = ([], env)
bindParamPats prog env ((p, a)::rest) =
  let (binds, env2) = bindPatRef prog env p ["local.get $" ++ gname a]
  let (more, env3) = bindParamPats prog env2 rest
  (binds ++ more, env3)

-- zip patterns to synthetic param names (peer of zipPats but for synthetic params).
zipPatsP : List Pat -> List String -> List (Pat, String)
zipPatsP (p::ps) (a::bs) = (p, a) :: zipPatsP ps bs
zipPatsP _ _ = []

-- load captured var i: $__self_clos.$env[i] → its local.
capLoadAt : (String, Int) -> List String
capLoadAt (c, i) = [
  "local.get $__self_clos",
  "struct.get $clos $env",
  "i32.const " ++ intToString i,
  "array.get $argarr",
  "ref.as_non_null",
  "local.set $" ++ gname c,
]

-- load param i: $args[i] → its local.
argLoadAt : (String, Int) -> List String
argLoadAt (p, i) = [
  "local.get $args",
  "i32.const " ++ intToString i,
  "array.get $argarr",
  "ref.as_non_null",
  "local.set $" ++ gname p,
]

-- ── W9: CLetGroup (where / local letrec functions) ───────────────────────────
-- A `where`/`let`-group of (possibly mutually-recursive, multi-clause) LOCAL
-- functions, lambda-lifted to top-level functions.  Strategy (the wasm peer of
-- llvm_emit.emitKnotRun):
--   * groupCaps = the free vars across ALL bindings' clause bodies, minus every
--     binding's own params and minus the group's own names, kept to those visible
--     in the enclosing env.  This single capture set is shared by every member.
--   * each binding `name` is lifted to `$mdk_lgN_<name>` whose $env carries
--     groupCaps.  Its prologue (a) loads groupCaps from $env, (b) REBUILDS every
--     group member's closure (ref.func + arity + an $argarr of groupCaps) into a
--     local — so a member body referencing itself or a sibling resolves to a fresh
--     closure with the same captures (the knot is tied by reconstruction, no cyclic
--     heap value needed), (c) loads its own params from $args, then emits the
--     clause chain.
--   * the USE site (the group body) rebuilds the same closures into locals from the
--     enclosing env, then emits the body — so the body sees each group name bound.
-- A zero-binding group is just its body.
emitLetGroupRef : Prog -> List String -> Int -> List CBind -> CExpr -> <Mut> List String
emitLetGroupRef prog env d binds body =
  let gid = freshLamId ()
  let names = map lgBindName binds
  let allParams = flatMap lgBindParams binds
  let groupCaps = filterList (c => contains c env)
        (dedupKeep (filterList (notIn (names ++ allParams)) (flatMap (freeVarsClauses []) binds)))
  -- emit each lifted top-level fn (drained into the module like other lifted lams).
  let _ = forEachU (b => emitLgLifted prog gid names groupCaps binds b) binds
  -- at the use site: rebuild every member closure from the enclosing env, bind to a
  -- local, then emit the body with those names in scope.
  let rebuilds = flatMap (b => rebuildLgClosure prog gid groupCaps b) binds
  rebuilds ++ emitRefTail2 prog (names ++ env) d body

-- when a group body is in NON-tail position we still want to evaluate it leaving a
-- value on the stack; emitRefExpr handles every node, so use it directly (the body
-- closures are already bound as locals above).
emitRefTail2 : Prog -> List String -> Int -> CExpr -> <Mut> List String
emitRefTail2 prog env d body = emitRefExpr prog env d body

-- params of a CLetGroup binding (the first clause's pattern arity → synthetic names).
lgBindParams : CBind -> List String
lgBindParams (CBind _ clauses) = synthParams (clauseArityOf clauses)

-- the lifted member function `$mdk_lg<gid>_<name>`: $env = groupCaps; prologue loads
-- caps, rebuilds every member closure into its local, loads own params, emits clauses.
emitLgLifted : Prog -> Int -> List String -> List String -> List CBind -> CBind -> <Mut> Unit
emitLgLifted prog gid names groupCaps binds (CBind name clauses) =
  let _ = setRef curBindRef ("lg:" ++ name)
  let lamName = "$mdk_lg\{intToString gid}_\{gname name}"
  let _ = noteFuncRef lamName
  let arity = clauseArityOf clauses
  let params = synthParams arity
  let capPrologue = flatMap (capLoadAt) (zipIdx groupCaps 0)
  let memberRebuilds = flatMap (b => rebuildLgClosure prog gid groupCaps b) binds
  let argPrologue = flatMap (argLoadAt) (zipIdx params 0)
  -- a lifted letgroup member is an independent function: clear any live TMC /
  -- dispatch-group context so its body doesn't leak `$__tmc_*`/`$tmcloop` references
  -- (see emitLamDefine — same hazard when lifted under a live wTrmcCtxRef).
  let savedTrmc = wTrmcCtxRef.value
  let savedDisp = wDispCtxRef.value
  let _ = setRef wTrmcCtxRef WTrmcOff
  let _ = setRef wDispCtxRef WDispOff
  let bodyLines = emitClausesRefEnv prog (names ++ groupCaps) name params arity clauses
  let _ = setRef wTrmcCtxRef savedTrmc
  let _ = setRef wDispCtxRef savedDisp
  let memberLocals = names
  let bodyLocals = filterList (notIn (params ++ groupCaps ++ memberLocals)) (dedupKeep (clauseLocals clauses))
  let scratch = scratchLocals (clausesMaxDepth clauses)
  let localLines = ["(local $__self_clos (ref $clos))"]
    ++ map (n => "(local $" ++ gname n ++ " (ref eq))") memberLocals
    ++ map (l => localDeclRef l) (params ++ groupCaps ++ bodyLocals ++ scratch)
    ++ w7LocalDecls (clausesMaxDepth clauses)
  let setup = ["local.get $self", "ref.cast (ref $clos)", "local.set $__self_clos"]
  let def = ["  (func " ++ lamName ++ " (type $codety) (param $self (ref eq)) (param $args (ref $argarr)) (result (ref eq))"]
    ++ map ("  " ++ _) localLines
    ++ indent (setup ++ capPrologue ++ memberRebuilds ++ argPrologue ++ bodyLines)
    ++ ["  )"]
  addLifted def

-- rebuild ONE member's closure value (ref.func + arity + $argarr of groupCaps) and
-- bind it to its local `$<name>`.  Used BOTH at the use site and inside each lifted
-- member's prologue; groupCaps must be bound as locals in either context.
rebuildLgClosure : Prog -> Int -> List String -> CBind -> List String
rebuildLgClosure prog gid groupCaps (CBind name clauses) =
  let lamName = "$mdk_lg\{intToString gid}_\{gname name}"
  let arity = clauseArityOf clauses
  let capInstrs = flatMap (c => ["local.get $" ++ gname c]) groupCaps
  ["ref.func " ++ lamName, "i32.const " ++ intToString arity]
    ++ capInstrs
    ++ [
      "array.new_fixed $argarr " ++ intToString (listLen groupCaps),
      "struct.new $clos",
      "local.set $" ++ gname name,
    ]

zipIdx : List String -> Int -> List (String, Int)
zipIdx [] _ = []
zipIdx (x::xs) i = (x, i) :: zipIdx xs (i + 1)

-- free variables of a lambda body (names referenced, minus the bound params; we
-- also subtract names bound by inner let/lambda/match so only truly-free names
-- remain).  Returns names in first-seen order.
freeVarsExpr : List String -> CExpr -> <Mut> List String
freeVarsExpr bound (CVar x _) = if contains x bound then [] else [x]
freeVarsExpr bound (CApp f a) = freeVarsExpr bound f ++ freeVarsExpr bound a
-- A lambda param may be a DESTRUCTURING pattern (tuple/ctor) — e.g. a `do`-bind
-- with a tuple LHS `(a, b) <- m` desugars to `andThen m (\(a, b) => …)`.  Subtract
-- ALL its bound vars (patVars, like the CLet case), not `map patName` which only
-- accepts PVar/PWild and gaps on any real pattern.  (emitClosure/emitLamDefine
-- already destructure such params via bindPatRef; only this free-var walk lagged.)
freeVarsExpr bound (CLam pats b) =
  freeVarsExpr (flatMap patVars pats ++ bound) b
freeVarsExpr bound (CLit _) = []
freeVarsExpr bound (CBinPrim _ l r _) = freeVarsExpr bound l
  ++ freeVarsExpr bound r
freeVarsExpr bound (CUnOp _ x) = freeVarsExpr bound x
freeVarsExpr bound (CIf c t f) = freeVarsExpr bound c
  ++ freeVarsExpr bound t
  ++ freeVarsExpr bound f
freeVarsExpr bound (CLet _ pat e1 e2) = freeVarsExpr bound e1
  ++ freeVarsExpr (patVars pat ++ bound) e2
freeVarsExpr bound (CBlock stmts) = freeVarsStmts bound stmts
freeVarsExpr bound (CDecision scrut arms _) = freeVarsExpr bound scrut
  ++ flatMap (freeVarsArm bound) arms
freeVarsExpr bound (CMatch scrut arms) = freeVarsExpr bound scrut
  ++ flatMap (freeVarsArm bound) arms
freeVarsExpr bound (CLetGroup binds b) =
  let names = map lgBindName binds
  let bound2 = names ++ bound
  flatMap (freeVarsClauses bound2) binds ++ freeVarsExpr bound2 b
-- compound value nodes: their sub-expressions can reference outer-bound vars
-- (e.g. a do-block's `pure (a, b, c)` lowers to CTuple — without this arm the
-- captured `a`/`b` are dropped and emit as unbound).  Each descends with the
-- SAME `bound` (these nodes introduce no binders).
freeVarsExpr bound (CTuple es) = flatMap (freeVarsExpr bound) es
freeVarsExpr bound (CList es) = flatMap (freeVarsExpr bound) es
freeVarsExpr bound (CArray es) = flatMap (freeVarsExpr bound) es
freeVarsExpr bound (CRecord _ fields) = flatMap (freeVarsField bound) fields
freeVarsExpr bound (CFieldAccess e _ _) = freeVarsExpr bound e
freeVarsExpr bound (CRecordUpdate e fields) = freeVarsExpr bound e
  ++ flatMap (freeVarsField bound) fields
freeVarsExpr bound (CVariantUpdate _ e fields) = freeVarsExpr bound e
  ++ flatMap (freeVarsField bound) fields
freeVarsExpr bound (CRangeList lo hi _) = freeVarsExpr bound lo
  ++ freeVarsExpr bound hi
freeVarsExpr bound (CRangeArray lo hi _) = freeVarsExpr bound lo
  ++ freeVarsExpr bound hi
freeVarsExpr bound (CIndex e i) = freeVarsExpr bound e ++ freeVarsExpr bound i
freeVarsExpr bound (CSlice e lo hi _) = freeVarsExpr bound e
  ++ freeVarsExpr bound lo
  ++ freeVarsExpr bound hi
-- cat4/W5: a return-position method occurrence (CMethod) and a constrained-fn
-- occurrence (CDict) carry their dispatch Routes; a route's RDict/RDictFwd names a
-- dict PARAM that is read at the use site.  Without surfacing it here, a method/
-- constrained-fn call inside a lifted lambda (`clamp lo hi = min hi >> max lo`) or a
-- where-group closure (`minimum`/`maximum`'s `step`) drops the dict from the closure
-- capture set → "dict param '$dict_…' not in scope".  (These nodes carry no value
-- args of their own — args arrive via the surrounding CApp, already handled.)
freeVarsExpr bound (CMethod _ route implRoutes methRoutes) =
  flatMap (freeVarsRoute bound) (route :: implRoutes ++ methRoutes)
freeVarsExpr bound (CDict _ routes) = flatMap (freeVarsRoute bound) routes
freeVarsExpr bound _ = []

-- the dict-param names a Route reads: RDict/RDictFwd name a leading dict param (free
-- unless locally bound); RKey recurses into its nested requires-routes; RNone none.
freeVarsRoute : List String -> Route -> List String
freeVarsRoute bound (RDict d) = if contains d bound then [] else [d]
freeVarsRoute bound (RDictFwd d) = if contains d bound then [] else [d]
freeVarsRoute bound (RKey _ rs) = flatMap (freeVarsRoute bound) rs
freeVarsRoute bound RNone = []

-- free vars of a CLetGroup binding's clauses (each clause's params are locally bound).
freeVarsClauses : List String -> CBind -> <Mut> List String
freeVarsClauses bound (CBind _ clauses) = flatMap (freeVarsClause bound) clauses

freeVarsClause : List String -> CClause -> <Mut> List String
freeVarsClause bound (CClause pats body) =
  freeVarsExpr (flatMap patVars pats ++ bound) body

lgBindName : CBind -> String
lgBindName (CBind n _) = n

freeVarsStmts : List String -> List CStmt -> <Mut> List String
freeVarsStmts _ [] = []
freeVarsStmts bound ((CSExpr e)::rest) = freeVarsExpr bound e
  ++ freeVarsStmts bound rest
freeVarsStmts bound ((CSLet _ pat e)::rest) = freeVarsExpr bound e
  ++ freeVarsStmts (patVars pat ++ bound) rest
freeVarsStmts bound (_::rest) = freeVarsStmts bound rest

freeVarsArm : List String -> CArm -> <Mut> List String
freeVarsArm bound (CArm pat guards body) =
  let bound2 = patVars pat ++ bound
  flatMap (freeVarsGuard bound2) guards ++ freeVarsExpr bound2 body

freeVarsGuard : List String -> CGuard -> <Mut> List String
freeVarsGuard bound (CGBool g) = freeVarsExpr bound g
freeVarsGuard bound (CGBind p e) = freeVarsExpr bound e

freeVarsField : List String -> CField -> <Mut> List String
freeVarsField bound (CField _ e) = freeVarsExpr bound e

-- ── ADT construction (§3.4) ──────────────────────────────────────────────────
-- A NULLARY ctor → an `i31ref` carrying its PER-TYPE dense ordinal (the same value
-- a payload ctor stores in struct field 0, so one discriminant read + one br_table
-- cover both reps within a match).  Two nullary ctors of DIFFERENT types could
-- share an i31 ordinal, but a well-typed match's scrutinee is one fixed type, so
-- only that type's ctors are ever compared — no cross-type aliasing.  The §3.4
-- structural-collapse caution is about STRUCTS (handled by the per-ctor struct type
-- + explicit i32 tag field), not i31 immediates.  A PAYLOAD ctor → `struct.new
-- $S_ctor` with the per-type dense ordinal as i32 field 0, then the (ref eq) fields.
emitCtorConstruct : Prog -> List String -> Int -> String -> List CExpr -> <Mut> List String
emitCtorConstruct prog env d ctor args =
  let arity = ctorArity prog ctor
  if arity == 0 then ["i32.const " ++ intToString (ctorOrdinal prog ctor), "ref.i31"]
  else
    let tagField = ["i32.const " ++ intToString (ctorOrdinal prog ctor)]
    let argInstrs = flatMap (a => emitRefExpr prog env d a) args
    tagField ++ argInstrs ++ ["struct.new $" ++ ctorStructName ctor]

-- ════════════════════════════════════════════════════════════════════════════
-- W7 — collections (§3.3): List / Tuple / Array / Record / Ref, ranges, index/slice
-- ════════════════════════════════════════════════════════════════════════════

-- a tuple: a single-shape struct `$C_Tup<n>` (tag-0 field + n (ref eq) fields).
-- Reuses the W3 ctor construction shape (a leading i32 tag = ordinal 0) so the match
-- machinery (discrimReadOf → struct field-0) drives HTuple uniformly.
emitTupleRef : Prog -> List String -> Int -> List CExpr -> <Mut> List String
emitTupleRef prog env d es =
  let n = listLen es
  let argInstrs = flatMap (a => emitRefExpr prog env d a) es
  ["i32.const 0"]
    ++ argInstrs
    ++ ["struct.new $" ++ ctorStructName (tupleCtorName n)]

-- a list literal: a right-nested cons spine ending in the Nil i31.  Built
-- back-to-front so the emitted struct.news nest correctly (Cons head tail).
emitListRef : Prog -> List String -> Int -> List CExpr -> <Mut> List String
emitListRef prog env d [] = emitCtorConstruct prog env d "Nil" []
emitListRef prog env d (x::xs) =
  let hd = emitRefExpr prog env d x
  let tl = emitListRef prog env d xs
  ["i32.const 0"] ++ hd ++ tl ++ ["struct.new $C_Cons"]

-- a range list [lo..hi] / [lo..=hi]: a back-to-front counted loop building the cons
-- spine in a scratch accumulator local.  The accumulator + counter reuse the
-- depth-keyed scratch locals ($__rl_acc<d> / $__rl_i<d>) declared in the header.
emitRangeListRef : Prog -> List String -> Int -> CExpr -> CExpr -> Bool -> <Mut> List String
emitRangeListRef prog env d lo hi incl =
  let loI = emitRefExpr prog env d lo ++ ["ref.cast (ref i31)", "i31.get_s"]
  let hiI = emitRefExpr prog env d hi ++ ["ref.cast (ref i31)", "i31.get_s"]
  let sfx = intToString d
  let accL = "$__rlacc" ++ sfx
  let iL = "$__rli" ++ sfx
  let loL = "$__rllo" ++ sfx
  -- count = (incl ? hi+1 : hi) - lo ; clamped at 0 by the loop guard.
  let adj = if incl then ["i32.const 1", "i32.add"] else []
  -- stash lo, init acc=Nil, i = count-1, loop i>=0: acc = Cons (lo+i) acc.
  loI ++ ["local.set " ++ loL]
    ++ ["i32.const 1", "ref.i31", "local.set " ++ accL]
    ++ hiI ++ adj ++ ["local.get " ++ loL, "i32.sub", "i32.const 1", "i32.sub", "local.set " ++ iL]
    ++ ["block $rld" ++ sfx, "loop $rll" ++ sfx]
    ++ ["local.get " ++ iL, "i32.const 0", "i32.lt_s", "br_if $rld" ++ sfx]
    ++ ["i32.const 0"]
    ++ ["local.get " ++ loL, "local.get " ++ iL, "i32.add", "ref.i31"]
    ++ ["local.get " ++ accL]
    ++ ["struct.new $C_Cons", "local.set " ++ accL]
    ++ ["local.get " ++ iL, "i32.const 1", "i32.sub", "local.set " ++ iL]
    ++ ["br $rll" ++ sfx, "end", "end"]
    ++ ["local.get " ++ accL]

-- an array literal: array.new_fixed over the emitted element values.
emitArrayCreateRef : Prog -> List String -> Int -> List CExpr -> <Mut> List String
emitArrayCreateRef prog env d es =
  let argInstrs = flatMap (a => emitRefExpr prog env d a) es
  argInstrs ++ ["array.new_fixed $arr " ++ intToString (listLen es)]

-- a range array [lo..hi] / [lo..=hi]: allocate `count` slots, fill with a counted
-- loop (peer to llvm_emit.emitRangeArray's alloca-counter loop).
emitRangeArrayRef : Prog -> List String -> Int -> CExpr -> CExpr -> Bool -> <Mut> List String
emitRangeArrayRef prog env d lo hi incl =
  let loI = emitRefExpr prog env d lo ++ ["ref.cast (ref i31)", "i31.get_s"]
  let hiI = emitRefExpr prog env d hi ++ ["ref.cast (ref i31)", "i31.get_s"]
  let sfx = intToString d
  let arrL = "$__raarr" ++ sfx
  let iL = "$__rai" ++ sfx
  let loL = "$__ralo" ++ sfx
  let cntL = "$__racnt" ++ sfx
  let adj = if incl then ["i32.const 1", "i32.add"] else []
  loI ++ ["local.set " ++ loL]
    ++ hiI ++ adj ++ ["local.get " ++ loL, "i32.sub", "local.set " ++ cntL]
    -- clamp negative count to 0
    ++ ["local.get " ++ cntL, "i32.const 0", "i32.lt_s", "if", "i32.const 0", "local.set " ++ cntL, "end"]
    ++ ["i32.const 0", "ref.i31", "local.get " ++ cntL, "array.new $arr", "local.set " ++ arrL]
    ++ ["i32.const 0", "local.set " ++ iL]
    ++ ["block $rad" ++ sfx, "loop $ral" ++ sfx]
    ++ ["local.get " ++ iL, "local.get " ++ cntL, "i32.ge_s", "br_if $rad" ++ sfx]
    ++ ["local.get " ++ arrL, "ref.as_non_null", "local.get " ++ iL]
    ++ ["local.get " ++ loL, "local.get " ++ iL, "i32.add", "ref.i31"]
    ++ ["array.set $arr"]
    ++ ["local.get " ++ iL, "i32.const 1", "i32.add", "local.set " ++ iL]
    ++ ["br $ral" ++ sfx, "end", "end"]
    ++ ["local.get " ++ arrL, "ref.as_non_null"]

-- CIndex arr i: bounds-check (i<0 or i>=len → trap, matching native @mdk_oob), then
-- array.get.  The trap is `unreachable` (WasmGC has no host-trap call here; an OOB
-- access aborting the module mirrors the native abort).
emitIndexRef : Prog -> List String -> Int -> CExpr -> CExpr -> <Mut> List String
emitIndexRef prog env d a i =
  let sfx = intToString d
  let arrL = "$__ixarr" ++ sfx
  let idxL = "$__ixi" ++ sfx
  let arrI = emitRefExpr prog env d a ++ ["ref.cast (ref $arr)", "local.set " ++ arrL]
  let idxI = emitRefExpr prog env d i ++ ["ref.cast (ref i31)", "i31.get_s", "local.set " ++ idxL]
  arrI ++ idxI
    -- bounds: idx < 0 || idx >= len → B5 coded [E-INDEX-OOB] trap (peer of native
    -- @mdk_oob; message matches medaka_rt.c, sans the index value native also omits).
    ++ ["local.get " ++ idxL, "i32.const 0", "i32.lt_s"]
    ++ ["local.get " ++ idxL, "local.get " ++ arrL, "ref.as_non_null", "array.len", "i32.ge_s"]
    ++ ["i32.or", "if"] ++ indent (wasmTrap "E-INDEX-OOB" "index out of bounds") ++ ["end"]
    ++ ["local.get " ++ arrL, "ref.as_non_null", "local.get " ++ idxL, "array.get $arr", "ref.as_non_null"]

-- CSlice arr lo hi incl: new array of (end-lo) slots, copy via array.copy.  end =
-- incl ? hi+1 : hi.  (No bounds clamping beyond non-negative count — mirrors the
-- native slice which assumes valid indices; an over-range copy traps in-engine.)
emitSliceRef : Prog -> List String -> Int -> CExpr -> CExpr -> CExpr -> Bool -> <Mut> List String
emitSliceRef prog env d a lo hi incl =
  let sfx = intToString d
  let srcL = "$__slsrc" ++ sfx
  let dstL = "$__sldst" ++ sfx
  let loL = "$__sllo" ++ sfx
  let lenL = "$__sllen" ++ sfx
  let arrI = emitRefExpr prog env d a ++ ["ref.cast (ref $arr)", "local.set " ++ srcL]
  let loI = emitRefExpr prog env d lo ++ ["ref.cast (ref i31)", "i31.get_s", "local.set " ++ loL]
  let hiI = emitRefExpr prog env d hi ++ ["ref.cast (ref i31)", "i31.get_s"]
  let adj = if incl then ["i32.const 1", "i32.add"] else []
  arrI ++ loI ++ hiI ++ adj ++ ["local.get " ++ loL, "i32.sub", "local.set " ++ lenL]
    ++ ["i32.const 0", "ref.i31", "local.get " ++ lenL, "array.new $arr", "local.set " ++ dstL]
    -- array.copy dst dstoff src srcoff len
    ++ ["local.get " ++ dstL, "ref.as_non_null", "i32.const 0", "local.get " ++ srcL, "ref.as_non_null", "local.get " ++ loL, "local.get " ++ lenL, "array.copy $arr $arr"]
    ++ ["local.get " ++ dstL, "ref.as_non_null"]

-- a named-field record construction: CRecord carries fields in DECLARED order
-- (lowering preserves it), so emit positionally — identical to a positional ctor
-- struct.new (the ctor IS a W3 user ctor with a $C_<name> struct already declared).
emitRecordRef : Prog -> List String -> Int -> String -> List CField -> <Mut> List String
emitRecordRef prog env d name fields =
  let tagField = ["i32.const " ++ intToString (ctorOrdinal prog name)]
  let argInstrs = flatMap (f => emitRefExpr prog env d (cFieldExpr f)) fields
  tagField ++ argInstrs ++ ["struct.new $" ++ ctorStructName name]

-- field access `r.label`: cast to the record's ctor struct and struct.get the field
-- at index (1 + its declared position).  The record ctor + its field order come from
-- the recFieldsRef table built in emitProgram.
emitFieldAccessRef : Prog -> List String -> Int -> CExpr -> String -> <Mut> List String
emitFieldAccessRef prog env d ex label =
  match findRecByField recFieldsRef.value label
    Some (ctor, labels) =>
      let idx = orZeroIdx (indexOfL label labels)
      emitRefExpr prog env d ex
        ++ ["ref.cast (ref $" ++ ctorStructName ctor ++ ")", "struct.get $\{ctorStructName ctor} \{intToString (idx + 1)}"]
    -- `r.value` on a Ref: no record ctor owns the field `value`, so this is a
    -- $refbox read — cast to $refbox and read the mutable field at slot 0.
    None =>
      if label == "value" then
        emitRefExpr prog env d ex ++ ["ref.cast (ref $refbox)", "struct.get $refbox 0"]
      else
        gapL ("ref-mode: CFieldAccess on unknown field '" ++ label ++ "' (no record ctor in the field-order table)")

-- functional update `{ base | f = v … }`: copy the base's struct, overriding the
-- named fields.  The record type is recovered from the first update field's label.
emitRecordUpdateRef : Prog -> List String -> Int -> CExpr -> List CField -> <Mut> List String
emitRecordUpdateRef prog env d base fields = match firstFieldLabel fields
  None => gapL "ref-mode: empty record update"
  Some k0 => match findRecByField recFieldsRef.value k0
    Some (ctor, labels) => emitUpdateCopy prog env d ctor labels base fields
    None => gapL ("ref-mode: CRecordUpdate on unknown field '" ++ k0 ++ "'")

firstFieldLabel : List CField -> Option String
firstFieldLabel [] = None
firstFieldLabel ((CField k _)::_) = Some k

-- named-field variant update `Con { base | f = v … }`: same copy, ctor known.
emitVariantUpdateRef : Prog -> List String -> Int -> String -> CExpr -> List CField -> <Mut> List String
emitVariantUpdateRef prog env d con base fields = match lookupAssoc con recFieldsRef.value
  Some labels => emitUpdateCopy prog env d con labels base fields
  None =>
    gapL ("ref-mode: CVariantUpdate on unknown constructor '" ++ con ++ "'")

-- the shared copy-with-overrides: stash the base into a scratch local, then build a
-- struct.new whose tag is the ctor ordinal and whose fields are, per declared label,
-- the override expr (if present) or a struct.get of the stashed base.
emitUpdateCopy : Prog -> List String -> Int -> String -> List String -> CExpr -> List CField -> <Mut> List String
emitUpdateCopy prog env d ctor labels base fields =
  let sfx = intToString d
  let bL = "$__rub" ++ sfx
  let baseI = emitRefExpr prog env d base ++ ["ref.cast (ref $" ++ ctorStructName ctor ++ ")", "local.set " ++ bL]
  let tagField = ["i32.const " ++ intToString (ctorOrdinal prog ctor)]
  baseI
    ++ tagField
    ++ fieldInstrsWithLabels prog env d ctor bL labels fields
    ++ ["struct.new $" ++ ctorStructName ctor]

-- per declared label index, emit the override expr or the base's struct.get.
fieldInstrsWithLabels : Prog -> List String -> Int -> String -> String -> List String -> List CField -> <Mut> List String
fieldInstrsWithLabels prog env d ctor bL labels fields = flatMap
  (lab => oneUpdateField prog env d ctor bL fields lab)
  (idxZip labels 0)

idxZip : List String -> Int -> List (Int, String)
idxZip [] _ = []
idxZip (x::xs) i = (i, x) :: idxZip xs (i + 1)

oneUpdateField : Prog -> List String -> Int -> String -> String -> List CField -> (Int, String) -> <Mut> List String
oneUpdateField prog env d ctor bL fields (idx, label) = match findUpdateExpr label fields
  Some ex => emitRefExpr prog env d ex
  None => [
    "local.get " ++ bL,
    "ref.cast (ref $" ++ ctorStructName ctor ++ ")",
    "struct.get $\{ctorStructName ctor} \{intToString (idx + 1)}",
  ]

findUpdateExpr : String -> List CField -> Option CExpr
findUpdateExpr _ [] = None
findUpdateExpr label ((CField k ex)::rest) =
  if k == label then
    Some ex
  else
    findUpdateExpr label rest

-- the (ctor, labels) of the record whose declared fields contain `label`.
findRecByField : List (String, List String) -> String -> Option (String, List String)
findRecByField [] _ = None
findRecByField ((ctor, labels)::rest) label =
  if contains label labels then
    Some (ctor, labels)
  else
    findRecByField rest label

-- ── match lowering: CDecision → discriminant + br_table + field extraction ───
-- The scrutinee is a (ref eq).  The decision tree (CTree) is walked into a nest of
-- wasm blocks.  We mirror the LLVM emitter's structure: `root` is the whole
-- scrutinee value (kept for the leaf re-match that recovers bindings); each arm
-- body computes a (ref eq).  A CTSwitch on a constructor column reads the column's
-- discriminant (i31 nullary tag vs struct field-0 ordinal) and `br_table`s on the
-- dense per-type ordinal to the matching branch.
--
-- IMPLEMENTATION: a uniform result via a labelled block that all arms `br` out of
-- with their value.  Each arm stores its (ref eq) into a fresh result LOCAL and
-- branches to the shared end.  The tree's control flow is a tower of wasm `block`s.
-- We thread occurrence-values (the focus stack) as a list of "value-producing
-- instruction snippets" (each a List String that, executed, pushes that occurrence
-- onto the stack) — the LLVM emitter uses SSA register names; we use re-emittable
-- snippets (local.get of a stashed local), which keeps it stackless and simple.

-- CDecision at nesting depth `d`.  Stashes the scrutinee into scratch local
-- `$__rf<d>` (so the focus stack re-reads it), wraps the tree in a result block
-- `$dec<d>` that arm bodies `br` out of with their value, and recurses into the
-- tree at depth `d+1` (nested matches/switches get fresh, non-colliding locals +
-- labels).  `decLabel` is `$dec<d>` — the target every arm body branches to.
emitDecisionRef : Prog -> List String -> Int -> CExpr -> List CArm -> CTree -> <Mut> List String
emitDecisionRef prog env d scrut arms tree =
  let st = emitRefExpr prog env d scrut
  let scrutL = scratchLocal d
  let decLabel = "$dec" ++ intToString d
  let occ0 = ["local.get $" ++ scrutL]
  st
    ++ ["local.set $" ++ scrutL]
    ++ ["block " ++ decLabel ++ " (result (ref eq))"]
    ++ indent (emitTreeRef prog env (d + 1) decLabel occ0 [occ0] arms tree)
    ++ ["end"]

-- emit a CTree.  `d` = nesting depth (fresh locals/labels); `decLabel` = the
-- enclosing `$dec<n>` an arm body branches to; `root` = the scrutinee occurrence
-- snippet (for leaf re-match); `occs` = the live focus columns.  Every path leaves
-- exactly one (ref eq) for `decLabel`'s block to yield (via `br decLabel`), except
-- the default tail of a switch tower which falls through with the value on the stack.
emitTreeRef : Prog -> List String -> Int -> String -> List String -> List (List String) -> List CArm -> CTree -> <Mut> List String
emitTreeRef prog env d decLabel root occs arms CTFail =
  wasmTrap "E-NONEXHAUSTIVE-MATCH" "non-exhaustive match"
emitTreeRef prog env d decLabel root occs arms (CTLeaf i) =
  emitLeafRef prog env d decLabel root arms i
emitTreeRef prog env d decLabel root occs arms (CTGuard i fail) =
  emitGuardArmRef prog env d decLabel root occs arms i fail
emitTreeRef prog env d decLabel root occs arms (CTDrop sub) =
  emitTreeRef prog env d decLabel root (tailList occs) arms sub
emitTreeRef prog env d decLabel root occs arms (CTSwitch branches dft) =
  emitSwitchRef prog env d decLabel root occs arms branches dft

-- a leaf: re-match arm i's pattern against `root` to bind its PVars (loading struct
-- fields), then emit the body, then `br decLabel` with the value.
-- W-SQLITE-4 stage 2: if the arm's pattern is a PCon with Float fields, temporarily
-- add those binder names to floatLocalsRef so cexprIsFloat sees them in the body.
emitLeafRef : Prog -> List String -> Int -> String -> List String -> List CArm -> Int -> <Mut> List String
emitLeafRef prog env d decLabel root arms i = match nthArm arms i
  Some (CArm pat _ body) =>
    let (binds, env2) = bindPatRef prog env pat root
    let floatBinders = ctorPatFloatBinders pat
    let savedFloat = floatLocalsRef.value
    let _ = setRef floatLocalsRef (floatBinders ++ savedFloat)
    let bodyCode = emitRefExpr prog env2 d body
    let _ = setRef floatLocalsRef savedFloat
    binds ++ bodyCode ++ ["br " ++ decLabel]
  None => gapL "ref-mode: decision arm index out of range"

-- a guarded arm: bind the pattern, evaluate the guards; all-pass → body + br
-- decLabel; any fail → the `fail` subtree (resumes at the same column context).
-- Fall-through is a labelled block `$g<d>`: a failed guard `br_if $g<d>` skips the
-- body, then control falls into the fail subtree after the block's `end`.
-- W-SQLITE-4 stage 2: same ctor-payload Float binder seeding as emitLeafRef.
emitGuardArmRef : Prog -> List String -> Int -> String -> List String -> List (List String) -> List CArm -> Int -> CTree -> <Mut> List String
emitGuardArmRef prog env d decLabel root occs arms i fail = match nthArm arms i
  Some (CArm pat guards body) => if allBoolGuards guards then
    let (binds, env2) = bindPatRef prog env pat root
    let floatBinders = ctorPatFloatBinders pat
    let savedFloat = floatLocalsRef.value
    let _ = setRef floatLocalsRef (floatBinders ++ savedFloat)
    let gLabel = "$g" ++ intToString d
    let armCode = ["block " ++ gLabel] ++ indent (binds ++ flatMap (emitGuardTest prog env2 d gLabel) guards ++ emitRefExpr prog env2 d body ++ ["br " ++ decLabel]) ++ ["end"]
    let _ = setRef floatLocalsRef savedFloat
    armCode ++ emitTreeRef prog env d decLabel root occs arms fail
  else gapL "ref-mode: refutable pattern guard (`p <- e`) in a match arm — not yet lowered"
  None => gapL "ref-mode: guarded arm index out of range"

-- a CGBool guard: unbox the i31 Bool; if false, br out of the guard block (skip body).
emitGuardTest : Prog -> List String -> Int -> String -> CGuard -> <Mut> List String
emitGuardTest prog env d gLabel (CGBool g) = emitRefExpr prog env d g
  ++ ["ref.cast (ref i31)", "i31.get_u", "i32.eqz", "br_if " ++ gLabel]
emitGuardTest _ _ _ _ (CGBind _ _) =
  gapL "ref-mode: refutable pattern guard (`p <- e`) — not yet lowered"

allBoolGuards : List CGuard -> Bool
allBoolGuards [] = True
allBoolGuards ((CGBool _)::rest) = allBoolGuards rest
allBoolGuards _ = False

-- a CTSwitch on the focus column.  All heads in one switch are homogeneous.  ADT
-- heads → discriminant + br_table on the dense per-type ordinal.  Int-literal heads
-- → compare immediates.  HUnit is irrefutable (drop focus, descend).
emitSwitchRef : Prog -> List String -> Int -> String -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> <Mut> List String
emitSwitchRef prog env d decLabel root [] arms branches dft =
  emitTreeRef prog env d decLabel root [] arms dft
emitSwitchRef prog env d decLabel root (foc::rest) arms [] dft =
  emitTreeRef prog env d decLabel root rest arms dft
emitSwitchRef prog env d decLabel root (foc::rest) arms (branches@((CTBranch (HLit _) _)::_)) dft = emitLitSwitchRef prog env d decLabel root foc rest arms branches dft
emitSwitchRef prog env d decLabel root (foc::rest) arms ((CTBranch HUnit sub)::_) dft = emitTreeRef prog env d decLabel root rest arms sub
emitSwitchRef prog env d decLabel root (foc::rest) arms (branches@((CTBranch h _)::_)) dft = match conHeadInfo h
  Some _ => emitConSwitchRef prog env d decLabel root foc rest arms branches dft
  None => gapL "ref-mode: unsupported switch head (constructor / int-literal / unit only)"

-- the constructor switch (§3.4): stash the focus into scratch local `$__rf<d>`,
-- read its discriminant, and `br_table` on the dense per-type ordinal.  Recurses
-- into branch subtrees at depth d+1.
emitConSwitchRef : Prog -> List String -> Int -> String -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> <Mut> List String
emitConSwitchRef prog env d decLabel root foc rest arms branches dft =
  let ty = switchTypeName prog branches
  let nOrd = typeCtorCount prog ty
  let sv = scratchLocal d
  let svRead = ["local.get $" ++ sv]
  foc
    ++ ["local.set $" ++ sv]
    ++ emitBrTableTower prog env (d + 1) decLabel root svRead rest arms branches dft ty d nOrd

-- the discriminant: from a value that is EITHER an i31 nullary (its per-type ordinal,
-- set at construction) OR a payload struct (the per-type ordinal in field 0).
-- `ref.test (ref i31)` selects the rep; both yield the SAME dense ordinal.
discrimReadOf : List String -> String -> List String
discrimReadOf svRead ty =
  -- W9: Bool is always an i31 (0/1) — it has no $T_Bool root struct, so emit the i31
  -- read directly (the generic two-branch form would reference an undeclared type in
  -- its dead struct branch and fail wasm-tools validation).
  if ty == "Bool" then svRead ++ ["ref.cast (ref i31)", "i31.get_u"]
  else svRead ++ ["ref.test (ref i31)", "if (result i32)"]
    ++ indent (svRead ++ ["ref.cast (ref i31)", "i31.get_u"])
    ++ ["else"]
    ++ indent (svRead ++ ["ref.cast (ref $" ++ typeRootName ty ++ ")", "struct.get $" ++ typeRootName ty ++ " 0"])
    ++ ["end"]

-- build the br_table tower (the standard switch idiom).  Labels are suffixed by the
-- SWITCH depth `sd` so nested switches don't collide.  Structure for nOrd cases:
--
--   block $swd<sd> (result (ref eq))
--     block $sw<sd>_{n-1} … block $sw<sd>_0
--       <discriminant i32>  br_table $sw<sd>_0 … $sw<sd>_{n-1} $swd<sd>
--     end           ;; end $sw<sd>_0 — fall through = ordinal 0 selected
--     <arm 0>  br decLabel
--     end           ;; end $sw<sd>_1
--     <arm 1>  br decLabel
--     …
--   end             ;; end $swd<sd>
--   <default subtree>          (falls through with its value on the stack)
emitBrTableTower : Prog -> List String -> Int -> String -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> String -> Int -> Int -> <Mut> List String
emitBrTableTower prog env d decLabel root svRead rest arms branches dft ty sd nOrd =
  let sfx = intToString sd
  let labels = map (k => "$sw\{sfx}_\{intToString k}") (rangeList 0 nOrd)
  let tableInstr = "br_table \{joinWith " " labels} $swd\{sfx}"
  let opens = ["block $swd" ++ sfx] ++ map (k => "block $sw\{sfx}_\{intToString k}") (rangeList 0 nOrd)
  let pick = discrimReadOf svRead ty ++ [tableInstr]
  opens
    ++ pick
    ++ towerBodies prog env d decLabel root svRead rest arms branches dft ty sd (nOrd - 1)

-- emit, innermost-first (ordinal n-1 down to 0): `end` of $sw<sd>_k then ordinal k's
-- arm; finally `end` of $swd<sd> then the default subtree (yields the block value).
towerBodies : Prog -> List String -> Int -> String -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> String -> Int -> Int -> <Mut> List String
towerBodies prog env d decLabel root svRead rest arms branches dft ty sd k =
  if k < 0 then
    ["end"] ++ emitTreeRef prog env d decLabel root rest arms dft
  else
    ["end"] ++ emitOrdinalSlot prog env d decLabel root svRead rest arms branches ty sd k ++ towerBodies prog env d decLabel root svRead rest arms branches dft ty sd (k - 1)

-- ordinal k's arm: the branch whose head has ordinal k.  Present → extract its
-- fields (ref.cast to the ctor struct + struct.get i+1) as new leading occurrences,
-- emit its subtree.  Absent → fall to $swd<sd> (the default).
emitOrdinalSlot : Prog -> List String -> Int -> String -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> String -> Int -> Int -> <Mut> List String
emitOrdinalSlot prog env d decLabel root svRead rest arms branches ty sd k = match branchForOrdinal prog branches ty k
  Some (CTBranch h sub) =>
    let (c, a) = conHeadInfoUnsafe h
    let fieldOccs = map (i => svRead ++ [
      "ref.cast (ref $" ++ ctorStructName c ++ ")",
      "struct.get $\{ctorStructName c} \{intToString (i + 1)}",
    ]) (rangeList 0 a)
    emitTreeRef prog env d decLabel root (fieldOccs ++ rest) arms sub
  None => ["br $swd" ++ intToString sd]

-- the literal switch: compare the focus i31 Int against each branch's constant via
-- an if/else chain.  The focus is re-read per comparison through `foc`.
emitLitSwitchRef : Prog -> List String -> Int -> String -> List String -> List String -> List (List String) -> List CArm -> List CTBranch -> CTree -> <Mut> List String
emitLitSwitchRef prog env d decLabel root foc rest arms [] dft =
  emitTreeRef prog env d decLabel root rest arms dft
emitLitSwitchRef prog env d decLabel root foc rest arms ((CTBranch (HLit (LInt k)) sub)::more) dft =
  -- W6 (validate fix): a NO-RESULT `if`.  Every decision-tree path is `br`-terminated
  -- (leaves `br decLabel`, CTFail → unreachable, the else-chain recurses to another
  -- br-terminated `if` or the br-terminated `dft`), so the `if` never falls through
  -- with a value.  A `(result (ref eq))` form leaves a PHANTOM `(ref eq)` on the stack
  -- when this switch is NESTED inside a con-tower slot — at the slot's untyped `end`
  -- that strands the value ("values remaining on stack at end of block").  No result
  -- type ⇒ nothing stranded.
  (foc ++ ["ref.cast (ref i31)", "i31.get_s", "i32.const " ++ intToString k, "i32.eq"])
    ++ ["if"]
    ++ indent (emitTreeRef prog env d decLabel root rest arms sub)
    ++ ["else"]
    ++ indent (emitLitSwitchRef prog env d decLabel root foc rest arms more dft)
    ++ ["end"]
-- W6: Char-literal switch head — a Char is an i31 codepoint immediate (cf.
-- `PLit (LChar)`); compare the i31 against the codepoint constant.
emitLitSwitchRef prog env d decLabel root foc rest arms ((CTBranch (HLit (LChar c)) sub)::more) dft = foc ++ ["ref.cast (ref i31)", "i31.get_u", "i32.const " ++ intToString (charCode (arrayGetUnsafe 0 (stringToChars c))), "i32.eq"] ++ ["if"] ++ indent (emitTreeRef prog env d decLabel root rest arms sub) ++ ["else"] ++ indent (emitLitSwitchRef prog env d decLabel root foc rest arms more dft) ++ ["end"]
-- W6: String-literal switch head — compare the focus $str against each literal via
-- `$mdk_str_compare` (returns the i31 1 on equal), reusing the `PLit (LString)` logic.
emitLitSwitchRef prog env d decLabel root foc rest arms ((CTBranch (HLit (LString s)) sub)::more) dft =
  let _ = setRef useStrSearchRef True
  let _ = setRef useStrLeafRef True
  let _ = setRef useStrRef True
  foc
    ++ ["ref.cast (ref $str)"]
    ++ emitLitRef (LString s)
    ++ [
      "call $mdk_str_compare",
      "ref.cast (ref i31)",
      "i31.get_u",
      "i32.const 1",
      "i32.eq",
    ]
    ++ ["if"]
    ++ indent (emitTreeRef prog env d decLabel root rest arms sub)
    ++ ["else"]
    ++ indent (emitLitSwitchRef prog env d decLabel root foc rest arms more dft)
    ++ ["end"]
emitLitSwitchRef _ _ _ _ _ _ _ _ _ _ =
  gapL "ref-mode: non-Int literal switch head (Char/String literals are W6)"

-- ── pattern binding (leaf re-match) ──────────────────────────────────────────
-- bind a pattern's PVars against the value the snippet `v` produces, emitting struct
-- field extractions.  Returns (instructions that stash bound vars into their locals,
-- extended env).  Mirrors the LLVM bindPattern but stashes into named locals.
bindPatRef : Prog -> List String -> Pat -> List String -> <Mut> (List String, List String)
bindPatRef prog env PWild v = ([], env)
bindPatRef prog env (PLit _) v = ([], env)
bindPatRef prog env (PVar x) v = (v ++ ["local.set $" ++ gname x], x::env)
bindPatRef prog env (PCon c args) v = bindConFields prog env c args v
-- W7: a cons cell — field 1 = head, field 2 = tail (struct $C_Cons).
bindPatRef prog env (PCons h t) v =
  let hSnip = v ++ ["ref.cast (ref $C_Cons)", "struct.get $C_Cons 1"]
  let tSnip = v ++ ["ref.cast (ref $C_Cons)", "struct.get $C_Cons 2"]
  let (hb, env2) = bindPatRef prog env h hSnip
  let (tb, env3) = bindPatRef prog env2 t tSnip
  (hb ++ tb, env3)
-- W7: a fixed-length list pattern — bind each element by descending the Cons spine.
bindPatRef prog env (PList ps) v = bindListPat prog env ps v
-- W7: a tuple pattern — field i+1 of the $C_Tup<n> struct.
bindPatRef prog env (PTuple ps) v =
  bindTupleFields prog env (tupleCtorName (listLen ps)) ps v 0
bindPatRef prog env (PAs x p) v =
  let setX = v ++ ["local.set $" ++ gname x]
  let (inner, env2) = bindPatRef prog (x::env) p v
  (setX ++ inner, env2)
bindPatRef prog env other v =
  gapL2
    ("ref-mode: unsupported pattern in match arm (variable / wildcard / constructor / literal): " ++ ptag other)

-- bind a fixed-length list pattern `[p0, p1, …]`: p0 = head of v, the rest match the
-- tail recursively (descending Cons cells; the final empty list / Nil is irrefutable
-- here — the decision tree already proved the length).
bindListPat : Prog -> List String -> List Pat -> List String -> <Mut> (List String, List String)
bindListPat _ env [] _ = ([], env)
bindListPat prog env (p::ps) v =
  let hSnip = v ++ ["ref.cast (ref $C_Cons)", "struct.get $C_Cons 1"]
  let tSnip = v ++ ["ref.cast (ref $C_Cons)", "struct.get $C_Cons 2"]
  let (hb, env2) = bindPatRef prog env p hSnip
  let (tb, env3) = bindListPat prog env2 ps tSnip
  (hb ++ tb, env3)

-- bind a tuple pattern's fields: field i+1 of $C_Tup<n> (after the i32 tag).
bindTupleFields : Prog -> List String -> String -> List Pat -> List String -> Int -> <Mut> (List String, List String)
bindTupleFields _ env _ [] _ _ = ([], env)
bindTupleFields prog env tc (p::rest) v i =
  let fieldSnippet = v ++ [
    "ref.cast (ref $" ++ ctorStructName tc ++ ")",
    "struct.get $\{ctorStructName tc} \{intToString (i + 1)}",
  ]
  let (cur, env2) = bindPatRef prog env p fieldSnippet
  let (more, env3) = bindTupleFields prog env2 tc rest v (i + 1)
  (cur ++ more, env3)

-- bind a constructor pattern's fields: for each field i, extract via ref.cast +
-- struct.get (field i+1, after the i32 tag), then recurse into the sub-pattern.
bindConFields : Prog -> List String -> String -> List Pat -> List String -> <Mut> (List String, List String)
bindConFields prog env c args v = bindConFieldsGo prog env c args v 0

bindConFieldsGo : Prog -> List String -> String -> List Pat -> List String -> Int -> <Mut> (List String, List String)
bindConFieldsGo _ env _ [] _ _ = ([], env)
bindConFieldsGo prog env c (p::rest) v i =
  let fieldSnippet = v ++ [
    "ref.cast (ref $" ++ ctorStructName c ++ ")",
    "struct.get $\{ctorStructName c} \{intToString (i + 1)}",
  ]
  let (cur, env2) = bindPatRef prog env p fieldSnippet
  let (more, env3) = bindConFieldsGo prog env2 c rest v (i + 1)
  (cur ++ more, env3)

-- ── helpers shared by both modes ─────────────────────────────────────────────

-- top-level binding classification (W2 + W3, identical).
isValBind : CBind -> Bool
isValBind (CBind name [CClause [] _]) = name != "main"
isValBind _ = False

isFnBind : CBind -> Bool
isFnBind (CBind "main" _) = False
isFnBind b = not (isValBind b)

userFnBinds : List CBind -> List CBind
userFnBinds groups = filterList isFnBind groups

collectFnNames : List CBind -> List String
collectFnNames groups = map bindName (filterList isFnBind groups)

collectValNames : List CBind -> List String
collectValNames groups = map bindName (filterList isValBind groups)

bindName : CBind -> String
bindName (CBind n _) = n

findMain : List CBind -> <Mut> Option CExpr
findMain [] = None
findMain ((CBind "main" [CClause [] body])::_) = Some body
findMain ((CBind "main" _)::_) =
  gapOptE "`main` must be a nullary value (main = ...)"
findMain (_::rest) = findMain rest

-- the let-bound locals inside a binding's (single, nullary) clause body.
collectBindLocals : CBind -> List String
collectBindLocals (CBind _ [CClause _ body]) = collectExprLocals body
collectBindLocals _ = []

patName : Pat -> <Mut> String
patName (PVar x) = x
patName PWild = "_"
patName _ =
  gapS
    ("only PVar/PWild parameters (pattern params are inner-match material) [in " ++ curBindRef.value ++ "]")

-- ── local collection ─────────────────────────────────────────────────────────
-- Wasm requires every local declared in the function header.  Walk the body for
-- every `let`-bound / block-let-bound PVar AND (W3) every PATTERN-bound var in a
-- CDecision arm (the leaf re-match binds them into locals).
collectExprLocals : CExpr -> List String
collectExprLocals (CLet _ (PVar x) e1 e2) =
  x :: collectExprLocals e1 ++ collectExprLocals e2
collectExprLocals (CLet _ pat e1 e2) = patVars pat
  ++ (collectExprLocals e1 ++ collectExprLocals e2)
collectExprLocals (CBinPrim _ l r _) = collectExprLocals l
  ++ collectExprLocals r
collectExprLocals (CUnOp _ x) = collectExprLocals x
collectExprLocals (CIf c t f) = collectExprLocals c
  ++ collectExprLocals t
  ++ collectExprLocals f
collectExprLocals (CApp f a) = collectExprLocals f ++ collectExprLocals a
collectExprLocals (CBlock stmts) = flatMap collectStmtLocals stmts
collectExprLocals (CDecision scrut arms _) = collectExprLocals scrut
  ++ flatMap collectArmLocals arms
collectExprLocals (CMatch scrut arms) = collectExprLocals scrut
  ++ flatMap collectArmLocals arms
-- W9: a CLetGroup's member NAMES are bound as closure locals at the use site (the
-- enclosing fn must declare them); the bindings' own clause locals belong to the
-- LIFTED fns, not here, so only the group body's locals are collected here.
collectExprLocals (CLetGroup binds body) = map lgBindName binds
  ++ collectExprLocals body
collectExprLocals _ = []

collectStmtLocals : CStmt -> List String
collectStmtLocals (CSExpr ex) = collectExprLocals ex
collectStmtLocals (CSLet _ (PVar x) ex) = x :: collectExprLocals ex
collectStmtLocals (CSLet _ pat ex) = patVars pat ++ collectExprLocals ex
collectStmtLocals (CSLetElse pat ex els) = patVars pat
  ++ collectExprLocals ex
  ++ collectExprLocals els
collectStmtLocals (CSAssign _ ex) = collectExprLocals ex

-- ── W7 scratch-local declarations ────────────────────────────────────────────
-- The range/index/slice/record-update codegen uses depth-keyed scratch locals
-- ($__rli<d> etc.) with specific WAT types (i32 counters, (ref $arr) array temps,
-- (ref eq) accumulators).  A W7 node is emitted at the same depth `d` the surrounding
-- match nesting threads, so declaring the locals for every depth 0..maxDepth (the
-- bound `maxRefDepth` already computes for $__rf<d>) covers every site (unused locals
-- are valid WasmGC, so over-declaring is harmless).  Gated by the per-kind usage refs
-- so a program that uses none declares none.  Returns full `(local …)` lines.
w7LocalDecls : Int -> List String
w7LocalDecls maxDepth = flatMap w7LocalsAtDepth (rangeList 0 (maxI maxDepth 1))

w7LocalsAtDepth : Int -> List String
w7LocalsAtDepth d =
  let sfx = intToString d
  let rl = if useListRef.value then ["(local $__rlacc" ++ sfx ++ " (ref eq))", "(local $__rli" ++ sfx ++ " i32)", "(local $__rllo" ++ sfx ++ " i32)"] else []
  let ra = if useArrayRef.value then ["(local $__raarr" ++ sfx ++ " (ref null $arr))", "(local $__rai" ++ sfx ++ " i32)", "(local $__ralo" ++ sfx ++ " i32)", "(local $__racnt" ++ sfx ++ " i32)", "(local $__ixarr" ++ sfx ++ " (ref null $arr))", "(local $__ixi" ++ sfx ++ " i32)", "(local $__slsrc" ++ sfx ++ " (ref null $arr))", "(local $__sldst" ++ sfx ++ " (ref null $arr))", "(local $__sllo" ++ sfx ++ " i32)", "(local $__sllen" ++ sfx ++ " i32)",
    -- W10 array-intrinsic-extern scratch (loop counter, size, result array, list cursor,
    -- closure/init value) for arrayMake/arrayMakeWith/arrayFromList/arraySetUnsafe.
    "(local $__aexi" ++ sfx ++ " i32)", "(local $__aexn" ++ sfx ++ " i32)", "(local $__aexarr" ++ sfx ++ " (ref null $arr))", "(local $__aexlst" ++ sfx ++ " (ref eq))", "(local $__aexf" ++ sfx ++ " (ref eq))", "(local $__aexv" ++ sfx ++ " (ref eq))",
    -- stage-B: i64 bit accumulator for floatToBytes64/bytesToFloat64 reinterpret.
    "(local $__aexbits" ++ sfx ++ " i64)"] else []
  let ru = if isNonEmptyList recFieldsRef.value then ["(local $__rub" ++ sfx ++ " (ref eq))"] else []
  -- B5: the i64 divisor-guard scratch for a concrete-Int `/`/`%` at this depth.
  let dv = if useDivGuardRef.value then ["(local $__divr" ++ sfx ++ " i64)"] else []
  rl ++ ra ++ ru ++ dv

-- an arm contributes its pattern's bound vars + its body's locals + guard locals.
collectArmLocals : CArm -> List String
collectArmLocals (CArm pat guards body) = patVars pat
  ++ flatMap collectGuardLocals guards
  ++ collectExprLocals body

collectGuardLocals : CGuard -> List String
collectGuardLocals (CGBool g) = collectExprLocals g
collectGuardLocals (CGBind p e) = patVars p ++ collectExprLocals e

-- the variables a pattern binds (for local declaration).
patVars : Pat -> List String
patVars (PVar x) = [x]
patVars PWild = []
patVars (PLit _) = []
patVars (PCon _ args) = flatMap patVars args
patVars (PTuple ps) = flatMap patVars ps
patVars (PCons h t) = patVars h ++ patVars t
patVars (PList ps) = flatMap patVars ps
patVars (PAs x p) = x :: patVars p
patVars _ = []

-- ── operator tables (both modes) ─────────────────────────────────────────────

wasmBinOp : String -> <Mut> String
wasmBinOp "+" = "i32.add"
wasmBinOp "-" = "i32.sub"
wasmBinOp "*" = "i32.mul"
wasmBinOp "/" = "i32.div_s"
wasmBinOp "%" = "i32.rem_s"
wasmBinOp "==" = "i32.eq"
wasmBinOp "!=" = "i32.ne"
wasmBinOp "<" = "i32.lt_s"
wasmBinOp ">" = "i32.gt_s"
wasmBinOp "<=" = "i32.le_s"
wasmBinOp ">=" = "i32.ge_s"
wasmBinOp op =
  gapS
    ("unsupported binary operator '" ++ op ++ "' (`::`/`++` are list/string ops — W6/W7)")

-- layer-17 §2.1: the i64 peer of wasmBinOp for ref-mode Int arithmetic over the
-- box/unbox seam.  Division/modulo are i64 signed (i64.div_s/i64.rem_s) — matching
-- native's truncated-toward-zero div and sign-of-dividend rem (medaka_rt.c).
wasmBinOp64 : String -> <Mut> String
wasmBinOp64 "+" = "i64.add"
wasmBinOp64 "-" = "i64.sub"
wasmBinOp64 "*" = "i64.mul"
wasmBinOp64 "/" = "i64.div_s"
wasmBinOp64 "%" = "i64.rem_s"
wasmBinOp64 "==" = "i64.eq"
wasmBinOp64 "!=" = "i64.ne"
wasmBinOp64 "<" = "i64.lt_s"
wasmBinOp64 ">" = "i64.gt_s"
wasmBinOp64 "<=" = "i64.le_s"
wasmBinOp64 ">=" = "i64.ge_s"
wasmBinOp64 op = gapS ("unsupported i64 binary operator '" ++ op ++ "'")

binOpTy : String -> WTy
binOpTy op =
  if op == "++" then
    WStr
  else if contains op ["==", "!=", "<", ">", "<=", ">="] then
    WBool
  else
    WInt

-- ── ctor / type info (ref mode) ──────────────────────────────────────────────

isCtor : Prog -> String -> Bool
isCtor (Prog ctorArs _ _ _ _ _ _ _ _) name = isSome (lookupAssoc name ctorArs)
  || isReservedCtor name
  || isSyntheticCtor name

isReservedCtor : String -> Bool
isReservedCtor name = isSome (reservedCtorOrdinal name)

-- ── W7 synthetic ctors (List Cons/Nil, tuple Tup<n>) ─────────────────────────
-- These are not in the user ctor table; they share the W3 ctor machinery so the
-- match tower / construction / field-extract code stays uniform.  A tuple ctor is
-- "Tup<n>" (its own single-ctor synthetic type "$Tuple<n>").  List = Cons/Nil under
-- type "List".
isSyntheticCtor : String -> Bool
isSyntheticCtor name = name == "Cons"
  || name == "Nil"
  || name == "True"
  || name == "False"
  || isTupleCtorName name

tupleCtorName : Int -> String
tupleCtorName n = "Tup" ++ intToString n

isTupleCtorName : String -> Bool
isTupleCtorName name = startsWithStr name "Tup"
  && allDigitsFrom (stringToChars name) 3

-- the synthetic type a synthetic ctor belongs to.
syntheticCtorType : String -> String
syntheticCtorType "Cons" = "List"
syntheticCtorType "Nil" = "List"
-- W9: with the REAL prelude, `Bool` is a builtin (not a `data` decl), so its ctors
-- True/False are not in the ctor table.  Treat them as synthetic Bool ctors:
-- type "Bool", ordinals False=0/True=1, nullary, rep = i31 (same as emitVarRef's
-- True/False fast path and emitLitRef LBool), so discrimReadOf's i31 branch reads
-- the ordinal directly.
syntheticCtorType "True" = "Bool"
syntheticCtorType "False" = "Bool"
syntheticCtorType name = "$Tuple" ++ intToString (trailingIntOf name)

syntheticCtorOrdinal : String -> Int
syntheticCtorOrdinal "Cons" = 0
syntheticCtorOrdinal "Nil" = 1
syntheticCtorOrdinal "False" = 0
syntheticCtorOrdinal "True" = 1
syntheticCtorOrdinal _ = 0

syntheticCtorArity : String -> Int
syntheticCtorArity "Cons" = 2
syntheticCtorArity "Nil" = 0
syntheticCtorArity "True" = 0
syntheticCtorArity "False" = 0
syntheticCtorArity name = trailingIntOf name

ctorArity : Prog -> String -> Int
ctorArity (Prog ctorArs _ _ _ _ _ _ _ _) name = match lookupAssoc name ctorArs
  Some a => a
  None =>
    if isSyntheticCtor name then
      syntheticCtorArity name
    else
      reservedCtorArity name

-- a ctor's owning type name (user types via the ctor→type map; reserved ctors map
-- to their fixed type names; W7 synthetic ctors to their synthetic types).
ctorTypeName : Prog -> String -> <Mut> String
ctorTypeName (Prog _ ctorTypes _ _ _ _ _ _ _) name = match lookupAssoc name ctorTypes
  Some ty => ty
  None =>
    if isSyntheticCtor name then
      syntheticCtorType name
    else
      reservedTypeOf name

-- the per-type dense ordinal of a ctor (0-based index in its type's declaration
-- order).  Reserved + synthetic ctors have fixed ordinals.
ctorOrdinal : Prog -> String -> <Mut> Int
ctorOrdinal prog name = match reservedCtorOrdinal name
  Some o => o
  None =>
    if isSyntheticCtor name then
      syntheticCtorOrdinal name
    else
      orZeroIdx (indexOfL name (ctorsOfType prog (ctorTypeName prog name)))

-- the declaration-ordered ctor list of a user type (the ctor→type map lists each
-- type's ctors consecutively in declaration order — filter to this type).
ctorsOfType : Prog -> String -> List String
ctorsOfType prog ty =
  if isReservedType ty then reservedCtorsOfType ty
  else if ty == "List" then ["Cons", "Nil"]
  -- Bool's ctors are SYNTHETIC (registered via syntheticCtor* helpers, not in the
  -- program's ctorTypes table), so ctorsOfTypeUser would return [] → a 0-slot
  -- br_table tower → both arms dropped → fall-through `unreachable`.  A genuine
  -- `match <Bool> { True => …; False => … }` (a CDecision switch, not a lowered CIf)
  -- hits this.  Index-aligned to syntheticCtorOrdinal: False=0, True=1.
  else if ty == "Bool" then ["False", "True"]
  else if isTupleType ty then [tupleCtorName (tupleTypeArity ty)]
  else ctorsOfTypeUser prog ty

-- a synthetic tuple type name "$Tuple<n>" and its arity.
isTupleType : String -> Bool
isTupleType ty = startsWithStr ty "$Tuple"

tupleTypeArity : String -> Int
tupleTypeArity ty = trailingIntOf ty

ctorsOfTypeUser : Prog -> String -> List String
ctorsOfTypeUser (Prog _ ctorTypes _ _ _ _ _ _ _) ty =
  map fstPair (filterList (e => eqStr (sndPair e) ty) ctorTypes)

-- the number of ctors a type has (the br_table's slot count).
typeCtorCount : Prog -> String -> Int
typeCtorCount prog ty = listLen (ctorsOfType prog ty)

-- the type a switch's branches discriminate (all branches share one type — take the
-- first ADT head's ctor's owning type).
switchTypeName : Prog -> List CTBranch -> <Mut> String
switchTypeName prog [] = gapS "ref-mode: empty constructor switch"
switchTypeName prog ((CTBranch h _)::rest) = match conHeadInfo h
  Some (c, _) => ctorTypeName prog c
  None => switchTypeName prog rest

-- the branch whose head's ordinal is k (for the br_table slot).
branchForOrdinal : Prog -> List CTBranch -> String -> Int -> <Mut> Option CTBranch
branchForOrdinal _ [] _ _ = None
branchForOrdinal prog ((CTBranch h sub)::rest) ty k = match conHeadInfo h
  Some (c, _) =>
    if ctorOrdinal prog c == k then
      Some (CTBranch h sub)
    else
      branchForOrdinal prog rest ty k
  None => branchForOrdinal prog rest ty k

-- the name + arity a constructor-LIKE head tests against.  W7 maps the built-in
-- heads to synthetic ctor names so the SAME ctor machinery (ordinal / struct /
-- field-extract) drives them: HCons → ("Cons", 2) / HNil → ("Nil", 0) (type "List",
-- exactly the LLVM names), HTuple n → the per-arity synthetic tuple ctor "Tup<n>".
conHeadInfo : CHead -> Option (String, Int)
conHeadInfo (HCon c a) = Some (c, a)
conHeadInfo HCons = Some ("Cons", 2)
conHeadInfo HNil = Some ("Nil", 0)
conHeadInfo (HTuple n) = Some (tupleCtorName n, n)
conHeadInfo _ = None

conHeadInfoUnsafe : CHead -> <Mut> (String, Int)
conHeadInfoUnsafe h = match conHeadInfo h
  Some p => p
  None => gapSInt "ref-mode: non-constructor head in a constructor switch (HCons/HNil/HTuple are W7)"

-- ── reserved ADTs (Option / Result / Ordering) ───────────────────────────────
-- The lowering names Ordering's ctors `Lt`/`Eq`/`Gt` (capitalized — see
-- llvm_emit.reservedTag).
isReservedType : String -> Bool
isReservedType ty = contains ty ["Option", "Result", "Ordering"]

reservedCtorsOfType : String -> List String
reservedCtorsOfType "Option" = ["Some", "None"]
reservedCtorsOfType "Result" = ["Ok", "Err"]
reservedCtorsOfType "Ordering" = ["Lt", "Eq", "Gt"]
reservedCtorsOfType _ = []

reservedTypeOf : String -> <Mut> String
reservedTypeOf name =
  if contains name ["Some", "None"] then
    "Option"
  else if contains name ["Ok", "Err"] then
    "Result"
  else if contains name ["Lt", "Eq", "Gt"] then
    "Ordering"
  else
    gapS ("ref-mode: unknown constructor '" ++ name ++ "' (not in the ctor table, not reserved)")

reservedCtorOrdinal : String -> Option Int
reservedCtorOrdinal "Some" = Some 0
reservedCtorOrdinal "None" = Some 1
reservedCtorOrdinal "Ok" = Some 0
reservedCtorOrdinal "Err" = Some 1
reservedCtorOrdinal "Lt" = Some 0
reservedCtorOrdinal "Eq" = Some 1
reservedCtorOrdinal "Gt" = Some 2
reservedCtorOrdinal _ = None

reservedCtorArity : String -> Int
reservedCtorArity "Some" = 1
reservedCtorArity "Ok" = 1
reservedCtorArity "Err" = 1
reservedCtorArity _ = 0

-- ── WAT type-name mangling ───────────────────────────────────────────────────
-- a per-type root struct type name and a per-ctor struct type name.  Prefixed to
-- avoid colliding with the fixed $float / $boxint scaffolding.
typeRootName : String -> String
typeRootName ty = "T_" ++ ty

ctorStructName : String -> String
ctorStructName ctor = "C_" ++ ctor

-- ── distinct type names (declaration order) ──────────────────────────────────
-- the ctor→type map lists each type's ctors consecutively, so dedup-preserving-
-- order over the type column gives declaration order.
distinctTypeNames : List (String, String) -> List String
distinctTypeNames ctorTypes = dedupKeep (map sndPair ctorTypes)

-- ── scratch locals for match scrutinee/focus stashes ─────────────────────────
-- a CDecision/CTSwitch at nesting depth d stashes its value into `$__rf<d>`.  The
-- function header declares `$__rf0..$__rf<maxDepth-1>`.
scratchLocal : Int -> String
scratchLocal d = "__rf" ++ intToString d

scratchLocals : Int -> List String
scratchLocals n = map scratchLocal (rangeList 0 n)

-- the number of scratch locals an expression needs = (highest scratch index used
-- anywhere) + 1.  This MIRRORS the actual depth threading: emitDecisionRef at depth
-- d uses local d and recurses its tree at d+1; emitConSwitchRef at depth d uses
-- local d and recurses subtrees at d+1.  `maxIndexAt e d` = the highest local index
-- used when `e` is emitted at depth d (or d-1 if `e` uses no stash, meaning no
-- scratch beyond what the caller already accounts for).
maxRefDepth : CExpr -> Int
maxRefDepth e = maxIndexAt e 0 + 1

-- the highest scratch-local index used emitting `e` at depth `d`.  Returns d-1 as a
-- "nothing used here" sentinel (so `+1` gives d, i.e. no extra slot).
maxIndexAt : CExpr -> Int -> Int
maxIndexAt (CDecision scrut arms tree) d =
  let scrutI = maxIndexAt scrut d
  let treeI = maxIndexTree tree (d + 1)
  let armDepth = d + 1 + treeSwitchNesting tree
  let armsI = foldMaxI (map (a => maxIndexAt (armBody a) armDepth) arms)
  maxI d (maxI scrutI (maxI treeI armsI))
maxIndexAt (CMatch scrut arms) d =
  let scrutI = maxIndexAt scrut d
  let armsI = foldMaxI (map (a => maxIndexAt (armBody a) (d + 1)) arms)
  maxI d (maxI scrutI armsI)
maxIndexAt (CIf c t f) d =
  maxI (maxIndexAt c d) (maxI (maxIndexAt t d) (maxIndexAt f d))
maxIndexAt (CLet _ pat a b) d =
  maxI (letStashIndex pat a d) (maxI (maxIndexAt a d) (maxIndexAt b d))
maxIndexAt (CBinPrim _ a b _) d = maxI (maxIndexAt a d) (maxIndexAt b d)
maxIndexAt (CUnOp _ a) d = maxIndexAt a d
maxIndexAt (CApp f a) d = maxI (maxIndexAt f d) (maxIndexAt a d)
maxIndexAt (CBlock stmts) d = foldMaxI (map (s => maxIndexAtStmt s d) stmts)
-- a let-group's BODY is emitted at this same depth `d` at the use site (its lifted
-- members carry their own scratch in their own functions); descend into the body so
-- the enclosing function declares enough `$__rf` slots (a match in the body uses them).
maxIndexAt (CLetGroup _ body) d = maxIndexAt body d
-- compound value nodes emit their sub-expressions at depth `d` (no own stash slot);
-- descend so a scratch-using element (e.g. CIndex/CSlice/a nested match) is counted.
maxIndexAt (CTuple es) d = foldMaxI (map (x => maxIndexAt x d) es)
maxIndexAt (CList es) d = foldMaxI (map (x => maxIndexAt x d) es)
maxIndexAt (CArray es) d = foldMaxI (map (x => maxIndexAt x d) es)
maxIndexAt (CRecord _ fields) d =
  foldMaxI (map (x => maxIndexAt (cFieldExpr x) d) fields)
-- CRecordUpdate/CVariantUpdate stash the base in $__rub<d> at their own emit site.
maxIndexAt (CRecordUpdate b fields) d = maxI
  d
  (maxI
    (maxIndexAt b d)
    (foldMaxI (map (x => maxIndexAt (cFieldExpr x) d) fields)))
maxIndexAt (CVariantUpdate _ b fields) d = maxI
  d
  (maxI
    (maxIndexAt b d)
    (foldMaxI (map (x => maxIndexAt (cFieldExpr x) d) fields)))
maxIndexAt (CFieldAccess e1 _ _) d = maxIndexAt e1 d
-- These four nodes each allocate depth-`d` scratch locals ($__rl*/$__ra*/$__ix*/
-- $__sl* at suffix `d`) at their OWN emit site, so they must contribute `d` even
-- when their subexpressions are leaves (which report d-1).  Omitting the `maxI d`
-- undercounts by one — masked at depths 0/1 by the `maxI maxDepth 1` floor in
-- w7LocalDecls, but at depth >= 2 (e.g. an `arr[i]` nested inside two matches, as in
-- the sqlite lib) it left `$__ixarr2` undeclared → wasm-tools "unknown local".
maxIndexAt (CRangeList lo hi _) d =
  maxI d (maxI (maxIndexAt lo d) (maxIndexAt hi d))
maxIndexAt (CRangeArray lo hi _) d =
  maxI d (maxI (maxIndexAt lo d) (maxIndexAt hi d))
maxIndexAt (CIndex a i) d = maxI d (maxI (maxIndexAt a d) (maxIndexAt i d))
maxIndexAt (CSlice a lo hi _) d =
  maxI d (maxI (maxIndexAt a d) (maxI (maxIndexAt lo d) (maxIndexAt hi d)))
maxIndexAt _ d = d - 1

-- the deepest switch nesting in a tree (each CTSwitch increments the emit depth by
-- 1 for its subtrees; an arm body at a leaf is emitted at decision-depth + this).
treeSwitchNesting : CTree -> Int
treeSwitchNesting CTFail = 0
treeSwitchNesting (CTLeaf _) = 0
treeSwitchNesting (CTGuard _ fail) = treeSwitchNesting fail
treeSwitchNesting (CTDrop sub) = treeSwitchNesting sub
treeSwitchNesting (CTSwitch branches dft) =
  let bd = foldMaxI (map (b => treeSwitchNesting (branchSub b)) branches)
  maxI (1 + bd) (treeSwitchNesting dft)

maxIndexAtStmt : CStmt -> Int -> Int
maxIndexAtStmt (CSExpr e) d = maxIndexAt e d
maxIndexAtStmt (CSLet _ pat e) d = maxI (letStashIndex pat e d) (maxIndexAt e d)
maxIndexAtStmt (CSLetElse pat e els) d =
  maxI (letStashIndex pat e d) (maxI (maxIndexAt e d) (maxIndexAt els d))
maxIndexAtStmt (CSAssign _ e) d = maxIndexAt e d

-- the scratch-local index a let/block-let with `pat` against RHS `e` (emitted at
-- depth d) needs to stash its RHS, or d-1 (no stash) for a PVar/PWild bind which
-- needs no scratch.  An irrefutable destructure stashes the RHS one slot ABOVE
-- whatever the RHS itself uses, so the stash never collides with the RHS's own
-- scratch and is live only while the sub-patterns extract their fields.
letStashIndex : Pat -> CExpr -> Int -> Int
letStashIndex (PVar _) _ d = d - 1
letStashIndex PWild _ d = d - 1
letStashIndex _ e d = maxIndexAt e d + 1

-- the highest scratch index used emitting a decision tree at depth d (a CTSwitch
-- stashes the focus at index d and recurses subtrees at d+1; leaves/guards re-emit
-- arm bodies via emitTreeRef at the same depth, accounted by the arm walk above).
maxIndexTree : CTree -> Int -> Int
maxIndexTree CTFail d = d - 1
maxIndexTree (CTLeaf _) d = d - 1
maxIndexTree (CTGuard _ fail) d = maxIndexTree fail d
maxIndexTree (CTDrop sub) d = maxIndexTree sub d
maxIndexTree (CTSwitch branches dft) d =
  let bd = foldMaxI (map (b => maxIndexTree (branchSub b) (d + 1)) branches)
  maxI d (maxI bd (maxIndexTree dft d))

branchSub : CTBranch -> CTree
branchSub (CTBranch _ sub) = sub

armBody : CArm -> CExpr
armBody (CArm _ _ body) = body

foldMaxI : List Int -> Int
foldMaxI [] = 0
foldMaxI (x::xs) = maxI x (foldMaxI xs)

-- ── small generic helpers ────────────────────────────────────────────────────

-- W7 string helpers (no stdlib): trailing-integer parse over the char array.
-- Used only for the synthetic tuple ctor/type names ("Tup<n>" / "$Tuple<n>")
-- whose arity is recovered from the trailing decimal.
--
-- the integer formed by the trailing decimal digits of `s` (e.g. "Tup3" → 3,
-- "$Tuple12" → 12).  Walks from the first digit to the end.
trailingIntOf : String -> Int
trailingIntOf s =
  let cs = stringToChars s
  trailingIntGo cs (firstDigitIdx cs 0) 0

firstDigitIdx : Array Char -> Int -> Int
firstDigitIdx cs i =
  if i >= arrayLength cs then
    i
  else if isDigitCh (charCode (arrayGetUnsafe i cs)) then
    i
  else
    firstDigitIdx cs (i + 1)

trailingIntGo : Array Char -> Int -> Int -> Int
trailingIntGo cs i acc =
  if i >= arrayLength cs then
    acc
  else
    trailingIntGo cs (i + 1) (acc * 10 + (charCode (arrayGetUnsafe i cs) - 48))

isDigitCh : Int -> Bool
isDigitCh c = c >= 48 && c <= 57

-- True if every char from index `i` to the end is a decimal digit (and there is at
-- least one).  Used to confirm a "Tup<n>" synthetic tuple ctor name.
allDigitsFrom : Array Char -> Int -> Bool
allDigitsFrom cs i = if i >= arrayLength cs then False else allDigitsGo cs i

allDigitsGo : Array Char -> Int -> Bool
allDigitsGo cs i =
  if i >= arrayLength cs then
    True
  else if isDigitCh (charCode (arrayGetUnsafe i cs)) then
    allDigitsGo cs (i + 1)
  else
    False

flattenApp : CExpr -> List CExpr -> (CExpr, List CExpr)
flattenApp (CApp f a) acc = flattenApp f (a::acc)
flattenApp hd acc = (hd, acc)

indent : List String -> List String
indent lines = map ("    " ++ _) lines

gname : String -> String
-- A user identifier that is LITERALLY one of the codety ABI param names (`$self` /
-- `$args`, emitted as `(param ...)` on every lifted lambda / wrapper / extern-eta)
-- would collide with that param when it also becomes a `(local ...)` in the same body
-- → wasm-tools "duplicate local identifier".  Escape just those two reserved words so
-- the user var renders distinctly; consistent here means decl + local.get + local.set
-- (all routed through gname) stay in agreement.  Top-level fn/global names also flow
-- through gname, but a user binding named `self`/`args` is equally safe to rename there.
gname "self" = "u__self"
gname "args" = "u__args"
gname n =
  -- The `__wparg<digits>` family is reserved for synthetic positional fn params
  -- (synthParams).  A source var spelled identically would collide with a sibling
  -- positional param's wasm local — escape it so user vars stay distinct.
  if startsWithStr n "__wparg" && allDigitsFrom (stringToChars n) 7 then "u__" ++ n
  else n

notIn : List String -> String -> Bool
notIn xs x = not (contains x xs)

dedupKeep : List String -> List String
dedupKeep xs = reverseL (dedupGo xs [])

dedupGo : List String -> List String -> List String
dedupGo [] acc = acc
dedupGo (x::xs) acc =
  if contains x acc then
    dedupGo xs acc
  else
    dedupGo xs (x::acc)

fst : (a, b) -> a
fst (x, _) = x

fstPair : (String, String) -> String
fstPair (x, _) = x

sndPair : (String, String) -> String
sndPair (_, y) = y

eqStr : String -> String -> Bool
eqStr a b = a == b

isSome : Option a -> Bool
isSome (Some _) = True
isSome None = False

-- inclusive-exclusive integer range [lo, hi) as a list.
rangeList : Int -> Int -> List Int
rangeList lo hi = if lo >= hi then [] else lo :: rangeList (lo + 1) hi

tailList : List a -> List a
tailList [] = []
tailList (_::xs) = xs

nthArm : List CArm -> Int -> Option CArm
nthArm [] _ = None
nthArm (a::rest) i = if i == 0 then Some a else nthArm rest (i - 1)

-- the index of `x` in a String list, or -1.
indexOfL : String -> List String -> Int
indexOfL x xs = indexOfGo x xs 0

indexOfGo : String -> List String -> Int -> Int
indexOfGo _ [] _ = -1
indexOfGo x (y::ys) i = if x == y then i else indexOfGo x ys (i + 1)

orZeroIdx : Int -> Int
orZeroIdx i = if i < 0 then 0 else i

-- a readable tag for the unsupported-node gap message.
ctag : CExpr -> String
ctag (CApp _ _) = "CApp (application)"
ctag (CLam _ _) = "CLam (lambda — W4)"
ctag (CMatch _ _) = "CMatch (ordered-arm match — needs the decision-tree form)"
ctag (CDecision _ _ _) = "CDecision (match)"
ctag (CTuple _) = "CTuple (W7)"
ctag (CList _) = "CList (W7)"
ctag (CArray _) = "CArray (W7)"
ctag (CRecord _ _) = "CRecord (W7)"
ctag (CFieldAccess _ _ _) = "CFieldAccess (W7)"
ctag (CRecordUpdate _ _) = "CRecordUpdate (W7)"
ctag (CVariantUpdate _ _ _) = "CVariantUpdate (W7)"
ctag (CRangeList _ _ _) = "CRangeList (W7)"
ctag (CRangeArray _ _ _) = "CRangeArray (W7)"
ctag (CIndex _ _) = "CIndex (W7)"
ctag (CSlice _ _ _ _) = "CSlice (W7)"
ctag (CMethod _ _ _ _) = "CMethod (dispatch — W5)"
ctag (CDict _ _) = "CDict (dispatch — W5)"
ctag (CLetGroup _ _) = "CLetGroup (where/let-group — W4)"
ctag _ = "?"

-- a readable tag for an unsupported pattern.
ptag : Pat -> String
ptag (PVar _) = "PVar"
ptag PWild = "PWild"
ptag (PLit (LInt _)) = "PLit-LInt"
ptag (PLit (LFloat _)) = "PLit-LFloat"
ptag (PLit (LString _)) = "PLit-LString"
ptag (PLit (LChar _)) = "PLit-LChar"
ptag (PLit (LBool _)) = "PLit-LBool"
ptag (PLit LUnit) = "PLit-LUnit"
ptag (PCon _ _) = "PCon"
ptag (PTuple _) = "PTuple (W7)"
ptag (PCons _ _) = "PCons (list — W7)"
ptag (PList _) = "PList (list — W7)"
ptag (PAs _ _) = "PAs"
ptag _ = "?"

-- the W3 scope wall: any out-of-slice node lands here (an explicit hard stop).
gap : String -> a
gap msg = panic ("wasm_emit gap — " ++ msg)
