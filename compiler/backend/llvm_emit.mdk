    (r, LTStr)
  _ => panic "llvm spike: buildFingerprint takes one (Unit) argument"
emitFileExtern _ _ name _ = gapE ("unsupported file extern " ++ name)

-- Net externs (NET-DESIGN.md).  A SEPARATE family from isFileExtern — deliberately,
-- so the wasm backend can reject the whole net set in one guard.  All return a
-- Result (LTCon) traffic'ing raw tagged-Int fds; blocking BSD-socket shims in
-- runtime/medaka_rt.c.
isNetExtern : String -> Bool
-- Intentional cross-file duplicate of the same helper in wasm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
isNetExtern name = contains
  name
  [
    "netResolve",
    "netTcpConnect",
    "netTcpListen",
    "netListenPort",
    "netTcpAccept",
    "netSend",
    "netRecv",
    "netShutdown",
    "netClose",
    "netSetTimeout",
  ]

emitNetExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> (String, LTy)
emitNetExtern e env "netResolve" args = match emitArgs e env args
  [h] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_resolve(i64 \{h})"
    (r, LTCon)
  _ => panic "llvm spike: netResolve takes one argument"
emitNetExtern e env "netTcpConnect" args = match emitArgs e env args
  [h, p] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_tcp_connect(i64 \{h}, i64 \{p})"
    (r, LTCon)
  _ => panic "llvm spike: netTcpConnect takes two arguments"
emitNetExtern e env "netTcpListen" args = match emitArgs e env args
  [a, p] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_tcp_listen(i64 \{a}, i64 \{p})"
    (r, LTCon)
  _ => panic "llvm spike: netTcpListen takes two arguments"
emitNetExtern e env "netListenPort" args = match emitArgs e env args
  [fd] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_listen_port(i64 \{fd})"
    (r, LTCon)
  _ => panic "llvm spike: netListenPort takes one argument"
emitNetExtern e env "netTcpAccept" args = match emitArgs e env args
  [fd] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_tcp_accept(i64 \{fd})"
    (r, LTCon)
  _ => panic "llvm spike: netTcpAccept takes one argument"
emitNetExtern e env "netSend" args = match emitArgs e env args
  [fd, bs] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_send(i64 \{fd}, i64 \{bs})"
    (r, LTCon)
  _ => panic "llvm spike: netSend takes two arguments"
emitNetExtern e env "netRecv" args = match emitArgs e env args
  [fd, n] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_recv(i64 \{fd}, i64 \{n})"
    (r, LTCon)
  _ => panic "llvm spike: netRecv takes two arguments"
emitNetExtern e env "netShutdown" args = match emitArgs e env args
  [fd, how] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_shutdown(i64 \{fd}, i64 \{how})"
    (r, LTCon)
  _ => panic "llvm spike: netShutdown takes two arguments"
emitNetExtern e env "netClose" args = match emitArgs e env args
  [fd] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_close(i64 \{fd})"
    (r, LTCon)
  _ => panic "llvm spike: netClose takes one argument"
emitNetExtern e env "netSetTimeout" args = match emitArgs e env args
  [fd, ms] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_net_set_timeout(i64 \{fd}, i64 \{ms})"
    (r, LTCon)
  _ => panic "llvm spike: netSetTimeout takes two arguments"
emitNetExtern _ _ name _ = gapE ("unsupported net extern " ++ name)

-- Tier D: RNG (deterministic SplitMix64).  The C runtime holds the state; the
-- algorithm matches lib/eval.ml splitmix64_next, seeded identically, so output is
-- byte-identical per seed.  randomInt/Bool/Char return RAW words tagged here;
-- randomFloat returns a boxed Float word; setSeed is Unit.
isRngExtern : String -> Bool
isRngExtern name = contains
  name
  ["randomInt", "randomBool", "randomFloat", "randomChar", "setSeed"]

emitRngExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> (String, LTy)
emitRngExtern e env "randomInt" args = match emitArgs e env args
  [lo, hi] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_random_int(i64 \{lo}, i64 \{hi})"
    (tagInt e r, LTInt)
  _ => panic "llvm spike: randomInt takes two arguments (Tier D)"
emitRngExtern e env "randomBool" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_random_bool(i64 \{u})"
    (tagInt e r, LTBool)
  _ => panic "llvm spike: randomBool takes one (Unit) argument (Tier D)"
emitRngExtern e env "randomFloat" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_random_float(i64 \{u})"
    (r, LTFloat)
  _ => panic "llvm spike: randomFloat takes one (Unit) argument (Tier D)"
emitRngExtern e env "randomChar" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_random_char(i64 \{u})"
    (tagInt e r, LTChar)
  _ => panic "llvm spike: randomChar takes one (Unit) argument (Tier D)"
emitRngExtern e env "setSeed" args = match emitArgs e env args
  [n] =>
    let _ = emit e ("  call void @mdk_set_seed(i64 " ++ n ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: setSeed takes one argument (Tier D)"
emitRngExtern _ _ name _ = gapE ("unsupported rng extern " ++ name)

-- wallTimeSec / allocBytes: both take Unit and return a boxed Float (same ABI
-- as randomFloat).  C: mdk_wall_time_sec / mdk_alloc_bytes in medaka_rt.c.
isPerfExtern : String -> Bool
isPerfExtern name =
  contains name ["wallTimeSec", "monotonicSec", "sleepMs", "allocBytes"]

emitPerfExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> (String, LTy)
emitPerfExtern e env "wallTimeSec" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_wall_time_sec(i64 \{u})"
    (r, LTFloat)
  _ => panic "llvm spike: wallTimeSec takes one (Unit) argument"
emitPerfExtern e env "monotonicSec" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_monotonic_sec(i64 \{u})"
    (r, LTFloat)
  _ => panic "llvm spike: monotonicSec takes one (Unit) argument"
emitPerfExtern e env "sleepMs" args = match emitArgs e env args
  [n] =>
    let _ = emit e ("  call void @mdk_sleep_ms(i64 " ++ n ++ ")")
    ("1", LTUnit)
  _ => panic "llvm spike: sleepMs takes one (Int) argument"
emitPerfExtern e env "allocBytes" args = match emitArgs e env args
  [u] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_alloc_bytes(i64 \{u})"
    (r, LTFloat)
  _ => panic "llvm spike: allocBytes takes one (Unit) argument"
emitPerfExtern _ _ name _ = gapE ("unsupported perf extern " ++ name)

-- Hashable per-type hashers (specified, byte-identical to lib/eval.ml hash_*).
-- Each unpacks the native arg the C helper wants (untagged int / codepoint /
-- unboxed double / String cell pointer) and tags the RAW Int result.  hashBool
-- untags the 0/1 bool word.  See runtime/medaka_rt.c mdk_hash_*.
-- Bitwise / shift externs (PURE).  Args are tagged ints — untag each operand,
-- call the C helper on the raw values, retag the result.  shiftRight is LOGICAL
-- (C >> on the untagged non-negative value == OCaml lsr for non-negative);
-- bitNot's retag (shl/or) drops the top bit so it matches OCaml lnot on the
-- 63-bit rep.  See runtime/medaka_rt.c mdk_bit_*/mdk_shift_*.
isBitExtern : String -> Bool
isBitExtern name = contains
  name
  ["bitAnd", "bitOr", "bitXor", "shiftLeft", "shiftRight", "bitNot"]

emitBitBin : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> (String, LTy)
emitBitBin e env sym args = match emitArgs e env args
  [a, b] =>
    let x = untagInt e a
    let y = untagInt e b
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @\{sym}(i64 \{x}, i64 \{y})"
    (tagInt e r, LTInt)
  _ => panic ("llvm spike: " ++ sym ++ " takes two arguments")

emitBitExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> (String, LTy)
emitBitExtern e env "bitAnd" args = emitBitBin e env "mdk_bit_and" args
emitBitExtern e env "bitOr" args = emitBitBin e env "mdk_bit_or" args
emitBitExtern e env "bitXor" args = emitBitBin e env "mdk_bit_xor" args
emitBitExtern e env "shiftLeft" args = emitBitBin e env "mdk_shift_left" args
emitBitExtern e env "shiftRight" args = emitBitBin e env "mdk_shift_right" args
emitBitExtern e env "bitNot" args = match emitArgs e env args
  [a] =>
    let x = untagInt e a
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_bit_not(i64 \{x})"
    (tagInt e r, LTInt)
  _ => panic "llvm spike: bitNot takes one argument"
emitBitExtern _ _ name _ = gapE ("unsupported bit extern " ++ name)

isHashExtern : String -> Bool
isHashExtern name =
  contains name ["hashInt", "hashChar", "hashBool", "hashFloat", "hashString"]

emitHashExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> (String, LTy)
emitHashExtern e env "hashInt" args = match emitArgs e env args
  [a] =>
    let i = untagInt e a
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_hash_int(i64 \{i})"
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashInt takes one argument"
emitHashExtern e env "hashChar" args = match emitArgs e env args
  [a] =>
    let cp = untagInt e a
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_hash_char(i64 \{cp})"
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashChar takes one argument"
emitHashExtern e env "hashBool" args = match emitArgs e env args
  [a] =>
    let b = untagInt e a
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_hash_bool(i64 \{b})"
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashBool takes one argument"
emitHashExtern e env "hashFloat" args = match emitArgs e env args
  [a] =>
    let d = unboxFloat e a
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_hash_float(double \{d})"
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashFloat takes one argument"
emitHashExtern e env "hashString" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_hash_string(i64 \{a})"
    (tagInt e r, LTInt)
  _ => panic "llvm spike: hashString takes one argument"
emitHashExtern _ _ name _ = gapE ("unsupported hash extern " ++ name)

-- Debug-literal externs (byte-exact quoted/escaped rendering; no oracle change).
-- The String/Char arg word passes straight to the C helper (mdk_debug_*_lit
-- reads the cell / untags the codepoint); result is a heap String (LTStr).
isDebugLitExtern : String -> Bool
isDebugLitExtern name = contains name ["debugStringLit", "debugCharLit"]

emitDebugLitExtern : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> (String, LTy)
emitDebugLitExtern e env "debugStringLit" args = match emitArgs e env args
  [a] =>
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_debug_string_lit(i64 \{a})"
    (r, LTStr)
  _ => panic "llvm spike: debugStringLit takes one argument"
emitDebugLitExtern e env "debugCharLit" args = match emitArgs e env args
  [a] =>
    let cp = untagInt e a
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_debug_char_lit(i64 \{cp})"
    (r, LTStr)
  _ => panic "llvm spike: debugCharLit takes one argument"
emitDebugLitExtern _ _ name _ = gapE ("unsupported debug-lit extern " ++ name)

-- ── extern dispatch: applied form ───────────────────────────────────────────
-- Is `name` a KNOWN extern of any family the emitter handles?  The OR of every
-- family predicate (plus the `arrayMakeWith` intrinsic, which has no `isXxx`
-- predicate — it is dispatched by exact name).  Drives both the saturated CApp
-- head path (emitExternApplied) and the value-position eta-wrap (emitVar →
-- emitExternEtaClosure); keeping the membership in ONE place means the two paths
-- can never disagree about what counts as an extern.
isAnyExtern : String -> Bool
isAnyExtern name = isStrExtern name
  || isNumExtern name
  || isIoExtern name
  || isAbortExtern name
  || isArrIntrinsic name
  || name == "arrayMakeWith"
  || isArrLeafExtern name
  || isCharExtern name
  || isStrCharExtern name
  || isUnicodeExtern name
  || isAdtExtern name
  || isEnvExtern name
  || isFileExtern name
  || isNetExtern name
  || isRngExtern name
  || isHashExtern name
  || isBitExtern name
  || isDebugLitExtern name
  || isPerfExtern name

-- SATURATED extern application: route a known extern + its (non-empty) argument
-- list to the right family emitter.  Factored out of emitApp's CVar-head ladder
-- so that the VALUE-position eta-wrap (emitExternEtaClosure) can REPLAY the exact
-- applied-form codegen on synthetic `%argK` operands — value/applied byte-
-- consistency by construction, no parallel codegen to drift.  The family order is
-- the ladder's original order (behaviour-preserving; `arrayMakeWith` keeps its
-- exact-name slot ahead of the arrayLeaf family).  Caller guards `hasArgs args`.
emitExternApplied : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> (String, LTy)
emitExternApplied e env fname args =
  if isStrExtern fname then
    emitStrExtern e env fname args
  else if isNumExtern fname then
    emitNumExtern e env fname args
  else if isIoExtern fname then
    emitIoExtern e env fname args
  else if isAbortExtern fname then
    emitAbortExtern e env fname args
  else if isArrIntrinsic fname then
    emitArrIntrinsic e env fname args
  else if fname == "arrayMakeWith" then
    emitArrayMakeWith e env args
  else if isArrLeafExtern fname then
    emitArrLeafExtern e env fname args
  else if isCharExtern fname then
    emitCharExtern e env fname args
  else if isStrCharExtern fname then
    emitStrCharExtern e env fname args
  else if isUnicodeExtern fname then
    emitUnicodeExtern e env fname args
  else if isAdtExtern fname then
    emitAdtExtern e env fname args
  else if isEnvExtern fname then
    emitEnvExtern e env fname args
  else if isFileExtern fname then
    emitFileExtern e env fname args
  else if isNetExtern fname then
    emitNetExtern e env fname args
  else if isRngExtern fname then
    emitRngExtern e env fname args
  else if isHashExtern fname then
    emitHashExtern e env fname args
  else if isBitExtern fname then
    emitBitExtern e env fname args
  else if isPerfExtern fname then
    emitPerfExtern e env fname args
  else
    emitDebugLitExtern e env fname args

emitBin : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> String -> (String, LTy)
emitBin e env op l r tag
  | isCmpOp op = emitCmp e env op l r
  | isArithOp op = emitArith e env op l r tag
  | op == "::" =
    let (lv, _) = emitExpr e env l
    let (rv, _) = emitExpr e env r
    emitCtorAlloc e "Cons" [lv, rv]
  | op == "++" =
    let (lv, lty) = emitExpr e env l
    let (rv, _) = emitExpr e env r
    let r2 = freshReg e
    match lty
      LTStr =>
        let _ = emit e "  \{r2} = call i64 @mdk_string_append(i64 \{lv}, i64 \{rv})"
        (r2, LTStr)
      LTCon =>
        let _ = emit e "  \{r2} = call i64 @mdk_list_append(i64 \{lv}, i64 \{rv})"
        (r2, LTCon)
      LTUnknown =>
        let _ = emit e "  \{r2} = call i64 @mdk_append(i64 \{lv}, i64 \{rv})"
        (r2, LTUnknown)
      _ =>
        let _ = emit e "  \{r2} = call i64 @mdk_append(i64 \{lv}, i64 \{rv})"
        (r2, LTUnknown)
  | otherwise = gapE ("unsupported binary operator '" ++ op ++ "'")
-- LTUnknown: the left operand is itself a runtime-dispatched-append result
-- (a CHAINED `++`, e.g. `a ++ b ++ c`).  Its kind is genuinely unknown — it
-- may be a String OR a list (typecheck.mdk's `freeEffvars` builds `List Int`
-- this way).  Re-route through @mdk_append (NOT a direct @mdk_string_append,
-- which would crash on a list cell), keeping the result LTUnknown so any
-- further chaining stays runtime-dispatched.  Value-identical to the direct
-- path for the string case (mdk_append → mdk_string_append on a String
-- header), so every byte-diff gate is unaffected.

-- E8 (#3 census-B): operand static LTy unknown (E2c/E7 couldn't recover
-- it) — the ~328 scanTriple/splitLines string-builder residual.  Instead
-- of gapE, dispatch at RUNTIME via @mdk_append, which inspects the left
-- cell header (odd => Nil/list; even header==MDK_STR_TAG => string; else
-- => Cons/list) and calls the right append helper.  The result VALUE is
-- always correct.  Result LTy is statically unknowable here, so we tag it
-- LTUnknown (NOT LTStr): LTUnknown follows LTStr at print/`==` sites (the
-- dominant String-builder downstream) but a CHAINED `++` over it re-routes
-- through @mdk_append instead of a direct @mdk_string_append — closing the
-- segfault when the value is actually a list.  emitPrint LTCon already
-- panics on lists, and fixtures project String results through
-- stringLength (a type-forcing String read) so validation is
-- byte-identical and independent of this default.

-- the arithmetic operators the spike lowers to int/float instructions.  `::` and
-- `++` survive lowering as CBinPrim but are NOT arithmetic — they fall to the gap.
isArithOp : String -> Bool
isArithOp op = op == "+" || op == "-" || op == "*" || op == "/" || op == "%"

-- ── float-expression fusion (unboxed double arithmetic) ─────────────────────
-- Float arith/compare otherwise boxes a 16B cell at EVERY intermediate node and
-- round-trips each result through a box even when the parent immediately
-- re-consumes it.  Fusion computes a maximal float-arith subtree in unboxed
-- `double` SSA registers and boxes ONCE at the boundary (and ZERO times when the
-- consumer is a comparison).  Bit-identical results — box/unbox is a pure memory
-- round-trip of the same double.  No ABI change; only the statically-Float path
-- (the polymorphic LTNum path is untouched).

-- Statically Float?  CONSERVATIVE (no false positives vs emitExpr's emitted LTy):
-- a float literal; a local typed LTFloat; an arith node whose left operand is
-- statically float (arith preserves operand type).  A false negative only loses
-- the optimization (falls to the boxing path); it can never miscompile.
staticIsFloat : List (String, (String, LTy)) -> CExpr -> Bool
staticIsFloat env (CLit (LFloat _)) = True
staticIsFloat env (CVar x _) = match lookupAssoc x env
  Some (_, LTFloat) => True
  Some (_, LTFloatU) => True
  _ => False
staticIsFloat env (CBinPrim op l _ _) = isArithOp op && staticIsFloat env l
staticIsFloat env _ = False

-- CONSERVATIVE "does this expression evidently evaluate to a Float?" check, used to
-- record a lambda's return type.  Unlike staticIsFloat (which checks only the LEFT
-- arith operand, for the unbox-fusion fast path) this is SYMMETRIC over arith (a
-- float on EITHER side ⇒ the homogeneous `+`/`-`/`*`/`/` result is float) and
-- descends if/let/block tails.  Only a float LITERAL or a known-float var (capture)
-- makes it True, so it never false-positives a non-float body.
bodyFloatRet : List (String, (String, LTy)) -> CExpr -> Bool
bodyFloatRet env (CLit (LFloat _)) = True
bodyFloatRet env (CVar x _) = match lookupAssoc x env
  Some (_, LTFloat) => True
  Some (_, LTFloatU) => True
  _ => False
bodyFloatRet env (CBinPrim op l r _) = isArithOp op
  && (bodyFloatRet env l || bodyFloatRet env r)
bodyFloatRet env (CIf _ t f) = bodyFloatRet env t || bodyFloatRet env f
bodyFloatRet env (CLet _ _ _ b) = bodyFloatRet env b
bodyFloatRet env (CBlock stmts) = blockFloatRet env stmts
bodyFloatRet env _ = False

-- a block evaluates to its LAST statement's value (a trailing CSLet yields Unit).
blockFloatRet : List (String, (String, LTy)) -> List CStmt -> Bool
blockFloatRet _ [] = False
blockFloatRet env [CSExpr e] = bodyFloatRet env e
blockFloatRet _ [_] = False
blockFloatRet env (_::rest) = blockFloatRet env rest

-- record a closure word's return type as LTFloat when its body evidently returns a
-- Float (so a saturated indirect call to it types its result LTFloat).
recordFloatRet : Emit -> List (String, (String, LTy)) -> String -> CExpr -> Unit
recordFloatRet e env w body =
  if bodyFloatRet env body then
    setRef closureRetTyRef ((w, LTFloat)::closureRetTyRef.value)
  else
    ()

-- Emit `ex` as an UNBOXED double register (no heap box).  Recurses through float
-- arith nodes; a non-arith leaf is emitted normally to a word then unboxed once
-- (matching emitArith's existing LTFloat branch, which already unboxes operands on
-- the strength of the left's type).  Only called in statically-Float context.
emitFloatD : Emit -> List (String, (String, LTy)) -> CExpr -> String
emitFloatD e env (CLit (LFloat f)) = ensureFloatDot (floatToString f)
emitFloatD e env (ex@(CBinPrim op l r _)) =
  if isArithOp op then
    let ld = emitFloatD e env l
    let rd = emitFloatD e env r
    let res = freshReg e
    let _ = emit e "  \{res} = \{floatOp op} double \{ld}, \{rd}"
    res
  else emitFloatLeaf e env ex
emitFloatD e env ex = emitFloatLeaf e env ex

emitFloatLeaf : Emit -> List (String, (String, LTy)) -> CExpr -> String
emitFloatLeaf e env ex = match floatFromIntArg ex
  Some a =>
    let (aw, _) = emitExpr e env a
    let i = untagInt e aw
    let r = freshReg e
    let _ = emit e "  \{r} = sitofp i64 \{i} to double"
    r
  None => emitFloatLeafN e env ex

-- a saturated call to a float-fw fn → call its `$fw` (double-ABI) directly (float-pos
-- args as doubles, others i64) and use the returned double — no box/unbox round-trip.
emitFloatLeafN : Emit -> List (String, (String, LTy)) -> CExpr -> String
emitFloatLeafN e env ex = match flattenApp ex []
  (CVar f _, args) => match floatFwHas f (lengthS args) && not (isLocal env f)
    True =>
      let ops = emitWorkerArgs e env (floatFwFp f) 0 args
      let r = freshReg e
      let _ = emit e "  \{r} = call double @mdk_\{f}__fw(\{ops})"
      r
    False => emitFloatLeafVar e env ex
  _ => emitFloatLeafVar e env ex

emitFloatLeafVar : Emit -> List (String, (String, LTy)) -> CExpr -> String
emitFloatLeafVar e env ex = match floatVarReg env ex
  Some reg => reg
  None =>
    let (w, _) = emitExpr e env ex
    unboxFloat e w

-- floatFwSetRef accessors: does `f` have a `$fw` of arity `n`, and its float positions.
floatFwHas : String -> Int -> Bool
floatFwHas f n = match lookupAssoc f floatFwSetRef.value
  Some (ar, _) => ar == n
  None => False

floatFwFp : String -> List Int
floatFwFp f = match lookupAssoc f floatFwSetRef.value
  Some (_, fp) => fp
  None => []

-- in a statically-Float context, `intToFloat x` / `fromInt x` (@ Float) is just an
-- int→double conversion: emit `sitofp` directly instead of the extern/impl call's
-- box-then-unbox. Returns the Int arg if `ex` is such a call (head name match, arity 1).
floatFromIntArg : CExpr -> Option CExpr
floatFromIntArg ex = match flattenApp ex []
  (h, a::[]) =>
    if headNameIs h "intToFloat" || headNameIs h "fromInt" then
      Some a
    else
      None
  _ => None

headNameIs : CExpr -> String -> Bool
headNameIs (CVar n _) name = n == name
headNameIs (CMethod n _ _ _) name = n == name
headNameIs _ _ = False

-- the unboxed-double register for an LTFloatU let-bound CVar (a float-let kept
-- unboxed in the env), else None — then emitFloatLeaf unboxes the boxed word.
floatVarReg : List (String, (String, LTy)) -> CExpr -> Option String
floatVarReg env (CVar x _) = match lookupAssoc x env
  Some (reg, LTFloatU) => Some reg
  _ => None
floatVarReg _ _ = None

-- arithmetic preserves operand type (well-typed: both operands share a type).
-- SHARED-FLOAT-RESIDUAL §3(C): [tag] is the typecheck-stamped scalar type of this
-- arithmetic node ("Float"/"Int"/""; from CBinPrim's RScalar route).  When it is
-- "Float" (fieldNameToLTy → LTFloat) route to the float path even when the
-- structural staticIsFloat can't see through a type-lost operand (e.g. a value
-- bound from a polymorphic HOF, #9) — additive: an absent/non-Float tag falls back
-- to today's structural detection, so the tag only ever ADDS Float knowledge.
scalarTagIsFloat : String -> Bool
scalarTagIsFloat tag = match fieldNameToLTy tag
  Some LTFloat => True
  _ => False

emitArith : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> String -> (String, LTy)
emitArith e env op l r tag =
  if scalarTagIsFloat tag || staticIsFloat env l || isFloatFieldAccess e l || isFloatFieldAccess e r then
    emitFloatArith e env op l r
  else
    emitArithW e env op l r

-- True when `ex` is a record field ACCESS of a declared-Float field.  Used ONLY to
-- route arith to the float path (emitFloatArith unboxes the boxed-float field word
-- via emitFloatLeafVar) — `r.dx + r.dy` over Float fields otherwise defaulted both
-- operands to LTInt (emitFieldAccess always returns LTInt) and did INTEGER arith on
-- boxed-float pointers → garbage.  Scoped to the arith ROUTING decision (no change
-- to emitFieldAccess's returned LTy), so field accesses flowing elsewhere — e.g.
-- arg-tag dispatch — keep LTInt and the emitter's own self-compile is unperturbed.
isFloatFieldAccess : Emit -> CExpr -> Bool
isFloatFieldAccess e (CFieldAccess _ label recName) =
  isFloatFieldLabel e recName label
isFloatFieldAccess _ _ = False

isFloatFieldLabel : Emit -> String -> String -> Bool
isFloatFieldLabel e recName label = match floatFieldRecord e recName label
  Some (name, labels) => match indexOfStr label labels
    Some pos =>
      let tns = ctorFieldTypeNamesOf name
      if pos < listLen tns then nthStr tns pos == "Float" else False
    None => False
  None => False

-- Pick the record owning `label` for float-ness: by the typecheck-stamped name
-- when known + present, else the label-only search (same fallback rule as
-- fieldIdxByName, so an Int/Float collision on the same field name routes float
-- arithmetic by the receiver's actual record).
floatFieldRecord : Emit -> String -> String -> Option (String, List String)
floatFieldRecord e recName label =
  if recName == "" then findRecordByLabel (recFieldTable e) label
  else match lookupAssoc recName (recFieldTable e)
    Some labels =>
      if contains label labels then
        Some (recName, labels)
      else
        findRecordByLabel (recFieldTable e) label
    None => findRecordByLabel (recFieldTable e) label

-- fused statically-Float arithmetic: both operands as unboxed doubles, one float
-- op, box ONCE (replaces N intermediate boxes with 1).
emitFloatArith : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> (String, LTy)
emitFloatArith e env op l r =
  let ld = emitFloatD e env l
  let rd = emitFloatD e env r
  let res = freshReg e
  let _ = emit e "  \{res} = \{floatOp op} double \{ld}, \{rd}"
  (boxFloat e res, LTFloat)

-- the boxing fallback path (left operand not statically float): unchanged from the
-- original emitArith.  Still reached for float values the static check misses (e.g.
-- a float-returning CALL on the left) — its LTFloat branch boxes as before.
emitArithW : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> (String, LTy)
emitArithW e env op l r =
  let (lv, lty) = emitExpr e env l
  let (rv, rty) = emitExpr e env r
  match lty
    LTFloat =>
      let ld = unboxFloat e lv
      let rd = unboxFloat e rv
      let res = freshReg e
      let _ = emit e "  \{res} = \{floatOp op} double \{ld}, \{rd}"
      (boxFloat e res, LTFloat)
    LTNum =>
      let res = freshReg e
      let _ = emit e "  \{res} = call i64 @\{numOp op}(i64 \{lv}, i64 \{rv})"
      (res, LTNum)
    _ => match rty
      LTFloat =>
        let ld = unboxFloat e lv
        let rd = unboxFloat e rv
        let res = freshReg e
        let _ = emit e "  \{res} = \{floatOp op} double \{ld}, \{rd}"
        (boxFloat e res, LTFloat)
      LTNum =>
        let res = freshReg e
        let _ = emit e "  \{res} = call i64 @\{numOp op}(i64 \{lv}, i64 \{rv})"
        (res, LTNum)
      _ =>
        let li = untagInt e lv
        let ri = untagInt e rv
        if op == "/" || op == "%" then emitIntDivZeroChecked e op li ri
        else
          let res = freshReg e
          let _ = emit e "  \{res} = \{intOp op} i64 \{li}, \{ri}"
          (tagInt e res, LTInt)

-- Integer `/` or `%`: guard the divisor against zero before the hardware
-- sdiv/srem.  A zero divisor is UB in LLVM (the div is elided / yields garbage
-- and the program silently exits 0), so branch to a runtime abort
-- (@mdk_div_zero / @mdk_mod_zero: prints `runtime error [E-DIV-ZERO]` /
-- `[E-MOD-ZERO]` to stderr, exits nonzero), matching the interpreter's evalArith
-- guard.  No source location is baked in — Core IR carries none, so the native
-- trap is the interpreter's message MINUS `file:L:C:` (a located trap is a
-- follow-on).  On a nonzero divisor the ok-branch runs the original sdiv/srem
-- unchanged, so valid-division output is byte-identical.
emitIntDivZeroChecked : Emit -> String -> String -> String -> (String, LTy)
emitIntDivZeroChecked e op li ri =
  let z = freshReg e
  let _ = emit e "  \{z} = icmp eq i64 \{ri}, 0"
  let n = intToString (freshLocal e)
  let zeroL = "divzero" ++ n
  let okL = "divok" ++ n
  let _ = emit e "  br i1 \{z}, label %\{zeroL}, label %\{okL}"
  let _ = emit e (zeroL ++ ":")
  let abortFn = if op == "%" then "mdk_mod_zero" else "mdk_div_zero"
  let _ = emit e "  call void @\{abortFn}()"
  let _ = emit e "  unreachable"
  let _ = emit e (okL ++ ":")
  let res = freshReg e
  let _ = emit e "  \{res} = \{intOp op} i64 \{li}, \{ri}"
  (tagInt e res, LTInt)
-- G3: a POLYMORPHIC Num operand (declared type-var param) — could be Int OR
-- Float at runtime.  Route through the runtime tag-dispatched @mdk_num_* helper
-- (low-bit discriminator), keeping the result LTNum so a chained `Num` op and
-- the polymorphic print site stay runtime-dispatched.  An LTNum on EITHER side
-- propagates (the other operand shares the type by well-typing).

-- comparison always yields a Bool word; dispatch the compare on operand type.
emitCmp : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> (String, LTy)
emitCmp e env op l r =
  if staticIsFloat env l then
    emitFloatCmp e env op l r
  else
    emitCmpW e env op l r

-- fused statically-Float comparison: operands as unboxed doubles, fcmp, NO box.
emitFloatCmp : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> (String, LTy)
emitFloatCmp e env op l r =
  let ld = emitFloatD e env l
  let rd = emitFloatD e env r
  let c = freshReg e
  let _ = emit e "  \{c} = fcmp \{floatPred op} double \{ld}, \{rd}"
  boolFromI1 e c

emitCmpW : Emit -> List (String, (String, LTy)) -> String -> CExpr -> CExpr -> (String, LTy)
emitCmpW e env op l r =
  let (lv, lty) = emitExpr e env l
  let (rv, rty) = emitExpr e env r
  if (isLTUnknown lty || isLTUnknown rty) && isEqOp op then emitValueEq e op lv rv
  else
    if isStrLTy lty || isStrLTy rty then emitStrCmp e op lv rv
    else match lty
      LTFloat =>
        let ld = unboxFloat e lv
        let rd = unboxFloat e rv
        let c = freshReg e
        let _ = emit e "  \{c} = fcmp \{floatPred op} double \{ld}, \{rd}"
        boolFromI1 e c
      LTInt =>
        if isEqOp op then
          emitValueEq e op lv rv
        else
          emitValueCmp e op lv rv
      -- Same split as LTInt: `==`/`!=` are @mdk_value_eq's job, ordering is
      -- emitValueCmp's.  (This arm USED to send BOTH to the 3-way, where `==`
      -- worked only incidentally — `icmp eq raw, 0` ⟺ "compare said EQ" — and
      -- inherited the 3-way's NaN collapse, so a Float reaching here compared
      -- `nan == nan` as True.  @mdk_value_eq's `da == db` is IEEE. #305)
      _ =>
        if isEqOp op then
          emitValueEq e op lv rv
        else
          emitValueCmp e op lv rv
-- A boxed-string operand (EITHER side — a `""` literal forces it even when the
-- other side's static LTy wasn't inferred to LTStr) routes `==`/`!=` through
-- @mdk_string_eq; pointer identity (the integer arm) is WRONG for string cells.
-- An LTUnknown operand (chained-`++` result) could be a String OR a list, so
-- for `==`/`!=` route through @mdk_value_eq (runtime String/word discriminator)
-- rather than @mdk_string_eq, which would crash reading a list cell as a String.

-- Unknown static type (LTInt default — could be Int/Bool/Char OR a boxed
-- String/Float the emitter couldn't recover, e.g. `k <= k2` where `k`/`k2`
-- were bound through a TUPLE destructure inside a recursive list walk, losing
-- their `(String,String)` component type → both default to LTInt): an integer
-- `icmp` then compares boxed-String/Float POINTERS as ints — pointer-identity
-- (heap-ADDRESS) ordering, and so WRONG.  Route BOTH equality AND ordering
-- through the runtime discriminators: `==`/`!=` via @mdk_value_eq, `<`/`>`/…
-- via the per-op IEEE predicates @mdk_value_lt/le/gt/ge (Float cell → direct f64
-- predicate, #305; String cell → byte compare; immediate → word compare, the
-- latter two over the shared 3-way @mdk_value_cmp_raw), mirroring mdk_append's runtime
-- String/List discrimination.  This is the ordering analog of the @mdk_value_eq
-- precedent — concrete-Int ordering also routes through the runtime helper
-- (as concrete-Int `==` already does), staying correct and uniform.
--
-- An `if`-EXPRESSION (not a guarded `LTInt if isEqOp op` arm) keeps this
-- function self-compilable: the gap-tolerant bootstrap emitter cannot lower a
-- guarded match arm.  IR is byte-identical to the guarded form.

-- ordering (`<`/`>`/`<=`/`>=`) of two operands of statically-unknown kind via the
-- runtime per-op IEEE predicates @mdk_value_lt/le/gt/ge (note at emitCmp), which
-- return a TAGGED Bool directly — no `icmp … , 0` step.
--
-- #305 (S0): this USED to call the three-way @mdk_value_cmp_raw and then `icmp
-- <intPred op> raw, 0`.  That is wrong at Float+NaN: a -1/0/1 Ordering
-- STRUCTURALLY CANNOT express NaN's unorderedness, so the runtime's Float arm
-- collapsed an unordered pair to 0 (EQ) and `nan <= nan` read as `0 <= 0` = True
-- — while `run` (eval) and the static-Float path (`fcmp ole`, #288) both said
-- False.  EMITTER-SEMANTICS §4 N5/N6: the four relational ops at Float are
-- PRIMITIVE IEEE predicates on EVERY path and are never derived from `compare`.
-- The runtime helpers take the boxed-Float arm themselves (plain f64 compare —
-- False at NaN, matching inline `fcmp`) and fall back to the 3-way only for the
-- String/immediate shapes, where -1/0/1 is exact.
emitValueCmp : Emit -> String -> String -> String -> (String, LTy)
emitValueCmp e op lv rv =
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @mdk_value_\{valueRelName op}(i64 \{lv}, i64 \{rv})"
  (r, LTBool)

-- The @mdk_value_* suffix for an ordering op.  Only `<`/`>`/`<=`/`>=` reach
-- emitValueCmp — emitCmpW routes `==`/`!=` to emitValueEq before it.
valueRelName : String -> String
valueRelName "<" = "lt"
valueRelName ">" = "gt"
valueRelName "<=" = "le"
valueRelName ">=" = "ge"
valueRelName op = panic ("llvm: unsupported value ordering op " ++ op)

-- equality of two operands of statically-unknown kind via the runtime
-- discriminator (note at emitCmp).  `==` returns @mdk_value_eq's tagged Bool
-- directly; `!=` flips 3<->1 with `xor … 2` (same shape as emitStrCmp).
emitValueEq : Emit -> String -> String -> String -> (String, LTy)
emitValueEq e op lv rv
  | op == "==" =
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_value_eq(i64 \{lv}, i64 \{rv})"
    (r, LTBool)
  | otherwise =
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_value_eq(i64 \{lv}, i64 \{rv})"
    let n = freshReg e
    let _ = emit e "  \{n} = xor i64 \{r}, 2"
    (n, LTBool)

isEqOp : String -> Bool
isEqOp op = op == "==" || op == "!="

isStrLTy : LTy -> Bool
isStrLTy LTStr = True
-- LTUnknown (chained-`++` result) follows LTStr for `==`/`!=`: route through the
-- runtime string/value discriminator rather than a pointer-identity icmp.
isStrLTy LTUnknown = True
isStrLTy _ = False

isLTUnknown : LTy -> Bool
isLTUnknown LTUnknown = True
isLTUnknown _ = False

-- String `==`/`!=`: pointer identity is WRONG for boxed string cells, so route
-- content equality through @mdk_string_eq (the same helper the pattern-match
-- literal path uses, returning a TAGGED Bool word 3/1).  `==` returns it directly;
-- `!=` flips 3<->1 via `xor … 2`.  Ordering ops (`<`/`>`/`<=`/`>=`) on strings
-- route through @mdk_string_compare_raw, which returns a PLAIN -1/0/1 i64; the
-- operator then becomes `icmp <intPred op> raw, 0` (e.g. `a < b` ⟺ `cmp < 0`),
-- reusing intPred's slt/sgt/sle/sge and boolFromI1.  (Self-compile C2 exercises
-- this: the native emitter's own sanitizeId/safeChar do String `<`/`<=` at emit
-- time; a pointer `icmp` there mis-mangled module names.)
emitStrCmp : Emit -> String -> String -> String -> (String, LTy)
emitStrCmp e op lv rv
  | op == "==" =
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_string_eq(i64 \{lv}, i64 \{rv})"
    (r, LTBool)
  | op == "!=" =
    let r = freshReg e
    let _ = emit e "  \{r} = call i64 @mdk_string_eq(i64 \{lv}, i64 \{rv})"
    let n = freshReg e
    let _ = emit e "  \{n} = xor i64 \{r}, 2"
    (n, LTBool)
  | otherwise =
    let cmp = freshReg e
    let _ = emit e "  \{cmp} = call i64 @mdk_string_compare_raw(i64 \{lv}, i64 \{rv})"
    let c = freshReg e
    let _ = emit e "  \{c} = icmp \{intPred op} i64 \{cmp}, 0"
    boolFromI1 e c

-- an i1 (from icmp/fcmp) -> a Bool word (zext to i64, then tag as immediate int).
boolFromI1 : Emit -> String -> (String, LTy)
boolFromI1 e c =
  let z = freshReg e
  let _ = emit e "  \{z} = zext i1 \{c} to i64"
  (tagInt e z, LTBool)

emitUn : Emit -> List (String, (String, LTy)) -> String -> CExpr -> (String, LTy)
emitUn e env "-" x =
  let (v, ty) = emitExpr e env x
  match ty
    LTFloat =>
      let d = unboxFloat e v
      let r = freshReg e
      let _ = emit e "  \{r} = fneg double \{d}"
      (boxFloat e r, LTFloat)
    _ =>
      let i = untagInt e v
      let r = freshReg e
      let _ = emit e "  \{r} = sub i64 0, \{i}"
      (tagInt e r, LTInt)
emitUn e env "!" x =
  let (v, _) = emitExpr e env x
  let i = untagInt e v
  let r = freshReg e
  let _ = emit e "  \{r} = xor i64 \{i}, 1"
  (tagInt e r, LTBool)
emitUn _ _ op _ = gapE ("unsupported unary op " ++ op)

-- `if`: lower via an alloca slot (memory, not phi) so a branch's own internal
-- control flow never has to be threaded into a phi's incoming-block list — the
-- simplest correct lowering for a spike (clang -O0 keeps the alloca; mem2reg
-- would promote it under -O).  Both arms share a type; report the then-arm's.
emitIf : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> CExpr -> (String, LTy)
emitIf e env c t f =
  let (cv, _) = emitExpr e env c
  let ci = untagInt e cv
  let cb = freshReg e
  let _ = emit e "  \{cb} = icmp ne i64 \{ci}, 0"
  let n = intToString (freshLocal e)
  let thenL = "then" ++ n
  let elseL = "else" ++ n
  let endL = "end" ++ n
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let _ = emit e "  br i1 \{cb}, label %\{thenL}, label %\{elseL}"
  let _ = emit e (thenL ++ ":")
  let (tv, tty) = emitExpr e env t
  let _ = emit e "  store i64 \{tv}, ptr \{slot}"
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (elseL ++ ":")
  let (fv, _) = emitExpr e env f
  let _ = emit e "  store i64 \{fv}, ptr \{slot}"
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{slot}"
  (r, tty)

emitLet : Emit -> List (String, (String, LTy)) -> Bool -> Pat -> CExpr -> CExpr -> (String, LTy)
emitLet e env False (PVar x) e1 e2 =
  if staticIsFloat env e1 then
    let d = emitFloatD e env e1
    emitExpr e ((x, (d, LTFloatU))::env) e2
  else
    let (v, ty) = emitExpr e env e1
    emitExpr e ((x, (v, ty))::env) e2
emitLet e env False PWild e1 e2 =
  let _ = emitExpr e env e1
  emitExpr e env e2
emitLet e env False (PTuple ps) e1 e2 =
  let (v, _) = emitExpr e env e1
  let env2 = bindPattern e env (PTuple ps) v e2
  emitExpr e env2 e2
-- a recursive (function-`let`) closure: `let f p… = … in e2` lowers to
-- CLet True (PVar f) (CLam …) (slice 5b).  The lambda's own name `f` is the
-- closure itself, so it is EXCLUDED from the capture set at the alloc site and
-- bound to `%clos` (the leading closure pointer) inside the lifted define — a
-- recursive self-call re-enters the same code with the same cell.  Non-recursive
-- function-lets take the same path harmlessly (`f` simply never appears free).
emitLet e env True (PVar f) (CLam pats body) e2 =
  let (w, ty) = emitRecLam e env f pats body
  emitExpr e ((f, (w, ty))::env) e2
-- P0-2c: general expression-level `let pat = e1 in e2` for a non-recursive,
-- non-(var/wild/tuple) pattern (PCon/PCons/PList/PAs) — the expression-position
-- analog of emitBlock's general CSLet arms.  Mirrors them: an irrefutable head
-- (single-ctor PCon) destructures unchecked (bindPattern); a refutable head
-- (sibling ctors, list) gets the trap-on-miss check (emitRefutableCsLet), matching
-- the interpreter's blockLet "E-LET-REFUTE" panic.  Previously this shape hit the
-- gapE catch-all (build-fail); it now lowers.  Placed after the PVar/PWild/PTuple
-- and recursive-function arms so those stay byte-identical.
emitLet e env False pat e1 e2 =
  let (v, _) = emitExpr e env e1
  let env2 = if refutableCsLet e pat then
    emitRefutableCsLet e env pat v
  else
    bindPattern e env pat v e2
  emitExpr e env2 e2
emitLet _ _ _ _ _ _ =
  gapE
    "unsupported let (slice 5b: only non-recursive let var/_/tuple = e, or function-let)"

-- a `let`/`where` group.  Bindings emit one at a time, left-to-right, threading
-- the growing env, so a later binding sees the earlier ones (and the body sees
-- all).  Two binding shapes:
--   • `CBind name [CClause [] rhs]` — a nullary VALUE binding (slice 1): emit the
--     rhs, bind the word, recurse.
--   • `CBind name clauses` with non-empty params (a LOCAL FUNCTION, possibly
--     multi-clause / self-recursive — the `go`/`step`/`g` workers core.mdk writes
--     with `where`): lambda-lift it into a (self-recursive) closure via
--     `emitGroupBind` and bind its closure word, then recurse.
-- A binding that forward/mutually references a LATER sibling can't be lifted
-- one-at-a-time — the referent's closure word isn't allocated when this binding's
-- captures are taken.  When that happens the maximal contiguous run of LOCAL
-- FUNCTION bindings starting here is KNOT-TIED together (`emitLetGroupKnot`): all
-- their closure cells are allocated up front (so every sibling word exists), every
-- sibling name is bound in the env, and each cell's capture fields are then
-- back-patched with the now-available sibling words (and any enclosing-scope
-- captures).  References to EARLIER siblings, self-references (bound to `%clos`),
-- arbitrary forward refs and true mutual recursion all emit correctly.  A value
-- binding interleaved INSIDE such a run (a mutual ref crossing a non-function
-- sibling) is the residue this scheme doesn't cover — it is rejected precisely
-- (`gapE`) rather than miscompiled.
emitLetGroup : Emit -> List (String, (String, LTy)) -> List CBind -> CExpr -> (String, LTy)
emitLetGroup e env [] body = emitExpr e env body
emitLetGroup e env ((CBind name [CClause [] rhs])::rest) body =
  let (v, ty) = emitExpr e env rhs
  emitLetGroup e ((name, (v, ty))::env) rest body
emitLetGroup e env ((CBind name clauses)::rest) body
  | refsLater name clauses (bindNames rest) =
    emitKnotRun e env (CBind name clauses :: rest) body
  | otherwise =
    let (w, ty) = emitGroupBind e env (CBind name clauses)
    emitLetGroup e ((name, (w, ty))::env) rest body

-- knot-tie the maximal leading run of function bindings of `binds`, then continue
-- the group with the remainder.  A forward/mutual ref crossing into a LATER value
-- binding (outside the run) is the uncovered residue — rejected precisely.
emitKnotRun : Emit -> List (String, (String, LTy)) -> List CBind -> CExpr -> (String, LTy)
emitKnotRun e env binds body =
  let run = takeFnRun binds
  let after = dropS (lengthS run) binds
  let runNames = bindNames run
  if anyRefsOutsideRun run runNames (bindNames after) then gapE "unsupported let-group: a binding forward/mutually references a later value binding (knot-tying covers only mutual function bindings)"
  else
    let env2 = emitLetGroupKnot e env run runNames
    emitLetGroup e env2 after body

-- the maximal leading run of LOCAL FUNCTION bindings (non-empty params) — a nullary
-- VALUE binding (`CBind _ [CClause [] _]`) ends the run.
takeFnRun : List CBind -> List CBind
takeFnRun [] = []
takeFnRun ((CBind _ [CClause [] _])::_) = []
takeFnRun (b::rest) = b :: takeFnRun rest

dropS : Int -> List a -> List a
dropS _ [] = []
dropS n (x::xs) = if n <= 0 then x::xs else dropS (n - 1) xs

-- True if any binding in the run references a name bound LATER but OUTSIDE the run
-- (i.e. a later value binding) — the case knot-tying cannot tie.
anyRefsOutsideRun : List CBind -> List String -> List String -> Bool
anyRefsOutsideRun [] _ _ = False
anyRefsOutsideRun ((CBind name clauses)::rest) runNames laterOutside
  | anyInList (dedupS (clausesFreeVars name clauses)) laterOutside = True
  | otherwise = anyRefsOutsideRun rest runNames laterOutside
anyRefsOutsideRun (_::rest) runNames laterOutside =
  anyRefsOutsideRun rest runNames laterOutside

-- True when any clause of a local-function binding references a sibling bound
-- LATER in the same group (a forward or mutually-recursive reference whose
-- closure word is not yet available at this binding's capture site).  Self- and
-- param-bound names are excluded by `clausesFreeVars`.
refsLater : String -> List CClause -> List String -> Bool
refsLater name clauses laterNames =
  anyInList (dedupS (clausesFreeVars name clauses)) laterNames

-- the free variables across ALL clauses of a binding, with the self name and each
-- clause's own parameter variables treated as bound.
clausesFreeVars : String -> List CClause -> List String
clausesFreeVars _ [] = []
clausesFreeVars self ((CClause pats body)::rest) = freeVars (self :: patVarNames pats) body
  ++ clausesFreeVars self rest

anyInList : List String -> List String -> Bool
anyInList [] _ = False
anyInList (x::xs) ys = if contains x ys then True else anyInList xs ys

-- lambda-lift a LOCAL FUNCTION binding from a `let`/`where` group into a (possibly
-- self-recursive) closure.  Captures are the free variables across all clauses
-- present in the emit env, MINUS the binding's own name (it is the closure cell
-- itself, bound to `%clos` inside the lift — a self-call re-enters the same cell).
-- The lifted body reuses the E1a decision-tree path (`emitClauseTree`), so a
-- multi-clause worker or a patterned param lowers exactly as a top-level fn does.
emitGroupBind : Emit -> List (String, (String, LTy)) -> CBind -> (String, LTy)
emitGroupBind e env (CBind name clauses) =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let arity = clauseArity (clauseList clauses)
  let captured = keepInEnv env (removeStr name (dedupS (clausesFreeVars name clauses)))
  let captureWords = capWords e env captured
  let _ = emitGroupBindDefine e env lamName name arity clauses captured
  emitClosureAllocA e lamName arity captureWords

-- emit the lifted multi-clause `define` for a let-group local function into the
-- SIDE buffer (same swap discipline as emitPatLamDefine).  Captures load from
-- `%clos` fields 1.., the self name binds to `%clos` (recursive self-call
-- re-enters the same cell), and `emitClauseTree` lowers the clauses over the
-- `%argK` words (arity ≥1 here — nullary values take the fast path above).
emitGroupBindDefine : Emit -> List (String, (String, LTy)) -> String -> String -> Int -> List CClause -> List String -> Unit
emitGroupBindDefine e env lamName name arity clauses captured =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{lamName}(i64 %clos, \{implParamDecls arity 0}) {"
  let _ = emit e "entry:"
  let cenv = loadCaptures e env captured 0
  let _ = emitClauseTree e (((name, ("%clos", LTClosure))::cenv) ++ implParamEnv arity 0) arity (clauseList clauses) ""
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved
-- A lifted define is a FRESH function: its clause chain's last-clause
-- fallthrough must be @mdk_oob (non-exhaustive abort), NOT the enclosing
-- function's leftover next-clause label.  Without this the lifted `go`'s final
-- clause would `br label %clauseN` to a block defined in the PARENT function —
-- invalid LLVM once functions are concatenated in the multi-module output
-- (issue #53).  Hence the explicit "" outer argument to emitClauseTree — which since
-- issue #354 is a parameter, so a fresh define states its own contract instead of
-- depending on nulling ambient state.

clauseList : List CClause -> List (List Pat, CExpr)
clauseList [] = []
clauseList ((CClause pats body)::rest) = (pats, body) :: clauseList rest

-- ── knot-tying: forward/mutual local function bindings ──────────────────────
-- Tie the knot for a RUN of mutually/forward-referencing local function bindings
-- (E5 residual / EMITTER-GAPS #10).  Two passes over the run:
--   1. ALLOC: for each fn binding, lambda-lift it (the lifted `@mdk_lamN` define is
--      independent of the cells — captures load from `%clos` fields by index), then
--      allocate its closure cell with the code pointer in field 0 and PLACEHOLDER
--      `0` words in the capture fields (`emitClosureAllocPatch` returns the raw cell
--      pointer for later stores).  Every sibling name is bound to its cell word.
--   2. PATCH: now that every sibling word exists, store each cell's REAL capture
--      words — looked up in the fully-knotted env (siblings + enclosing scope) — into
--      its capture fields.  This BY-VALUE back-patch ties arbitrary mutual recursion
--      and forward references; self-recursion still flows through `%clos`.
-- The capture-NAME list per binding is computed against a sibling env (so a sibling
-- ref is kept by `keepInEnv` and indexed correctly), and must MATCH the field order
-- the lifted define's `loadCaptures` reads — both walk the same `captured` list.
emitLetGroupKnot : Emit -> List (String, (String, LTy)) -> List CBind -> List String -> List (String, (String, LTy))
emitLetGroupKnot e env run runNames =
  let sibEnv = sibPlaceholderEnv runNames
  let cellEnv = sibEnv ++ env
  let (cells, env2) = knotAlloc e env cellEnv run
  let _ = knotPatch e env2 cells
  env2
-- pass 2: back-patch each cell's capture fields with real words from env2.

-- a placeholder env entry per run name (word "0", LTClosure) for capture-name
-- computation only.
sibPlaceholderEnv : List String -> List (String, (String, LTy))
sibPlaceholderEnv [] = []
sibPlaceholderEnv (n::rest) = (n, ("0", LTClosure)) :: sibPlaceholderEnv rest

-- a knot cell records the binding name, its allocated cell POINTER (for stores),
-- and its ordered capture-name list (matching the lifted define's field layout).
data KnotCell = KnotCell String String (List String)

-- pass 1: for each fn binding, lift it and alloc its closure cell with placeholder
-- captures; thread the env binding each cell word.  `cellEnv` (siblings + outer)
-- is used to compute the capture NAME set so a sibling ref is kept and indexed.
knotAlloc : Emit -> List (String, (String, LTy)) -> List (String, (String, LTy)) -> List CBind -> (List KnotCell, List (String, (String, LTy)))
knotAlloc _ env _ [] = ([], env)
knotAlloc e env cellEnv ((CBind name clauses)::rest) =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let arity = clauseArity (clauseList clauses)
  let captured = keepInEnv cellEnv (removeStr name (dedupS (clausesFreeVars name clauses)))
  let _ = emitGroupBindDefine e cellEnv lamName name arity clauses captured
  let (cellPtr, cellWord) = emitClosureAllocPatch e lamName arity (lengthS captured)
  let (cells, env2) = knotAlloc e ((name, (cellWord, LTClosure))::env) cellEnv rest
  (KnotCell name cellPtr captured :: cells, env2)
knotAlloc e env cellEnv (_::rest) = knotAlloc e env cellEnv rest

-- pass 2: store each cell's real capture words (from the fully-bound env) into its
-- capture fields (offset 8*(i+1), field 0 holds the code pointer).
knotPatch : Emit -> List (String, (String, LTy)) -> List KnotCell -> Unit
knotPatch _ _ [] = ()
knotPatch e env ((KnotCell _ cellPtr captureNames)::rest) =
  let words = capWords e env captureNames
  let _ = storeFields e cellPtr words 1
  knotPatch e env rest

-- allocate a closure cell with the code pointer in field 0 and `nCap` PLACEHOLDER
-- zero capture words, returning BOTH the raw cell pointer (for later stores) and
-- the cell word (the closure value).  Mirrors emitClosureAlloc/emitCtorAlloc's
-- layout exactly — field 0 = code_ptr — so the cell is callable immediately
-- (`emitIndirect` loads field 0); only the capture fields await back-patch.
emitClosureAllocPatch : Emit -> String -> Int -> Int -> (String, String)
emitClosureAllocPatch e lamName callArity nCap =
  let codePtr = "ptrtoint (ptr @" ++ lamName ++ " to i64)"
  let fields = codePtr :: zeroWords nCap
  let nFields = lengthS fields
  let p = freshReg e
  let _ = emit e "  \{p} = call ptr @mdk_alloc(i64 \{intToString (8 * (nFields + 1))})"
  let _ = emit e "  store i64 \{intToString callArity}, ptr \{p}"
  let _ = storeFields e p fields 0
  let w = freshReg e
  let _ = emit e "  \{w} = ptrtoint ptr \{p} to i64"
  (p, w)

zeroWords : Int -> List String
zeroWords n = if n <= 0 then [] else "0" :: zeroWords (n - 1)

emitBlock : Emit -> List (String, (String, LTy)) -> List CStmt -> (String, LTy)
emitBlock e env [CSExpr ex] = emitExpr e env ex
emitBlock e env ((CSExpr ex)::rest) =
  let _ = emitExpr e env ex
  emitBlock e env rest
-- #314: a block-statement function-`let` (`let go i = … go …`) lowers to a
-- `CSLet` whose rhs is a `CLam` and whose body may call `go` recursively (the
-- self-ref is annotated AGlobal since the non-recursive let does not scope its own
-- name).  The generic PVar arm below would `emitExpr` the CLam with `go` NOT in the
-- env, so the lifted body's self-call hits the `gapE "unbound variable"` build
-- failure (`run` worked — eval binds the name before evaluating the body).  Route
-- it through `emitRecLam` (which binds `go -> %clos` inside the lifted define, so a
-- self-call re-enters the same closure) and bind `go` for the rest of the block —
-- the exact mirror of the expression-level `emitLet _ True (PVar f) (CLam …)` arm.
-- A non-recursive function-`let` takes this path harmlessly (`go` never appears
-- free, so it is simply not captured).
emitBlock e env ((CSLet _ (PVar x) (CLam pats body))::rest) =
  let (w, ty) = emitRecLam e env x pats body
  emitBlock e ((x, (w, ty))::env) rest
emitBlock e env ((CSLet _ (PVar x) ex)::rest) =
  if staticIsFloat env ex then
    let d = emitFloatD e env ex
    emitBlock e ((x, (d, LTFloatU))::env) rest
  else
    let (v, ty) = emitExpr e env ex
    emitBlock e ((x, (v, ty))::env) rest
emitBlock e env ((CSLet _ PWild ex)::rest) =
  let _ = emitExpr e env ex
  emitBlock e env rest
emitBlock e env ((CSLet _ (PTuple ps) ex)::rest) =
  let (v, _) = emitExpr e env ex
  let env2 = bindPattern e env (PTuple ps) v (CBlock rest)
  emitBlock e env2 rest
-- General block-let `let pat = e` for an ARBITRARY pattern (PCon, PCons, PList,
-- PAs, nested).  Two cases (P0-2c):
--  • IRREFUTABLE pattern (PVar/PWild/PAs-of-irrefutable, or a PCon of a
--    single-constructor type) — destructure with NO failure branch, exactly as
--    cevalBlock's cBlockLet does (core_ir_eval :269) and as the PTuple arm above.
--    Reuses bindPattern; keeps existing goldens byte-identical.
--  • REFUTABLE pattern (a PCon of a type with sibling ctors, or a list pattern) —
--    a plain `let (Some y) = e` with NO `else` can FAIL at runtime.  The
--    interpreter's blockLet runtimePanics "E-LET-REFUTE"; before this fix the
--    emitter blindly loaded field 0 of a mismatching cell → SIGSEGV.  Now emit a
--    head-ctor tag check that traps @mdk_let_refute on a miss (emitRefutableCsLet).
-- Placed after the specialized PVar/PWild/PTuple arms so those stay byte-identical.
emitBlock e env ((CSLet _ pat ex)::rest) =
  let (v, _) = emitExpr e env ex
  if refutableCsLet e pat then
    let env2 = emitRefutableCsLet e env pat v
    emitBlock e env2 rest
  else
    let env2 = bindPattern e env pat v (CBlock rest)
    emitBlock e env2 rest
-- last-position block-let `[let pat = e]`: mirror cevalBlock's cBlockLetLast
-- (core_ir_eval :265/:277) — evaluate `e` (for effect + to honour the binding),
-- destructure, and the block yields Unit.  Without this a block ending in a let
-- would recurse into `emitBlock e env2 []` and hit the "empty block" gap.  A
-- refutable pattern still gets the trap-on-miss check (P0-2c).
emitBlock e env [CSLet _ pat ex] =
  let (v, _) = emitExpr e env ex
  let _ = if refutableCsLet e pat then
    let _ = emitRefutableCsLet e env pat v
    env
  else bindPattern e env pat v (CLit (LInt 0))
  ("1", LTUnit)
-- `let mut x = e` reuses the irrefutable `CSLet _ (PVar x)` arm above (the mut
-- flag carries no extra emit work — a mutable local is just an SSA value the
-- block's tail rebinds).  A reassignment `x = e` (CSAssign, gap B1) mirrors the
-- tree-walker's `cevalBlock ((CSAssign x e)::rest)`: re-evaluate `e` and SHADOW
-- the `x` binding for the rest of the block.  Blocks are linear (no back-edge re-
-- enters the binding), so functional rebinding is observationally identical to a
-- real mutable slot — no Ref cell needed.
emitBlock e env ((CSAssign x ex)::rest) =
  let (v, ty) = emitExpr e env ex
  emitBlock e ((x, (v, ty))::env) rest
-- the tail statement of a block may be a bare assignment (`x = e`): evaluate for
-- effect, the block yields Unit.
emitBlock e env [CSAssign _ ex] =
  let _ = emitExpr e env ex
  ("1", LTUnit)
emitBlock _ _ [] = gapE "empty block"
emitBlock _ _ _ = gapE "unsupported block statement (slice 1)"

-- bind a list of field patterns to a parallel list of loaded field words.
bindFieldList : Emit -> List (String, (String, LTy)) -> List Pat -> List String -> List (String, (String, LTy))
bindFieldList _ env [] _ = env
bindFieldList _ env _ [] = env
bindFieldList e env (p::ps) (v::vs) =
  let env2 = bindPattern e env p v (CLit (LInt 0))
  bindFieldList e env2 ps vs

-- the head ctor (name, arity, field patterns) of a refutable let-else pattern, if
-- it is a constructor-like pattern (named ctor, cons, or non-empty list literal).
letElseHead : Pat -> Option (String, Int, List Pat)
letElseHead (PCon c args) = Some (c, listLen args, args)
letElseHead (PCons h t) = Some ("Cons", 2, [h, t])
letElseHead (PList (p::ps)) = Some ("Cons", 2, [p, PList ps])
letElseHead _ = None

-- P0-2c: does a general block-`let` pattern (already NOT PVar/PWild/PTuple — those
-- have specialized irrefutable arms) need a runtime match-failure trap?  A PCon is
-- refutable iff its type has SIBLING constructors (a single-ctor `data` — e.g.
-- `Box` — always matches → keep the no-check fast path so goldens stay
-- byte-identical); a cons / non-empty list pattern can always miss (Nil).  Only the
-- TOP-LEVEL head is classified here — nested refutability inside fields shares
-- emitRefutableCsLet's single-level-check limitation.
refutableCsLet : Emit -> Pat -> Bool
refutableCsLet e (PAs _ p) = refutableCsLet e p
refutableCsLet e (PCon c _) = ctorHasSiblings e c
refutableCsLet _ (PCons _ _) = True
refutableCsLet _ (PList (_::_)) = True
refutableCsLet _ _ = False

-- True when constructor `c` shares its type with at least one other constructor
-- (so a pattern on `c` can fail to match).  Unknown ctors (absent from the
-- ctor→type table — e.g. the built-in list Cons/Nil) are conservatively refutable.
ctorHasSiblings : Emit -> String -> Bool
ctorHasSiblings e c = match lookupAssoc c (ctorTypeTable e)
  Some ty => listLen (ctorsOfType e ty) > 1
  None => True

-- P0-2c: emit a REFUTABLE block-`let` bind with a trap-on-miss.  Emits a
-- head-ctor tag check that branches to a noreturn @mdk_let_refute panic
-- (matching the interpreter's blockLet runtimePanic "E-LET-REFUTE").  On a tag
-- match, bind the fields (bindFieldList → bindPattern, a single-level extract)
-- and return the extended env; the
-- caller continues emission in the `ok` block.  A non-constructor-head refutable
-- pattern (letElseHead None — e.g. a bare Nil `let [] = …`) falls back to the old
-- unchecked bindPattern behaviour (no regression).
emitRefutableCsLet : Emit -> List (String, (String, LTy)) -> Pat -> String -> List (String, (String, LTy))
emitRefutableCsLet e env pat sv = match letElseHead pat
  Some (c, a, fieldPats) =>
    let tag = loadDiscriminant e sv
    let cmp = freshReg e
    let _ = emit e "  \{cmp} = icmp eq i64 \{tag}, \{intToString (cellTag e c)}"
    let n = intToString (freshLocal e)
    let ok = "letrefok" ++ n
    let no = "letrefno" ++ n
    let _ = emit e "  br i1 \{cmp}, label %\{ok}, label %\{no}"
    let _ = emit e (no ++ ":")
    let _ = emit e "  call void @mdk_let_refute()"
    let _ = emit e "  unreachable"
    let _ = emit e (ok ++ ":")
    let fields = loadFields e sv a 0
    bindFieldList e env fieldPats fields
  None => bindPattern e env pat sv (CLit (LInt 0))

-- ── function application (slices 2 + 4) ─────────────────────────────────────
-- Three call shapes, by the application spine's head:
--   • a known top-level FUNCTION (slice 2) — saturated direct `call @mdk_<name>`.
--   • a CONSTRUCTOR (slice 3) — heap-cell allocation.
--   • ANYTHING ELSE (slice 4) — a closure-valued head (a parameter, a let-bound
--     lambda, an immediately-applied `CLam`, or a returned closure): emit the head
--     to a closure word, load its code_ptr, and INDIRECT-call it passing the
--     closure word as the leading argument.  SATURATED only — the Core IR is
--     type-erased, so the call site cannot see the closure's arity; the spike
--     relies on controlled fixtures applying a closure with exactly its arity in
--     one spine.  Partial application (under-application → a residual closure) and
--     over-application are OUT (the real backend will carry arity in the cell).
emitApp : Emit -> List (String, (String, LTy)) -> CExpr -> (String, LTy)
emitApp e env app =
  let (hd, args) = flattenApp app []
  match hd
    CVar fname _ => if fname == "Ref" then emitRefAlloc e env args
    else
      if fname == "setRef" then emitSetRef e env args
      else
        -- A LOCALLY-BOUND name (param / let-binding) SHADOWS any same-named ctor /
        -- known top-level fn / interface method / extern: it is a runtime closure
        -- value, so applying it is an INDIRECT call, never a ctor alloc / direct
        -- call / method dispatch.  Without this, a HOF param named like a method
        -- (`pickEq eq x y = eq x y`, or `cmp`/`compare`) fell to the isImplMethod
        -- arm → emitMethodArgDispatch arg-tag-dispatched over the method's impl
        -- groups (incl. PRIMITIVE Int/String/… that own no ctor cell tag) →
        -- emitTagMatch [] slice-7 build reject — while `medaka run` was always
        -- correct (eval treats the param as the local it is).  Mirrors emitVar's
        -- isLocal-first priority for the same name in VALUE position.
        if isLocal env fname then emitIndirect e env hd args
        else if isAnyExtern fname && hasArgs args then emitExternApplied e env fname args
        else
          if isCtor e fname then
            let argOps = emitArgs e env args
            emitCtorApp e fname argOps (ctorArity e fname)
          else
            let fname2 = canonFnName e fname
            if isKnownFn e fname2 && hasArgs args then
              let argOps = emitArgs e env args
              let res = emitKnownFnSat e ("mdk_" ++ fname2) argOps (fnArity e fname2) (fnRetTy e fname2)
              let _ = recordFloatClosureResult e fname2 (lengthS argOps) (fnArity e fname2) res
              res
            else
              if isImplMethod e fname && hasArgs args then
                let argOps = emitArgs e env args
                emitMethodArgDispatch e fname argOps
              else if isFallthroughVar fname then emitFallthrough e fname else emitIndirect e env hd args
    CMethod name route implRoutes methRoutes =>
      let argOps = emitArgs e env args
      emitMethod e env name route implRoutes methRoutes argOps
    CDict name routes =>
      let argOps = emitArgs e env args
      emitDictApp e env name routes argOps
    _ => emitIndirect e env hd args
-- slice 6: an applied method / constrained-fn occurrence.  The real arguments
-- emit first (left-to-right), then the dispatch resolves to a direct impl call
-- (RKey), a runtime impl switch (RDict/RDictFwd), or a dict-passing call (CDict).

-- a saturated INDIRECT call (slice 4): emit the head to a closure word, load its
-- code_ptr (cell field 0), and `call` the loaded pointer with the closure word as
-- the leading argument.  The result type is unknown to the type-erased call site;
-- default Int — EXCEPT (native backend) when the head is a self-returning function
-- PARAM of the impl currently being emitted (`andThen`'s `f` in `f x`): that
-- callback yields the container, so type the result as `tagToLTy <curImplTag>`.
emitIndirect : Emit -> List (String, (String, LTy)) -> CExpr -> List CExpr -> (String, LTy)
emitIndirect e env hd args =
  let (cw, _) = emitExpr e env hd
  let argOps = emitArgs e env args
  match lookupAssoc cw closureArityRef.value
    Some n =>
      if n > 0 && lengthS argOps > n then
        -- OVER-APPLICATION of a let-bound closure (`(g 7) 9`): saturate with the
        -- first `n` args, then apply the surplus to the returned (opaque) value.
        let r0 = emitIndirectCallWords e cw (takeS n argOps)
        (emitApplyAny e r0 (dropS n argOps), LTInt)
      else if n > 0 && lengthS argOps < n then
        -- UNDER-APPLICATION (`let h = g 7` for arity-2 g): build a residual
        -- partial-application closure over the inner closure value + supplied args.
        emitPapClosureIndirect e cw argOps n
      else
        (emitIndirectCallWords e cw argOps, indirectRetTy cw hd)
    -- OPAQUE head (arity unknown at compile time — e.g. a closure PARAM `f` in
    -- `map f`, or a closure pulled from a container).  The supplied count may not
    -- match the closure's runtime arity, so dispatch arity-aware (emitApplyAny):
    -- exact ⇒ inline call; partial ⇒ runtime PAP; over ⇒ saturate + reapply.
    None => (emitApplyAny e cw argOps, indirectRetTy cw hd)

-- the raw indirect call: load the closure's code_ptr (cell field 0) and `call` it
-- with the closure word as the leading argument followed by `argOps`.
emitIndirectCallWords : Emit -> String -> List String -> String
emitIndirectCallWords e cw argOps =
  let cp = loadField e cw 0
  let fp = freshReg e
  let _ = emit e "  \{fp} = inttoptr i64 \{cp} to ptr"
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 \{fp}(\{argDecls (cw::argOps)})"
  r

-- the static result type of an indirect call: container when the head is a
-- self-returning function param of the current impl, else LTInt (unchanged).
indirectResultTy : CExpr -> LTy
indirectResultTy (CVar f _) =
  if isCurSelfFnParam f then
    tagToLTy curImplTagRef.value
  else
    LTInt
indirectResultTy _ = LTInt

-- the result type of an indirect call: a recorded float-returning closure (keyed by
-- the closure word `cw`) types its result LTFloat; otherwise the historical
-- indirectResultTy (self-fn-param container, else LTInt).
indirectRetTy : String -> CExpr -> LTy
indirectRetTy cw hd = match lookupAssoc cw closureRetTyRef.value
  Some t => t
  None => indirectResultTy hd

hasArgs : List CExpr -> Bool
hasArgs [] = False
hasArgs _ = True

-- emit each argument expression (left-to-right); collect the i64 operand words.
emitArgs : Emit -> List (String, (String, LTy)) -> List CExpr -> List String
emitArgs _ _ [] = []
emitArgs e env (a::rest) =
  let (v, _) = emitExpr e env a
  v :: emitArgs e env rest

-- render an operand list as a comma-separated i64 argument list.
argDecls : List String -> String
argDecls [] = ""
argDecls [x] = "i64 " ++ x
argDecls (x::rest) = "i64 \{x}, \{argDecls rest}"

-- ── typeclass dispatch (slice 6) ────────────────────────────────────────────
-- Core IR carries the typechecker's resolved dispatch in two structural nodes
-- (core_ir.mdk): `CMethod name route implRoutes methRoutes` (a method occurrence)
-- and `CDict name routes` (a `=>`-constrained-function occurrence).  Each Route is
-- RNone | RKey String (List Route) | RDict String | RDictFwd String (ast.mdk).
--
-- The KEY TRACTABILITY PROPERTY (the reason the bootstrap is in reach): an RKey
-- route is STATICALLY resolved — the typechecker already pinned the concrete type
-- head, so the impl is known at COMPILE time and the site lowers to a DIRECT call
-- to that impl's lifted `@mdk_impl_<tag>_<method>`, with NO runtime tag inspection.
-- The self-host compiler dispatches return-position via RKey (compiler/README.md),
-- so RKey alone covers the bootstrap.  RDict/RDictFwd read a named dict PARAMETER
-- at run time, so they lower to an if-chain switching on the dict's head tag over
-- the method's impls (corpus completeness — the dict-passing fixtures).  This
-- mirrors core_ir_eval's `methodAtNarrow`/`applyDicts`/`narrowMethod` one-to-one,
-- resolving the same routes in emitted control flow instead of walking VMulti
-- values.  RNone (D3a: a type-variable arg-position site the front end left
-- unstamped) falls back to runtime arg-tag dispatch; nested-requires dicts are out
-- of scope.
--
-- SPIKE-REP NOTES (slice 6; the (j)/(k)/(l) entries in STAGE2-DESIGN §2.4a):
--   (j) DICTS (GAP 1, Option A — BOXED witness) — a dict witness is a POINTER to a
--       heap cell `[ i64 head_tag | i64 reqdict_0 | … ]` (via @mdk_alloc, the same
--       boxed-cell shape ADT ctors use): field 0 = `hashName(impl-head-tag)` (the
--       djb2 used for the `icmp eq` dispatch test), fields 1..n = the RECURSIVELY-
--       built witness words for the impl's per-instance `requires` dicts.  RNone ⇒ 0
--       (no cell).  The rep is UNIFORM: a one-level dict (`RKey k []`) is a 1-word
--       cell `[ hashName k ]`; a two-level dict (`RKey k [RKey k2 …]`) nests another
--       cell pointer in field 1.  Consumption: the RKey direct-call path forwards the
--       boxed pointer as the impl fn's leading dict param; the RDict dispatch chain
--       (emitDispatchChain) loads the head tag from field 0 for the `icmp` and
--       prepends fields 1..n as the matched impl's leading element-dict args.
--       (Previously the witness was a flat i64 that dropped nested reqs and panicked
--       on a non-empty set — the GAP-1 SIGSEGV `medaka build` hit on `[[Int]]`.)
--   (k) IMPL FUNCTIONS — each tagged impl method lowers to a top-level
--       `@mdk_impl_<tag>_<method>(params…)` (lambda-lift convention of emitFn).  A
--       nullary return-position impl (`def`/`zero`/`empty`) is a zero-arg function
--       the use site CALLs for its value; a parameterized impl takes its params.
--   (l) DISPATCH — RKey ⇒ a direct call (impl chosen at compile time).  RDict/
--       RDictFwd ⇒ a CALL to the method's SHARED dispatcher
--       `@mdk_disp_<method>_<nMeth>_<nArgs>(%dict, %mw…, %arg…)`.  ⚠️ THE IF-CHAIN IS
--       NOT AT THE SITE — it lives in that dispatcher (issue #118: it used to be
--       inlined at every site, which made emitted IR grow as `Σ over sites of
--       (#impls of that site's method)`; 107 sites shared just 9 distinct chains on a
--       9-line fixture).  INSIDE the dispatcher the chain is unchanged: compare the
--       dict witness word to each impl's hashName tag; an exhausted chain is
--       `unreachable` (the typechecker proves the dict names a real impl).
--       Debugging a dispatch miscompile? The arm you want is in `@mdk_disp_*`.
--
--       Why one dispatcher can serve every site of a method: the chain body is a pure
--       function of the method NAME, the method-level dict count, and the arg count —
--       all three are baked into the symbol — plus program-global tables
--       (`implsOf`/`defaultFor`/`ifaceTags`, all reading `e.implEntries`, which is
--       written ONCE at Emit construction and never mutated).  So the impl set cannot
--       grow between the site that mints a dispatcher and any later site.

-- a method occurrence.  `argOps` are the already-emitted real-argument words (empty
-- for a bare nullary method like `def`).  methRoutes/implRoutes apply method-/
-- instance-level constraint dicts as leading args (D3b-1): on an RKey call into a
-- parametric `requires` impl, each materializes a one-word dict witness prepended
-- ahead of the real args, matching dict_pass's leading `$dict_<method>_<slot>`
-- params.  Both empty for an unconstrained impl ⇒ the plain direct call.
-- GAP 1: the route's OWN nested `reqs` are now representable (boxed dict cells,
-- Option A) — the former `ensureNoReqs reqs` guard is gone.  This site's leading
-- dicts come from the call-site routes (methRoutes ++ implRoutes); each such
-- route's nested reqs are materialized recursively inside dictWordOfRoute.
emitMethod : Emit -> List (String, (String, LTy)) -> String -> Route -> List Route -> List Route -> List String -> (String, LTy)
emitMethod e env name route implRoutes methRoutes argOps
  -- UNDER-APPLICATION of a runtime-dict-routed method (E22).  A partially-applied
  -- method whose dispatch reads a forwarded `$dict_<method>_<slot>` param (RDict/
  -- RDictFwd) — e.g. `eq y` (arity 2, one arg) passed to a HOF inside a
  -- `Eq a =>` fn — must become a residual PAP closure, NOT a truncated dispatch.
  -- emitMethodDispatch assumes a SATURATED arg list, so calling it with too few
  -- args runs the impl on garbage and the (scalar) result is then INDIRECTLY
  -- called as a closure → SIGSEGV.  The RKey/RNone paths already PAP correctly
  -- (emitImplCallSat/emitMethodArgDispatch → emitPapClosure); this is the missing
  -- RDict/RDictFwd analogue.  The PAP captures the route's dict word(s) + the
  -- supplied args; its forwarder rebinds them and re-emits the saturated dispatch.
  | dictRoutedUnderApplied route name argOps =
      emitMethodPap e env name route implRoutes methRoutes argOps (methodArityOf name)
emitMethod e env name (RKey tag _) implRoutes methRoutes argOps = match implFor e name tag
  Some entry =>
    let dictWords = dictWordsOf e env (methRoutes ++ implRoutes)
    -- [tag] is the stamped route tag — the bare head when the head is unique, the
    -- canonical key on a C7 collision.  For tagToLTy/returns-self use the matched
    -- entry's REAL head tag; the lifted-fn symbol uses implFnSymOf (head when
    -- unique, sanitized key on collision) so it matches emitGroup's name.
    let headTag = implEntryTag entry
    let resTy = if methodReturnsSelf (implEntryIface entry) name then tagToLTy headTag else LTInt
    emitImplCallSat
      e
      (implFnName (implFnSymOf (implEntriesOf e) name entry) name)
      (dictWords ++ argOps)
      (methodArityOf name + lengthS dictWords)
      resTy
  None => emitDefaultRKey e env name tag methRoutes implRoutes argOps
emitMethod e env name (RDict d) implRoutes methRoutes argOps =
  emitMethodDispatch e env name d methRoutes argOps
emitMethod e env name (RDictFwd d) implRoutes methRoutes argOps =
  emitMethodDispatch e env name d methRoutes argOps
emitMethod e env name RNone implRoutes methRoutes argOps =
  emitMethodArgDispatch e name argOps
-- S-1: a CONSTRAINED shadowing standalone was given leading dict PARAMS by
-- dictPassDecl, so its call must supply the matching dict WORDS.  Delegate to
-- emitDictApp — the SAME tested helper the ordinary CDict path uses (it prepends the
-- dict words and, via defArityOf, builds a residual PAP when genuinely
-- under-applied).  Without this the direct emitKnownFnSat call below supplies one
-- word too few, emitKnownFnSat correctly reads that as under-application, and the
-- program silently prints a PAP heap pointer instead of the answer (the S-1 bug).
-- `dicts == []` (every unconstrained standalone, incl. all 5 of the compiler's own
-- definer shadows) keeps the byte-identical pre-S1 direct call ⇒ the self-compile
-- fixpoint cannot move.
emitMethod e env name (RLocal sym dicts) implRoutes methRoutes argOps =
  let target = if sym == "" then name else sym
  if isEmpty dicts then
    emitKnownFnSat e ("mdk_" ++ target) argOps (fnArity e target) (fnRetTy e target)
  else
    emitDictApp e env target dicts argOps
-- native backend: a method whose RESULT mentions the interface/self
-- type variable (map/ap/andThen) returns the CONTAINER; type its
-- RKey-dispatched result as the impl's own type (tagToLTy tag) so a
-- downstream `++`/`::` on it dispatches list/string append.  Otherwise
-- (scalar/element result) keep the LTInt default.

-- C5 (mirror lib/eval.ml RLocal): NOT a method dispatch — the receiver has no
-- impl of this interface but an explicitly-imported/local standalone shadows the
-- method name.  Emit a DIRECT call to that standalone top-level fn (`mdk_<target>`),
-- exactly as emitApp's isKnownFn branch would for a plain call — no dispatch, no
-- dicts.  P0-18: `target` is the carried MANGLED symbol `<mid>__name` when non-empty
-- (the EMИТ path, where the def was renamed by mangleUnits and the EMethodAt carries
-- the BARE dispatch name), else the bare `name` (un-mangled run path).  The compiler's
-- OWN 5 definer shadows (map/hash_map `toList`/`isEmpty`, parser `orElse`) now reach
-- THIS arm with their mangled symbol; the emitted `emitKnownFnSat` call is byte-
-- identical to the pre-P0-18 direct `@mdk_<mid>__name` bare-EVar call (fixpoint gate).

-- Gap #50 (value position) — a bare method occurrence `CMethod name route ..` used
-- as a FIRST-CLASS VALUE (passed to a HOF, e.g. `applyOp max 3 7`): there are no
-- applied args, so the saturated dispatch chain that `emitMethod .. []` would emit
-- runs the impl/default with ZERO operands (garbage), and the result is then handed
-- to the HOF as a closure word and INDIRECTLY called → crash.  Instead eta-wrap the
-- method into a real closure value: a lifted `@mdk_methval_<name>_N(%clos, %arg…)`
-- whose body re-emits the SATURATED dispatch (emitMethod with the full %argK
-- operands) under the method's own route.  For an RDict/RDictFwd route the closure
-- CAPTURES the dict word and rebinds it from `%clos` field 1 in the body, so the
-- runtime impl switch still reads the caller's dict.  A nullary method (arity 0,
-- e.g. `def`) is a plain value — keep the immediate `emitMethod .. []`.
-- S1-RESIDUAL-A (FIXED 2026-07-16, issue #410; SHADOW-SEMANTICS.md §6): a VALUE-position
-- standalone SHADOW (`map size [1,2,3]`) used to miscompile here — the built binary
-- SEGFAULTed (wasm: `illegal cast`) while `check`/`run` were both green.  The lift built
-- the closure at `methodArityOf name` — the interface METHOD's arity — for a body that
-- calls the STANDALONE, whose value arity need not match.  With the two arities EQUAL the
-- lie is invisible, which is why every pre-#410 probe (and the whole d4/d10 corpus) missed
-- it.  When they differ the closure advertises N args to the HOF but its body forwards
-- them to an M-arg function: N>M makes `emitKnownFnSat` take the `emitOverApp` path
-- (:3941), which calls the target, gets a SCALAR back, and hands that Int to
-- `emitApplyAny`, which reads an arity out of the "cell header" of an integer ⇒ SEGFAULT.
-- Fix: the arity is now ROUTE-derived (`methValArity`), not name-derived — the RLocal arm
-- below already knew the truth via `fnArity e target`.
emitMethodValue : Emit -> List (String, (String, LTy)) -> String -> Route -> List Route -> List Route -> (String, LTy)
emitMethodValue e env name route implRoutes methRoutes =
  let arity = methValArity e name route
  if arity <= 0 then emitMethod e env name route implRoutes methRoutes []
  else
    let capNames = methValDictNames route
    let capWords = capDictWords env capNames
    let lamName = "mdk_methval_\{name}_\{intToString (freshId e)}"
    let _ = emitMethodValDefine e env lamName name route implRoutes methRoutes arity capNames
    emitClosureAllocA e lamName arity capWords

-- the VALUE arity the lifted method-value closure must advertise to a HOF — i.e. the
-- number of value args the body it wraps actually consumes, which is a property of the
-- ROUTE, not of the method name (#410).
--
-- RLocal is the definer-shadow route: the body (`emitMethod`'s RLocal arm) forwards to
-- the STANDALONE `mdk_<target>`, so the closure must expose the STANDALONE's value arity.
-- `fnArity` is the right source precisely because it is what that arm's own
-- `emitKnownFnSat`/`emitDictApp` measure against — deriving the closure arity from
-- anything else re-opens the same mismatch from the other side.
--
-- ⚠️ the `- listLen dicts` is load-bearing and NOT cosmetic: `inferSigs` runs over the
-- LOWERED (post-dict-pass) clauses, so `fnArity`'s `ptys` is DICT-INCLUSIVE (see the
-- `trmcTryFn` note ~:7081).  A CONSTRAINED shadow's `fnArity` therefore counts its leading
-- dict params, but the closure exposes VALUE args only — the dict words are CAPTURED (see
-- `methValDictNames`) and re-prepended inside the body by `emitDictApp`.  Without the
-- subtraction a constrained shadow would advertise nDicts too many and segfault exactly
-- like the unconstrained case it fixes.  `dicts == []` ⇒ subtract 0 ⇒ plain `fnArity`.
--
-- A non-RLocal route (RDict/RDictFwd/RKey/RNone) really is dispatching the METHOD, so it
-- keeps `methodArityOf` — byte-identical to pre-#410 codegen, so the fixpoint cannot move.
-- `<= 0` means the target has no known signature (uninstalled sig table / unknown name);
-- fall back to the old name-derived arity rather than emit a 0-arity closure.
methValArity : Emit -> String -> Route -> Int
methValArity e name (RLocal sym dicts) =
  let target = if sym == "" then name else sym
  let a = fnArity e target - listLen dicts
  if a <= 0 then methodArityOf name else a
methValArity _ name _ = methodArityOf name

-- the dict-witness param name(s) a route reads at runtime (the names whose words the
-- value-closure must capture so the lifted body can rebind them).  Only RDict/
-- RDictFwd name a dict; RKey/RNone/RLocal capture nothing.  (Distinct from the
-- `freeVars` helper `routeDictNames`, which scans a route LIST for free dict vars.)
methValDictNames : Route -> List String
methValDictNames (RDict d) = [d]
methValDictNames (RDictFwd d) = [d]
-- S-1: a VALUE-position constrained shadow (`map size xs`) lifts to a closure, and its
-- RLocal route's dict slots may include an RDict — the enclosing constrained fn's own
-- dict param.  That word must be CAPTURED or the lifted body reads an out-of-scope
-- name.  Empty dicts ⇒ [] ⇒ byte-identical to the pre-S1 catch-all.
methValDictNames (RLocal _ dicts) = routeDictNames [] dicts
methValDictNames _ = []

-- the operand words for each captured dict name, looked up in the current emit env.
capDictWords : List (String, (String, LTy)) -> List String -> List String
capDictWords _ [] = []
capDictWords env (d::rest) = dictOperand env d :: capDictWords env rest

-- emit the lifted method-value forwarder.  Captures (the dict words) load from
-- `%clos` fields 1.. and rebind the route's dict name(s); the body re-emits the
-- SATURATED method dispatch over the `%argK` value operands.
emitMethodValDefine : Emit -> List (String, (String, LTy)) -> String -> String -> Route -> List Route -> List Route -> Int -> List String -> Unit
emitMethodValDefine e env lamName name route implRoutes methRoutes arity capNames =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{lamName}(\{etaParamDecls arity}) {"
  let _ = emit e "entry:"
  let cenv = loadCaptures e env capNames 0
  let synArgs = etaArgOps arity 0
  let (r, _) = emitMethod e cenv name route implRoutes methRoutes synArgs
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- CDict in VALUE position (EMITTER-GAPS #18, value facet): a `=>`-constrained
-- NAMED function used as a FIRST-CLASS value — passed unapplied to a higher-order
-- combinator (`filter myParity xs`, `map inc xs`, a user HOF `apply isEv 4`).  The
-- dict_pass-elaborated define `@mdk_<name>` takes `listLen routes` leading dict
-- PARAMS + the value args; emitDictApp handles the CALL (head) position, but a bare
-- occurrence used as a value reached emitExpr's catch-all and panicked
-- "unsupported Core IR node CDict".  Mirror emitMethodValue (the CMethod-as-value
-- path): build the route dict words at THIS site, capture them in a closure cell,
-- and emit a forwarder that reloads them and prepends them ahead of the `%argK`
-- value words when the HOF invokes the closure — yielding a plain closure VALUE with
-- the ABI filter/map/apply expect (field 0 = code_ptr, fields 1.. = captured dicts).
-- The forwarder body is a DIRECT `@mdk_<name>` call (vs emitMethodValue's dispatch).
-- A nullary value arity (the constrained fn takes no value args) degenerates to the
-- plain saturated dict call.
emitDictValue : Emit -> List (String, (String, LTy)) -> String -> List Route -> (String, LTy)
emitDictValue e env name routes =
  if isKnownFn e name then
    let valArity = fnArity e name - listLen routes
    if valArity <= 0 then emitDictApp e env name routes []
    else
      let dictWords = dictWordsOf e env routes
      let lamName = "mdk_dictval_\{name}_\{intToString (freshId e)}"
      let _ = emitDictValDefine e lamName name (lengthS dictWords) valArity
      emitClosureAllocA e lamName valArity dictWords
  else gapE ("CDict head '" ++ name ++ "' is not a known top-level function (slice 6)")

-- emit the lifted constrained-fn value forwarder.  Closure cell layout: field 0 =
-- code_ptr, fields 1..nDicts = captured dict words.  The forwarder takes `valArity`
-- fresh `%argK` params, reloads the dict words from %clos fields 1..nDicts, and
-- calls `@mdk_<name>(dicts.., %arg0.., %arg(valArity-1))` — the same leading-dict-then-
-- value-arg order emitDictApp / dict_pass use at every direct call site.
emitDictValDefine : Emit -> String -> String -> Int -> Int -> Unit
emitDictValDefine e lamName name nDicts valArity =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{lamName}(\{etaParamDecls valArity}) {"
  let _ = emit e "entry:"
  let dictOps = loadPapCaptures e nDicts 0
  let synArgs = dictOps ++ etaArgOps valArity 0
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @mdk_\{name}(\{argDecls synArgs})"
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- E22: a runtime-dict-routed (RDict/RDictFwd) method occurrence is UNDER-APPLIED —
-- arity known, fewer real args than that, and the route reads a forwarded dict
-- param.  (RKey/RNone routes PAP through their own emitImplCallSat/arg-dispatch
-- paths, so they are excluded here and keep their existing lowering.)
dictRoutedUnderApplied : Route -> String -> List String -> Bool
dictRoutedUnderApplied (RDict _) name argOps =
  lengthS argOps < methodArityOf name
dictRoutedUnderApplied (RDictFwd _) name argOps =
  lengthS argOps < methodArityOf name
dictRoutedUnderApplied _ _ _ = False

-- E22: build the residual PAP closure for an under-applied dict-routed method.
-- Captures the route's dict word(s) (so the runtime impl switch still reads the
-- caller's forwarded dict after the closure escapes) PLUS the already-supplied
-- args; the forwarder rebinds both and re-emits the SATURATED `emitMethod` once
-- the remaining args arrive.  Mirrors emitMethodValue (Gap #50, the zero-supplied
-- case) generalised to N supplied args.  Recorded arity is the RESIDUAL value
-- arity so a later over-application of the PAP also splits correctly.
emitMethodPap : Emit -> List (String, (String, LTy)) -> String -> Route -> List Route -> List Route -> List String -> Int -> (String, LTy)
emitMethodPap e env name route implRoutes methRoutes argOps arity =
  let capNames = dedupS (routeDictNames [] (route :: implRoutes ++ methRoutes))
  let dictWords = capDictWords env capNames
  let remaining = arity - lengthS argOps
  let lamName = "mdk_methpap_\{name}_\{intToString (freshId e)}"
  let _ = emitMethodPapDefine e env lamName name route implRoutes methRoutes arity capNames (lengthS argOps)
  emitClosureAllocA e lamName remaining (dictWords ++ argOps)

-- emit the under-applied-method PAP forwarder.  Closure cell layout:
-- field 0 = code_ptr, fields 1..K = captured dict words (K = listLen capNames),
-- fields K+1..K+S = the S supplied arg words.  The forwarder takes `remaining`
-- fresh `%argK` params; its body rebinds the dict names from fields 1..K, reloads
-- the supplied args from fields K+1.., then re-emits the saturated dispatch over
-- (supplied ++ fresh) under the method's own route.
emitMethodPapDefine : Emit -> List (String, (String, LTy)) -> String -> String -> Route -> List Route -> List Route -> Int -> List String -> Int -> Unit
emitMethodPapDefine e env lamName name route implRoutes methRoutes arity capNames supplied =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let remaining = arity - supplied
  let _ = emit e "define i64 @\{lamName}(\{etaParamDecls remaining}) {"
  let _ = emit e "entry:"
  let cenv = loadCaptures e env capNames 0
  let capCount = listLen capNames
  let suppliedOps = loadPapCaptures e (capCount + supplied) capCount
  let synArgs = suppliedOps ++ etaArgOps remaining 0
  let (r, _) = emitMethod e cenv name route implRoutes methRoutes synArgs
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- E19: an RKey route into a method with NO tagged impl for `tag` — the type's
-- `impl` did not override an interface DEFAULT.  Emit the default body as a
-- lifted `@mdk_default_<method>_<tag>` define (eta-expanded to full arity, inner
-- same-interface calls re-stamped to `RKey tag` so a partially-applied inner
-- method like `filterMap` lowers to a direct call), cache it, and call it
-- directly with the call-site args.  No default ⇒ the original missing-impl gap.
-- G7: a default-method body may call methods of a DIFFERENT interface whose dict
-- is threaded per-call by the method's own `=>` constraint (foldMap's `empty`, a
-- Monoid method routed by the RESULT type, not the Foldable container).  Those
-- method-level dicts (methRoutes, resolved from the CALL-SITE constraint monos) are
-- passed as LEADING dict-word args to the shared `@mdk_default_<method>_<tag>` define,
-- whose cross-interface methods the emitter restamped to `RDict $dict_<method>_<slot>`
-- (the dict-passing param) and dispatch the right impl at run time.  The define is
-- still shared across monoids: only the runtime dict word differs per call, so one
-- `@mdk_default_foldMap_List` serves both a List- and a String-monoid fold.
emitDefaultRKey : Emit -> List (String, (String, LTy)) -> String -> String -> List Route -> List Route -> List String -> (String, LTy)
emitDefaultRKey e env name tag methRoutes implRoutes argOps = match defaultFor e name
  Some entry =>
    let fname = defaultFnName tag name
    let _ = ensureDefaultEmitted e fname tag name entry
    let dictWords = dictWordsOf e env (methRoutes ++ implRoutes)
    let resTy = if methodReturnsSelf (methodIfaceOf name) name then
      tagToLTy tag
    else
      LTInt
    emitImplCall e fname (dictWords ++ argOps) resTy
  None => gapE "no impl of method '\{name}' for type '\{tag}' (slice 6)"
-- Native Gap C (parametric default-method dict-synthesis, 2026-06-12): a
-- relational OPERATOR (`<`→`lt`/…) on a parametric Ord head (tuple/`List a`/
-- `Box a`) carries the impl's element `requires` dicts on implRoutes (stamped by
-- typecheck's stampBinopRoute, keyed on the inner `compare`).  Thread them — with
-- the method-level dicts — as LEADING words to `@mdk_default_<op>_<tag>`, whose
-- emitDefaultDefine eta-prepends the matching dict params and forwards them into
-- the inner `@mdk_impl_<tag>_compare(dict.., a, b)` call.  Concrete Ord has empty
-- implRoutes → the plain `(a, b)` call, byte-identical to before.

-- a direct call to a statically-resolved impl fn (RKey).  Nullary (argOps == [])
-- ⇒ `call @mdk_impl_<tag>_<method>()`, yielding the impl's value.  `resTy` is the
-- statically-inferred result type: LTInt for a scalar/element-returning method,
-- or the container (tagToLTy tag) for a returns-self method (map/ap/andThen) so
-- a downstream `++`/`::` types its operand correctly (native backend).
emitImplCall : Emit -> String -> List String -> LTy -> (String, LTy)
emitImplCall e fname argOps resTy =
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @\{fname}(\{argDecls argOps})"
  (r, resTy)

-- a call to a statically-resolved impl fn (RKey / single arg-tag group) that
-- may be UNDER-APPLIED.  A point-free prelude binding (`length = fold f 0`)
-- lowers to the impl method applied to FEWER args than the impl fn's full arity:
-- a saturated `emitImplCall` would emit a call missing its trailing parameter(s),
-- which on the native backend reads a garbage register for the missing arg and
-- crashes.  When `lengthS argOps < arity`, build a PARTIAL-APPLICATION closure
-- capturing the supplied words; the residual closure completes the call when the
-- remaining args arrive at an indirect call site.  Saturated (`==`) ⇒ the plain
-- direct call, unchanged.  (Over-application can't arise at an impl call head —
-- the method's declared arity is its full arity.)
emitImplCallSat : Emit -> String -> List String -> Int -> LTy -> (String, LTy)
emitImplCallSat e fname argOps arity resTy
  | lengthS argOps < arity = emitPapClosure e fname argOps arity
  | otherwise = emitImplCall e fname argOps resTy

-- a call to a known top-level function (`@<sym>`, sym already mdk-prefixed) that
-- may be UNDER-APPLIED.  A partial application of a named function passed to a
-- higher-order combinator (`map (desugarDottedField e) fields` — 1 of 2 args)
-- lowers to a residual closure capturing the supplied args, not a truncated
-- direct call (which would read garbage for the missing trailing param).
-- Saturated (`==`) ⇒ the plain direct call, unchanged.  fnArity returns 0 for a
-- fn with no recorded signature; then `lengthS argOps >= 0` is always saturated,
-- preserving the old direct-call behaviour for such (signature-less) callees.
emitKnownFnSat : Emit -> String -> List String -> Int -> LTy -> (String, LTy)
emitKnownFnSat e sym argOps arity resTy
  | arity > 0 && lengthS argOps < arity = emitPapClosure e sym argOps arity
  | arity > 0 && lengthS argOps > arity = emitOverApp e sym argOps arity resTy
  | otherwise = emitImplCall e sym argOps resTy

-- OVER-APPLICATION: a known fn of arity N applied to >N args (`makeAdder 10 5` —
-- `makeAdder` returns a closure that consumes the extra arg).  Saturate the direct
-- call with the FIRST N args, then apply the residual VALUE (a closure) to each
-- remaining arg through an indirect call (the same load-code_ptr / call-(closure,
-- arg) shape as emitIndirect).  Without this the trailing args are silently dropped
-- into @sym (which ignores them) and the returned closure is never applied —
-- garbage result / crash.
emitOverApp : Emit -> String -> List String -> Int -> LTy -> (String, LTy)
emitOverApp e sym argOps arity resTy =
  let satArgs = takeS arity argOps
  let extra = dropS arity argOps
  let (r0, _) = emitImplCall e sym satArgs resTy
  (emitApplyAny e r0 extra, LTInt)

-- ARITY-AWARE application of an OPAQUE closure word `cw` to `argOps` (count N): the
-- compile-time arity is unknown (a closure param, a container element, an over-app
-- residual), so the supplied count may not equal the closure's runtime arity.  Read
-- the arity from the cell header (field 0); if it equals N, inline the direct call
-- (the historical fast path); otherwise route through the runtime @mdk_apply, which
-- builds a PAP for a partial application, flattens a PAP, and splits an
-- over-application.  A PAP carries a -1 header so it never matches N (>=1) and always
-- takes the runtime path.  Uses an alloca result slot (like emitIf) so no phi
-- predecessor-label bookkeeping is needed.
emitApplyAny : Emit -> String -> List String -> String
emitApplyAny e cw [] = cw
emitApplyAny e cw argOps =
  let n = lengthS argOps
  let hdr = loadHeader e cw
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp eq i64 \{hdr}, \{intToString n}"
  let m = intToString (freshLocal e)
  let fastL = "apfast" ++ m
  let slowL = "apslow" ++ m
  let endL = "apend" ++ m
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let _ = emit e "  br i1 \{cmp}, label %\{fastL}, label %\{slowL}"
  let _ = emit e (fastL ++ ":")
  let rf = emitIndirectCallWords e cw argOps
  let _ = emit e "  store i64 \{rf}, ptr \{slot}"
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (slowL ++ ":")
  let rs = emitApplyRuntime e cw argOps
  let _ = emit e "  store i64 \{rs}, ptr \{slot}"
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{slot}"
  r

-- the runtime-generic path: materialize `argOps` into an [N x i64] alloca and call
-- @mdk_apply(cw, N, ptr).  Handles partial / over application + PAP flatten.
emitApplyRuntime : Emit -> String -> List String -> String
emitApplyRuntime e cw argOps =
  let n = lengthS argOps
  let arr = freshReg e
  let _ = emit e "  \{arr} = alloca i64, i64 \{intToString n}"
  let _ = storeArgv e arr argOps 0
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @__mdk_apply(i64 \{cw}, i64 \{intToString n}, ptr \{arr})"
  r

-- store each arg word into the argv alloca at index `i` (getelementptr i64 stride).
storeArgv : Emit -> String -> List String -> Int -> Unit
storeArgv _ _ [] _ = ()
storeArgv e arr (a::rest) i =
  let p = freshReg e
  let _ = emit e "  \{p} = getelementptr i64, ptr \{arr}, i64 \{intToString i}"
  let _ = emit e "  store i64 \{a}, ptr \{p}"
  storeArgv e arr rest (i + 1)

-- load the header word (field 0, offset 0 — the closure arity) of a boxed cell.
loadHeader : Emit -> String -> String
loadHeader e ptrWord =
  let p = freshReg e
  let _ = emit e "  \{p} = inttoptr i64 \{ptrWord} to ptr"
  let f = freshReg e
  let _ = emit e "  \{f} = load i64, ptr \{p}"
  f

-- build a partial-application closure over `@fname` with `argOps` already-supplied
-- arg words captured.  Emits a forwarder `@mdk_pap_..(%clos, %arg0..%arg(rem-1))`
-- that loads the captured words from the closure cell (fields 1..k, code_ptr is
-- field 0) and tail-calls `@fname(captured.., remaining..)`; allocates the closure
-- capturing `argOps`.  The residual is a closure VALUE (LTClosure) consumed at an
-- indirect call site — the same cell shape emitClosureAlloc / emitIndirect use.
emitPapClosure : Emit -> String -> List String -> Int -> (String, LTy)
emitPapClosure e fname argOps arity =
  let supplied = lengthS argOps
  let remaining = arity - supplied
  let papName = "mdk_pap_\{fname}_\{intToString (freshId e)}"
  let _ = emitPapDefine e papName fname supplied remaining
  emitClosureAlloc e papName remaining argOps

-- emit the PAP forwarder define into the side buffer (same swap discipline as
-- emitEtaDefine).  `supplied` captured words are loaded from %clos fields 1..k;
-- `remaining` fresh %argK params follow; the body calls @fname with the captured
-- words first, then the fresh params, in original order, and returns the result.
emitPapDefine : Emit -> String -> String -> Int -> Int -> Unit
emitPapDefine e papName fname supplied remaining =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{papName}(\{etaParamDecls remaining}) {"
  let _ = emit e "entry:"
  let capOps = loadPapCaptures e supplied 0
  let allArgs = capOps ++ argNames remaining 0
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @\{fname}(\{argDecls allArgs})"
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- load the `k` captured argument words from %clos fields 1..k (code_ptr is 0).
loadPapCaptures : Emit -> Int -> Int -> List String
loadPapCaptures e k i
  | i >= k = []
  | otherwise = loadField e "%clos" (i + 1) :: loadPapCaptures e k (i + 1)

-- UNDER-APPLICATION of an INDIRECT closure VALUE `cw` of arity `arity`, given
-- `argOps` supplied (1..arity-1).  Unlike emitPapClosure (which closes over a known
-- @fname symbol), here the callee is a runtime closure word, so the cell captures
-- BOTH the inner closure word and the supplied args: field 1 = inner closure, fields
-- 2.. = supplied args.  The forwarder loads them and does an INDIRECT call of the
-- inner closure with (supplied.. ++ remaining..) — now saturated.  Recorded with its
-- residual arity so a further over-application of the PAP also splits correctly.
emitPapClosureIndirect : Emit -> String -> List String -> Int -> (String, LTy)
emitPapClosureIndirect e cw argOps arity =
  let supplied = lengthS argOps
  let remaining = arity - supplied
  let papName = "mdk_pap_ind_" ++ intToString (freshId e)
  let _ = emitPapDefineIndirect e papName supplied remaining
  emitClosureAllocA e papName remaining (cw::argOps)

-- emit the indirect-PAP forwarder define into the side buffer.  field 1 = the
-- captured inner closure word; fields 2.. = `supplied` captured arg words; then
-- `remaining` fresh %argK params.  Body: load the inner closure's code_ptr (its
-- field 0) and `call` it with (innerClosure, supplied.., remaining..).
emitPapDefineIndirect : Emit -> String -> Int -> Int -> Unit
emitPapDefineIndirect e papName supplied remaining =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{papName}(\{etaParamDecls remaining}) {"
  let _ = emit e "entry:"
  let innerCw = loadField e "%clos" 1
  let capOps = loadPapCaptures e (supplied + 1) 1
  let allArgs = capOps ++ argNames remaining 0
  let cp = loadField e innerCw 0
  let fp = freshReg e
  let _ = emit e "  \{fp} = inttoptr i64 \{cp} to ptr"
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 \{fp}(\{argDecls (innerCw::allArgs)})"
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- the interface name a resolved impl entry belongs to (for the returns-self
-- lookup); "" for a default entry (it carries no tag/iface — never RKey-reached).
implEntryIface : CImplEntry -> String
implEntryIface (CImplEntry _ _ (CImplTagged _ _ iface _ _ _)) = iface
implEntryIface (CImplEntry _ _ (CImplDefault _ _)) = ""

-- a runtime method dispatch (RDict/RDictFwd): the enclosing function's dict
-- PARAMETER `d` (a BOXED dict-witness pointer, GAP 1 Option A) selects the impl at
-- run time.  Load the head tag from the cell's field 0, then emit an if-chain over
-- the method's tagged impls — compare the head tag to each impl's hashName tag, on
-- a match load the matched impl's nested per-instance dicts from the cell's fields
-- 1..n, PREPEND them to argOps (the impl fn's leading element-dict params), call
-- that impl's lifted fn into a result slot and branch to the end; an exhausted
-- chain is `unreachable`.
emitMethodDispatch : Emit -> List (String, (String, LTy)) -> String -> String -> List Route -> List String -> (String, LTy)
emitMethodDispatch e env name d methRoutes argOps = match soleImplDirectSite e name
  Some ent =>
    -- WS-1b: the method has exactly ONE impl with no `requires` element dicts, so a
    -- well-typed call always reaches that impl regardless of the runtime dict (mirrors
    -- eval's `narrowMethod (VMulti vs) ""` → sole-impl pick, and the arg-position
    -- single-impl-group DIRECT-call optimization).  Emitting a direct call here avoids
    -- LOADING the dict head tag — which, under an AMBIGUOUS return-position superclass
    -- constraint (`build : Sub a => Int -> a; build n = mk n`, where `mk`'s `Sup` dict
    -- stays ungrounded → the caller passes a NULL dict), would dereference null → the
    -- run≠build SIGTRAP.  Concrete-grounded callers (a real dict) are unaffected: the
    -- direct call is the same impl the tag-dispatch chain would have selected.
    let symTag = implFnSymOf (implEntriesOf e) name ent
    emitImplCall e (implFnName symTag name) argOps LTInt
  None => emitMethodDispatchChain e env name d methRoutes argOps

-- WS-1b: Some impl iff [name] has exactly one tagged impl AND that impl takes no
-- leading `requires` element-dict params (reqCount 0) — the case where a direct call
-- needs nothing from the runtime dict.  A multi-impl method, or a sole impl WITH
-- requires (whose element dicts live in the dict cell), still goes through the
-- tag-switching chain (which reads the dict).
soleImplDirect : Emit -> String -> Option CImplEntry
soleImplDirect e name = match implsOf e name
  [ent] => if implReqCount e name ent <= 0 then Some ent else None
  _ => None

-- The SITE-level form of the same test.  In prelude-object mode a dict-routed
-- site must NOT bake an impl decision into its enclosing define, because that
-- define may be a PRELUDE body destined for the shared `prelude.o` — and the sole
-- impl of a method in the prelude ALONE is not the sole impl in a program that
-- adds one (`impl Bimappable MyPair`).  Baking it there would be a silent
-- miscompile: `prelude.o` would direct-call the wrong impl forever.
--
-- So under `MEDAKA_PRELUDE_OBJ` every site routes through the shared dispatcher,
-- and the sole-impl shortcut moves INSIDE the dispatcher body (emitDispatcherDefine),
-- which is re-emitted per program from the WHOLE-program impl table.  The
-- null-dict property WS-1b exists for is preserved exactly: that body still makes
-- a direct call and still never loads `%dict` (see emitDispatcherDefine).
--
-- Mode 0 (every ordinary `medaka build`) is unchanged, so the default path's IR
-- stays byte-for-byte what it was.
soleImplDirectSite : Emit -> String -> Option CImplEntry
soleImplDirectSite e name =
  if emitHalfRef.value == emitHalfWhole then
    soleImplDirect e name
  else
    None

-- ── issue #118 step 3: the shared prelude object (MEDAKA_PRELUDE_OBJ) ────────
-- 88% of a small program's emitted IR is the PRELUDE (270 of 281 defines, 9,935
-- of 11,841 lines on `test/wasm/fixtures/adt_enum_nullary.mdk` — a NINE-line
-- program), and `clang -O2` re-optimises all of it on every single build.  The fix
-- mirrors MEDAKA_RT_OBJ one level up: compile the prelude ONCE to `prelude.o`, and
-- per program emit only the program's own code plus `declare`s for what it uses.
--
-- This was IMPOSSIBLE until the dispatch chains were outlined (step 2, above): a
-- program's own `impl` decls used to be INLINED into prelude function bodies, so no
-- one object could serve two programs.  With the chains outlined into shared
-- `@mdk_disp_*` dispatchers, prelude bodies are program-independent — verified by
-- emitting two programs differing only by an `impl Eq Color` and comparing all 249
-- shared prelude defines: ZERO structural differences (only the module-global
-- gensym counter shifts the `@mdk_lamN`/`@mdk_etac_*_N` names).
--
-- THREE MODES, selected by MEDAKA_EMIT_HALF (read by the emit driver):
--
--   0 WHOLE   (unset — every ordinary `medaka build`).  Untouched.  Every branch
--             this section adds is keyed on `emitHalfRef.value != 0`, so the
--             default path's IR is byte-for-byte what it was.
--
--   1 PRELUDE (`medaka build --emit-prelude-obj <path>`).  Emit core.mdk ALONE, as
--             a library: no `@mdk_program_main`, `@mdk_g_*` globals declared
--             `external` (the program half defines and initialises them), and the
--             two per-program symbol families — `@mdk_disp_*` and
--             `@mdk_default_*` — DECLARED, not defined.
--
--   2 PROGRAM (a build with MEDAKA_PRELUDE_OBJ set).  Emit the whole program, but
--             replace every PRELUDE define's BODY with a `declare` (emitAsDeclares).
--             The prelude's bodies are still WALKED — that is what registers the
--             dispatchers and defaults `prelude.o` declares — their text is just
--             dropped.
--
-- ⚠️ DCE MUST BE OFF in modes 1 and 2 (the emit driver does this).  Source DCE is
-- per-program, so an on-DCE prelude.o would ship only what the STUB reached; and an
-- on-DCE program half would walk fewer prelude bodies than prelude.o was built from
-- and so fail to define a dispatcher it declares.  The LINKER's `--gc-sections`
-- (already in the link line, issue #120) recovers the size, from the real
-- relocation graph rather than source reachability.
emitHalfWhole : Int
emitHalfWhole = 0

emitHalfPrelude : Int
emitHalfPrelude = 1

emitHalfProgram : Int
emitHalfProgram = 2

emitHalfRef : Ref Int
emitHalfRef = Ref emitHalfWhole

export installEmitHalf : Int -> Unit
installEmitHalf n = setRef emitHalfRef n

-- The gensym-id base for the PROGRAM half.  `freshId` (the module-global counter)
-- names every LIFTED define — `@mdk_lamN`, `@mdk_eta*_N`, `@mdk_pap_*_N` — and
-- those have external linkage, so if the two halves drew from the same range they
-- would collide on a symbol name (loudly, at link).  The halves are emitted by two
-- INDEPENDENT emitter runs, so give them disjoint ranges: the prelude half counts
-- up from 0, the program half from this base.  `preludeIdSpaceGuard` turns the
-- "0 .. base is enough for the prelude" assumption into a build-time check rather
-- than a hope — emitting core.mdk whole draws ~500 ids, four orders of magnitude
-- below the base.
programHalfIdBase : Int
programHalfIdBase = 1000000

preludeIdSpaceGuard : Emit -> Unit
preludeIdSpaceGuard e =
  if emitHalfRef.value == emitHalfPrelude && e.counter.value >= programHalfIdBase then
    panic "prelude-object emit exhausted its gensym id space (\{intToString e.counter.value} >= \{intToString programHalfIdBase}) — raise programHalfIdBase in llvm_emit.mdk"
  else
    ()

-- The PRELUDE-owned symbols, installed by the emit driver in PROGRAM-half mode
-- (mode 2 only — in mode 1 every decl in the program IS the prelude).  Derived by
-- lowering core.mdk's decls on their own, so the classification comes from where a
-- decl was DEFINED, not from guessing at its emitted name.
preludeBindsRef : Ref (List String)
preludeBindsRef = Ref []

preludeImplsRef : Ref (List (String, String))
preludeImplsRef = Ref []

export installPreludeSyms : List String -> List (String, String) -> Unit
installPreludeSyms binds impls =
  let _ = setRef preludeBindsRef binds
  setRef preludeImplsRef impls

-- Is this top-level bind / impl group one whose define lives in `prelude.o`?
-- Only ever True in mode 2.
hiddenBind : String -> Bool
hiddenBind name = emitHalfRef.value == emitHalfProgram
  && contains name preludeBindsRef.value

hiddenImplGroup : ImplGroup -> Bool
hiddenImplGroup (ImplGroup method tag _ _ _ _) = emitHalfRef.value == emitHalfProgram
  && hasImplKey method tag preludeImplsRef.value

hasImplKey : String -> String -> List (String, String) -> Bool
hasImplKey _ _ [] = False
hasImplKey m t ((m2, t2)::rest) = m == m2 && t == t2 || hasImplKey m t rest

-- Run `act` (an ordinary emitFn/emitGroup), then throw its BODY TEXT away and keep
-- only a `declare` per define it produced.
--
-- Running it and discarding the output is the whole point, not waste: emitting a
-- prelude body is what REGISTERS the `@mdk_disp_*` dispatchers and
-- `@mdk_default_*` defines that `prelude.o` only declares, so the program half
-- defines exactly the set the prelude half demanded.  The lifted lambdas/strings/
-- dict-cells it also produces land (dead) in `e.lams` and are dropped by
-- `--gc-sections` — they cost IR lines, not correctness, and their names cannot
-- collide with prelude.o's (disjoint gensym range, see programHalfIdBase).
--
-- Deriving the `declare` from the `define` line the emitter ACTUALLY produced —
-- rather than re-deriving the signature — is what makes the two halves' ABI
-- impossible to drift apart.  It also handles, for free, the cases where a bind
-- emits no define (a TMC dispatch-group MEMBER) or more than one (a float `__fw`
-- worker): whatever was emitted is exactly what gets declared.
emitAsDeclares : Emit -> (Unit -> Unit) -> Unit
emitAsDeclares e act =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let _ = act ()
  let produced = reverseL (bufRef e).value
  let _ = setRef (bufRef e) saved
  emitDeclaresFor e produced

emitDeclaresFor : Emit -> List String -> Unit
emitDeclaresFor _ [] = ()
emitDeclaresFor e (l::rest) =
  let _ = match declareOfDefine l
    Some d => emit e d
    None => ()
  emitDeclaresFor e rest

-- `define i64 @f(i64 %a, i64 %b) {`  →  `declare i64 @f(i64 %a, i64 %b)`.
-- Every define the emitter writes has exactly this shape (verified: all 281 define
-- lines of the reference module end in `) {`); a line that does not is not a define
-- header and yields None.
declareOfDefine : String -> Option String
declareOfDefine l =
  let n = stringLength l
  if n > 9 && stringSlice 0 7 l == "define " && stringSlice (n - 2) n l == " {" then
    Some ("declare " ++ stringSlice 7 (n - 2) l)
  else
    None

-- ── issue #118: the dispatch chain is OUTLINED, one per method ──────────────
-- A runtime-dict dispatch site used to INLINE the whole impl chain — one `icmp` +
-- branch + call arm per impl of the method, at EVERY site.  That made the emitted IR
-- grow as `Σ over sites of (#impls of that site's method)`, and it is the dominant
-- term in a small program's IR: on `test/wasm/fixtures/adt_enum_nullary.mdk` (9 lines
-- of source) there were 107 dispatch sites but only NINE distinct chains between
-- them — 2,123 emitted arms, ~80% of the module's 32,895 lines, to express 9 chains.
--
-- So the chain now lives ONCE, in a shared `@mdk_disp_<method>_<nMeth>_<nArgs>`
-- define, and the site is a single `call`.  The chain BODY is unchanged — the same
-- head-tag `icmp` arms in the same order, the same default-synthesis arms, the same
-- `unreachable` tail — so every dispatch decision is byte-for-byte the one the inline
-- chain made; only its PLACEMENT moved.
--
-- The dispatcher's parameters are exactly what the inline chain read out of the
-- enclosing define, in that order:
--   %dict   — the dict-witness word (the enclosing fn's dict PARAM; `loadTag`/
--             `loadField` read the cell's head tag and per-instance `requires`).
--   %mwK    — the METHOD-LEVEL constraint dicts.  These are AMBIENT at the CALL site
--             (a `traverse : Thenable m =>` whose `m` is not the dispatch receiver),
--             so they are still resolved from `env` HERE and passed IN — they are not,
--             and never were, in the dict cell.
--   %argK   — the value args.  Always exactly `methodArityOf name`: under-application
--             is diverted to a PAP by `dictRoutedUnderApplied` before we get here, and
--             over-application cannot arise at an impl head (see emitImplCallSat).
--
-- Both counts are baked into the dispatcher's NAME, so a site that somehow disagreed
-- on either would get its own dispatcher rather than a silently mis-arity'd call.
emitMethodDispatchChain : Emit -> List (String, (String, LTy)) -> String -> String -> List Route -> List String -> (String, LTy)
emitMethodDispatchChain e env name d methRoutes argOps =
  let dictPtr = dictOperand env d
  let methWords = dictWordsOf e env methRoutes
  let nmw = lengthS methWords
  let nargs = lengthS argOps
  let fname = dispFnName name nmw nargs
  let _ = ensureDispatcherEmitted e fname name nmw nargs
  emitImplCall e fname (dictPtr :: methWords ++ argOps) LTInt

-- the shared dispatcher's symbol.  Method names are plain identifiers here (an
-- operator is a `CBinPrim`, never a method name — same assumption `implFnName`
-- already makes), so the concatenation is a legal LLVM symbol.
dispFnName : String -> Int -> Int -> String
dispFnName name nmw nargs =
  "mdk_disp_\{name}_\{intToString nmw}_\{intToString nargs}"

-- the dispatchers emitted so far, by symbol.  Module-level Ref (mirroring
-- `dictConstCacheRef`), reset per program by emitProgram/emitProgramGaps.
dispCacheRef : Ref (List String)
dispCacheRef = Ref []

ensureDispatcherEmitted : Emit -> String -> String -> Int -> Int -> Unit
ensureDispatcherEmitted e fname name nmw nargs =
  if contains fname dispCacheRef.value then
    ()
  else
    -- REGISTER BEFORE EMITTING.  A default-synthesis arm lifts `@mdk_default_<m>_<tag>`
    -- on demand (ensureDefaultEmitted), and that body can itself reach a dict-routed
    -- site for the SAME method — which would re-enter here and recurse forever if the
    -- symbol were only recorded after the body was emitted.
    let _ = setRef dispCacheRef (fname :: dispCacheRef.value)
    -- PRELUDE HALF: the dispatcher body enumerates every impl of the method in THIS
    -- program, so it is inherently per-program and must NOT be baked into the shared
    -- `prelude.o` — declare it and let the program half define it.  The program half
    -- re-walks the prelude's own bodies (emitAsDeclares), so it reaches this exact
    -- (name, nmw, nargs) site and DEFINES every dispatcher the prelude declares: the
    -- demand set is derived, never encoded, and a mismatch is a LOUD undefined symbol.
    if emitHalfRef.value == emitHalfPrelude then
      emitGlobal e "declare i64 @\{fname}(\{dispParamDecls nmw nargs})"
    else
      emitDispatcherDefine e fname name nmw nargs

-- emit the shared dispatcher define.  Same side-buffer swap every other lifted define
-- uses (emitMethodValDefine/emitDictValDefine): redirect `buf`, emit, splice into
-- `lams`, restore.  `beginDefine` resets the per-define `%tN`/label counter, so the
-- dispatcher's text depends only on the method — not on where the first site of it
-- happened to appear (issue #118 step 1).
emitDispatcherDefine : Emit -> String -> String -> Int -> Int -> Unit
emitDispatcherDefine e fname name nmw nargs =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{fname}(\{dispParamDecls nmw nargs}) {"
  let _ = emit e "entry:"
  let (r, _) = emitDispatcherBody e name nmw nargs
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- The dispatcher's body.  Ordinarily (mode 0) this is only ever reached when the
-- method has ≥2 impls — soleImplDirect already diverted the sole-impl case to a
-- direct call at the SITE — so the `Some` arm below is dead and the emitted IR is
-- byte-identical to what it was.
--
-- Under MEDAKA_PRELUDE_OBJ the site no longer takes that shortcut
-- (soleImplDirectSite), so the shortcut lives HERE instead, where it is computed
-- from the whole-program impl table each build.  It reproduces WS-1b exactly: a
-- direct call to the sole impl that never touches `%dict` — which is what keeps an
-- ambiguous return-position superclass constraint's NULL dict from being
-- dereferenced.  `%mw`/`%dict` are simply left unread, as at the direct call site.
emitDispatcherBody : Emit -> String -> Int -> Int -> (String, LTy)
emitDispatcherBody e name nmw nargs = match soleImplDirect e name
  Some ent =>
    let symTag = implFnSymOf (implEntriesOf e) name ent
    emitImplCall e (implFnName symTag name) (dispWordNames "%arg" nargs 0) LTInt
  None => emitDispatchBody e name "%dict" (dispWordNames "%mw" nmw 0) (dispWordNames "%arg" nargs 0)

dispParamDecls : Int -> Int -> String
dispParamDecls nmw nargs =
  argDecls
    ("%dict" :: dispWordNames "%mw" nmw 0 ++ dispWordNames "%arg" nargs 0)

dispWordNames : String -> Int -> Int -> List String
dispWordNames pre n i
  | i >= n = []
  | otherwise = pre ++ intToString i :: dispWordNames pre n (i + 1)

-- the dispatch chain itself, verbatim from the old inline site — now the BODY of the
-- shared dispatcher.  [dictPtr] is the dict-witness word, [methWords] the ambient
-- method-level constraint dicts (`emitDispatchChain` prepends them ahead of the
-- cell-sourced per-instance `requires`, matching the lifted fn's leading dict-param
-- order: dict_pass binds methRoutes ++ implRoutes), [argOps] the saturated value args.
emitDispatchBody : Emit -> String -> String -> List String -> List String -> (String, LTy)
emitDispatchBody e name dictPtr methWords argOps =
  let headTag = loadTag e dictPtr
  let impls = implsOf e name
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "dispend" ++ intToString (freshLocal e)
  let _ = match impls
    [] => match defaultFor e name
      Some entry => emitDefaultDispatchChain e dictPtr headTag (ifaceTags e (methodIfaceOf name)) name entry argOps slot endL
      None => emitDispatchChain e dictPtr headTag impls name methWords argOps slot endL
    _ => match defaultFor e name
      -- MIXED default+impls: append default-synthesis arms for interface tags with no
      -- explicit impl (derived-Ord ADTs inheriting `max`/`min` from the default).
      Some entry =>
        let covered = implEntryTags impls
        let uncovered = tagsMinus (ifaceTags e (methodIfaceOf name)) covered
        match uncovered
          [] => emitDispatchChain e dictPtr headTag impls name methWords argOps slot endL
          _ => emitDispatchChainDefaulted e dictPtr headTag impls uncovered name entry methWords argOps slot endL
      None => emitDispatchChain e dictPtr headTag impls name methWords argOps slot endL
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{slot}"
  (r, LTInt)
-- GAP 2 phase-b: a method with NO tagged impl but a CImplDefault (a pure
-- interface default like `max`/`min` over `Ord`) reaches an RDict site
-- generically (`maximum [..]` keeps `Ord a`).  An empty impl chain emits only
-- `unreachable`, so the dispatched body blanks.  Synthesize a per-tag default
-- (the E19 machinery) for every tag the interface's dict can carry: the chain
-- switches the dict's head tag and calls `@mdk_default_<method>_<tag>`, whose
-- inner same-interface `compare` is restamped to that concrete `RKey tag` (so
-- it stays a direct call, never the unsound arg-tag site of emitDefaultArgTag).

-- GAP 2 phase-b: the distinct type-head tags an `iface`'s dict can carry — every
-- tagged impl entry whose interface equals `iface`, deduped.  These are exactly
-- the runtime element tags a generic `iface a` dict-word may hold, so the default
-- dispatch chain enumerates one default-synthesis arm per tag.
ifaceTags : Emit -> String -> List String
ifaceTags e iface = dedupS (ifaceTagsGo iface (implEntriesOf e))

ifaceTagsGo : String -> List CImplEntry -> List String
ifaceTagsGo _ [] = []
ifaceTagsGo iface ((CImplEntry _ _ (CImplTagged tag _ ifc _ _ _))::rest)
  | ifc == iface = tag :: ifaceTagsGo iface rest
  | otherwise = ifaceTagsGo iface rest
ifaceTagsGo iface (_::rest) = ifaceTagsGo iface rest

-- GAP 2 phase-b: emit the default-synthesis dispatch chain.  For each `tag` the
-- interface's dict may carry, test the dict head tag and on a match synthesize +
-- call `@mdk_default_<method>_<tag>` (ensureDefaultEmitted restamps its inner
-- same-interface calls to `RKey tag`, keeping `compare` a concrete direct call —
-- the unsoundness trap is avoided precisely because the tag is concrete here).
-- An exhausted chain is `unreachable` (the dict names a real interface impl).
emitDefaultDispatchChain : Emit -> String -> String -> List String -> String -> CImplEntry -> List String -> String -> String -> Unit
emitDefaultDispatchChain e _ _ [] _ _ _ _ _ = emit e "  unreachable"
emitDefaultDispatchChain e dictPtr headTag (tag::rest) name entry argOps slot endL =
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp eq i64 \{headTag}, \{intToString (hashName tag)}"
  let n = intToString (freshLocal e)
  let yes = "ddispyes" ++ n
  let next = "ddispnext" ++ n
  let _ = emit e "  br i1 \{cmp}, label %\{yes}, label %\{next}"
  let _ = emit e (yes ++ ":")
  let fname = defaultFnName tag name
  let _ = ensureDefaultEmitted e fname tag name entry
  let reqCount = innerDefaultReqCount e name tag
  let reqDicts = loadReqDicts e dictPtr reqCount 0
  let (rv, _) = emitImplCall e fname (reqDicts ++ argOps) LTInt
  let _ = emit e "  store i64 \{rv}, ptr \{slot}"
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (next ++ ":")
  emitDefaultDispatchChain e dictPtr headTag rest name entry argOps slot endL
-- Native Gap C (parametric default-method dict-synthesis, 2026-06-12): when this
-- default reduces to a PARAMETRIC inner `compare` (tag = tuple/`List`/`Box`), the
-- lifted `@mdk_default_<method>_<tag>` now takes leading element-dict params (see
-- emitDefaultDefine).  They live in THIS runtime dict cell (the `Ord <tag>` witness),
-- fields 0..nReq-1, exactly like emitDispatchChain loads an impl's own requires —
-- load + PREPEND them.  Concrete tag ⇒ nReq=0 ⇒ unchanged (`maximum [Int]`).

-- the count of leading element-dict params a matched impl's lifted fn expects: its
-- full clause arity (number of patterns) minus the method's interface arity.  This
-- equals the number of per-instance `requires` dicts stored in the boxed dict cell
-- (fields 1..count), so the chain loads exactly that many and prepends them.
implReqCount : Emit -> String -> CImplEntry -> Int
implReqCount e name ent = listLen (implPats ent) - methodArityOf name

-- load `n` nested dict words from the boxed dict cell `dictPtr`.  The head tag is
-- the cell header (offset 0); the nested req dicts are fields 0..n-1 (loadField i ⇒
-- offset 8*(i+1)), stored by emitDictCell via storeFields at the same field indices.
loadReqDicts : Emit -> String -> Int -> Int -> List String
loadReqDicts e dictPtr n i
  | i >= n = []
  | otherwise = loadField e dictPtr i :: loadReqDicts e dictPtr n (i + 1)

-- emit ONE tagged-impl dispatch arm: test the dict head tag against this impl's route
-- key and, on a match, call the impl fn (prepending method-level + per-instance
-- `requires` dicts) and jump to `endL`; otherwise fall through to the `next` label the
-- caller continues after.
--
-- The matched impl's lifted fn expects `implReqCount` leading dict params, ordered
-- methRoutes ++ implRoutes.  The first `lengthS methWords` are METHOD-LEVEL
-- constraint dicts — already materialized from the caller's ambient args (env);
-- the remaining are this impl's per-instance `requires` dicts, loaded from the
-- runtime dispatch-dict cell's fields 0..k-1.  Sourcing the method-level ones from
-- the cell (the old behavior) was an OUT-OF-BOUNDS load whenever the dispatch dict
-- was a bare tag (no requires) → a garbage dict → SIGSEGV (e.g. `traverse` whose
-- `Thenable m =>` is over a tyvar that is not the `Traversable` receiver).
emitDispatchArm : Emit -> String -> String -> CImplEntry -> String -> List String -> List String -> String -> String -> Unit
emitDispatchArm e dictPtr headTag ent name methWords argOps slot endL =
  let routeKey = implEntryRouteKey (implEntriesOf e) ent
  let symTag = implFnSymOf (implEntriesOf e) name ent
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp eq i64 \{headTag}, \{intToString (hashName routeKey)}"
  let n = intToString (freshLocal e)
  let yes = "dispyes" ++ n
  let next = "dispnext" ++ n
  let _ = emit e "  br i1 \{cmp}, label %\{yes}, label %\{next}"
  let _ = emit e (yes ++ ":")
  let cellCount = implReqCount e name ent - lengthS methWords
  let cellDicts = loadReqDicts e dictPtr cellCount 0
  let (rv, _) = emitImplCall e (implFnName symTag name) (methWords ++ cellDicts ++ argOps) LTInt
  let _ = emit e "  store i64 \{rv}, ptr \{slot}"
  let _ = emit e ("  br label %" ++ endL)
  emit e (next ++ ":")

emitDispatchChain : Emit -> String -> String -> List CImplEntry -> String -> List String -> List String -> String -> String -> Unit
emitDispatchChain e _ _ [] _ _ _ _ _ = emit e "  unreachable"
emitDispatchChain e dictPtr headTag (ent::rest) name methWords argOps slot endL =
  let _ = emitDispatchArm e dictPtr headTag ent name methWords argOps slot endL
  emitDispatchChain e dictPtr headTag rest name methWords argOps slot endL

-- GAP 2 phase-b (MIXED case): a method that HAS tagged impls but whose interface ALSO
-- owns a default AND can carry element tags with no explicit impl — the derived-Ord
-- ADT case.  `max`/`min` have real impls at primitive types (Int/Float/…), yet a
-- `deriving (Ord)` ADT (e.g. `Color`) materializes only `compare` and inherits
-- `max`/`min` from the interface DEFAULT.  A generic `Ord a` dict flowing through
-- `maximum`/`minimum`'s fold reaches this chain; the plain chain enumerates ONLY the
-- tagged impls, so the ADT tag matches no arm and falls to `unreachable`/nonexhaustive.
-- Emit the tagged-impl arms, then — instead of an immediate `unreachable` — append one
-- default-synthesis arm per `uncovered` iface tag (the same `@mdk_default_<method>_<tag>`
-- machinery as the pure-default path, its inner `compare` restamped to `RKey tag`).
emitDispatchChainDefaulted : Emit -> String -> String -> List CImplEntry -> List String -> String -> CImplEntry -> List String -> List String -> String -> String -> Unit
emitDispatchChainDefaulted e dictPtr headTag [] uncovered name entry _ argOps slot endL = emitDefaultDispatchChain e dictPtr headTag uncovered name entry argOps slot endL
emitDispatchChainDefaulted e dictPtr headTag (ent::rest) uncovered name entry methWords argOps slot endL =
  let _ = emitDispatchArm e dictPtr headTag ent name methWords argOps slot endL
  emitDispatchChainDefaulted
    e
    dictPtr
    headTag
    rest
    uncovered
    name
    entry
    methWords
    argOps
    slot
    endL

-- the type tags a method's tagged impls already cover (the `t` field of each entry),
-- for diffing against the interface's full tag set to find the derived-default tags.
implEntryTags : List CImplEntry -> List String
implEntryTags [] = []
implEntryTags (ent::rest) = implEntryTag ent :: implEntryTags rest

-- interface tags NOT covered by any tagged impl — the derived-default tags that need a
-- `@mdk_default_<method>_<tag>` synthesis arm appended to the tagged-impl dispatch chain.
tagsMinus : List String -> List String -> List String
tagsMinus [] _ = []
tagsMinus (t::rest) covered
  | contains t covered = tagsMinus rest covered
  | otherwise = t :: tagsMinus rest covered
-- GAP 1: prepend the matched impl's nested element-dicts (cell fields 1..reqCount)
-- ahead of the real args, matching its leading dict-param order (dict_pass's
-- methRoutes ++ implRoutes; here the impl's own requires, stored in cell order).

-- ── arg-position (arg-tag) dispatch at a call site (slice 7) ─────────────────
-- A bare CVar naming an impl method, applied to args.  The impl is chosen by the
-- discriminating argument's runtime constructor TYPE (mirrors eval's
-- filterByTag → runtimeTypeTag).  Two shapes:
--   • ONE impl group (the method has impls at a single type) — no runtime test is
--     needed: a well-typed call always reaches that impl, so emit a DIRECT call
--     (covers single-impl + the multi-clause-body fixture; the multi-clause
--     fall-through lives INSIDE the impl fn's decision tree, note (n)/(o)).
--   • SEVERAL impl groups (impls at distinct types) — load the discriminating
--     argument's cell tag and emit an if-chain: for each group, test whether the
--     loaded ctor tag is one the group's TYPE owns (OR over its constructors'
--     hashName, via ctorsOfType), and on a match call that group's impl fn.  An
--     exhausted chain is `unreachable` (the typechecker proved a real impl).
--     The discriminating arg may be an IMMEDIATE nullary ctor, so the tag is read
--     via `loadDiscriminant` (low-bit branch), not a bare `loadTag` (note (p)).
emitMethodArgDispatch : Emit -> String -> List String -> (String, LTy)
emitMethodArgDispatch e method argOps =
  let groups = implGroupsForMethod e method
  match groups
    [] => emitDefaultArgTag e method argOps
    [g] => emitImplCallSat e (implFnName (groupSymTag g) method) argOps (methodArityOf method) LTInt
    _ => emitArgTagDispatch e method groups argOps

-- E19: an arg-tag site for a method with NO tagged impl groups — an interface
-- DEFAULT reached on the RNone fallback (`max`/`min`, whose `maximum`/`minimum`
-- callers stay generic `Ord a`).  EMITTING the default body here is UNSOUND for
-- the prelude's Ord defaults: `max`/`min` reduce to `compare m x`, and `compare`'s
-- only impls are at PRIMITIVE types (Int/Float/String/Char/Bool/Ordering) which
-- carry NO runtime constructor cell tag — so the inner `compare` arg-tag dispatch
-- hits `emitTagMatch`'s "owns no constructors" gap (one event per primitive Ord
-- impl × caller).  Emitting the default would therefore REPLACE 1 honest gap with
-- ~6 deeper ones.  A correct max/min needs RKey-concrete `compare` (a monomorphic
-- caller) or primitive-typed arg-tag dispatch — both out of this slice's scope.
-- So a no-impl-groups default is left as the original honest gap; only a default
-- whose inner same-interface calls reach a CONCRETE tag is emittable (the RKey
-- path, emitDefaultRKey — `filter`@List).
emitDefaultArgTag : Emit -> String -> List String -> (String, LTy)
emitDefaultArgTag e method argOps =
  gapE
    ("arg-tag dispatch for method '" ++ method ++ "' has no impl groups (slice 7: unresolved RNone fallback)")

emitArgTagDispatch : Emit -> String -> List ImplGroup -> List String -> (String, LTy)
emitArgTagDispatch e method groups argOps
  | headPos (groupPositionsOf (headGroup groups)) >= lengthS argOps = gapE ("arg-tag dispatch for method '" ++ method ++ "': discriminating arg position not supplied (slice 7: under-applied / unapplied method)")
  | otherwise = emitArgTagDispatchGo e method groups argOps (headPos (groupPositionsOf (headGroup groups)))

emitArgTagDispatchGo : Emit -> String -> List ImplGroup -> List String -> Int -> (String, LTy)
emitArgTagDispatchGo e method groups argOps discrimPos =
  let discrimWord = nthStr argOps discrimPos
  let tagReg = loadDiscriminant e discrimWord
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "argdispend" ++ intToString (freshLocal e)
  let _ = emitArgDispatchChain e method tagReg groups argOps slot endL
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{slot}"
  (r, LTInt)

emitArgDispatchChain : Emit -> String -> String -> List ImplGroup -> List String -> String -> String -> Unit
emitArgDispatchChain e _ _ [] _ _ _ = emit e "  unreachable"
emitArgDispatchChain e method tagReg (g::rest) argOps slot endL =
  let tag = groupTag g
  let cond = emitTagMatch e tagReg (ctorsOfType e tag)
  let n = intToString (freshLocal e)
  let yes = "argyes" ++ n
  let next = "argnext" ++ n
  let _ = emit e "  br i1 \{cond}, label %\{yes}, label %\{next}"
  let _ = emit e (yes ++ ":")
  let (rv, _) = emitImplCall e (implFnName (groupSymTag g) method) argOps LTInt
  let _ = emit e "  store i64 \{rv}, ptr \{slot}"
  let _ = emit e ("  br label %" ++ endL)
  let _ = emit e (next ++ ":")
  emitArgDispatchChain e method tagReg rest argOps slot endL

-- an i1 that is true when the loaded ctor tag equals ANY of a type's constructor
-- tags (OR-chain of icmp eq against each hashName).
emitTagMatch : Emit -> String -> List String -> String
emitTagMatch _ _ [] =
  gapStr
    "arg-tag dispatch on impl type that owns no constructors (slice 7: primitive receiver carries no cell tag)"
emitTagMatch e tagReg [c] =
  let r = freshReg e
  let _ = emit e "  \{r} = icmp eq i64 \{tagReg}, \{intToString (cellTag e c)}"
  r
emitTagMatch e tagReg (c::rest) =
  let r = freshReg e
  let _ = emit e "  \{r} = icmp eq i64 \{tagReg}, \{intToString (cellTag e c)}"
  let rrest = emitTagMatch e tagReg rest
  let o = freshReg e
  let _ = emit e "  \{o} = or i1 \{r}, \{rrest}"
  o

-- the impl groups of one method, in program order.
implGroupsForMethod : Emit -> String -> List ImplGroup
implGroupsForMethod e method =
  filterGroupsByMethod method (groupImpls (implEntriesOf e))

filterGroupsByMethod : String -> List ImplGroup -> List ImplGroup
filterGroupsByMethod _ [] = []
filterGroupsByMethod method (g::rest)
  | groupMethodOf g == method = g :: filterGroupsByMethod method rest
  | otherwise = filterGroupsByMethod method rest

groupTag : ImplGroup -> String
groupTag (ImplGroup _ tag _ _ _ _) = tag

groupSymTag : ImplGroup -> String
groupSymTag (ImplGroup _ _ symTag _ _ _) = symTag

groupMethodOf : ImplGroup -> String
groupMethodOf (ImplGroup m _ _ _ _ _) = m

groupPositionsOf : ImplGroup -> List Int
groupPositionsOf (ImplGroup _ _ _ p _ _) = p

headGroup : List ImplGroup -> ImplGroup
headGroup (g::_) = g
headGroup [] = panic "llvm spike: no impl group for arg-tag dispatch (slice 7)"

-- the discriminating arg position (first dispatch position; default 0 — for a
-- single-position method like `eq` the head suffices, both args share the type).
headPos : List Int -> Int
headPos (p::_) = p
headPos [] = 0

nthStr : List String -> Int -> String
nthStr (x::_) 0 = x
nthStr (_::rest) i = nthStr rest (i - 1)
nthStr [] _ =
  panic "llvm spike: discriminating arg index out of range (slice 7)"

-- a constrained-function occurrence (CDict): `name` is a `=>`-constrained function
-- that dict_pass gave leading dict PARAMETERS; the routes give the dict values for
-- this call site.  Lower to a direct call passing the dict words FOLLOWED by the
-- real argument words — the same order applyDicts prepends them at run time and
-- the order emitFn bound `name`'s leading dict params.
emitDictApp : Emit -> List (String, (String, LTy)) -> String -> List Route -> List String -> (String, LTy)
emitDictApp e env name routes argOps =
  if isKnownFn e name then
    let dictWords = dictWordsOf e env routes
    let allWords = dictWords ++ argOps
    -- E22: a constrained fn that RETURNS A CLOSURE is under-applied at the call site
    -- (`mkEq : Eq a => a -> (a -> Bool); mkEq y = (z => eq y z)` called `mkEq 1`).
    -- Its #12-eta-saturated define has `nDicts + sigValueArity` params, but the site
    -- supplies fewer value args (the rest go to the returned closure).  A direct call
    -- would under-supply the trailing param (garbage → a bad closure word indirectly
    -- called → SIGSEGV).  When the RECORDED define arity says we are short, build a
    -- residual PAP capturing the dict + supplied words.  Saturated sites (the only
    -- shape the compiler's own source produces) keep the byte-identical direct call
    -- below, so the self-compile fixpoint is unaffected.
    match defArityOf name
      Some n => if lengthS allWords < n then
          emitPapClosure e ("mdk_" ++ name) allWords n
        else emitDictAppDirect e name allWords
      None => emitDictAppDirect e name allWords
  else gapE ("CDict head '" ++ name ++ "' is not a known top-level function (slice 6)")

-- the plain direct constrained-fn call: dict words followed by the real arg words,
-- in the order dict_pass bound `name`'s leading dict params (the historical lowering).
emitDictAppDirect : Emit -> String -> List String -> (String, LTy)
emitDictAppDirect e name allWords =
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @mdk_\{name}(\{argDecls allWords})"
  (r, fnRetTy e name)

-- the dict witness words for a constrained-function call's routes (note (j)).
dictWordsOf : Emit -> List (String, (String, LTy)) -> List Route -> List String
dictWordsOf _ _ [] = []
dictWordsOf e env (r::rest) = dictWordOfRoute e env r :: dictWordsOf e env rest

-- one route -> its dict witness word (GAP 1, Option A — BOXED dict witness).
-- A dict witness is a POINTER to a heap cell `[ i64 head_tag | i64 reqdict_0 | … ]`
-- allocated via @mdk_alloc (the same boxed-cell shape emitCtorAlloc uses): field 0
-- is `hashName(impl-head-tag)`, fields 1..n are the RECURSIVELY-built witness words
-- for the impl's per-instance `requires` dicts, in `reqs` order (matching the
-- interpreter's structured `VDict(key, map dict_of_route reqs)` and the leading
-- dict-param order dict_pass binds — methRoutes then implRoutes, here the impl's
-- own requires).  This makes the rep UNIFORM: a one-level dict (`RKey k []`) is a
-- pointer to a 1-word cell `[ hashName k ]`; a two-level dict nests another cell
-- pointer in field 1.  Consumption (emitDispatchChain / the RKey direct-call path)
-- loads field 0 for the icmp and prepends fields 1..n as the matched impl's leading
-- element-dict args.  RDict/RDictFwd forward the enclosing dict parameter's word
-- (already a boxed-cell pointer); RNone is the 0 dict (no cell).
dictWordOfRoute : Emit -> List (String, (String, LTy)) -> Route -> String
dictWordOfRoute e env (RKey key reqs) =
  let reqWords = dictWordsOf e env reqs
  if allConstWords reqWords then
    emitConstDictCell e (hashName key) reqWords
  else
    emitDictCell e (hashName key) reqWords
dictWordOfRoute _ env (RDict d) = dictOperand env d
dictWordOfRoute _ env (RDictFwd d) = dictOperand env d
dictWordOfRoute _ _ RNone = "0"
-- S-1: RLocal's own dicts are the call's leading dict ARGS (emitted by emitMethod's
-- RLocal arm via emitDictApp), not a dict WITNESS for this route — so as a witness it
-- stays the no-op 0 dict, mirroring eval's `dictOfRoute (RLocal _ _) = VDict "" []`.
dictWordOfRoute _ _ (RLocal _ _) = "0"

-- allocate a boxed dict-witness cell `[ i64 headTag | i64 req_0 | … | i64 req_(n-1) ]`
-- via @mdk_alloc and return its pointer word (ptrtoint).  Mirrors emitCtorAlloc's
-- header+fields layout (header at offset 0, field i at 8*(i+1)) so loadField /
-- loadTag read it back without type info.  A one-word cell (no reqs) is the
-- uniform one-level dict.
emitDictCell : Emit -> Int -> List String -> String
emitDictCell e headTag reqWords =
  let n = lengthS reqWords
  let p = freshReg e
  let _ = emit e "  \{p} = call ptr @mdk_alloc(i64 \{intToString (8 * (n + 1))})"
  let _ = emit e "  store i64 \{intToString headTag}, ptr \{p}"
  let _ = storeFields e p reqWords 0
  let w = freshReg e
  let _ = emit e "  \{w} = ptrtoint ptr \{p} to i64"
  w

-- ── constant dict-witness hoisting (perf/dict-const) ────────────────────────
-- A dict witness whose head tag and every requirement word are compile-time
-- constants (a one-level `RKey k []` → `[hashName k]`, or a nested RKey whose reqs
-- are themselves constant) does NOT need a per-call `@mdk_alloc`: the cell is
-- immutable and identical at every invocation. Emit it ONCE as an `internal
-- constant` module global and pass `ptrtoint (ptr @g to i64)` — eliminating the
-- per-invocation allocation that dominated dispatch-heavy polymorphic loops (~4×
-- on a tight `Ord` loop; broad — every constant dict across stdlib/compiler/user
-- code). Deduped by initializer content so identical dicts share one global.
dictConstCacheRef : Ref (List (String, String))
dictConstCacheRef = Ref []

-- every dict word is a compile-time constant (not a runtime %register): a literal
-- tag, "0" (RNone), or a `ptrtoint`-of-global constant-expr (a nested const dict).
allConstWords : List String -> Bool
allConstWords [] = True
allConstWords (w::rest) = not (startsWith "%" w) && allConstWords rest

constDictReqInits : List String -> String
constDictReqInits [] = ""
constDictReqInits (w::rest) = ", i64 \{w}\{constDictReqInits rest}"

-- emit (or reuse) a module-global constant dict cell; return its pointer-as-i64
-- constant-expr. Layout byte-identical to emitDictCell's heap cell, so every
-- consumer (RKey dispatch loadField, nested-dict store, call arg) reads it the same.
emitConstDictCell : Emit -> Int -> List String -> String
emitConstDictCell e headTag reqWords =
  let n = lengthS reqWords
  let initBody = "[\{intToString (n + 1)} x i64] [i64 \{intToString headTag}\{constDictReqInits reqWords}]"
  match lookupAssoc initBody dictConstCacheRef.value
    Some gname => "ptrtoint (ptr @" ++ gname ++ " to i64)"
    None =>
      let gname = "mdk_dc_" ++ intToString (freshId e)
      let _ = emitGlobal e "@\{gname} = internal constant \{initBody}"
      let _ = setRef dictConstCacheRef ((initBody, gname)::dictConstCacheRef.value)
      "ptrtoint (ptr @" ++ gname ++ " to i64)"

-- the operand word a dict parameter name is bound to in the emit env.
dictOperand : List (String, (String, LTy)) -> String -> String
dictOperand env d = match lookupAssoc d env
  Some (op, _) => op
  None => gapStr ("unbound dict witness '" ++ d ++ "' in emit env (slice 6: dict not threaded to this site)")

-- ── impl method definitions (slice 6 + slice 7) ─────────────────────────────
-- Each typeclass impl method lowers to ONE top-level `@mdk_impl_<tag>_<method>`,
-- emitted alongside the ordinary function defines (before @main).  Untagged
-- interface defaults (CImplDefault) are the arg-tag fallback path — never a
-- static-dispatch target — so they are skipped.
--
-- SLICE 7 — multi-clause / arg-position impl methods.  The Core IR carries one
-- CImplEntry PER CLAUSE (eval coalesces same-named candidates into a VMulti that
-- falls through arg-by-arg, leftmost clause winning — exactly Maranget column
-- specialization, see ceval/applyOpt/collectPartials).  So same-`(method,tag)`
-- entries are COALESCED here into a single lifted fn whose body is a decision
-- tree built by the SAME `compileTree` the match lowering uses (Axis-1: shared
-- backend-neutral pass).  By arity:
--   • 0 (slice-6 nullary return-position `zero`/`def`): the body is emitted in
--     TAIL position (emitFnBody), byte-for-byte the old single-clause path.
--   • 1: the lone param `%arg0` is the scrutinee; the clauses' single patterns
--     are the match arms.
--   • ≥2: the params are wrapped in a synthetic tuple `(a0, a1, …)` so the
--     multi-param match reduces to a single scrutinee — letting emitDecision /
--     emitTree / bindPattern be reused VERBATIM (note (o); one extra `$tuple`
--     cell alloc per call, acceptable for the spike).

-- a coalesced impl group: method, type-head tag, the SYMBOL tag (= head tag when
-- this is the sole impl at that head, else the sanitized canonical key — C7), the
-- dispatch positions, arity, and the clauses (patterns + body) in source order
-- (leftmost-first — the priority the decision tree preserves).
data ImplGroup =
  | ImplGroup String String String (List Int) Int (List (List Pat, CExpr))

emitImpls : Emit -> List CImplEntry -> Unit
emitImpls e entries = emitGroups e (groupImpls entries)

emitGroups : Emit -> List ImplGroup -> Unit
emitGroups _ [] = ()
emitGroups e (g::rest) =
  -- PROGRAM half (issue #118): same treatment as a prelude fn bind — see emitFns.
  let _ = if hiddenImplGroup g then
    emitAsDeclares e (_ => emitGroup e g)
  else
    emitGroup e g
  emitGroups e rest

emitGroup : Emit -> ImplGroup -> Unit
emitGroup e (ImplGroup method tag symTag positions arity clauses) =
  let fname = implFnName symTag method
  let iface = implGroupIface e method tag
  let selfFnPos = selfFnParamPositions iface method
  let _ = setCurImplSelfFns tag (selfFnParamNames clauses selfFnPos)
  if trmcImplTry e fname method tag positions arity clauses then
    let _ = clearCurImplSelfFns ()
    ()
  else
    let _ = beginDefine e
    let _ = emit e "define i64 @\{fname}(\{implParamDecls arity 0}) {"
    let _ = emit e "entry:"
    let _ = emitGroupBody e fname tag positions arity clauses
    let _ = clearCurImplSelfFns ()
    let _ = emit e "}"
    emit e ""
-- native backend: set the self-returning-fn-param context for this impl body so
-- `emitIndirect` types `f x` (a callback returning the container) as the impl's
-- own type.  The self-fn positions come from the method's signature (keyed by
-- iface, looked up from the resolved impl entry); their names are the PVar names
-- the clauses bind at those positions.  (Set BEFORE choosing the TRMC vs ordinary
-- body so a cons-head callback `f x` — e.g. `map`'s `f x :: …` — types correctly.)

-- Phase 2 B-dispatch (TRMC-DESIGN.md): a DISPATCHED self-recursive cons/ctor-tail
-- impl method (`map`/`filterMap`/`ap` over List, recursing via a `CMethod method
-- (RKey tag)` node) is emitted as an O(1)-stack destination-passing loop, just like
-- a top-level builder.  Scope: uniform-leading-dict impls (`dictUniformPairs`); a
-- point-free eta-reshaped impl (`filter p = filterMap …`) is a single dispatched
-- call, NOT cons-tail-recursive, so `trmcEligible` rejects it (stays ordinary).

-- Phase 2 B-dispatch: try to emit an impl group as a TRMC destination-passing loop.
-- Returns True (and emits the whole define) when the impl is F2(a)/F2(b)-shape-(a)
-- eligible: uniform leading-dict count (`dictUniformPairs` — dicts are admitted as
-- ordinary loop slots) and cons/ctor-tail self-recursive via its own `CMethod method
-- (RKey tag)` dispatch (`trmcEligible (SelfByMethod …)`).  Otherwise returns False so
-- emitGroup falls back to the ordinary `emitGroupBody`.  The loop body reuses
-- emitTrmcLoopBody verbatim (the shared Axis-A machinery); the impl path supplies the
-- `@mdk_impl_<tag>_<method>` define name, the receiver-typed `aK` scrutinee env
-- (`patPosTys`), and the SelfByMethod self-ref for the cons/ctor leaf's self-call
-- recognition + the safety-critical `mentionsSelfMethod` disqualification.
trmcImplTry : Emit -> String -> String -> String -> List Int -> Int -> List (List Pat, CExpr) -> Bool
trmcImplTry e fname method tag positions arity clauses =
  let self = SelfByMethod method tag
  if arity > 0 && dictUniformPairs clauses && trmcEligible (isCtor e) (ctorArity e) self arity clauses then
    let slotTys = patPosTys tag positions arity 0
    let (spats, sbody) = match clauses
      (ps, b)::_ => (ps, b)
      [] => ([], CLit LUnit)
    let single = listLen clauses == 1 && allClausesPVar clauses
    let _ = tmcMarker e fname "trmc"
    let _ = emitTrmcHeader e fname arity
    let _ = emitTrmcLoopBody e self arity slotTys clauses single spats sbody
    let _ = emit e "}"
    let _ = emit e ""
    True
  else False

-- ── interface DEFAULT method bodies (E19) ───────────────────────────────────
-- An interface default (`CImplDefault`) the type's `impl` did not override is
-- lifted to a `@mdk_default_<method>[_<tag>]` define ON DEMAND (the first dispatch
-- that needs it), cached so each (method, tag) is emitted once.  Like a lifted
-- lambda, the define is emitted into the SIDE buffer (LLVM forbids nesting it
-- inside the body being emitted) via the bufRef save/restore swap.
--
-- Two transforms make the point-free / return-position default callable as a
-- DIRECT impl-shaped fn:
--   • ETA-EXPAND to the method's full declared arity (methodArityOf): `filter p =
--     filterMap …` declares arity 2 (`(a->Bool) -> f a -> f a`) but binds one
--     param; the missing trailing params are added and the body applied to them,
--     so the direct call passes every call-site argument.
--   • RE-STAMP inner SAME-interface method calls to `RKey tag` (concrete-tag
--     defaults only — the `filter`@List path): the inner `filterMap` is partially
--     applied (container not yet supplied) so it cannot arg-tag-dispatch; stamping
--     it to the same dispatch tag lowers it to a direct `@mdk_impl_<tag>_filterMap`
--     call.  The arg-tag default path (max/min, tag="") skips this — its inner
--     `compare m x` HAS the discriminating arg and dispatches at run time.
ensureDefaultEmitted : Emit -> String -> String -> String -> CImplEntry -> Unit
ensureDefaultEmitted e fname tag method entry =
  if defaultAlreadyEmitted fname then ()
  else
    let _ = markDefaultEmitted fname
    emitDefaultDefine e fname tag method entry

emitDefaultDefine : Emit -> String -> String -> String -> CImplEntry -> Unit
emitDefaultDefine e fname tag method entry =
  let pats0 = implPats entry
  let body0 = implBody entry
  let dictIfaces = methodConstraintIfacesOf method
  let nDicts = listLen dictIfaces
  let arity0 = maxInt (nDicts + methodArityOf method) (listLen pats0)
  let (pats1, body1) = etaExpand pats0 body0 arity0 (listLen pats0)
  let nReq = innerDefaultReqCount e method tag
  let reqPats = reqDictPats nReq 0
  let pats = reqPats ++ pats1
  let arity = arity0 + nReq
  -- PRELUDE half (issue #118): `@mdk_default_<method>_<tag>` is NAME-derived, and
  -- BOTH halves can demand the same one (a prelude body via emitDefaultRKey, the
  -- program's own code via its dispatch chain) — defining it in each would be a
  -- duplicate symbol.  So it joins `@mdk_disp_*` in the program half, which walks
  -- the prelude's bodies and therefore reaches every default the prelude declares.
  if emitHalfRef.value == emitHalfPrelude then
    emitGlobal e "declare i64 @\{fname}(\{implParamDecls arity 0})"
  else
    let bodyS = restampIfaceDicts methodIfaceTableRef.value (methodIfaceOf method) tag (reqDictRoutes nReq 0) body1
    let body = restampCrossIface methodIfaceTableRef.value method dictIfaces bodyS
    let saved = (bufRef e).value
    let _ = setRef (bufRef e) []
    let scope = beginDefine e
    let _ = emit e "define i64 @\{fname}(\{implParamDecls arity 0}) {"
    let _ = emit e "entry:"
    let _ = emitGroupBody e fname tag [] arity [(pats, body)]
    let _ = emit e "}"
    let _ = emit e ""
    let defLines = (bufRef e).value
    let _ = setRef (lamsRef e) (defLines ++ (lamsRef e).value)
    let _ = endDefine e scope
    setRef (bufRef e) saved
-- G7: the dict-passing pass already PREPENDED one `$dict_<method>_<slot>` param per
-- method-level constraint (foldMap's `Monoid m`) to this default's pats, so the full
-- arity is nDicts + the method's interface arity.  `methodArityOf` counts only the
-- interface args (f + container); add nDicts back so eta-expansion supplies the
-- still-missing trailing interface params (the container) — without it the body stays
-- the under-applied `fold lam empty` (a partial closure, never run on the container).

-- Native Gap C (parametric default-method dict-synthesis, 2026-06-12): a parametric
-- Ord head (tuple/`List a`/`Box a`) reaches this default (`lt`/`gt`/…) whose inner
-- same-interface `compare` is impl'd with element `requires` dicts.  PREPEND that many
-- `$reqdict_<k>` PVar params (so emitGroupBody's all-PVar path binds them by name to
-- the leading `%argK`), and restamp the inner `compare` to carry them as its impl-dict
-- routes (RDict `$reqdict_<k>`).  Then `@mdk_default_<op>_<tag>(reqdict.., a, b)` calls
-- `@mdk_impl_<tag>_compare(reqdict.., a, b)`.  Concrete Ord (no requires) ⇒ nReq=0 ⇒
-- no prepended params, the inner compare keeps empty impl-dicts — byte-identical.

-- re-stamp inner same-interface method occurrences to the concrete RKey tag so a
-- partially-applied inner method (`filterMap` in `filter`'s body) lowers to a
-- direct `@mdk_impl_<tag>_<method>` call instead of an arg-tag site.  The parametric
-- variant also fills the matched call's impl-dict routes from the `$reqdict_<k>` params.

-- G7: a CROSS-interface method in the body (the Monoid `empty`, routed per-call by
-- the RESULT type) is left RNone by restampIface (different interface) → arg-tag
-- dispatch with no discriminating arg → panic.  Route it through the dict-passing's
-- own `$dict_<method>_<slot>` PARAM (RDict) so it dispatches the right Monoid impl at
-- run time from the threaded word; emitDefaultRKey supplies that word at the call site.

-- Native Gap C: the element-`requires` dict count of the inner same-interface method
-- a default reduces to at head [tag].  Ord's `lt`/`gt`/`lte`/`gte`/`min`/`max` defaults
-- reduce to `compare`; that impl carries the parametric element dicts.  A method WITH
-- its own impl at [tag], or whose inner impl has no requires, yields 0 (concrete path).
innerDefaultReqCount : Emit -> String -> String -> Int
innerDefaultReqCount e method tag = match implFor e (innerDefaultMethodE method) tag
  Some entry => maxInt 0 (implReqCount e (innerDefaultMethodE method) entry)
  None => 0

-- the inner same-interface method a relational default reduces to (mirror of
-- typecheck.mdk's innerDefaultMethod): Ord defaults reduce to `compare`.
innerDefaultMethodE : String -> String
innerDefaultMethodE m
  | contains m ["lt", "gt", "lte", "gte", "min", "max"] = "compare"
  | otherwise = m

-- `n` element-dict PVar params named `$reqdict_<i>..` (emitGroupBody's all-PVar path
-- binds each by name to the leading `%argK`).
reqDictPats : Int -> Int -> List Pat
reqDictPats n i
  | i >= n = []
  | otherwise = PVar ("$reqdict_" ++ intToString i) :: reqDictPats n (i + 1)

-- `n` RDict routes forwarding the `$reqdict_<i>` params into the inner same-interface
-- call's impl-dict slots (matching the inner impl fn's leading element-dict params).
reqDictRoutes : Int -> Int -> List Route
reqDictRoutes n i
  | i >= n = []
  | otherwise = RDict ("$reqdict_" ++ intToString i) :: reqDictRoutes n (i + 1)

maxInt : Int -> Int -> Int
-- Intentional: this IS the compiler's hot monomorphic Int max (AGENTS.md
-- anti-pattern: don't delegate hot inner-loop helpers to the dict-passed
-- prelude Ord method).
-- lint-disable-next-line rule-if-max-min
maxInt a b = if a >= b then a else b

-- eta-expand `pats`/`body` from `have` params to `arity` by appending fresh
-- `$etaK` params and applying the body to each (left-to-right).
etaExpand : List Pat -> CExpr -> Int -> Int -> (List Pat, CExpr)
etaExpand pats body arity have
  | have >= arity = (pats, body)
  | otherwise =
    let name = "$eta" ++ intToString have
    etaExpand
      (pats ++ [PVar name])
      (CApp body (CVar name AGlobal))
      arity
      (have + 1)

-- rewrite every inner SAME-interface method occurrence (a bare `CVar m` whose
-- interface equals `iface`) to a `CMethod m (RKey tag) reqRoutes`, so a partially-
-- applied inner method lowers to a direct impl call.  Walks the whole CExpr tree.  The
-- method→(iface,arity) table is passed in (a pure snapshot) so the walk stays pure.
-- [reqRoutes] are the element `requires` dict routes (RDict `$reqdict_<k>`) threaded
-- into the matched inner call's impl-dict slots for a PARAMETRIC head (tuple/`List a`/
-- `Box a`); [] for a concrete head (the `filter`@List / non-parametric default path),
-- byte-identical to the old empty-impl-dicts restamp.
restampIfaceDicts : List (String, (String, Int)) -> String -> String -> List Route -> CExpr -> CExpr
restampIfaceDicts tbl iface tag rr (CVar m ad)
  | iface != "" && ifaceOfIn tbl m == iface = CMethod m (RKey tag []) rr []
  | otherwise = CVar m ad
-- An inner same-interface method that method_marker already rewrote to a
-- `CMethod m RNone` (e.g. `compare` inside the `lt`/`gt`/… Ord defaults) must
-- ALSO be re-stamped to `RKey tag`, or it falls to arg-tag dispatch and a
-- primitive-Ord receiver (which owns no cell tag) panics in emitTagMatch.  Only
-- an unrouted (RNone) same-iface method is restamped — an already-concrete route
-- (a different element type) is left intact.  The parametric element dicts [rr]
-- REPLACE the call's empty impl-dicts so the inner `@mdk_impl_<tag>_compare` sees
-- its leading element-dict params (`reqDictRoutes`); [] preserves the old behaviour.
restampIfaceDicts tbl iface tag rr (CMethod m RNone irs mrs)
  | iface != "" && ifaceOfIn tbl m == iface =
    CMethod m (RKey tag []) (chooseReqRoutes rr irs) mrs
  | otherwise = CMethod m RNone irs mrs
restampIfaceDicts tbl iface tag rr (CApp f a) =
  CApp
    (restampIfaceDicts tbl iface tag rr f)
    (restampIfaceDicts tbl iface tag rr a)
restampIfaceDicts tbl iface tag rr (CLam ps b) =
  CLam ps (restampIfaceDicts tbl iface tag rr b)
restampIfaceDicts tbl iface tag rr (CLet r p rhs b) =
  CLet
    r
    p
    (restampIfaceDicts tbl iface tag rr rhs)
    (restampIfaceDicts tbl iface tag rr b)
restampIfaceDicts tbl iface tag rr (CLetGroup bs b) =
  CLetGroup
    (map (restampBind tbl iface tag rr) bs)
    (restampIfaceDicts tbl iface tag rr b)
restampIfaceDicts tbl iface tag rr (CMatch s arms) =
  CMatch
    (restampIfaceDicts tbl iface tag rr s)
    (map (restampArm tbl iface tag rr) arms)
restampIfaceDicts tbl iface tag rr (CDecision s arms tr) =
  CDecision
    (restampIfaceDicts tbl iface tag rr s)
    (map (restampArm tbl iface tag rr) arms)
    tr
restampIfaceDicts tbl iface tag rr (CIf c t el) =
  CIf
    (restampIfaceDicts tbl iface tag rr c)
    (restampIfaceDicts tbl iface tag rr t)
    (restampIfaceDicts tbl iface tag rr el)
restampIfaceDicts tbl iface tag rr (CBinPrim op a b stag) =
  CBinPrim
    op
    (restampIfaceDicts tbl iface tag rr a)
    (restampIfaceDicts tbl iface tag rr b)
    stag
restampIfaceDicts tbl iface tag rr (CUnOp op a) =
  CUnOp op (restampIfaceDicts tbl iface tag rr a)
restampIfaceDicts tbl iface tag rr (CTuple xs) =
  CTuple (map (restampIfaceDicts tbl iface tag rr) xs)
restampIfaceDicts tbl iface tag rr (CList xs) =
  CList (map (restampIfaceDicts tbl iface tag rr) xs)
restampIfaceDicts tbl iface tag rr (CFieldAccess a f n) =
  CFieldAccess (restampIfaceDicts tbl iface tag rr a) f n
restampIfaceDicts tbl iface tag rr (CIndex a b) =
  CIndex
    (restampIfaceDicts tbl iface tag rr a)
    (restampIfaceDicts tbl iface tag rr b)
restampIfaceDicts tbl iface tag rr (CStringIndex a b) =
  CStringIndex
    (restampIfaceDicts tbl iface tag rr a)
    (restampIfaceDicts tbl iface tag rr b)
restampIfaceDicts tbl iface tag rr (CListIndex a b) =
  CListIndex
    (restampIfaceDicts tbl iface tag rr a)
    (restampIfaceDicts tbl iface tag rr b)
restampIfaceDicts _ _ _ _ other = other

-- prefer the threaded element dict routes [rr] when present; else keep whatever the
-- call already carried (empty for the non-parametric path).
chooseReqRoutes : List Route -> List Route -> List Route
chooseReqRoutes [] irs = irs
chooseReqRoutes rr _ = rr

-- G7: route every CROSS-interface method occurrence in a default body (a bare
-- `CVar m` / `CMethod m RNone` whose interface is one of the method's constraint
-- interfaces, e.g. the Monoid `empty` in foldMap's default) to read the dict PARAM
-- the dict-passing pass already prepended (`$dict_<method>_<slot>`, slot = the
-- iface's index in dictIfaces).  emitGroupBody binds that PVar (by name) to its
-- %argK, so `dictOperand env "$dict_<method>_<slot>"` resolves it at the dispatch
-- site, and emitMethodDispatch switches the right Monoid impl off the threaded word.
-- Same-interface methods were already restamped to RKey by restampIface — untouched.
restampCrossIface : List (String, (String, Int)) -> String -> List String -> CExpr -> CExpr
restampCrossIface tbl method difs (CVar m ad) = match crossDictSlot tbl difs m
  Some k => CMethod m (RDict (dictParamNameE method k)) [] []
  None => CVar m ad
restampCrossIface tbl method difs (CMethod m RNone irs mrs) = match crossDictSlot tbl difs m
  Some k => CMethod m (RDict (dictParamNameE method k)) irs mrs
  None => CMethod m RNone irs mrs
restampCrossIface tbl method difs (CApp f a) =
  CApp
    (restampCrossIface tbl method difs f)
    (restampCrossIface tbl method difs a)
restampCrossIface tbl method difs (CLam ps b) =
  CLam ps (restampCrossIface tbl method difs b)
restampCrossIface tbl method difs (CLet r p rhs b) =
  CLet
    r
    p
    (restampCrossIface tbl method difs rhs)
    (restampCrossIface tbl method difs b)
restampCrossIface tbl method difs (CLetGroup bs b) =
  CLetGroup
    (map (restampCrossBind tbl method difs) bs)
    (restampCrossIface tbl method difs b)
restampCrossIface tbl method difs (CMatch s arms) =
  CMatch
    (restampCrossIface tbl method difs s)
    (map (restampCrossArm tbl method difs) arms)
restampCrossIface tbl method difs (CDecision s arms tr) =
  CDecision
    (restampCrossIface tbl method difs s)
    (map (restampCrossArm tbl method difs) arms)
    tr
restampCrossIface tbl method difs (CIf c t el) =
  CIf
    (restampCrossIface tbl method difs c)
    (restampCrossIface tbl method difs t)
    (restampCrossIface tbl method difs el)
restampCrossIface tbl method difs (CBinPrim op a b stag) =
  CBinPrim
    op
    (restampCrossIface tbl method difs a)
    (restampCrossIface tbl method difs b)
    stag
restampCrossIface tbl method difs (CUnOp op a) =
  CUnOp op (restampCrossIface tbl method difs a)
restampCrossIface tbl method difs (CTuple xs) =
  CTuple (map (restampCrossIface tbl method difs) xs)
restampCrossIface tbl method difs (CList xs) =
  CList (map (restampCrossIface tbl method difs) xs)
restampCrossIface tbl method difs (CFieldAccess a f n) =
  CFieldAccess (restampCrossIface tbl method difs a) f n
restampCrossIface tbl method difs (CIndex a b) =
  CIndex
    (restampCrossIface tbl method difs a)
    (restampCrossIface tbl method difs b)
restampCrossIface tbl method difs (CStringIndex a b) =
  CStringIndex
    (restampCrossIface tbl method difs a)
    (restampCrossIface tbl method difs b)
restampCrossIface tbl method difs (CListIndex a b) =
  CListIndex
    (restampCrossIface tbl method difs a)
    (restampCrossIface tbl method difs b)
restampCrossIface _ _ _ other = other

-- the dict-passing param name for [method]'s [slot]-th method-level constraint dict;
-- matches typecheck.mdk's dictParamName ("$dict_" ++ fn ++ "_" ++ slot).
dictParamNameE : String -> Int -> String
dictParamNameE method slot = "$dict_\{method}_\{intToString slot}"

-- the dict slot (index in dictIfaces) for method [m], if its interface is one of
-- the method's method-level constraint interfaces; None otherwise.
crossDictSlot : List (String, (String, Int)) -> List String -> String -> Option Int
crossDictSlot tbl difs m =
  let mi = ifaceOfIn tbl m
  if mi == "" then None else indexOfStr mi difs

restampCrossBind : List (String, (String, Int)) -> String -> List String -> CBind -> CBind
restampCrossBind tbl method difs (CBind n cs) =
  CBind n (map (restampCrossClause tbl method difs) cs)

restampCrossClause : List (String, (String, Int)) -> String -> List String -> CClause -> CClause
restampCrossClause tbl method difs (CClause ps b) =
  CClause ps (restampCrossIface tbl method difs b)

restampCrossArm : List (String, (String, Int)) -> String -> List String -> CArm -> CArm
restampCrossArm tbl method difs (CArm p gs b) =
  CArm
    p
    (map (restampCrossGuard tbl method difs) gs)
    (restampCrossIface tbl method difs b)

restampCrossGuard : List (String, (String, Int)) -> String -> List String -> CGuard -> CGuard
restampCrossGuard tbl method difs (CGBool c) =
  CGBool (restampCrossIface tbl method difs c)
restampCrossGuard tbl method difs (CGBind p c) =
  CGBind p (restampCrossIface tbl method difs c)

-- the interface a method name belongs to, looked up in a pure table snapshot.
ifaceOfIn : List (String, (String, Int)) -> String -> String
-- Intentional cross-file duplicate of the same helper in wasm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
ifaceOfIn tbl m = match lookupAssoc m tbl
  Some (iface, _) => iface
  None => ""

restampBind : List (String, (String, Int)) -> String -> String -> List Route -> CBind -> CBind
restampBind tbl iface tag rr (CBind n cs) =
  CBind n (map (restampClause tbl iface tag rr) cs)

restampClause : List (String, (String, Int)) -> String -> String -> List Route -> CClause -> CClause
restampClause tbl iface tag rr (CClause ps b) =
  CClause ps (restampIfaceDicts tbl iface tag rr b)

restampArm : List (String, (String, Int)) -> String -> String -> List Route -> CArm -> CArm
restampArm tbl iface tag rr (CArm p gs b) =
  CArm
    p
    (map (restampGuard tbl iface tag rr) gs)
    (restampIfaceDicts tbl iface tag rr b)

restampGuard : List (String, (String, Int)) -> String -> String -> List Route -> CGuard -> CGuard
restampGuard tbl iface tag rr (CGBool c) =
  CGBool (restampIfaceDicts tbl iface tag rr c)
restampGuard tbl iface tag rr (CGBind p c) =
  CGBind p (restampIfaceDicts tbl iface tag rr c)

-- the interface a (method, tag) impl belongs to, via the resolved impl entry.
implGroupIface : Emit -> String -> String -> String
implGroupIface e method tag = match implFor e method tag
  Some entry => implEntryIface entry
  None => ""

-- the PVar names bound at the self-fn positions, taken from the FIRST clause that
-- binds a plain variable there (impl callback params are PVars across clauses; a
-- non-PVar position contributes no name and is simply not typed specially).
selfFnParamNames : List (List Pat, CExpr) -> List Int -> List String
selfFnParamNames clauses positions =
  dedupS (concatMapClausePVars clauses positions)

concatMapClausePVars : List (List Pat, CExpr) -> List Int -> List String
concatMapClausePVars [] _ = []
concatMapClausePVars ((pats, _)::rest) positions = pvarsAtPositions pats positions 0
  ++ concatMapClausePVars rest positions

pvarsAtPositions : List Pat -> List Int -> Int -> List String
pvarsAtPositions [] _ _ = []
pvarsAtPositions ((PVar x)::rest) positions i
  | listContains positions i = x :: pvarsAtPositions rest positions (i + 1)
  | otherwise = pvarsAtPositions rest positions (i + 1)
pvarsAtPositions (_::rest) positions i = pvarsAtPositions rest positions (i + 1)

-- the lifted impl fn's positional parameter list: `i64 %arg0, …` (arity words),
-- or "" for a nullary return-position impl.
implParamDecls : Int -> Int -> String
implParamDecls n i
  | i >= n = ""
  | i == n - 1 = "i64 %arg" ++ intToString i
  | otherwise = "i64 %arg\{intToString i}, \{implParamDecls n (i + 1)}"

-- bind each positional param to its `%argK` operand under a synthetic name aK
-- (the names the synthetic scrutinee CVars reference).
implParamEnv : Int -> Int -> List (String, (String, LTy))
implParamEnv n i
  | i >= n = []
  | otherwise = ("a" ++ intToString i, ("%arg" ++ intToString i, LTInt)) :: implParamEnv n (i + 1)

-- map an impl head tag name to its static LTy for use in param typing.
-- Known primitives → their type; everything else (ADT, List, Array, tuples, …) → LTCon.
tagToLTy : String -> LTy
tagToLTy "String" = LTStr
tagToLTy "Int" = LTInt
tagToLTy "Float" = LTFloat
tagToLTy "Bool" = LTBool
tagToLTy "Char" = LTChar
tagToLTy _ = LTCon

-- like implParamEnv, but types param `i` as `tagToLTy tag` when `i ∈ positions`
-- (the receiver-type positions from CImplTagged), otherwise LTInt.
-- This lets `append xs ys = xs ++ ys` in impl Semigroup (List a) emit xs/ys as
-- LTCon → mdk_list_append, and in impl Semigroup String emit them as LTStr →
-- mdk_string_append — without touching emitBin.
implParamEnvByPos : String -> List Int -> Int -> Int -> List (String, (String, LTy))
implParamEnvByPos _ _ n i
  | i >= n = []
implParamEnvByPos tag positions n i =
  let ty = if listContains positions i then tagToLTy tag else LTInt
  ("a" ++ intToString i, ("%arg" ++ intToString i, ty)) :: implParamEnvByPos tag positions n (i + 1)

listContains : List Int -> Int -> Bool
listContains [] _ = False
listContains (x::rest) v
  | x == v = True
  | otherwise = listContains rest v

emitGroupBody : Emit -> String -> String -> List Int -> Int -> List (List Pat, CExpr) -> Unit
emitGroupBody e fname _ _ 0 [([], body)] = emitFnBody e [] fname body
emitGroupBody e fname _ _ 0 _ =
  gapU "nullary impl group with more than one clause (slice 6)"
-- Fast path: single-clause all-PVar impl (e.g. `append xs ys = xs ++ ys`).
-- Build a typed env directly from param names × receiver type so that `++`/`::`
-- operands inherit the correct LTy (LTStr/LTCon) from the impl head tag.
-- The decision-tree path (emitClauseTree) loses this type info through the
-- tuple-scrutinee indirection → paramUseTy falls back to LTInt → ++ gaps.
--
-- NOTE: this dispatch is written with `if`-EXPRESSIONS (not a guarded match arm)
-- so the emitter itself is self-compilable — the gap-tolerant bootstrap driver
-- cannot lower a guarded match arm (it inserts a `store 0` placeholder, see the
-- CTGuard arm of emitTree), which would silently blank this body in the native
-- emitter.  The IR produced is byte-identical to the guarded form; only the
-- source shape changes.  (The other compiler stages contain NO guarded matches
-- for the same reason.)
emitGroupBody e fname tag positions arity (clauses@[(pats, body)]) =
  if allPVar pats then
    let tyList = patPosTys tag positions (listLen pats) 0
    let env = paramEnvByPos pats tyList 0
    emitFnBody e env fname body
  else emitClauseTree e (implParamEnvByPos tag positions arity 0) arity clauses ""
emitGroupBody e fname tag positions arity clauses =
  emitClauseTree e (implParamEnvByPos tag positions arity 0) arity clauses ""

-- build a LTy list of length n, typed as tagToLTy tag at positions ∈ positions,
-- LTInt elsewhere.
patPosTys : String -> List Int -> Int -> Int -> List LTy
patPosTys _ _ n i
  | i >= n = []
patPosTys tag positions n i =
  let ty = if listContains positions i then tagToLTy tag else LTInt
  ty :: patPosTys tag positions n (i + 1)

-- bind PVar params to their %argK operands at the given LTy list.
paramEnvByPos : List Pat -> List LTy -> Int -> List (String, (String, LTy))
paramEnvByPos [] _ _ = []
paramEnvByPos ((PVar x)::rest) (ty::tys) i =
  (x, ("%arg" ++ intToString i, ty)) :: paramEnvByPos rest tys (i + 1)
paramEnvByPos ((PVar x)::rest) [] i =
  (x, ("%arg" ++ intToString i, LTInt)) :: paramEnvByPos rest [] (i + 1)
paramEnvByPos _ _ _ = []

-- the shared decision-tree body for a coalesced multi-clause group (impl methods
-- AND top-level fns, slice 2/E1a).  `env` binds the synthetic `aK` scrutinee
-- params to their `%argK` operands at the caller's chosen LTy (impl: all LTInt;
-- top-level fn: the inferred signature param types).
--
-- The params are scrutinised AS A MATRIX — one decision-tree COLUMN per param,
-- each column's occurrence word being the param's own operand.  Historically an
-- arity-≥2 group boxed its params into a synthetic `CTuple` cell so the
-- multi-param match reduced to a SINGLE scrutinee; that cost an `@mdk_alloc` on
-- EVERY call (24 B at arity 2) — including every tail-recursive self-call and
-- every TRMC loop iteration — purely to destructure the cell back into the very
-- words it was built from.  Maranget's algorithm is already multi-column
-- (`compileTree` specializes the leftmost column and `emitTree` carries `occs` as
-- a column LIST), so the tuple was never needed: `implRows` now emits one column
-- per param and the occurrences start as the param words themselves.  A leaf
-- binds the clause's patterns element-wise against those words (`bindArm`) rather
-- than loading them back out of a cell.  Zero allocation, one fewer (always-true)
-- tuple-discriminant test, and the param LTys survive into the leaf.
-- `outer` is the fallthrough target for the LAST clause of the chain — see
-- emitClauseChain.  It is a PARAMETER (issue #354): it used to be read out of the
-- module-level fallthroughLabelRef, which made the contract "whatever ambient value
-- some ancestor happened to leave behind".  Every caller today passes "" (a chain
-- either opens a fresh `define` — where inheriting a parent function's block label
-- would emit invalid cross-function LLVM, issue #53 — or sits at top level), so
-- making it explicit costs one argument and buys a call-site-local answer.
emitClauseTree : Emit -> List (String, (String, LTy)) -> Int -> List (List Pat, CExpr) -> String -> Unit
emitClauseTree e env arity clauses outer =
  let roots = emitArgs e env (implScrutVars arity 0)
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "decend" ++ intToString (freshLocal e)
  let rty = Ref LTInt
  let _ = emitClauseChain e env arity clauses roots slot endL rty outer
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{slot}"
  emit e ("  ret i64 " ++ r)
-- Emit the clauses as a CHAIN of single-clause decision trees sharing one result
-- slot + end label.  Each clause passes the NEXT clause's
-- entry block to emitTree, so a pattern miss (CTFail) or a guard fallthrough
-- (`__fallthrough__`) resumes the next clause — the interpreter's "try next
-- clause" semantics.  The scrutinee is emitted ONCE, before the chain.  (A lone
-- clause degenerates to the historical single-tree path: no next label → CTFail
-- stays `unreachable`, fallthrough stays oob.)

-- emit clause chain: each clause's fallthrough target is the NEXT clause's entry
-- block; the LAST clause falls through to `outer` (the fallthrough that was in
-- effect when the chain began — "" at top level → oob; a nested chain inside a
-- guarded clause body inherits the enclosing clause's next-clause label).  A
-- single-clause function degenerates to `outer` directly, preserving the historical
-- single-tree behaviour.
emitClauseChain : Emit -> List (String, (String, LTy)) -> Int -> List (List Pat, CExpr) -> List String -> String -> String -> Ref LTy -> String -> Unit
emitClauseChain _ _ _ [] _ _ _ _ _ = ()
emitClauseChain e env arity (c::rest) roots slot endL rty outer =
  let nextL = chainNextLabel e rest outer
  -- Stamp this clause's next-clause label INTO its `__fallthrough__` sentinels
  -- (emit_support's labelFallthrough) before building the arms, so the sentinel
  -- lowers to `br %nextL` from the var name alone.  The old code left the sentinel
  -- bare and had emitFallthrough read the old module-level fallthrough Ref — which
  -- emitDecision NULLED, so a refutable pattern-guard clause (whose guard chain
  -- desugars to a body-level CDecision) fell through to `@mdk_oob` instead of the
  -- next clause.  (That Ref is gone as of issue #354; the label is now threaded.)
  let c2 = ftClause nextL c
  let arms = [clauseArm arity c2]
  let tree = compileTree [False] (implRows [c2] 0)
  -- This tree is SINGLE-ROW (one clause), so its CTFail means "this clause's pattern
  -- missed" → resume at nextL.  Handed to emitTree as an argument (issue #354); it is
  -- the only emitTree entry point with a live fallthrough — the other three (a
  -- self-contained expression match, and the two tail-match descents) pass "".
  let _ = emitTree e env roots arms roots slot endL nextL rty tree
  if isEmptyL rest then ()
  else
    let _ = emit e (nextL ++ ":")
    emitClauseChain e env arity rest roots slot endL rty outer

-- label a clause's fall-through sentinels with the block to resume at.  An EMPTY
-- label means "no next clause" (the last clause of a top-level chain): leave the
-- sentinels BARE so emitFallthrough lowers them to the non-exhaustive abort.
ftClause : String -> (List Pat, CExpr) -> (List Pat, CExpr)
ftClause "" c = c
ftClause lbl (pats, body) = (pats, labelFallthrough body lbl)

-- the next clause's entry label: the outer fallthrough when this is the last
-- clause, else a fresh `clauseN` block label.
chainNextLabel : Emit -> List (List Pat, CExpr) -> String -> String
chainNextLabel _ [] outer = outer
chainNextLabel e _ _ = "clause" ++ intToString (freshLocal e)

isEmptyL : List a -> Bool
isEmptyL [] = True
isEmptyL _ = False

-- the synthetic scrutinee components of a group: `[a0, a1, …]`.  Emitted through
-- `emitArgs`, so each resolves to the param's operand word — `%argK` for an
-- ordinary define, the loop-head reload register under TRMC.
implScrutVars : Int -> Int -> List CExpr
implScrutVars n i
  | i >= n = []
  | otherwise = CVar ("a" ++ intToString i) AGlobal :: implScrutVars n (i + 1)

-- one match arm per clause: arity 1 uses the lone pattern directly; arity ≥2
-- keeps the clause's params as a `PTuple` — NOT because a tuple cell exists (it
-- does not; see emitClauseTree), but because `CArm` carries a single `Pat`.  The
-- leaf binder (`bindArm`) recognises the multi-root case and binds the tuple's
-- element patterns element-wise against the param words.
clauseArm : Int -> (List Pat, CExpr) -> CArm
clauseArm 1 (pats, body) = CArm (headPat pats) [] body
clauseArm _ (pats, body) = CArm (PTuple pats) [] body

-- one matrix row per clause, ONE COLUMN PER PARAM (each CANONICALISED into matrix
-- form via canonPat — the same normalisation initialRows applies to match arms, so
-- compileTree recognises list/bool/ctor heads); index = the clause position so the
-- decision-tree leaf selects the right arm.  The ARM keeps the RAW patterns
-- (clauseArm) — bindArm re-matches those to bind variables.
implRows : List (List Pat, CExpr) -> Int -> List (List Pat, Int)
implRows [] _ = []
implRows ((pats, _)::rest) i = (map canonPat pats, i) :: implRows rest (i + 1)

headPat : List Pat -> Pat
headPat (p::_) = p
headPat [] = PWild

-- ── impl coalescing (slice 7) ───────────────────────────────────────────────
-- group the per-clause CImplTagged entries by `(method, key)` — the canonical
-- full-type impl key, so two impls sharing a head tycon but differing in type args
-- (C7) land in DISTINCT groups (own body each) while a multi-clause impl (one key)
-- stays coalesced.  Preserves first-seen group order and source clause order within
-- each (the Maranget priority).  CImplDefault entries (interface defaults) are
-- skipped — they are the arg-tag fallback, never a lifted static-dispatch target.
groupImpls : List CImplEntry -> List ImplGroup
groupImpls entries = mapMut (gatherGroup entries) (distinctImplKeys entries [])

-- map a <Mut> function over a list (map is pure; gatherGroup now reads the method
-- arity table to eta-expand point-free impls, so the walk must be <Mut>).
mapMut : (a -> b) -> List a -> List b
mapMut _ [] = []
mapMut f (x::rest) = f x :: mapMut f rest

-- the (method, key) keys of tagged entries, in first-seen order.
distinctImplKeys : List CImplEntry -> List (String, String) -> List (String, String)
distinctImplKeys [] seen = reverseL seen
distinctImplKeys ((CImplEntry method _ (CImplTagged _ key _ _ _ _))::rest) seen
  | keySeen method key seen = distinctImplKeys rest seen
  | otherwise = distinctImplKeys rest ((method, key)::seen)
distinctImplKeys (_::rest) seen = distinctImplKeys rest seen

keySeen : String -> String -> List (String, String) -> Bool
keySeen _ _ [] = False
keySeen m t ((m2, t2)::rest) =
  if m == m2 && t == t2 then
    True
  else
    keySeen m t rest

-- build the group for one (method, key) key: head tag + symTag + positions + arity
-- from the first matching entry, clauses (pats, body) from all matching entries in
-- order.  The SYMBOL tag (C7) is the head tag when this is the sole impl of the head
-- (byte-identical to the pre-C7 scheme), else the sanitized canonical key.  A
-- POINT-FREE impl (`length = fold f 0` — clauseArity < the method's declared
-- arity) is ETA-EXPANDED to the method's full arity, mirroring emitDefaultDefine:
-- the lifted `@mdk_impl_<symTag>_<method>` then takes every call-site arg, so the
-- RKey/arg-tag call sites (which use methodArityOf) and the define agree.  A
-- multi-clause or already-full-arity impl is unchanged (etaExpand is a no-op when
-- have >= arity).
gatherGroup : List CImplEntry -> (String, String) -> ImplGroup
gatherGroup entries (method, key) =
  let tag = headTagForKey method key entries
  let symTag = implFnSymTag entries method tag key
  let cls0 = gatherClauses method key entries
  let positions = groupPositions method key entries
  -- Eta-expand a point-free / ETA-SHORT impl clause up to the method's FULL arity
  -- INCLUDING its leading dict params: `methodArityOf` counts only the source value
  -- params, so a default like `foldMap f = fold (acc x => acc ++ f x) empty`
  -- (synthesized into an impl, clause `[$dict_foldMap_0, f]`) must expand to
  -- `dict + f + container`, not stop at `dict + f`.  Adding `nDicts` (the leading
  -- `$dict_*` params dict_pass prepended) makes the lifted fn take every call-site
  -- arg (RKey/arg-tag callers use `methodArityOf + dictWords`), so the unapplied PAP
  -- (container dropped) → SIGSEGV no longer happens.  nDicts = 0 for a concrete impl
  -- ⇒ identical to the old `maxInt (clauseArity) (methodArityOf)`.
  let nDicts = leadingDictPats (firstClausePats cls0)
  let arity = maxInt (clauseArity cls0) (methodArityOf method + nDicts)
  let cls = map (etaExpandClause arity) cls0
  ImplGroup method tag symTag positions arity cls

-- the head tycon tag of the impl whose (method, key) matches (the first such entry).
headTagForKey : String -> String -> List CImplEntry -> String
headTagForKey _ _ [] = ""
headTagForKey method key ((CImplEntry m _ (CImplTagged t k _ _ _ _))::rest)
  | m == method && k == key = t
  | otherwise = headTagForKey method key rest
headTagForKey method key (_::rest) = headTagForKey method key rest

-- eta-expand one impl clause's (pats, body) to `arity` (no-op when already there).
etaExpandClause : Int -> (List Pat, CExpr) -> (List Pat, CExpr)
etaExpandClause arity (pats, body) = etaExpand pats body arity (lengthS pats)

gatherClauses : String -> String -> List CImplEntry -> List (List Pat, CExpr)
gatherClauses _ _ [] = []
gatherClauses method key ((CImplEntry m _ (CImplTagged _ k _ _ pats body))::rest)
  | m == method && k == key = (pats, body) :: gatherClauses method key rest
  | otherwise = gatherClauses method key rest
gatherClauses method key (_::rest) = gatherClauses method key rest

groupPositions : String -> String -> List CImplEntry -> List Int
groupPositions _ _ [] = []
groupPositions method key ((CImplEntry m _ (CImplTagged _ k _ positions _ _))::rest)
  | m == method && k == key = positions
  | otherwise = groupPositions method key rest
groupPositions method key (_::rest) = groupPositions method key rest

clauseArity : List (List Pat, CExpr) -> Int
clauseArity ((pats, _)::_) = lengthS pats
clauseArity [] = 0

-- the first clause's patterns (for counting leading dict params); [] when no clause.
firstClausePats : List (List Pat, CExpr) -> List Pat
firstClausePats ((pats, _)::_) = pats
firstClausePats [] = []

-- ── closures + higher-order functions (slice 4) ─────────────────────────────
-- VALUE REPRESENTATION (RUNTIME-DESIGN.md §8.5 "Closures"): a closure value is a
-- BOXED heap cell, the same boxed-pointer discipline as ADTs (slice 3) and Floats
-- (slice 1).  Cell layout (8-byte words):
--   [ 0: i64 header ] [ 8: i64 code_ptr ] [ 16: capt0 ] [ 24: capt1 ] …
-- DECISION (filed in PLAN.md as a spike-rep note): the cell carries a one-word
-- HEADER (a fixed closure tag) before `code_ptr`, mirroring §8.5's `{ header,
-- code_ptr, captured… }` and the slice-3 ADT header — NOT code_ptr-at-offset-0.
-- This lets the closure cell reuse `emitCtorAlloc`/`storeFields`/`loadField`
-- VERBATIM: it is allocated exactly like a constructor whose "fields" are
-- `[code_ptr, capt0, capt1, …]`, so `code_ptr` is field 0 and capture i is field
-- i+1.  The CALLING CONVENTION (§8.5): load `code_ptr`, then call passing the
-- closure pointer as a LEADING argument (`@mdk_lamN(i64 %clos, i64 %arg0, …)`).
--
-- Each CLam is LAMBDA-LIFTED to a top-level `define @mdk_lamN` (LLVM has no nested
-- functions).  Its CAPTURED set is freeVars(body) − params, intersected with the
-- emit-time env (free names NOT in the env are top-level globals — known fns /
-- ctors — which need no capture).  At the CLam site we allocate the cell storing
-- `[&@mdk_lamN, capturedWords…]`; in the lifted body we bind params from `%argK`
-- and re-load captures from `%clos`.  Lifted-lambda params/captures default to Int
-- (the type-erased subset; every slice-4 fixture's lambda is Int-typed) — a
-- documented scope limit, like the saturated-only call rule above.

-- allocate a closure cell {arity, code_ptr, captured…}.  Field 0 is the closure's
-- callable ARITY (the value-arg count of its lifted `@mdk_lamN` define, i.e. the
-- args AFTER the leading `%clos` word) — the runtime reads it (mdk_apply) to decide
-- exact / partial / over application.  `code_ptr` is a constant-expression operand
-- (`ptrtoint (ptr @mdk_lamN to i64)`).  The arity MUST equal the emitted define's
-- param count (the E22 hazard): an inline exact call trusts field 0, so a mismatch
-- would divert a saturated call to the PAP path.  Result is the cell pointer word,
-- typed LTClosure.
emitClosureAlloc : Emit -> String -> Int -> List String -> (String, LTy)
emitClosureAlloc e lamName arity captureWords =
  let codePtr = "ptrtoint (ptr @" ++ lamName ++ " to i64)"
  let (w, _) = emitClosureCell e arity (codePtr::captureWords)
  (w, LTClosure)

-- allocate a boxed cell whose header word is the raw integer `hdr` (the closure
-- arity) rather than a hashed ctor tag; fields stored at offset 8*(i+1) as usual.
emitClosureCell : Emit -> Int -> List String -> (String, LTy)
emitClosureCell e hdr fields =
  let n = lengthS fields
  let p = freshReg e
  let _ = emit e "  \{p} = call ptr @mdk_alloc(i64 \{intToString (8 * (n + 1))})"
  let _ = emit e "  store i64 \{intToString hdr}, ptr \{p}"
  let _ = storeFields e p fields 0
  let w = freshReg e
  let _ = emit e "  \{w} = ptrtoint ptr \{p} to i64"
  (w, LTClosure)

-- emitClosureAlloc + record the closure's compile-time arity in closureArityRef
-- (keyed by its SSA word) so an indirect over-application of this closure value can
-- split saturate+apply-extra.  Used for user lambdas and let-group/method-value
-- closures whose arity is statically known.
emitClosureAllocA : Emit -> String -> Int -> List String -> (String, LTy)
emitClosureAllocA e lamName arity captureWords =
  let (w, lty) = emitClosureAlloc e lamName arity captureWords
  let _ = setRef closureArityRef ((w, arity)::closureArityRef.value)
  (w, lty)

-- emit a CLam: compute its captured set, lift its body to a top-level define, and
-- allocate the closure cell capturing the live operand words.
-- E2b — a CLam whose params are NOT all plain `PVar` (a tuple/constructor
-- destructuring lambda) routes through `emitLamPatDefine`: the SAME lifted-frame
-- machinery as `emitLamGo`, but the patterned params are bound by a single-clause
-- decision tree (`emitClauseTree`) over the `%argK` words instead of a verbatim
-- `paramEnv`.  Capture computation is identical — `patVarNames` already collects
-- nested pattern vars, so the patterned param vars are correctly excluded from the
-- captured set.  Closes the lambda half of EMITTER-GAPS #5.
emitLam : Emit -> List (String, (String, LTy)) -> List Pat -> CExpr -> (String, LTy)
emitLam e env pats body =
  if allPVar pats then
    emitLamGo e env pats body
  else
    emitLamPat e env pats body

emitLamGo : Emit -> List (String, (String, LTy)) -> List Pat -> CExpr -> (String, LTy)
emitLamGo e env pats body =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let pnames = patVarNames pats
  let captured = keepInEnv env (dedupS (freeVars pnames body))
  let captureWords = capWords e env captured
  let _ = emitLamDefine e env lamName pats captured body
  let (cw, clty) = emitClosureAllocA e lamName (listLen pats) captureWords
  let _ = recordFloatRet e env cw body
  (cw, clty)

emitLamPat : Emit -> List (String, (String, LTy)) -> List Pat -> CExpr -> (String, LTy)
emitLamPat e env pats body =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let pnames = patVarNames pats
  let captured = keepInEnv env (dedupS (freeVars pnames body))
  let captureWords = capWords e env captured
  let _ = emitPatLamDefine e env lamName [] pats captured body
  let (cw, clty) = emitClosureAllocA e lamName (listLen pats) captureWords
  let _ = recordFloatRet e env cw body
  (cw, clty)

-- emit a RECURSIVE function-`let` closure (slice 5b): lambda-lift exactly like
-- emitLam, but EXCLUDE the binding's own name `f` from the captured set (it is the
-- closure cell itself, not an external free variable) and, inside the lifted body,
-- bind `f` to `%clos` so a self-call re-enters the same code with the same cell.
emitRecLam : Emit -> List (String, (String, LTy)) -> String -> List Pat -> CExpr -> (String, LTy)
emitRecLam e env f pats body =
  if allPVar pats then
    emitRecLamGo e env f pats body
  else
    emitRecLamPat e env f pats body

emitRecLamGo : Emit -> List (String, (String, LTy)) -> String -> List Pat -> CExpr -> (String, LTy)
emitRecLamGo e env f pats body =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let pnames = patVarNames pats
  let captured = keepInEnv env (removeStr f (dedupS (freeVars pnames body)))
  let captureWords = capWords e env captured
  let _ = emitRecLamDefine e env lamName f pats captured body
  let (cw, clty) = emitClosureAllocA e lamName (listLen pats) captureWords
  let _ = recordFloatRet e env cw body
  (cw, clty)

-- E2b — recursive-`let` lambda with non-`PVar` params: same patterned-frame body
-- as `emitLamPat`, but binds `f -> %clos` ahead of captures so a self-call
-- re-enters the same code with the same cell (mirrors `emitRecLamGo` vs
-- `emitLamGo`).  `f` is removed from the free set before computing captures.
emitRecLamPat : Emit -> List (String, (String, LTy)) -> String -> List Pat -> CExpr -> (String, LTy)
emitRecLamPat e env f pats body =
  let lamName = "mdk_lam" ++ intToString (freshId e)
  let pnames = patVarNames pats
  let captured = keepInEnv env (removeStr f (dedupS (freeVars pnames body)))
  let captureWords = capWords e env captured
  let _ = emitPatLamDefine e env lamName [(f, ("%clos", LTClosure))] pats captured body
  let (cw, clty) = emitClosureAllocA e lamName (listLen pats) captureWords
  let _ = recordFloatRet e env cw body
  (cw, clty)

-- like emitLamDefine, but prepends `f -> %clos` to the body's env so the lifted
-- body's recursive references resolve to the closure pointer (the leading param).
-- (Gap E3: lambda params are per-param inferred from the body via `inferParamTys`/
-- `paramUseTy`, so a Float-param lambda gets float instruction selection; params
-- `paramUseTy` can't resolve default to LTInt as before.)
emitRecLamDefine : Emit -> List (String, (String, LTy)) -> String -> String -> List Pat -> List String -> CExpr -> Unit
emitRecLamDefine e env lamName f pats captured body =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{lamName}(\{closureParamDecls pats}) {"
  let _ = emit e "entry:"
  let cenv = loadCaptures e env captured 0
  let penv = paramEnv pats (inferParamTys (sigMapOf e) pats body) 0
  let _ = emitFnBody e (((f, ("%clos", LTClosure))::cenv) ++ penv) lamName body
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- E2b — emit a lifted lambda whose params are NON-variable patterns, into the side
-- buffer (same swap discipline as emitLamDefine).  Captures load from `%clos`
-- fields 1.., the patterned params are the synthetic `aK` scrutinee words
-- (`%argK`, via `implParamEnv`), and the SINGLE clause's body is lowered by
-- `emitClauseTree` — the SAME decision-tree path the patterned top-level fns use
-- (E1a) — so a tuple/constructor param binds its vars via `bindPattern` and the
-- body `ret`s.  `extra` is the leading env binding the recursive case prepends
-- (`f -> %clos`); the non-recursive case passes `[]`.  Lambda params/captures
-- default to Int (`implParamEnv`) — the documented slice-4 scope limit, identical
-- to emitLamDefine's `paramEnv … (allInt pats)`.
emitPatLamDefine : Emit -> List (String, (String, LTy)) -> String -> List (String, (String, LTy)) -> List Pat -> List String -> CExpr -> Unit
emitPatLamDefine e env lamName extra pats captured body =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let arity = listLen pats
  let _ = emit e "define i64 @\{lamName}(i64 %clos, \{implParamDecls arity 0}) {"
  let _ = emit e "entry:"
  let cenv = loadCaptures e env captured 0
  let _ = emitClauseTree e (extra ++ cenv ++ implParamEnv arity 0) arity [(pats, body)] ""
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- drop every occurrence of a name from a list (the recursive-closure self name is
-- removed from its own free-variable set before computing the capture set).
removeStr : String -> List String -> List String
removeStr _ [] = []
removeStr x (y::ys) = if x == y then removeStr x ys else y :: removeStr x ys

-- eta-wrap a NAMED top-level function used as a value into a captureless static
-- closure whose lifted body forwards every argument to `@mdk_<fname>`.  The arity
-- is the function's inferred parameter count (signature table).
emitEtaClosure : Emit -> String -> (String, LTy)
emitEtaClosure e fname =
  let arity = fnArity e fname
  let lamName = "mdk_eta_\{fname}_\{intToString (freshId e)}"
  let _ = emitEtaDefine e lamName fname arity
  emitClosureAlloc e lamName arity []

-- the inferred arity of a known top-level function (its signature's param count).
fnArity : Emit -> String -> Int
fnArity e fname = match sigMapRef.value
  Some m => match omLookup fname m
    Some (FnSig ptys _) => lengthS ptys
    None => 0
  None => match lookupAssoc fname (sigTable e)
    Some (FnSig ptys _) => lengthS ptys
    None => 0

-- the declared arity of constructor `name` (its field count, from the ctor table).
ctorArity : Emit -> String -> Int
ctorArity e name = match ctorMapRef.value
  Some m => match omLookup name m
    Some n => n
    None => 0
  None => match lookupAssoc name (ctorTable e)
    Some n => n
    None => 0

-- #35: an APPLIED constructor, dispatched on saturation.  This is the arity check
-- that the emitVar-side comment below has always ASSUMED but which emitApp did not
-- actually perform: the ctor arm used to call `emitCtorAlloc` unconditionally, so an
-- UNDER-applied ctor (`Bin OAdd` for arity-3 `Bin`) allocated a `Bin` cell holding 1
-- of its 3 fields.  Saturating that later applied args to a DATA cell as if it were a
-- closure (@mdk_apply read the ctor TAG out of the header as if it were an arity), so
-- the value carried the right tag but junk fields — a SILENT wrong-value miscompile:
-- `check` accepted, `run` was correct, `build` produced garbage (E-NONEXHAUSTIVE-MATCH).
--   • SATURATED (the overwhelmingly common case) ⇒ `emitCtorAlloc`, byte-identical to
--     before, so no gate/fixpoint churn.
--   • UNDER-applied ⇒ a ctor PAP (emitCtorPap): a real closure cell over the supplied
--     args whose forwarder allocates the cell once the rest arrive.
--   • OVER-applied ⇒ unreachable for a well-typed program (typecheck rejects applying
--     a data value), but route the surplus through the runtime @mdk_apply rather than
--     silently storing past the cell's end.
emitCtorApp : Emit -> String -> List String -> Int -> (String, LTy)
emitCtorApp e name argOps arity
  | lengthS argOps < arity = emitCtorPap e name argOps arity
  | lengthS argOps > arity =
    let (cw, _) = emitCtorAlloc e name (takeS arity argOps)
    (emitApplyAny e cw (dropS arity argOps), LTInt)
  | otherwise = emitCtorAlloc e name argOps

-- the residual PAP closure for an UNDER-applied constructor.  Exactly the E22
-- method-PAP shape (emitMethodPap) with the dict captures dropped: the closure cell
-- captures the k supplied arg words, its recorded arity is the RESIDUAL (arity − k)
-- so a later over-application of the PAP still splits correctly, and the lifted
-- forwarder reloads the captures and allocates the cell from (supplied ++ fresh).
-- Equivalently: emitCtorEtaClosure (the captureless k==0 eta-wrapper below)
-- generalised to k > 0 supplied args.
emitCtorPap : Emit -> String -> List String -> Int -> (String, LTy)
emitCtorPap e name argOps arity =
  let remaining = arity - lengthS argOps
  let lamName = "mdk_ctorpap_\{name}_\{intToString (freshId e)}"
  let _ = emitCtorPapDefine e lamName name arity (lengthS argOps)
  emitClosureAllocA e lamName remaining argOps

-- emit the under-applied-ctor PAP forwarder.  Closure cell layout: field 0 =
-- code_ptr, fields 1..S = the S supplied arg words.  The forwarder takes `remaining`
-- fresh `%argK` params, reloads the supplied words from fields 1..S, and allocates
-- the ctor cell from (supplied ++ fresh).  Side-buffer swap discipline is
-- emitCtorEtaDefine's, verbatim.
emitCtorPapDefine : Emit -> String -> String -> Int -> Int -> Unit
emitCtorPapDefine e lamName name arity supplied =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let remaining = arity - supplied
  let _ = emit e "define i64 @\{lamName}(\{etaParamDecls remaining}) {"
  let _ = emit e "entry:"
  let suppliedOps = loadPapCaptures e supplied 0
  let (w, _) = emitCtorAlloc e name (suppliedOps ++ etaArgOps remaining 0)
  let _ = emit e ("  ret i64 " ++ w)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- a CONSTRUCTOR with arity>0 referenced as a FIRST-CLASS value (`map PVar vars`):
-- emitApp only builds the cell when the ctor is SATURATED (via emitCtorAlloc — see
-- emitCtorApp above, which now ENFORCES that), so a bare ctor name reaches emitVar.
-- Eta-wrap it into a captureless static closure whose lifted forwarder allocates the
-- ctor cell from its `%argK` words — mirrors emitEtaClosure (known-fn eta) but the
-- body is emitCtorAlloc, not a call.
-- (Arity-0 ctors stay the immediate `emitCtorAlloc e name []` in emitVar — already a
-- complete value, not a function.)
emitCtorEtaClosure : Emit -> String -> (String, LTy)
emitCtorEtaClosure e name =
  let arity = ctorArity e name
  let lamName = "mdk_etac_\{name}_\{intToString (freshId e)}"
  let _ = emitCtorEtaDefine e lamName name arity
  emitClosureAlloc e lamName arity []

-- emit the captureless ctor-eta forwarder `@mdk_etacN(i64 %clos, %arg…) { <alloc
-- cell from %arg0..%argN-1>; ret }` into the side buffer (same swap discipline as
-- emitEtaDefine).
emitCtorEtaDefine : Emit -> String -> String -> Int -> Unit
emitCtorEtaDefine e lamName name arity =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{lamName}(\{etaParamDecls arity}) {"
  let _ = emit e "entry:"
  let (w, _) = emitCtorAlloc e name (argNames arity 0)
  let _ = emit e ("  ret i64 " ++ w)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- emit a lifted lambda's top-level `define` into the SIDE buffer (LLVM forbids a
-- nested define).  Swap the main buffer out, emit the define with `emit` (so it
-- lands in a private buffer), then move those lines (forward order) into the lams
-- buffer and restore the main buffer.  Captures bind by loading `%clos` fields
-- 1.., params bind to `%argK`; the body is emitted in TAIL position (it `ret`s).
-- (Gap E3: param types are per-param inferred from the body via `inferParamTys`/
-- `paramUseTy` — a Float-param lambda gets float ops; unresolved params → LTInt.)
emitLamDefine : Emit -> List (String, (String, LTy)) -> String -> List Pat -> List String -> CExpr -> Unit
emitLamDefine e env lamName pats captured body =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{lamName}(\{closureParamDecls pats}) {"
  let _ = emit e "entry:"
  let cenv = loadCaptures e env captured 0
  let penv = paramEnv pats (inferParamTys (sigMapOf e) pats body) 0
  let _ = emitFnBody e (cenv ++ penv) lamName body
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- emit the captureless eta-forwarder `@mdk_etaN(i64 %clos, %arg…) { ret = call
-- @mdk_fname(%arg…); ret }` into the side buffer (same swap discipline).
emitEtaDefine : Emit -> String -> String -> Int -> Unit
emitEtaDefine e lamName fname arity =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{lamName}(\{etaParamDecls arity}) {"
  let _ = emit e "entry:"
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @mdk_\{fname}(\{argDecls (argNames arity 0)})"
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- gap-2 (GENERAL): a known extern of ANY family (str/num/io/char/file/hash/…)
-- referenced as a FIRST-CLASS value (point-free alias `f = stringLength`, or
-- passed to a HOF like a fold that applies the extern).  emitApp lowers an extern
-- only when SATURATED (via emitExternApplied); a bare name reaches emitVar.  Eta-
-- wrap it into a captureless static closure whose lifted body REPLAYS
-- emitExternApplied's applied-form codegen on the incoming `%argK` operands, so
-- the value form is byte-consistent with the applied form for every family —
-- including INTRINSICS with no C symbol (e.g. `stringLength`, which inlines a load
-- of the cached codepoint count) since we reuse the exact applied emitter.  Arity
-- comes from the runtime sig (externArity → declSigOf, the runtime extern decls'
-- arrow count), so no per-family arity is hardcoded.
emitExternEtaClosure : Emit -> String -> (String, LTy)
emitExternEtaClosure e name =
  let lamName = "mdk_eta_\{name}_\{intToString (freshId e)}"
  let _ = emitExternEtaDefine e lamName name (externArity e name)
  emitClosureAlloc e lamName (externArity e name) []

-- Gap #50 (value position) — an interface METHOD name reaching emitVar as a bare
-- first-class value (passed to a HOF, e.g. `apply2 max 3 8`).  At a value site the
-- receiver type is monomorphic but NO route accompanies the bare CVar (routes live
-- on CMethod, not CVar), so dispatch must fall to the runtime arg-tag path.  Eta-
-- wrap into a captureless closure whose lifted body REPLAYS emitMethodArgDispatch's
-- applied-form codegen on the incoming `%argK` operands — byte-consistent with the
-- saturated `isImplMethod` call site (emitApp).  Arity = methodArityOf.  (A method
-- reached point-free under a `=>` CONSTRAINT instead becomes a fn-bind with a dict
-- param and is eta-saturated at the define by etaSaturateMethodBody.)
emitMethodEtaClosure : Emit -> String -> (String, LTy)
emitMethodEtaClosure e name =
  let lamName = "mdk_eta_\{name}_\{intToString (freshId e)}"
  let _ = emitMethodEtaDefine e lamName name (methodArityOf name)
  emitClosureAlloc e lamName (methodArityOf name) []

-- the captureless method-eta forwarder `@mdk_etaN(i64 %clos, %arg…) { <inline
-- arg-tag dispatch over %arg0..%arg(N-1)>; ret }` (mirror of emitExternEtaDefine).
emitMethodEtaDefine : Emit -> String -> String -> Int -> Unit
emitMethodEtaDefine e lamName name arity =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{lamName}(\{etaParamDecls arity}) {"
  let _ = emit e "entry:"
  let synArgs = etaArgOps arity 0
  let (r, _) = emitMethodArgDispatch e name synArgs
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- the declared arity of extern `name` = the arrow count of its runtime signature
-- (`declSigOf` is seeded from the runtime extern decls via declSigTypeNames).  An
-- extern with no recorded signature defaults to arity 1 (every current extern is
-- annotated, so this is a defensive fallback, not a live path).
externArity : Emit -> String -> Int
externArity _ name = match declSigOf name
  Some (ptys, _) => lengthS ptys
  None => 1

-- emit the captureless extern-eta forwarder `@mdk_etaN(i64 %clos, %arg…) {
-- <inline applied-extern body over %arg0..%arg(N-1)>; ret }` into the side buffer
-- (same swap discipline as emitEtaDefine).  The body is produced by calling
-- emitExternApplied with synthetic `__eta_argK__` CVars bound to the `%argK`
-- regs — reuses the EXACT applied-form codegen, guaranteeing value/applied
-- consistency across all families.
emitExternEtaDefine : Emit -> String -> String -> Int -> Unit
emitExternEtaDefine e lamName name arity =
  let saved = (bufRef e).value
  let _ = setRef (bufRef e) []
  let scope = beginDefine e
  let _ = emit e "define i64 @\{lamName}(\{etaParamDecls arity}) {"
  let _ = emit e "entry:"
  let argEnv = etaArgEnv arity 0
  let synArgs = etaArgVars arity 0
  let (r, _) = emitExternApplied e argEnv name synArgs
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  let _ = emit e ""
  let lamLines = (bufRef e).value
  let _ = setRef (lamsRef e) (lamLines ++ (lamsRef e).value)
  let _ = endDefine e scope
  setRef (bufRef e) saved

-- env binding `__eta_argK__ -> (%argK, LTInt)` for K in [i, arity) — so the
-- replayed applied-form emitter resolves each synthetic arg to its `%argK` reg.
etaArgEnv : Int -> Int -> List (String, (String, LTy))
etaArgEnv n i =
  if i >= n then
    []
  else
    ("__eta_arg" ++ intToString i ++ "__", ("%arg" ++ intToString i, LTInt)) :: etaArgEnv n (i + 1)

-- the synthetic argument exprs `CVar "__eta_argK__" AGlobal` for K in [i, arity).
etaArgVars : Int -> Int -> List CExpr
etaArgVars n i =
  if i >= n then
    []
  else
    CVar ("__eta_arg" ++ intToString i ++ "__") AGlobal :: etaArgVars n (i + 1)

-- the eta-define's `%arg0..%arg(n-1)` parameter OPERAND words (as raw register
-- strings), for an eta body that consumes operands directly (emitMethodArgDispatch)
-- rather than re-emitting CVars through an env.
etaArgOps : Int -> Int -> List String
etaArgOps n i =
  if i >= n then
    []
  else
    "%arg" ++ intToString i :: etaArgOps n (i + 1)

closureParamDecls : List Pat -> String
closureParamDecls [] = "i64 %clos"
closureParamDecls pats = "i64 %clos, " ++ paramDecls pats 0

-- the eta-forwarder's parameter list: `%clos` then `arity` `%argK`s.
etaParamDecls : Int -> String
etaParamDecls n = "i64 %clos" ++ etaArgDecls n 0

etaArgDecls : Int -> Int -> String
etaArgDecls n i =
  if i >= n then
    ""
  else
    ", i64 %arg\{intToString i}\{etaArgDecls n (i + 1)}"

-- the `%argK` operand names 0..n-1 (the eta-forwarder's call arguments).
argNames : Int -> Int -> List String
argNames n i =
  if i >= n then
    []
  else
    "%arg" ++ intToString i :: argNames n (i + 1)

-- bind each captured variable by loading `%clos` field i+1 (field 0 is code_ptr).
loadCaptures : Emit -> List (String, (String, LTy)) -> List String -> Int -> List (String, (String, LTy))
loadCaptures _ _ [] _ = []
loadCaptures e env (c::rest) i =
  let r = loadField e "%clos" (i + 1)
  (c, (r, capTypeOf env c)) :: loadCaptures e env rest (i + 1)

-- a captured FLOAT is stored BOXED in the closure cell (capWords/lookupVarG boxes
-- an unboxed LTFloatU on escape), so bind it LTFloat inside the lifted body —
-- matching emitLit's boxed-float convention, so arith (the Win-12 one-float-operand
-- path), print, and list ops all unbox it correctly.  Every OTHER capture stays
-- LTInt (the uniform-i64 default), so non-float captures are unaffected → zero
-- regression surface.  Fixes the closure-float-capture arith soundness bug
-- (`map (x => x * scale)` with a captured float `scale`, `(z => z + k)` etc., which
-- previously did INTEGER arith on boxed-float pointers → garbage).
capTypeOf : List (String, (String, LTy)) -> String -> LTy
capTypeOf env c = match lookupAssoc c env
  Some (_, LTFloat) => LTFloat
  Some (_, LTFloatU) => LTFloat
  _ => LTInt

-- the live operand words for a captured-name list (looked up in the emit env).
-- Routed through lookupVarG (Mut) so an LTFloatU let-bound float is BOXED to an
-- i64 word before being stored into a closure capture slot (escape coercion) —
-- the closure ABI is uniform i64, and loadCaptures reads captures back as words.
capWords : Emit -> List (String, (String, LTy)) -> List String -> List String
capWords _ _ [] = []
capWords e env (c::rest) =
  let (op, _) = lookupVarG e env c
  op :: capWords e env rest

-- keep only the names present as keys in the emit env (the capturable locals);
-- drop free names that resolve to top-level globals (known fns / ctors).
keepInEnv : List (String, (String, LTy)) -> List String -> List String
keepInEnv _ [] = []
keepInEnv env (k::rest) =
  if envHasKey env k then
    k :: keepInEnv env rest
  else
    keepInEnv env rest

envHasKey : List (String, (String, LTy)) -> String -> Bool
envHasKey [] _ = False
envHasKey ((n, _)::rest) k = if n == k then True else envHasKey rest k

dedupS : List String -> List String
dedupS [] = []
dedupS (x::xs) = if contains x xs then dedupS xs else x :: dedupS xs

-- ── ADT constructors + pattern matching (slice 3) ───────────────────────────
-- VALUE REPRESENTATION (RUNTIME-DESIGN.md §8.4 "Option A", extended from the
-- slice-1 Float box): an ADT value is a BOXED heap cell with a one-word header.
--   cell layout (8-byte words):  [ 0: i64 tag ] [ 8: field0 ] [ 16: field1 ] …
-- the tag is the constructor's COMPOSITE (typeId, ordinal) — see `cellTag` (computed
-- identically at the alloc site and at every switch test, so the two always agree); the word
-- carried in registers is the cell pointer (`ptrtoint`, low bit 0 — disjoint from
-- the immediate-int low-bit-1 encoding, exactly as the Float box is).  Allocation
-- reuses the slice-1 `@mdk_alloc` (malloc-and-leak; no GC this slice).

-- `hashName` (djb2, seed 5381) lives in `backend.private_mangle`, shared with the
-- WasmGC emitter so the dict-witness tag agrees across backends.  STILL used here
-- for the NON-ctor sentinel headers ("$tuple"/"$ref"/"$closure") and dict witness
-- words; constructor cell tags use `cellTag` (ordinals) instead.

-- ── constructor tag = dense per-type ordinal (RUNTIME-DESIGN §8.4, ratified ──────
--    2026-06-07; supersedes the spike's i64 string-hash for CONSTRUCTOR tags).
-- A constructor C of type T is tagged with its 0-based index in T's
-- declaration-ordered constructor list (the ratified value — `br_table`-ready and
-- collision-free).  But the spike's ARG-TAG dispatch (emitTagMatch) discriminates a
-- value's TYPE by loading its cell tag and OR-ing it against a candidate type's
-- ctor tags — and per-type ordinals COLLIDE across types (every type has an
-- ordinal-0 ctor), so a bare ordinal cannot identify the type.  The one-word header
-- therefore carries a COMPOSITE: a dense per-type id in the high 32 bits and the
-- ratified per-type ctor ordinal in the low 32 bits.
--   • match-head test (within ONE statically-known type) and `br_table` use the low
--     half — `tag & 0xffffffff` is the dense 0-based ordinal.
--   • the spike's arg-tag dispatch uses the FULL composite, which is globally unique
--     (distinct type ⇒ distinct high half), so cross-type discrimination is exact.
-- The high half is spike scaffolding for that runtime dispatch; the real backend
-- resolves such call sites statically / by dictionary and keeps only the low-half
-- ordinal.  hashName is gone from every constructor tag — collisions are impossible.
-- 2^32, the type-id shift.  (Int is 63-bit; type-id × 2^32 + ordinal stays well
-- under 2^62 for any real program.)
ctorTagShift : Int
ctorTagShift = 4294967296

-- the cell-header tag a NAME stamps / is tested against.  Sentinel headers
-- ("$tuple"/"$ref"/"$closure") keep their hash; every constructor (incl. the
-- built-in list Cons/Nil and a user ctor that owns those names) gets the composite
-- (typeId, ordinal).  Alloc and every tag test route through THIS one function, so
-- the stored tag and the compared tag are identical by construction.
-- RESERVED ADT-TAG BLOCK (slice 10 precursor).  The runtime ADTs — List, Option,
-- Result, Ordering — get FIXED composite tags, far above any real program's dense
-- type-id range, so a C extern can construct these cells (mdk_some/mdk_cons/… in
-- runtime/medaka_rt.c) with a tag a later `match` agrees with.  The driver
-- (llvm_emit_main.mdk) does NOT load the prelude, so a prelude-free fixture using
-- `Some`/`None`/`Ok`/… has them ABSENT from the ctor→type table — without this
-- reservation `Some` and `Cons` both fall to the "one past" type-id with ordinal 0
-- and COLLIDE.  Both alloc and every tag test route through `cellTag`, so reserving
-- here keeps construction and the match-head test consistent by construction.
-- The C side hardcodes the SAME constants (MDK_TAG_* in runtime/medaka_rt.c); keep
-- the two in sync.  Ordinals follow core.mdk: Option = Some|None, Result = Ok|Err,
-- Ordering = Lt|Eq|Gt; List (synthetic) = Cons|Nil.  #361: the comment that used to
-- stand here called a user type reusing one of these names a "KNOWN SPIKE LIMITATION"
-- that "the real backend resolves statically" — as if this emitter were the spike and
-- some other, more careful backend existed downstream. THIS is the real (and only)
-- backend; there is no other one to defer to. The actual guard is upstream, in the
-- RESOLVER: `data Foo = Ok Int | Bad` is rejected before it ever reaches this file
-- (`dupErr "constructor"`, resolve.mdk:1422, message "Duplicate constructor: Ok" —
-- probed). So a user ctor can never actually alias `Cons`/`Some`/`None`/`Ok`/`Err`/
-- `Lt`/`Eq`/`Gt` by the time `reservedTag` runs; this function's fixed-tag table is
-- safe because that invariant is enforced elsewhere, not because collisions here are
-- merely "consistent." If that resolver check is ever removed, THIS is the place a
-- silent tag collision would resurface — worth an emit-time assertion, not just a
-- comment (EMITTER-SEMANTICS M2).
reservedTypeBase : Int
reservedTypeBase = 65536

reservedTag : String -> Option Int
reservedTag name =
  if name == "Cons" then
    Some ((reservedTypeBase + 0) * ctorTagShift + 0)
  else if name == "Nil" then
    Some ((reservedTypeBase + 0) * ctorTagShift + 1)
  else if name == "Some" then
    Some ((reservedTypeBase + 1) * ctorTagShift + 0)
  else if name == "None" then
    Some ((reservedTypeBase + 1) * ctorTagShift + 1)
  else if name == "Ok" then
    Some ((reservedTypeBase + 2) * ctorTagShift + 0)
  else if name == "Err" then
    Some ((reservedTypeBase + 2) * ctorTagShift + 1)
  else if name == "Lt" then
    Some ((reservedTypeBase + 3) * ctorTagShift + 0)
  else if name == "Eq" then
    Some ((reservedTypeBase + 3) * ctorTagShift + 1)
  else if name == "Gt" then
    Some ((reservedTypeBase + 3) * ctorTagShift + 2)
  else
    None

-- the cell-header tag a NAME stamps / is tested against.  Sentinel headers
-- ("$tuple"/"$ref"/"$closure") keep their hash; the runtime ADTs route through
-- `reservedTag` (fixed, program-stable); every other constructor gets the composite
-- (typeId, ordinal).  Alloc and every tag test route through THIS one function, so
-- the stored tag and the compared tag are identical by construction.
-- Bool immediates are hardcoded by emitVar/emitLit: True→word 3 (ashr1→tag 1),
-- False→word 1 (ashr1→tag 0).  Special-case before the ctor-table lookup so
-- construction and discrimination agree regardless of whether Bool is in the table.
cellTag : Emit -> String -> Int
cellTag e name =
  if name == "True" then 1
  else
    if name == "False" then 0
    else
      if contains name ["$tuple", "$ref", "$closure"] then hashName name
      else match reservedTag name
        Some t => t
        None => ctorTypeId e name * ctorTagShift + ctorOrdinal e name

-- the 0-based index of constructor `name` in its type's declaration-ordered ctor
-- list.  The built-in list Cons/Nil are not user-declared (absent from the
-- ctor→type table) → reserved ordinals 0/1 of the synthetic list type.
ctorOrdinal : Emit -> String -> Int
ctorOrdinal e name = match lookupAssoc name (ctorTypeTable e)
  Some ty => orZero (indexOfStr name (ctorsOfType e ty))
  None => if name == "Nil" then 1 else 0

-- the dense per-type id of the type that owns constructor `name`: its index among
-- the program's distinct type names (declaration order).  The built-in list (and
-- any name not in the ctor→type table) gets a reserved id one past the user types,
-- so its composite tags can never collide with a user type's.
ctorTypeId : Emit -> String -> Int
ctorTypeId e name = match lookupAssoc name (ctorTypeTable e)
  Some ty => orZero (indexOfStr ty (distinctTypeNames e))
  None => lengthS (distinctTypeNames e)

-- the distinct type names of the program, in declaration order (the ctor→type
-- table lists each type's ctors consecutively, so dedup-preserving-order gives the
-- type declaration order).
-- `distinctTypeNames` is constant during a program's emission (the ctor→type
-- table is set once), but `ctorTypeId` calls it per ADT-constructor emission and
-- it recomputes the O(n²) `nubStr` each time. Memoize the result (a plain
-- List String — no hash container, so it self-compiles cleanly) in a module-level
-- ref, reset to None at each emitProgram/emitProgramGaps so batched emits recompute.
distinctTypeNamesRef : Ref (Option (List String))
distinctTypeNamesRef = Ref None

resetDistinctTypeNames : Unit -> Unit
resetDistinctTypeNames _ = setRef distinctTypeNamesRef None

distinctTypeNames : Emit -> List String
distinctTypeNames e = match distinctTypeNamesRef.value
  Some xs => xs
  None =>
    let xs = nubStr (typeNamesOf (ctorTypeTable e))
    let _ = setRef distinctTypeNamesRef (Some xs)
    xs

typeNamesOf : List (String, String) -> List String
typeNamesOf [] = []
typeNamesOf ((_, t)::rest) = t :: typeNamesOf rest

orZero : Option Int -> Int
orZero (Some i) = i
orZero None = 0

-- dedup a list of strings, preserving first-occurrence order.
nubStr : List String -> List String
nubStr xs = nubStrAcc xs []

nubStrAcc : List String -> List String -> List String
nubStrAcc [] _ = []
nubStrAcc (x::xs) seen =
  if contains x seen then
    nubStrAcc xs seen
  else
    x :: nubStrAcc xs (x::seen)

-- allocate a constructor cell {tag, field…}; the field words are already emitted.
-- Result is the cell pointer as an i64 word, typed LTCon.  A NULLARY constructor
-- (RUNTIME-DESIGN §8.1 / §8.4 decision 1: nullary ctors are immediate/free) does
-- NOT allocate — it is the IMMEDIATE word `(cellTag<<1)|1`, carrying the SAME
-- composite (typeId, ordinal) tag a boxed cell would store in its header, untaggable
-- by `ashr 1`.  This generalises the existing Bool immediate (emitVar True→"3"/
-- False→"1") to every nullary ctor.  The constant operand emits no instructions; a
-- `match` recovers the tag via `loadDiscriminant` (low-bit branch), so construction
-- and the match-head test agree on `cellTag` whether the value is immediate or boxed.
emitCtorAlloc : Emit -> String -> List String -> (String, LTy)
emitCtorAlloc e name [] = (intToString (cellTag e name * 2 + 1), LTCon)
emitCtorAlloc e name fields =
  let arity = lengthS fields
  let p = freshReg e
  let _ = emit e "  \{p} = call ptr @mdk_alloc(i64 \{intToString (8 * (arity + 1))})"
  let _ = emit e "  store i64 \{intToString (cellTag e name)}, ptr \{p}"
  let _ = storeFields e p fields 0
  let w = freshReg e
  let _ = emit e "  \{w} = ptrtoint ptr \{p} to i64"
  (w, LTCon)

-- store each field at offset 8*(i+1) (field 0 follows the one-word header).
storeFields : Emit -> String -> List String -> Int -> Unit
storeFields _ _ [] _ = ()
storeFields e p (f::rest) i =
  let fp = freshReg e
  let _ = emit e "  \{fp} = getelementptr i8, ptr \{p}, i64 \{intToString (8 * (i + 1))}"
  let _ = emit e "  store i64 \{f}, ptr \{fp}"
  storeFields e p rest (i + 1)

-- load a cell's tag (header word at offset 0) given the cell's pointer word.
loadTag : Emit -> String -> String
loadTag e ptrWord =
  let p = freshReg e
  let _ = emit e "  \{p} = inttoptr i64 \{ptrWord} to ptr"
  let t = freshReg e
  let _ = emit e "  \{t} = load i64, ptr \{p}"
  t

-- the DISCRIMINANT word a constructor `match` head (and arg-tag dispatch) tests.
-- A value of an ADT type is EITHER an immediate nullary ctor (low bit 1 — its
-- composite (typeId, ordinal) tag rides the payload, recovered by `ashr 1`) OR a
-- boxed pointer to a cell whose header word IS that same composite tag (low bit 0 —
-- `loadTag` it).  A type that mixes the two (e.g. Option = None immediate + Some
-- boxed) means a single scrutinee can be either, so branch on the low bit BEFORE
-- choosing — an immediate must NEVER be dereferenced (`loadTag` on an odd word
-- inttoptr's to a misaligned address and segfaults).  Both arms phi to ONE tag word
-- equal to the `cellTag` the alloc site stamps, so emitConChain/emitTagMatch compare
-- against `cellTag` UNCHANGED: immediate and boxed reps are tag-comparable by
-- construction (RUNTIME-DESIGN §8.1).  loadTag stays the raw boxed-cell load — used
-- directly only where the value is known boxed (array length header).
loadDiscriminant : Emit -> String -> String
loadDiscriminant e word =
  let n = intToString (freshLocal e)
  let imm = "discimm" ++ n
  let box = "discbox" ++ n
  let cont = "disccont" ++ n
  let lb = freshReg e
  let _ = emit e "  \{lb} = and i64 \{word}, 1"
  let isImm = freshReg e
  let _ = emit e "  \{isImm} = icmp eq i64 \{lb}, 1"
  let _ = emit e "  br i1 \{isImm}, label %\{imm}, label %\{box}"
  let _ = emit e (imm ++ ":")
  let iv = freshReg e
  let _ = emit e "  \{iv} = ashr i64 \{word}, 1"
  let _ = emit e ("  br label %" ++ cont)
  let _ = emit e (box ++ ":")
  let bv = loadTag e word
  let _ = emit e ("  br label %" ++ cont)
  let _ = emit e (cont ++ ":")
  let d = freshReg e
  let _ = emit e "  \{d} = phi i64 [ \{iv}, %\{imm} ], [ \{bv}, %\{box} ]"
  d

-- load field `idx` (offset 8*(idx+1)) of a cell given its pointer word.
loadField : Emit -> String -> Int -> String
loadField e ptrWord idx =
  let p = freshReg e
  let _ = emit e "  \{p} = inttoptr i64 \{ptrWord} to ptr"
  let fp = freshReg e
  let _ = emit e "  \{fp} = getelementptr i8, ptr \{p}, i64 \{intToString (8 * (idx + 1))}"
  let f = freshReg e
  let _ = emit e "  \{f} = load i64, ptr \{fp}"
  f

-- load the first `a` fields of a cell as a list of operand words.
loadFields : Emit -> String -> Int -> Int -> List String
loadFields e foc a i
  | i >= a = []
  | otherwise =
    let f = loadField e foc i
    f :: loadFields e foc a (i + 1)

-- a `match` lowered to a decision tree (CDecision).  Mirrors core_ir_eval's
-- cevalDecision exactly, but emits an LLVM CFG instead of walking values: the
-- scrutinee word, an `alloca` result slot, the tree (which routes control via
-- br/icmp to the selected arm, where the arm stores its body value into the slot
-- and branches to the end label), then a load of the slot in the end block.  The
-- arm's static result type is captured into `rty` as the arm body is emitted (all
-- arms agree — well-typed match).
emitDecision : Emit -> List (String, (String, LTy)) -> CExpr -> List CArm -> CTree -> (String, LTy)
emitDecision e env scrut arms tree =
  let (sv, _) = emitExpr e env scrut
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "decend" ++ intToString (freshLocal e)
  let rty = Ref LTInt
  let savedTrmc = trmcCtxRef.value
  let _ = setRef trmcCtxRef TrmcOff
  let savedGDisp = gDispCtxRef.value
  let _ = setRef gDispCtxRef GDispOff
  -- "" = a miss in an expression-position match is a genuine non-exhaustive abort,
  -- NOT the enclosing clause chain's fallthrough (the clause's pattern already
  -- matched to get here).  Passing it as an argument replaces the old
  -- save+null+restore of fallthroughLabelRef (issue #354).
  let _ = emitTree e env [sv] arms [sv] slot endL "" rty tree
  let _ = setRef trmcCtxRef savedTrmc
  let _ = setRef gDispCtxRef savedGDisp
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{slot}"
  (r, rty.value)
-- A `match` in expression position is self-contained: its own non-exhaustive
-- CTFail is a genuine abort, NOT the enclosing clause-chain's fallthrough.  Save
-- + null the fallthrough label across the tree so a body-level match emitted
-- inside a chained clause leaf doesn't inherit (and wrongly branch to) the
-- next-clause block.  Restored after.

-- Likewise self-contained for TRMC: an expression-position `match`'s arms
-- compute VALUES into `slot`, never cons-into-dest — so clear the TRMC ctx
-- across the tree (a tail cons in a match arm is Phase 2, deliberately not here).

-- walk the compiled CTree, emitting basic blocks.  `root` is the whole scrutinee
-- word (kept for the leaf re-match that recovers bindings — mirrors ceval's
-- `root`); `occs` is the live column words (the matrix columns), starting as just
-- [root] and expanding into a constructor's fields as the tree descends.  Every
-- path terminates its current block (a `br` to `endL` after storing, a `br` into
-- a sibling test block, or `unreachable` for CTFail).
emitTree : Emit -> List (String, (String, LTy)) -> List String -> List CArm -> List String -> String -> String -> String -> Ref LTy -> CTree -> Unit
-- CTFail: the matrix path matched no row.  In a CHAINED single-clause tree
-- (emitClauseChain) this is "this clause's pattern didn't match" → resume the next
-- clause via `ftL`, the fallthrough label THREADED IN by the caller; with no next
-- clause (`""`) it is a genuine non-exhaustive-match abort.  A bare `unreachable`
-- here was UB (LLVM `ud2` → a
-- silent SIGTRAP, no output); call the noreturn @mdk_nonexhaustive_match (prints
-- `runtime error [E-NONEXHAUSTIVE-MATCH]` to stderr, exits nonzero — the
-- interpreter's message MINUS `file:L:C:`, Core IR carrying no loc) before the
-- `unreachable`, mirroring the div-by-zero trap.  (The GUARD-chain half of "try the
-- next clause" is NOT this arm — that is the `__fallthrough__` sentinel, lowered by
-- emitFallthrough from the label stamped into the node.)
--
-- `ftL` is a PLAIN PARAMETER, not ambient state (issue #354).  It used to be a
-- module-level Ref that four entry points saved+NULLED+restored, which made "is the
-- fallthrough live here?" a whole-call-graph question — the exact shape that made the
-- `__fallthrough__` sentinel branch to @mdk_oob instead of the next clause (a run≠build
-- miscompile, fixed 2026-07-13 by moving THAT label into the node).  Threading it makes
-- the answer local and the hazard structurally impossible: an entry point that means
-- "a miss here is a genuine abort" passes "" and cannot forget to restore.
emitTree e _ _ _ _ _ _ "" _ CTFail =
  let _ = emit e "  call void @mdk_nonexhaustive_match()"
  emit e "  unreachable"
emitTree e _ _ _ _ _ _ lbl _ CTFail = emit e ("  br label %" ++ lbl)
emitTree e env roots arms _ slot endL _ rty (CTLeaf i) =
  emitLeaf e env roots arms i slot endL rty
-- CTGuard i fail: arm i matched but is GUARDED.  Re-bind its pattern (like a
-- leaf), evaluate its guards; all pass → eval the body (emitLeaf-style); any
-- guard fails → branch to the `fail` subtree, which resumes the ordered match at
-- the same column context `occs` (mirrors core_ir_eval's `cevalGuardedBody`).
-- This CLOSES the historical CTGuard emitter gap — `compiler/` code on the native
-- self-compile path no longer needs the guard-free convention for `CGBool`
-- guards.  A refutable `p <- e` pattern guard stays a contained gap (not produced
-- by current source); a bad arm index likewise.
emitTree e env roots arms occs slot endL ftL rty (CTGuard i fail) = match nthArm arms i
  Some (CArm pat guards body) => if allGuardsEmittable guards then emitGuardedArm e env roots arms occs pat guards body fail slot endL ftL rty
  else
    let _ = gapU "refutable pattern guard (`p <- e`) in a match arm (CTGuard) — not yet lowered"
    let _ = emit e ("  store i64 0, ptr " ++ slot)
    emit e ("  br label %" ++ endL)
  None =>
    let _ = gapU "guarded arm index out of range (CTGuard)"
    let _ = emit e ("  store i64 0, ptr " ++ slot)
    emit e ("  br label %" ++ endL)
emitTree e env roots arms occs slot endL ftL rty (CTDrop sub) =
  emitTree e env roots arms (tailS occs) slot endL ftL rty sub
emitTree e env roots arms occs slot endL ftL rty (CTSwitch branches dft) =
  emitSwitch e env roots arms occs branches dft slot endL ftL rty

-- a terminal leaf: re-match the selected arm's ORIGINAL pattern against the leaf's
-- root word(s) — `roots` (the tree path guarantees it matches) to bind its
-- variables — emitting getelementptr loads for each field a `PVar` deconstructs —
-- then emit the body, store the result, and branch to the end block.
emitLeaf : Emit -> List (String, (String, LTy)) -> List String -> List CArm -> Int -> String -> String -> Ref LTy -> Unit
emitLeaf e env roots arms i slot endL rty = match nthArm arms i
  Some (CArm pat _ body) =>
    let env2 = bindArm e env pat roots body
    match gDispCtxRef.value
      GDispOn _ _ _ _ _ => emitGDispBody e env2 body
      GDispOff => match trmcCtxRef.value
        TrmcOn _ _ _ _ _ _ => emitTrmcBody e env2 body
        TrmcOff =>
          let (bv, bty) = emitExpr e env2 body
          let _ = setRef rty bty
          let _ = emit e "  store i64 \{bv}, ptr \{slot}"
          emit e ("  br label %" ++ endL)
  None => gapU "decision arm index out of range"
-- TRMC (TRMC-DESIGN.md): when a destination-passing loop is active (multi-clause
-- eligible fn — emitClauseTree's clause-selection tree), the clause body is a
-- TAIL leaf → descend it via emitTrmcBody (cons-into-dest+loop / store+exit)
-- instead of computing a value into `slot`.  trmcCtxRef is cleared inside any
-- expression-position `match` (emitDecision), so a nested match's arms still
-- compute values normally.

-- a guarded clause: re-match the arm pattern against `root` (a RANGE/`PRng` arm
-- canonicalizes to PWild in the matrix, so the tree routed here unconditionally
-- and the actual range comparison happens HERE — `emitRefutMatch` branches to
-- `failL` on no-match; an irrefutable pattern emits no test, preserving the
-- plain-`if`-guard case), run the guards (branching to `failL` on any failure),
-- and on all-pass eval the body into `slot`; then emit `failL` and the `fail`
-- subtree (resumes the match at the same column context `occs`).
emitGuardedArm : Emit -> List (String, (String, LTy)) -> List String -> List CArm -> List String -> Pat -> List CGuard -> CExpr -> CTree -> String -> String -> String -> Ref LTy -> Unit
emitGuardedArm e env roots arms occs pat guards body fail slot endL ftL rty =
  let failL = "guardfail" ++ intToString (freshLocal e)
  let env2 = emitRefutArm e env pat roots body failL
  let env3 = emitGuardChain e env2 guards body failL
  -- Under an ACTIVE TRMC loop the guarded arm's body is a TAIL leaf: descend it
  -- via emitTrmcBody (cons-into-dest+loop / plain-tail+loop / base+exit), exactly
  -- like emitLeaf's TrmcOn branch.  Value-emitting it here instead stored into
  -- `slot` and branched to the TAIL match's DEAD end block (`trmcdecend:` … loads
  -- then `unreachable`) — runtime UB, a SILENT MISCOMPILE (native returned `[]`/0
  -- where the interpreter and WasmGC returned the right list; wasm's tail engine
  -- always handled guards).  Fixture: test/stack_fixtures/guard_arm_trmc.mdk.
  let _ = match gDispCtxRef.value
    GDispOn _ _ _ _ _ => emitGDispBody e env3 body
    GDispOff => match trmcCtxRef.value
      TrmcOn _ _ _ _ _ _ => emitTrmcBody e env3 body
      TrmcOff =>
        let (bv, bty) = emitExpr e env3 body
        let _ = setRef rty bty
        let _ = emit e "  store i64 \{bv}, ptr \{slot}"
        emit e ("  br label %" ++ endL)
  let _ = emit e (failL ++ ":")
  emitTree e env roots arms occs slot endL ftL rty fail

-- emit the guard tests left-to-right: a `CGBool` tests a Bool (`True` = the word
-- 3) and branches to `failL` on failure, falling through on success; a
-- `CGBind p <- e` evaluates `e` and refutably matches `p` against it via
-- `emitRefutMatch` (an irrefutable `p` emits no test + just binds; a refutable
-- `Just x <- e` tests the discriminant and branches to `failL` on no-match — G5).
-- Returns the env extended by any `CGBind` bindings (visible to later guards +
-- the body).
emitGuardChain : Emit -> List (String, (String, LTy)) -> List CGuard -> CExpr -> String -> List (String, (String, LTy))
emitGuardChain _ env [] _ _ = env
emitGuardChain e env ((CGBool g)::rest) body failL =
  let (bw, _) = emitExpr e env g
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp eq i64 \{bw}, 3"
  let pass = "guardok" ++ intToString (freshLocal e)
  let _ = emit e "  br i1 \{cmp}, label %\{pass}, label %\{failL}"
  let _ = emit e (pass ++ ":")
  emitGuardChain e env rest body failL
emitGuardChain e env ((CGBind p ex)::rest) body failL =
  let (v, _) = emitExpr e env ex
  let env2 = emitRefutMatch e env p v body failL
  emitGuardChain e env2 rest body failL

-- a clause's guards are now ALL emittable: `CGBool` guards always were; a
-- `CGBind p <- e` is lowered via `emitRefutMatch` whether `p` is irrefutable
-- (just binds) or refutable (`Just x <- e` — runtime discriminant test, G5).
allGuardsEmittable : List CGuard -> Bool
allGuardsEmittable [] = True
allGuardsEmittable ((CGBool _)::rest) = allGuardsEmittable rest
allGuardsEmittable ((CGBind _ _)::rest) = allGuardsEmittable rest

-- ── arm binding against the leaf's ROOT WORD(S) ─────────────────────────────
-- ONE root is the ordinary single scrutinee (a `match` expression, or an arity-1
-- clause chain): re-match the arm pattern against it, exactly as before.
--
-- SEVERAL roots are the un-boxed PARAMETER WORDS of an arity-≥2 clause chain
-- (emitClauseTree).  There, `clauseArm` wrapped the clause's param patterns in a
-- synthetic `PTuple` only because `CArm` carries a single `Pat` — there is NO
-- tuple cell at runtime.  So bind element-wise: pattern i against param word i.
-- This is what retires the per-call argument-tuple `@mdk_alloc`.
bindArm : Emit -> List (String, (String, LTy)) -> Pat -> List String -> CExpr -> List (String, (String, LTy))
bindArm e env pat [v] body = bindPattern e env pat v body
bindArm e env (PTuple ps) roots body = bindEach e env ps roots body
bindArm e env pat (v::_) body = bindPattern e env pat v body
bindArm _ env _ [] _ = env

-- bind each pattern against its OWN word — no cell, hence no `loadField`.  The
-- multi-root counterpart of `bindFields` (which loads field i out of one cell).
bindEach : Emit -> List (String, (String, LTy)) -> List Pat -> List String -> CExpr -> List (String, (String, LTy))
bindEach e env (p::ps) (v::vs) body =
  let env2 = bindPattern e env p v body
  bindEach e env2 ps vs body
bindEach _ env _ _ _ = env

-- the refutable counterpart of `bindArm` (guarded / range-pattern clause): test +
-- bind each param pattern against its own word, branching to `failL` on a miss.
emitRefutArm : Emit -> List (String, (String, LTy)) -> Pat -> List String -> CExpr -> String -> List (String, (String, LTy))
emitRefutArm e env pat [v] body failL = emitRefutMatch e env pat v body failL
emitRefutArm e env (PTuple ps) roots body failL =
  emitRefutEach e env ps roots body failL
emitRefutArm e env pat (v::_) body failL = emitRefutMatch e env pat v body failL
emitRefutArm _ env _ [] _ _ = env

emitRefutEach : Emit -> List (String, (String, LTy)) -> List Pat -> List String -> CExpr -> String -> List (String, (String, LTy))
emitRefutEach e env (p::ps) (v::vs) body failL =
  let env2 = emitRefutMatch e env p v body failL
  emitRefutEach e env2 ps vs body failL
emitRefutEach _ env _ _ _ _ = env

-- bind a pattern's variables against a value word, emitting field loads for the
-- constructor sub-patterns.  Mirrors the binding half of eval.mdk's matchPat, but
-- since the decision tree already proved the shape, it only EXTRACTS (no tests).
-- A `PVar`'s static type is recovered from its first typed use in the arm body
-- (reusing the slice-2b `paramUseTy`); pointer-typed fields default to Int, which
-- is harmless — they only ever flow on as LTy-agnostic call args.
bindPattern : Emit -> List (String, (String, LTy)) -> Pat -> String -> CExpr -> List (String, (String, LTy))
bindPattern _ env PWild _ _ = env
bindPattern _ env (PLit _) _ _ = env
bindPattern e env (PVar x) v body = bindVarTy e env x v body ""
-- A constructor pattern binds each field with the field's DECLARED type (Gap E2):
-- a scalar declared field type (esp. Float/Bool) types the bound var directly,
-- so `match (Rect w h) { … w * h }` does FLOAT arith on the unboxed fields rather
-- than guessing LTInt from body-use.  Non-scalar / unknown fields fall back to the
-- paramUseTy guess (declared name "" passed through bindFieldsDecl).
bindPattern e env (PCon c args) v body =
  bindFieldsDecl e env args (ctorFieldTypeNamesOf c) v body 0
bindPattern e env (PTuple ps) v body = bindFields e env ps v body 0
-- built-in list patterns (slice 5b): a cons cell is a 2-field "Cons" constructor
-- (head = field 0, tail = field 1); the empty-list pattern (a "Nil" cell) binds
-- nothing.  The decision tree already proved the shape (HCons/HNil switch), so
-- this only EXTRACTS — same as the PCon binding path, with [head, tail] fields.
bindPattern e env (PCons h t) v body = bindFields e env [h, t] v body 0
bindPattern _ env (PList []) _ _ = env
-- as-pattern `x@p`: bind `x` to the WHOLE value v (same LTy lookup as PVar),
-- then descend into `p` so its inner vars also bind.
bindPattern e env (PAs x p) v body =
  let env2 = bindVarTy e env x v body ""
  bindPattern e env2 p v body
-- non-empty list-literal pattern `[p::ps]`: v is a Cons cell (the switch proved
-- it); bind the head element (field 0) to `p` and the tail (field 1) to `PList ps`.
bindPattern e env (PList (p::ps)) v body =
  bindFields e env [p, PList ps] v body 0
bindPattern _ env p _ _ =
  gapEnv
    ("unsupported pattern in match arm (slice 3/5b: variable / wildcard / constructor / tuple / cons / nil / int-literal only): " ++ ptag p)
    env

-- bind variable `x` to word `v`.  Its LTy is the DECLARED field type-head name
-- `declName` when that is a known scalar (Gap E2), else the paramUseTy guess from
-- the arm body, else LTInt — so the declared-type override is additive.
bindVarTy : Emit -> List (String, (String, LTy)) -> String -> String -> CExpr -> String -> List (String, (String, LTy))
bindVarTy e env x v body declName =
  let ty = match fieldNameToLTy declName
    Some t => t
    None => match paramUseTy (sigMapOf e) [] x body
      Some t => t
      None => LTInt
  (x, (v, ty))::env

bindFields : Emit -> List (String, (String, LTy)) -> List Pat -> String -> CExpr -> Int -> List (String, (String, LTy))
bindFields _ env [] _ _ _ = env
bindFields e env (p::rest) v body i =
  let f = loadField e v i
  let env2 = bindPattern e env p f body
  bindFields e env2 rest v body (i + 1)

-- like bindFields, but pairs each field pattern with its constructor's DECLARED
-- field type-head name (Gap E2).  A bare PVar/PAs field uses the declared scalar
-- type when known; everything else (nested patterns, unknown/non-scalar fields,
-- missing declared names) falls through to the paramUseTy guess.
bindFieldsDecl : Emit -> List (String, (String, LTy)) -> List Pat -> List String -> String -> CExpr -> Int -> List (String, (String, LTy))
bindFieldsDecl _ env [] _ _ _ _ = env
bindFieldsDecl e env (p::rest) declNames v body i =
  let f = loadField e v i
  let declName = nthOr declNames i ""
  let env2 = bindFieldDecl e env p declName f body
  bindFieldsDecl e env2 rest declNames v body (i + 1)

-- bind one constructor field: a bare PVar/PAs uses its declared scalar type, any
-- other pattern recurses through bindPattern (no scalar to apply at the top).
bindFieldDecl : Emit -> List (String, (String, LTy)) -> Pat -> String -> String -> CExpr -> List (String, (String, LTy))
bindFieldDecl e env (PVar x) declName f body = bindVarTy e env x f body declName
bindFieldDecl e env (PAs x p) declName f body =
  let env2 = bindVarTy e env x f body declName
  bindPattern e env2 p f body
bindFieldDecl e env p _ f body = bindPattern e env p f body

-- ── refutable pattern match (G5 refutable pattern-guards / G6 range patterns) ──
-- Test pattern `p` against value word `v`, branching to `failL` on a MISMATCH;
-- on a match, bind `p`'s variables and FALL THROUGH, returning the extended env
-- (visible to later guards + the body).  Unlike `bindPattern` (which only
-- EXTRACTS at a tree leaf the decision tree already proved), this emits the
-- runtime TEST too — for the two sites the decision tree can't pre-test: a
-- refutable `p <- e` pattern guard (CGBind) and a range/`PRng` arm pattern
-- (which canonicalizes to PWild in the matrix, so the tree routes to it
-- unconditionally and the guarded-arm re-match must do the comparison — exactly
-- mirroring core_ir_eval's `cevalGuardedBody` re-running `matchPat`).
--   Irrefutable patterns (PWild/PVar/PAs/PTuple) emit NO test (reuse
-- bindPattern's extraction); refutable ones (PLit/PRng/PCon/PCons/PList) emit a
-- discriminant/range/equality test + a `br … failL`.  An unsupported shape is a
-- gap (records, nested-refutable beyond this set).
emitRefutMatch : Emit -> List (String, (String, LTy)) -> Pat -> String -> CExpr -> String -> List (String, (String, LTy))
-- irrefutable: no test, just bind (delegates to bindPattern's extraction).
emitRefutMatch e env PWild v body _ = bindPattern e env PWild v body
emitRefutMatch e env (PVar x) v body _ = bindPattern e env (PVar x) v body
emitRefutMatch e env (PAs x p) v body failL =
  let env2 = bindVarTy e env x v body ""
  emitRefutMatch e env2 p v body failL
-- a tuple is irrefutable in SHAPE (the type fixes the arity), but its element
-- patterns can be refutable — recurse element-wise on the loaded fields.
emitRefutMatch e env (PTuple ps) v body failL =
  emitRefutFields e env ps v body failL 0
-- integer / char literal: compare the tagged immediate word directly (both are
-- `n*2+1`); String literal via @mdk_string_eq (tagged Bool result); Bool literal
-- compares the immediate (3/1).
emitRefutMatch e env (PLit (LInt k)) v _ failL =
  let _ = emitWordEqTest e v (intToString (k * 2 + 1)) failL
  env
emitRefutMatch e env (PLit (LChar c)) v _ failL =
  let cp = charCode (arrayGetUnsafe 0 (stringToChars c))
  let _ = emitWordEqTest e v (intToString (cp * 2 + 1)) failL
  env
emitRefutMatch e env (PLit (LBool b)) v _ failL =
  let _ = emitWordEqTest e v (if b then "3" else "1") failL
  env
emitRefutMatch e env (PLit (LString s)) v _ failL =
  let (lit, _) = emitLit e (LString s)
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @mdk_string_eq(i64 \{v}, i64 \{lit})"
  let _ = emitWordEqTest e r "3" failL
  env
-- range pattern (G6): `lo <= v && v <= hi` (`..=`) or `lo <= v && v < hi` (`..`),
-- on the tagged immediate words (the `n*2+1` transform is strictly monotonic for
-- both Int and Char, so the tagged comparison matches the untagged one).  Mirrors
-- eval.mdk's inIntRange/inCharRange: incl ⇒ `<= hi`, else `<= hi-1` ≡ `< hi`.
emitRefutMatch e env (PRng lo hi incl) v _ failL =
  let _ = emitRangeTest e v (rngBound lo) (rngBound hi) incl failL
  env
-- constructor: test the discriminant against the ctor's composite tag; on
-- mismatch branch to failL, on match load fields and recurse element-wise.
emitRefutMatch e env (PCon "True" []) v body failL =
  emitRefutMatch e env (PLit (LBool True)) v body failL
emitRefutMatch e env (PCon "False" []) v body failL =
  emitRefutMatch e env (PLit (LBool False)) v body failL
emitRefutMatch e env (PCon c args) v body failL =
  let tagReg = loadDiscriminant e v
  let _ = emitWordEqTest e tagReg (intToString (cellTag e c)) failL
  emitRefutFields e env args v body failL 0
-- list cons cell: test the discriminant is "Cons", then recurse on head/tail.
emitRefutMatch e env (PCons h t) v body failL =
  let tagReg = loadDiscriminant e v
  let _ = emitWordEqTest e tagReg (intToString (cellTag e "Cons")) failL
  emitRefutFields e env [h, t] v body failL 0
emitRefutMatch e env (PList []) v _ failL =
  let tagReg = loadDiscriminant e v
  let _ = emitWordEqTest e tagReg (intToString (cellTag e "Nil")) failL
  env
emitRefutMatch e env (PList (p::ps)) v body failL =
  let tagReg = loadDiscriminant e v
  let _ = emitWordEqTest e tagReg (intToString (cellTag e "Cons")) failL
  emitRefutFields e env [p, PList ps] v body failL 0
emitRefutMatch e env p _ _ _ =
  gapEnv
    ("refutable pattern in guard/range arm not lowered (variable / wildcard / as / tuple / literal / range / constructor / cons / list only): " ++ ptag p)
    env

-- recurse a refutable test over a cell's leading fields (loadField per index).
emitRefutFields : Emit -> List (String, (String, LTy)) -> List Pat -> String -> CExpr -> String -> Int -> List (String, (String, LTy))
emitRefutFields _ env [] _ _ _ _ = env
emitRefutFields e env (p::rest) v body failL i =
  let f = loadField e v i
  let env2 = emitRefutMatch e env p f body failL
  emitRefutFields e env2 rest v body failL (i + 1)

-- emit `icmp eq word, k`; on inequality branch to failL, else fall through.
emitWordEqTest : Emit -> String -> String -> String -> Unit
emitWordEqTest e word k failL =
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp eq i64 \{word}, \{k}"
  let ok = "refok" ++ intToString (freshLocal e)
  let _ = emit e "  br i1 \{cmp}, label %\{ok}, label %\{failL}"
  emit e (ok ++ ":")

-- emit a range membership test on the tagged word `v`: `v >= loWord` AND
-- (incl ? `v <= hiWord` : `v < hiWord`); any failing comparison branches to failL.
emitRangeTest : Emit -> String -> Int -> Int -> Bool -> String -> Unit
emitRangeTest e v lo hi incl failL =
  let loW = intToString (lo * 2 + 1)
  let hiW = intToString (hi * 2 + 1)
  let n = intToString (freshLocal e)
  let cLo = freshReg e
  let _ = emit e "  \{cLo} = icmp sge i64 \{v}, \{loW}"
  let mid = "rngmid" ++ n
  let _ = emit e "  br i1 \{cLo}, label %\{mid}, label %\{failL}"
  let _ = emit e (mid ++ ":")
  let cHi = freshReg e
  let op = if incl then "sle" else "slt"
  let _ = emit e "  \{cHi} = icmp \{op} i64 \{v}, \{hiW}"
  let ok = "rngok" ++ n
  let _ = emit e "  br i1 \{cHi}, label %\{ok}, label %\{failL}"
  emit e (ok ++ ":")

-- (`rngBound` — the Int codepoint of a range bound literal — is backend-neutral and
-- now lives in backend.emit_support, shared with the WasmGC emitter.)

-- the i-th element of a list, or `dflt` if out of range.
nthOr : List String -> Int -> String -> String
nthOr [] _ dflt = dflt
nthOr (x::rest) i dflt
  | i == 0 = x
  | otherwise = nthOr rest (i - 1) dflt

-- a switch on the focus column (occs head): constructor-LIKE heads (named ADT
-- constructors HCon, built-in list HCons/HNil, and tuples HTuple) test a
-- DISCRIMINANT word (`loadDiscriminant`: an immediate nullary ctor's `ashr 1`
-- payload, or a boxed cell's loaded header — both the composite `cellTag`); int
-- literals test the immediate directly.  A homogeneous switch (the
-- matrix is either all-constructor-like or all-literal in a column), so the first
-- branch's head selects the test kind.  HCons/HNil/HTuple map to the same tag the
-- alloc site stamps (`cellTag` of "Cons"/"Nil"/"$tuple"), so a constructor
-- test reaches them with no special case beyond the name/arity (see conHeadInfo).
emitSwitch : Emit -> List (String, (String, LTy)) -> List String -> List CArm -> List String -> List CTBranch -> CTree -> String -> String -> String -> Ref LTy -> Unit
emitSwitch e env roots arms [] branches dft slot endL ftL rty =
  emitTree e env roots arms [] slot endL ftL rty dft
emitSwitch e env roots arms (foc::rest) [] dft slot endL ftL rty =
  emitTree e env roots arms rest slot endL ftL rty dft
emitSwitch e env roots arms (foc::rest) (branches@((CTBranch (HLit _) _)::_)) dft slot endL ftL rty = emitLitChain e env roots arms foc rest branches dft slot endL ftL rty
emitSwitch e env roots arms (foc::rest) ((CTBranch HUnit sub)::_) dft slot endL ftL rty = emitTree e env roots arms rest slot endL ftL rty sub
emitSwitch e env roots arms (foc::rest) (branches@((CTBranch h _)::_)) dft slot endL ftL rty = match conHeadInfo h
  Some _ =>
    let tagReg = loadDiscriminant e foc
    emitConChain e env roots arms foc rest tagReg branches dft slot endL ftL rty
  None => gapSwitchHead e slot endL
-- HUnit is irrefutable (Unit has exactly one inhabitant): no discriminant test
-- needed.  Drop the focus occurrence and descend into the single branch body.
-- This closes gap #12 (the 6 Arbitrary impls in core.mdk and any user f()=…).

-- gap-TOLERANT terminator (bootstrap): a switch head the spike cannot lower
-- records the gap, then — when recording is ON — still TERMINATES the current block
-- (store "0" placeholder, branch to the decision end) so the module stays
-- structurally valid LLVM even though the function is dead code.  With recording
-- OFF the `gapU` panics first, exactly as before.  The harness byte-diff catches
-- any switch the program actually REACHES (its output would diverge).
-- Note: HUnit is now handled before reaching here (irrefutable — no test needed).
gapSwitchHead : Emit -> String -> String -> Unit
gapSwitchHead e slot endL =
  let _ = gapU "unsupported switch head (slice 5b: constructor / list / tuple / int-literal / unit heads only)"
  let _ = emit e ("  store i64 0, ptr " ++ slot)
  emit e ("  br label %" ++ endL)

-- the name + arity a constructor-LIKE head tests against: a named ADT constructor
-- carries them directly; built-in list HCons/HNil and tuples HTuple reuse the same
-- boxed-cell discipline with the fixed names the alloc sites stamp (emitTuple uses
-- "$tuple"; a user `data … = Cons … | Nil` stamps "Cons"/"Nil").  HLit/HUnit are
-- not constructor-like (HLit goes through emitLitChain; HUnit handled irrefutably
-- before this call — see emitSwitch).
conHeadInfo : CHead -> Option (String, Int)
conHeadInfo (HCon c a) = Some (c, a)
conHeadInfo HCons = Some ("Cons", 2)
conHeadInfo HNil = Some ("Nil", 0)
conHeadInfo (HTuple n) = Some ("$tuple", n)
conHeadInfo _ = None

-- the constructor-switch test chain: compare the discriminant word (immediate or
-- boxed, via loadDiscriminant) against each branch's composite (type, ctor) tag
-- (`cellTag`); on a match, descend with the matched
-- cell's fields as the new leading columns; on exhausting the branches, take the
-- default (focus dropped).
emitConChain : Emit -> List (String, (String, LTy)) -> List String -> List CArm -> String -> List String -> String -> List CTBranch -> CTree -> String -> String -> String -> Ref LTy -> Unit
emitConChain e env roots arms _ rest _ [] dft slot endL ftL rty =
  emitTree e env roots arms rest slot endL ftL rty dft
emitConChain e env roots arms foc rest tagReg ((CTBranch h sub)::more) dft slot endL ftL rty = match conHeadInfo h
  Some (c, a) =>
    let cmp = freshReg e
    let _ = emit e "  \{cmp} = icmp eq i64 \{tagReg}, \{intToString (cellTag e c)}"
    let n = intToString (freshLocal e)
    let yes = "conyes" ++ n
    let next = "connext" ++ n
    let _ = emit e "  br i1 \{cmp}, label %\{yes}, label %\{next}"
    let _ = emit e (yes ++ ":")
    let fields = loadFields e foc a 0
    let _ = emitTree e env roots arms (fields ++ rest) slot endL ftL rty sub
    let _ = emit e (next ++ ":")
    emitConChain e env roots arms foc rest tagReg more dft slot endL ftL rty
  None =>
    let _ = gapU "heterogeneous constructor switch (slice 3: a column is all-constructor or all-literal)"
    let _ = emit e ("  store i64 0, ptr " ++ slot)
    emit e ("  br label %" ++ endL)

-- the literal-switch test chain: compare the focus immediate against each branch's
-- tagged-int constant; a literal head has arity 0, so a match descends with the
-- focus simply dropped (no field columns).
emitLitChain : Emit -> List (String, (String, LTy)) -> List String -> List CArm -> String -> List String -> List CTBranch -> CTree -> String -> String -> String -> Ref LTy -> Unit
emitLitChain e env roots arms _ rest [] dft slot endL ftL rty =
  emitTree e env roots arms rest slot endL ftL rty dft
emitLitChain e env roots arms foc rest ((CTBranch (HLit (LInt k)) sub)::more) dft slot endL ftL rty =
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp eq i64 \{foc}, \{intToString (k * 2 + 1)}"
  let n = intToString (freshLocal e)
  let yes = "lityes" ++ n
  let next = "litnext" ++ n
  let _ = emit e "  br i1 \{cmp}, label %\{yes}, label %\{next}"
  let _ = emit e (yes ++ ":")
  let _ = emitTree e env roots arms rest slot endL ftL rty sub
  let _ = emit e (next ++ ":")
  emitLitChain e env roots arms foc rest more dft slot endL ftL rty
-- Char = immediate codepoint word (cp << 1) | 1 — same comparison shape as Int.
emitLitChain e env roots arms foc rest ((CTBranch (HLit (LChar c)) sub)::more) dft slot endL ftL rty =
  let cp = charCode (arrayGetUnsafe 0 (stringToChars c))
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp eq i64 \{foc}, \{intToString (cp * 2 + 1)}"
  let n = intToString (freshLocal e)
  let yes = "lityes" ++ n
  let next = "litnext" ++ n
  let _ = emit e "  br i1 \{cmp}, label %\{yes}, label %\{next}"
  let _ = emit e (yes ++ ":")
  let _ = emitTree e env roots arms rest slot endL ftL rty sub
  let _ = emit e (next ++ ":")
  emitLitChain e env roots arms foc rest more dft slot endL ftL rty
-- String = boxed cell; equality via the @mdk_string_eq runtime helper, which
-- returns a TAGGED Bool word (3 = True), so branch on `icmp eq i64 r, 3`.
-- Materialize the literal operand the same way emitLit (LString _) does.
emitLitChain e env roots arms foc rest ((CTBranch (HLit (LString s)) sub)::more) dft slot endL ftL rty =
  let (lit, _) = emitLit e (LString s)
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @mdk_string_eq(i64 \{foc}, i64 \{lit})"
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp eq i64 \{r}, 3"
  let n = intToString (freshLocal e)
  let yes = "lityes" ++ n
  let next = "litnext" ++ n
  let _ = emit e "  br i1 \{cmp}, label %\{yes}, label %\{next}"
  let _ = emit e (yes ++ ":")
  let _ = emitTree e env roots arms rest slot endL ftL rty sub
  let _ = emit e (next ++ ":")
  emitLitChain e env roots arms foc rest more dft slot endL ftL rty
emitLitChain _ _ _ _ _ _ _ _ _ _ _ _ =
  gapU "non-Int literal switch (slice 3: no Float / Bool literal heads)"

-- ── small list helpers (slice 3) ────────────────────────────────────────────
takeS : Int -> List a -> List a
takeS n xs
  | n <= 0 = []
  | otherwise = match xs
    [] => []
    y::ys => y :: takeS (n - 1) ys

tailS : List a -> List a
tailS [] = []
tailS (_::xs) = xs

nthArm : List CArm -> Int -> Option CArm
nthArm (a::_) 0 = Some a
nthArm (_::rest) n = nthArm rest (n - 1)
nthArm [] _ = None

-- a readable tag for the unsupported-pattern panic.
ptag : Pat -> String
ptag (PTuple _) = "PTuple"
ptag (PCons _ _) = "PCons"
ptag (PList _) = "PList"
ptag (PAs _ _) = "PAs"
ptag (PRng _ _ _) = "PRng"
ptag (PRec _ _ _) = "PRec"
ptag _ = "?"

-- ── top-level function definitions (slice 2) ────────────────────────────────
-- Each non-`main` top-level binding with parameters becomes an LLVM function
-- `@mdk_<name>(i64 %arg0, …) -> i64`.  Parameters bind to %argN at their
-- INFERRED static type (slice 2b — every param is still an i64 word at the ABI;
-- the type only selects int-vs-float instructions in the body).  The
-- body is emitted in TAIL position so a self-recursive tail call lowers to
-- `musttail call` immediately followed by `ret` (the calling-convention proof:
-- self-recursion guarantees the caller/callee prototypes match, which musttail
-- requires).  Cross-function tail calls lower to an ordinary `call` (still
-- correct; guaranteed-TCO across distinct prototypes is a later increment).
emitFns : Emit -> List CBind -> Unit
emitFns _ [] = ()
emitFns e (b::rest) =
  -- PROGRAM half (issue #118): a prelude bind's define already lives in prelude.o,
  -- so emit it, keep the side effects, and ship only its `declare`.
  let _ = if hiddenBind (bindName b) then
    emitAsDeclares e (_ => emitFn e b)
  else
    emitFn e b
  emitFns e rest

-- (b′) routing first (mirrors wasm's emitRefFnBind precedence: a multi-member
-- group claims its members ahead of Stage-1 TRMC; the shared detection's v5 keeps
-- Stage-1-claimable SINGLETONS out of groups).  A group MEMBER emits nothing
-- standalone — its body lives as basic blocks inside the root's group define
-- (v3/v4 prove nothing outside the group references it); the ROOT emits the whole
-- group define at its own bind position (deterministic emission order).
emitFn : Emit -> CBind -> Unit
emitFn e (CBind name [CClause pats body]) = match dispGroupOf gDispGroupsRef.value name
  Some grp => if dispRootOf grp == name then emitGDispGroup e grp else ()
  None =>
    let (pats2, body2) = etaSaturateMethodBody e name pats body
    if trmcTryFn e name [(pats2, body2)] True then
      ()
    else if allPVar pats2 then
      emitFnClause e name pats2 body2
    else
      emitMultiClauseFn e name [(pats2, body2)]
emitFn e (CBind name (c::rest)) = match dispGroupOf gDispGroupsRef.value name
  Some grp => if dispRootOf grp == name then emitGDispGroup e grp else ()
  None =>
    let clauses = clausePairs (c::rest)
    if trmcTryFn e name clauses False then
      ()
    else
      emitMultiClauseFn e name clauses
emitFn _ (CBind _ []) = gapU "top-level function with no clauses"

-- TRMC branch point (TRMC-DESIGN.md §"Emitter touchpoints" #2): if `name`'s
-- clauses are TRMC-eligible AND its leading-dict count is uniform across clauses
-- (`dictUniformPairs` — a dict-carrying define, i.e. every unannotated
-- polymorphic builder, is admitted; the dict is just another loop slot, and
-- `inferSigs` runs over the LOWERED clauses so `ptys` is already dict-inclusive),
-- emit it as a destination-passing loop and return True; else
-- return False so the caller falls back to the current (stack-growing) codegen.
-- `forceSingle` marks the all-PVar single-clause path so emitTrmcFn descends the
-- CIf-guarded body directly instead of the decision-tree chain.
trmcTryFn : Emit -> String -> List (List Pat, CExpr) -> Bool -> Bool
trmcTryFn e name clauses forceSingle =
  let arity = clauseArity clauses
  let single = forceSingle && allClausesPVar clauses
  if arity > 0 && dictUniformPairs clauses && trmcEligible (isCtor e) (ctorArity e) (SelfByVar name) arity clauses then
    let ptys = match sigLookup e name
      Some (FnSig ts _) => ts
      None => []
    let (spats, sbody) = match clauses
      (ps, b)::_ => (ps, b)
      [] => ([], CLit LUnit)
    let _ = emitTrmcFn e name arity ptys clauses single spats sbody
    True
  else False

-- every clause's params are all plain PVars (the single-clause TRMC ABI shape).
allClausesPVar : List (List Pat, CExpr) -> Bool
allClausesPVar [] = True
allClausesPVar ((pats, _)::rest) = allPVar pats && allClausesPVar rest

-- Gap #50 — eta-SATURATE a point-free constrained binding whose body is an
-- UNDER-APPLIED interface-method (CMethod) or constrained-fn (CDict) occurrence.
-- `callMax : Ord a => a -> a -> a; callMax = max` dict-passes to a clause with ONE
-- param (the `Ord a` dict) and body `CMethod "max" (RDict $d) ..` applied to ZERO
-- value args — but `max` needs TWO.  The lifted define then has arity 1 (dict only)
-- while the call site (emitDictApp `callMax $d x y`) passes dict + the two real
-- args, OVER-applying the define and silently DROPPING the value args → the method
-- dispatch runs with garbage operands (observed: 0).  Append `deficit` fresh value
-- params to the clause and apply them to the body, so (1) the define's arity matches
-- what the call site passes, and (2) the body becomes a SATURATED method application
-- (emitMethod threads the full argOps through the RDict dispatch chain).  General:
-- any method/constrained-fn used point-free under a `=>` constraint (the dict makes
-- it a fn-bind, not the arity-0 value global that an UNCONSTRAINED alias becomes and
-- which already eta-closures correctly via emitVar→emitEtaClosure).
--
-- Gap #12 (3rd wrapper shape — CLam/compose) — a point-free `=>`-constrained binding
-- whose body is a CLOSURE VALUE, not a method spine.  `clamp lo hi = min hi >> max lo`
-- dict-passes to a clause `[$dict, lo, hi]` (arity 3) whose body is the `CLam` compose
-- (`>>`/`<<` desugar to CLam) producing `\x -> max lo (min hi x)`.  The closure is
-- well-formed and dispatches correctly, but the define RETURNS it unapplied (arity 3)
-- while the call site `clamp 0 10 7` passes `$dict + 3 value args` (arity 4) — the
-- extra arg is DROPPED, garbage out (SIGSEGV at -O2).  methodBodyDeficit is 0 (the
-- body is a CLam value, not an under-applied CMethod/CDict head), so the method-spine
-- path can't fire.  The SIGNATURE-arity deficit catches it: a constrained binding's
-- define MUST have arity `dictCount + sigValueArity` (what emitDictApp passes at every
-- call site = leading dict words ++ all declared value args); when the clause binds
-- fewer params (the closure body supplies the rest), append the shortfall as fresh
-- eta params and APPLY them to the body.  applyEtaArgs' `CApp body etaVar` over a CLam
-- body lowers via emitIndirect (closure-alloc → load code_ptr → call), i.e. it applies
-- the returned closure — exactly the missing application.  General for any point-free
-- constrained binding under-applied relative to its declared value arity, whatever the
-- wrapper (bare CLam, or a method/closure spine the method-spine path already covers —
-- both deficits agree there, so the method-spine path is kept as the primary signal).
etaSaturateMethodBody : Emit -> String -> List Pat -> CExpr -> (List Pat, CExpr)
etaSaturateMethodBody e name pats body =
  let mDeficit = methodBodyDeficit e body
  let deficit = etaDeficit e name pats body mDeficit
  if deficit <= 0 then (pats, body)
  else
    let fresh = etaFreshPats deficit (listLen pats)
    (pats ++ fresh, applyEtaArgsTail body fresh)
-- method-spine deficit is the primary signal (#50/#11).  When it is 0 the body may
-- still be a CLOSURE VALUE (CLam from compose `>>`/`<<`) that the define returns
-- unapplied while the call site passes more value args (clamp/#12) — recover that
-- shortfall from the SIGNATURE arity, but ONLY when the tail is a CLam (a bare value
-- return is legitimate point-free currying; eta-applying it would corrupt the body).

-- the eta deficit: the method-spine count when positive, else the signature-arity
-- shortfall when the body tail is a CLam closure value (#12), else 0.
etaDeficit : Emit -> String -> List Pat -> CExpr -> Int -> Int
etaDeficit e name pats body mDeficit
  | mDeficit > 0 = mDeficit
  | tailIsLam body = sigArityDeficit e name pats
  | otherwise = 0

-- does the body's TAIL (through where/let wrappers) reduce to a CLam closure value?
-- Mirrors applyEtaArgsTail's CLet/CLetGroup transparency so a compose under a
-- `where` is still recognised.
tailIsLam : CExpr -> Bool
tailIsLam (CLet _ _ _ b) = tailIsLam b
tailIsLam (CLetGroup _ b) = tailIsLam b
tailIsLam (CLam _ _) = True
tailIsLam _ = False

-- the shortfall between a constrained binding's REQUIRED define arity
-- (`dictCount + sigValueArity` = what every call site passes through emitDictApp)
-- and the clause's actual param count.  0 (or negative) when the clause already
-- binds every dict + value param (the ordinary case) or when no signature is known
-- (fnArity 0 ⇒ no eta-expansion — leave it to the method-spine path).  dictCount is
-- the number of leading `$dict_…` params dict_pass prepended; the remaining pats are
-- the source value params, and a point-free closure body (e.g. compose) makes that
-- count fall short of the declared sigValueArity.
sigArityDeficit : Emit -> String -> List Pat -> Int
sigArityDeficit e name pats =
  let sigArity = fnArity e name
  if sigArity <= 0 then
    0
  else
    maxInt 0 (leadingDictPats pats + sigArity - listLen pats)

-- count of leading `$dict_…` parameter patterns (the dict witnesses dict_pass
-- prepends ahead of the source value params).
leadingDictPats : List Pat -> Int
leadingDictPats ((PVar x)::rest) =
  if isDictParamName x then
    1 + leadingDictPats rest
  else
    0
leadingDictPats _ = 0

-- (`isDictParamName` — a dict-witness parameter name, `$dict_<method>_<slot>` — now
-- lives in backend/emit_support.mdk: BOTH backends need it, for the same reason.)

-- the count of still-unapplied VALUE params of an under-applied method/dict body
-- (0 = saturated / not a method-or-dict head ⇒ no eta-expansion).  A bare CMethod
-- needs its full `methodArityOf`; an applied spine `(CApp.. (CMethod..) a1..ak)`
-- needs `methodArityOf - k`.  A CDict (a `=>`-constrained-function occurrence) head is
-- handled the SAME way (#21 point-free CAF), but its arity needs care: `fnArity name`
-- counts the LEADING DICT params dict_pass prepended as well as the value params, so a
-- CDict's remaining VALUE arity is `fnArity name - <dict count> - <value args applied>`.
-- The dict count is exactly `listLen routes` (the witnesses this occurrence supplies —
-- emitDictApp passes one word per route ahead of the value args).  So a bare
-- `seqp = trav` needs `fnArity trav - routes` eta params and an applied spine
-- `seqp = trav identity` needs `fnArity trav - routes - k` (here 3 - 1 - 1 = 1).  This
-- is the load-bearing case the old "leave CDict alone" rule MISSED: when seqp's define
-- is under-applied (clause `[$dict]`, body `trav identity`) the emitter lowered the body
-- as a DIRECT under-saturated call to trav (emitDictApp forwards only the supplied args)
-- AND gave seqp's define arity 1 (dict only) while the saturated call site `seqp xs`
-- passes dict + xs → the value arg was dropped and trav ran on garbage → SIGSEGV.
-- Appending the deficit as fresh eta params makes BOTH the define arity and the inner
-- trav application saturate, byte-identically to the eta-expanded source form.  (The old
-- comment's "partially-applied CDict passes its supplied args through emitDictApp" is true
-- but does not produce the missing-args closure a point-free define returns — that is the
-- bug.)  A SATURATED clause (`seqp xs = trav identity xs`, deficit 3 - 1 - 2 = 0) is left
-- untouched.
-- A `where`/`let` wrapper (CLet/CLetGroup) is TRANSPARENT to the deficit — the
-- under-applied method may be the let-body TAIL (`maximum = fold step None`
-- desugars its `step` `where`-helper to a CLetGroup around the `fold` spine).  The
-- companion applyEtaArgsTail threads the fresh args into that same tail.
methodBodyDeficit : Emit -> CExpr -> Int
methodBodyDeficit e (CLet _ _ _ b) = methodBodyDeficit e b
methodBodyDeficit e (CLetGroup _ b) = methodBodyDeficit e b
methodBodyDeficit _ (CMethod name _ _ _) = methodArityOf name
methodBodyDeficit e (CDict name routes) =
  maxInt 0 (fnArity e name - listLen routes)
methodBodyDeficit e app =
  let (hd, args) = flattenApp app []
  match hd
    CMethod name _ _ _ => maxInt 0 (methodArityOf name - listLen args)
    CDict name routes =>
      maxInt 0 (fnArity e name - listLen routes - listLen args)
    _ => 0

-- `n` fresh value-param PVars (`__eta_<i>`) numbered after the existing `start`
-- params so paramEnv/paramDecls index them positionally without clashing.
etaFreshPats : Int -> Int -> List Pat
etaFreshPats 0 _ = []
etaFreshPats n start =
  PVar ("__eta_" ++ intToString start) :: etaFreshPats (n - 1) (start + 1)

-- apply the fresh eta params at the body's TAIL position, threading THROUGH any
-- enclosing `where`/`let` wrappers so the let bindings (e.g. `maximum`'s `step`
-- helper) stay in scope for the now-saturated tail application.  Mirrors
-- methodBodyDeficit's CLet/CLetGroup transparency.
applyEtaArgsTail : CExpr -> List Pat -> CExpr
applyEtaArgsTail (CLet r p rhs b) fresh =
  CLet r p rhs (applyEtaArgsTail b fresh)
applyEtaArgsTail (CLetGroup bs b) fresh =
  CLetGroup bs (applyEtaArgsTail b fresh)
applyEtaArgsTail body fresh = applyEtaArgs body fresh

-- apply `body` to each fresh eta param as a CVar (AGlobal — emit resolves a CVar by
-- NAME against the param env, ignoring the Addr), left to right.
applyEtaArgs : CExpr -> List Pat -> CExpr
applyEtaArgs body [] = body
applyEtaArgs body ((PVar x)::rest) =
  applyEtaArgs (CApp body (CVar x AGlobal)) rest
applyEtaArgs body (_::rest) = applyEtaArgs body rest

-- E1a — multi-clause / patterned top-level fns.  Route ordinary fn-binds whose
-- clauses don't all reduce to plain-variable params through the SAME
-- clause-coalescing + decision-tree lowering the impl methods use
-- (`emitClauseTree`).  This closes EMITTER-GAPS #1 (multi-clause top-level fn)
-- and the fn half of #4 (non-variable parameter pattern), since the decision
-- tree binds patterned params via `bindPattern` in each leaf.  The synthetic
-- `aK` scrutinee params are typed from the fn's inferred signature (sigTable /
-- FnSig) so body arithmetic/printing selects the right instruction; absent a
-- sig, params default to Int (the impl-path behaviour).
emitMultiClauseFn : Emit -> String -> List (List Pat, CExpr) -> Unit
emitMultiClauseFn e name clauses =
  let arity = clauseArity clauses
  let ptys = match sigLookup e name
    Some (FnSig ts _) => ts
    None => []
  let env = implParamEnvTyped arity ptys 0
  let _ = beginDefine e
  let _ = emit e "define i64 @mdk_\{name}(\{implParamDecls arity 0}) {"
  let _ = emit e "entry:"
  let _ = emitClauseTree e env arity clauses ""
  let _ = emit e "}"
  emit e ""

-- the (List Pat, CExpr) clause pairs of a fn-bind, in source order.
clausePairs : List CClause -> List (List Pat, CExpr)
clausePairs [] = []
clausePairs ((CClause pats body)::rest) = (pats, body) :: clausePairs rest

-- ── TRMC emit (destination-passing loop) ────────────────────────────────────
-- emit a TRMC-eligible function as an O(1)-stack destination-passing loop.
-- entry sets up the result hole + the mutable destination slot + the mutable
-- param slots, then jumps to the loop head; the loop reloads the params, runs the
-- ORDINARY param dispatch (single-clause: CIf-tail descent; multi-clause: the
-- decision-tree clause chain) whose LEAVES are redirected via trmcCtxRef:
--   • cons leaf:  alloc Cons cell, store head, link cell into `*dest`, advance
--                 `dest` to the cell's tail slot (+16), recompute the recursion
--                 args into the param slots, br loop.
--   • base leaf:  store the value into `*dest`, br exit.
-- exit loads the hole (the final list head) and rets it.  destSlot holds the
-- ADDRESS of the next i64 to fill; the hole's address is the first destination, a
-- linked cell's tail slot (cell+16) each subsequent one.
-- census marker (TMC-parity gate): one deterministic `; tmc: <fn> <mode>`
-- comment per TMC decision — the LLVM peer of wasm's wTmcMarker.
-- test/tmc_census.sh + diff_compiler_tmc_parity.sh extract these to diff both
-- backends' TMC'd source-function sets.  Census-normalized name (leading `mdk_`
-- stripped).
tmcMarker : Emit -> String -> String -> Unit
tmcMarker e sym mode =
  let name = if startsWith "mdk_" sym then
    stringSlice 4 (stringLength sym) sym
  else
    sym
  emit e "; tmc: \{name} \{mode}"

tmcGroupMarkers : Emit -> String -> List String -> Unit
tmcGroupMarkers _ _ [] = ()
tmcGroupMarkers e root (m::rest) =
  let _ = if m == root then
    tmcMarker e m "group-root"
  else
    tmcMarker e m ("group:" ++ root)
  tmcGroupMarkers e root rest

emitTrmcFn : Emit -> String -> Int -> List LTy -> List (List Pat, CExpr) -> Bool -> List Pat -> CExpr -> Unit
emitTrmcFn e name arity ptys clauses single singlePats singleBody =
  let _ = tmcMarker e name "trmc"
  let _ = emitTrmcHeader e ("mdk_" ++ name) arity
  let _ = emitTrmcLoopBody e (SelfByVar name) arity ptys clauses single singlePats singleBody
  let _ = emit e "}"
  emit e ""

-- emit the `define` header + entry label for a TRMC define.  `defineName` is the
-- bare symbol (`mdk_<name>` for a top-level fn, `mdk_impl_<tag>_<method>` for a
-- dispatched impl method).  The caller emits the closing `}` (the impl path's
-- emitGroup already brackets the define).
emitTrmcHeader : Emit -> String -> Int -> Unit
emitTrmcHeader e defineName arity =
  let _ = beginDefine e
  let _ = emit e "define i64 @\{defineName}(\{implParamDecls arity 0}) {"
  emit e "entry:"

-- the REUSABLE TRMC loop body (assumes `define`+`entry:` already emitted; does NOT
-- emit the closing `}`).  Sets up the result hole + mutable destination slot +
-- mutable param slots, jumps to the loop head, reloads the params, runs the
-- ordinary param dispatch (single-clause: CIf-tail descent; multi-clause: the
-- decision-tree clause chain) with the LEAVES redirected via trmcCtxRef (TrmcOn
-- carries the SelfRef so the cons/ctor leaf recognises the self-call — a CVar for
-- a top-level fn, a CMethod for a dispatched impl method), then emits the exit
-- block (load hole, ret).  `self` is the SelfRef the loop recurses on; `slotTys`
-- types each reloaded `aK` scrutinee word (top-level: inferred sig types, padded
-- with LTInt; impl: receiver type at the impl positions, LTInt elsewhere).
emitTrmcLoopBody : Emit -> SelfRef -> Int -> List LTy -> List (List Pat, CExpr) -> Bool -> List Pat -> CExpr -> Unit
emitTrmcLoopBody e self arity slotTys clauses single singlePats singleBody =
  let hole = freshReg e
  let _ = emit e ("  " ++ hole ++ " = alloca i64")
  let destSlot = freshReg e
  let _ = emit e ("  " ++ destSlot ++ " = alloca ptr")
  let _ = emit e "  store ptr \{hole}, ptr \{destSlot}"
  let pslots = trmcEmitParamSlots e arity 0
  let loopL = "trmcloop" ++ intToString (freshLocal e)
  let exitL = "trmcexit" ++ intToString (freshLocal e)
  let _ = emit e ("  br label %" ++ loopL)
  let _ = emit e (loopL ++ ":")
  let reloaded = trmcReloadParams e pslots slotTys 0
  let saved = trmcCtxRef.value
  let _ = setRef trmcCtxRef (TrmcOn self arity destSlot loopL exitL pslots)
  let _ = trmcEmitDispatch e reloaded arity clauses single singlePats reloaded singleBody
  let _ = setRef trmcCtxRef saved
  let _ = emit e (exitL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{hole}"
  emit e ("  ret i64 " ++ r)
-- mutable param slots, seeded from the incoming %argK words.

-- reload the params into fresh regs for THIS iteration (each loop re-executes
-- the loads, so a back-edge to %loop re-reads the mutated slots — valid SSA).

-- one mutable `alloca i64` param slot per arg, seeded from %argK; returns the slot
-- registers in order.
trmcEmitParamSlots : Emit -> Int -> Int -> List String
trmcEmitParamSlots e arity i
  | i >= arity = []
  | otherwise =
    let slot = freshReg e
    let _ = emit e ("  " ++ slot ++ " = alloca i64")
    let _ = emit e "  store i64 %arg\{intToString i}, ptr \{slot}"
    slot :: trmcEmitParamSlots e arity (i + 1)

-- reload each param slot into a fresh reg at the loop head, binding the synthetic
-- `aK` scrutinee name (the name emitClauseTree's scrutinee tuple uses) to the
-- loaded word at the fn's inferred param type.
trmcReloadParams : Emit -> List String -> List LTy -> Int -> List (String, (String, LTy))
trmcReloadParams _ [] _ _ = []
trmcReloadParams e (slot::rest) tys i =
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{slot}"
  let ty = match tys
    t::_ => t
    [] => LTInt
  ("a" ++ intToString i, (r, ty)) :: trmcReloadParams e rest (trmcTail tys) (i + 1)

trmcTail : List a -> List a
trmcTail [] = []
trmcTail (_::xs) = xs

-- run the in-loop param dispatch.  Single-clause (all-PVar params): rename the
-- reloaded `aK` env to the clause's PVar names and descend the body in tail
-- position (emitTrmcBody).  Multi-clause: reuse emitClauseTree's decision-tree
-- chain verbatim — its emitLeaf is TRMC-aware via trmcCtxRef.
trmcEmitDispatch : Emit -> List (String, (String, LTy)) -> Int -> List (List Pat, CExpr) -> Bool -> List Pat -> List (String, (String, LTy)) -> CExpr -> Unit
trmcEmitDispatch e reloaded arity clauses single singlePats aenv singleBody =
  if single then
    let env = trmcRenameEnv singlePats aenv
    emitTrmcBody e env singleBody
  else emitClauseTree e reloaded arity clauses ""

-- bind the clause's PVar param names to the reloaded `aK` operand words (single
-- clause, all-PVar params — the slice-2 ABI requirement also holds for TRMC).
trmcRenameEnv : List Pat -> List (String, (String, LTy)) -> List (String, (String, LTy))
trmcRenameEnv [] _ = []
trmcRenameEnv ((PVar x)::ps) ((_, op)::rest) = (x, op) :: trmcRenameEnv ps rest
trmcRenameEnv (_::ps) (_::rest) = trmcRenameEnv ps rest
trmcRenameEnv _ [] = []

-- single-clause TRMC body in TAIL position: descend CIf/CLet/CLetGroup wrappers,
-- emit each leaf via the TRMC context (cons leaf or base leaf).  Mirrors
-- emitFnBody's CIf descent but redirects the value leaves.  CLet/CLetGroup descend
-- only their (self-free, verified by trmcBodyOk) simple value-binding shapes; any
-- richer let is emitted whole as a base leaf (no self-call inside ⇒ no stack risk).
emitTrmcBody : Emit -> List (String, (String, LTy)) -> CExpr -> Unit
emitTrmcBody e env (CIf c t f) =
  let (cv, _) = emitExpr e env c
  let ci = untagInt e cv
  let cb = freshReg e
  let _ = emit e "  \{cb} = icmp ne i64 \{ci}, 0"
  let n = intToString (freshLocal e)
  let thenL = "trmcthen" ++ n
  let elseL = "trmcelse" ++ n
  let _ = emit e "  br i1 \{cb}, label %\{thenL}, label %\{elseL}"
  let _ = emit e (thenL ++ ":")
  let _ = emitTrmcBody e env t
  let _ = emit e (elseL ++ ":")
  emitTrmcBody e env f
emitTrmcBody e env (CLet False (PVar x) rhs b) =
  let (v, ty) = emitExpr e env rhs
  emitTrmcBody e ((x, (v, ty))::env) b
emitTrmcBody e env (CLetGroup binds b) =
  if allNullaryBinds binds then
    let env2 = trmcBindNullaryGroup e env binds
    emitTrmcBody e env2 b
  else emitTrmcLeaf e env (CLetGroup binds b)
-- B-match-descent (TRMC-DESIGN §"Phase 2 sub-part 3"): a TAIL-position decision
-- tree.  Emit the scrutinee, then walk the SAME decision-tree machinery as
-- emitDecision (emitTree) but keep trmcCtxRef LIVE — so each arm body is descended
-- as a TRMC tail leaf (cons-into-dest+loop / plain-tail-call+loop / base+exit) via
-- emitLeaf's TrmcOn branch, NOT computed into a value slot.  This is the inverse of
-- emitDecision's save+clear, which stays for an EXPRESSION-position match inside an
-- arm (a value-producing match whose arms must store into its own slot).  The
-- result slot + end label passed to emitTree are a DEAD block (no leaf stores into
-- them under TrmcOn — every leaf branches to loopL/exitL); LLVM tolerates the
-- unreachable load/branch (Phase-1 precedent: the nested decision result slot is a
-- dead block).  emitTree is passed "" as its fallthrough label (a non-exhaustive tail
-- match's CTFail is a genuine abort, not the enclosing clause chain's fallthrough).
emitTrmcBody e env (CDecision scrut arms tree) =
  let (sv, _) = emitExpr e env scrut
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "trmcdecend" ++ intToString (freshLocal e)
  let rty = Ref LTInt
  let _ = emitTree e env [sv] arms [sv] slot endL "" rty tree
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{slot}"
  emit e "  unreachable"
-- trmcCtxRef is INTENTIONALLY left LIVE across the tree (the tail arms cons/loop
-- into the active destination); a nested EXPRESSION-position match within an arm
-- body re-enters emitDecision, which saves+clears it for its own value arms.

-- the dead end block: no TrmcOn leaf branches here, but emit it well-formed so a
-- (non-treeable / fallthrough) path that did would still verify.

emitTrmcBody e env ex = emitTrmcLeaf e env ex

-- every binding is a nullary value binding (the descendable let-group shape).
allNullaryBinds : List CBind -> Bool
allNullaryBinds [] = True
allNullaryBinds ((CBind _ [CClause [] _])::rest) = allNullaryBinds rest
allNullaryBinds _ = False

-- emit each nullary value binding left-to-right, threading the env (mirrors
-- emitLetGroup's value-binding arm).
trmcBindNullaryGroup : Emit -> List (String, (String, LTy)) -> List CBind -> List (String, (String, LTy))
trmcBindNullaryGroup _ env [] = env
trmcBindNullaryGroup e env ((CBind name [CClause [] rhs])::rest) =
  let (v, ty) = emitExpr e env rhs
  trmcBindNullaryGroup e ((name, (v, ty))::env) rest
trmcBindNullaryGroup _ env (_::rest) = env

-- a TRMC tail leaf: an eligible ctor-tail conses into the destination + loops; a
-- bare plain-tail self-call (F3 — `None => self …`, no enclosing cons/ctor)
-- recomputes its args + loops with NO cell alloc + NO dest store (iterate on a
-- shorter list); any other leaf stores its value into the destination + exits.
emitTrmcLeaf : Emit -> List (String, (String, LTy)) -> CExpr -> Unit
emitTrmcLeaf e env ex = match trmcCtxRef.value
  TrmcOff => emitValueRet e env ex
  TrmcOn self arity destSlot loopL exitL pslots =>
    if isCtorTail (isCtor e) (ctorArity e) self arity ex then
      emitTrmcCtor e env (ctorTailName ex) (ctorTailLeadFields ex) (consTailArgs ex) (ctorTailSelfIdx ex) destSlot loopL pslots
    else if isSelfSatApp self arity ex then
      emitTrmcTailCall e env ex loopL pslots
    else
      emitTrmcBase e env ex destSlot exitL

-- F3 plain-tail self-call leaf (TRMC-DESIGN §"Phase 2 sub-part 3"): a bare
-- saturated self-call in tail position (`None => filterMap f xs`).  It is the
-- cons-leaf MINUS the cell alloc + head store + dest link/advance — an
-- iterate-on-a-shorter-list step: recompute the recursion args into TEMPS (an arg
-- may read an earlier param), store them into the loop's param slots, and branch
-- back to the loop head.  The destination is left UNCHANGED (this arm produces no
-- list cell), so the next iteration fills the same destination slot — exactly the
-- "drop this element" semantics of `filter`/`filterMap`.  The self-call is NOT
-- emitted as a `call` (that is what removes the stack-growing recursion).
emitTrmcTailCall : Emit -> List (String, (String, LTy)) -> CExpr -> String -> List String -> Unit
emitTrmcTailCall e env ex loopL pslots =
  let args = match flattenApp ex []
    (_, as_) => as_
  let argOps = emitArgs e env args
  -- a dict-carrying (CDict-headed) self-call's args cover only the VALUE params;
  -- its leading dict slots are loop-invariant (identity-forwarded routes,
  -- trmc_analysis dictRoutesForwarded) — store into the LAST |args| slots only.
  let _ = trmcStoreParamSlots e (dropFirstN (lengthS pslots - lengthS argOps) pslots) argOps
  emit e ("  br label %" ++ loopL)

-- ctor leaf (Phase 2 Axis A): alloc a single-constructor cell (header + the
-- non-last fields), link it into the current destination at the SELF-CALL field
-- slot (offset `8*(selfIdx+1)`), advance the destination to that slot, recompute
-- the recursion args into the param slots, and branch back to the loop head.  The
-- self-call is NOT emitted — only the leading fields + arg recomputations are,
-- which is what removes the stack-growing `call`.  Store order (GC-safe,
-- TRMC-DESIGN §"Risk"): alloc → header → leading fields → link-into-dest → advance;
-- the cell's own self-call slot stays ZEROED (GC_malloc returns zeroed memory; an
-- even/null word is never dereferenced by Boehm) until the next iteration fills it.
-- For `::`/Cons this is arity 2, selfIdx 1 (offset 16) — the Phase-1 cons shape.
-- F1(b) SEAM: the dest-offset is COMPUTED from `selfIdx`, not hardcoded "last", so a
-- future self-call-in-any-field is a detection-only patch (this emit is unchanged).
emitTrmcCtor : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> List CExpr -> Int -> String -> String -> List String -> Unit
emitTrmcCtor e env ctor leadFields args selfIdx destSlot loopL pslots =
  let arity = lengthS leadFields + 1
  let leadVals = emitArgs e env leadFields
  let cell = freshReg e
  let _ = emit e "  \{cell} = call ptr @mdk_alloc(i64 \{intToString (8 * (arity + 1))})"
  let _ = emit e "  store i64 \{intToString (cellTag e ctor)}, ptr \{cell}"
  let _ = storeFields e cell leadVals 0
  let cellw = freshReg e
  let _ = emit e "  \{cellw} = ptrtoint ptr \{cell} to i64"
  let d = freshReg e
  let _ = emit e "  \{d} = load ptr, ptr \{destSlot}"
  let _ = emit e "  store i64 \{cellw}, ptr \{d}"
  let newdest = freshReg e
  let _ = emit e "  \{newdest} = getelementptr i8, ptr \{cell}, i64 \{intToString (8 * (selfIdx + 1))}"
  let _ = emit e "  store ptr \{newdest}, ptr \{destSlot}"
  let argOps = emitArgs e env args
  -- dict-carrying self-call: skip the loop-invariant leading dict slots (see
  -- emitTrmcTailCall); non-dict is |argOps| == |pslots| ⇒ drop 0.
  let _ = trmcStoreParamSlots e (dropFirstN (lengthS pslots - lengthS argOps) pslots) argOps
  emit e ("  br label %" ++ loopL)
-- emit the leading (non-last) field values FIRST (left-to-right), then alloc.

-- store the leading fields at their positional offsets (field 0 at +8, …).  The
-- self-call slot (offset 8*(selfIdx+1)) is left zeroed for the link below.

-- advance the destination to THIS cell's self-call field slot (offset
-- 8*(selfIdx+1)) — COMPUTED from the field index (F1(b) seam).

-- recompute every recursion arg into a TEMP first (an arg may read an earlier
-- param), THEN store all temps into the slots, so an in-place store can't clobber
-- a not-yet-read param within the same iteration.

-- store the recomputed arg operands back into the loop's mutable param slots.
trmcStoreParamSlots : Emit -> List String -> List String -> Unit
trmcStoreParamSlots _ [] _ = ()
trmcStoreParamSlots _ _ [] = ()
trmcStoreParamSlots e (slot::slots) (op::ops) =
  let _ = emit e "  store i64 \{op}, ptr \{slot}"
  trmcStoreParamSlots e slots ops

-- base/other leaf: store the value into the current destination, branch to exit.
emitTrmcBase : Emit -> List (String, (String, LTy)) -> CExpr -> String -> String -> Unit
emitTrmcBase e env ex destSlot exitL =
  let (v, _) = emitExpr e env ex
  let d = freshReg e
  let _ = emit e "  \{d} = load ptr, ptr \{destSlot}"
  let _ = emit e "  store i64 \{v}, ptr \{d}"
  emit e ("  br label %" ++ exitL)

-- ════════════════════════════════════════════════════════════════════════════
-- Dispatch-graph (b′) TMC — the LLVM group emit (TMC-parity arc, TRMC-DESIGN
-- §Phase 3).  The shared detection (backend/trmc_analysis.mdk) finds a family of
-- mutually tail-calling fns rooted at ONE external entry (the lexer's `scan`
-- token spine, the offside-rule `layout` family), whose spine conses bottom in
-- saturated member calls.  The WasmGC emit keeps members as separate funcs and
-- loops via `return_call` + per-group dest GLOBALS; LLVM has no `return_call`
-- and `musttail` demands caller/callee prototype equality — but the detection's
-- v4 check PROVES no bind or impl outside the group references a non-root
-- member, so the whole group INLINES into the root's single define:
--   • one labeled entry block per member (`gdisp_<member>:`), its body emitted
--     by the ORDINARY clause machinery (direct tail descent / emitClauseTree)
--     under a live gDispCtxRef, leaves redirected;
--   • every sanctioned tail edge = recompute the callee's args into fresh regs,
--     store them into the shared param slots, `br %gdisp_<callee>` — a plain
--     branch, no call, no musttail (the "heterogeneous member arities" obstacle
--     that deferred the 2026-06-22 port is moot: there is no cross-define edge);
--   • the destination is a LOCAL `alloca` seeded to &hole — the Stage-1 protocol
--     verbatim (no module globals, no first-cell flag; a nested outer call to
--     the root gets a fresh frame, so re-entrancy is safe by construction);
--   • a spine-cons leaf links its 1..N Cons cells into *dest in source order
--     and advances dest through each tail slot before branching to the bottom
--     callee; a base leaf stores its value into *dest and exits (emitTrmcBase).
-- Members emit NO standalone define; the root's public `@mdk_<root>` IS the
-- group define, so external callers and fn-as-value eta closures over the root
-- are untouched.

-- the member's basic-block label inside the group define (member names are
-- unique within a group; LLVM labels are function-scoped, so two groups may
-- reuse the scheme).
gDispLabel : String -> String
gDispLabel m = "gdisp_" ++ m

-- emit the whole group define, rooted at `@mdk_<root>` with the root's real
-- params.  U = max member arity shared slots; slots 0..rootArity seed from
-- %argK, the rest from 0 (never read before a store — zeroed only so no undef
-- load exists).
emitGDispGroup : Emit -> DispGroup -> Unit
emitGDispGroup e grp =
  let root = dispRootOf grp
  let members = dispMembersOf grp
  let binds = gDispBindsRef.value
  let rootArity = gDispFnArity root
  let u = gDispMaxArity members 0
  let _ = tmcGroupMarkers e root members
  let _ = emitTrmcHeader e ("mdk_" ++ root) rootArity
  let uslots = gDispEmitSlots e u rootArity 0
  let hole = freshReg e
  let _ = emit e ("  " ++ hole ++ " = alloca i64")
  let destSlot = freshReg e
  let _ = emit e ("  " ++ destSlot ++ " = alloca ptr")
  let _ = emit e "  store ptr \{hole}, ptr \{destSlot}"
  let exitL = "gdispexit" ++ intToString (freshLocal e)
  let _ = emit e ("  br label %" ++ gDispLabel root)
  let saved = gDispCtxRef.value
  let _ = setRef gDispCtxRef (GDispOn root members uslots destSlot exitL)
  let _ = emitGDispMembers e binds members
  let _ = setRef gDispCtxRef saved
  let _ = emit e (exitL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{hole}"
  let _ = emit e ("  ret i64 " ++ r)
  let _ = emit e "}"
  emit e ""

-- one shared `alloca i64` slot per uniform param position, seeded from the
-- root's %argK (< rootArity) or 0.
gDispEmitSlots : Emit -> Int -> Int -> Int -> List String
gDispEmitSlots e u rootArity i
  | i >= u = []
  | otherwise =
    let slot = freshReg e
    let _ = emit e ("  " ++ slot ++ " = alloca i64")
    let seed = if i < rootArity then "%arg" ++ intToString i else "0"
    let _ = emit e "  store i64 \{seed}, ptr \{slot}"
    slot :: gDispEmitSlots e u rootArity (i + 1)

gDispMaxArity : List String -> Int -> Int
gDispMaxArity [] acc = acc
gDispMaxArity (m::rest) acc =
  let a = gDispFnArity m
  gDispMaxArity rest (maxInt a acc)

emitGDispMembers : Emit -> List CBind -> List String -> Unit
emitGDispMembers _ _ [] = ()
emitGDispMembers e binds (m::rest) =
  let _ = match dispFindBind binds m
    Some b => emitGDispMember e b
    None => gapU ("(b') group member without a bind: " ++ m)
  emitGDispMembers e binds rest

-- a member's entry block: reload its arity-many slots (typed from its inferred
-- sig, LTInt-padded — the same trmcReloadParams the Stage-1 loop head uses,
-- binding the synthetic `aK` scrutinee names), then run the ordinary dispatch:
-- a single all-PVar clause descends its body directly (emitGDispBody); anything
-- else reuses emitClauseTree verbatim (its emitLeaf/emitGuardedArm are
-- gDispCtx-aware).  Each member's clause chain is emitted with "" as its outer
-- fallthrough (each member manages its own fallthroughs).
emitGDispMember : Emit -> CBind -> Unit
emitGDispMember e (CBind name clauses) = match gDispCtxRef.value
  GDispOff => gapU "(b') member emit with no active group context"
  GDispOn _ _ uslots _ _ =>
    let arity = clauseArityOf clauses
    let ptys = match sigLookup e name
      Some (FnSig ts _) => ts
      None => []
    let _ = emit e (gDispLabel name ++ ":")
    let reloaded = trmcReloadParams e (gDispTake arity uslots) ptys 0
    let pairs = clausePairs clauses
    match pairs
      [(pats, body)] =>
        if allPVar pats then
          emitGDispBody e (trmcRenameEnv pats reloaded) body
        else
          emitClauseTree e reloaded arity pairs ""
      _ => emitClauseTree e reloaded arity pairs ""

gDispTake : Int -> List a -> List a
gDispTake n _
  | n <= 0 = []
gDispTake _ [] = []
gDispTake n (x::rest) = x :: gDispTake (n - 1) rest

-- member-body TAIL descent.  Mirrors the shared detection's wrapper set EXACTLY
-- (dispLeavesOk: CIf / non-rec CLet PVar+PWild / CBlock / CDecision), so the
-- emit redirects precisely the leaves the detection sanctioned.  A CLetGroup is
-- deliberately NOT descended (the detection treats it as a leaf: base if
-- member-free, else the group was rejected).
emitGDispBody : Emit -> List (String, (String, LTy)) -> CExpr -> Unit
emitGDispBody e env (CIf c t f) =
  let (cv, _) = emitExpr e env c
  let ci = untagInt e cv
  let cb = freshReg e
  let _ = emit e "  \{cb} = icmp ne i64 \{ci}, 0"
  let n = intToString (freshLocal e)
  let thenL = "gdispthen" ++ n
  let elseL = "gdispelse" ++ n
  let _ = emit e "  br i1 \{cb}, label %\{thenL}, label %\{elseL}"
  let _ = emit e (thenL ++ ":")
  let _ = emitGDispBody e env t
  let _ = emit e (elseL ++ ":")
  emitGDispBody e env f
emitGDispBody e env (CLet False (PVar x) rhs b) =
  let (v, ty) = emitExpr e env rhs
  emitGDispBody e ((x, (v, ty))::env) b
emitGDispBody e env (CLet False PWild rhs b) =
  let _ = emitExpr e env rhs
  emitGDispBody e env b
emitGDispBody e env (CBlock stmts) = emitGDispBlock e env stmts
-- tail-position decision tree: keep gDispCtxRef LIVE across the tree (each arm
-- body is a redirected tail leaf via emitLeaf/emitGuardedArm), save+null the
-- fallthrough label (a non-exhaustive tail match's CTFail is a genuine abort).
-- The result slot + end label are a DEAD block (no leaf stores there under an
-- active group ctx) — the Stage-1 B-match precedent.
emitGDispBody e env (CDecision scrut arms tree) =
  let (sv, _) = emitExpr e env scrut
  let slot = freshReg e
  let _ = emit e ("  " ++ slot ++ " = alloca i64")
  let endL = "gdispdecend" ++ intToString (freshLocal e)
  let rty = Ref LTInt
  let _ = emitTree e env [sv] arms [sv] slot endL "" rty tree
  let _ = emit e (endL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{slot}"
  emit e "  unreachable"
emitGDispBody e env ex = emitGDispLeaf e env ex

-- block TAIL descent: emit the prefix statements exactly as emitBlock does
-- (minus its float-let unboxing specialization — a boxed binding is the
-- universal rep, semantics unchanged), then descend the final CSExpr.  The
-- detection only sanctions blocks whose LAST statement is a CSExpr
-- (lastStmtExpr); any other tail form falls to the base leaf (member-free by
-- detection, so emitting it whole as a value is sound).
emitGDispBlock : Emit -> List (String, (String, LTy)) -> List CStmt -> Unit
emitGDispBlock e env [CSExpr ex] = emitGDispBody e env ex
emitGDispBlock e env ((CSExpr ex)::rest) =
  let _ = emitExpr e env ex
  emitGDispBlock e env rest
emitGDispBlock e env ((CSLet _ (PVar x) ex)::rest) =
  let (v, ty) = emitExpr e env ex
  emitGDispBlock e ((x, (v, ty))::env) rest
emitGDispBlock e env ((CSLet _ PWild ex)::rest) =
  let _ = emitExpr e env ex
  emitGDispBlock e env rest
emitGDispBlock e env ((CSLet _ pat ex)::rest) =
  let (v, _) = emitExpr e env ex
  if refutableCsLet e pat then
    let env2 = emitRefutableCsLet e env pat v
    emitGDispBlock e env2 rest
  else
    let env2 = bindPattern e env pat v (CBlock rest)
    emitGDispBlock e env2 rest
emitGDispBlock e env ((CSAssign x ex)::rest) =
  let (v, ty) = emitExpr e env ex
  emitGDispBlock e ((x, (v, ty))::env) rest
emitGDispBlock e env stmts = emitGDispLeaf e env (CBlock stmts)

-- a group TAIL leaf.  Three classes, matching the detection's dispLeafOk:
--   • spine cons `<h1> :: … :: f <sat>` (f a member) — link the 1..N cells into
--     the dest in source order, then edge to `f`;
--   • bare saturated member call — edge to `f` (dest threads through untouched);
--   • anything else — a base value: close the dest + exit (emitTrmcBase; the
--     detection guarantees it references no member, so no member symbol — which
--     does not exist — can be emitted).
emitGDispLeaf : Emit -> List (String, (String, LTy)) -> CExpr -> Unit
emitGDispLeaf e env ex = match gDispCtxRef.value
  GDispOff => emitValueRet e env ex
  GDispOn _ members uslots destSlot exitL => match gDispSpine e members ex
    Some (heads, f, args) =>
      let _ = emitGDispCells e env heads destSlot
      emitGDispEdge e env f args uslots
    None => match flattenApp ex []
      (CVar f0 _, args) =>
        let f = canonFnName e f0
        let fa = gDispFnArity f
        if contains f members && fa >= 0 && listLen args == fa then
          emitGDispEdge e env f args uslots
        else
          emitTrmcBase e env ex destSlot exitL
      _ => emitTrmcBase e env ex destSlot exitL

-- the shared spine classifier, closed over this emitter's hooks (identical to
-- what the detection ran, so emit and detection agree leaf-by-leaf).
gDispSpine : Emit -> List String -> CExpr -> Option (List CExpr, String, List CExpr)
gDispSpine e members ex = dispSpineParts
  (n => canonFnName e n)
  (n => gDispIsFn n)
  (n => gDispFnArity n)
  (f => contains f members)
  ex

-- link one Cons cell per peeled head into the destination, in source order:
-- head value → alloc 24 → tag Cons → store head at +8 → link the cell word into
-- *dest → advance dest to THIS cell's tail slot (+16).  The tail word stays
-- zeroed (GC_malloc) until the next cell/base fills it — the Stage-1 GC-safety
-- argument verbatim.
emitGDispCells : Emit -> List (String, (String, LTy)) -> List CExpr -> String -> Unit
emitGDispCells _ _ [] _ = ()
emitGDispCells e env (h::rest) destSlot =
  let hv = emitArgs e env [h]
  let cell = freshReg e
  let _ = emit e "  \{cell} = call ptr @mdk_alloc(i64 24)"
  let _ = emit e "  store i64 \{intToString (cellTag e "Cons")}, ptr \{cell}"
  let _ = storeFields e cell hv 0
  let cellw = freshReg e
  let _ = emit e "  \{cellw} = ptrtoint ptr \{cell} to i64"
  let d = freshReg e
  let _ = emit e "  \{d} = load ptr, ptr \{destSlot}"
  let _ = emit e "  store i64 \{cellw}, ptr \{d}"
  let newdest = freshReg e
  let _ = emit e "  \{newdest} = getelementptr i8, ptr \{cell}, i64 16"
  let _ = emit e "  store ptr \{newdest}, ptr \{destSlot}"
  emitGDispCells e env rest destSlot

-- a sanctioned tail edge: recompute the callee's args into fresh regs FIRST (an
-- arg may read the current member's params), store them into the shared slots
-- (positional, first arity_f slots), branch to the callee's entry block.  NO
-- call — the branch IS the loop edge.
emitGDispEdge : Emit -> List (String, (String, LTy)) -> String -> List CExpr -> List String -> Unit
emitGDispEdge e env f args uslots =
  let argOps = emitArgs e env args
  let _ = trmcStoreParamSlots e uslots argOps
  emit e ("  br label %" ++ gDispLabel f)

-- the clause-derived fn-arity table (wasm's collectFnArities contract: name →
-- first clause's param count) — the detection's isFn/fa hooks read it.
gDispFnArsOf : List CBind -> List (String, Int)
gDispFnArsOf [] = []
gDispFnArsOf ((CBind n cs)::rest) = (n, clauseArityOf cs) :: gDispFnArsOf rest

-- would the LLVM Stage-1 self-TMC (trmcTryFn's gate) already claim this fn?
-- (the shared dispValidate v5 keeps such singletons on Stage-1.)
gDispStage1Claims : Emit -> String -> Int -> List CClause -> Bool
gDispStage1Claims e name arity clauses =
  let pairs = clausePairs clauses
  arity > 0
    && dictUniformPairs pairs
    && trmcEligible (isCtor e) (ctorArity e) (SelfByVar name) arity pairs

-- keep only groups whose every SINGLE-CLAUSE member has eta deficit 0 (the
-- multi-clause emitFn arm never eta-saturates, so multi-clause members are
-- always stable).  A deficit member's ordinary define would gain params
-- (etaSaturateMethodBody), diverging from the group's clause-arity slot
-- protocol — no real group contains one (members are non-dict with cons/call/
-- base tails), but reject deterministically rather than assume.
gDispKeepEtaStable : Emit -> List CBind -> List DispGroup -> List DispGroup
gDispKeepEtaStable _ _ [] = []
gDispKeepEtaStable e binds (g::rest) =
  if gDispMembersEtaStable e binds (dispMembersOf g) then
    g :: gDispKeepEtaStable e binds rest
  else
    gDispKeepEtaStable e binds rest

gDispMembersEtaStable : Emit -> List CBind -> List String -> Bool
gDispMembersEtaStable _ _ [] = True
gDispMembersEtaStable e binds (m::rest) = match dispFindBind binds m
  Some (CBind name [CClause pats body]) => etaDeficit e name pats body (methodBodyDeficit e body) == 0
    && gDispMembersEtaStable e binds rest
  Some _ => gDispMembersEtaStable e binds rest
  None => False

-- drop group members from the float worker-wrapper advertisement set.
gDispDropMembers : List (String, (Int, List Int)) -> List (String, (Int, List Int))
gDispDropMembers [] = []
gDispDropMembers ((n, v)::rest) =
  let isMember = gDispIsMember n
  if isMember then gDispDropMembers rest else (n, v) :: gDispDropMembers rest

-- like implParamEnv, but types each synthetic `aK` scrutinee param from the fn's
-- inferred signature param types (FnSig ts) instead of defaulting to LTInt.
-- Params past the signature length (or with no sig) fall back to LTInt.
implParamEnvTyped : Int -> List LTy -> Int -> List (String, (String, LTy))
implParamEnvTyped n _ i
  | i >= n = []
implParamEnvTyped n (ty::tys) i =
  ("a" ++ intToString i, ("%arg" ++ intToString i, ty)) ::
    implParamEnvTyped n tys (i + 1)
implParamEnvTyped n [] i =
  ("a" ++ intToString i, ("%arg" ++ intToString i, LTInt)) ::
    implParamEnvTyped n [] (i + 1)

-- emit one variable-pattern function clause (the slice-2 path).
-- ── worker-wrapper float-param unboxing (perf/float-param-unbox) ─────────────
-- A self-recursive float-accumulator fn (`f acc n | n==0 = acc | otherwise =
-- f (acc + e) (n-1)`) boxes `acc` at every self-call (i64 ABI) then unboxes it
-- next iteration; clang TCO-loops the self-call, so the box is the only cost.
-- Emit a WORKER `@mdk_<name>__fw(double acc, …)` that carries float params as
-- native `double` (self-calls musttail back into it with unboxed args → NO box per
-- iteration) + a WRAPPER `@mdk_<name>(i64 …)` (the original ABI) that unboxes float
-- params, calls the worker, boxes the result. External callers + eta/dispatch see
-- the unchanged wrapper. Scope: single-clause, all-PVar, non-dict, ≥1 Float param,
-- Float return, body is CIf/value only (every leaf is a full-arity tail self-call
-- OR a self-free value). A `match`-bodied fn (CDecision) falls back to normal
-- codegen (safe; the CDecision-double extension is future work).
floatPositions : List LTy -> Int -> List Int
floatPositions [] _ = []
floatPositions (LTFloat::rest) i = i :: floatPositions rest (i + 1)
floatPositions (_::rest) i = floatPositions rest (i + 1)

elemInt : Int -> List Int -> Bool
elemInt _ [] = False
elemInt n (x::rest) = if n == x then True else elemInt n rest

hasFloatPty : List LTy -> Bool
hasFloatPty [] = False
hasFloatPty (LTFloat::_) = True
hasFloatPty (_::rest) = hasFloatPty rest

-- a 2-arm `match scrut { lit => A ; _ => B }` (literal pattern then wildcard, no
-- guards) as the equivalent `if scrut == lit then A else B`, so a match-bodied float
-- accumulator (the idiomatic floatsum form) reuses the CIf worker machinery. None for
-- any other shape → the function stays ineligible / falls back. == on a scalar literal
-- is value-equality (emitCmp routes Int/Char/Bool/String), matching match semantics.
decisionToIf : CExpr -> List CArm -> Option CExpr
decisionToIf scrut ((CArm (PLit l) [] a)::(CArm PWild [] b)::[]) =
  Some (CIf (CBinPrim "==" scrut (CLit l) "") a b)
decisionToIf _ _ = None

-- `self` does not occur free in `ex` (so the leaf is an ordinary value, safe to
-- compute via the wrapper-ABI path).
selfFreeW : String -> CExpr -> Bool
selfFreeW self ex = not (contains self (freeVars [] ex))

-- every leaf of the body is either a full-arity tail self-call or a self-free value;
-- descends CIf and a desugarable 2-arm match. Any self outside a tail self-call ⇒
-- ineligible.
floatWorkerOk : String -> Int -> CExpr -> Bool
floatWorkerOk self arity (CIf c t f) = selfFreeW self c
  && floatWorkerOk self arity t
  && floatWorkerOk self arity f
floatWorkerOk self arity (CDecision scrut arms tree) = match decisionToIf scrut arms
  Some cif => floatWorkerOk self arity cif
  None => selfFreeW self (CDecision scrut arms tree)
floatWorkerOk self arity (CBlock stmts) = floatWorkerBlockOk self arity stmts
floatWorkerOk self arity ex = match flattenApp ex []
  (CVar f _, args) =>
    if f == self then
      lengthS args == arity
    else
      selfFreeW self ex
  _ => selfFreeW self ex

-- a let-block body is worker-eligible if every leading CSLet binds a plain var with a
-- self-free RHS (the lets are evaluated before the tail) and the final stmt is a
-- CSExpr that is itself worker-eligible (the tail). Any other stmt shape (assign,
-- let-else, non-PVar pattern, non-CSExpr final) disqualifies → fall back.
floatWorkerBlockOk : String -> Int -> List CStmt -> Bool
floatWorkerBlockOk self arity ((CSExpr ex)::[]) = floatWorkerOk self arity ex
floatWorkerBlockOk self arity ((CSLet _ (PVar _) rhs)::rest) = selfFreeW self rhs
  && floatWorkerBlockOk self arity rest
floatWorkerBlockOk _ _ _ = False

floatWorkerEligible : Emit -> String -> List Pat -> List LTy -> CExpr -> Bool
floatWorkerEligible e name pats ptys body =
  let rty = match sigLookup e name
    Some (FnSig _ r) => r
    None => LTInt
  let isFloatRet = match rty
    LTFloat => True
    _ => False
  allPVar pats
    && leadingDictPats pats == 0
    && hasFloatPty ptys
    && isFloatRet
    && contains name (freeVars [] body)
    && floatWorkerOk name (lengthS pats) body

-- a float-RETURNING fn that gets a `$fw` double-ABI variant for float-context callers
-- (no self-recursive / float-param requirement — return-unboxing alone is a win).
-- Single-clause, all-PVar, non-dict, float return, body shape `emitFnBodyD` handles.
floatFwEligible : Emit -> String -> List Pat -> List LTy -> CExpr -> Bool
floatFwEligible e name pats ptys body =
  let rty = match sigLookup e name
    Some (FnSig _ r) => r
    None => LTInt
  let isFloatRet = match rty
    LTFloat => True
    _ => False
  allPVar pats
    && leadingDictPats pats == 0
    && isFloatRet
    && floatWorkerOk name (lengthS pats) body

-- module set of fns that have an emitted `@mdk_<name>__fw` (name → (arity, float
-- param positions)), for emitFloatLeaf to reroute float-context calls. Built once
-- per program (call sites may precede the callee's emission).
floatFwSetRef : Ref (List (String, (Int, List Int)))
floatFwSetRef = Ref []

-- collect the float-fw set from the program's single-clause function binds.
collectFloatFw : Emit -> List CBind -> List (String, (Int, List Int))
collectFloatFw _ [] = []
collectFloatFw e ((CBind name ((CClause pats body)::[]))::rest) =
  let ptys = match sigLookup e name
    Some (FnSig ts _) => ts
    None => allInt pats
  if floatFwEligible e name pats ptys body then
    (name, (lengthS pats, floatPositions ptys 0)) :: collectFloatFw e rest
  else
    collectFloatFw e rest
collectFloatFw e (_::rest) = collectFloatFw e rest

-- module set of top-level fns that RETURN a float-returning closure (their single
-- clause body is a CLam whose body evidently returns Float, e.g.
-- `mkAdd base = (x => x + base)`).  A SATURATED call to such a fn yields a closure
-- whose own saturated call returns Float — so `recordFloatClosureResult` records the
-- call-result word in closureRetTyRef, letting indirectRetTy type `f 1.0` LTFloat
-- for `let f = mkAdd 100.0`.  Closes the returned-from-fn case of the closure-call-
-- result float-arith bug (the direct `let f = (x=>…)` case is handled at emitLam).
floatClosureFnsRef : Ref (List String)
floatClosureFnsRef = Ref []

collectFloatClosureFns : Emit -> List CBind -> List String
collectFloatClosureFns _ [] = []
collectFloatClosureFns e ((CBind name ((CClause pats body)::[]))::rest) =
  if isFloatClosureBody e name pats body then
    name :: collectFloatClosureFns e rest
  else
    collectFloatClosureFns e rest
collectFloatClosureFns e (_::rest) = collectFloatClosureFns e rest

isFloatClosureBody : Emit -> String -> List Pat -> CExpr -> Bool
isFloatClosureBody e name pats (CLam _ lamBody) =
  let ptys = match sigLookup e name
    Some (FnSig ts _) => ts
    None => allInt pats
  bodyFloatRet (paramEnv pats ptys 0) lamBody
isFloatClosureBody e name pats _ = False

-- after a SATURATED known-fn call whose callee returns a float-returning closure,
-- record the result word as a float-returning closure (closureRetTyRef) so a later
-- indirect call of it types its result LTFloat.
recordFloatClosureResult : Emit -> String -> Int -> Int -> (String, LTy) -> Unit
recordFloatClosureResult e fname argc arity (reg, _) =
  if argc == arity && contains fname floatClosureFnsRef.value then
    setRef closureRetTyRef ((reg, LTFloat)::closureRetTyRef.value)
  else
    ()

-- param decls with `double` at the float positions, `i64` elsewhere.
paramDeclsD : List Pat -> List Int -> Int -> String
paramDeclsD [] _ _ = ""
paramDeclsD ((PVar _)::rest) fp i =
  let ty = if elemInt i fp then "double" else "i64"
  let sep = match rest
    [] => ""
    _ => ", "
  "\{ty} %arg\{intToString i}\{sep}\{paramDeclsD rest fp (i + 1)}"
paramDeclsD _ _ _ = panic "llvm: float-worker params must be plain variables"

-- env for the worker: float params are unboxed doubles (LTFloatU → %argN holds a
-- double); other params keep their LTy.
paramEnvD : List Pat -> List LTy -> List Int -> Int -> List (String, (String, LTy))
paramEnvD [] _ _ _ = []
paramEnvD ((PVar x)::rest) (ty::tys) fp i =
  let lty = if elemInt i fp then LTFloatU else ty
  (x, ("%arg" ++ intToString i, lty)) :: paramEnvD rest tys fp (i + 1)
paramEnvD ((PVar x)::rest) [] fp i =
  (x, ("%arg" ++ intToString i, LTInt)) :: paramEnvD rest [] fp (i + 1)
paramEnvD _ _ _ _ = panic "llvm: float-worker params must be plain variables"

-- a self-call's argument operands: `double <d>` at float positions, `i64 <w>` else,
-- emitted left-to-right.
emitWorkerArgs : Emit -> List (String, (String, LTy)) -> List Int -> Int -> List CExpr -> String
emitWorkerArgs _ _ _ _ [] = ""
emitWorkerArgs e env fp i (a::rest) =
  let op = match elemInt i fp
    True => "double " ++ emitFloatD e env a
    False =>
      let (w, _) = emitExpr e env a
      "i64 " ++ w
  let sep = match rest
    [] => ""
    _ => ", "
  op ++ sep ++ emitWorkerArgs e env fp (i + 1) rest

-- the worker body in tail position: CIf recurses; a full-arity tail self-call
-- musttails into the worker (NO box); any other (self-free) value rets a double.
emitFnBodyD : Emit -> List (String, (String, LTy)) -> String -> String -> List Int -> Int -> CExpr -> Unit
emitFnBodyD e env self worker fp arity (CIf c t f) =
  let (cv, _) = emitExpr e env c
  let ci = untagInt e cv
  let cb = freshReg e
  let _ = emit e "  \{cb} = icmp ne i64 \{ci}, 0"
  let n = intToString (freshLocal e)
  let thenL = "then" ++ n
  let elseL = "else" ++ n
  let _ = emit e "  br i1 \{cb}, label %\{thenL}, label %\{elseL}"
  let _ = emit e (thenL ++ ":")
  let _ = emitFnBodyD e env self worker fp arity t
  let _ = emit e (elseL ++ ":")
  emitFnBodyD e env self worker fp arity f
emitFnBodyD e env self worker fp arity (CDecision scrut arms tree) = match decisionToIf scrut arms
  Some cif => emitFnBodyD e env self worker fp arity cif
  None =>
    let d = emitFloatD e env (CDecision scrut arms tree)
    emit e ("  ret double " ++ d)
emitFnBodyD e env self worker fp arity (CBlock stmts) =
  emitFnBodyDBlock e env self worker fp arity stmts
emitFnBodyD e env self worker fp arity other =
  emitTailLeafD e env self worker fp arity other (flattenApp other [])

-- emit a worker-mode let-block: bind each leading CSLet (float RHS → unboxed double
-- LTFloatU, same as emitBlock; else normal), then emit the final CSExpr in tail
-- (double-return) mode. Gated by floatWorkerBlockOk, so the shape is guaranteed.
emitFnBodyDBlock : Emit -> List (String, (String, LTy)) -> String -> String -> List Int -> Int -> List CStmt -> Unit
emitFnBodyDBlock e env self worker fp arity ((CSExpr ex)::[]) =
  emitFnBodyD e env self worker fp arity ex
emitFnBodyDBlock e env self worker fp arity ((CSLet _ (PVar x) rhs)::rest) =
  if staticIsFloat env rhs then
    let d = emitFloatD e env rhs
    emitFnBodyDBlock e ((x, (d, LTFloatU))::env) self worker fp arity rest
  else
    let (v, ty) = emitExpr e env rhs
    emitFnBodyDBlock e ((x, (v, ty))::env) self worker fp arity rest
emitFnBodyDBlock e env _ _ _ _ _ =
  gapU
    "float-worker block: unexpected statement shape (should be gated by floatWorkerBlockOk)"

emitTailLeafD : Emit -> List (String, (String, LTy)) -> String -> String -> List Int -> Int -> CExpr -> (CExpr, List CExpr) -> Unit
emitTailLeafD e env self worker fp arity _ (CVar f0 _, args)
  | f0 == self && lengthS args == arity =
    let ops = emitWorkerArgs e env fp 0 args
    let r = freshReg e
    let _ = emit e "  \{r} = musttail call double @mdk_\{worker}(\{ops})"
    emit e ("  ret double " ++ r)
emitTailLeafD e env _ _ _ _ other _ =
  let d = emitFloatD e env other
  emit e ("  ret double " ++ d)

-- the wrapper's call args: `double <unbox %argN>` at float positions, `i64 %argN` else.
wrapperCallArgs : Emit -> List Int -> Int -> List Pat -> String
wrapperCallArgs _ _ _ [] = ""
wrapperCallArgs e fp i (_::rest) =
  let op = match elemInt i fp
    True => "double " ++ unboxFloat e ("%arg" ++ intToString i)
    False => "i64 %arg" ++ intToString i
  let sep = match rest
    [] => ""
    _ => ", "
  op ++ sep ++ wrapperCallArgs e fp (i + 1) rest

-- emit ONLY the double-ABI `$fw` variant of a float fn (no wrapper) — used both by
-- emitFloatWorkerFn (self-recursive: wrapper added separately) and for non-recursive
-- float fns emitted alongside their original i64-ABI definition.
emitFloatFwOnly : Emit -> String -> List Pat -> List LTy -> CExpr -> Unit
emitFloatFwOnly e name pats ptys body =
  let fp = floatPositions ptys 0
  let arity = lengthS pats
  let worker = name ++ "__fw"
  let wenv = paramEnvD pats ptys fp 0
  let _ = beginDefine e
  let _ = emit e "define double @mdk_\{worker}(\{paramDeclsD pats fp 0}) {"
  let _ = emit e "entry:"
  let _ = emitFnBodyD e wenv name worker fp arity body
  let _ = emit e "}"
  emit e ""

emitFloatWorkerFn : Emit -> String -> List Pat -> List LTy -> CExpr -> Unit
emitFloatWorkerFn e name pats ptys body =
  let fp = floatPositions ptys 0
  let worker = name ++ "__fw"
  -- worker ($fw): float params as doubles, body emitted double-returning
  let _ = emitFloatFwOnly e name pats ptys body
  -- wrapper: original i64 ABI; unbox float params, call worker, box the result
  let _ = beginDefine e
  let _ = emit e "define i64 @mdk_\{name}(\{paramDecls pats 0}) {"
  let _ = emit e "entry:"
  let callArgs = wrapperCallArgs e fp 0 pats
  let r = freshReg e
  let _ = emit e "  \{r} = call double @mdk_\{worker}(\{callArgs})"
  let b = boxFloat e r
  let _ = emit e ("  ret i64 " ++ b)
  let _ = emit e "}"
  emit e ""

emitFnClause : Emit -> String -> List Pat -> CExpr -> Unit
emitFnClause e name pats body =
  let ptys = match sigLookup e name
    Some (FnSig ts _) => ts
    None => allInt pats
  if floatWorkerEligible e name pats ptys body then
    emitFloatWorkerFn e name pats ptys body
  else
    emitFnClauseStd e name pats ptys body

-- non-worker single-clause fn: emit the original i64-ABI define; if it is a
-- float-returning fn `emitFnBodyD` can handle, ALSO emit a standalone `$fw` variant
-- (the original stays for i64-ABI callers; float-context callers use `$fw`).
emitFnClauseStd : Emit -> String -> List Pat -> List LTy -> CExpr -> Unit
emitFnClauseStd e name pats ptys body =
  let _ = emitFnClauseW e name pats ptys body
  if floatFwEligible e name pats ptys body then
    emitFloatFwOnly e name pats ptys body
  else
    ()

emitFnClauseW : Emit -> String -> List Pat -> List LTy -> CExpr -> Unit
emitFnClauseW e name pats ptys body =
  let env = paramEnv pats ptys 0
  let _ = beginDefine e
  let _ = emit e "define i64 @mdk_\{name}(\{paramDecls pats 0}) {"
  let _ = emit e "entry:"
  let _ = emitFnBody e env name body
  let _ = emit e "}"
  emit e ""

-- every parameter is a plain variable pattern (the slice-2 ABI requirement).
allPVar : List Pat -> Bool
allPVar [] = True
allPVar ((PVar _)::rest) = allPVar rest
allPVar _ = False

sigTable : Emit -> List (String, FnSig)
sigTable e = e.sigs.value

-- default param types when no signature was inferred (every param Int).
allInt : List Pat -> List LTy
allInt [] = []
allInt (_::rest) = LTInt :: allInt rest

paramDecls : List Pat -> Int -> String
paramDecls [] _ = ""
paramDecls [PVar _] i = "i64 %arg" ++ intToString i
paramDecls ((PVar _)::rest) i =
  "i64 %arg\{intToString i}, \{paramDecls rest (i + 1)}"
paramDecls _ _ =
  panic "llvm spike: function parameters must be plain variables in slice 2"

-- bind each parameter to %argN at its inferred static type (every param is an i64
-- word at the ABI; the type only drives int-vs-float instruction selection).
paramEnv : List Pat -> List LTy -> Int -> List (String, (String, LTy))
paramEnv [] _ _ = []
paramEnv ((PVar x)::rest) (ty::tys) i =
  (x, ("%arg" ++ intToString i, ty)) :: paramEnv rest tys (i + 1)
paramEnv ((PVar x)::rest) [] i =
  (x, ("%arg" ++ intToString i, LTInt)) :: paramEnv rest [] (i + 1)
paramEnv _ _ _ =
  panic "llvm spike: function parameters must be plain variables in slice 2"

-- emit a function body in TAIL position: every control path ends in a `ret`.
-- An `if` recurses into both arms (each arm is itself in tail position and rets);
-- a tail call to a known function emits `[musttail] call` + `ret`; anything else
-- is computed as a value and returned.
emitFnBody : Emit -> List (String, (String, LTy)) -> String -> CExpr -> Unit
emitFnBody e env self (CIf c t f) =
  let (cv, _) = emitExpr e env c
  let ci = untagInt e cv
  let cb = freshReg e
  let _ = emit e "  \{cb} = icmp ne i64 \{ci}, 0"
  let n = intToString (freshLocal e)
  let thenL = "then" ++ n
  let elseL = "else" ++ n
  let _ = emit e "  br i1 \{cb}, label %\{thenL}, label %\{elseL}"
  let _ = emit e (thenL ++ ":")
  let _ = emitFnBody e env self t
  let _ = emit e (elseL ++ ":")
  emitFnBody e env self f
emitFnBody e env self other =
  let (hd, args) = flattenApp other []
  match hd
    CVar fname0 _ =>
      let fname = canonFnName e fname0
      if isKnownFn e fname && hasArgs args then
        let argOps = emitArgs e env args
        let r = freshReg e
        let kw = if fname == self then "musttail call" else "call"
        let _ = emit e "  \{r} = \{kw} i64 @mdk_\{fname}(\{argDecls argOps})"
        emit e ("  ret i64 " ++ r)
      else emitValueRet e env other
    _ => emitValueRet e env other

emitValueRet : Emit -> List (String, (String, LTy)) -> CExpr -> Unit
emitValueRet e env ex =
  let (v, _) = emitExpr e env ex
  emit e ("  ret i64 " ++ v)

-- ── classifying top-level bindings ──────────────────────────────────────────
-- a function binding = non-`main`, first clause has at least one parameter.
isFnBind : CBind -> Bool
isFnBind (CBind "main" _) = False
isFnBind (CBind _ ((CClause (_::_) _)::_)) = True
isFnBind _ = False

collectFns : List CBind -> List String
collectFns [] = []
collectFns (b::rest) =
  if isFnBind b then
    bindName b :: collectFns rest
  else
    collectFns rest

fnBinds : List CBind -> List CBind
fnBinds [] = []
fnBinds (b::rest) = if isFnBind b then b :: fnBinds rest else fnBinds rest

-- the nullary value bindings (non-`main`, no parameters), in source order.
valBinds : List CBind -> List CBind
valBinds [] = []
valBinds ((CBind "main" cs)::rest) = valBinds rest
valBinds (b::rest) = if isFnBind b then valBinds rest else b :: valBinds rest

-- value bindings ORDERED so a binding precedes the ones that reference it (E1b).
-- The init prologue computes each rhs once, eagerly, so a binding whose rhs reads
-- ANOTHER value global (`prog = andThen skip …`, `skip` defined later) must run
-- after that dependency or it captures the still-zero global cell — a null that
-- crashes at use.  Source order is NOT dependency order in general (the self-host
-- parser binds combinator values forward of their producers), so topologically
-- sort by intra-value-global references.  A genuine VALUE cycle (mutual recursion
-- through nullary globals — none arise in practice) keeps its members in source
-- order, the pre-existing behaviour (still caught by the forward-ref gap).
orderedValBinds : List CBind -> List CBind
-- Intentional cross-file duplicate of the same helper in wasm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
orderedValBinds binds =
  let names = map bindName binds
  let (_, ordered) = topoValGo binds names binds [] []
  ordered

-- DFS post-order: visit each binding's value-global dependencies first, appending
-- the binding after them.  `visiting` guards against cycles (a back-edge is
-- skipped — its target stays where source order placed it).  Returns the grown
-- (done-names, ordered-binds) accumulators.
topoValGo : List CBind -> List String -> List CBind -> List String -> List CBind -> (List String, List CBind)
topoValGo _ _ [] done acc = (done, acc)
-- Intentional cross-file duplicate of the same helper in wasm_emit.mdk; not consolidating (tiny helper / divergent-by-design backend pair).
-- lint-disable-next-line rule-duplicate-body
topoValGo all names (b::rest) done acc =
  let (done2, acc2) = topoValVisit all names b done acc []
  topoValGo all names rest done2 acc2

topoValVisit : List CBind -> List String -> CBind -> List String -> List CBind -> List String -> (List String, List CBind)
topoValVisit all names b done acc visiting
  | contains (bindName b) done = (done, acc)
  | contains (bindName b) visiting = (done, acc)
  | otherwise =
    let deps = intersectStr (dedupS (bindFreeVars b)) names
    let (done2, acc2) = topoValVisitDeps all names deps done acc (bindName b :: visiting)
    (bindName b :: done2, acc2 ++ [b])

topoValVisitDeps : List CBind -> List String -> List String -> List String -> List CBind -> List String -> (List String, List CBind)
topoValVisitDeps _ _ [] done acc _ = (done, acc)
topoValVisitDeps all names (d::rest) done acc visiting = match findBind d all
  Some db =>
    let (done2, acc2) = topoValVisit all names db done acc visiting
    topoValVisitDeps all names rest done2 acc2 visiting
  None => topoValVisitDeps all names rest done acc visiting

-- the value-global names a binding's rhs references EAGERLY (at init time) — i.e.
-- references NOT inside a lambda body.  A `CLam` captures a global by reference
-- and resolves it only when the closure is later CALLED (at parse time, long after
-- all globals are initialised), so a name appearing only inside a lambda is NOT an
-- init-order dependency.  Counting it would forge a false cycle between two
-- combinator globals that reference each other solely through their closures
-- (`stmtsLoop = orElse stmtsCons (pure [])` ← eager; `stmtsCons = do … stmtsLoop`
-- ← the back-reference is inside stmtsCons's `do` closure, lazy), and the
-- cycle-fallback would then emit them in source order, leaving the eager ref null.
bindFreeVars : CBind -> List String
bindFreeVars (CBind _ [CClause [] body]) = eagerVars [] body
bindFreeVars _ = []

findBind : String -> List CBind -> Option CBind
findBind _ [] = None
findBind name (b::rest) =
  if bindName b == name then
    Some b
  else
    findBind name rest

-- the elements of `xs` that also appear in `ys` (membership, order from xs).
intersectStr : List String -> List String -> List String
intersectStr [] _ = []
intersectStr (x::rest) ys
  | contains x ys = x :: intersectStr rest ys
  | otherwise = intersectStr rest ys

-- the initial globals registry (slice E1b): every value binding's name registered
-- UNinitialised (`False`) with a placeholder LTy.  The `@main` init prologue flips
-- each to `(True, <its rhs LTy>)` in source order as it computes the rhs, so a
-- reference to a not-yet-computed global is caught as a forward/mutual dependency.
initGlobalsReg : List CBind -> List (String, (Bool, LTy))
initGlobalsReg [] = []
initGlobalsReg (b::rest) = (bindName b, (False, LTInt)) :: initGlobalsReg rest

-- a fully-initialised globals registry: every value binding registered `True` with
-- a placeholder LTy.  The D4 gaps probe uses this so a function body referencing a
-- top-level value binding resolves to a global load (no spurious gap) — the probe
-- discards the emitted text, so the placeholder LTy is immaterial.
initGlobalsRegReady : List CBind -> List (String, (Bool, LTy))
initGlobalsRegReady [] = []
initGlobalsRegReady (b::rest) =
  (bindName b, (True, LTInt)) :: initGlobalsRegReady rest

-- emit a zero-initialised module global `@mdk_g_<name> = global i64 0` for each
-- value binding (into the side buffer, like string-literal globals — LLVM module
-- item order is irrelevant).  The `@main` prologue stores each binding's computed
-- rhs word here; references anywhere load it back.
emitGlobalDecls : Emit -> List CBind -> Unit
emitGlobalDecls _ [] = ()
emitGlobalDecls e (b::rest) =
  -- PRELUDE half (issue #118): a top-level value's storage is DEFINED (and, in
  -- source order, INITIALISED) by `@mdk_program_main`, which lives in the program
  -- half — so prelude.o only declares it.  Defining it in both halves would be a
  -- duplicate symbol.
  let line = if emitHalfRef.value == emitHalfPrelude then
    "@mdk_g_" ++ bindName b ++ " = external global i64"
  else
    "@mdk_g_" ++ bindName b ++ " = global i64 0"
  let _ = emitGlobal e line
  emitGlobalDecls e rest

-- ── function signature inference (slice 2b) ──────────────────────────────────
-- Core IR is type-erased, so to lower a Bool/Float-typed function boundary we
-- must RECOVER the static type of each parameter and result.  `typeOf` is the
-- pure (non-emitting) twin of the type-recovery that `emitExpr` already does as
-- it emits — it computes a CExpr's LTy from the signature table + a var→LTy env,
-- with no side effects.  `inferSigs` runs it to a two-pass fixpoint so a callee's
-- signature is available before its caller's body is typed (one extra pass lets a
-- caller see a callee defined later / mutual recursion settle).
--
-- Float/Bool ride the EXISTING uniform i64 word (Float boxed, Bool immediate), so
-- inference changes no LLVM type — only which instructions the body emits and the
-- print routine `main` picks.  Param/return remain i64 at the ABI, so musttail's
-- prototype-match invariant is untouched.

-- structural type of an expression given known fn signatures + a var→type env.
-- Unknown vars (top-level value globals) default to Int — the slice's existing
-- assumption (function bodies referencing globals are out of scope anyway).
typeOf : OrdMap FnSig -> List (String, LTy) -> CExpr -> LTy
typeOf _ _ (CLit (LInt _)) = LTInt
typeOf _ _ (CLit (LFloat _)) = LTFloat
typeOf _ _ (CLit (LBool _)) = LTBool
typeOf _ _ (CLit (LString _)) = LTStr
typeOf _ _ (CLit (LChar _)) = LTChar
-- A list literal / range-list is a chain of Cons/Nil cells — a constructor
-- value (LTCon), NOT an Int.  Without this, the empty-list base clause of a
-- list-returning multi-clause fn (e.g. `externNames [] = []`) typed as LTInt, so
-- the fn's inferred return LTy was LTInt; a `++` on its result then fell to the
-- runtime-dispatch arm (default LTStr), and a CHAINED outer `++` saw LTStr and
-- statically emitted mdk_string_append on a List → memmove crash.  LTCon routes
-- the whole `++` chain through mdk_list_append correctly.
typeOf _ _ (CList _) = LTCon
typeOf _ _ (CRangeList _ _ _) = LTCon
typeOf _ env (CVar x _) = match lookupAssoc x env
  Some LTFloatU => LTFloat
  Some t => t
  None => LTInt
typeOf sigs env (CBinPrim op l r _)
  | isCmpOp op = LTBool
  | op == "::" = LTCon
  | otherwise = typeOf sigs env l
typeOf _ _ (CUnOp "!" _) = LTBool
typeOf sigs env (CUnOp "-" x) = typeOf sigs env x
typeOf sigs env (CIf _ t _) = typeOf sigs env t
typeOf sigs env (CLet False (PVar x) e1 e2) =
  typeOf sigs ((x, typeOf sigs env e1)::env) e2
typeOf sigs env (CLetGroup binds body) =
  typeOf sigs (letGroupEnv sigs env binds) body
typeOf sigs env (CBlock stmts) = blockTy sigs env stmts
typeOf sigs env (CDecision _ arms _) = armsRetTy sigs env arms
-- A constrained-function or return-position-method occurrence (CDict/CMethod)
-- carries the SAME callee name as the bare CVar would; its emit path
-- (`emitDictApp`/`emitMethod`) types the result via `fnRetTy e name`, so the pure
-- twin must mirror that and route through `callRetTy sigs name` — not default to
-- LTInt.  Without this, a Unit-returning constrained stdlib fn called inside a
-- user fn (e.g. `f s = println s`, where `println : Display a => a -> <IO> Unit`
-- lowers `f`'s body to `CDict "println" …`) inferred `f`'s return as LTInt,
-- mis-printing `main`'s `()` result as `0` (construct-gap F1; layers on #2b's
-- LTUnit IO-extern fix).
typeOf sigs env app =
  let (hd, args) = flattenApp app []
  match hd
    CVar fname _ => if hasArgs args then callRetTy sigs fname else LTInt
    CDict fname _ => callRetTy sigs fname
    CMethod fname _ _ _ => callRetTy sigs fname
    _ => LTInt

-- the return type of a known function from the sig table (Int if unknown).
-- the return type of a known function from the sig table (Int if unknown).
-- IO output externs (putStr/putStrLn/…) return Unit but are NOT user-fn binds,
-- so they are absent from `sigs` and would default to LTInt — typing a
-- Unit-returning wrapper (e.g. `println x = putStrLn (display x)`) as LTInt and
-- mis-rendering `main`'s result as `0` instead of `()` (Stage 3 #2b).  Resolve
-- them to LTUnit up front, matching the real emit path (`emitIoExtern`).
callRetTy : OrdMap FnSig -> String -> LTy
callRetTy sigs fname =
  if isIoExtern fname then LTUnit
  else match omLookup fname sigs
    Some (FnSig _ rty) => rty
    None => LTInt

-- a decision's result type is its first arm's body type (all arms agree —
-- well-typed match).  Pattern-bound vars are unknown to the pure pass, so a body
-- referencing them defaults via typeOf's CVar/None branch; the fixtures' arms are
-- Int-typed, matching the runtime-captured `rty`.
armsRetTy : OrdMap FnSig -> List (String, LTy) -> List CArm -> LTy
armsRetTy _ _ [] = LTInt
armsRetTy sigs env ((CArm _ _ body)::_) = typeOf sigs env body

letGroupEnv : OrdMap FnSig -> List (String, LTy) -> List CBind -> List (String, LTy)
letGroupEnv _ env [] = env
letGroupEnv sigs env ((CBind name [CClause [] rhs])::rest) =
  letGroupEnv sigs ((name, typeOf sigs env rhs)::env) rest
letGroupEnv _ env _ = env

blockTy : OrdMap FnSig -> List (String, LTy) -> List CStmt -> LTy
blockTy sigs env [CSExpr ex] = typeOf sigs env ex
blockTy sigs env ((CSExpr _)::rest) = blockTy sigs env rest
blockTy sigs env ((CSLet _ (PVar x) ex)::rest) =
  blockTy sigs ((x, typeOf sigs env ex)::env) rest
-- a constructor / nested block-let (emitBlock now binds these): type its pattern
-- vars in blockTy's env so a tail expr that uses a bound field still recurses
-- (the old catch-all stopped at LTInt for the whole tail).  blockTy is pure, so
-- it cannot consult the (Mut) ctor field-type table — each var gets LTInt, the
-- same default the catch-all produced.  emitBlock's bindPattern applies the
-- precise declared scalar types at emit time; this only types the result lookup.
blockTy sigs env ((CSLet _ pat ex)::rest) =
  blockTy sigs (patBindTys pat ++ env) rest
blockTy sigs env ((CSAssign x ex)::rest) =
  blockTy sigs ((x, typeOf sigs env ex)::env) rest
blockTy _ _ _ = LTInt

-- bind a non-PVar block-let pattern's vars for blockTy's env.  blockTy is pure,
-- so we cannot consult the (Mut) ctor field-type table; each var gets LTInt (the
-- same value the catch-all `blockTy _ _ _ = LTInt` produced for these lets).
patBindTys : Pat -> List (String, LTy)
patBindTys pat = mapVarLTInt (patVars pat)

mapVarLTInt : List String -> List (String, LTy)
mapVarLTInt [] = []
mapVarLTInt (x::rest) = (x, LTInt) :: mapVarLTInt rest

-- infer one parameter's type from its first typed USE in the body: the condition
-- of an `if` or the operand of `!` forces Bool; an operand of an arithmetic/
-- comparison binop shares its SIBLING's type; an argument to a known function
-- takes that function's parameter type.  None ⇒ no determining use found (the
-- caller defaults it to Int).

-- infer the type of `p` given the OTHER operand of a binop.  For ARITHMETIC ops the
-- operand is provably numeric (`+`/`-`/`*`/`/`/`%`, not the String `++`/`::`), so
-- when the other operand does NOT pin a concrete Int/Float (e.g. `a + b` where both
-- are tuple-destructured vars with no type source — typeOf DEFAULTS them to LTInt and
-- emits INTEGER arith on boxed-float pointers → garbage) fall back to LTNum, whose
-- arith/print route through the runtime tag-dispatched @mdk_num_* helpers (correct
-- for Int AND Float).  When the other operand DOES pin a concrete numeric type (a
-- literal, an env-typed var) use it — so int-literal-anchored arith (`a + 1`) keeps
-- its inline fast path.  Non-arith ops keep the historical `typeOf other` (a
-- comparison var has the same type as what it is compared to).
binOperandTy : OrdMap FnSig -> List (String, LTy) -> String -> CExpr -> LTy
binOperandTy sigs env op other =
  if isArithOp op then match concreteNumTy sigs env other
    Some t => t
    None => LTNum
  else typeOf sigs env other

-- Some (concrete numeric LTy) when `e` is DEFINITELY typed; None when its type would
-- only be a guess (a bare var absent from env, a call result) — mirrors typeOf but
-- treats typeOf's LTInt-default as "unknown" so binOperandTy can pick LTNum instead.
concreteNumTy : OrdMap FnSig -> List (String, LTy) -> CExpr -> Option LTy
concreteNumTy _ _ (CLit (LInt _)) = Some LTInt
concreteNumTy _ _ (CLit (LFloat _)) = Some LTFloat
concreteNumTy sigs env (CUnOp "-" x) = concreteNumTy sigs env x
concreteNumTy _ env (CVar x _) = match lookupAssoc x env
  Some LTFloatU => Some LTFloat
  Some t => Some t
  None => None
concreteNumTy sigs env (CBinPrim op l r _) =
  if isArithOp op then
    firstSome (concreteNumTy sigs env l) (concreteNumTy sigs env r)
  else
    None
concreteNumTy _ _ _ = None

paramUseTy : OrdMap FnSig -> List (String, LTy) -> String -> CExpr -> Option LTy
paramUseTy sigs env p (CIf c t f) =
  if isVarNamed p c then
    Some LTBool
  else
    firstSome (paramUseTy sigs env p t) (paramUseTy sigs env p f)
paramUseTy _ _ p (CUnOp "!" x) = if isVarNamed p x then Some LTBool else None
paramUseTy sigs env p (CUnOp _ x) = paramUseTy sigs env p x
-- `::` is NOT a symmetric binop: in `l :: r`, l is the ELEMENT and r is the
-- `List element` — their LTys differ.  So a var on the LEFT of `::` cannot take
-- the right operand's (list) type; doing so mistypes a String accumulator as
-- LTCon (e.g. `acc :: …` in splitLines), routing its OTHER `++` use to
-- mdk_list_append on a String → crash.  Skip the element side; a var on the
-- right of `::` is a list (LTCon).
paramUseTy sigs env p (CBinPrim "::" l r _) =
  if isVarNamed p r then
    Some LTCon
  else
    firstSome (paramUseTy sigs env p l) (paramUseTy sigs env p r)
paramUseTy sigs env p (CBinPrim op l r _) =
  if isVarNamed p l then
    Some (binOperandTy sigs env op r)
  else if isVarNamed p r then
    Some (binOperandTy sigs env op l)
  else
    firstSome (paramUseTy sigs env p l) (paramUseTy sigs env p r)
paramUseTy sigs env p (CLet _ _ e1 e2) =
  firstSome (paramUseTy sigs env p e1) (paramUseTy sigs env p e2)
-- scan a block's statements for a determining use of `p` (a tuple/pattern-destructure
-- in a block passes its continuation here as `CBlock rest` so the bound var's type
-- can be inferred from later uses, not a dummy `0`).
paramUseTy sigs env p (CBlock stmts) = paramUseStmts sigs env p stmts
paramUseTy sigs env p app =
  let (hd, args) = flattenApp app []
  match hd
    CVar fname _ =>
      if hasArgs args then
        firstSome (argPosTy sigs env p fname args 0) (paramUseArgs sigs env p args)
      else
        None
    _ => paramUseArgs sigs env p args

-- if `p` is passed as the Nth argument to a known function, its type is that
-- function's Nth parameter type.
argPosTy : OrdMap FnSig -> List (String, LTy) -> String -> String -> List CExpr -> Int -> Option LTy
argPosTy _ _ _ _ [] _ = None
argPosTy sigs env p fname (a::rest) i =
  if isVarNamed p a then
    nthParamTy sigs fname i
  else
    argPosTy sigs env p fname rest (i + 1)

-- the type of the Nth parameter of a known function (None if unknown).
nthParamTy : OrdMap FnSig -> String -> Int -> Option LTy
nthParamTy sigs fname i = match omLookup fname sigs
  Some (FnSig ptys _) => nthTy ptys i
  None => None

nthTy : List LTy -> Int -> Option LTy
nthTy [] _ = None
nthTy (t::_) 0 = Some t
nthTy (_::rest) i = nthTy rest (i - 1)

paramUseArgs : OrdMap FnSig -> List (String, LTy) -> String -> List CExpr -> Option LTy
paramUseArgs _ _ _ [] = None
paramUseArgs sigs env p (a::rest) =
  firstSome (paramUseTy sigs env p a) (paramUseArgs sigs env p rest)

-- scan block statements for a determining use of `p` in any statement's expression
-- (CSExpr / CSLet rhs); unknown statement shapes are skipped.
paramUseStmts : OrdMap FnSig -> List (String, LTy) -> String -> List CStmt -> Option LTy
paramUseStmts _ _ _ [] = None
paramUseStmts sigs env p ((CSExpr ex)::rest) =
  firstSome (paramUseTy sigs env p ex) (paramUseStmts sigs env p rest)
paramUseStmts sigs env p ((CSLet _ _ ex)::rest) =
  firstSome (paramUseTy sigs env p ex) (paramUseStmts sigs env p rest)
paramUseStmts sigs env p (_::rest) = paramUseStmts sigs env p rest

isVarNamed : String -> CExpr -> Bool
isVarNamed p (CVar x _) = p == x
isVarNamed _ _ = False

firstSome : Option a -> Option a -> Option a
firstSome (Some x) _ = Some x
firstSome None y = y

-- infer one function's full signature against the current (partial) sig table.
inferOneSig : OrdMap FnSig -> Option (List String, String) -> CBind -> FnSig
inferOneSig sigs dsig (CBind _ [CClause pats body]) =
  let ptys = inferParamTysSeed sigs dsig pats body 0
  let env = zipParamEnv pats ptys
  FnSig ptys (seedRetTy dsig (typeOf sigs env body))
inferOneSig sigs dsig (CBind _ (c::rest)) = inferMultiSig sigs dsig (c::rest)
inferOneSig _ _ _ = FnSig [] LTInt

-- E1: a DECLARED scalar param/return type (from `declSigTypesRef`, sourced from
-- the fn's `DTypeSig`) WINS over the body-use guess.  `seedParamTy` overrides the
-- i-th inferred param type with its declared scalar LTy when one is known (else
-- keeps the guess); `seedRetTy` likewise for the return.  ADDITIVE: an
-- unannotated fn (`dsig = None`) or a non-scalar declared type leaves the guess
-- untouched, so literal-anchored Float fns and Int fns are unchanged.
seedParamTy : Option (List String, String) -> Int -> LTy -> LTy
seedParamTy (Some (ptyNames, _)) i guessed = match declScalarAt ptyNames i
  Some t => t
  None => guessed
seedParamTy None i guessed = guessed

seedRetTy : Option (List String, String) -> LTy -> LTy
seedRetTy (Some (_, retName)) guessed = match fieldNameToLTy retName
  Some t => t
  None => guessed
seedRetTy None guessed = guessed

-- the declared scalar LTy at param index `i` of a declared param-type-head list,
-- or None when out of range / not a known scalar.
declScalarAt : List String -> Int -> Option LTy
declScalarAt names i = match nthName names i
  Some n => fieldNameToLTy n
  None => None

-- E1a: signature inference for a MULTI-CLAUSE binding.  A param's type is the
-- first type-revealing finding scanning clauses left-to-right (a literal pattern
-- names it directly; a plain-var pattern is inferred from that clause's body use
-- via `paramUseTy`; a constructor/tuple/wild pattern is an i64 word, left to
-- default Int).  The return type is the first clause's body typed under its
-- param env.  Without this, a multi-clause fn fell to `FnSig [] LTInt`, so its
-- non-Int params (`implParamEnvTyped`) and non-Int result (`fnRetTy` → print
-- selection) were both lost.  (Gap E1: a declared scalar param/return seeds over
-- the guess via `seedParamTy`/`seedRetTy`.)
inferMultiSig : OrdMap FnSig -> Option (List String, String) -> List CClause -> FnSig
inferMultiSig sigs dsig clauses =
  let arity = clauseArityC clauses
  let ptys = inferMultiParamTys sigs dsig clauses arity 0
  FnSig ptys (seedRetTy dsig (inferMultiRetTy sigs clauses ptys))

clauseArityC : List CClause -> Int
clauseArityC ((CClause pats _)::_) = listLen pats
clauseArityC [] = 0

inferMultiParamTys : OrdMap FnSig -> Option (List String, String) -> List CClause -> Int -> Int -> List LTy
inferMultiParamTys sigs dsig clauses arity i
  | i >= arity = []
  | otherwise = seedParamTy dsig i (paramTyAcross sigs clauses i) :: inferMultiParamTys sigs dsig clauses arity (i + 1)

-- the i-th param's type: the first informative finding across clauses, else Int.
paramTyAcross : OrdMap FnSig -> List CClause -> Int -> LTy
paramTyAcross sigs clauses i = match firstInformative sigs clauses i
  Some t => t
  None => LTInt

firstInformative : OrdMap FnSig -> List CClause -> Int -> Option LTy
firstInformative _ [] _ = None
firstInformative sigs ((CClause pats body)::rest) i =
  firstSome (clausePatTy sigs pats body i) (firstInformative sigs rest i)

-- one clause's contribution to the i-th param type: a plain var is inferred from
-- its body use; a literal pattern carries its literal type; a ctor/tuple/wild
-- pattern is uninformative (an i64 word, defaulted to Int by the caller).
clausePatTy : OrdMap FnSig -> List Pat -> CExpr -> Int -> Option LTy
clausePatTy sigs pats body i = match nthPat pats i
  Some (PVar x) => paramUseTy sigs [] x body
  Some (PLit l) => Some (litTy l)
  _ => None

litTy : Lit -> LTy
litTy (LInt _) = LTInt
litTy (LFloat _) = LTFloat
litTy (LBool _) = LTBool
litTy (LString _) = LTStr
litTy (LChar _) = LTChar
litTy LUnit = LTInt

nthPat : List Pat -> Int -> Option Pat
nthPat (p::_) 0 = Some p
nthPat (_::rest) i = nthPat rest (i - 1)
nthPat [] _ = None

-- the multi-clause return type: the first clause's body typed under that clause's
-- (var-pattern → inferred-param-type) env.
inferMultiRetTy : OrdMap FnSig -> List CClause -> List LTy -> LTy
inferMultiRetTy sigs ((CClause pats body)::_) ptys =
  typeOf sigs (zipParamEnv pats ptys) body
inferMultiRetTy _ [] _ = LTInt

inferParamTys : OrdMap FnSig -> List Pat -> CExpr -> List LTy
inferParamTys _ [] _ = []
inferParamTys sigs pats body
  | isArithSectionLam pats body = mapConst LTNum pats
inferParamTys sigs ((PVar x)::rest) body =
  let ty = match paramUseTy sigs [] x body
    Some t => t
    None => LTInt
  ty :: inferParamTys sigs rest body
inferParamTys sigs (_::rest) body = LTInt :: inferParamTys sigs rest body

-- G9: an operator-SECTION lambda — `\_a _b => _a OP _b` for an arithmetic OP,
-- the desugaring of a bare arithmetic section `(+)`/`(*)`/… (desugar.mdk
-- `sectionToCore (SecBare op)`).  Such a section flows as a first-class function
-- value (`fold (+) seed xs`), so it is POLYMORPHIC over `Num` — neither
-- statically Int nor Float.  Its two params carry no declared sig and no Float
-- literal anchor, so the default LTInt path would emit integer `add`/`mul`,
-- which is WRONG when the section is applied at Float (untags a boxed Float
-- pointer → garbage/SIGSEGV).  Seeding LTNum routes the body through the runtime
-- tag-dispatched @mdk_num_* helper (low-bit Int/Float discriminator), correct for
-- BOTH (Int: low-bit immediate → int op, byte-identical value to the old int
-- path; Float: boxed → float op).  Shape is EXACT: body is a single CBinPrim of
-- an arith op over the two params in order, so only the genuine section lambda is
-- affected — a lambda doing other work keeps its per-param inference.
isArithSectionLam : List Pat -> CExpr -> Bool
isArithSectionLam [PVar a, PVar b] (CBinPrim op (CVar la _) (CVar rb _) _) = isArithOp op
  && la == a
  && rb == b
isArithSectionLam _ _ = False

mapConst : a -> List b -> List a
mapConst _ [] = []
mapConst v (_::rest) = v :: mapConst v rest

-- like inferParamTys, but a DECLARED scalar type at param index `i` seeds (wins)
-- over the body-use guess (Gap E1: `double x = x + x : Float -> Float` has no
-- Float literal anchor, so the guess is LTInt → int arith on a boxed Float;
-- the declared `Float` overrides to LTFloat).  Index-tracked so each param's
-- declared type lines up by position.
inferParamTysSeed : OrdMap FnSig -> Option (List String, String) -> List Pat -> CExpr -> Int -> List LTy
inferParamTysSeed sigs dsig pats body i =
  inferParamTysSeedD sigs dsig pats body i i

-- like inferParamTysSeed, but tracks the DECLARED-param index `di` separately from
-- the emit/IR position `i`.  A dict-passing param (`$dict_<fn>_<slot>`, prepended
-- by elaborateModules to a `=>`-constrained fn) advances `i` but NOT `di`, so the
-- declared signature's param types — which DON'T include the synthesized dict
-- params — stay aligned to the source params.  Without this, a `Num a =>` fn's
-- real param sits one slot right of where `declScalarAt`/`isNumPolyParam` look
-- (the G3 root cause: x's LTNum seed was read at the dict's index → missed).
inferParamTysSeedD : OrdMap FnSig -> Option (List String, String) -> List Pat -> CExpr -> Int -> Int -> List LTy
inferParamTysSeedD _ _ [] _ _ _ = []
inferParamTysSeedD sigs dsig ((PVar x)::rest) body i di
  | isDictParamName x =
    LTInt :: inferParamTysSeedD sigs dsig rest body (i + 1) di
  | otherwise =
    let guessed = match paramUseTy sigs [] x body
      Some t => t
      None => LTInt
    let seeded = seedParamTy dsig di guessed
    let final = numPolySeed dsig di seeded (paramUsedInArith x body)
    final :: inferParamTysSeedD sigs dsig rest body (i + 1) (di + 1)
-- G3: a param whose DECLARED type head is a type variable (`a` in
-- `double : Num a => a -> a`) and which is USED arithmetically is polymorphic
-- over Num — neither statically Int nor Float.  Seed LTNum so emitArith/emitPrint
-- route through the runtime tag-dispatched @mdk_num_* helpers.  A concrete
-- declared scalar (Int/Float/…) still wins via seedParamTy; a type-var param
-- NOT used in arithmetic (e.g. `id : a -> a`) keeps its guess (no LTNum).

inferParamTysSeedD sigs dsig (_::rest) body i di =
  seedParamTy dsig di LTInt ::
    inferParamTysSeedD sigs dsig rest body (i + 1) (di + 1)

-- G3: override a type-var param's LTInt seed with LTNum when it's used in
-- arithmetic (a polymorphic Num operand); otherwise keep the seed unchanged.
numPolySeed : Option (List String, String) -> Int -> LTy -> Bool -> LTy
numPolySeed dsig i seeded usedArith
  | isNumPolyParam dsig i seeded && usedArith = LTNum
  | otherwise = seeded

-- G3: True when param index `i`'s declared type head is a type VARIABLE (a
-- lowercase-initial name like `a` — concrete cons are uppercase) and the
-- seedParamTy result is still LTInt (i.e. no concrete scalar declared/inferred).
-- This is the "polymorphic Num operand" signal.
isNumPolyParam : Option (List String, String) -> Int -> LTy -> Bool
isNumPolyParam (Some (ptyNames, _)) i LTInt = match nthName ptyNames i
  Some n => isTypeVarName n
  None => False
isNumPolyParam None i LTInt = True
isNumPolyParam dsig i _ = False

-- a type-variable head name is lowercase-initial (`a`, `elem`); a concrete type
-- (`Int`, `Float`, a user type) is uppercase-initial.  Empty ⇒ not a var.
isTypeVarName : String -> Bool
isTypeVarName n =
  let cs = stringToChars n
  numVarFirst cs

numVarFirst : Array Char -> Bool
numVarFirst cs
  | arrayLength cs == 0 = False
  | otherwise = isLowerCode (charCode (arrayGetUnsafe 0 cs))

isLowerCode : Int -> Bool
isLowerCode c = c >= 97 && c <= 122

-- G3: True when `p` is an operand of an arithmetic binop anywhere in the body.
paramUsedInArith : String -> CExpr -> Bool
paramUsedInArith p (CBinPrim op l r _) =
  if isArithOp op && (isVarNamed p l || isVarNamed p r) then
    True
  else
    paramUsedInArith p l || paramUsedInArith p r
paramUsedInArith p (CIf c t f) = paramUsedInArith p c
  || paramUsedInArith p t
  || paramUsedInArith p f
paramUsedInArith p (CUnOp _ x) = paramUsedInArith p x
paramUsedInArith p (CLet _ _ e1 e2) = paramUsedInArith p e1
  || paramUsedInArith p e2
paramUsedInArith p app =
  let (_, args) = flattenApp app []
  anyArithArg p args
paramUsedInArith _ _ = False

anyArithArg : String -> List CExpr -> Bool
anyArithArg _ [] = False
anyArithArg p (a::rest) = paramUsedInArith p a || anyArithArg p rest

zipParamEnv : List Pat -> List LTy -> List (String, LTy)
zipParamEnv ((PVar x)::ps) (t::ts) = (x, t) :: zipParamEnv ps ts
zipParamEnv (_::ps) (_::ts) = zipParamEnv ps ts
zipParamEnv _ _ = []

-- one inference pass: recompute every function's signature using the prior table.
-- (Gap E1: each binding's DECLARED signature, looked up by name in the installed
-- `declSigTypesRef` table, seeds its param/return types over the body-use guess.)
inferPass : OrdMap FnSig -> List CBind -> List (String, FnSig)
inferPass _ [] = []
inferPass sigs (b::rest) =
  (bindName b, inferOneSig sigs (declSigOf (bindName b)) b) ::
    inferPass sigs rest

-- fixpoint to two passes: pass 1 seeds signatures (callees defined earlier are
-- already typed); pass 2 lets a caller see a callee defined later / mutual
-- recursion settle.  Two passes suffice for the spike's call graphs (no deeper
-- type-flow chains than caller→callee→sibling exist in the subset).
inferSigs : List CBind -> List (String, FnSig)
inferSigs fns =
  let pass1 = inferPass omEmpty fns
  inferPass (sigsToMap pass1) fns

-- ── operator -> LLVM mnemonic tables ────────────────────────────────────────
intOp : String -> String
intOp "+" = "add"
intOp "-" = "sub"
intOp "*" = "mul"
intOp "/" = "sdiv"  -- OCaml `/` truncates toward zero; sdiv matches
intOp "%" = "srem"  -- OCaml `mod` sign-of-dividend; srem matches
intOp op = panic ("llvm spike: unsupported int operator " ++ op)

floatOp : String -> String
floatOp "+" = "fadd"
floatOp "-" = "fsub"
floatOp "*" = "fmul"
floatOp "/" = "fdiv"
floatOp "%" = "frem"  -- OCaml Float.rem == C fmod == LLVM frem
floatOp op = panic ("llvm spike: unsupported float operator " ++ op)

-- G3: the runtime tag-dispatched numeric helper for a POLYMORPHIC Num operand
-- (mdk_num_* branch on the low bit: Int → int op, boxed Float → float op).
numOp : String -> String
numOp "+" = "mdk_num_add"
numOp "-" = "mdk_num_sub"
numOp "*" = "mdk_num_mul"
numOp "/" = "mdk_num_div"
numOp "%" = "mdk_num_mod"
numOp op = panic ("llvm spike: unsupported num operator " ++ op)

intPred : String -> String
intPred "==" = "eq"
intPred "!=" = "ne"
intPred "<" = "slt"
intPred ">" = "sgt"
intPred "<=" = "sle"
intPred ">=" = "sge"
intPred op = panic ("llvm spike: unsupported comparison " ++ op)

-- IEEE-754 comparison predicates (issue #285).  `==`/`<`/`>`/`<=`/`>=` are all
-- ORDERED (`o*`): every relational comparison against NaN is false, which is
-- correct IEEE semantics.  `!=` is the LONE exception — `a != b` must be TRUE
-- when either operand is NaN — so it needs the UNORDERED-or-not-equal predicate
-- `une`, not the ordered `one` (which is false for NaN and would break both IEEE
-- and the identity `(a != b) == !(a == b)`).  Matches eval and the wasm backend's
-- `f64.ne` (also une-equivalent).
floatPred : String -> String
floatPred "==" = "oeq"
floatPred "!=" = "une"
floatPred "<" = "olt"
floatPred ">" = "ogt"
floatPred "<=" = "ole"
floatPred ">=" = "oge"
floatPred op = panic ("llvm spike: unsupported comparison " ++ op)

isCmpOp : String -> Bool
isCmpOp op = op == "=="
  || op == "!="
  || op == "<"
  || op == ">"
  || op == "<="
  || op == ">="

-- ── records, tuples, and mutable refs (slice 5a) ────────────────────────────

emitTuple : Emit -> List (String, (String, LTy)) -> List CExpr -> (String, LTy)
emitTuple e env es =
  let words = emitArgs e env es
  if allConstWords words then
    (emitConstDictCell e (cellTag e "$tuple") words, LTCon)
  else
    emitCtorAlloc e "$tuple" words

emitRecordCreate : Emit -> List (String, (String, LTy)) -> String -> List CField -> (String, LTy)
emitRecordCreate e env name fields =
  let words = emitFieldExprs e env fields
  if allConstWords words then
    (emitConstDictCell e (cellTag e name) words, LTCon)
  else
    emitCtorAlloc e name words

emitFieldAccess : Emit -> List (String, (String, LTy)) -> CExpr -> String -> String -> (String, LTy)
emitFieldAccess e env ex label recName =
  let (w, _) = emitExpr e env ex
  if label == "value" then
    let f = loadField e w 0
    (f, LTInt)
  else
    let idx = fieldIdxByName (recFieldTable e) recName label
    let f = loadField e w idx
    (f, LTInt)

-- Resolve a field's positional index by the typecheck-stamped record name when
-- known (recName ≠ "" and that record actually has the label); otherwise fall
-- back to today's label-only search (safety for unstamped / synthesized
-- accesses).  The by-name path is what makes two records sharing a field name at
-- DIFFERENT indices resolve to the correct offset.
fieldIdxByName : List (String, List String) -> String -> String -> Int
fieldIdxByName table recName label =
  if recName == "" then findFieldIdx table label
  else match lookupAssoc recName table
    Some labels => match indexOfStr label labels
      Some i => i
      None => findFieldIdx table label
    None => findFieldIdx table label

emitRecordUpdate : Emit -> List (String, (String, LTy)) -> String -> CExpr -> List CField -> (String, LTy)
emitRecordUpdate e env recName base updates =
  let (bw, _) = emitExpr e env base
  let firstLabel = cFieldFirstLabel updates
  match recordByName (recFieldTable e) recName firstLabel
    None => gapE ("CRecordUpdate: unknown record type for field '" ++ firstLabel ++ "'")
    Some (name, labels) =>
      let updatePairs = emitUpdatePairs e env updates
      let words = buildUpdateWords e bw labels updatePairs 0
      emitCtorAlloc e name words

-- Resolve the RECEIVER record of an update by the typecheck-stamped record name
-- (CRecordUpdate's 1st field) when it is usable — non-empty, present in the
-- field-order table, and actually owning the update label — else fall back to
-- today's label-only search (unstamped / synthesized updates).  The by-name path
-- is what makes two records that share a field name at DIFFERENT slot indices
-- update the correct slot; the label-only guess silently wrote the other
-- record's slot (bug #38).  Peer of fieldIdxByName on the access path.
recordByName : List (String, List String) -> String -> String -> Option (String, List String)
recordByName table recName label =
  if recName == "" then findRecordByLabel table label
  else match lookupAssoc recName table
    Some labels => match indexOfStr label labels
      Some _ => Some (recName, labels)
      None => findRecordByLabel table label
    None => findRecordByLabel table label

emitVariantUpdate : Emit -> List (String, (String, LTy)) -> String -> CExpr -> List CField -> (String, LTy)
emitVariantUpdate e env con base updates =
  let (bw, _) = emitExpr e env base
  match lookupAssoc con (recFieldTable e)
    None => gapE ("CVariantUpdate: unknown variant type for constructor '" ++ con ++ "'")
    Some labels =>
      let updatePairs = emitUpdatePairs e env updates
      let words = buildUpdateWords e bw labels updatePairs 0
      emitCtorAlloc e con words

emitRefAlloc : Emit -> List (String, (String, LTy)) -> List CExpr -> (String, LTy)
emitRefAlloc e env [x] =
  let (xw, _) = emitExpr e env x
  emitCtorAlloc e "$ref" [xw]
emitRefAlloc e env _ = gapE "Ref expects exactly 1 argument"

emitSetRef : Emit -> List (String, (String, LTy)) -> List CExpr -> (String, LTy)
emitSetRef e env [r, x] =
  let (rw, _) = emitExpr e env r
  let (xw, _) = emitExpr e env x
  let p = freshReg e
  let _ = emit e "  \{p} = inttoptr i64 \{rw} to ptr"
  let fp = freshReg e
  let _ = emit e "  \{fp} = getelementptr i8, ptr \{p}, i64 8"
  let _ = emit e "  store i64 \{xw}, ptr \{fp}"
  ("1", LTInt)
emitSetRef e env _ = gapE "setRef expects exactly 2 arguments"

emitFieldExprs : Emit -> List (String, (String, LTy)) -> List CField -> List String
emitFieldExprs _ _ [] = []
emitFieldExprs e env ((CField _ ex)::rest) =
  let (w, _) = emitExpr e env ex
  w :: emitFieldExprs e env rest

emitUpdatePairs : Emit -> List (String, (String, LTy)) -> List CField -> List (String, String)
emitUpdatePairs _ _ [] = []
emitUpdatePairs e env ((CField k ex)::rest) =
  let (w, _) = emitExpr e env ex
  (k, w) :: emitUpdatePairs e env rest

buildUpdateWords : Emit -> String -> List String -> List (String, String) -> Int -> List String
buildUpdateWords _ _ [] _ _ = []
buildUpdateWords e bw (label::rest) updates i =
  let w = match lookupAssoc label updates
    Some newWord => newWord
    None => loadField e bw i
  w :: buildUpdateWords e bw rest updates (i + 1)

cFieldFirstLabel : List CField -> String
cFieldFirstLabel [] = panic "llvm spike: CRecordUpdate: empty update list"
cFieldFirstLabel ((CField k _)::_) = k

cFieldLabels : List CField -> List String
cFieldLabels [] = []
cFieldLabels ((CField k _)::rest) = k :: cFieldLabels rest

cFieldExprs : List CField -> List CExpr
cFieldExprs [] = []
cFieldExprs ((CField _ ex)::rest) = ex :: cFieldExprs rest

findFieldIdx : List (String, List String) -> String -> Int
findFieldIdx table label = match findRecordByLabel table label
  Some (_, labels) => match indexOfStr label labels
    Some i => i
    None => panic ("llvm spike: field '" ++ label ++ "' not found in record (internal error)")
  None => panic ("llvm spike: CFieldAccess: unknown field '" ++ label ++ "'")

findRecordByLabel : List (String, List String) -> String -> Option (String, List String)
findRecordByLabel [] _ = None
findRecordByLabel ((name, labels)::rest) label =
  if contains label labels then
    Some (name, labels)
  else
    findRecordByLabel rest label

indexOfStr : String -> List String -> Option Int
indexOfStr _ [] = None
indexOfStr x (y::rest) =
  if x == y then
    Some 0
  else
    map (+ 1) (indexOfStr x rest)

collectRecords : List CBind -> List (String, List String)
collectRecords [] = []
collectRecords ((CBind _ clauses)::rest) = collectRecordsClauses clauses
  ++ collectRecords rest

collectRecordsClauses : List CClause -> List (String, List String)
collectRecordsClauses [] = []
collectRecordsClauses ((CClause _ body)::rest) = scanExprRecords body
  ++ collectRecordsClauses rest

scanExprRecords : CExpr -> List (String, List String)
scanExprRecords (CRecord name fields) =
  (name, cFieldLabels fields) :: scanExprsRecords (cFieldExprs fields)
scanExprRecords (CFieldAccess ex _ _) = scanExprRecords ex
scanExprRecords (CRecordUpdate _ base updates) = scanExprRecords base
  ++ scanExprsRecords (cFieldExprs updates)
scanExprRecords (CVariantUpdate _ base updates) = scanExprRecords base
  ++ scanExprsRecords (cFieldExprs updates)
scanExprRecords (CTuple es) = scanExprsRecords es
scanExprRecords (CApp f a) = scanExprRecords f ++ scanExprRecords a
scanExprRecords (CLam _ body) = scanExprRecords body
scanExprRecords (CIf c t f) = scanExprRecords c
  ++ scanExprRecords t
  ++ scanExprRecords f
scanExprRecords (CBinPrim _ l r _) = scanExprRecords l ++ scanExprRecords r
scanExprRecords (CUnOp _ x) = scanExprRecords x
scanExprRecords (CLet _ _ e1 e2) = scanExprRecords e1 ++ scanExprRecords e2
scanExprRecords (CLetGroup binds body) = collectRecords binds
  ++ scanExprRecords body
scanExprRecords (CBlock stmts) = scanStmtsRecords stmts
scanExprRecords (CDecision scrut arms _) = scanExprRecords scrut
  ++ scanArmsRecords arms
scanExprRecords (CMatch scrut arms) = scanExprRecords scrut
  ++ scanArmsRecords arms
scanExprRecords (CArray es) = scanExprsRecords es
scanExprRecords (CList es) = scanExprsRecords es
scanExprRecords (CRangeArray lo hi _) = scanExprRecords lo ++ scanExprRecords hi
scanExprRecords (CRangeList lo hi _) = scanExprRecords lo ++ scanExprRecords hi
scanExprRecords (CIndex a i) = scanExprRecords a ++ scanExprRecords i
scanExprRecords (CStringIndex a i) = scanExprRecords a ++ scanExprRecords i
scanExprRecords (CStringSlice a lo hi _) = scanExprRecords a
scanExprRecords (CListIndex a i) = scanExprRecords a ++ scanExprRecords i
scanExprRecords (CListSlice a lo hi _) = scanExprRecords a
  ++ scanExprRecords lo
  ++ scanExprRecords hi
scanExprRecords (CSlice a lo hi _) = scanExprRecords a
  ++ scanExprRecords lo
  ++ scanExprRecords hi
scanExprRecords _ = []

scanExprsRecords : List CExpr -> List (String, List String)
scanExprsRecords [] = []
scanExprsRecords (e::rest) = scanExprRecords e ++ scanExprsRecords rest

scanArmsRecords : List CArm -> List (String, List String)
scanArmsRecords [] = []
scanArmsRecords ((CArm _ _ body)::rest) = scanExprRecords body
  ++ scanArmsRecords rest

scanStmtsRecords : List CStmt -> List (String, List String)
scanStmtsRecords [] = []
scanStmtsRecords ((CSExpr ex)::rest) = scanExprRecords ex
  ++ scanStmtsRecords rest
scanStmtsRecords ((CSLet _ _ ex)::rest) = scanExprRecords ex
  ++ scanStmtsRecords rest
scanStmtsRecords ((CSAssign _ ex)::rest) = scanExprRecords ex
  ++ scanStmtsRecords rest
scanStmtsRecords (_::rest) = scanStmtsRecords rest

-- ── arrays + ranges (slice 8) ────────────────────────────────────────────────
-- VALUE REPRESENTATION (RUNTIME-DESIGN.md §8 — see also §2.4a-5 in STAGE2-DESIGN.md):
-- an array is a BOXED heap cell with the same layout as an ADT cell but with the
-- header word = the raw element count (not a constructor hash):
--   [ 0: i64 raw_len | 8: elem0 | 16: elem1 … ]
-- `loadTag` thus reads the raw element count; `loadField e w i` reads element i
-- (at offset 8*(i+1)), exactly the ADT field convention.  Allocation reuses
-- @mdk_alloc; element words are uniform i64 (tagged Ints for range elements).
-- BOUNDS CHECKS: OOB calls @mdk_oob() (noreturn; prints + exits, matching eval's
-- panic).  Fixtures are in-bounds so the check never fires in practice.
-- LOOPS: CRangeArray and CSlice use an alloca-counter loop (the first non-recursion
-- loop in the spike — avoids phi instructions and matches the alloca/store/load
-- pattern the rest of the emitter uses for multi-path merges).
-- SCOPE: CList and CRangeList are covered by slice 9 ("lists" section below).
-- list MATCH (HCons/HNil) works from slice 5b.
-- SPIKE-REP NOTES (slice 8; extending (a)–(p)):
--   (q) ARRAY CELL — header word = raw_len (not hashName), so `loadTag` gives the
--       count directly.  Element i is at offset 8*(i+1), consistent with `loadField`.
--   (r) BOUNDS CHECK — two icmps (idx < 0 || idx >= len) OR'd, br to an @mdk_oob
--       block (call + unreachable); the ok path continues inline.
--   (s) RANGE LOOP — alloca i64 counter + load/store inside the loop; each element
--       = `tagInt(lo_raw + i)`.  CFG: br to cond block → load/icmp/br → body
--       (compute+store+increment) → back to cond; done block receives the br on
--       exit.  No phi nodes (consistent with the rest of the emitter).
--   (t) SLICE LOOP — same alloca-counter pattern; each iteration loads element
--       (lo_raw+i) from the source array via `loadFieldDyn` and stores it to dest
--       field i.

-- allocate an array cell with a STATICALLY known element list; header = raw count.
emitArrayAlloc : Emit -> Int -> List String -> (String, LTy)
emitArrayAlloc e n fields =
  let p = freshReg e
  let _ = emit e "  \{p} = call ptr @mdk_alloc(i64 \{intToString (8 * (n + 1))})"
  let _ = emit e "  store i64 \{intToString n}, ptr \{p}"
  let _ = storeFields e p fields 0
  let w = freshReg e
  let _ = emit e "  \{w} = ptrtoint ptr \{p} to i64"
  (w, LTCon)

-- allocate an array cell with a DYNAMIC element count (for ranges and slices);
-- returns the raw ptr register (caller fills element fields).
emitArrayDynAlloc : Emit -> String -> String
emitArrayDynAlloc e len_raw =
  let sz = freshReg e
  let _ = emit e "  \{sz} = add i64 \{len_raw}, 1"
  let bytes = freshReg e
  let _ = emit e "  \{bytes} = mul i64 \{sz}, 8"
  let p = freshReg e
  let _ = emit e "  \{p} = call ptr @mdk_alloc(i64 \{bytes})"
  let _ = emit e "  store i64 \{len_raw}, ptr \{p}"
  p

-- CArray [e0, e1, …]: allocate a static-size array cell, emit each element,
-- store them as fields, return the cell pointer word.
emitArrayCreate : Emit -> List (String, (String, LTy)) -> List CExpr -> (String, LTy)
emitArrayCreate e env es =
  let words = emitArgs e env es
  emitArrayAlloc e (lengthS words) words

-- load a cell field at a DYNAMIC index (offset = (idxRaw+1)*8).  Used for CIndex
-- and the CSlice copy loop.
loadFieldDyn : Emit -> String -> String -> String
loadFieldDyn e ptrWord idxRaw =
  let p = freshReg e
  let _ = emit e "  \{p} = inttoptr i64 \{ptrWord} to ptr"
  let off1 = freshReg e
  let _ = emit e "  \{off1} = add i64 \{idxRaw}, 1"
  let off = freshReg e
  let _ = emit e "  \{off} = mul i64 \{off1}, 8"
  let fp = freshReg e
  let _ = emit e "  \{fp} = getelementptr i8, ptr \{p}, i64 \{off}"
  let f = freshReg e
  let _ = emit e "  \{f} = load i64, ptr \{fp}"
  f

-- store `val` (an i64 word) to element at dynamic index `idxRaw` of a boxed array.
-- mirrors loadFieldDyn verbatim, but ends with a store instead of a load.
storeFieldDyn : Emit -> String -> String -> String -> Unit
storeFieldDyn e ptrWord idxRaw val =
  let p = freshReg e
  let _ = emit e "  \{p} = inttoptr i64 \{ptrWord} to ptr"
  let off1 = freshReg e
  let _ = emit e "  \{off1} = add i64 \{idxRaw}, 1"
  let off = freshReg e
  let _ = emit e "  \{off} = mul i64 \{off1}, 8"
  let fp = freshReg e
  let _ = emit e "  \{fp} = getelementptr i8, ptr \{p}, i64 \{off}"
  let _ = emit e "  store i64 \{val}, ptr \{fp}"
  ()

-- CIndex arr i: bounds-check, then load element at dynamic offset.
emitArrayIndex : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> (String, LTy)
emitArrayIndex e env a i =
  let (arr_w, _) = emitExpr e env a
  let (idx_w, _) = emitExpr e env i
  let idx_raw = untagInt e idx_w
  let arr_len = loadTag e arr_w
  let c1 = freshReg e
  let _ = emit e "  \{c1} = icmp slt i64 \{idx_raw}, 0"
  let c2 = freshReg e
  let _ = emit e "  \{c2} = icmp sge i64 \{idx_raw}, \{arr_len}"
  let oob = freshReg e
  let _ = emit e "  \{oob} = or i1 \{c1}, \{c2}"
  let n = intToString (freshLocal e)
  let oobL = "oob" ++ n
  let okL = "idx_ok" ++ n
  let _ = emit e "  br i1 \{oob}, label %\{oobL}, label %\{okL}"
  let _ = emit e (oobL ++ ":")
  let _ = emit e "  call void @mdk_oob()"
  let _ = emit e "  unreachable"
  let _ = emit e (okL ++ ":")
  let r = loadFieldDyn e arr_w idx_raw
  (r, LTInt)

-- CRangeArray lo hi incl: compute count, alloc, fill with alloca-counter loop.
emitRangeArray : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> Bool -> (String, LTy)
emitRangeArray e env lo hi incl =
  let (lo_w, _) = emitExpr e env lo
  let (hi_w, _) = emitExpr e env hi
  let lo_raw = untagInt e lo_w
  let hi_raw = untagInt e hi_w
  let hi_adj = if incl then
    let r = freshReg e
    let _ = emit e "  \{r} = add i64 \{hi_raw}, 1"
    r
  else hi_raw
  let count = freshReg e
  let _ = emit e "  \{count} = sub i64 \{hi_adj}, \{lo_raw}"
  let p = emitArrayDynAlloc e count
  let n = intToString (freshLocal e)
  let condL = "rng_cond" ++ n
  let bodyL = "rng_body" ++ n
  let doneL = "rng_done" ++ n
  let ic = freshReg e
  let _ = emit e ("  " ++ ic ++ " = alloca i64")
  let _ = emit e ("  store i64 0, ptr " ++ ic)
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (condL ++ ":")
  let iv = freshReg e
  let _ = emit e "  \{iv} = load i64, ptr \{ic}"
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp sge i64 \{iv}, \{count}"
  let _ = emit e "  br i1 \{cmp}, label %\{doneL}, label %\{bodyL}"
  let _ = emit e (bodyL ++ ":")
  let elem_sum = freshReg e
  let _ = emit e "  \{elem_sum} = add i64 \{lo_raw}, \{iv}"
  let elem_w = tagInt e elem_sum
  let off1 = freshReg e
  let _ = emit e "  \{off1} = add i64 \{iv}, 1"
  let off = freshReg e
  let _ = emit e "  \{off} = mul i64 \{off1}, 8"
  let fp = freshReg e
  let _ = emit e "  \{fp} = getelementptr i8, ptr \{p}, i64 \{off}"
  let _ = emit e "  store i64 \{elem_w}, ptr \{fp}"
  let iv2 = freshReg e
  let _ = emit e "  \{iv2} = add i64 \{iv}, 1"
  let _ = emit e "  store i64 \{iv2}, ptr \{ic}"
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (doneL ++ ":")
  let w = freshReg e
  let _ = emit e "  \{w} = ptrtoint ptr \{p} to i64"
  (w, LTCon)

-- CSlice arr lo hi incl: compute new_len, alloc, copy elements with loop.
emitArraySlice : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> CExpr -> Bool -> (String, LTy)
emitArraySlice e env a lo hi incl =
  let (arr_w, _) = emitExpr e env a
  let (lo_w, _) = emitExpr e env lo
  let (hi_w, _) = emitExpr e env hi
  let lo_raw = untagInt e lo_w
  let hi_raw = untagInt e hi_w
  let end_raw = if incl then
    let r = freshReg e
    let _ = emit e "  \{r} = add i64 \{hi_raw}, 1"
    r
  else hi_raw
  let new_len = freshReg e
  let _ = emit e "  \{new_len} = sub i64 \{end_raw}, \{lo_raw}"
  let p = emitArrayDynAlloc e new_len
  let n = intToString (freshLocal e)
  let condL = "sl_cond" ++ n
  let bodyL = "sl_body" ++ n
  let doneL = "sl_done" ++ n
  let ic = freshReg e
  let _ = emit e ("  " ++ ic ++ " = alloca i64")
  let _ = emit e ("  store i64 0, ptr " ++ ic)
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (condL ++ ":")
  let iv = freshReg e
  let _ = emit e "  \{iv} = load i64, ptr \{ic}"
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp sge i64 \{iv}, \{new_len}"
  let _ = emit e "  br i1 \{cmp}, label %\{doneL}, label %\{bodyL}"
  let _ = emit e (bodyL ++ ":")
  let src_idx = freshReg e
  let _ = emit e "  \{src_idx} = add i64 \{lo_raw}, \{iv}"
  let elem = loadFieldDyn e arr_w src_idx
  let dst_off1 = freshReg e
  let _ = emit e "  \{dst_off1} = add i64 \{iv}, 1"
  let dst_off = freshReg e
  let _ = emit e "  \{dst_off} = mul i64 \{dst_off1}, 8"
  let dst_fp = freshReg e
  let _ = emit e "  \{dst_fp} = getelementptr i8, ptr \{p}, i64 \{dst_off}"
  let _ = emit e "  store i64 \{elem}, ptr \{dst_fp}"
  let iv2 = freshReg e
  let _ = emit e "  \{iv2} = add i64 \{iv}, 1"
  let _ = emit e "  store i64 \{iv2}, ptr \{ic}"
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (doneL ++ ":")
  let w = freshReg e
  let _ = emit e "  \{w} = ptrtoint ptr \{p} to i64"
  (w, LTCon)

-- CStringIndex s i: codepoint-indexed Char.  The String runtime rep is a packed
-- UTF-8 cell (NOT an i64-element array), so we mirror the interpreter's
-- stringIndexCp: convert to a Char array via @mdk_string_to_chars (each element
-- already a Char immediate (cp<<1)|1, header = codepoint count), bounds-check the
-- codepoint index against that count, then load element i.  Result LTy = LTChar.
-- Bounds violation calls @mdk_oob (matching the interpreter's index-OOB panic).
emitStringIndex : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> (String, LTy)
emitStringIndex e env a i =
  let (str_w, _) = emitExpr e env a
  let (idx_w, _) = emitExpr e env i
  let chars = freshReg e
  let _ = emit e "  \{chars} = call i64 @mdk_string_to_chars(i64 \{str_w})"
  let idx_raw = untagInt e idx_w
  let arr_len = loadTag e chars
  let c1 = freshReg e
  let _ = emit e "  \{c1} = icmp slt i64 \{idx_raw}, 0"
  let c2 = freshReg e
  let _ = emit e "  \{c2} = icmp sge i64 \{idx_raw}, \{arr_len}"
  let oob = freshReg e
  let _ = emit e "  \{oob} = or i1 \{c1}, \{c2}"
  let n = intToString (freshLocal e)
  let oobL = "soob" ++ n
  let okL = "sidx_ok" ++ n
  let _ = emit e "  br i1 \{oob}, label %\{oobL}, label %\{okL}"
  let _ = emit e (oobL ++ ":")
  let _ = emit e "  call void @mdk_oob()"
  let _ = emit e "  unreachable"
  let _ = emit e (okL ++ ":")
  let r = loadFieldDyn e chars idx_raw
  (r, LTChar)

-- CStringSlice s lo hi incl: codepoint substring.  Mirror the interpreter's
-- evalSliceInt VString = stringSlice lo (incl ? hi+1 : hi) s — which CLAMPS lo/hi
-- to [0, cp_count] (no OOB panic, unlike the array slice).  Reuse the
-- @mdk_string_slice extern (it >>1-untags the tagged Int bounds internally); for
-- the inclusive form hi+1 in value space is +2 on the tagged word (tag = n*2+1).
emitStringSlice : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> CExpr -> Bool -> (String, LTy)
emitStringSlice e env a lo hi incl =
  let (str_w, _) = emitExpr e env a
  let (lo_w, _) = emitExpr e env lo
  let (hi_w, _) = emitExpr e env hi
  let hi_adj = if incl then
    let r = freshReg e
    let _ = emit e "  \{r} = add i64 \{hi_w}, 2"
    r
  else hi_w
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @mdk_string_slice(i64 \{lo_w}, i64 \{hi_adj}, i64 \{str_w})"
  (r, LTStr)

-- CListIndex xs i: walk the Cons chain to the i-th element.  A List is a chain of
-- Cons cells ([tag|head@8|tail@16], Nil = odd immediate), NOT an i64-element
-- array, so we can't array-GEP it.  Mirror the interpreter's listNthAt: walk
-- (i decrementing) returning the head once i<=0, panic (@mdk_oob) on running off
-- the end.  @mdk_list_index does the walk in C (>>1-untags the tagged index).
-- Result word is the stored head (same shape as an array load → LTInt).
emitListIndex : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> (String, LTy)
emitListIndex e env a i =
  let (lst_w, _) = emitExpr e env a
  let (idx_w, _) = emitExpr e env i
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @mdk_list_index(i64 \{lst_w}, i64 \{idx_w})"
  (r, LTInt)

-- CListSlice xs lo hi incl: collect elements at indices [lo, hi) into a NEW list.
-- Mirror the interpreter's listSliceV/listSliceGo — which CLAMPS (no OOB panic):
-- walks the chain with a running index, keeps heads in [lo, hi), stops at hi or
-- end-of-list.  @mdk_list_slice does the walk + rebuild in C (>>1-untags lo/hi);
-- for the inclusive form hi+1 in value space is +2 on the tagged word (tag n*2+1).
-- Result is a boxed Cons/Nil list → LTCon (same as the array slice).
emitListSlice : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> CExpr -> Bool -> (String, LTy)
emitListSlice e env a lo hi incl =
  let (lst_w, _) = emitExpr e env a
  let (lo_w, _) = emitExpr e env lo
  let (hi_w, _) = emitExpr e env hi
  let hi_adj = if incl then
    let r = freshReg e
    let _ = emit e "  \{r} = add i64 \{hi_w}, 2"
    r
  else hi_w
  let r = freshReg e
  let _ = emit e "  \{r} = call i64 @mdk_list_slice(i64 \{lst_w}, i64 \{lo_w}, i64 \{hi_adj})"
  (r, LTCon)

-- arrayMakeWith n f: INLINE INTRINSIC.  Allocates a dynamic array of `n` elements;
-- fills element i by calling the Medaka closure `f` with the tagged index `i`.
-- Shape mirrors emitRangeArray (alloca-counter loop) + emitIndirect (closure call).
-- No C extern; the closure is called directly from the emitted loop body.
emitArrayMakeWith : Emit -> List (String, (String, LTy)) -> List CExpr -> (String, LTy)
emitArrayMakeWith e env [nExpr, fExpr] =
  let (n_w, _) = emitExpr e env nExpr
  let (fw, _) = emitExpr e env fExpr
  let count = untagInt e n_w
  let p = emitArrayDynAlloc e count
  let n = intToString (freshLocal e)
  let condL = "mw_cond" ++ n
  let bodyL = "mw_body" ++ n
  let doneL = "mw_done" ++ n
  let ic = freshReg e
  let _ = emit e ("  " ++ ic ++ " = alloca i64")
  let _ = emit e ("  store i64 0, ptr " ++ ic)
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (condL ++ ":")
  let iv = freshReg e
  let _ = emit e "  \{iv} = load i64, ptr \{ic}"
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp sge i64 \{iv}, \{count}"
  let _ = emit e "  br i1 \{cmp}, label %\{doneL}, label %\{bodyL}"
  let _ = emit e (bodyL ++ ":")
  let ti = tagInt e iv
  let cp = loadField e fw 0
  let fp = freshReg e
  let _ = emit e "  \{fp} = inttoptr i64 \{cp} to ptr"
  let elem = freshReg e
  let _ = emit e "  \{elem} = call i64 \{fp}(i64 \{fw}, i64 \{ti})"
  let off1 = freshReg e
  let _ = emit e "  \{off1} = add i64 \{iv}, 1"
  let off = freshReg e
  let _ = emit e "  \{off} = mul i64 \{off1}, 8"
  let ep = freshReg e
  let _ = emit e "  \{ep} = getelementptr i8, ptr \{p}, i64 \{off}"
  let _ = emit e "  store i64 \{elem}, ptr \{ep}"
  let iv2 = freshReg e
  let _ = emit e "  \{iv2} = add i64 \{iv}, 1"
  let _ = emit e "  store i64 \{iv2}, ptr \{ic}"
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (doneL ++ ":")
  let w = freshReg e
  let _ = emit e "  \{w} = ptrtoint ptr \{p} to i64"
  (w, LTCon)
emitArrayMakeWith e env _ = gapE "arrayMakeWith takes two arguments"

-- ── lists (slice 9) ─────────────────────────────────────────────────────────
-- VALUE REPRESENTATION: a list is a chain of boxed Cons cells (matching the
-- slice-5b match heads HCons/HNil, which test `cellTag` of "Cons"/"Nil").
-- The built-in list is not user-declared, so "Cons"/"Nil" are absent from the
-- ctor→type table and `cellTag` gives them the reserved list-type id with ordinals
-- 0 (Cons) and 1 (Nil) — UNLESS a user `data` owns those names, in which case both
-- the list literal and the user ctor resolve to that type's ordinal (they alias,
-- exactly as they did under the old hash).  Cell layouts (8-byte words):
--   Nil  → odd immediate (nullary; low bit 1)                  (no cell allocated)
--   Cons → [ i64 cellTag "Cons" | i64 head | i64 tail ]   (3-word cell)
-- Construction uses emitCtorAlloc "Nil" [] / emitCtorAlloc "Cons" [hw, tw]
-- verbatim — the SAME tag the slice-5b switch tests, so construction
-- and match agree by construction.
--
-- SPIKE-REP NOTES (slice 9; extending (a)–(t)):
--   (u) CList [e0…en] is RIGHT-FOLDED INLINE (compile-time unroll): N+1 allocs
--       emitted as a straight-line sequence from tail to head.  No loop, no
--       stack growth — the list size is statically known.  Consistent with
--       emitTuple (which also unrolls inline for a static arity).
--   (v) CRangeList lo hi incl uses an ALLOCA-COUNTER LOOP (back-to-front):
--       initialise tail=Nil, i=count-1; while i≥0 prepend Cons(lo+i, tail) and
--       decrement i.  Back-to-front builds the list in ascending order (lo…hi)
--       without reversing.  An alloca i64 `acc` holds the current list head word
--       (a cell pointer as i64), so the same alloca/store/load discipline the
--       rest of the emitter uses for multi-path merges.  An empty range (count≤0)
--       returns Nil immediately (i=count-1 < 0 on first test).  This approach
--       matches the slice-8 loop pattern and avoids stack overflow on large ranges.

-- CList [e0, e1, …, en]: right-fold to Cons cells, innermost first.
emitList : Emit -> List (String, (String, LTy)) -> List CExpr -> (String, LTy)
emitList e _ [] = emitCtorAlloc e "Nil" []
emitList e env xs =
  let words = emitListWords e env xs
  if allConstWords words then emitConstList e words else emitRtList e words

-- emit every element to its operand word, head-to-tail (same order as the original
-- recursive emitList's element emission).
emitListWords : Emit -> List (String, (String, LTy)) -> List CExpr -> List String
emitListWords _ _ [] = []
emitListWords e env (x::xs) =
  let (w, _) = emitExpr e env x
  w :: emitListWords e env xs

-- runtime cons chain from already-emitted element words (back-to-front), IR-identical
-- to the original recursive emitList for the non-constant case.
emitRtList : Emit -> List String -> (String, LTy)
emitRtList e [] = emitCtorAlloc e "Nil" []
emitRtList e (w::rest) =
  let (tw, _) = emitRtList e rest
  emitCtorAlloc e "Cons" [w, tw]

-- a list literal whose elements are ALL compile-time constants: build the cons spine
-- as a chain of `internal constant` module globals (one cell per element, tail = the
-- next cell's pointer-constant; the base is the Nil immediate) instead of allocating
-- N cons cells at every evaluation. `==` on lists is structural, so sharing/dedup is
-- value-safe. Deduped via the same constant-cell cache as dict witnesses.
emitConstList : Emit -> List String -> (String, LTy)
emitConstList e words =
  let nilImm = intToString (cellTag e "Nil" * 2 + 1)
  let head = emitConstListGo e (cellTag e "Cons") (reverseL words) nilImm
  (head, LTCon)

emitConstListGo : Emit -> Int -> List String -> String -> String
emitConstListGo _ _ [] tl = tl
emitConstListGo e consTag (w::rest) tl =
  let cell = emitConstDictCell e consTag [w, tl]
  emitConstListGo e consTag rest cell

-- CRangeList lo hi incl: build an ascending list [lo…hi] (or [lo…<hi]) via a
-- back-to-front alloca-counter loop.  An alloca i64 `acc` holds the current
-- head pointer; a second alloca i64 `ic` holds the loop counter (count-1 downto 0).
emitRangeList : Emit -> List (String, (String, LTy)) -> CExpr -> CExpr -> Bool -> (String, LTy)
emitRangeList e env lo hi incl =
  let (lo_w, _) = emitExpr e env lo
  let (hi_w, _) = emitExpr e env hi
  let lo_raw = untagInt e lo_w
  let hi_raw = untagInt e hi_w
  let hi_adj = if incl then
    let r = freshReg e
    let _ = emit e "  \{r} = add i64 \{hi_raw}, 1"
    r
  else hi_raw
  let count = freshReg e
  let _ = emit e "  \{count} = sub i64 \{hi_adj}, \{lo_raw}"
  let (nil_w, _) = emitCtorAlloc e "Nil" []
  let acc = freshReg e
  let _ = emit e ("  " ++ acc ++ " = alloca i64")
  let _ = emit e "  store i64 \{nil_w}, ptr \{acc}"
  let ic = freshReg e
  let _ = emit e ("  " ++ ic ++ " = alloca i64")
  let im1 = freshReg e
  let _ = emit e "  \{im1} = sub i64 \{count}, 1"
  let _ = emit e "  store i64 \{im1}, ptr \{ic}"
  let n = intToString (freshLocal e)
  let condL = "rl_cond" ++ n
  let bodyL = "rl_body" ++ n
  let doneL = "rl_done" ++ n
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (condL ++ ":")
  let iv = freshReg e
  let _ = emit e "  \{iv} = load i64, ptr \{ic}"
  let cmp = freshReg e
  let _ = emit e "  \{cmp} = icmp slt i64 \{iv}, 0"
  let _ = emit e "  br i1 \{cmp}, label %\{doneL}, label %\{bodyL}"
  let _ = emit e (bodyL ++ ":")
  let elem_raw = freshReg e
  let _ = emit e "  \{elem_raw} = add i64 \{lo_raw}, \{iv}"
  let elem_w = tagInt e elem_raw
  let tail_w = freshReg e
  let _ = emit e "  \{tail_w} = load i64, ptr \{acc}"
  let (cons_w, _) = emitCtorAlloc e "Cons" [elem_w, tail_w]
  let _ = emit e "  store i64 \{cons_w}, ptr \{acc}"
  let iv2 = freshReg e
  let _ = emit e "  \{iv2} = sub i64 \{iv}, 1"
  let _ = emit e "  store i64 \{iv2}, ptr \{ic}"
  let _ = emit e ("  br label %" ++ condL)
  let _ = emit e (doneL ++ ":")
  let r = freshReg e
  let _ = emit e "  \{r} = load i64, ptr \{acc}"
  (r, LTCon)
-- Seed the accumulator with Nil.

-- Counter starts at count-1 (back-to-front).

-- ── program ─────────────────────────────────────────────────────────────────
-- Emit a whole CProgram as a textual LLVM module: the runtime declares, then one
-- LLVM function per top-level `name p… = …` binding (slice 2), then a single
-- `@main` that computes the top-level nullary value bindings (in source order),
-- then `main`'s body, then a type-directed print.
export emitProgram : CProgram -> String
emitProgram (CProgram groups ctorArs ctorTypes implEntries) =
  let e = Emit {
    -- issue #118: the two halves are emitted by INDEPENDENT emitter runs, so they
    -- get disjoint gensym ranges or their lifted defines collide — see
    -- programHalfIdBase.  Mode 0 keeps starting at 0, so its IR is unchanged.
    counter = Ref (if emitHalfRef.value == emitHalfProgram then programHalfIdBase else 0),
    buf = Ref [],
    fnNames = Ref (collectFns groups),
    sigs = Ref (inferSigs (fnBinds groups)),
    ctors = Ref ctorArs,
    lams = Ref [],
    recFields = Ref (collectRecords groups),
    implEntries = Ref implEntries,
    ctorTypes = Ref ctorTypes,
    -- The PRELUDE half emits no `@mdk_program_main`, hence no init prologue to mark
    -- the globals initialised as it computes them — so they start READY, exactly as
    -- the non-emitting gaps driver does (initGlobalsRegReady).  Without this every
    -- prelude body that loads a global would hit the forward-dependency gap.
    globalsReg = Ref (if emitHalfRef.value == emitHalfPrelude then
      initGlobalsRegReady (valBinds groups)
    else
      initGlobalsReg (valBinds groups)),
  }
  let _ = resetDistinctTypeNames ()
  let _ = setRef dictConstCacheRef []
  let _ = setRef dispCacheRef []
  let _ = installKnownFnMap (collectFns groups)
  let _ = installCtorMap ctorArs
  let _ = installSigMap (sigTable e)
  let _ = installDefArityMap e (fnBinds groups)
  -- (b′) dispatch-graph TMC: run the SHARED detection (backend/trmc_analysis.mdk)
  -- before any fn emit, so emitFn can route group members/roots.  Hooks: the LLVM
  -- canonFnName + a clause-derived fn-arity table with wasm's progFnArity contract
  -- (-1 when unknown); v5's stage-1-claims hook is the LLVM Stage-1 gate (no
  -- uniform-ctor condition — the backends' hooks unify when wasm's gate retires).
  -- gDispGroupEtaStable then drops any group containing a single-clause member
  -- that eta-saturation would re-arity (deficit > 0 — such a member's inlined
  -- clause-arity body would diverge from the ordinary define's ABI); dropped
  -- groups fall back to ordinary codegen, no transform, no regression.
  let _ = setRef gDispArsRef (gDispFnArsOf (fnBinds groups))
  let _ = setRef gDispBindsRef (fnBinds groups)
  let dispGroups0 = detectDispatchGroups
    (n => canonFnName e n)
    (n => gDispIsFn n)
    (n => gDispFnArity n)
    (nm ar cs => gDispStage1Claims e nm ar cs)
    (fnBinds groups)
    groups
    implEntries
  let _ = setRef gDispGroupsRef (gDispKeepEtaStable e (fnBinds groups) dispGroups0)
  -- a group member must never be ADVERTISED as having a float `__fw` worker (the
  -- group path emits no standalone defines, so a float-context caller would call
  -- a nonexistent symbol; v3/v4 make external float callers impossible anyway —
  -- belt and braces).
  let _ = setRef floatFwSetRef (gDispDropMembers (collectFloatFw e (fnBinds groups)))
  let _ = setRef floatClosureFnsRef (collectFloatClosureFns e (fnBinds groups))
  let _ = resetEmittedDefaults ()
  let _ = emitPreamble e
  let _ = emitGlobalDecls e (valBinds groups)
  -- issue #118: the PRELUDE half is a LIBRARY — it has no entry point, and the
  -- program half's `@mdk_program_main` is the one that defines and initialises
  -- every `@mdk_g_*` (the prelude's included).
  let _ = if emitHalfRef.value == emitHalfPrelude then () else emitProgramMain e groups
  let _ = emitFns e (fnBinds groups)
  let _ = emitImpls e implEntries
  let _ = preludeIdSpaceGuard e
  joinNl (reverseL e.buf.value ++ reverseL e.lams.value)

-- `@mdk_program_main`: the init prologue (every top-level value binding's rhs, in
-- source order) followed by `main`'s own body and the type-directed print.
emitProgramMain : Emit -> List CBind -> Unit
emitProgramMain e groups =
  let _ = beginDefine e
  let _ = emit e "define i32 @mdk_program_main(i32 %argc, ptr %argv) {"
  let _ = emit e "entry:"
  let _ = emit e "  call void @mdk_set_args(i32 %argc, ptr %argv)"
  let _ = emitTopGlobals e (orderedValBinds (valBinds groups))
  let (mv, mty) = emitExpr e [] (mainBody groups)
  -- A Unit-returning `main` produces output ONLY through explicit print calls (or
  -- a panic); never auto-print its `()` result.  Detected by the DECLARED return
  -- type (`declSigOf "main"` → "Unit", robust even when the body LTy is
  -- mis-inferred — e.g. the medaka CLI's own `match`-bodied main, which otherwise
  -- printed a stray `0`) OR a body LTy that is already LTUnit (an unannotated IO
  -- `main = putStrLn …`).  Value-returning mains keep auto-printing (the pp_value
  -- differential-test contract).
  -- C4: if the typecheck Float hint is set, override the structural LTy so the
  -- print path uses the Float formatter even when emitExpr returns LTUnknown/LTInt
  -- (the type-erased result from a polymorphic HOF like `fold`).
  let mty2 = if mainIsFloatHintRef.value then LTFloat else mty
  let _ = if mainIsUnit e mty2 then () else emitPrint e mv mty2
  let _ = emit e "  ret i32 0"
  emit e "}"
-- declare a module global per top-level value/`Ref` binding (slice E1b).

-- emit `@main` FIRST: its init prologue computes each value-binding rhs in
-- SOURCE ORDER and marks the registry, so the globals' LTys are resolved before
-- the function `define`s (emitted next) reference them.  LLVM module-item order
-- is irrelevant, so emitting `@main` ahead of the fn/impl defines is sound.

-- the function + impl defines (registry now fully initialised, so any body may
-- reference any global via a `load i64, ptr @mdk_g_<name>`).

-- the module body (preamble, @main, fn/impl defines) in forward order, then the
-- side buffer (string-literal + value-binding globals, lifted-lambda defines).
-- LLVM module-item order is irrelevant, so appending the side buffer is sound.

emitPreamble : Emit -> Unit
emitPreamble e = emitLines e preambleLines

-- emit each constant preamble line in order; the strings live in
-- backend.llvm_preamble (pure data) so this module's `emit`/`Emit` machinery
-- stays here without a circular import.
emitLines : Emit -> List String -> Unit
emitLines _ [] = ()
emitLines e (line::rest) =
  let _ = emit e line
  emitLines e rest

-- the `@main` init prologue (slice E1b): compute each top-level value/`Ref`
-- binding's rhs in SOURCE ORDER and `store` the word into its module global
-- `@mdk_g_<name>`, then mark the registry entry initialised with the rhs's LTy.
-- Computing in source order means a binding referencing an EARLIER one loads the
-- already-stored global; a reference to a LATER (not-yet-marked) global hits the
-- forward/mutual-dependency gap in lookupVarG instead of an uninitialised 0.
-- A `Ref v` rhs allocs its cell as usual → the stored word is the cell POINTER, so
-- `.value`/`setRef` deref through the loaded global.
emitTopGlobals : Emit -> List CBind -> Unit
emitTopGlobals _ [] = ()
emitTopGlobals e ((CBind name [CClause [] body])::rest) =
  let (v, ty) = emitExpr e [] body
  let _ = emit e "  store i64 \{v}, ptr @mdk_g_\{name}"
  let _ = markGlobalInit e name ty
  emitTopGlobals e rest
emitTopGlobals _ ((CBind name _)::_) =
  panic
    ("llvm spike: top-level function '" ++ name ++ "' unsupported in slice 1 (value bindings only)")

-- Hint from the driver: True when typecheck resolved main's inferred return type to
-- Unit (e.g. via a polymorphic HOF whose result specialises to Unit with no explicit
-- annotation).  Set by the emit driver after elaborateModules via installMainIsUnitHint.
mainIsUnitHintRef : Ref Bool
mainIsUnitHintRef = Ref False

export installMainIsUnitHint : Bool -> Unit
installMainIsUnitHint b = setRef mainIsUnitHintRef b

-- Hint from the driver: True when typecheck resolved main's inferred return type to
-- Float (e.g. via a polymorphic HOF whose result specialises to Float with no explicit
-- annotation).  Set by the emit driver after elaborateModules via installMainIsFloatHint.
-- C4 (SHARED-FLOAT-RESIDUAL-DESIGN §6): fixes bare Float value mains that print garbage
-- because the structural mainKind sees LTInt on a type-erased polymorphic-HOF return.
mainIsFloatHintRef : Ref Bool
mainIsFloatHintRef = Ref False

export installMainIsFloatHint : Bool -> Unit
installMainIsFloatHint b = setRef mainIsFloatHintRef b

-- Is `main` Unit-returning (→ suppress the auto-print of its result)?  Three checks:
-- 1. The typecheck-inferred-Unit hint (installMainIsUnitHint) — catches unannotated
--    mains whose return type resolved to Unit through a polymorphic HOF.
-- 2. The DECLARED return type (declSigOf "main" → "Unit") — catches the annotated
--    case `main : <IO> Unit`; effects already stripped by core_ir_lower.methodRetTy.
-- 3. The body's emit-time LTy (LTUnit) — catches the simple `main = putStrLn …` case.
mainIsUnit : Emit -> LTy -> Bool
mainIsUnit e mty =
  if mainIsUnitHintRef.value then True
  else match declSigOf "main"
    Some (_, "Unit") => True
    _ => match mty
      LTUnit => True
      _ => False

emitPrint : Emit -> String -> LTy -> Unit
emitPrint e v LTInt =
  let i = untagInt e v
  emit e ("  call void @mdk_print_int(i64 " ++ i ++ ")")
emitPrint e v LTBool =
  let i = untagInt e v
  emit e ("  call void @mdk_print_bool(i64 " ++ i ++ ")")
emitPrint e v LTFloat =
  let d = unboxFloat e v
  emit e ("  call void @mdk_print_float(double " ++ d ++ ")")
emitPrint e v LTStr = emit e ("  call void @mdk_print_str(i64 " ++ v ++ ")")
-- LTUnknown reaches print only for the dominant String-builder case (a chained
-- `++` whose value is a String); print it as a String, matching the old LTStr
-- default.  A list-valued LTUnknown is never printed by the bootstrap fixtures.
emitPrint e v LTUnknown = emit e ("  call void @mdk_print_str(i64 " ++ v ++ ")")
emitPrint e _ LTUnit = emit e "  call void @mdk_print_unit()"
emitPrint e v LTChar = emit e ("  call void @mdk_print_char(i64 " ++ v ++ ")")
-- G3: a polymorphic Num result (LTNum) is an Int OR boxed-Float word; dispatch
-- the print on its runtime tag via @mdk_print_num (mirrors the @mdk_num_* arith).
emitPrint e v LTNum = emit e ("  call void @mdk_print_num(i64 " ++ v ++ ")")
emitPrint _ _ LTCon =
  panic
    "llvm spike: cannot print an ADT value (slice 3: `main` must reduce to a scalar Int/Bool/Float)"
emitPrint _ _ LTClosure =
  panic
    "llvm spike: cannot print a closure value (slice 4: `main` must reduce to a scalar Int/Bool/Float)"

-- the body of the `main` binding (must be a nullary clause).
mainBody : List CBind -> CExpr
mainBody [] = panic "llvm spike: no `main` binding"
mainBody ((CBind "main" [CClause [] body])::_) = body
mainBody ((CBind "main" _)::_) =
  panic "llvm spike: `main` must be a nullary value (main = ...)"
mainBody (_::rest) = mainBody rest

-- a readable tag for the unsupported-node panic (only the nodes a slice-1
-- fixture could hit if it strayed out of scope).
ctag : CExpr -> String
ctag (CApp _ _) = "CApp (function application)"
ctag (CLam _ _) = "CLam (lambda)"
ctag (CMatch _ _) = "CMatch"
ctag (CDecision _ _ _) = "CDecision (match)"
ctag (CTuple _) = "CTuple"
ctag (CList _) = "CList"
ctag (CArray _) = "CArray"
ctag (CRecord _ _) = "CRecord"
ctag (CFieldAccess _ _ _) = "CFieldAccess"
ctag (CRecordUpdate _ _ _) = "CRecordUpdate"
ctag (CRangeList _ _ _) = "CRangeList"
ctag (CRangeArray _ _ _) = "CRangeArray"
ctag (CIndex _ _) = "CIndex"
ctag (CSlice _ _ _ _) = "CSlice"
ctag (CStringIndex _ _) = "CStringIndex"
ctag (CStringSlice _ _ _ _) = "CStringSlice"
ctag (CListIndex _ _) = "CListIndex"
ctag (CListSlice _ _ _ _) = "CListSlice"
ctag (CMethod _ _ _ _) = "CMethod (typeclass dispatch)"
ctag (CDict _ _) = "CDict (dictionary)"
ctag (CVariantUpdate _ _ _) = "CVariantUpdate (named-field variant update)"
ctag _ = "?"

-- ── D4 emitter-completeness inventory entry point ───────────────────────────
-- Mirrors emitProgram's setup but turns gap-recording ON, attributes each gap to
-- the top-level binding / impl group being emitted, and SKIPS the `@main` path (a
-- real prelude/compiler module carries no `main`).  Emits every fn-bind, value
-- bind, and impl group; returns the recorded gap events ("<binding>\t<reason>").
-- The emitted LLVM text is discarded by the probe — only the gap log matters.
export emitProgramGaps : CProgram -> List String
emitProgramGaps (CProgram groups ctorArs ctorTypes implEntries) =
  let e = Emit {
    counter = Ref 0,
    buf = Ref [],
    fnNames = Ref (collectFns groups),
    sigs = Ref (inferSigs (fnBinds groups)),
    ctors = Ref ctorArs,
    lams = Ref [],
    recFields = Ref (collectRecords groups),
    implEntries = Ref implEntries,
    ctorTypes = Ref ctorTypes,
    globalsReg = Ref (initGlobalsRegReady (valBinds groups)),
  }
  let _ = resetDistinctTypeNames ()
  let _ = setRef dictConstCacheRef []
  let _ = setRef dispCacheRef []
  let _ = installKnownFnMap (collectFns groups)
  let _ = installCtorMap ctorArs
  let _ = installSigMap (sigTable e)
  let _ = installDefArityMap e (fnBinds groups)
  let _ = setRef floatFwSetRef (collectFloatFw e (fnBinds groups))
  let _ = setRef floatClosureFnsRef (collectFloatClosureFns e (fnBinds groups))
  -- the gap census emits every bind ORDINARILY — reset the (b′) groups so a prior
  -- emitProgram's routing state can never leak into this path.
  let _ = setRef gDispGroupsRef []
  let _ = resetGaps ()
  let _ = enableGapRecord ()
  let _ = emitPreamble e
  let _ = emitFnsGaps e (fnBinds groups)
  let _ = emitImplsGaps e implEntries
  let _ = emitTopBindsGaps e [] (valBinds groups)
  gapEvents ()

emitFnsGaps : Emit -> List CBind -> Unit
emitFnsGaps _ [] = ()
emitFnsGaps e ((CBind name cs)::rest) =
  let _ = setGapBind ("fn " ++ name)
  let _ = emitFn e (CBind name cs)
  emitFnsGaps e rest

emitImplsGaps : Emit -> List CImplEntry -> Unit
emitImplsGaps e entries = emitGroupsGaps e (groupImpls entries)

emitGroupsGaps : Emit -> List ImplGroup -> Unit
emitGroupsGaps _ [] = ()
emitGroupsGaps e (g::rest) =
  let _ = setGapBind "impl \{groupMethodOf g}@\{groupTag g}"
  let _ = emitGroup e g
  emitGroupsGaps e rest

emitTopBindsGaps : Emit -> List (String, (String, LTy)) -> List CBind -> Unit
emitTopBindsGaps _ _ [] = ()
emitTopBindsGaps e env ((CBind name [CClause [] body])::rest) =
  let _ = setGapBind ("val " ++ name)
  let (v, ty) = emitExpr e env body
  emitTopBindsGaps e ((name, (v, ty))::env) rest
emitTopBindsGaps e env ((CBind name _)::rest) =
  let _ = setGapBind ("val " ++ name)
  let _ = gapU "non-nullary / multi-clause value binding (slice 1)"
  emitTopBindsGaps e env rest
