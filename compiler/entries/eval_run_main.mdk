-- Run a program for its OUTPUT through the self-hosted eval:
--
--   medaka run compiler/entries/eval_run_main.mdk <prelude.mdk>... <source.mdk>
--
-- prepends the prelude file(s) (core.mdk [list.mdk …]), evaluates the program,
-- and prints the captured stdout (putStr/putStrLn output) — diffs against the
-- === EVAL === goldens.  This is the "true execution" path (vs eval_main, which
-- renders pp_value of `main`): the program actually runs its IO.

import eval.eval.{evalOutputWith}
import frontend.ast.{Decl}
import entries.entry_support.{drivePrelude}

main = drivePrelude emit

emit : List Decl -> List Decl -> <IO, Mut> Unit
emit preludeDecls userDecls = putStr (evalOutputWith preludeDecls userDecls)
