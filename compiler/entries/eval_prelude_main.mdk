-- Prelude-loading entry point for the self-hosted eval stage (slice 4b):
--
--   medaka run compiler/entries/eval_prelude_main.mdk <prelude.mdk>... <source.mdk>
--
-- parses + desugars each prelude file (core.mdk, and optionally list.mdk, …) and
-- the target, prepends all the prelude decls (in order), evaluates the whole
-- thing, and prints pp_value of `main`.  Diffs against `dev/eval_probe.exe
-- --prepend <prelude.mdk>... <source.mdk>`.  The prelude has no embedded copy in
-- the self-host, so its paths are passed in (like the marker/resolve stages).

import frontend.ast.{Decl}
import frontend.parser.{parse}
import frontend.desugar.{desugar}
import support.util.{splitLast}
import eval.eval.{evalMain}

main = match splitLast (args ())
  Some (preludePaths, targetPath) => withPreludes preludePaths targetPath
  None => ePutStrLn "usage: medaka run compiler/entries/eval_prelude_main.mdk <prelude.mdk>... <file.mdk>"

-- split a non-empty list into (init, last)

withPreludes : List String -> String -> <IO, Mut> Unit
withPreludes preludePaths targetPath = match readAllDecls preludePaths
  Ok preludeDecls => withTarget preludeDecls targetPath
  Err msg => ePutStrLn msg

withTarget : List Decl -> String -> <IO, Mut> Unit
withTarget preludeDecls targetPath = match readFile targetPath
  Ok targetSrc => putStrLn (evalMain (preludeDecls ++ desugar (parse targetSrc)))
  Err msg => ePutStrLn msg

-- parse + desugar each prelude file in order, concatenating their decls
readAllDecls : List String -> <IO> Result String (List Decl)
readAllDecls [] = Ok []
readAllDecls (p::rest) = match readFile p
  Err msg => Err msg
  Ok src => match readAllDecls rest
    Err msg => Err msg
    Ok more => Ok (desugar (parse src) ++ more)
