-- Prelude-loading entry point for the self-hosted eval stage (slice 4b):
--
--   medaka run compiler/entries/eval_prelude_main.mdk <prelude.mdk>... <source.mdk>
--
-- parses + desugars each prelude file (core.mdk, and optionally list.mdk, …) and
-- the target, prepends all the prelude decls (in order), evaluates the whole
-- thing, and prints pp_value of `main`.  Diffs against `dev/eval_probe.exe
-- --prepend <prelude.mdk>... <source.mdk>`.  The prelude has no embedded copy in
-- the self-host, so its paths are passed in (like the marker/resolve stages).

import eval.eval.{evalMain}
import frontend.ast.{Decl}
import entries.entry_support.{drivePrelude}

main = drivePrelude emit

emit : List Decl -> List Decl -> <IO, Mut> Unit
emit preludeDecls userDecls = putStrLn (evalMain (preludeDecls ++ userDecls))
