-- Batched variant of eval_prelude_main.mdk with core.mdk + list.mdk — prelude caching.
--   medaka run compiler/entries/eval_list_batch.mdk <core.mdk> <list.mdk> <file.mdk>...
-- Parses + desugars core.mdk + list.mdk ONCE, evaluates pp_value of each target's
-- `main`.  Strict per-target IO loop (see eval_prelude_batch.mdk for why).

import frontend.ast.{Decl}
import eval.eval.{evalMain}
import entries.entry_support.{driveRuntimeBatch}

main = driveRuntimeBatch "===SELFHOST-FIX=== " render

render : List Decl -> List Decl -> List Decl -> <Mut> String
render coreDecls listDecls targetDecls =
  evalMain (coreDecls ++ listDecls ++ targetDecls)
