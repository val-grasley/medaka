-- TYPED execution path: type-check (resolving return-position method dispatch),
-- then evaluate.
--
--   medaka run compiler/entries/eval_typed_main.mdk <runtime.mdk> <prelude.mdk>... <source.mdk>
--
-- The single shared tree is: desugar → elaborate (pre-pass + typecheck stamps the
-- EMethodAt tags) → eval (narrows return-position methods by those tags).  This is
-- what makes `pure`/`empty`/… dispatch by the concrete return type (RKey) instead
-- of the untyped arg-tag fallback — e.g. a user Applicative's `pure`.

import frontend.ast.{Decl}
import frontend.parser.{parse}
import frontend.desugar.{desugar}
import types.typecheck.{elaborateOne}
import support.util.{splitLast}
import eval.eval.{evalOneOutput, funNamesOf, dropShadowedExp}

main = match args ()
  runtimePath::rest => withRuntime runtimePath rest
  _ => ePutStrLn "usage: medaka run compiler/entries/eval_typed_main.mdk <runtime.mdk> <prelude.mdk>... <file.mdk>"

withRuntime runtimePath rest = match splitLast rest
  Some (preludePaths, targetPath) => withFiles runtimePath preludePaths targetPath
  None => ePutStrLn "usage: <runtime.mdk> <prelude.mdk>... <file.mdk>"

withFiles runtimePath preludePaths targetPath = match readFile runtimePath
  Ok rsrc => withPreludes rsrc preludePaths targetPath
  Err msg => ePutStrLn msg

withPreludes rsrc preludePaths targetPath = match readAllDecls preludePaths
  Ok preludeDecls => withTarget rsrc preludeDecls targetPath
  Err msg => ePutStrLn msg

withTarget rsrc preludeDecls targetPath = match readFile targetPath
  Ok tsrc => putStr (runTyped (desugar (parse rsrc)) preludeDecls (desugar (parse tsrc)))
  Err msg => ePutStrLn msg

runTyped : List Decl -> List Decl -> List Decl -> <Mut> String
runTyped runtimeDecls preludeDecls userDecls =
  let livePrelude = dropShadowedExp (funNamesOf userDecls) preludeDecls
  evalOneOutput
    []
    ("__main__", elaborateOne runtimeDecls livePrelude ("__user__", userDecls))

readAllDecls : List String -> <IO> Result String (List Decl)
readAllDecls [] = Ok []
readAllDecls (p::rest) = match readFile p
  Err msg => Err msg
  Ok src => match readAllDecls rest
    Err msg => Err msg
    Ok more => Ok (desugar (parse src) ++ more)
