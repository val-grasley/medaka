-- Batched variant of eval_typed_main.mdk — prelude caching.
--   medaka run compiler/entries/eval_typed_batch.mdk <runtime.mdk> <core.mdk> <file.mdk>...
-- Parses + desugars runtime.mdk + core.mdk ONCE, type-elaborates + evals each
-- target.  Strict per-target IO loop (see eval_prelude_batch.mdk for why).

import frontend.ast.{Decl}
import frontend.parser.{parse}
import frontend.desugar.{desugar}
import types.typecheck.{elaborateOne}
import eval.eval.{evalOneOutput, funNamesOf, dropShadowedExp}

main = match args ()
  runtimePath::corePath::targets => withFiles runtimePath corePath targets
  _ => ePutStrLn "usage: medaka run compiler/entries/eval_typed_batch.mdk <runtime.mdk> <core.mdk> <file.mdk>..."

withFiles runtimePath corePath targets = match readFile runtimePath
  Err msg => ePutStrLn msg
  Ok rsrc => match readFile corePath
    Err msg => ePutStrLn msg
    Ok csrc => emitAll (desugar (parse rsrc)) (desugar (parse csrc)) targets

emitAll : List Decl -> List Decl -> List String -> <IO, Mut> Unit
emitAll runtimeDecls preludeDecls [] = putStr ""
emitAll runtimeDecls preludeDecls (path::rest) = match readFile path
  Err msg =>
    let _ = ePutStrLn msg
    emitAll runtimeDecls preludeDecls rest
  Ok src =>
    let _ = putStr ("===SELFHOST-FIX=== " ++ path ++ "\n" ++ runTyped runtimeDecls preludeDecls (desugar (parse src)) ++ "\n")
    emitAll runtimeDecls preludeDecls rest

runTyped : List Decl -> List Decl -> List Decl -> <Mut> String
runTyped runtimeDecls preludeDecls userDecls =
  let livePrelude = dropShadowedExp (funNamesOf userDecls) preludeDecls
  evalOneOutput
    []
    ("__main__", elaborateOne runtimeDecls livePrelude ("__user__", userDecls))
